Dialogue: 0,0:01:58.11,0:01:59.91,tanda,,0000,0000,0000,,TO YOUR ETERNITY\NSEASON 3
Dialogue: 0,0:01:59.99,0:02:03.99,tanda,,0000,0000,0000,,#20 HIDUP BERDAMPINGAN
Dialogue: 0,0:11:32.60,0:11:35.02,tanda,,0000,0000,0000,,TO YOUR ETERNITY\NSEASON 3
Dialogue: 0,0:24:29.97,0:24:31.93,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:24:51.99,0:24:54.99,tanda,,0000,0000,0000,,#21 SAMA SEPERTI INI, TEPAT DI SINI
Dialogue: 0,0:00:01.91,0:00:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mizuha tidak kidal.
Dialogue: 0,0:00:08.21,0:00:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi bertarung satu lawan satu\Ndengan Nokker Mizuha.
Dialogue: 0,0:00:14.26,0:00:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertempuran kita di masa kini\Nsudah berakhir.
Dialogue: 0,0:00:18.68,0:00:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari makan bersama!
Dialogue: 0,0:00:23.14,0:00:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah melakukan yang terbaik.
Dialogue: 0,0:00:26.06,0:00:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi membawa Mizuha kembali.
Dialogue: 0,0:02:09.83,0:02:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hot pot ini lezat!
Dialogue: 0,0:02:12.50,0:02:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bumbunya? Ajari aku.
Dialogue: 0,0:02:15.15,0:02:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutanyakan pada Kakek.
Dialogue: 0,0:02:22.30,0:02:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha… Silakan.
Dialogue: 0,0:02:25.89,0:02:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah. Kau pasti lapar.
Dialogue: 0,0:02:28.94,0:02:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:02:32.98,0:02:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memberi tahu sekolah\NMizuha bisa kembali besok.
Dialogue: 0,0:02:38.45,0:02:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:02:41.53,0:02:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Silakan.\N- Dia meminum air
Dialogue: 0,0:02:43.24,0:02:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang berisi Nokker tanpa ragu.
Dialogue: 0,0:02:46.83,0:02:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, kemarilah.
Dialogue: 0,0:02:48.04,0:02:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, ada apa?
Dialogue: 0,0:02:49.67,0:02:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satoru, kau juga.
Dialogue: 0,0:02:55.38,0:02:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu Yuki mengeluarkan Nokker\Nyang diminumnya.
Dialogue: 0,0:03:00.59,0:03:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau!
Dialogue: 0,0:03:02.09,0:03:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:03:03.01,0:03:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku ingin begitu.
Dialogue: 0,0:03:04.68,0:03:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi itu berbahaya.
Dialogue: 0,0:03:06.85,0:03:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nokker mungkin akan memanipulasimu.
Dialogue: 0,0:03:09.39,0:03:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan bisa membunuhmu.
Dialogue: 0,0:03:11.23,0:03:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawamu akan terancam.
Dialogue: 0,0:03:12.23,0:03:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:03:13.15,0:03:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa?
Dialogue: 0,0:03:14.69,0:03:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup berdampingan.
Dialogue: 0,0:03:16.86,0:03:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dikeluarkan dari tubuhmu,\Nbukankah masih bisa hidup berdampingan?
Dialogue: 0,0:03:20.24,0:03:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha dikendalikan oleh Nokker.
Dialogue: 0,0:03:22.36,0:03:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga melihatnya, kan?
Dialogue: 0,0:03:23.91,0:03:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika kelak itu terjadi?
Dialogue: 0,0:03:26.16,0:03:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan.
Dialogue: 0,0:03:27.74,0:03:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tidak apa-apa seperti ini.
Dialogue: 0,0:03:29.54,0:03:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun…
Dialogue: 0,0:03:30.58,0:03:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sendiri yang menginginkannya,\Njadi aku tak bisa memaksa.
Dialogue: 0,0:03:35.71,0:03:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah adanya.
Dialogue: 0,0:03:37.13,0:03:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki.
Dialogue: 0,0:03:38.30,0:03:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan pulang.
Dialogue: 0,0:03:39.80,0:03:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:03:41.22,0:03:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencemaskan Yuki,\Njadi aku akan kembali besok.
Dialogue: 0,0:03:50.39,0:03:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:03:51.64,0:03:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semalam, seusai itu, kuberikan\Nalbum foto tersebut kepada Kak Mizuha.
Dialogue: 0,0:03:56.32,0:03:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:03:57.52,0:04:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tersenyum padaku\Ndan berucap, "Terima kasih."
Dialogue: 0,0:04:00.74,0:04:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itulah kau menyentuh tangan Mizuha.
Dialogue: 0,0:04:02.65,0:04:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:04:03.57,0:04:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kau langsung menyatakan perasaanmu?
Dialogue: 0,0:04:07.12,0:04:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:04:08.79,0:04:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa, masih ada kesempatan.
Dialogue: 0,0:04:11.33,0:04:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:13.58,0:04:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan apa?
Dialogue: 0,0:04:15.17,0:04:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini…
Dialogue: 0,0:04:18.83,0:04:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan untuk memberimu\Nhadiah ulang tahun
Dialogue: 0,0:04:22.26,0:04:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemarin.
Dialogue: 0,0:04:24.59,0:04:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untukku?
Dialogue: 0,0:04:27.14,0:04:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua, kau licik. Kau mencuri start!
Dialogue: 0,0:04:32.85,0:04:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub Riset Hal Gaib telah tiba.
Dialogue: 0,0:04:34.31,0:04:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami perlu bicara dengan kalian.
Dialogue: 0,0:04:36.44,0:04:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang saat didekati gadis.
Dialogue: 0,0:04:38.15,0:04:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kita dalam keadaan darurat.
Dialogue: 0,0:04:40.23,0:04:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:41.69,0:04:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dicurigai sebagai pelaku\Nkeributan kemarin.
Dialogue: 0,0:04:45.74,0:04:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,
Dialogue: 0,0:04:47.24,0:04:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rekaman kamera pengawas dihapus.
Dialogue: 0,0:04:49.91,0:04:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi mencurigai kalian semua\Nberbuat iseng.
Dialogue: 0,0:04:53.79,0:04:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian akan segera diinterogasi.
Dialogue: 0,0:04:56.71,0:04:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak bisa menjelaskannya,
Dialogue: 0,0:04:58.38,0:05:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian mungkin dikeluarkan dari sekolah.
Dialogue: 0,0:05:02.21,0:05:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan ditangkap?
Dialogue: 0,0:05:03.47,0:05:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mencegah hal itu,
Dialogue: 0,0:05:04.63,0:05:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami mau ke restoran keluarga\Nuntuk rapat strategi.
Dialogue: 0,0:05:06.84,0:05:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak ke sekolah hari itu, kan?
Dialogue: 0,0:05:09.10,0:05:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu kami mengatasinya.
Dialogue: 0,0:05:11.10,0:05:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha, kau juga!
Dialogue: 0,0:05:12.43,0:05:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nokker punya hubungan denganmu, kan?
Dialogue: 0,0:05:15.06,0:05:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku punya jam malam…
Dialogue: 0,0:05:16.94,0:05:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika Fushi ditangkap?\NApa itu tak masalah?
Dialogue: 0,0:05:18.94,0:05:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:05:20.90,0:05:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Restoran keluarga? Kalau begitu…
Dialogue: 0,0:05:22.90,0:05:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau memesan parfe mangga musiman!
Dialogue: 0,0:05:24.36,0:05:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paket steik!
Dialogue: 0,0:05:25.49,0:05:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita sepakat.
Dialogue: 0,0:05:27.11,0:05:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Payah!\N- Kalian keterlaluan.
Dialogue: 0,0:05:28.66,0:05:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memesan piza.
Dialogue: 0,0:05:30.33,0:05:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:05:32.20,0:05:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga harus mengundang Bon.
Dialogue: 0,0:05:34.29,0:05:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga Satoru.
Dialogue: 0,0:05:36.04,0:05:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laporan lanjutan insiden kebakaran\Ndan hipnosis massal
Dialogue: 0,0:05:39.50,0:05:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di SMP Minamoto kemarin.
Dialogue: 0,0:05:42.05,0:05:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama insiden itu,
Dialogue: 0,0:05:44.80,0:05:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seluruh rekaman kamera pengawas\Ndi sekolah telah dihapus.
Dialogue: 0,0:05:49.55,0:05:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut polisi,
Dialogue: 0,0:05:50.51,0:05:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tampaknya ini tindakan terencana.
Dialogue: 0,0:05:54.35,0:05:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, itu menakutkan.
Dialogue: 0,0:05:56.44,0:05:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pelakunya?
Dialogue: 0,0:05:59.31,0:06:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu kau?
Dialogue: 0,0:06:01.02,0:06:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekaman yang paling penting telah hilang.
Dialogue: 0,0:06:03.19,0:06:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan mencegah situasi\Nmenjadi tak terkendali.
Dialogue: 0,0:06:05.40,0:06:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, menghapus rekamannya saja\Nbelum cukup.
Dialogue: 0,0:06:08.91,0:06:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi sepertinya akan menelusuri ini\Nhingga pelaku tertangkap.
Dialogue: 0,0:06:12.45,0:06:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:06:13.49,0:06:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah lebih cepat menghapus\Ningatan semua orang di sekolah?
Dialogue: 0,0:06:16.91,0:06:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu mungkin?
Dialogue: 0,0:06:18.79,0:06:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya kita tak bisa bergerak\Nsama sekali, bukan?
Dialogue: 0,0:06:22.09,0:06:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah rasanya.
Dialogue: 0,0:06:23.09,0:06:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melakukannya, tapi tidak mau.
Dialogue: 0,0:06:25.05,0:06:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengganggu ingatan seseorang
Dialogue: 0,0:06:26.84,0:06:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan melukainya.
Dialogue: 0,0:06:28.80,0:06:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama saja dengan membunuhnya.
Dialogue: 0,0:06:32.76,0:06:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, diriku yang lama
Dialogue: 0,0:06:34.43,0:06:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin akan melakukannya.
Dialogue: 0,0:06:36.43,0:06:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia benar-benar Sosok Hitam?
Dialogue: 0,0:06:39.23,0:06:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:40.40,0:06:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satoru.
Dialogue: 0,0:06:42.31,0:06:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pulang.
Dialogue: 0,0:06:47.86,0:06:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana kau rupanya. Satoru!
Dialogue: 0,0:06:50.16,0:06:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kami ingin bicara soal kemarin.\N- Kakek, aku pergi dulu
Dialogue: 0,0:06:52.37,0:06:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau ada waktu?\N- bersama yang lain.
Dialogue: 0,0:06:53.83,0:06:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka teman-temanmu?
Dialogue: 0,0:06:55.58,0:06:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi kami harus pulang.
Dialogue: 0,0:06:58.71,0:07:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ada rapat strategi mengenai Nokker.
Dialogue: 0,0:07:02.08,0:07:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nokker? Apa itu?
Dialogue: 0,0:07:04.25,0:07:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir, itu bukan apa-apa.
Dialogue: 0,0:07:07.59,0:07:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, waktunya rapat strategi.
Dialogue: 0,0:07:11.09,0:07:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Bon menyuruhku menjemput kalian.
Dialogue: 0,0:07:13.80,0:07:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan naik.
Dialogue: 0,0:07:14.72,0:07:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo.
Dialogue: 0,0:07:16.89,0:07:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek, aku mau ke restoran keluarga.
Dialogue: 0,0:07:18.89,0:07:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek tak perlu menyiapkan\Nmakan malam untuk kami.
Dialogue: 0,0:07:25.82,0:07:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan mereka?
Dialogue: 0,0:07:29.70,0:07:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama operasinya:
Dialogue: 0,0:07:31.15,0:07:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tidak Boleh Tertangkap".
Dialogue: 0,0:07:33.24,0:07:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terang-terangan sekali.
Dialogue: 0,0:07:34.37,0:07:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai rapat strateginya!
Dialogue: 0,0:07:40.96,0:07:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kita harus menyelaraskan\Npernyataan semua orang.
Dialogue: 0,0:07:44.63,0:07:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku sudah menyiapkan naskah.
Dialogue: 0,0:07:47.55,0:07:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kau menyiapkan ini?
Dialogue: 0,0:07:49.30,0:07:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dimulai.
Dialogue: 0,0:07:50.34,0:07:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, kau terlambat.
Dialogue: 0,0:07:51.84,0:07:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Pak Bon.
Dialogue: 0,0:07:53.09,0:07:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah mulai makan!
Dialogue: 0,0:08:10.19,0:08:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:08:12.15,0:08:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, selamat datang.
Dialogue: 0,0:08:13.86,0:08:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana sekolahmu?
Dialogue: 0,0:08:15.41,0:08:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku banyak mengobrol dengan teman-teman.
Dialogue: 0,0:08:17.95,0:08:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisi Kakek?
Dialogue: 0,0:08:19.41,0:08:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu menjenguknya di rumah sakit, kan?
Dialogue: 0,0:08:22.12,0:08:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, tak mengenai organ vitalnya.
Dialogue: 0,0:08:24.54,0:08:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mendapat penanganan tepat waktu.
Dialogue: 0,0:08:27.09,0:08:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Syukurlah.
Dialogue: 0,0:08:29.51,0:08:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu sudah memaafkannya?
Dialogue: 0,0:08:31.47,0:08:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum.
Dialogue: 0,0:08:32.84,0:08:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, entah butuh berapa lama.
Dialogue: 0,0:08:35.54,0:08:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu akan berusaha memaafkannya.
Dialogue: 0,0:08:37.64,0:08:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memajang foto yang kau terima.
Dialogue: 0,0:08:40.52,0:08:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujadikan dekorasi.
Dialogue: 0,0:08:42.30,0:08:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai bukti cinta.
Dialogue: 0,0:08:45.06,0:08:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, Ayah, lihat!
Dialogue: 0,0:08:47.56,0:08:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulannya besar sekali hari ini.
Dialogue: 0,0:08:51.07,0:08:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:08:54.49,0:08:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Mizuha?
Dialogue: 0,0:08:55.91,0:08:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaanmu?
Dialogue: 0,0:08:58.08,0:09:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja. Seperti biasa.
Dialogue: 0,0:09:00.70,0:09:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau begitu.
Dialogue: 0,0:09:10.75,0:09:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Tak ada yang aneh\Ndi jalanan pagi ini.
Dialogue: 0,0:09:13.34,0:09:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wakil Ketua!
Dialogue: 0,0:09:14.72,0:09:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Draf Buletin Bulanan\NKlub Riset Hal Gaib sudah siap.
Dialogue: 0,0:09:17.76,0:09:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih! Cepat sekali.
Dialogue: 0,0:09:19.81,0:09:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tak masalah menulis semua ini?
Dialogue: 0,0:09:22.35,0:09:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:09:23.27,0:09:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, tentang pelakunya.
Dialogue: 0,0:09:25.89,0:09:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya pelaku penggemar berat Fushi.
Dialogue: 0,0:09:28.40,0:09:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyamar menjadi Fushi,\Npadahal Fushi absen hari itu.
Dialogue: 0,0:09:31.65,0:09:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kesal, dia meracuni tangki air.
Dialogue: 0,0:09:34.40,0:09:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau tahu?
Dialogue: 0,0:09:35.61,0:09:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelakunya sendiri yang memberitahuku\Nsetelah semua orang tertidur.
Dialogue: 0,0:09:38.87,0:09:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu motifnya?
Dialogue: 0,0:09:39.95,0:09:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dia mendendam pada sekolah.
Dialogue: 0,0:09:41.99,0:09:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Tonari memanahnya?
Dialogue: 0,0:09:43.66,0:09:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelakunya sangat kejam.
Dialogue: 0,0:09:45.16,0:09:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memakai rompi antipeluru\Nagar tidak terbunuh.
Dialogue: 0,0:09:47.88,0:09:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami bakar dan meledakkan bomnya.
Dialogue: 0,0:09:50.09,0:09:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mencoba berkali-kali,\Nakhirnya kami berhasil membunuhnya.
Dialogue: 0,0:09:51.88,0:09:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami takkan menyesal.
Dialogue: 0,0:09:52.80,0:09:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:09:54.01,0:09:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sejak awal kalian mencoba\Nmembunuh pelakunya?
Dialogue: 0,0:09:56.01,0:09:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kami pikir\Ndia telah membunuh semua orang!
Dialogue: 0,0:09:58.80,0:09:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin membalas dendam!
Dialogue: 0,0:09:59.72,0:10:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:10:00.85,0:10:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila tak salah ingat,\NTonari sudah menarik busurnya
Dialogue: 0,0:10:04.64,0:10:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum semua orang pingsan.
Dialogue: 0,0:10:07.19,0:10:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kami menerima surat peringatan!
Dialogue: 0,0:10:08.85,0:10:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelakunya adalah berandal yang populer\Ndi kalangan penggemar Fushi.
Dialogue: 0,0:10:11.77,0:10:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebab itu Aoki dan aku melindunginya\Ndi rumahku pada hari tersebut.
Dialogue: 0,0:10:16.65,0:10:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:10:17.74,0:10:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dari mana busur itu didapat?
Dialogue: 0,0:10:19.49,0:10:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meminjamnya dari Klub Panahan.
Dialogue: 0,0:10:21.12,0:10:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak mirip busur dari Klub Panahan.
Dialogue: 0,0:10:23.62,0:10:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu koleksi milik anggotanya.
Dialogue: 0,0:10:25.66,0:10:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa orang itu kemari.
Dialogue: 0,0:10:27.46,0:10:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seorang alumni.
Dialogue: 0,0:10:29.08,0:10:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa dia kemari.
Dialogue: 0,0:10:31.08,0:10:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku alumni sekolah ini.
Dialogue: 0,0:10:32.84,0:10:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau petugas kebersihan, bukan?
Dialogue: 0,0:10:34.46,0:10:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan masuk TV kemarin!
Dialogue: 0,0:10:36.47,0:10:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gayamu bicara seolah kau tak terlibat.
Dialogue: 0,0:10:37.67,0:10:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun kau sangat terlibat\Ndalam insiden ini, bukan?
Dialogue: 0,0:10:39.30,0:10:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:40.51,0:10:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Bonchien Nicoli La Tasty Peach Uralis.
Dialogue: 0,0:10:43.85,0:10:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tanda tanganku.
Dialogue: 0,0:10:47.52,0:10:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bapak.
Dialogue: 0,0:10:49.35,0:10:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Anda sudah dewasa. Tidak malu?\N- Aduh!
Dialogue: 0,0:10:51.31,0:10:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa yang Anda lakukan\N- Aduh!
Dialogue: 0,0:10:52.65,0:10:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dengan mencuci otak anak-anak ini?\N- Aduh!
Dialogue: 0,0:10:54.19,0:10:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telingaku yang berharga!
Dialogue: 0,0:10:55.82,0:10:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu, itu salah paham.
Dialogue: 0,0:10:56.94,0:10:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bu Guru, sudah cukup.\N- Anda menarik telingaku!
Dialogue: 0,0:10:58.49,0:10:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aoki!\N- Aduh!
Dialogue: 0,0:10:59.70,0:11:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Akan kukatakan kebenarannya.\N- Sakit…
Dialogue: 0,0:11:01.24,0:11:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejadian di sekolah hari itu
Dialogue: 0,0:11:03.28,0:11:04.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tertulis di sini.
Dialogue: 0,0:11:04.58,0:11:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki…
Dialogue: 0,0:11:06.45,0:11:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kulihat.
Dialogue: 0,0:11:07.70,0:11:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pelakunya Nokker, makhluk asing\Nyang jumlahnya tak terhitung."
Dialogue: 0,0:11:11.67,0:11:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aoki, ini…
Dialogue: 0,0:11:13.63,0:11:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh!\N- Aku tak punya waktu meladeni hobimu!
Dialogue: 0,0:11:17.34,0:11:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita tak menerima mereka,
Dialogue: 0,0:11:18.97,0:11:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka akan jadi makhluk asing selamanya,\Nsampai kapan pun itu.
Dialogue: 0,0:11:22.80,0:11:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Anda bersedia menjadi penasihat\NKlub Riset Hal Gaib?
Dialogue: 0,0:11:26.06,0:11:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini langkah awal guna saling memahami\Ndengan makhluk asing!
Dialogue: 0,0:11:30.39,0:11:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki…
Dialogue: 0,0:11:36.15,0:11:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah sepekan sejak Mizuha kembali.
Dialogue: 0,0:11:38.57,0:11:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Bon dan Yayasan,\Nsemua terhindar dari penangkapan.
Dialogue: 0,0:11:41.99,0:11:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:11:43.41,0:11:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski pemimpin Nokker sudah tiada,
Dialogue: 0,0:11:45.45,0:11:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa masih ada Nokker lain di dunia ini?
Dialogue: 0,0:11:48.50,0:11:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dengan mengamati\Npejalan kaki di sekitar kita,
Dialogue: 0,0:11:51.17,0:11:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}populasi Nokker telah menurun\Nhingga di bawah sepuluh persen.
Dialogue: 0,0:11:53.00,0:11:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang akan berhenti menyerang,
Dialogue: 0,0:11:55.50,0:11:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak ada yang tahu apakah Nokker jahat
Dialogue: 0,0:11:56.75,0:11:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maaf.\N- akan muncul kembali.
Dialogue: 0,0:12:00.30,0:12:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia pun sama.
Dialogue: 0,0:12:04.43,0:12:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang yang membunuh sesamanya,
Dialogue: 0,0:12:04.55,0:12:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi mayoritas tidak.
Dialogue: 0,0:12:06.89,0:12:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti itulah cara kita memandangnya.
Dialogue: 0,0:12:09.02,0:12:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiada habisnya jika terus berpikiran buruk.
Dialogue: 0,0:12:11.85,0:12:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar, Yuki.
Dialogue: 0,0:12:13.44,0:12:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sependapat denganmu.
Dialogue: 0,0:12:18.40,0:12:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik di TV maupun di majalah,
Dialogue: 0,0:12:20.86,0:12:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin dunia lebih memahami Nokker.
Dialogue: 0,0:12:22.91,0:12:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus menyampaikan\Nnilai positif Nokker.
Dialogue: 0,0:12:25.74,0:12:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin masyarakat akan menerima,
Dialogue: 0,0:12:27.41,0:12:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Nokker pun akan membuka hati.
Dialogue: 0,0:12:30.41,0:12:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau setuju membiarkan Nokker\Nmengendalikan tubuh manusia?
Dialogue: 0,0:12:36.29,0:12:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa terlalu dini\Nuntuk menyimpulkan begitu.
Dialogue: 0,0:12:39.09,0:12:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari awali dengan saling memahami.
Dialogue: 0,0:12:40.30,0:12:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku di sini!
Dialogue: 0,0:12:43.13,0:12:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hirotoshi?
Dialogue: 0,0:12:45.09,0:12:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru saja pindah.
Dialogue: 0,0:12:46.64,0:12:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku hidup mandiri.
Dialogue: 0,0:12:49.35,0:12:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit membicarakan Nokker di luar, kan?
Dialogue: 0,0:12:52.27,0:12:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku meminjam kamar Hirotoshi.
Dialogue: 0,0:12:54.31,0:12:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimori.
Dialogue: 0,0:12:57.81,0:12:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:12:58.77,0:13:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adiknya Sumika…
Dialogue: 0,0:13:00.90,0:13:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Michi, Nokker yang telah menyatu.
Dialogue: 0,0:13:02.65,0:13:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang memintanya datang.
Dialogue: 0,0:13:04.66,0:13:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau menjadi musuh kalian.
Dialogue: 0,0:13:07.07,0:13:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebab itu aku ingin saling memahami.
Dialogue: 0,0:13:08.58,0:13:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa ceritakan semuanya dari awal?
Dialogue: 0,0:13:10.70,0:13:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:13:19.50,0:13:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:13:21.13,0:13:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi berniat hidup sebagai manusia.
Dialogue: 0,0:13:23.76,0:13:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak masalah.
Dialogue: 0,0:13:24.97,0:13:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bicara.
Dialogue: 0,0:13:27.76,0:13:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya,
Dialogue: 0,0:13:29.39,0:13:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua bilang ada orang jahat,\Njadi kami pergi untuk membasmi mereka.
Dialogue: 0,0:13:33.56,0:13:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku tidak paham alasannya,\Ntapi aku lekas mengerti.
Dialogue: 0,0:13:37.23,0:13:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebab orang jahat menangkap rekan kami\Ndan mengurungnya di dalam boneka.
Dialogue: 0,0:13:41.78,0:13:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan kami mengingat pedih dan lara,\Nlalu kembali satu per satu.
Dialogue: 0,0:13:46.70,0:13:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah aku harus\Nmenyelamatkan mereka.
Dialogue: 0,0:13:49.20,0:13:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku pun turun ke darat.
Dialogue: 0,0:13:51.41,0:13:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menuju tempat bernama Renril.
Dialogue: 0,0:13:54.00,0:13:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku lekas dikalahkan.
Dialogue: 0,0:13:57.33,0:13:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku kembali ke atas,
Dialogue: 0,0:13:58.79,0:14:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya menyuruhku berubah\Nlebih kecil agar tak kalah lagi.
Dialogue: 0,0:14:03.05,0:14:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu…
Dialogue: 0,0:14:03.96,0:14:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang kau maksud dengan "semuanya"?
Dialogue: 0,0:14:05.88,0:14:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya ya semuanya, makhluk sepertiku.
Dialogue: 0,0:14:08.80,0:14:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, hanya ada satu dari kami\Nyang paling memahami manusia.
Dialogue: 0,0:14:12.85,0:14:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebab itu semuanya patuh kepadanya.
Dialogue: 0,0:14:14.98,0:14:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu Nokker dari Pasukan Pelindung?
Dialogue: 0,0:14:17.81,0:14:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:14:19.19,0:14:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang demi hidup berdampingan.
Dialogue: 0,0:14:22.40,0:14:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka semua berusaha hidup\Nsesuai standar keadilan manusia.
Dialogue: 0,0:14:25.82,0:14:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, dia tak bilang apa pun soal\Napa yang terjadi usai berdampingan?
Dialogue: 0,0:14:29.41,0:14:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya membuat kami percaya kalian\Ntak berbahaya agar kami lengah?
Dialogue: 0,0:14:31.24,0:14:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, tenanglah dahulu.
Dialogue: 0,0:14:33.54,0:14:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tinggal di dalam tubuh manusia.
Dialogue: 0,0:14:35.79,0:14:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus terus melakukannya.
Dialogue: 0,0:14:38.46,0:14:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mengenai hal setelah itu,
Dialogue: 0,0:14:39.96,0:14:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku belum mendengar apa pun.
Dialogue: 0,0:14:42.04,0:14:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang
Dialogue: 0,0:14:43.30,0:14:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian akan mengganti seluruh\Nmakhluk hidup di dunia dengan Nokker.
Dialogue: 0,0:14:46.26,0:14:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu akan membuat\Ntujuan kalian tercapai?
Dialogue: 0,0:14:48.84,0:14:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:14:50.30,0:14:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Fushi sudah bangkit.
Dialogue: 0,0:14:52.05,0:14:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi mampu membangkitkan orang mati.
Dialogue: 0,0:14:54.10,0:14:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nokker di dalam diri Mimori\Nsempat berusaha membunuh Fushi,
Dialogue: 0,0:14:57.35,0:14:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi gagal.
Dialogue: 0,0:14:58.98,0:15:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,\Ndia mencoba membunuh Sosok Hitam,
Dialogue: 0,0:15:01.98,0:15:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi gagal juga.
Dialogue: 0,0:15:04.27,0:15:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemimpinnya, Nokker Mizuha, telah pergi.
Dialogue: 0,0:15:07.24,0:15:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:15:08.36,0:15:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nokker di tubuh ayah Mizuha\Nbilang ini belum usai.
Dialogue: 0,0:15:12.74,0:15:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya masih ada yang tersisa.
Dialogue: 0,0:15:15.66,0:15:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebab itu kita harus bersiap dari sekarang.
Dialogue: 0,0:15:18.04,0:15:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mencari tahu\Napa yang patut kulakukan.
Dialogue: 0,0:15:20.75,0:15:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya bisa mencari cara bertahan\Nsaat ditinggalkan di daratan.
Dialogue: 0,0:15:25.09,0:15:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi Michi\Nuntuk Sumika dan Tomori.
Dialogue: 0,0:15:28.80,0:15:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mendambakan hidup damai, kan?
Dialogue: 0,0:15:31.76,0:15:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuan awalmu sudah tak penting?
Dialogue: 0,0:15:34.30,0:15:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun terkejut\Nsaat merasuki tubuh Michi.
Dialogue: 0,0:15:37.27,0:15:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mereka berdua tersenyum padaku,
Dialogue: 0,0:15:39.94,0:15:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perasaan yang belum pernah kualami\Nmenyeruak di hatiku.
Dialogue: 0,0:15:43.86,0:15:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini aku ingin terus\Nmelindungi perasaan ini.
Dialogue: 0,0:15:47.19,0:15:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak peduli\Nmeski harus hidup dengan rasa sakit.
Dialogue: 0,0:15:50.11,0:15:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membantu.
Dialogue: 0,0:15:53.32,0:15:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mempermudah hidup kalian.
Dialogue: 0,0:15:55.66,0:15:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi, kuharap kau mau membantuku.
Dialogue: 0,0:16:04.63,0:16:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat iri pada Yuki.
Dialogue: 0,0:16:06.71,0:16:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tahu apa yang ingin dia lakukan
Dialogue: 0,0:16:08.34,0:16:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan apa yang patut dia jalankan.
Dialogue: 0,0:16:11.09,0:16:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti pemikiran Yuki,
Dialogue: 0,0:16:13.89,0:16:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi jika itu gagal,\Napa ada yang bisa kulakukan?
Dialogue: 0,0:16:17.26,0:16:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu cemas.
Dialogue: 0,0:16:18.64,0:16:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama mereka punya tubuh fisik,
Dialogue: 0,0:16:20.23,0:16:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua Nokker berada\Ndi bawah perlindungan kita.
Dialogue: 0,0:16:24.15,0:16:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:25.81,0:16:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milikilah aku, Fushi.
Dialogue: 0,0:16:28.61,0:16:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memilikimu?
Dialogue: 0,0:16:31.40,0:16:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:16:32.78,0:16:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius.
Dialogue: 0,0:16:34.99,0:16:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku melatihmu.
Dialogue: 0,0:16:37.70,0:16:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar kau menjadi sosok terkuat\Nyang mampu bertahan di dunia ini.
Dialogue: 0,0:16:41.16,0:16:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa maksudmu?
Dialogue: 0,0:16:43.04,0:16:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski harus memilikimu, aku…
Dialogue: 0,0:16:44.96,0:16:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mewariskan\Nseluruh kemampuanku padamu.
Dialogue: 0,0:16:48.46,0:16:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, seluruh dunia,\Ntermasuk Nokker, akan jadi milikmu.
Dialogue: 0,0:16:58.64,0:17:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kekuatan untuk menciptakan\Nsesuatu dari kehampaan.
Dialogue: 0,0:17:02.06,0:17:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pun bisa menciptakan apa saja.
Dialogue: 0,0:17:03.81,0:17:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rancanglah sesukamu dan buat itu hidup.
Dialogue: 0,0:17:06.44,0:17:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun itu makhluk hidup.
Dialogue: 0,0:17:09.81,0:17:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang "ada" sekarang\Npernah menjadi bagian diriku.
Dialogue: 0,0:17:12.95,0:17:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menciptakannya, melepasnya,\Ndan membiarkannya berkembang.
Dialogue: 0,0:17:16.61,0:17:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya adalah milikku.
Dialogue: 0,0:17:18.36,0:17:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mencampuri segalanya.
Dialogue: 0,0:17:20.86,0:17:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia ini,\Nmateri lebih kuat daripada fye.
Dialogue: 0,0:17:23.82,0:17:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun fye berniat menguasai dunia\Nsebagai Nokker,
Dialogue: 0,0:17:27.46,0:17:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama terbungkus oleh daging,\Nmereka takkan bisa menaklukkanku.
Dialogue: 0,0:17:31.38,0:17:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan wewenang ini kepadamu.
Dialogue: 0,0:17:33.84,0:17:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:17:35.55,0:17:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdasarkan pemahamanku,
Dialogue: 0,0:17:36.72,0:17:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makin kecil wujud Nokker,\Nmakin sulit pelacakannya.
Dialogue: 0,0:17:39.68,0:17:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya.\N- Sebab itu kau tak tahu posisi mereka
Dialogue: 0,0:17:41.85,0:17:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum kau mendekat.
Dialogue: 0,0:17:42.98,0:17:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena aku memakai tubuh ini.
Dialogue: 0,0:17:45.02,0:17:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau bilang, "Kita sudah kalah."
Dialogue: 0,0:17:48.31,0:17:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak begitu, pasti tak seru.
Dialogue: 0,0:17:52.40,0:17:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu terdengar aneh?
Dialogue: 0,0:17:54.61,0:17:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya mereka yang memiliki\Nketerikatan dengan dunia ini
Dialogue: 0,0:17:56.74,0:17:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sanggup hidup abadi.
Dialogue: 0,0:18:00.12,0:18:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sejak awal kau diberi kekuatan ini,
Dialogue: 0,0:18:02.29,0:18:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}takkan ada yang datang menolongmu
Dialogue: 0,0:18:04.45,0:18:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kau takkan menyayangi siapa pun.
Dialogue: 0,0:18:07.96,0:18:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menganugerahkan kekuatan ini padamu,
Dialogue: 0,0:18:10.04,0:18:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus memiliki ikatan emosional.
Dialogue: 0,0:18:14.09,0:18:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:18:15.80,0:18:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau enggan melihat\Npara sahabatmu tiada,
Dialogue: 0,0:18:18.39,0:18:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bisa mencegah tubuh mereka\Ndari kerusakan.
Dialogue: 0,0:18:21.01,0:18:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah mempraktikkannya\Npada siapa pun,
Dialogue: 0,0:18:22.89,0:18:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi kau bisa mengujinya sesukamu.
Dialogue: 0,0:18:25.18,0:18:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini sanggup melakukan apa pun.
Dialogue: 0,0:18:26.89,0:18:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kekuatan yang kau sebutkan itu
Dialogue: 0,0:18:28.77,0:18:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghidupkan kembali orang mati?
Dialogue: 0,0:18:32.48,0:18:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin menghidupkan kembali\Nmereka yang sudah ke surga?
Dialogue: 0,0:18:35.65,0:18:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah alam nonmateri.
Dialogue: 0,0:18:37.99,0:18:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa membangkitkan mereka\Njika bertentangan dengan kehendak fye.
Dialogue: 0,0:18:41.07,0:18:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:18:42.24,0:18:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika mau, kau boleh mencobanya.
Dialogue: 0,0:18:52.17,0:18:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tak terlalu dini memberinya informasi\Nterkait segala masalah ini?
Dialogue: 0,0:18:56.01,0:18:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini masih sesuai perkiraanku.
Dialogue: 0,0:18:58.80,0:19:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan memicunya untuk menentang.
Dialogue: 0,0:19:01.51,0:19:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, aku akan menunggumu\Ntiga tahun lagi.
Dialogue: 0,0:19:04.68,0:19:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau bersedia,\Nsaat waktunya tiba, temui aku lagi.
Dialogue: 0,0:19:07.14,0:19:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan menjadi perwujudanku.
Dialogue: 0,0:19:11.86,0:19:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, maaf aku terlambat!
Dialogue: 0,0:19:14.11,0:19:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Nokker-nya?
Dialogue: 0,0:19:15.32,0:19:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gugu.
Dialogue: 0,0:19:16.53,0:19:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah berakhir.
Dialogue: 0,0:19:19.40,0:19:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:19:20.53,0:19:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, jangan mati! Kau belum mati, kan?
Dialogue: 0,0:19:23.87,0:19:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, sebaiknya kau…
Dialogue: 0,0:19:25.24,0:19:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pingsan sejak semalam.
Dialogue: 0,0:19:27.25,0:19:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:19:28.66,0:19:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gugu…
Dialogue: 0,0:19:30.17,0:19:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kau baik-baik saja!
Dialogue: 0,0:19:32.46,0:19:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita bisa mulai berbenah.
Dialogue: 0,0:19:34.09,0:19:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang sering pingsan.
Dialogue: 0,0:19:36.17,0:19:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Tonari.
Dialogue: 0,0:19:38.26,0:19:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan menjadi diriku.
Dialogue: 0,0:19:41.13,0:19:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi Sosok Hitam.
Dialogue: 0,0:19:46.18,0:19:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gugu, tolong aku.
Dialogue: 0,0:19:48.64,0:19:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi.
Dialogue: 0,0:19:50.81,0:19:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.\NKurasa aku mulai mengerti sekarang.
Dialogue: 0,0:19:54.31,0:19:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti mendapat tawaran\Nmenjadi dewa.
Dialogue: 0,0:19:57.15,0:19:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau malah godaan iblis.
Dialogue: 0,0:19:58.24,0:20:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum mengambil keputusan, kan?
Dialogue: 0,0:20:00.49,0:20:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau benar-benar mahakuasa,
Dialogue: 0,0:20:02.66,0:20:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}artinya kau harus bertanggung jawab\Natas segala tindakan yang perlu diambil.
Dialogue: 0,0:20:05.66,0:20:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tak sampai sejauh itu,
Dialogue: 0,0:20:07.66,0:20:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau merasa wajib mengawasi Nokker.
Dialogue: 0,0:20:11.25,0:20:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, situasinya kini memang begitu.
Dialogue: 0,0:20:14.33,0:20:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika menyegel Nokker semudah itu,\Nlakukan saja.
Dialogue: 0,0:20:18.17,0:20:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bantu aku"? Alangkah menyedihkan.
Dialogue: 0,0:20:20.76,0:20:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, hentikan ini!
Dialogue: 0,0:20:22.38,0:20:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu masih lebih baik daripada berdiam diri.
Dialogue: 0,0:20:24.18,0:20:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak tahu alasannya,
Dialogue: 0,0:20:26.14,0:20:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku dirundung ragu dan gelisah.
Dialogue: 0,0:20:28.14,0:20:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebab itu aku ingin mendengar\Npendapat kalian.
Dialogue: 0,0:20:31.94,0:20:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, biar aku duluan.
Dialogue: 0,0:20:33.23,0:20:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menentangnya.
Dialogue: 0,0:20:34.35,0:20:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa tak ada alasan\Nmenuruti arahan Sosok Hitam
Dialogue: 0,0:20:35.90,0:20:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terbawa emosi.
Dialogue: 0,0:20:38.57,0:20:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:20:39.74,0:20:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Fushi menjadi dewa,\Ndia tak bisa lagi tinggal bersama kita.
Dialogue: 0,0:20:43.28,0:20:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun menentangnya.
Dialogue: 0,0:20:44.91,0:20:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meluasnya indramu hanya akan\Nmemperberat beban fisikmu.
Dialogue: 0,0:20:48.83,0:20:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tertidur lelap\Nseperti tempo hari,
Dialogue: 0,0:20:51.25,0:20:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa itu sama sekali tidak baik.
Dialogue: 0,0:20:52.92,0:20:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju.
Dialogue: 0,0:20:54.67,0:20:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika hanya kau yang mampu melakukannya,\Nkau harus bertindak.
Dialogue: 0,0:20:56.84,0:20:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu alasan agar kau menerimanya,\Nkarena kita tak tahu apa yang terjadi.
Dialogue: 0,0:20:58.88,0:20:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bon…
Dialogue: 0,0:20:59.84,0:21:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau serius?
Dialogue: 0,0:21:00.84,0:21:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila terjadi sesuatu pada Fushi,\Nkau berani bertanggung jawab?
Dialogue: 0,0:21:03.30,0:21:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila saatnya tiba, akan kuberikan\Nseluruh dukungan yang kau butuhkan.
Dialogue: 0,0:21:05.84,0:21:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pun jika Fushi memutuskan\Nuntuk mengambil langkah tersebut.
Dialogue: 0,0:21:07.30,0:21:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua keputusan ada di tangan Fushi.
Dialogue: 0,0:21:09.64,0:21:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak keberatan dengan keduanya.
Dialogue: 0,0:21:11.93,0:21:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kau harus\Nmempermudah jalan hidupku.
Dialogue: 0,0:21:16.06,0:21:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iddy.
Dialogue: 0,0:21:23.24,0:21:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkataanmu benar, Iddy.
Dialogue: 0,0:21:25.49,0:21:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin hidup seperti ini\Nuntuk selamanya.
Dialogue: 0,0:21:28.49,0:21:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fu.
Dialogue: 0,0:21:29.74,0:21:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukanlah sesukamu.
Dialogue: 0,0:21:31.83,0:21:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan pun dan di mana pun,\NMarch akan selalu menjagamu.
Dialogue: 0,0:21:34.96,0:21:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}March.
Dialogue: 0,0:21:38.04,0:21:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, kau punya waktu tiga tahun\Nuntuk menimbangnya.
Dialogue: 0,0:21:40.71,0:21:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak harus memutuskannya sekarang.
Dialogue: 0,0:21:42.80,0:21:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutarik kembali ucapanku.\NAku setuju dengan March.
Dialogue: 0,0:21:45.59,0:21:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sependapat dengan March.
Dialogue: 0,0:21:47.55,0:21:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua sangat baik.
Dialogue: 0,0:21:49.64,0:21:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju dengan diriku sendiri.
Dialogue: 0,0:21:51.31,0:21:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, kau yang bertugas\Nberbelanja hari ini!
Dialogue: 0,0:21:53.89,0:21:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku lupa.
Dialogue: 0,0:21:55.14,0:21:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ikut.
Dialogue: 0,0:21:57.56,0:22:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku menjadi Fushi,\Naku akan mengambil kekuatan itu.
Dialogue: 0,0:22:00.77,0:22:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:22:01.69,0:22:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu memilih hal yang menyenangkan.
Dialogue: 0,0:22:04.44,0:22:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada jaminan itu akan seru.
Dialogue: 0,0:22:06.53,0:22:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak asyik, nikmati saja\Nbagian tak asyiknya itu.
Dialogue: 0,0:22:10.08,0:22:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:22:11.66,0:22:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Fushi,
Dialogue: 0,0:22:13.08,0:22:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa semua baik-baik saja seperti ini.
Dialogue: 0,0:22:16.54,0:22:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanyalah manusia biasa.
Dialogue: 0,0:22:18.46,0:22:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa usiaku tinggal 60 tahun lagi.
Dialogue: 0,0:22:21.55,0:22:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Nokker di dalam tubuhku keluar\Ndan membuat kekacauan,
Dialogue: 0,0:22:24.38,0:22:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}usia hidupku mungkin akan\Nkurang dari 60 tahun.
Dialogue: 0,0:22:28.09,0:22:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, pantang kubiarkan itu terjadi.
Dialogue: 0,0:22:30.18,0:22:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar dia tahu aku tak selemah itu\Nuntuk menyerahkan tubuhku.
Dialogue: 0,0:22:36.06,0:22:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku mampu menjalani takdir hidupku,
Dialogue: 0,0:22:38.56,0:22:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus sependapat denganku.
Dialogue: 0,0:22:40.40,0:22:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia tetap bisa damai dan makmur\Napa adanya.
Dialogue: 0,0:22:44.48,0:22:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Fushi, kau harus mengawasiku\Nmenjalani seluruh hidupku.
Dialogue: 0,0:22:52.20,0:22:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menunggu 60 tahun?\NLama sekali.
Dialogue: 0,0:22:56.75,0:22:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:24:32.01,0:24:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya Fushi\Nyang dapat memimpin Dunia Baru.
Dialogue: 0,0:24:38.18,0:24:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, beban yang dia tanggung\Nterlampau besar.
Dialogue: 0,0:24:43.65,0:24:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi telah tiba.
Dialogue: 0,0:24:46.19,0:24:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen Fushi untuk mengambil keputusan\Nmakin dekat.
