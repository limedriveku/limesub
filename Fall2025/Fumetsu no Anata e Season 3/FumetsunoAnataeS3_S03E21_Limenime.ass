Dialogue: 0,0:01:58.11,0:01:59.91,tanda,,0000,0000,0000,,TO YOUR ETERNITY\NSEASON 3
Dialogue: 0,0:01:59.99,0:02:03.99,tanda,,0000,0000,0000,,#21 SAMA SEPERTI INI, TEPAT DI SINI
Dialogue: 0,0:07:24.48,0:07:26.53,tanda,,0000,0000,0000,,D-N-A.
Dialogue: 0,0:11:38.57,0:11:40.99,tanda,,0000,0000,0000,,TO YOUR ETERNITY\NSEASON 3
Dialogue: 0,0:14:24.90,0:14:26.32,tanda,,0000,0000,0000,,CGI?
Dialogue: 0,0:24:29.97,0:24:30.97,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:24:51.99,0:24:54.99,tanda,,0000,0000,0000,,"#22 UNTUK FUSHI"
Dialogue: 0,0:00:01.00,0:00:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya Fushi ingin mengeluarkan Nokker\Ndari tubuh Yuki.
Dialogue: 0,0:00:07.00,0:00:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:00:07.92,0:00:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup berdampingan.
Dialogue: 0,0:00:11.34,0:00:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuasai aku, Fushi.
Dialogue: 0,0:00:19.18,0:00:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Fushi, kau harus melihatku\Nmenjalani seluruh hidupku.
Dialogue: 0,0:00:24.06,0:00:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi belum memutuskan.
Dialogue: 0,0:02:05.79,0:02:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kutulis\Nuntuk rencana pascakelulusan?
Dialogue: 0,0:02:08.50,0:02:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasabe, kau sudah memutuskan?
Dialogue: 0,0:02:11.03,0:02:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku belum memutuskan.
Dialogue: 0,0:02:14.05,0:02:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih ingin tahu\Nke mana Mizuha akan melanjutkan.
Dialogue: 0,0:02:18.09,0:02:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:02:23.60,0:02:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mizuha,
Dialogue: 0,0:02:25.27,0:02:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau ingin masuk SMA mana setelah lulus?
Dialogue: 0,0:02:28.64,0:02:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku akan masuk SMA Kawanami.
Dialogue: 0,0:02:33.07,0:02:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sekolah elite dari prefektur lain!
Dialogue: 0,0:02:36.57,0:02:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang hebat.
Dialogue: 0,0:02:38.40,0:02:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu sulit!\NAku takkan bisa masuk ke sana!
Dialogue: 0,0:02:41.49,0:02:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tak masuk sekolah biasa\Ndi dekat sini saja?
Dialogue: 0,0:02:44.95,0:02:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, suaramu keras sekali.\NYakin tidak apa-apa?
Dialogue: 0,0:02:48.25,0:02:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa? Ucapanku kan tidak dihitung.
Dialogue: 0,0:02:50.54,0:02:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin? Menyerah saja.
Dialogue: 0,0:02:52.46,0:02:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau mau ke mana?
Dialogue: 0,0:02:54.88,0:02:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami membicarakan rencana usai lulus.
Dialogue: 0,0:02:56.84,0:02:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, apa rencanamu?
Dialogue: 0,0:02:58.92,0:03:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi pekerja lepas?
Dialogue: 0,0:03:00.34,0:03:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu banyak soal itu.
Dialogue: 0,0:03:01.97,0:03:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bon mungkin\Nakan memikirkan sesuatu untukku.
Dialogue: 0,0:03:04.51,0:03:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu, Fushi.
Dialogue: 0,0:03:06.14,0:03:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus memutuskan\Nbagaimana kau ingin hidup.
Dialogue: 0,0:03:10.31,0:03:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fu, lakukan apa yang kau inginkan.
Dialogue: 0,0:03:15.02,0:03:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:03:15.94,0:03:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Yuki juga.
Dialogue: 0,0:03:19.74,0:03:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita baru akan lulus enam bulan lagi.
Dialogue: 0,0:03:23.24,0:03:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai saat itu, kau harus mandiri.
Dialogue: 0,0:03:25.28,0:03:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:03:26.20,0:03:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa yang harus kulakukan?
Dialogue: 0,0:03:27.79,0:03:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan memalukan jika membuat Mizuha cemas\Nsaat kita mengantarnya, bukan?
Dialogue: 0,0:03:31.46,0:03:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan yang belum selesai, kan?
Dialogue: 0,0:03:33.04,0:03:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah melakukan semua yang kau mau?
Dialogue: 0,0:03:35.71,0:03:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita baru setengah jalan\Ndengan Berita Gaib.
Dialogue: 0,0:03:38.21,0:03:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub Riset Hal Gaib, berkumpul!
Dialogue: 0,0:03:39.72,0:03:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ke rumah Hirotoshi untuk penelitian!
Dialogue: 0,0:03:41.59,0:03:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kerjakan laporannya!
Dialogue: 0,0:03:44.18,0:03:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:03:46.39,0:03:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah itu saja?
Dialogue: 0,0:03:51.69,0:03:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus memutuskan\Nrencana pascakelulusan.
Dialogue: 0,0:03:57.19,0:03:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah aku mewarisi kekuatan Sosok Hitam?
Dialogue: 0,0:03:59.82,0:04:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau tetap menjadi diriku?
Dialogue: 0,0:04:01.90,0:04:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika cuma kau yang bisa,\Nkau harus melakukannya.
Dialogue: 0,0:04:04.41,0:04:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika melihatnya secara positif,
Dialogue: 0,0:04:07.12,0:04:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu sesuatu yang harus kulakukan.
Dialogue: 0,0:04:08.91,0:04:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:04:11.00,0:04:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku belum tahu apa yang kucemaskan.
Dialogue: 0,0:04:17.45,0:04:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuda.
Dialogue: 0,0:04:18.83,0:04:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa kau akan bilang,\N"Lakukan apa yang kau inginkan."
Dialogue: 0,0:04:21.97,0:04:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya. Aku sudah siapkan nama untukmu.
Dialogue: 0,0:04:24.13,0:04:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau "Tahu"?
Dialogue: 0,0:04:27.35,0:04:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak suka?
Dialogue: 0,0:04:28.39,0:04:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau "Tahu Badam"?
Dialogue: 0,0:04:30.39,0:04:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau "Moci"? Atau "Nasi Putih"?
Dialogue: 0,0:04:33.31,0:04:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sawi Putih"?
Dialogue: 0,0:04:34.23,0:04:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Taoge"?
Dialogue: 0,0:04:35.40,0:04:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:04:37.48,0:04:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau keras kepala sekali.
Dialogue: 0,0:04:39.07,0:04:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak terpikir\Nbenda berwarna putih lainnya.
Dialogue: 0,0:04:42.61,0:04:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:47.49,0:04:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini
Dialogue: 0,0:04:49.20,0:04:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sesuatu yang sebelumnya dibuat Sosok Hitam.
Dialogue: 0,0:04:56.21,0:04:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak bergerak.
Dialogue: 0,0:04:58.21,0:04:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ia mati?
Dialogue: 0,0:05:07.39,0:05:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok Hitam!
Dialogue: 0,0:05:08.60,0:05:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:05:09.76,0:05:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau bilang kau mahakuasa?
Dialogue: 0,0:05:11.56,0:05:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang kekuatanmu\Nsanggup melakukan apa pun.
Dialogue: 0,0:05:13.77,0:05:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa ia mati?
Dialogue: 0,0:05:18.40,0:05:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengerti apa gunanya ini.
Dialogue: 0,0:05:21.02,0:05:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau mau,
Dialogue: 0,0:05:22.03,0:05:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bisa membuatnya abadi sepertiku.
Dialogue: 0,0:05:24.49,0:05:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka tidak ada\Nyang harus menderita dan mati.
Dialogue: 0,0:05:27.36,0:05:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parona dan Pioran tidak akan mati.
Dialogue: 0,0:05:29.49,0:05:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemahakuasaan macam apa itu?
Dialogue: 0,0:05:32.70,0:05:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:34.00,0:05:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk ini punya mata,\Ntapi tak punya hidung atau mulut.
Dialogue: 0,0:05:37.17,0:05:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit untuk bertahan.
Dialogue: 0,0:05:38.54,0:05:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab pertanyaanku.
Dialogue: 0,0:05:40.59,0:05:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menyiksa kami?
Dialogue: 0,0:05:42.75,0:05:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mempermainkan kami?
Dialogue: 0,0:05:43.71,0:05:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan pertanyaan. Itu keluhan.
Dialogue: 0,0:05:47.51,0:05:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tidak puas, ciptakanlah sendiri.
Dialogue: 0,0:05:51.60,0:05:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia tanpa penderitaan dan kematian,
Dialogue: 0,0:05:54.31,0:05:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat siapa pun bisa menjadi apa pun\Ndan melakukan apa pun.
Dialogue: 0,0:05:58.02,0:06:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu kau, kau bisa menciptakannya.
Dialogue: 0,0:06:04.78,0:06:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek! Dilarang masuk!
Dialogue: 0,0:06:08.28,0:06:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat, kemarilah!
Dialogue: 0,0:06:10.03,0:06:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena menciptakan sesuatu\Nyang tak sempurna.
Dialogue: 0,0:06:13.95,0:06:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagiku, itulah kesempurnaan.
Dialogue: 0,0:06:24.84,0:06:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dengan begini,\Nsemua orang akan tahu.
Dialogue: 0,0:06:27.09,0:06:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi, kau mau mencobanya?
Dialogue: 0,0:06:34.68,0:06:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:06:37.02,0:06:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:06:38.44,0:06:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memikirkan cara\Nagar Nokker membantu manusia.
Dialogue: 0,0:06:42.65,0:06:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada Nokker,
Dialogue: 0,0:06:44.40,0:06:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penyandang distabilitas\Nmungkin bisa bergerak bebas.
Dialogue: 0,0:06:47.36,0:06:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kehilangan anggota tubuh\Ndalam kecelakaan,
Dialogue: 0,0:06:50.03,0:06:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka bisa menumbuhkan yang baru.
Dialogue: 0,0:06:51.74,0:06:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan orang sejelek aku
Dialogue: 0,0:06:53.49,0:06:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa terlahir kembali sebagai pria tampan.
Dialogue: 0,0:06:56.50,0:06:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil.
Dialogue: 0,0:06:58.50,0:06:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:59.75,0:07:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa kami lakukan adalah
Dialogue: 0,0:07:01.83,0:07:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memanjangkan bagian depan anggota tubuh\Ndan memperkuat otot.
Dialogue: 0,0:07:05.59,0:07:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini agak berbeda\Ndengan membuat sesuatu yang baru.
Dialogue: 0,0:07:09.30,0:07:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:07:10.30,0:07:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya keahlian tingkat tinggi\Nseperti mengubah penampilan
Dialogue: 0,0:07:12.18,0:07:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}butuh evolusi lebih lanjut.
Dialogue: 0,0:07:14.56,0:07:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:07:15.64,0:07:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika Fushi bisa memberikan informasi\Ntentang wujudnya, seharusnya tak masalah.
Dialogue: 0,0:07:20.89,0:07:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasi wujud merujuk pada DNA, bukan?
Dialogue: 0,0:07:26.61,0:07:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya canggih.
Dialogue: 0,0:07:28.44,0:07:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini menyenangkan, Fushi?
Dialogue: 0,0:07:31.45,0:07:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Yang disebut DNA itu
Dialogue: 0,0:07:33.87,0:07:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti cetak biru untuk manusia.
Dialogue: 0,0:07:35.99,0:07:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika penggunaannya tepat, kita mampu\Nmenciptakan ulang makhluk, sepertimu.
Dialogue: 0,0:07:39.96,0:07:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa mereka sudah melakukan\Neksperimen di luar negeri.
Dialogue: 0,0:07:43.71,0:07:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hasilnya, ya?
Dialogue: 0,0:07:46.00,0:07:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar mereka mati cukup cepat.
Dialogue: 0,0:07:50.09,0:07:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu palsu, kan?
Dialogue: 0,0:07:52.01,0:07:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku ingin melihat\Nklona manusia sebelum mati.
Dialogue: 0,0:07:55.64,0:07:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu dilarang?
Dialogue: 0,0:07:58.10,0:08:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku ingat\N- Jika aku mewarisi kekuatan itu,
Dialogue: 0,0:08:00.98,0:08:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gereja Bennett memprotes…\N- tidak perlu membahas semua ini.
Dialogue: 0,0:08:03.56,0:08:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak perlu memikirkan\Narti keberadaan Nokker lagi.
Dialogue: 0,0:08:07.61,0:08:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengembalikan wajah asli Gugu.
Dialogue: 0,0:08:10.61,0:08:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa memberi Hairo gigi aslinya.
Dialogue: 0,0:08:13.61,0:08:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iddy juga bisa berbicara.
Dialogue: 0,0:08:16.99,0:08:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan bisa mempertemukan orang\Ndengan sosok yang ingin mereka temui?
Dialogue: 0,0:08:22.46,0:08:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membiarkan Tonari bertemu\Norang-orang Jananda lagi.
Dialogue: 0,0:08:26.34,0:08:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membiarkan March bertemu Parona lagi
Dialogue: 0,0:08:28.25,0:08:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan orang tua yang dia rindukan.
Dialogue: 0,0:08:31.38,0:08:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar mereka bisa kembali bersama\Nkeluarga dan teman-teman mereka.
Dialogue: 0,0:08:36.97,0:08:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku juga bisa bertemu dia?
Dialogue: 0,0:08:39.85,0:08:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Joan.
Dialogue: 0,0:08:42.39,0:08:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu bukan aku saat itu.
Dialogue: 0,0:08:48.23,0:08:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin takkan menjadi siapa pun.
Dialogue: 0,0:08:51.61,0:08:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti Sosok Hitam.
Dialogue: 0,0:09:00.74,0:09:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas kelulusan\Npara murid kelas tiga.
Dialogue: 0,0:09:06.75,0:09:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja,\Nartikel kita tak dianggap serius.
Dialogue: 0,0:09:08.75,0:09:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bahkan menerbitkan foto\Nuntuk menyampaikan yang sebenarnya.
Dialogue: 0,0:09:12.38,0:09:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang mengira\Nitu insiden gaib yang dibuat-buat.
Dialogue: 0,0:09:16.18,0:09:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub Riset Hal Gaib akan berakhir\Ndi angkatan kita.
Dialogue: 0,0:09:19.89,0:09:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tidak ada adik kelas\Nyang bergabung.
Dialogue: 0,0:09:22.93,0:09:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, impianmu adalah mewujudkan\Nimpian semua orang, bukan?
Dialogue: 0,0:09:29.15,0:09:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aoki!
Dialogue: 0,0:09:30.57,0:09:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Kak Fushi?
Dialogue: 0,0:09:32.28,0:09:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:09:33.28,0:09:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian menghina Klub Riset Hal Gaib.
Dialogue: 0,0:09:34.90,0:09:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin aku memberitahumu.
Dialogue: 0,0:09:37.11,0:09:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:09:39.07,0:09:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Fushi!
Dialogue: 0,0:09:40.66,0:09:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan lulus. Aku sedih sekali!
Dialogue: 0,0:09:42.33,0:09:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi!
Dialogue: 0,0:09:43.33,0:09:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu. Tolong beri aku\Nhadiah perpisahan sebagai kenang-kenangan.
Dialogue: 0,0:09:45.58,0:09:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tak tahu harus memberimu apa.
Dialogue: 0,0:09:48.42,0:09:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:09:49.33,0:09:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian boleh ambil kancingnya!
Dialogue: 0,0:09:51.09,0:09:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat! Pergi!
Dialogue: 0,0:09:54.26,0:09:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar serakah.
Dialogue: 0,0:09:55.80,0:09:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masalahnya? Hanya untuk hari ini.
Dialogue: 0,0:09:57.38,0:09:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hari terakhir.
Dialogue: 0,0:09:59.26,0:10:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kau lakukan, Ketua?
Dialogue: 0,0:10:02.14,0:10:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:10:03.68,0:10:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu, Kak Mizuha.
Dialogue: 0,0:10:07.69,0:10:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mizuha, aku menyukaimu!
Dialogue: 0,0:10:10.11,0:10:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkencanlah denganku!
Dialogue: 0,0:10:15.36,0:10:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini…
Dialogue: 0,0:10:17.20,0:10:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:10:20.41,0:10:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sedih, Anak Muda.
Dialogue: 0,0:10:23.49,0:10:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikuya.
Dialogue: 0,0:10:25.29,0:10:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama, ya?
Dialogue: 0,0:10:27.58,0:10:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku sudah pulih.
Dialogue: 0,0:10:30.96,0:10:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa kau bisa berkencan denganku?
Dialogue: 0,0:10:32.96,0:10:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Maafkan aku.
Dialogue: 0,0:10:35.55,0:10:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, berkencanlah denganku!
Dialogue: 0,0:10:36.55,0:10:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, denganku!
Dialogue: 0,0:10:37.51,0:10:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak, denganku!\N- Kalau aku?
Dialogue: 0,0:10:40.01,0:10:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap Mizuha masih sama saja.
Dialogue: 0,0:10:44.31,0:10:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habislah aku.
Dialogue: 0,0:10:46.06,0:10:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ditolak orang yang kusukai.
Dialogue: 0,0:10:47.81,0:10:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub Riset Hal Gaib juga sudah dibubarkan.
Dialogue: 0,0:10:49.52,0:10:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang berjalan sesuai keinginanku.
Dialogue: 0,0:10:52.73,0:10:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat. Semangatnya\Nsedang berada di titik terendah.
Dialogue: 0,0:11:03.95,0:11:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini edisi terakhir Berita Gaib.
Dialogue: 0,0:11:08.66,0:11:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya…
Dialogue: 0,0:11:19.47,0:11:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang jatuh.
Dialogue: 0,0:11:20.63,0:11:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:11:21.97,0:11:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Berita Gaib". Aneh sekali.
Dialogue: 0,0:11:27.43,0:11:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, aku sudah memutuskan!
Dialogue: 0,0:11:31.90,0:11:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memutuskan apa?
Dialogue: 0,0:11:33.52,0:11:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang ingin kulakukan!
Dialogue: 0,0:11:41.74,0:11:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku Nono.
Dialogue: 0,0:11:43.66,0:11:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nokker.
Dialogue: 0,0:11:45.45,0:11:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, akan kutunjukkan kekuatanku.
Dialogue: 0,0:11:53.00,0:11:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu?
Dialogue: 0,0:11:54.54,0:11:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah jelas? Itu palsu.
Dialogue: 0,0:11:57.34,0:11:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah. Kau mendapat cuti berbayar.
Dialogue: 0,0:12:00.01,0:12:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana lokakaryanya?
Dialogue: 0,0:12:02.01,0:12:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendapatanku tak sebanyak sebelumnya.
Dialogue: 0,0:12:05.51,0:12:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya pehobi yang sesekali mampir.
Dialogue: 0,0:12:08.10,0:12:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sulit.
Dialogue: 0,0:12:09.85,0:12:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku juga tidak cocok\Nuntuk pekerjaan modern.
Dialogue: 0,0:12:12.60,0:12:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih cari pekerjaan.
Dialogue: 0,0:12:14.90,0:12:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Fushi tidak bersekolah.
Dialogue: 0,0:12:16.40,0:12:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membantu di toko Gugu.
Dialogue: 0,0:12:19.99,0:12:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lebih dari tiga tahun\Nsejak kita datang ke sini.
Dialogue: 0,0:12:22.70,0:12:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah terbiasa.
Dialogue: 0,0:12:26.66,0:12:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Meiran.
Dialogue: 0,0:12:28.16,0:12:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, seseorang menamai kudanya?
Dialogue: 0,0:12:30.00,0:12:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama yang bagus.
Dialogue: 0,0:12:33.46,0:12:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi ingin menamainya "Ramen".
Dialogue: 0,0:12:36.29,0:12:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Aiko menentangnya.
Dialogue: 0,0:12:37.75,0:12:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka membaliknya\Ndan menjadi "Meiran".
Dialogue: 0,0:12:38.96,0:12:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:12:41.47,0:12:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:12:44.18,0:12:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun!
Dialogue: 0,0:12:46.01,0:12:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekerja!
Dialogue: 0,0:12:47.89,0:12:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Messar, apa yang kau lakukan?
Dialogue: 0,0:12:51.31,0:12:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak melakukan apa pun.
Dialogue: 0,0:12:53.85,0:12:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan sesuatu!
Dialogue: 0,0:12:56.06,0:12:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, lupakan pria tua itu!
Dialogue: 0,0:12:59.19,0:13:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari adakan pesta soda!
Dialogue: 0,0:13:02.90,0:13:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kai, Tuan Hairo,\Nselamat datang kembali.
Dialogue: 0,0:13:05.28,0:13:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka teman-temanmu?
Dialogue: 0,0:13:06.99,0:13:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi mereka akan menginap malam ini.
Dialogue: 0,0:13:10.49,0:13:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:13:12.25,0:13:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku mendapat boneka Nokker\Nbuatan perusahaan lokal.
Dialogue: 0,0:13:16.00,0:13:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satunya 888 yen.
Dialogue: 0,0:13:17.96,0:13:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantal ini 1.888 yen.
Dialogue: 0,0:13:20.50,0:13:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dijual?
Dialogue: 0,0:13:22.05,0:13:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dijual di internet.
Dialogue: 0,0:13:24.80,0:13:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini semua barang stok?
Dialogue: 0,0:13:26.34,0:13:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak yang tersisa.
Dialogue: 0,0:13:27.89,0:13:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:13:29.10,0:13:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stasiun TV dan penyiar mempromosikannya.
Dialogue: 0,0:13:31.06,0:13:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjualannya sangat bagus sekarang.
Dialogue: 0,0:13:33.48,0:13:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering mendengar kata "Nokker"\Nbelakangan ini.
Dialogue: 0,0:13:35.94,0:13:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:13:37.60,0:13:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu bukan hal yang buruk.
Dialogue: 0,0:13:39.23,0:13:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cukup terkenal\Ndi kalangan legenda urban.
Dialogue: 0,0:13:41.69,0:13:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya bantal Nokker.
Dialogue: 0,0:13:44.49,0:13:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka makhluk legendaris\Ndalam buku berusia 500 tahun
Dialogue: 0,0:13:47.28,0:13:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar ada.
Dialogue: 0,0:13:48.37,0:13:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bersemangat!
Dialogue: 0,0:13:50.45,0:13:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat inisiatif Yuki, dunia
Dialogue: 0,0:13:53.50,0:13:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!\N- perlahan mulai mengenal Nokker.
Dialogue: 0,0:13:55.41,0:13:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu yang diinginkan kakakku.
Dialogue: 0,0:13:58.75,0:14:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:14:00.17,0:14:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hampir tak ada yang percaya.
Dialogue: 0,0:14:05.22,0:14:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu.\NApa yang kalian bicarakan?
Dialogue: 0,0:14:07.72,0:14:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, kami membicarakan\Nreaksi penonton di internet.
Dialogue: 0,0:14:12.10,0:14:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu, aku membuat video\Ntentang Nokker di kanal kami, kan?
Dialogue: 0,0:14:15.85,0:14:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Video terbarunya\N"Coba Memancing dengan Satu Jari".
Dialogue: 0,0:14:19.40,0:14:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksinya bagus,
Dialogue: 0,0:14:21.32,0:14:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi semua orang berpikir itu CGI.
Dialogue: 0,0:14:26.40,0:14:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi semua orang terhadap Nono bagus.
Dialogue: 0,0:14:29.62,0:14:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka tak menganggapnya\Nsebagai Nokker.
Dialogue: 0,0:14:31.20,0:14:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka melihatnya sebagai karakter.
Dialogue: 0,0:14:34.24,0:14:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di benak penonton, Nokker seperti hantu\Natau makhluk misterius.
Dialogue: 0,0:14:39.21,0:14:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku bisa berkomunikasi\Ndengan Nokker di dalam diriku
Dialogue: 0,0:14:43.30,0:14:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membangun hubungan baik dengannya,
Dialogue: 0,0:14:44.25,0:14:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- aku bisa membuat video sebagai Nokker!\N- Nokker!
Dialogue: 0,0:14:47.38,0:14:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren sekali!
Dialogue: 0,0:14:48.47,0:14:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya akan berpikir\Nkomposisi kita sangat bagus.
Dialogue: 0,0:14:52.76,0:14:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ingin mereka tahu\Nbahwa Nokker benar-benar ada.
Dialogue: 0,0:14:59.85,0:15:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu boneka yang aneh?
Dialogue: 0,0:15:02.36,0:15:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dari pekerjaan paruh waktuku.
Dialogue: 0,0:15:04.11,0:15:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat seperti monster.
Dialogue: 0,0:15:06.90,0:15:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:15:08.61,0:15:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ke rumah temanmu hari ini?
Dialogue: 0,0:15:11.70,0:15:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu pukul berapa\Nkegiatan klub Tomori selesai.
Dialogue: 0,0:15:15.16,0:15:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan bertemu teman malam ini.
Dialogue: 0,0:15:17.45,0:15:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa membawa kuncimu.
Dialogue: 0,0:15:21.71,0:15:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu.
Dialogue: 0,0:15:27.55,0:15:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:29.09,0:15:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan membeli hadiah ulang tahun\Nuntuk Satoru besok.
Dialogue: 0,0:15:32.26,0:15:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kau luang.
Dialogue: 0,0:15:33.64,0:15:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku tahu…
Dialogue: 0,0:15:35.93,0:15:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi, kau baik-baik saja?
Dialogue: 0,0:15:40.10,0:15:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit, bukan? Kau terluka?
Dialogue: 0,0:15:43.98,0:15:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:15:45.48,0:15:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak boleh. Ayo ke rumah sakit.
Dialogue: 0,0:15:47.61,0:15:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik saja, sungguh.
Dialogue: 0,0:15:49.99,0:15:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat?
Dialogue: 0,0:15:52.03,0:15:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi!
Dialogue: 0,0:15:53.74,0:15:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:15:57.58,0:15:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:15:59.41,0:16:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi yang dahulu sangat lemah\Nhampir tampak tidak nyata.
Dialogue: 0,0:16:03.21,0:16:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini sungguh tidak apa-apa?
Dialogue: 0,0:16:05.88,0:16:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:16:08.80,0:16:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuncinya.
Dialogue: 0,0:16:09.84,0:16:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi, kau lupa kuncimu!
Dialogue: 0,0:16:15.01,0:16:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:16:16.10,0:16:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaan, ada banyak komentar\Nmenanyakan identitas asli Nono.
Dialogue: 0,0:16:19.43,0:16:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa?
Dialogue: 0,0:16:21.23,0:16:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika kita turuti kemauan mereka
Dialogue: 0,0:16:22.69,0:16:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membiarkan Michi mengungkap\Nidentitas aslinya di kamera?
Dialogue: 0,0:16:26.32,0:16:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,\Npemirsa takkan berpikir itu palsu, bukan?
Dialogue: 0,0:16:29.44,0:16:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, Hirotoshi.
Dialogue: 0,0:16:30.82,0:16:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak tahu alasan kami\Nmenutupi wajahnya?
Dialogue: 0,0:16:33.11,0:16:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:16:34.45,0:16:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada orang di sekitar Michi
Dialogue: 0,0:16:35.95,0:16:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tahu bahwa Michi yang sekarang\Nadalah Nokker.
Dialogue: 0,0:16:40.79,0:16:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi, kau sudah datang.
Dialogue: 0,0:16:42.54,0:16:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baru saja membicarakanmu.
Dialogue: 0,0:16:44.83,0:16:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang berdiskusi
Dialogue: 0,0:16:46.04,0:16:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah kau mau membuat video dan menyapa\Nsemua orang dalam wujud aslimu.
Dialogue: 0,0:16:52.05,0:16:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tentu saja aku tahu itu mustahil.
Dialogue: 0,0:16:55.22,0:16:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Sumika dan yang lainnya\Nbelum tahu.
Dialogue: 0,0:16:58.56,0:17:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi yang asli sudah lama mati.
Dialogue: 0,0:17:01.02,0:17:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kau, Nokker,\Ntelah menggantikan dia.
Dialogue: 0,0:17:06.85,0:17:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melakukannya.
Dialogue: 0,0:17:09.35,0:17:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan muncul sebagai Nokker.
Dialogue: 0,0:17:13.10,0:17:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak keberatan?
Dialogue: 0,0:17:14.10,0:17:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:17:15.49,0:17:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita baru saja bilang\Nitu akan menyakiti orang di sekitarnya?
Dialogue: 0,0:17:18.49,0:17:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia melakukan itu,
Dialogue: 0,0:17:20.07,0:17:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang akan dipikirkan Nokker lain\Nyang tersisa di Bumi?
Dialogue: 0,0:17:23.16,0:17:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa memprovokasi mereka.
Dialogue: 0,0:17:25.86,0:17:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin semua orang\Nmenerima Nokker sebagai spesies.
Dialogue: 0,0:17:29.80,0:17:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku tak ingin membuat orang\Ndi sekitar Michi sedih.
Dialogue: 0,0:17:32.67,0:17:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak mau Michi dalam bahaya.
Dialogue: 0,0:17:35.55,0:17:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita bisa memberinya\Npenampilan berbeda dengan riasan tebal.
Dialogue: 0,0:17:38.55,0:17:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku ingin tampil apa adanya.
Dialogue: 0,0:17:41.31,0:17:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi.
Dialogue: 0,0:17:42.43,0:17:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa jika Sumika\Ndan yang lainnya tahu.
Dialogue: 0,0:17:45.85,0:17:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin semua orang\Nmenerima diriku apa adanya.
Dialogue: 0,0:17:49.73,0:17:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau hidup\Ndengan menipu orang lain lagi.
Dialogue: 0,0:17:56.15,0:17:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku bukan orang yang mencurigakan.
Dialogue: 0,0:18:00.28,0:18:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimori, siapa di luar?
Dialogue: 0,0:18:02.62,0:18:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memintaku memberimu ini.
Dialogue: 0,0:18:05.96,0:18:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci rumahku.
Dialogue: 0,0:18:07.54,0:18:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara tadi… Apa itu Sumika?
Dialogue: 0,0:18:09.75,0:18:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak mungkin mendengar\Npembicaraan kita, kan?
Dialogue: 0,0:18:12.13,0:18:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi!
Dialogue: 0,0:18:16.34,0:18:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumika.
Dialogue: 0,0:18:18.30,0:18:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumika, maafkan aku!
Dialogue: 0,0:18:22.51,0:18:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mendengar semuanya, kan?
Dialogue: 0,0:18:25.23,0:18:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengerti maksudmu.
Dialogue: 0,0:18:27.19,0:18:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak tahu siapa dirimu.
Dialogue: 0,0:18:29.31,0:18:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan Michi, aku Nokker!
Dialogue: 0,0:18:35.36,0:18:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah membohongimu.
Dialogue: 0,0:18:37.45,0:18:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama ingin memberitahumu.
Dialogue: 0,0:18:43.49,0:18:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumi…
Dialogue: 0,0:18:49.46,0:18:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumika…
Dialogue: 0,0:19:06.93,0:19:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram sekali! Aku takut!
Dialogue: 0,0:19:17.28,0:19:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:19:30.71,0:19:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Semuanya.
Dialogue: 0,0:19:32.84,0:19:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nono.
Dialogue: 0,0:19:35.59,0:19:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku.
Dialogue: 0,0:19:38.13,0:19:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kalian tahu,
Dialogue: 0,0:19:40.01,0:19:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku adalah Nokker.
Dialogue: 0,0:19:41.80,0:19:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam banyak cerita,\Naku adalah musuh semua orang.
Dialogue: 0,0:19:45.31,0:19:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang berbeda.
Dialogue: 0,0:19:46.89,0:19:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami, Nokker, tak perlu bermusuhan\Ndengan manusia lagi.
Dialogue: 0,0:19:51.94,0:19:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena orang-orang di sekitarku bilang
Dialogue: 0,0:19:56.19,0:19:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- kami bisa menjadi seperti manusia.\N- Ini dia!
Dialogue: 0,0:20:01.45,0:20:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lezat!
Dialogue: 0,0:20:04.91,0:20:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mulai sekarang,
Dialogue: 0,0:20:08.20,0:20:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuharap kita bisa akur.
Dialogue: 0,0:20:13.42,0:20:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang melihat Nono tersenyum.
Dialogue: 0,0:20:15.42,0:20:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis sekali!\NKau tak perlu sembunyikan wajahmu.
Dialogue: 0,0:20:17.46,0:20:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah memberi tahu kami.
Dialogue: 0,0:20:21.59,0:20:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih menyukaimu daripada sebelumnya.
Dialogue: 0,0:20:23.05,0:20:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nono, kau punya kami.
Dialogue: 0,0:20:25.26,0:20:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga. Salam kenal.
Dialogue: 0,0:20:30.14,0:20:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, Nono!
Dialogue: 0,0:20:35.69,0:20:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin soal ini?
Dialogue: 0,0:20:39.19,0:20:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Apa yang kalian lakukan?
Dialogue: 0,0:20:41.90,0:20:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali ke tempat duduk kalian.
Dialogue: 0,0:20:43.66,0:20:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Bu Guru, Michi…
Dialogue: 0,0:20:46.20,0:20:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sekarang dia Nokker Nono.
Dialogue: 0,0:20:48.79,0:20:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nokker?
Dialogue: 0,0:20:50.33,0:20:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dahulu kalian sangat akrab.
Dialogue: 0,0:20:52.92,0:20:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku bilang entah apa\Nyang akan dia lakukan padaku,
Dialogue: 0,0:20:54.79,0:20:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, aku tak boleh mendekatinya.
Dialogue: 0,0:20:57.75,0:20:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michi!
Dialogue: 0,0:20:59.96,0:21:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau bisa berkomunikasi dengannya,
Dialogue: 0,0:21:02.72,0:21:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat Nokker menjadi parasit,
Dialogue: 0,0:21:04.55,0:21:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu artinya dia mengendalikan hidup kita.
Dialogue: 0,0:21:07.10,0:21:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga sangat populer sekarang.
Dialogue: 0,0:21:08.51,0:21:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu bisa membuat orang lebih sulit\Nmelihat masalahnya?
Dialogue: 0,0:21:14.31,0:21:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:21:15.85,0:21:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Nokker, kan?
Dialogue: 0,0:21:17.36,0:21:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bicara sebentar?
Dialogue: 0,0:21:19.23,0:21:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami penggemar Nono.
Dialogue: 0,0:21:21.90,0:21:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:21:23.15,0:21:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurut acara TV,\NNokker adalah sosok jahat.
Dialogue: 0,0:21:26.41,0:21:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu benar,\Nkami tak bisa mengabaikannya.
Dialogue: 0,0:21:29.45,0:21:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran seperti apa kau sebenarnya.
Dialogue: 0,0:21:31.20,0:21:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kyu ketiga di Katsuyama Kenpo.
Dialogue: 0,0:21:34.25,0:21:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu?
Dialogue: 0,0:21:35.17,0:21:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kami ingin\Nberlatih tanding denganmu.
Dialogue: 0,0:21:40.05,0:21:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia marah! Cepat, rekam!
Dialogue: 0,0:21:43.30,0:21:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, ini dia Nokker legendaris!
Dialogue: 0,0:21:46.84,0:21:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nono, jangan lakukan.
Dialogue: 0,0:21:49.76,0:21:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:21:51.01,0:21:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naiklah.
Dialogue: 0,0:21:52.89,0:21:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Keledainya bicara!\N- Fushi!
Dialogue: 0,0:21:54.94,0:21:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:21:55.85,0:21:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat rekam!
Dialogue: 0,0:21:58.06,0:21:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik saja?
Dialogue: 0,0:21:58.98,0:22:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Izinkan kami mewawancaraimu.\N- Terima kasih.
Dialogue: 0,0:22:01.73,0:22:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami benar-benar penggemarmu!
Dialogue: 0,0:22:04.40,0:22:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lari!
Dialogue: 0,0:22:06.53,0:22:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nono.
Dialogue: 0,0:22:07.45,0:22:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dikejar orang-orang aneh. Ini darurat.
Dialogue: 0,0:22:10.78,0:22:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak mau bertarung?
Dialogue: 0,0:22:12.83,0:22:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Nokker, kan? Bertarunglah!
Dialogue: 0,0:22:14.75,0:22:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau menonton kanal ini lagi.
Dialogue: 0,0:22:20.00,0:22:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nono, lari!
Dialogue: 0,0:22:21.55,0:22:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan sisanya pada kami.
Dialogue: 0,0:22:25.51,0:22:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke sini!
Dialogue: 0,0:22:32.60,0:22:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa.
Dialogue: 0,0:22:34.56,0:22:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan bertarung!
Dialogue: 0,0:22:38.60,0:22:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus! Kalian yang terbaik!
Dialogue: 0,0:22:41.06,0:22:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah! Cepat lari!
Dialogue: 0,0:22:43.57,0:22:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nono dan Keledai? Berjuanglah!
Dialogue: 0,0:22:49.78,0:22:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:22:55.25,0:22:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memutuskan untuk tidak mewarisi\Nkekuatan Sosok Hitam.
Dialogue: 0,0:24:31.05,0:24:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ialah sumbernya.
Dialogue: 0,0:24:33.01,0:24:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa di sana.
Dialogue: 0,0:24:35.64,0:24:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia bisa mengambil bentuk apa pun.
Dialogue: 0,0:24:38.06,0:24:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia bisa menciptakan apa pun.
Dialogue: 0,0:24:42.19,0:24:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi menemukan makna keberadaannya
Dialogue: 0,0:24:44.61,0:24:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari catatan yang dipercayakan kepadanya.
Dialogue: 0,0:24:49.40,0:24:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melalui perpisahan abadi,
Dialogue: 0,0:24:51.99,0:24:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masa depan yang dipilih Fushi adalah…
