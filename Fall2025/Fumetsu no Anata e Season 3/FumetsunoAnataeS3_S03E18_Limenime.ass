Dialogue: 0,0:01:58.11,0:01:59.91,tanda,,0000,0000,0000,,TO YOUR ETERNITY\NSEASON 3
Dialogue: 0,0:01:59.99,0:02:03.99,tanda,,0000,0000,0000,,#18 HATI YANG PERCAYA
Dialogue: 0,0:10:48.81,0:10:51.15,tanda,,0000,0000,0000,,TO YOUR ETERNITY\NSEASON 3
Dialogue: 0,0:24:29.97,0:24:32.01,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:24:53.11,0:24:54.99,tanda,,0000,0000,0000,,#19 AIR MURNI
Dialogue: 0,0:00:02.71,0:00:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan Fushi!
Dialogue: 0,0:00:06.21,0:00:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelompok Fushi dan Yuki\Nberusaha menyelamatkan Mizuha.
Dialogue: 0,0:00:12.22,0:00:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:00:15.47,0:00:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wujud anak-anak Fushi direbut darinya.
Dialogue: 0,0:00:21.68,0:00:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, lewat sini!
Dialogue: 0,0:00:25.23,0:00:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti bisa mengalahkan makhluk itu!
Dialogue: 0,0:02:25.18,0:02:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?
Dialogue: 0,0:02:40.28,0:02:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci pintunya!
Dialogue: 0,0:02:42.41,0:02:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kita ke lab sains?
Dialogue: 0,0:02:44.95,0:02:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cari apa?
Dialogue: 0,0:02:46.37,0:02:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang yang berguna.
Dialogue: 0,0:02:53.25,0:02:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu garam, nih!
Dialogue: 0,0:02:54.38,0:02:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa garam itu?
Dialogue: 0,0:02:56.38,0:02:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kulempar ke makhluk itu.\NSiapa tahu meleleh seperti siput.
Dialogue: 0,0:02:59.38,0:03:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh! Air penyiram otomatis\Npasti melarutkan garamnya.
Dialogue: 0,0:03:03.05,0:03:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah selama tak ada api.
Dialogue: 0,0:03:04.85,0:03:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pakai ini saja!
Dialogue: 0,0:03:08.85,0:03:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonari.
Dialogue: 0,0:03:12.56,0:03:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:03:14.94,0:03:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau buat apa gel silika itu?
Dialogue: 0,0:03:17.15,0:03:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kucampur dengan tepung roti.
Dialogue: 0,0:03:20.15,0:03:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kita harus apa?
Dialogue: 0,0:03:22.28,0:03:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin barikade.
Dialogue: 0,0:03:23.70,0:03:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kita alihkan perhatiannya.
Dialogue: 0,0:03:25.24,0:03:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengalihkan perhatian?
Dialogue: 0,0:03:26.74,0:03:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?
Dialogue: 0,0:03:28.33,0:03:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa saja ini dulu.
Dialogue: 0,0:03:33.33,0:03:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segini cukup, 'kan?
Dialogue: 0,0:03:35.84,0:03:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya butuh lebih banyak, deh.
Dialogue: 0,0:03:38.01,0:03:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita butuh waktu.
Dialogue: 0,0:04:03.61,0:04:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat!
Dialogue: 0,0:04:07.12,0:04:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:04:12.96,0:04:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia datang!
Dialogue: 0,0:04:14.08,0:04:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dorong yang kuat!
Dialogue: 0,0:04:15.50,0:04:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh! Ini pintu geser, lo!
Dialogue: 0,0:04:37.15,0:04:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:04:38.61,0:04:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, lewat sini!
Dialogue: 0,0:04:40.86,0:04:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kami serahkan padamu, 'kan?
Dialogue: 0,0:04:42.90,0:04:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kucoba sebisaku.
Dialogue: 0,0:04:44.61,0:04:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temui aku di atap sepuluh menit lagi.
Dialogue: 0,0:04:46.41,0:04:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa?
Dialogue: 0,0:04:47.99,0:04:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, ikuti aku.
Dialogue: 0,0:04:53.25,0:04:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, kita menyelinap keluar dari sini.
Dialogue: 0,0:05:02.51,0:05:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuberi tahu apa yang kita butuhkan\Nuntuk menyingkirkan makhluk itu.
Dialogue: 0,0:05:05.09,0:05:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi jadi dua kelompok\Ndan kumpulkan barangnya.
Dialogue: 0,0:05:07.22,0:05:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyingkirkannya? Bagaimana caranya?
Dialogue: 0,0:05:09.14,0:05:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:05:11.68,0:05:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonari tidak ikut sama kita.
Dialogue: 0,0:05:14.39,0:05:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa.
Dialogue: 0,0:05:15.39,0:05:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonari sedang mengulur waktu.
Dialogue: 0,0:05:18.90,0:05:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita butuh apa buat mengalahkan Nokker itu?
Dialogue: 0,0:05:20.69,0:05:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagisa!
Dialogue: 0,0:05:21.61,0:05:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat beri tahu kami.
Dialogue: 0,0:05:37.21,0:05:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku di sini!
Dialogue: 0,0:05:41.00,0:05:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api!
Dialogue: 0,0:05:45.38,0:05:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api!
Dialogue: 0,0:05:49.72,0:05:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Keren, 'kan? Apinya disulut air, lo!\N- Api!
Dialogue: 0,0:05:53.14,0:05:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, kau berusaha keras banget.\N- Api!
Dialogue: 0,0:05:55.23,0:05:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi ini masih banyak.\N- Api!
Dialogue: 0,0:05:58.44,0:06:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api!
Dialogue: 0,0:06:05.28,0:06:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Kok bisa begini?
Dialogue: 0,0:06:08.03,0:06:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:06:09.20,0:06:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Maaf, lepaskan aku!
Dialogue: 0,0:06:12.08,0:06:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi!
Dialogue: 0,0:06:13.16,0:06:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, lakukan sesuatu, dong!
Dialogue: 0,0:06:15.70,0:06:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi!
Dialogue: 0,0:06:21.88,0:06:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurungan besi yang dipakai di Renril.
Dialogue: 0,0:06:25.21,0:06:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus beri tahu yang lain\Nbiar mereka tak khawatir lagi.
Dialogue: 0,0:06:34.89,0:06:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api!
Dialogue: 0,0:06:39.23,0:06:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api!
Dialogue: 0,0:06:43.19,0:06:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tak apa-apa, Fushi.\N- Api!
Dialogue: 0,0:06:47.07,0:06:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih bisa bertahan, kok.
Dialogue: 0,0:06:53.91,0:06:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi.
Dialogue: 0,0:06:58.79,0:07:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master…
Dialogue: 0,0:07:09.55,0:07:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chami, amunisi.
Dialogue: 0,0:07:12.80,0:07:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amunisi!
Dialogue: 0,0:07:14.30,0:07:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amunisi kita sudah habis.
Dialogue: 0,0:07:16.22,0:07:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, maaf.
Dialogue: 0,0:07:19.48,0:07:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa.
Dialogue: 0,0:07:20.98,0:07:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nokker juga ada banyak jenisnya.
Dialogue: 0,0:07:23.61,0:07:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kau pasti bisa!
Dialogue: 0,0:07:25.19,0:07:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keluarkan kau sekarang…
Dialogue: 0,0:07:26.65,0:07:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master.
Dialogue: 0,0:07:32.87,0:07:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Kau tak mau melawan balik?
Dialogue: 0,0:07:36.16,0:07:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku ingin mengalahkanmu
Dialogue: 0,0:07:37.45,0:07:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengembalikan ayah Mizuha,
Dialogue: 0,0:07:40.33,0:07:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak niat pakai kekerasan.
Dialogue: 0,0:07:43.38,0:07:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:07:46.59,0:07:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:07:49.38,0:07:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus bermain denganmu\Nsampai amunisimu habis.
Dialogue: 0,0:08:03.31,0:08:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau sudah hilang\Nsemangat bertarung, ya?
Dialogue: 0,0:08:07.40,0:08:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bosan juga kalau kau\Ntak menghindari seranganku.
Dialogue: 0,0:08:11.24,0:08:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menghindar, kok.
Dialogue: 0,0:08:13.49,0:08:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku kehilangan niat\Nbuat bertarung.
Dialogue: 0,0:08:15.99,0:08:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mengganti\Norang yang kuanggap penting.
Dialogue: 0,0:08:18.74,0:08:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin tahu apa, sih?
Dialogue: 0,0:08:26.04,0:08:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat yang kau sebut Surga itu\Nseperti apa?
Dialogue: 0,0:08:35.97,0:08:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada tanamannya?
Dialogue: 0,0:08:47.98,0:08:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada rumah yang melindungimu dari angin?
Dialogue: 0,0:08:57.45,0:08:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada kursi favoritmu?
Dialogue: 0,0:09:01.37,0:09:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada jendela\Nbiar kau bisa terus melihat ke luar?
Dialogue: 0,0:09:07.21,0:09:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada makanan hangat?
Dialogue: 0,0:09:22.89,0:09:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi akan baik-baik saja sendirian, 'kan?
Dialogue: 0,0:09:26.35,0:09:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi pasti baik-baik saja.
Dialogue: 0,0:09:29.44,0:09:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita hampir sampai.
Dialogue: 0,0:09:31.90,0:09:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti bisa.
Dialogue: 0,0:09:34.24,0:09:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai rumah, kita harus apa?
Dialogue: 0,0:09:36.61,0:09:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun itu, aku mau mandi dulu.
Dialogue: 0,0:09:39.37,0:09:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lapar banget.
Dialogue: 0,0:09:40.87,0:09:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main ke rumahku saja.
Dialogue: 0,0:09:42.95,0:09:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyambut hangat\Nkehidupan dari luar Bumi.
Dialogue: 0,0:09:46.54,0:09:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita mungkin diserang.
Dialogue: 0,0:09:48.46,0:09:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi bisa bikin banyak futon, kok.
Dialogue: 0,0:09:52.30,0:09:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu intinya.
Dialogue: 0,0:09:54.80,0:09:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahasa kita sama.
Dialogue: 0,0:09:57.30,0:09:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua bisa berteman.
Dialogue: 0,0:10:00.18,0:10:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat yakin soal itu.
Dialogue: 0,0:10:02.60,0:10:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahasa yang sama?
Dialogue: 0,0:10:08.06,0:10:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin!
Dialogue: 0,0:10:09.56,0:10:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini? Lantainya basah.
Dialogue: 0,0:10:11.94,0:10:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha, maafkan Ibu.
Dialogue: 0,0:10:13.61,0:10:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu tak sengaja numpahin air.
Dialogue: 0,0:10:16.15,0:10:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, selamat datang.
Dialogue: 0,0:10:18.91,0:10:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, aku punya bunga baru.
Dialogue: 0,0:10:21.74,0:10:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik, 'kan?
Dialogue: 0,0:10:23.04,0:10:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:10:24.83,0:10:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan hari ini kesukaan Ayah lagi.
Dialogue: 0,0:10:26.58,0:10:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha, bukankah kau juga suka\Nsemur daging sapi?
Dialogue: 0,0:10:34.05,0:10:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena hal-hal inilah
Dialogue: 0,0:10:35.88,0:10:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia jadi tidak bahagia.
Dialogue: 0,0:10:46.68,0:10:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya enak.
Dialogue: 0,0:10:53.32,0:10:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, Yuki. Ini oleh-oleh buatmu.
Dialogue: 0,0:10:56.94,0:10:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pergi dulu, ya.
Dialogue: 0,0:10:59.49,0:11:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, jaga dirimu baik-baik.
Dialogue: 0,0:11:02.70,0:11:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah mau pergi?\NHati-hati di jalan, ya.
Dialogue: 0,0:11:18.09,0:11:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, lihat.
Dialogue: 0,0:11:21.26,0:11:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Yuki! Kau tidak nakal, 'kan?
Dialogue: 0,0:11:24.56,0:11:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kita terpisah,\Nhati kami selalu bersamamu.
Dialogue: 0,0:11:35.27,0:11:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wakil Ketua!
Dialogue: 0,0:11:36.19,0:11:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aoki!
Dialogue: 0,0:11:37.65,0:11:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, bilang kalau tak sanggup membawanya.
Dialogue: 0,0:11:41.86,0:11:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana aku bisa ngomong hal\Nyang mengecewakan begitu?
Dialogue: 0,0:11:44.70,0:11:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus berangkat\Nsebelum matahari terbenam.
Dialogue: 0,0:11:47.54,0:11:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:11:49.25,0:11:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, nanti telat makan malam.
Dialogue: 0,0:11:51.79,0:11:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu masalahnya?
Dialogue: 0,0:11:56.46,0:11:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sedang diuji sekarang.
Dialogue: 0,0:12:00.13,0:12:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diuji?
Dialogue: 0,0:12:03.47,0:12:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal apa yang kita yakini.
Dialogue: 0,0:12:06.05,0:12:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta cara kita bersikap.
Dialogue: 0,0:12:10.88,0:12:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin
Dialogue: 0,0:12:13.35,0:12:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa berbagi rasa sakit\Nkarena kita punya tubuh.
Dialogue: 0,0:12:17.65,0:12:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati kita juga bisa saling mengandalkan.
Dialogue: 0,0:12:21.65,0:12:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hampir sepuluh menit.
Dialogue: 0,0:12:33.46,0:12:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini!
Dialogue: 0,0:12:34.75,0:12:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, itu pintu keluarnya!
Dialogue: 0,0:12:36.42,0:12:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lompat!
Dialogue: 0,0:12:54.06,0:12:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil!
Dialogue: 0,0:12:55.23,0:12:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua lancar!
Dialogue: 0,0:12:56.31,0:12:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil mengalahkannya!
Dialogue: 0,0:13:19.67,0:13:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:13:23.22,0:13:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita…
Dialogue: 0,0:13:25.59,0:13:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih dalam bahaya.
Dialogue: 0,0:13:28.68,0:13:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:13:30.81,0:13:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk itu…
Dialogue: 0,0:13:33.31,0:13:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia masih hidup!
Dialogue: 0,0:13:38.23,0:13:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:13:45.53,0:13:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:13:47.24,0:13:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:48.16,0:13:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:13:49.78,0:13:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Messar, Hairo, Kai!
Dialogue: 0,0:13:52.24,0:13:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ke sini\Nbuat menyelamatkan kami, 'kan?
Dialogue: 0,0:13:53.95,0:13:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kenal mereka?
Dialogue: 0,0:13:55.21,0:13:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka itu rekannya Fushi.
Dialogue: 0,0:13:57.29,0:13:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ligard Tonari yang kasih tahu kami.
Dialogue: 0,0:14:01.71,0:14:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Fushi juga tahu?
Dialogue: 0,0:14:04.01,0:14:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bon mungkin sudah tahu Fushi di mana\Ndan sedang ke sana.
Dialogue: 0,0:14:07.34,0:14:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia akan aman sendirian?
Dialogue: 0,0:14:09.60,0:14:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia tak pergi sendirian, deh.
Dialogue: 0,0:14:13.18,0:14:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani-beraninya kau sentuh anak-anak ini!
Dialogue: 0,0:14:16.39,0:14:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan pedang keadilanku ini!
Dialogue: 0,0:14:20.65,0:14:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hirotoshi!
Dialogue: 0,0:14:22.11,0:14:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:14:23.07,0:14:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, semuanya, kita pulang!
Dialogue: 0,0:14:26.49,0:14:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cepat naik ke punggung Tuan Beruang!
Dialogue: 0,0:14:33.04,0:14:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa!
Dialogue: 0,0:14:36.08,0:14:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gigih banget, sih.
Dialogue: 0,0:14:38.17,0:14:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, ayo!
Dialogue: 0,0:14:39.67,0:14:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:14:41.29,0:14:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kita melakukan ini tanpa Fushi?
Dialogue: 0,0:14:43.30,0:14:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bisa.
Dialogue: 0,0:15:03.36,0:15:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:15:04.69,0:15:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya pedangku kurang mempan, deh.
Dialogue: 0,0:15:11.66,0:15:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan dia!
Dialogue: 0,0:15:18.04,0:15:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tangki airnya!
Dialogue: 0,0:15:19.12,0:15:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Lari!
Dialogue: 0,0:15:20.58,0:15:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:15:21.54,0:15:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan mati kalau kena airnya!
Dialogue: 0,0:15:30.22,0:15:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Beruang, awas!
Dialogue: 0,0:15:33.80,0:15:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:15:35.10,0:15:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:36.06,0:15:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana makhluk itu?
Dialogue: 0,0:15:48.28,0:15:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa begini?
Dialogue: 0,0:15:50.49,0:15:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hidup lagi!
Dialogue: 0,0:15:51.66,0:15:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku berlebihan, ya.
Dialogue: 0,0:15:59.33,0:16:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonari?
Dialogue: 0,0:16:09.80,0:16:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek! Apa-apaan kau?
Dialogue: 0,0:16:11.72,0:16:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi.
Dialogue: 0,0:16:17.06,0:16:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonari?
Dialogue: 0,0:16:18.18,0:16:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tidak mungkin.\NSebenarnya apa yang terjadi, sih?
Dialogue: 0,0:16:20.64,0:16:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:16:22.60,0:16:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Nokker, 'kan?
Dialogue: 0,0:16:24.23,0:16:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Fushi seharusnya\Nsudah menghancurkan mereka semua.
Dialogue: 0,0:16:27.86,0:16:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari gelagatnya belakangan ini,\Nakhirnya aku paham.
Dialogue: 0,0:16:31.15,0:16:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu terjadi di luar sepengetahuan kita.
Dialogue: 0,0:16:34.49,0:16:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 500 tahun.
Dialogue: 0,0:16:36.03,0:16:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja kalau berevolusi.
Dialogue: 0,0:16:40.37,0:16:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya ngobrol.
Dialogue: 0,0:16:42.16,0:16:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kita bunuhkah?
Dialogue: 0,0:16:43.33,0:16:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku tega.
Dialogue: 0,0:16:45.08,0:16:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia teman kita!
Dialogue: 0,0:16:51.01,0:16:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:16:55.39,0:16:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:56.47,0:16:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menghabisinya\Nsebelum kita yang dihabisi.
Dialogue: 0,0:17:13.10,0:17:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, ada apa?
Dialogue: 0,0:17:25.50,0:17:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:17:29.55,0:17:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hasilnya?
Dialogue: 0,0:17:31.80,0:17:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telat.
Dialogue: 0,0:17:38.43,0:17:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apaan ini?
Dialogue: 0,0:17:40.68,0:17:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kurungan besi\Nyang kita pakai di Renril, 'kan?
Dialogue: 0,0:17:43.85,0:17:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi.
Dialogue: 0,0:17:45.10,0:17:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bukan Nokker!
Dialogue: 0,0:17:48.48,0:17:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Messar dan yang lainnya terjebak.
Dialogue: 0,0:17:51.78,0:17:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini perbuatan Fu.
Dialogue: 0,0:17:53.49,0:17:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, kita harus apa sekarang?
Dialogue: 0,0:17:55.95,0:17:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, lihat ke sana!
Dialogue: 0,0:18:09.96,0:18:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia melihat kita.
Dialogue: 0,0:18:12.59,0:18:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ia akan ke sini?
Dialogue: 0,0:18:14.30,0:18:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat…
Dialogue: 0,0:18:18.93,0:18:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat…
Dialogue: 0,0:19:06.56,0:19:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak apa-apa?
Dialogue: 0,0:19:07.64,0:19:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baik-baik saja.
Dialogue: 0,0:19:08.56,0:19:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Bagaimana keadaannya sekarang?
Dialogue: 0,0:19:11.19,0:19:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seakan-akan waktu berhenti.
Dialogue: 0,0:19:13.90,0:19:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka membeku di tempat.
Dialogue: 0,0:19:25.20,0:19:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung aku tepat waktu.
Dialogue: 0,0:19:30.08,0:19:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:19:31.08,0:19:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:20:07.24,0:20:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, jangan injak airnya!
Dialogue: 0,0:20:16.38,0:20:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat sekarang! Dia Satoru!
Dialogue: 0,0:20:18.30,0:20:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kenal dia?
Dialogue: 0,0:20:20.38,0:20:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu bareng Fushi dan…
Dialogue: 0,0:20:22.89,0:20:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aoki, yang setahun lebih muda dari kita.
Dialogue: 0,0:20:26.10,0:20:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bareng Fushi?
Dialogue: 0,0:20:27.81,0:20:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama kakakku?
Dialogue: 0,0:20:31.48,0:20:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa pindahkan itu ke sini?
Dialogue: 0,0:20:33.85,0:20:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:20:44.53,0:20:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa gerak, ya.
Dialogue: 0,0:20:54.37,0:20:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku harus apa?
Dialogue: 0,0:20:58.34,0:21:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa harus kubunuh mereka atau…
Dialogue: 0,0:21:02.76,0:21:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:21:05.39,0:21:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih harus istirahat.
Dialogue: 0,0:21:07.14,0:21:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri.
Dialogue: 0,0:21:10.52,0:21:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa. Sekarang sudah aman.
Dialogue: 0,0:21:13.94,0:21:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang aman, coba?
Dialogue: 0,0:21:17.94,0:21:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah baikan.
Dialogue: 0,0:21:21.07,0:21:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tetap di sini.
Dialogue: 0,0:21:23.49,0:21:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menetap buat penuhi tugasku\Nsebagai pimpinan Pelindung.
Dialogue: 0,0:21:27.20,0:21:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau mengecewakan leluhur kami.
Dialogue: 0,0:21:31.04,0:21:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau pamitan sama kami?
Dialogue: 0,0:21:34.46,0:21:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau sekadar ngomong begitu\Nbuat bikin kami kesal?
Dialogue: 0,0:21:37.79,0:21:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha, kau bisa pergi\Nke mana pun sesukamu.
Dialogue: 0,0:21:41.76,0:21:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kau mau penuhi tugas\Nsebagai pimpinan,
Dialogue: 0,0:21:44.05,0:21:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus cepat bertindak.
Dialogue: 0,0:21:46.47,0:21:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhentilah menguji Fushi.
Dialogue: 0,0:21:48.01,0:21:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, termasuk kejadian\Ndi sekolah sekarang ini.
Dialogue: 0,0:21:50.39,0:21:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan agresi Nokker\Nyang menyerang warga sipil.
Dialogue: 0,0:22:01.61,0:22:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku akan berusaha.
Dialogue: 0,0:22:07.53,0:22:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada makanan yang tak kau suka?
Dialogue: 0,0:22:10.58,0:22:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau makanan yang bikin alergi?
Dialogue: 0,0:22:12.37,0:22:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba nanya begitu?
Dialogue: 0,0:22:14.25,0:22:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bicarakan masa depan\Nbersama para Pelindung.
Dialogue: 0,0:22:18.58,0:22:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kita diskusikan\Nsambil makan nabe di rumahku.
Dialogue: 0,0:22:22.00,0:22:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua?
Dialogue: 0,0:22:24.38,0:22:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau memercayai kami?
Dialogue: 0,0:22:28.47,0:22:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi di masa lalu,
Dialogue: 0,0:22:30.51,0:22:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus coba memercayai masa depan.
Dialogue: 0,0:22:33.27,0:22:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali kita ke kedai krep, yuk.
Dialogue: 0,0:22:36.56,0:22:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga boleh gabung Klub Riset Hal Gaib.
Dialogue: 0,0:22:39.52,0:22:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita coba radiestesi bareng-bareng.
Dialogue: 0,0:22:44.07,0:22:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Napa aku bisa memercayai kalian juga?
Dialogue: 0,0:24:32.09,0:24:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Yuki dan yang lainnya\Nmulai bernapas lega,
Dialogue: 0,0:24:35.05,0:24:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan Pelindung memberi mereka\Ntanda pertemanan.
