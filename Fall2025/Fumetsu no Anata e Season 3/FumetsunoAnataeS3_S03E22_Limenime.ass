Dialogue: 0,0:01:58.11,0:01:59.91,tanda,,0000,0000,0000,,TO YOUR ETERNITY\NSEASON 3
Dialogue: 0,0:01:59.99,0:02:03.99,tanda,,0000,0000,0000,,#22 UNTUK FUSHI
Dialogue: 0,0:15:39.64,0:15:41.98,tanda,,0000,0000,0000,,TO YOUR ETERNITY\NSEASON 3
Dialogue: 0,0:00:01.12,0:00:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habislah aku.
Dialogue: 0,0:00:03.33,0:00:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang berjalan sesuai keinginanku.
Dialogue: 0,0:00:08.88,0:00:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi sudah memutuskan\Napa yang ingin dia lakukan.
Dialogue: 0,0:00:13.43,0:00:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, semuanya.
Dialogue: 0,0:00:15.39,0:00:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nono.
Dialogue: 0,0:00:18.43,0:00:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memutuskan untuk hidup\Ndi dunia ini apa adanya.
Dialogue: 0,0:00:27.15,0:00:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi sudah memutuskan.
Dialogue: 0,0:02:04.75,0:02:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun!
Dialogue: 0,0:02:07.16,0:02:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kehidupan di sana?
Dialogue: 0,0:02:09.28,0:02:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa berjalan lancar?
Dialogue: 0,0:02:10.96,0:02:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru awal. Ini hanya permulaan.
Dialogue: 0,0:02:13.75,0:02:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha peringkat pertama di kelas\Nuntuk Matematika dan Fisika.
Dialogue: 0,0:02:17.55,0:02:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bangga\Nkita lulus dari SMP yang sama.
Dialogue: 0,0:02:20.68,0:02:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasabe, kau sekelas dengan Mizuha?
Dialogue: 0,0:02:23.26,0:02:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, pelajarannya terasa sangat sulit.
Dialogue: 0,0:02:25.14,0:02:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha, kau akan ambil jurusan\Nyang berkaitan dengan itu saat kuliah?
Dialogue: 0,0:02:29.02,0:02:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semacam itu. Kalau kau, Hanna?
Dialogue: 0,0:02:30.90,0:02:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi guru TK.
Dialogue: 0,0:02:33.86,0:02:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kudengar aku harus bisa bermain piano.
Dialogue: 0,0:02:35.69,0:02:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku belum pernah bermain piano,\Njadi entah harus bagaimana.
Dialogue: 0,0:02:38.53,0:02:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jari-jariku juga sangat pendek.
Dialogue: 0,0:02:41.87,0:02:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piano… Mizuha,\Ndahulu kau bermain piano, kan?
Dialogue: 0,0:02:45.08,0:02:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ajari aku!
Dialogue: 0,0:02:46.45,0:02:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, lain kali, ya.
Dialogue: 0,0:02:50.67,0:02:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:02:52.00,0:02:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membuatku kaget.
Dialogue: 0,0:02:53.46,0:02:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuha, selamat ulang tahun.
Dialogue: 0,0:02:55.46,0:02:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau inginkan?\NAku bisa membuatkan apa pun untukmu.
Dialogue: 0,0:02:57.51,0:03:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak suka jika kau bilang begitu.\NSama sekali tidak menyentuh.
Dialogue: 0,0:03:00.93,0:03:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, kau luar biasa.
Dialogue: 0,0:03:03.55,0:03:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar tentangmu,
Dialogue: 0,0:03:04.85,0:03:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak kusangka\Nkau masih sama seperti dulu.
Dialogue: 0,0:03:06.43,0:03:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan? Ini sangat tidak adil.
Dialogue: 0,0:03:08.31,0:03:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kita yang berusia 18 tahun.
Dialogue: 0,0:03:11.14,0:03:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Yuki tidak datang?
Dialogue: 0,0:03:13.48,0:03:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:03:15.32,0:03:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bergegas kemari, tapi tetap terlambat.
Dialogue: 0,0:03:17.36,0:03:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun, Kak Mizuha!
Dialogue: 0,0:03:19.78,0:03:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mizuha yang berusia 18 tahun\Nmasih secantik dulu.
Dialogue: 0,0:03:23.66,0:03:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:24.91,0:03:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, lama tidak bertemu.
Dialogue: 0,0:03:26.49,0:03:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang ada di sampingmu?
Dialogue: 0,0:03:28.50,0:03:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Ini aku.
Dialogue: 0,0:03:32.79,0:03:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, kau punya pacar?
Dialogue: 0,0:03:35.21,0:03:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa. Aku terlalu sibuk syuting.
Dialogue: 0,0:03:39.17,0:03:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menonton kanalmu tentang Nokker.
Dialogue: 0,0:03:43.30,0:03:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kami agak kesulitan.
Dialogue: 0,0:03:45.39,0:03:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa. Kau baru mulai, kan?
Dialogue: 0,0:03:47.85,0:03:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar!
Dialogue: 0,0:03:49.43,0:03:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Diam, Yuki! Jangan berisik!\N- Aku akan berusaha!
Dialogue: 0,0:03:53.06,0:03:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bir di sini!
Dialogue: 0,0:03:54.44,0:03:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kau mau minum bir.
Dialogue: 0,0:03:57.15,0:03:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku bisa ambil motornya besok.\N- Messar, ada apa?
Dialogue: 0,0:03:59.48,0:04:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bukan itu masalahnya.\N- Bon?
Dialogue: 0,0:04:01.24,0:04:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Permisi, Pelayan!\N- Bon ada di stasiun TV.
Dialogue: 0,0:04:02.61,0:04:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonari.
Dialogue: 0,0:04:03.74,0:04:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kau tak boleh minum!
Dialogue: 0,0:04:05.66,0:04:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau masih di bawah umur!\N- Sebelah sini!
Dialogue: 0,0:04:07.62,0:04:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hanna, hentikan dia!\N- Uangmu habis lagi?
Dialogue: 0,0:04:11.71,0:04:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau menciptakan uang.
Dialogue: 0,0:04:13.50,0:04:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau Aiko marah padaku.
Dialogue: 0,0:04:15.54,0:04:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kututup teleponnya, ya.
Dialogue: 0,0:04:18.83,0:04:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:04:21.26,0:04:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satoru suka warna apa?
Dialogue: 0,0:04:22.76,0:04:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hitam. Dia suka warna hitam.
Dialogue: 0,0:04:24.38,0:04:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu kurang manis?
Dialogue: 0,0:04:26.39,0:04:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nkau bisa putuskan sendiri, Sumika.
Dialogue: 0,0:04:28.85,0:04:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, ya.
Dialogue: 0,0:04:33.14,0:04:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Messar, sudah kubilang\Naku tidak akan membuatnya!
Dialogue: 0,0:04:37.06,0:04:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupon pijat gratis? Aku tidak butuh itu!
Dialogue: 0,0:04:39.40,0:04:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dah.
Dialogue: 0,0:04:40.32,0:04:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tampak sibuk sekali.
Dialogue: 0,0:04:41.94,0:04:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa semua orang\Nmendatangiku dengan masalahnya.
Dialogue: 0,0:04:43.65,0:04:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:44.74,0:04:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk memberitahumu\Nbahwa ada hadiah yang kuinginkan.
Dialogue: 0,0:04:49.08,0:04:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa keinginanmu?
Dialogue: 0,0:04:50.49,0:04:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kata saja.
Dialogue: 0,0:04:51.58,0:04:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kata?
Dialogue: 0,0:04:53.46,0:04:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kau bilang, "Baiklah."
Dialogue: 0,0:04:55.71,0:04:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:04:57.29,0:05:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin kau bilang, "Baiklah."
Dialogue: 0,0:05:00.21,0:05:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan katakan hal lain.
Dialogue: 0,0:05:02.05,0:05:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku merasa kau akan memintaku\Nmelakukan hal aneh?
Dialogue: 0,0:05:05.01,0:05:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sepuluh menit dari sekarang.
Dialogue: 0,0:05:06.84,0:05:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:05:08.18,0:05:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:05:10.18,0:05:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku berencana\Nmeninggalkan kalian selamanya.
Dialogue: 0,0:05:15.69,0:05:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ke luar negeri.
Dialogue: 0,0:05:17.40,0:05:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang sudah tahu tentang Nokker.
Dialogue: 0,0:05:20.11,0:05:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan Pelindung\Nmasih mengkhawatirkan hal ini.
Dialogue: 0,0:05:22.69,0:05:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ke luar negeri\Nuntuk memperluas jangkauan.
Dialogue: 0,0:05:24.95,0:05:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu saja.
Dialogue: 0,0:05:26.70,0:05:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada banyak pengikut.
Dialogue: 0,0:05:29.16,0:05:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bekerja sama dengan mereka
Dialogue: 0,0:05:30.78,0:05:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menemukan solusi masalah Nokker,
Dialogue: 0,0:05:32.83,0:05:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kini hal tersebut\Nsudah menjadi perbincangan publik.
Dialogue: 0,0:05:35.33,0:05:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pihak yang memahami Nokker,
Dialogue: 0,0:05:39.71,0:05:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin punya kewajiban\Nuntuk menangani masalah ini.
Dialogue: 0,0:05:43.80,0:05:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menciptakan dunia\Nyang akan kau sukai.
Dialogue: 0,0:05:49.05,0:05:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pergi seperti ini.
Dialogue: 0,0:05:51.51,0:05:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terbang besok.
Dialogue: 0,0:05:53.43,0:05:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku punya permintaan.
Dialogue: 0,0:05:56.27,0:05:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kau merahasiakan ini\Ndari yang lainnya untuk saat ini?
Dialogue: 0,0:05:59.44,0:06:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau tahu di mana aku.
Dialogue: 0,0:06:01.15,0:06:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:06:03.28,0:06:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin melihat\Nmereka semua sedih lagi.
Dialogue: 0,0:06:06.90,0:06:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera menemuimu…
Dialogue: 0,0:06:09.28,0:06:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengerti?
Dialogue: 0,0:06:11.28,0:06:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:12.24,0:06:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kau akan menemuiku.
Dialogue: 0,0:06:14.29,0:06:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan saja.
Dialogue: 0,0:06:16.75,0:06:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan aku berada di suatu tempat\Ndi dunia ini.
Dialogue: 0,0:06:20.21,0:06:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahwa ada gadis bernama Mizuha\Ndengan penampilan seperti ini.
Dialogue: 0,0:06:25.09,0:06:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:26.72,0:06:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya satu permintaan terakhir.
Dialogue: 0,0:06:29.09,0:06:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kau memejamkan matamu\Nselama 30 detik?
Dialogue: 0,0:07:16.52,0:07:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, kau lamban sekali.
Dialogue: 0,0:07:17.93,0:07:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bertelepon dengan siapa?
Dialogue: 0,0:07:19.43,0:07:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Di mana Mizuha?
Dialogue: 0,0:07:25.65,0:07:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu ke mana Kak Mizuha pergi.
Dialogue: 0,0:07:28.86,0:07:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, bersemangatlah.
Dialogue: 0,0:07:30.78,0:07:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Videonya sudah diedit. Tolong periksa.
Dialogue: 0,0:07:34.37,0:07:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu menyenangkan?
Dialogue: 0,0:07:35.95,0:07:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Model miniatur?
Dialogue: 0,0:07:37.66,0:07:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan-bahannya kudapat dari teman daring\Nyang sudah pensiun dari hobi ini.
Dialogue: 0,0:07:41.00,0:07:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu begitu melakukannya, aku ketagihan.
Dialogue: 0,0:07:44.79,0:07:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berencana syuting dengan model monster\Nusai menyelesaikan model kota.
Dialogue: 0,0:07:49.38,0:07:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga mau mencobanya, Satoru?
Dialogue: 0,0:07:51.30,0:07:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak mau menyentuhnya lagi.
Dialogue: 0,0:07:54.09,0:07:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dahulu kau melakukan ini?
Dialogue: 0,0:07:56.43,0:07:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau boleh melakukannya lagi kapan saja.
Dialogue: 0,0:07:58.18,0:07:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:07:59.56,0:08:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, kita harus pergi.
Dialogue: 0,0:08:01.52,0:08:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan sisanya kepada kami.
Dialogue: 0,0:08:04.90,0:08:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengandalkanmu.
Dialogue: 0,0:08:05.86,0:08:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok Hitam, kami pergi duluan.
Dialogue: 0,0:08:07.48,0:08:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:09.44,0:08:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nono, maaf sudah merepotkan.
Dialogue: 0,0:08:13.03,0:08:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa.
Dialogue: 0,0:08:13.95,0:08:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:08:15.32,0:08:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk perpisahan terakhir.
Dialogue: 0,0:08:17.99,0:08:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jaga Fushi.
Dialogue: 0,0:08:19.70,0:08:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perpisahan?
Dialogue: 0,0:08:20.66,0:08:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu "terakhir"?
Dialogue: 0,0:08:22.21,0:08:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari terakhirku sebagai diriku.
Dialogue: 0,0:08:33.29,0:08:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya adalah besok.
Dialogue: 0,0:08:34.72,0:08:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah empat tahun\Nsejak aku mendapatkan tubuh ini.
Dialogue: 0,0:08:37.29,0:08:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat tahun telah berlalu sejak aku kemari.
Dialogue: 0,0:08:39.52,0:08:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai besok,
Dialogue: 0,0:08:40.42,0:08:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua yang kumiliki akan hilang.
Dialogue: 0,0:08:43.80,0:08:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kekuatan yang tak pantas\Ndimiliki tubuh manusia.
Dialogue: 0,0:08:47.56,0:08:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua, kenangan dari penggunaan\Nkekuatan itu.
Dialogue: 0,0:08:51.11,0:08:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan melupakan kalian semua.
Dialogue: 0,0:08:53.15,0:08:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus hidup, hanya mewarisi\Nkenangan Satoru sebagai manusia.
Dialogue: 0,0:08:56.95,0:08:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau mencoba memberitahuku\Nsiapa aku sebenarnya,
Dialogue: 0,0:08:59.66,0:09:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku di masa depan\Nmungkin tak akan mengerti.
Dialogue: 0,0:09:02.79,0:09:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang pengendali\Ntelah meninggalkan posisinya.
Dialogue: 0,0:09:04.96,0:09:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya terserah pada kalian.
Dialogue: 0,0:09:07.58,0:09:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah kebebasan yang pernah kau bicarakan?
Dialogue: 0,0:09:13.34,0:09:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi tak perlu mendengarkan\Nperintah siluman lagi.
Dialogue: 0,0:09:17.14,0:09:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum ingatanmu hilang,
Dialogue: 0,0:09:18.97,0:09:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuharap kau bisa beri tahu semuanya\Nsiapa kau sebenarnya.
Dialogue: 0,0:09:21.97,0:09:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, yang selalu kau inginkan\Nadalah anak yang tak penting?
Dialogue: 0,0:09:26.65,0:09:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, seleramu buruk sekali.
Dialogue: 0,0:09:28.86,0:09:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa dengan mudah\Nmenghapus ingatanmu sendiri.
Dialogue: 0,0:09:31.65,0:09:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dunia ini cukup damai bagimu\Nuntuk melupakan semuanya tanpa penyesalan?
Dialogue: 0,0:09:36.91,0:09:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kami lakukan,\Norang-orang yang kau tinggalkan?
Dialogue: 0,0:09:39.45,0:09:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika kami kalah lagi dari Nokker?
Dialogue: 0,0:09:41.41,0:09:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika Fushi tak bisa bangkit lagi?
Dialogue: 0,0:09:43.87,0:09:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Nokker benar-benar ada\Ndi dalam tubuh kami,
Dialogue: 0,0:09:46.75,0:09:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami, bahkan Fushi,\Ntak akan bisa menemukannya.
Dialogue: 0,0:09:49.84,0:09:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika mereka\Nmembunuh kami sekarang?
Dialogue: 0,0:09:52.30,0:09:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi memahami semua ini\Ndan masih memilih memercayai Nokker.
Dialogue: 0,0:09:55.72,0:09:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya\Ndia tak akan mewarisi kekuatanku.
Dialogue: 0,0:09:58.68,0:09:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:09:59.72,0:10:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:00.64,0:10:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, tapi…
Dialogue: 0,0:10:02.10,0:10:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti kekhawatiranmu.
Dialogue: 0,0:10:04.52,0:10:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak tahu yang kau inginkan\Nadalah hidup selamanya
Dialogue: 0,0:10:08.48,0:10:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau memusnahkan semua Nokker.
Dialogue: 0,0:10:12.40,0:10:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi meski kau mendapatkan keinginanmu,\Nbukan berarti kau akan bahagia.
Dialogue: 0,0:10:16.65,0:10:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuki, bawa itu kemari.
Dialogue: 0,0:10:20.16,0:10:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,
Dialogue: 0,0:10:21.53,0:10:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku membuang satu-satunya kekuatan\Nyang sanggup mengendalikan Nokker.
Dialogue: 0,0:10:25.58,0:10:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada mencemaskan harus apa sekarang,
Dialogue: 0,0:10:27.75,0:10:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}fokuslah untuk melewati hari esok.
Dialogue: 0,0:10:30.17,0:10:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan lebih bahagia seperti itu.
Dialogue: 0,0:10:33.63,0:10:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panci tembikar?
Dialogue: 0,0:10:35.09,0:10:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupercayakan ini kepadamu.
Dialogue: 0,0:10:36.76,0:10:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berisi kenanganku.
Dialogue: 0,0:10:38.55,0:10:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah saat kau bosan.
Dialogue: 0,0:10:41.55,0:10:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenangan…
Dialogue: 0,0:10:42.93,0:10:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kau mau ke mana?
Dialogue: 0,0:10:44.77,0:10:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang.
Dialogue: 0,0:10:45.77,0:10:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panti asuhan menyuruhku\Npulang lebih awal hari ini.
Dialogue: 0,0:10:48.89,0:10:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini konyol.
Dialogue: 0,0:10:50.31,0:10:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar berandal. Itu saja?
Dialogue: 0,0:10:52.86,0:10:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku hanya datang untuk berpamitan.
Dialogue: 0,0:10:56.19,0:10:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhabisi kau sebelum ingatanmu hilang.
Dialogue: 0,0:10:58.11,0:10:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Messar!
Dialogue: 0,0:10:59.57,0:11:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, kuberi tahu satu hal terakhir.
Dialogue: 0,0:11:01.03,0:11:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau menyerah lagi,
Dialogue: 0,0:11:02.87,0:11:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selalu bawa teman-temanmu bersamamu.
Dialogue: 0,0:11:05.24,0:11:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, takkan ada yang terjadi padamu\Nmeski kau menjadi buah atau kepiting.
Dialogue: 0,0:11:08.91,0:11:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:11:10.96,0:11:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau yang membawa Fu kemari,
Dialogue: 0,0:11:15.00,0:11:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus menjaganya sampai akhir!
Dialogue: 0,0:11:17.59,0:11:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Fu masih kecil,\NMarch mengajarinya cara makan,
Dialogue: 0,0:11:22.26,0:11:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cara ke toilet,
Dialogue: 0,0:11:24.10,0:11:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan cara berterima kasih.
Dialogue: 0,0:11:26.56,0:11:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang pernah kau lakukan untuk Fu?
Dialogue: 0,0:11:30.94,0:11:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}March.
Dialogue: 0,0:11:34.36,0:11:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:11:35.86,0:11:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak melakukan apa pun.
Dialogue: 0,0:11:42.28,0:11:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}March.
Dialogue: 0,0:11:44.24,0:11:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberitahumu mewakilinya.
Dialogue: 0,0:11:47.29,0:11:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membuatku bertemu teman-teman\Nyang luar biasa.
Dialogue: 0,0:11:54.79,0:11:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laporan perkembangan.
Dialogue: 0,0:11:57.38,0:12:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan menjadi yang terakhir.
Dialogue: 0,0:12:00.84,0:12:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya wasiat yang kutinggalkan\Nuntuk fragmenku.
Dialogue: 0,0:12:06.01,0:12:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada awalnya, aku bukan apa-apa.
Dialogue: 0,0:12:10.35,0:12:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya punya rasa bahwa aku ada
Dialogue: 0,0:12:14.23,0:12:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ada banyak yang lainnya di sekitarku.
Dialogue: 0,0:12:18.36,0:12:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memainkan permainan\Nyang mengubah sensasi kami.
Dialogue: 0,0:12:23.53,0:12:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami meregang, membalut,\Ndan menyebar, memberinya makna.
Dialogue: 0,0:12:29.37,0:12:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mewariskannya kepada yang lain.
Dialogue: 0,0:12:31.50,0:12:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga menerimanya.
Dialogue: 0,0:12:34.50,0:12:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bebas menciptakan apa pun.
Dialogue: 0,0:12:37.25,0:12:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kami mengulanginya berulang kali.
Dialogue: 0,0:12:40.67,0:12:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana, konsep mustahil tidak ada.
Dialogue: 0,0:12:43.38,0:12:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup begitu lama\Nhingga kupikir itu untuk selamanya.
Dialogue: 0,0:12:49.81,0:12:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku bosan.
Dialogue: 0,0:12:53.85,0:12:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu dari mana asal perasaan ini
Dialogue: 0,0:12:56.61,0:12:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau hanya aku yang merasakannya.
Dialogue: 0,0:13:00.48,0:13:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kupikir-pikir,\Nmungkin aku hanya serakah.
Dialogue: 0,0:13:04.99,0:13:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung mulai mengerjakan\Nsesuatu yang baru.
Dialogue: 0,0:13:08.58,0:13:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membangun surgaku sendiri.
Dialogue: 0,0:13:13.96,0:13:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dunia yang terus berubah\Ndengan sendirinya.
Dialogue: 0,0:13:17.29,0:13:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuat salju dan memanggil badai.
Dialogue: 0,0:13:20.71,0:13:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang melihat mereka berlarian,\Ntak tahu harus bersembunyi di mana.
Dialogue: 0,0:13:24.30,0:13:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membatasi mereka.
Dialogue: 0,0:13:27.18,0:13:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka punya bahasa dan masa hidup.
Dialogue: 0,0:13:30.26,0:13:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuanku adalah menciptakan dunia\Nyang sama sekali tidak seperti duniaku.
Dialogue: 0,0:13:34.23,0:13:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh mereka yang rapuh\Nkelak segera berhenti bergerak.
Dialogue: 0,0:13:37.40,0:13:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mati, tubuh mereka akan membusuk,\Nberbau, dan menjadi jelek.
Dialogue: 0,0:13:41.40,0:13:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi entah kenapa,\Nsemua orang mengelilingi mereka.
Dialogue: 0,0:13:44.78,0:13:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu sangat indah.
Dialogue: 0,0:13:53.08,0:13:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa kusadari,\Naku ingin memasuki dunia fana ini.
Dialogue: 0,0:13:58.71,0:14:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski yang kurasakan di sini
Dialogue: 0,0:14:01.04,0:14:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah hal terakhir dalam hidupku,\Nitu sudah cukup bagiku.
Dialogue: 0,0:14:04.34,0:14:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi seseorang harus mengelola tanah ini\Nmenggantikanku.
Dialogue: 0,0:14:09.51,0:14:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga butuh kemampuan\Nuntuk menjaga sesuatu.
Dialogue: 0,0:14:13.22,0:14:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencoba menciptakan Doki
Dialogue: 0,0:14:15.68,0:14:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mencoba menyimpan informasi\Ndi mangkuk tembikar.
Dialogue: 0,0:14:19.31,0:14:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kehidupan abadi\Ntak ada di dunia itu.
Dialogue: 0,0:14:24.11,0:14:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, hidup Doki juga singkat,\Nsama seperti yang lainnya.
Dialogue: 0,0:14:29.11,0:14:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku membuat sesuatu yang istimewa.
Dialogue: 0,0:14:33.04,0:14:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk dengan tubuh terkuat,
Dialogue: 0,0:14:36.08,0:14:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi.
Dialogue: 0,0:14:37.75,0:14:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keabadianku akan menghilang.
Dialogue: 0,0:14:40.92,0:14:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku senang\Nkeinginanku akhirnya terwujud.
Dialogue: 0,0:14:47.34,0:14:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun
Dialogue: 0,0:14:51.35,0:14:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun
Dialogue: 0,0:14:58.39,0:15:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok Hitam, kau di sana?
Dialogue: 0,0:15:16.87,0:15:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun, Satoru
Dialogue: 0,0:15:22.25,0:15:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok Hitam, apa kau...
Dialogue: 0,0:15:27.59,0:15:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun
Dialogue: 0,0:15:36.52,0:15:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, semuanya.
Dialogue: 0,0:15:43.36,0:15:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok Hitam meninggalkan kita.
Dialogue: 0,0:15:49.61,0:15:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:15:51.07,0:15:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat badanku tidak bertambah!
Dialogue: 0,0:15:54.24,0:15:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya.
Dialogue: 0,0:15:57.49,0:15:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}March, ada apa?
Dialogue: 0,0:15:58.91,0:16:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengeriting rambutku.
Dialogue: 0,0:16:01.67,0:16:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berubah menjadi sarang burung.
Dialogue: 0,0:16:04.75,0:16:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:06.13,0:16:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:16:07.67,0:16:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau menertawakanku, bukan?\N- Maaf.
Dialogue: 0,0:16:10.76,0:16:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku belum sepenuhnya paham\Napa maksud Sosok Hitam,
Dialogue: 0,0:16:14.47,0:16:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa dia mungkin mencoba mengatakan
Dialogue: 0,0:16:17.14,0:16:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa apa pun situasinya,\Naku akan selalu bosan dan tidak puas.
Dialogue: 0,0:16:20.81,0:16:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:16:22.27,0:16:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada sesuatu yang masih kurang dariku.
Dialogue: 0,0:16:24.65,0:16:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang apa?
Dialogue: 0,0:16:25.56,0:16:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otot-ototku. Menurutmu otot apa\Nyang masih kurang dariku?
Dialogue: 0,0:16:30.28,0:16:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyerah.
Dialogue: 0,0:16:32.65,0:16:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untungnya,\Ntak ada Nokker jahat sekarang.
Dialogue: 0,0:16:36.07,0:16:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, ini masalah kami.
Dialogue: 0,0:16:38.37,0:16:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus buktikan\Nbahwa tubuh kami tak seremeh itu
Dialogue: 0,0:16:42.04,0:16:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga tak masalah\Njika Nokker mengambilnya.
Dialogue: 0,0:16:44.71,0:16:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau mendapatkan keinginanmu,\Nbukan berarti kau akan bahagia.
Dialogue: 0,0:16:48.71,0:16:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai bertanya-tanya\Napa arti kebahagiaan bagi kita.
Dialogue: 0,0:16:53.63,0:16:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Messar selalu terlihat bahagia.
Dialogue: 0,0:16:55.76,0:16:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sesuatu yang harus kupelajari darinya.
Dialogue: 0,0:16:58.01,0:17:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin cara hidupnya akan menginspirasiku.
Dialogue: 0,0:17:00.85,0:17:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Fushi?
Dialogue: 0,0:17:02.52,0:17:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku terlihat begitu santai?
Dialogue: 0,0:17:05.56,0:17:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sama sekali tak tampak sedih.
Dialogue: 0,0:17:07.19,0:17:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meninggalkan kesedihanku di Renril.
Dialogue: 0,0:17:10.31,0:17:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Tuan Putri Alma?
Dialogue: 0,0:17:13.78,0:17:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, tak ada kejadian\Nyang lebih buruk dari itu.
Dialogue: 0,0:17:16.95,0:17:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu.
Dialogue: 0,0:17:18.53,0:17:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya jalan\Nadalah naik usai mencapai titik terendah.
Dialogue: 0,0:17:20.54,0:17:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:17:22.86,0:17:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan sebelumnya,\Nhidup di masa kini tak terlalu buruk.
Dialogue: 0,0:17:27.79,0:17:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Messar hanya minum dan berjudi\Nagar otaknya merasa lebih baik.
Dialogue: 0,0:17:33.34,0:17:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya ilusi. Itu bukan kebahagiaan.
Dialogue: 0,0:17:36.30,0:17:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kau tahu apa itu kebahagiaan?
Dialogue: 0,0:17:39.14,0:17:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:17:40.18,0:17:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kertas apa ini?
Dialogue: 0,0:17:41.47,0:17:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sertifikat keahlian pembuat kue\Nmilikku.
Dialogue: 0,0:17:45.06,0:17:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu apa itu, tapi itu luar biasa!
Dialogue: 0,0:17:47.06,0:17:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat!
Dialogue: 0,0:17:48.31,0:17:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hairo bilang kebahagiaan adalah sesuatu\Nyang bisa diraih melalui kerja keras.
Dialogue: 0,0:17:54.15,0:17:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iddy telah belajar\Nmenggunakan kalimat sederhana.
Dialogue: 0,0:17:57.74,0:18:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para guru, orang tua Yuki,\Ndan banyak orang lain telah mengajarinya.
Dialogue: 0,0:18:03.08,0:18:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi sadar bahwa dibimbing orang lain\Njuga bisa menjadi semacam kebahagiaan.
Dialogue: 0,0:18:07.08,0:18:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Fushi, apa yang akan kau lakukan?
Dialogue: 0,0:18:10.21,0:18:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah selesai mengambil alih\Ntugas Sosok Hitam.
Dialogue: 0,0:18:13.30,0:18:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum mencoba hal baru?
Dialogue: 0,0:18:16.05,0:18:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum. Aku…
Dialogue: 0,0:18:17.93,0:18:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengerti apa pun selain\Nmempertahankan keadaan apa adanya.
Dialogue: 0,0:18:21.35,0:18:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:23.10,0:18:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, akan kuberi tahu.
Dialogue: 0,0:18:25.27,0:18:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku mati, tolong hidupkan aku kembali.
Dialogue: 0,0:18:29.31,0:18:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemaskan hal egois\Nyang kukatakan sebelumnya, Kai.
Dialogue: 0,0:18:33.15,0:18:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan begitu.
Dialogue: 0,0:18:35.69,0:18:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya tak mau hidupku berakhir\Nsaat aku mati.
Dialogue: 0,0:18:40.89,0:18:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:18:42.24,0:18:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga dibimbing oleh orang lain.
Dialogue: 0,0:18:44.49,0:18:49.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari makan steik\Nuntuk merayakan kelulusan Hairo.
Dialogue: 0,0:18:49.88,0:18:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bon, kau mengemudi?
Dialogue: 0,0:18:51.42,0:18:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Seksi, kan?
Dialogue: 0,0:18:53.34,0:18:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru dapat SIM. Ini masih baru.
Dialogue: 0,0:18:55.46,0:18:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?\NKau bisa mengemudi dengan benar?
Dialogue: 0,0:18:57.80,0:19:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita selalu berhasil?
Dialogue: 0,0:19:00.84,0:19:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua akan baik saja mulai sekarang.
Dialogue: 0,0:19:02.80,0:19:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fushi, aku mengandalkanmu,\Nseperti yang kita sepakati.
Dialogue: 0,0:19:06.68,0:19:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Meski ada kekurangan dalam hidup,
Dialogue: 0,0:19:10.73,0:19:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masa depan harus terus berjalan.
Dialogue: 0,0:19:14.90,0:19:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, setidaknya kita harus menghargai\Nkebahagiaan di depan kita.
Dialogue: 0,0:19:23.03,0:19:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika kita tak punya bahannya...
Dialogue: 0,0:19:25.79,0:19:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menjatuhkan sesuatu.
Dialogue: 0,0:19:27.25,0:19:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:19:28.58,0:19:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:29.87,0:19:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini rusak?
Dialogue: 0,0:19:31.54,0:19:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu barang antik.\NSudah tidak berfungsi lagi.
Dialogue: 0,0:19:34.59,0:19:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hadiah ulang tahun yang penting.
Dialogue: 0,0:19:37.34,0:19:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku membelikannya khusus untukku.
Dialogue: 0,0:19:42.39,0:19:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang menyala.
Dialogue: 0,0:19:44.30,0:19:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:19:46.93,0:19:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau baik-baik saja?
Dialogue: 0,0:19:48.85,0:19:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:19:49.98,0:19:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku!
Dialogue: 0,0:19:53.36,0:19:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamnya mulai berfungsi lagi!
Dialogue: 0,0:19:55.94,0:19:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bagus!
Dialogue: 0,0:19:58.03,0:20:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menghabiskan 60 tahun di sini.
Dialogue: 0,0:20:07.83,0:20:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kau datang jauh-jauh kemari.
Dialogue: 0,0:20:10.96,0:20:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenalan lama yang tak tahu\Nidentitas aslimu akan datang.
Dialogue: 0,0:20:16.42,0:20:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.\NMempersembahkan dupa saja sudah cukup.
Dialogue: 0,0:20:20.22,0:20:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena akan ada banyak orang di sini,
Dialogue: 0,0:20:22.01,0:20:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih aman datang sebagai pelayat biasa.
Dialogue: 0,0:20:26.01,0:20:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah merepotkan.
Dialogue: 0,0:20:28.85,0:20:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datanglah dengan pakaian biasa\Ndan pergi secepat mungkin.
Dialogue: 0,0:20:32.81,0:20:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aiko,
Dialogue: 0,0:20:34.10,0:20:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seluruh keluargamu\Ntelah mengurusku dengan baik.
Dialogue: 0,0:20:36.61,0:20:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:38.03,0:20:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menjalani hidup yang baik dan panjang.
Dialogue: 0,0:20:42.36,0:20:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku pasti senang mendengarnya.
Dialogue: 0,0:20:47.03,0:20:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini adalah upacara peringatan\Nuntuk Profesor Emeritus Yuki Aoki,
Dialogue: 0,0:20:50.66,0:20:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ahli terkemuka dalam penelitian Nokker.
Dialogue: 0,0:20:52.16,0:20:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Upacara akan diadakan\Ndi Rumah Duka Minamoto.
Dialogue: 0,0:20:54.46,0:20:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tokoh terkemuka dari semua lapisan\Ndatang memberi penghormatan terakhir.
Dialogue: 0,0:20:58.50,0:21:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat muda,\NPak Aoki mengembangkan krim tubuh
Dialogue: 0,0:21:02.17,0:21:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencegah Nokker memasuki tubuh,
Dialogue: 0,0:21:05.59,0:21:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menjadi topik hangat saat itu.
Dialogue: 0,0:21:08.56,0:21:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski metode utama saat ini\Ndalam mengendalikan Nokker
Dialogue: 0,0:21:10.43,0:21:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah cip mikro\Ndari Kaibara Cybernetics Corporation,
Dialogue: 0,0:21:14.14,0:21:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia manusia pertama
Dialogue: 0,0:21:16.15,0:21:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang fokus pada kemungkinan\Nhubungan antara Nokker dan manusia,
Dialogue: 0,0:21:18.69,0:21:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga dia dicintai dan dihormati\Ndi seluruh dunia.
Dialogue: 0,0:21:22.15,0:21:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dia, aku bisa hidup bahagia.
Dialogue: 0,0:21:26.66,0:21:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berterima kasih padanya\Ndari lubuk hatiku.
Dialogue: 0,0:21:29.74,0:21:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua menua dengan cepat.
Dialogue: 0,0:21:32.50,0:21:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:21:34.29,0:21:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah ini juga terasa sepi sekarang.
Dialogue: 0,0:21:37.29,0:21:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aiko bilang aku bisa tinggal\Ndi sini selamanya,
Dialogue: 0,0:21:40.88,0:21:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bagi tetangga, aku sudah mati.
Dialogue: 0,0:21:43.38,0:21:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus pergi dari sini\Ndan mencari tempat tinggal baru.
Dialogue: 0,0:21:46.13,0:21:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kau ingin tinggal lain kali?
Dialogue: 0,0:21:47.89,0:21:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membawamu ke mana saja.
Dialogue: 0,0:21:49.51,0:21:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fu, kau terlalu tidak sabar.
Dialogue: 0,0:21:51.68,0:21:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:21:53.81,0:21:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang menganggapku ceria\Ndan manis, bukan?
Dialogue: 0,0:21:57.56,0:21:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama aku bisa tetap seperti ini,
Dialogue: 0,0:21:59.48,0:22:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa pergi ke mana saja.
Dialogue: 0,0:22:01.57,0:22:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak peduli kau menjadi apa,\Nkau akan selalu menjadi March.
Dialogue: 0,0:22:03.94,0:22:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:22:05.15,0:22:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Fu.
Dialogue: 0,0:22:08.28,0:22:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau suka tinggal di sini?
Dialogue: 0,0:22:10.70,0:22:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa impianmu terwujud?
Dialogue: 0,0:22:13.95,0:22:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang impianku adalah\Nmenjadi seorang ibu, bukan?
Dialogue: 0,0:22:18.04,0:22:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau tidak populer di kalangan pria.
Dialogue: 0,0:22:23.17,0:22:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kejam, Fu! Kau sangat tidak peka!
Dialogue: 0,0:22:25.59,0:22:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:22:26.51,0:22:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu populer!
Dialogue: 0,0:22:27.80,0:22:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah bertemu orang yang kusukai!
Dialogue: 0,0:22:30.55,0:22:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau benar.
Dialogue: 0,0:22:33.03,0:22:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sangat menyukai March\Nyang mempertahankan impiannya seperti ini.
Dialogue: 0,0:22:37.64,0:22:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikir dengan mengatakan itu
Dialogue: 0,0:22:39.16,0:22:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membuatku memaafkanmu!
Dialogue: 0,0:22:41.11,0:22:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:22:42.65,0:22:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:22:44.44,0:22:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, saatnya pergi.
Dialogue: 0,0:22:48.99,0:22:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
