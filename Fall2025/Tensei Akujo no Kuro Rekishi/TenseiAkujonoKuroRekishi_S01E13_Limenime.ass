Dialogue: 0,0:01:50.25,0:01:51.04,tanda,,0000,0000,0000,,TEMAN MASA KECIL, YOMI
Dialogue: 0,0:01:59.89,0:02:01.20,tanda,,0000,0000,0000,,EPISODE EKSTRA: YOMI, CEMBURU,\NDAN ULANG TAHUN
Dialogue: 0,0:02:03.62,0:02:04.75,tanda,,0000,0000,0000,,KEDIAMAN COUNT MAGNOLIA,\NDI IBU KOTA KERAJAAN ROSE
Dialogue: 0,0:02:39.22,0:02:40.18,tanda,,0000,0000,0000,,HAH
Dialogue: 0,0:03:03.08,0:03:03.75,tanda,,0000,0000,0000,,AROMA MANIS
Dialogue: 0,0:03:16.28,0:03:16.49,tanda,,0000,0000,0000,,BINGUNG
Dialogue: 0,0:03:23.82,0:03:24.14,tanda,,0000,0000,0000,,OBAT MUJARAB SUPER, BARANG LANGKA!\NSUDAH TERSEDIA.
Dialogue: 0,0:03:43.29,0:03:44.21,tanda,,0000,0000,0000,,OBAT UNTUK BERUBAH JADI KECIL
Dialogue: 0,0:03:44.30,0:03:44.97,tanda,,0000,0000,0000,,KOTA DI SEKITAR KASTEL
Dialogue: 0,0:05:56.06,0:05:56.48,tanda,,0000,0000,0000,,HARI INI TOKO TUTUP
Dialogue: 0,0:06:02.99,0:06:03.46,tanda,,0000,0000,0000,,HARI INI TUTUP
Dialogue: 0,0:06:10.24,0:06:11.54,tanda,,0000,0000,0000,,MENYEBALKAN
Dialogue: 0,0:06:11.57,0:06:12.50,tanda,,0000,0000,0000,,PULANG SEJENAK
Dialogue: 0,0:06:58.28,0:06:59.13,tanda,,0000,0000,0000,,HARI INI TOKO TUTUP
Dialogue: 0,0:09:35.86,0:09:38.21,tanda,,0000,0000,0000,,"OBAT MUJARAB SUPER YANG DIRUMORKAN"
Dialogue: 0,0:09:55.46,0:09:57.64,tanda,,0000,0000,0000,,HARI ULANG TAHUN YOMI
Dialogue: 0,0:09:57.66,0:09:58.18,tanda,,0000,0000,0000,,KEDIAMAN MAGNOLIA
Dialogue: 0,0:10:19.79,0:10:20.64,tanda,,0000,0000,0000,,UNDANGAN DARI SATOU? MANTAP!\NAKU AKAN DATANG!
Dialogue: 0,0:10:24.61,0:10:25.09,tanda,,0000,0000,0000,,DUA SAHABATNYA TIDAK BISA DATANG
Dialogue: 0,0:10:25.11,0:10:25.47,tanda,,0000,0000,0000,,SUASANA YANG CANGGUNG
Dialogue: 0,0:10:47.36,0:10:48.80,tanda,,0000,0000,0000,,UNTUK YOMI, SELAMAT ULANG TAHUN
Dialogue: 0,0:11:36.69,0:11:37.04,tanda,,0000,0000,0000,,SENYUM
Dialogue: 0,0:11:43.66,0:11:44.95,tanda,,0000,0000,0000,,EPISODE EKSTRA THE DARK HISTORY\NOF THE REINCARNATED VILLAINESS
Dialogue: 0,0:11:51.74,0:11:53.54,tanda,,0000,0000,0000,,SOL, SI PELAYAN PEMBUNUH
Dialogue: 0,0:12:01.21,0:12:02.27,tanda,,0000,0000,0000,,NEMOPHILA SOL, 17 TAHUN
Dialogue: 0,0:12:02.45,0:12:05.64,tanda,,0000,0000,0000,,HARI PENUH DEMAM IANA DAN SOL
Dialogue: 0,0:14:25.89,0:14:26.85,tanda,,0000,0000,0000,,TEMAN IMAJINER
Dialogue: 0,0:15:26.74,0:15:27.16,tanda,,0000,0000,0000,,IANA GINOFORD, KONOHA
Dialogue: 0,0:15:56.27,0:15:56.57,tanda,,0000,0000,0000,,DI DALAM BAYANGANNYA
Dialogue: 0,0:18:12.17,0:18:13.03,tanda,,0000,0000,0000,,DOKTER MAGUS BERSERTIFIKASI,\NSAHABAT GINOFORD, YATORI RANUNCULU
Dialogue: 0,0:18:49.46,0:18:50.54,tanda,,0000,0000,0000,,DUA HARI KEMUDIAN
Dialogue: 0,0:18:59.61,0:19:00.25,tanda,,0000,0000,0000,,KAMAR PRIBADI YANG DIBERIKAN\NKEPADA PELAYAN OLEH KONOHA
Dialogue: 0,0:21:16.80,0:21:17.81,tanda,,0000,0000,0000,,SATU JAM KEMUDIAN
Dialogue: 0,0:21:24.46,0:21:25.63,tanda,,0000,0000,0000,,LAGI-LAGI! ADA KARAKTER YANG BELUM\NMUNCUL DI ANIME!
Dialogue: 0,0:21:26.71,0:21:27.52,tanda,,0000,0000,0000,,OUGNISSE YANG SUDAH TUMBUH BESAR
Dialogue: 0,0:21:27.55,0:21:28.29,tanda,,0000,0000,0000,,WAKTU KECIL, SAMA-SAMA DIJUAL JADI\NBUDAK BERSAMA SOL
Dialogue: 0,0:21:28.31,0:21:29.00,tanda,,0000,0000,0000,,MANTAN REKAN SOL YANG SANGAT AHLI\NDALAM TEKNIK PEMBUNUHAN
Dialogue: 0,0:21:29.02,0:21:29.62,tanda,,0000,0000,0000,,OUGNISSE
Dialogue: 0,0:22:05.94,0:22:06.31,tanda,,0000,0000,0000,,SOL X NISSE
Dialogue: 0,0:01:31.00,0:01:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Satou Konoha, seorang karyawan biasa
Dialogue: 0,0:01:34.62,0:01:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kecelakaan saat pulang kerja\Ndan bereinkarnasi
Dialogue: 0,0:01:37.15,0:01:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai antagonis bernama Iana Magnolia
Dialogue: 0,0:01:38.59,0:01:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dunia fiksi yang kutulis saat SMP.
Dialogue: 0,0:01:40.39,0:01:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mengubah takdir kematian\Ndi tangan pelayanku sendiri,
Dialogue: 0,0:01:43.02,0:01:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hari ini pun aku berjuang keras\Nmenghindari Bendera Kematian.
Dialogue: 0,0:01:45.48,0:01:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ini adalah episode ekstra.
Dialogue: 0,0:01:47.34,0:01:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira cerita tentang siapa, ya?
Dialogue: 0,0:01:51.10,0:01:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:01:52.05,0:01:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah kisah saat aku mencoba\Nmemberikan hadiah ulang tahun
Dialogue: 0,0:01:54.13,0:01:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepada teman masa kecilku,
Dialogue: 0,0:01:57.14,0:01:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi Blacksalena,\Nputra dari keluarga Count.
Dialogue: 0,0:02:01.22,0:02:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi, kecemburuan, dan ulang tahun.
Dialogue: 0,0:02:04.76,0:02:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kan aku sudah menyuruhmu berhenti.
Dialogue: 0,0:02:08.46,0:02:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya tidak boleh!
Dialogue: 0,0:02:09.78,0:02:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah masak sendiri\Ndan tidak mengandalkan koki?
Dialogue: 0,0:02:13.10,0:02:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, kau jadi kena luka bakar.
Dialogue: 0,0:02:15.77,0:02:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Mengatur besarnya api\Nitu sulit sekali.
Dialogue: 0,0:02:18.21,0:02:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali aku akan lebih hati-hati.
Dialogue: 0,0:02:19.79,0:02:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada lain kali!
Dialogue: 0,0:02:21.05,0:02:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana tidak boleh pakai dapur lagi!
Dialogue: 0,0:02:23.10,0:02:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:02:23.76,0:02:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi!
Dialogue: 0,0:02:25.14,0:02:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatap, meong.
Dialogue: 0,0:02:27.74,0:02:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatap, meong.
Dialogue: 0,0:02:31.05,0:02:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh! Dasar Iana keras kepala!
Dialogue: 0,0:02:32.94,0:02:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan!
Dialogue: 0,0:02:34.21,0:02:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal biasanya hubungan kami sangat baik.
Dialogue: 0,0:02:35.96,0:02:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah hubungan kami jadi renggang.
Dialogue: 0,0:02:40.59,0:02:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku mau membuatkan
Dialogue: 0,0:02:42.49,0:02:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kue untuk ulang tahun Yomi,
Dialogue: 0,0:02:44.74,0:02:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku malah gagal.
Dialogue: 0,0:02:46.63,0:02:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Ada apa, Iana?
Dialogue: 0,0:02:50.67,0:02:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak! Pokoknya begini dan begitu...
Dialogue: 0,0:02:53.63,0:02:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Benar kau bertengkar\Ndengan Yomi?
Dialogue: 0,0:02:55.99,0:02:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, Yomi cuma khawatir saja.
Dialogue: 0,0:02:58.69,0:03:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci diriku yang cuma bisa\Nbikin khawatir orang lain begini.
Dialogue: 0,0:03:01.66,0:03:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiks, hiks...
Dialogue: 0,0:03:04.18,0:03:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konoha pintar bikin kue, kan?
Dialogue: 0,0:03:06.50,0:03:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau membuatnya bersama lagi?\NAkan kuajari.
Dialogue: 0,0:03:08.83,0:03:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kakak yang buat,
Dialogue: 0,0:03:11.00,0:03:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan cari hadiah lain saja.
Dialogue: 0,0:03:12.53,0:03:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau memakannya.
Dialogue: 0,0:03:13.83,0:03:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kasih apa?
Dialogue: 0,0:03:15.15,0:03:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:03:16.52,0:03:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti barang yang berguna untuk Yomi...
Dialogue: 0,0:03:18.78,0:03:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia sangat sibuk menerima\Npesanan obat belakangan ini.
Dialogue: 0,0:03:22.10,0:03:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:24.14,0:03:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana, ada apa?
Dialogue: 0,0:03:26.94,0:03:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-ini dia!
Dialogue: 0,0:03:29.80,0:03:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, aku pergi sebentar.
Dialogue: 0,0:03:31.55,0:03:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabut!
Dialogue: 0,0:03:32.34,0:03:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana, kau mau ke mana?
Dialogue: 0,0:03:34.14,0:03:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke kota!
Dialogue: 0,0:03:35.40,0:03:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syung.
Dialogue: 0,0:03:36.09,0:03:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota?
Dialogue: 0,0:03:36.80,0:03:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, akhir-akhir ini situasi\Nagak berbahaya, lo.
Dialogue: 0,0:03:38.89,0:03:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Aku harus buru-buru\Nmengejarnya!
Dialogue: 0,0:03:44.99,0:03:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu!
Dialogue: 0,0:03:46.31,0:03:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi orang di dunia ini,\Npilihan putri Count pergi
Dialogue: 0,0:03:48.90,0:03:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke kota sendirian\Nadalah hal yang tidak terpuji.
Dialogue: 0,0:03:51.48,0:03:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika terjadi sesuatu, ini bukan lagi\Nsekadar tanggung jawab pribadi.
Dialogue: 0,0:03:53.49,0:03:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:55.21,0:03:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu masih jadi karyawan\Nkantoran pun, aku selalu
Dialogue: 0,0:03:57.41,0:03:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertindak menuruti emosi...
Dialogue: 0,0:03:59.38,0:04:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin banget cendera mata ini!
Dialogue: 0,0:04:00.76,0:04:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku harus bersabar!
Dialogue: 0,0:04:01.54,0:04:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau aku dipaksa berhenti,
Dialogue: 0,0:04:02.71,0:04:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- stresku malah bakal meledak.\N- Aku memang ingin itu!
Dialogue: 0,0:04:04.16,0:04:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ingin banget!\N- Orang dewasa itu apa?
Dialogue: 0,0:04:05.16,0:04:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup pastikan tidak ada\Nyang mengenali wajahku.
Dialogue: 0,0:04:07.66,0:04:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama orang-orang tidak tahu\Nkalau aku ini wanita jahat...
Dialogue: 0,0:04:09.08,0:04:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua akan baik-baik saja.
Dialogue: 0,0:04:10.28,0:04:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, sekarang cari hadiah untuk Yomi!
Dialogue: 0,0:04:12.82,0:04:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya obat mujarab itu\Nbarang berharga, ya?
Dialogue: 0,0:04:15.29,0:04:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal di situ tertulis jelas\Nmereka menjualnya.
Dialogue: 0,0:04:17.38,0:04:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak menutup kemungkinan kalau\Nitu cuma penipuan, kan?
Dialogue: 0,0:04:20.19,0:04:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku coba periksa dulu.
Dialogue: 0,0:04:21.72,0:04:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak yang di sana, apa yang kau lakukan?
Dialogue: 0,0:04:26.29,0:04:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tersesat? Mau aku pandu?
Dialogue: 0,0:04:28.88,0:04:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anak
Dialogue: 0,0:04:30.71,0:04:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ganteng muncul!
Dialogue: 0,0:04:32.48,0:04:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kau juga sendiri.
Dialogue: 0,0:04:34.46,0:04:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ayah dan ibumu?
Dialogue: 0,0:04:36.87,0:04:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin membiarkan anak\Nseganteng ini pergi sendirian!
Dialogue: 0,0:04:39.65,0:04:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku anak dari kota ini.
Dialogue: 0,0:04:41.66,0:04:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sendiri pun tidak masalah.
Dialogue: 0,0:04:43.37,0:04:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah? Tapi Bibi sendirian\Npun tidak masalah.
Dialogue: 0,0:04:46.74,0:04:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengkhawatirkanku.
Dialogue: 0,0:04:48.71,0:04:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Atau mau aku antar sampai rumahmu?\N- Tidak, tidak, tidak!
Dialogue: 0,0:04:53.16,0:04:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bukan bibi-bibi...
Dialogue: 0,0:04:56.85,0:04:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena Kakak sangat menggemaskan.
Dialogue: 0,0:04:58.53,0:04:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik mengaku saja.
Dialogue: 0,0:04:59.98,0:05:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, topengku berubah jadi abu!
Dialogue: 0,0:05:01.82,0:05:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini semacam kekuatan pemurnian?!
Dialogue: 0,0:05:03.07,0:05:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya tidak boleh jalan sendirian.
Dialogue: 0,0:05:05.46,0:05:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ikut.
Dialogue: 0,0:05:07.88,0:05:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana Magnolia menculik anak ganteng!
Dialogue: 0,0:05:10.61,0:05:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya banget! Malah makin gawat kalau
Dialogue: 0,0:05:13.22,0:05:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang-orang tahu aku ini sebenarnya\Nwanita jahat!
Dialogue: 0,0:05:17.40,0:05:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pergi membeli hadiah\Nuntuk orang yang penting?
Dialogue: 0,0:05:20.55,0:05:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang seperti apa yang sebenarnya\Nbutuh obat mujarab itu?
Dialogue: 0,0:05:23.35,0:05:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya ada yang bisa pakai\Nbarang selangka itu di sini?
Dialogue: 0,0:05:26.27,0:05:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria, ya?
Dialogue: 0,0:05:27.18,0:05:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seperti apa? Bagaimana wajahnya?\NApa pekerjaannya?
Dialogue: 0,0:05:29.62,0:05:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu banyak bertanya.
Dialogue: 0,0:05:30.35,0:05:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria, ya?
Dialogue: 0,0:05:31.13,0:05:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pria.
Dialogue: 0,0:05:32.24,0:05:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:34.06,0:05:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:34.96,0:05:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apakah itu sesuatu yang aneh?
Dialogue: 0,0:05:36.55,0:05:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti memberi obat mujarab kepada pria?
Dialogue: 0,0:05:39.39,0:05:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:05:40.33,0:05:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin hal seperti itu
Dialogue: 0,0:05:42.79,0:05:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aneh juga.
Dialogue: 0,0:05:43.66,0:05:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Benarkah?
Dialogue: 0,0:05:46.57,0:05:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membayangkan reaksi\Nseperti ini, tapi...
Dialogue: 0,0:05:48.99,0:05:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar banget!
Dialogue: 0,0:05:49.93,0:05:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan itu seperti obat perangsang?
Dialogue: 0,0:05:53.13,0:05:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Iana mesum...
Dialogue: 0,0:05:56.51,0:05:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya toko perlengkapan\Nsedang tutup hari ini, ya.
Dialogue: 0,0:05:59.54,0:06:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko ini memang jam bukanya tidak menentu.
Dialogue: 0,0:06:02.12,0:06:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau menyerah saja?
Dialogue: 0,0:06:03.49,0:06:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:06:04.40,0:06:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski hari ini tidak buka,\Naku tak akan menyerah.
Dialogue: 0,0:06:06.71,0:06:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini barang untuk orang yang penting.
Dialogue: 0,0:06:12.52,0:06:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.\NDiam-diam...
Dialogue: 0,0:06:16.40,0:06:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana.
Dialogue: 0,0:06:16.94,0:06:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:06:18.44,0:06:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Yomi.\NApa kabarmu?
Dialogue: 0,0:06:23.65,0:06:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, eng...
Dialogue: 0,0:06:25.13,0:06:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu...
Dialogue: 0,0:06:26.02,0:06:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konoha memanggilmu.
Dialogue: 0,0:06:28.01,0:06:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma memberitahumu itu.
Dialogue: 0,0:06:29.28,0:06:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ya.
Dialogue: 0,0:06:30.72,0:06:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi...
Dialogue: 0,0:06:32.21,0:06:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih marah, ya?
Dialogue: 0,0:06:36.95,0:06:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pastikan dulu efek obatnya,\Nkalau kelihatannya aman,
Dialogue: 0,0:06:39.72,0:06:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan berikan itu ke Yomi\Nsupaya kami bisa baikan lagi.
Dialogue: 0,0:06:41.84,0:06:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ini untukku? Senangnya!
Dialogue: 0,0:06:44.49,0:06:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, selama beberapa hari aku\Nterus mendatangi toko itu.
Dialogue: 0,0:06:48.36,0:06:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, tiap kali aku ke sana,\Npemuda tampan itu
Dialogue: 0,0:06:50.62,0:06:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga muncul dan terus mengikutiku.
Dialogue: 0,0:06:52.00,0:06:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prang!
Dialogue: 0,0:06:52.95,0:06:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di hari berhujan...\N- Selamat siang.
Dialogue: 0,0:06:53.79,0:06:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di hari berangin juga...\N- Halo!
Dialogue: 0,0:06:55.49,0:06:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari yang mendung juga!
Dialogue: 0,0:06:56.65,0:06:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sulit sekali membelinya.
Dialogue: 0,0:06:59.16,0:07:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada saat itulah...
Dialogue: 0,0:07:01.08,0:07:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi pingsan gara-gara kelelahan bekerja.
Dialogue: 0,0:07:04.01,0:07:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi!
Dialogue: 0,0:07:05.25,0:07:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana?
Dialogue: 0,0:07:06.22,0:07:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Konoha, bagaimana keadaan Yomi?
Dialogue: 0,0:07:07.70,0:07:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:07:08.79,0:07:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama-tama kau tenang dulu, ya.
Dialogue: 0,0:07:10.57,0:07:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-baik.
Dialogue: 0,0:07:11.85,0:07:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia cuma kelelahan.
Dialogue: 0,0:07:13.82,0:07:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya dia sibuk sekali.
Dialogue: 0,0:07:17.53,0:07:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi...
Dialogue: 0,0:07:20.26,0:07:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana...
Dialogue: 0,0:07:24.69,0:07:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus kerja.
Dialogue: 0,0:07:26.67,0:07:28.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, kau harus tidur\Nsedikit lebih lama lagi.
Dialogue: 0,0:07:28.30,0:07:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku masih ada kerjaan.
Dialogue: 0,0:07:30.64,0:07:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja, ya? Hm!
Dialogue: 0,0:07:32.37,0:07:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, istirahat saja 15 menit lagi.
Dialogue: 0,0:07:34.77,0:07:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu kondisimu pasti akan\Nsedikit membaik.
Dialogue: 0,0:07:36.66,0:07:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meracik obat butuh ketelitian tinggi, kan?
Dialogue: 0,0:07:38.91,0:07:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya kalau kau tidak istirahat\Nsebentar dulu.
Dialogue: 0,0:07:41.49,0:07:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku buatkan teh yang bikin kau rileks, ya.
Dialogue: 0,0:07:43.62,0:07:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu teh yang bagus!
Dialogue: 0,0:07:44.69,0:07:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bilang untuk jangan\Nke dapur, kan?
Dialogue: 0,0:07:47.47,0:07:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan lelah kalau saja kau\Nbisa duduk diam dengan tenang.
Dialogue: 0,0:07:54.37,0:07:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-maaf.
Dialogue: 0,0:07:56.15,0:07:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan itu maksudku.
Dialogue: 0,0:07:57.16,0:07:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, omong-omong,
Dialogue: 0,0:07:58.54,0:07:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya, tadi kan aku sedang menumpuk buku.
Dialogue: 0,0:07:59.95,0:08:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa mau membacanya\Ndi kamar dengan santai.
Dialogue: 0,0:08:02.19,0:08:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana!
Dialogue: 0,0:08:02.79,0:08:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita terus mengobrol,\Naku malah jadi mengganggu, ya.
Dialogue: 0,0:08:04.44,0:08:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi, semangat kerjanya!
Dialogue: 0,0:08:06.50,0:08:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana...
Dialogue: 0,0:08:08.67,0:08:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin malu saja.
Dialogue: 0,0:08:09.81,0:08:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiks...
Dialogue: 0,0:08:11.06,0:08:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksud hati ingin membuat senang,\Ntapi malah bikin dia terdesak.
Dialogue: 0,0:08:13.63,0:08:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar Kisah Kelam!
Dialogue: 0,0:08:15.28,0:08:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah begini?
Dialogue: 0,0:08:16.69,0:08:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah begini?
Dialogue: 0,0:08:18.69,0:08:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah begini?
Dialogue: 0,0:08:21.07,0:08:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana kelihatan lesu.
Dialogue: 0,0:08:22.78,0:08:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah terjadi sesuatu?
Dialogue: 0,0:08:24.49,0:08:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah seperti sayuran layu saja.
Dialogue: 0,0:08:26.12,0:08:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana...
Dialogue: 0,0:08:27.28,0:08:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengkhawatirkanmu...
Dialogue: 0,0:08:31.42,0:08:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan menyerah.\NKarena ini untuk orang yang penting.
Dialogue: 0,0:08:38.95,0:08:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana...
Dialogue: 0,0:08:43.90,0:08:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah hari ini toko peralatannya buka?
Dialogue: 0,0:08:46.35,0:08:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah. Aku merasa bersalah\Npada Yomi,
Dialogue: 0,0:08:48.30,0:08:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai-sampai membuat dia\Nmengatakan hal seperti itu.
Dialogue: 0,0:08:49.42,0:08:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dung, dung.
Dialogue: 0,0:08:51.00,0:08:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si ganteng!
Dialogue: 0,0:08:52.42,0:08:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:08:53.25,0:08:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak! Hari ini toko peralatan itu buka!
Dialogue: 0,0:08:57.03,0:08:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sudah tidak perlu lagi.
Dialogue: 0,0:08:58.56,0:08:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa begitu!
Dialogue: 0,0:08:59.75,0:09:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang ini untuk orang\Nyang sangat penting, kan?
Dialogue: 0,0:09:02.02,0:09:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau sudah berusaha keras\Nselama ini?
Dialogue: 0,0:09:05.29,0:09:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:09:06.25,0:09:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin menghargai
Dialogue: 0,0:09:07.85,0:09:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perasaanmu yang berharga itu.
Dialogue: 0,0:09:18.51,0:09:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini hujannya sangat deras,\Naku tutup lebih awal saja.
Dialogue: 0,0:09:21.73,0:09:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:09:22.77,0:09:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh? Aku seperti...\N- Kenapa malah tutup?
Dialogue: 0,0:09:24.58,0:09:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengar sesuatu.
Dialogue: 0,0:09:25.62,0:09:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman!
Dialogue: 0,0:09:27.87,0:09:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat mujarab...
Dialogue: 0,0:09:29.24,0:09:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Beli satu!
Dialogue: 0,0:09:31.53,0:09:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waaa! Ada dua dedemit!
Dialogue: 0,0:09:33.13,0:09:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:09:35.86,0:09:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bisa membelinya!
Dialogue: 0,0:09:38.59,0:09:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih! Terima kasih!
Dialogue: 0,0:09:40.38,0:09:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini aku bisa memberinya kejutan!
Dialogue: 0,0:09:42.53,0:09:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih, ya, anak ganteng!
Dialogue: 0,0:09:44.43,0:09:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Sudah tidak ada?
Dialogue: 0,0:09:45.91,0:09:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, anak ganteng!
Dialogue: 0,0:09:47.49,0:09:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ke mana?
Dialogue: 0,0:09:58.20,0:09:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah menyiapkan banyak hal,
Dialogue: 0,0:09:59.39,0:10:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi si tokoh utama malah terkapar\Nkarena flu.
Dialogue: 0,0:10:01.74,0:10:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga hari lalu saat hujan,
Dialogue: 0,0:10:03.44,0:10:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}entah kenapa dia pulang dalam\Nkeadaan basah kuyup, ya.
Dialogue: 0,0:10:06.01,0:10:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi...
Dialogue: 0,0:10:07.50,0:10:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita cepat berbaikan...
Dialogue: 0,0:10:09.31,0:10:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan nanti kita rayakan, ya.
Dialogue: 0,0:10:13.46,0:10:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semasa SMP,
Dialogue: 0,0:10:14.92,0:10:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena sangat mengidolakan\Npesta ulang tahun di komik,
Dialogue: 0,0:10:17.04,0:10:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengirim undangan ke beberapa\Nteman sekelas perempuan.
Dialogue: 0,0:10:20.66,0:10:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ternyata mereka datang hanya
Dialogue: 0,0:10:22.03,0:10:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena tidak enak menolak\Ndan kami tidak terlalu dekat.
Dialogue: 0,0:10:25.50,0:10:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, setelah 30 menit,\Nkami kehabisan bahan pembicaraan.
Dialogue: 0,0:10:28.44,0:10:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang, ya, karena ada urusan di rumah.
Dialogue: 0,0:10:30.61,0:10:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ya.
Dialogue: 0,0:10:31.96,0:10:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya ulang tahun itu seru,\Nasyik, dan membahagiakan.
Dialogue: 0,0:10:39.60,0:10:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana?!
Dialogue: 0,0:10:41.79,0:10:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia terus ada di sini?
Dialogue: 0,0:10:44.55,0:10:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi...
Dialogue: 0,0:10:45.52,0:10:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga...
Dialogue: 0,0:10:50.97,0:10:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, obat mujarab...
Dialogue: 0,0:10:53.92,0:10:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyerah.
Dialogue: 0,0:10:55.48,0:10:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini untuk orang yang penting.
Dialogue: 0,0:10:58.62,0:11:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, ini buatku?
Dialogue: 0,0:11:02.14,0:11:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi...
Dialogue: 0,0:11:05.53,0:11:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga...
Dialogue: 0,0:11:09.72,0:11:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana...
Dialogue: 0,0:11:14.48,0:11:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana?
Dialogue: 0,0:11:15.47,0:11:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Yomi sudah bangun?
Dialogue: 0,0:11:17.32,0:11:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah...
Dialogue: 0,0:11:18.66,0:11:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua terlihat sangat bahagia, ya.
Dialogue: 0,0:11:23.82,0:11:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi dan Iana adalah teman\Nmasa kecil yang selalu bersama.
Dialogue: 0,0:11:27.17,0:11:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi, kapan pun itu,
Dialogue: 0,0:11:28.61,0:11:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal itu tak akan berubah\Nsampai maut menjemput.
Dialogue: 0,0:11:30.87,0:11:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah yang menuju kematian\Nmemang bisa diubah,
Dialogue: 0,0:11:33.46,0:11:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi takdir yang satu ini\Ntak akan pernah bisa diubah.
Dialogue: 0,0:11:37.07,0:11:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi, Iana!
Dialogue: 0,0:11:39.10,0:11:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyum...
Dialogue: 0,0:11:39.55,0:11:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yomi?
Dialogue: 0,0:11:40.50,0:11:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imutnya!
Dialogue: 0,0:11:42.06,0:11:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutku berantakan!
Dialogue: 0,0:11:50.23,0:11:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kali ini,
Dialogue: 0,0:11:53.56,0:11:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah satu hari penuh gairah dengan\NNemophila Sol, 17 tahun,
Dialogue: 0,0:11:55.73,0:11:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pelayan pembunuh yang melindungi pahlawan,
Dialogue: 0,0:11:57.70,0:12:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musuh bebuyutan antagonis.
Dialogue: 0,0:12:08.18,0:12:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sol...
Dialogue: 0,0:12:09.91,0:12:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau urusan belanja\Nbiar aku saja yang lakukan.
Dialogue: 0,0:12:11.91,0:12:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tidak perlu dipikirkan.
Dialogue: 0,0:12:13.87,0:12:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu yang aku beli juga.
Dialogue: 0,0:12:16.40,0:12:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah tidak apa-apa?
Dialogue: 0,0:12:17.51,0:12:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik kau minum sesuatu yang hangat...
Dialogue: 0,0:12:20.08,0:12:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sekarang aku akan memeriksa\Nkondisi Nona Iana.
Dialogue: 0,0:12:24.65,0:12:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera ganti baju,
Dialogue: 0,0:12:26.17,0:12:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi tolong siapkan es batu saja.
Dialogue: 0,0:12:27.90,0:12:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ugh.
Dialogue: 0,0:12:28.79,0:12:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di suatu hari berudara dingin...
Dialogue: 0,0:12:30.85,0:12:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sakit!\N- Karena aku menangkap
Dialogue: 0,0:12:32.08,0:12:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kucing yang terluka,
Dialogue: 0,0:12:33.31,0:12:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang berada di luar waktu itu...
Dialogue: 0,0:12:35.87,0:12:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserang flu parah.
Dialogue: 0,0:12:37.46,0:12:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kwang, kwang...
Dialogue: 0,0:12:39.70,0:12:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:12:41.13,0:12:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Sol...
Dialogue: 0,0:12:42.73,0:12:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iana,
Dialogue: 0,0:12:43.54,0:12:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah Anda sudah bangun?
Dialogue: 0,0:12:45.37,0:12:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku sudah baik-baik saja.\NSekarang aku akan bangun.
Dialogue: 0,0:12:48.52,0:12:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda masih sakit!
Dialogue: 0,0:12:50.57,0:12:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong cepatlah berbaring.
Dialogue: 0,0:12:53.77,0:12:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas Anda... Sentuh dahi.
Dialogue: 0,0:12:55.97,0:12:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih tinggi.
Dialogue: 0,0:12:58.63,0:12:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat...
Dialogue: 0,0:12:59.75,0:13:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air...
Dialogue: 0,0:13:00.72,0:13:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, aku jarang sakit.
Dialogue: 0,0:13:03.72,0:13:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pelayan pun berpikiran sama.
Dialogue: 0,0:13:05.92,0:13:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahwa yang tubuhnya lemah\Ndan harus dijaga ketat
Dialogue: 0,0:13:08.09,0:13:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kesehatannya di musim ini\Njustru adalah Konoha.
Dialogue: 0,0:13:11.60,0:13:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng... Sol...
Dialogue: 0,0:13:13.08,0:13:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu apa?
Dialogue: 0,0:13:14.32,0:13:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyiapkan makanan
Dialogue: 0,0:13:16.26,0:13:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sekiranya akan dibutuhkan.
Dialogue: 0,0:13:17.86,0:13:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak banget!
Dialogue: 0,0:13:18.70,0:13:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kelihatannya Sol sangat benci\Ndengan hal-hal yang mubazir.
Dialogue: 0,0:13:21.98,0:13:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tiga jenis apel.
Dialogue: 0,0:13:24.42,0:13:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggurnya ada 10 jenis.
Dialogue: 0,0:13:25.72,0:13:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantas kenapa?
Dialogue: 0,0:13:27.36,0:13:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sedang flu,\Ntapi seperti sedang berulang tahun.
Dialogue: 0,0:13:32.02,0:13:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:13:34.19,0:13:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kaku gitu, dong, Pelayanku!\NAku jadi sedih!
Dialogue: 0,0:13:36.72,0:13:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, karena sudah waktunya,
Dialogue: 0,0:13:38.46,0:13:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya berikan hadiah.
Dialogue: 0,0:13:41.12,0:13:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:13:43.35,0:13:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau disuapi?
Dialogue: 0,0:13:44.69,0:13:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini apel.
Dialogue: 0,0:13:46.18,0:13:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena saya pikir Anda kesulitan\Nmenelan makanan padat,
Dialogue: 0,0:13:48.01,0:13:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka saya sudah memarutnya untuk Anda.
Dialogue: 0,0:13:49.29,0:13:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, aku bisa makan sendiri.
Dialogue: 0,0:13:50.88,0:13:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tangan Anda sedang gemetar,
Dialogue: 0,0:13:52.12,0:13:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar saya saja yang menyuapi.
Dialogue: 0,0:14:00.52,0:14:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:14:01.77,0:14:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petir?
Dialogue: 0,0:14:02.82,0:14:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:03.53,0:14:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat saya pergi berbelanja
Dialogue: 0,0:14:05.25,0:14:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum ada petir.
Dialogue: 0,0:14:07.01,0:14:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya akan periksa sebentar.
Dialogue: 0,0:14:08.34,0:14:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:09.55,0:14:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beristirahatlah, Nona Iana.
Dialogue: 0,0:14:12.79,0:14:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semasa SMP,
Dialogue: 0,0:14:14.38,0:14:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiap kali flu, imajinasiku saat\Nbermain sendirian jadi makin liar.
Dialogue: 0,0:14:17.60,0:14:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pura-pura menjadi pahlawan\Nyang kena status efek dalam gim...
Dialogue: 0,0:14:20.95,0:14:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan menikmati skenario di mana aku pingsan
Dialogue: 0,0:14:22.81,0:14:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah menghabiskan tenaga suci\Ndemi melindungi teman-teman.
Dialogue: 0,0:14:26.88,0:14:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi
Dialogue: 0,0:14:29.13,0:14:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}teman-temanku...
Dialogue: 0,0:14:31.16,0:14:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku bermain sendirian?
Dialogue: 0,0:14:33.20,0:14:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena orang tuaku sama-sama sibuk bekerja,
Dialogue: 0,0:14:36.22,0:14:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi saat kecil aku jarang dirawat\Nmereka saat sakit.
Dialogue: 0,0:14:39.32,0:14:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu pergi, ya.
Dialogue: 0,0:14:40.47,0:14:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari uang yang banyak!
Dialogue: 0,0:14:41.89,0:14:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari-hariku dilewati
Dialogue: 0,0:14:43.00,0:14:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan imajinasi dirawat\Noleh kawan khayalan
Dialogue: 0,0:14:44.91,0:14:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi bisa bertahan melalui rasa sakit ini.
Dialogue: 0,0:14:45.94,0:14:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konoha, kau terlalu memaksakan dirimu.
Dialogue: 0,0:14:47.54,0:14:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ginoford!
Dialogue: 0,0:14:49.16,0:14:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelahnya, aku main gim!
Dialogue: 0,0:14:50.90,0:14:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada orang yang bakal mikir,
Dialogue: 0,0:14:52.91,0:14:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Lagi bolos sekolah karena sakit,\Nkok malah main gim sih?" tapi...
Dialogue: 0,0:14:55.07,0:14:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai jenuh karena ditinggal sendiri!
Dialogue: 0,0:14:56.47,0:14:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kan cuma menjaga kesehatan mentalku!
Dialogue: 0,0:14:58.80,0:15:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menutup mataku...\NIdolaku akan muncul...
Dialogue: 0,0:15:01.22,0:15:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Idolaku akan muncul...
Dialogue: 0,0:15:02.41,0:15:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datanglah idolaku!
Dialogue: 0,0:15:03.85,0:15:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu, perasaan kesepian\Nsama sekali tidak muncul.
Dialogue: 0,0:15:07.12,0:15:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena sekarang ada kalian\Nsemua di sisiku...
Dialogue: 0,0:15:09.30,0:15:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah merasa sedikit kesepian.
Dialogue: 0,0:15:13.22,0:15:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tipe yang suka petir...
Dialogue: 0,0:15:15.93,0:15:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau sampai sedekat ini,\Naku jadi kaget.
Dialogue: 0,0:15:18.40,0:15:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi... di saat seperti ini pun\Ntidak ada yang menjengukku.
Dialogue: 0,0:15:23.48,0:15:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi kamarku juga agak terpencil
Dialogue: 0,0:15:25.46,0:15:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terisolasi, rasanya sepi sekali...
Dialogue: 0,0:15:27.19,0:15:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah Iana yang dulu, sama sepertiku,
Dialogue: 0,0:15:29.83,0:15:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tak ada yang merawatnya?
Dialogue: 0,0:15:31.81,0:15:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu sendiri tanpa ada\Nyang tahu perasaannya...?
Dialogue: 0,0:15:36.20,0:15:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah!
Dialogue: 0,0:15:37.14,0:15:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kondisiku makin parah,\Naku akan merepotkan semuanya.
Dialogue: 0,0:15:38.79,0:15:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo istirahat!
Dialogue: 0,0:15:39.90,0:15:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iana.
Dialogue: 0,0:15:41.25,0:15:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sol!
Dialogue: 0,0:15:42.78,0:15:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu...
Dialogue: 0,0:15:43.98,0:15:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku sengaja keluyuran\Natau banyak tingkah.
Dialogue: 0,0:15:46.75,0:15:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:15:48.30,0:15:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau takut, segera panggil saya.
Dialogue: 0,0:15:52.42,0:15:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak marah?
Dialogue: 0,0:15:53.89,0:15:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bersikaplah seperti orang sakit!
Dialogue: 0,0:15:57.58,0:16:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petirnya benar-benar menyambar\Ntepat di dekat sini!
Dialogue: 0,0:16:00.65,0:16:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuat Anda sendirian\Ndi saat seperti ini.
Dialogue: 0,0:16:05.17,0:16:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya.
Dialogue: 0,0:16:06.56,0:16:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sol sangat baik.
Dialogue: 0,0:16:08.19,0:16:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak apa-apa.
Dialogue: 0,0:16:10.56,0:16:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:12.37,0:16:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena aku sedang sakit...
Dialogue: 0,0:16:14.73,0:16:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iana Magnolia!
Dialogue: 0,0:16:16.14,0:16:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah cukup lama dibuat\Nmenderita olehnya.
Dialogue: 0,0:16:18.43,0:16:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal hanya karena sekarang dia\Njadi penurut,
Dialogue: 0,0:16:20.46,0:16:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan berarti dia berhak\Ndirawat seperti ini...
Dialogue: 0,0:16:22.81,0:16:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:16:23.87,0:16:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya dia bisa tidur.
Dialogue: 0,0:16:26.21,0:16:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Sol!
Dialogue: 0,0:16:28.13,0:16:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:16:28.96,0:16:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Konoha demam dan jatuh pingsan!
Dialogue: 0,0:16:32.03,0:16:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana?
Dialogue: 0,0:16:32.96,0:16:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini.
Dialogue: 0,0:16:40.46,0:16:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sol?
Dialogue: 0,0:16:42.48,0:16:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya izin membuka jendela sebentar\Nuntuk sirkulasi udara, ya.
Dialogue: 0,0:16:45.26,0:16:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya...
Dialogue: 0,0:16:50.78,0:16:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kapan...
Dialogue: 0,0:16:52.44,0:16:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kapan butuh sirkulasi udara?
Dialogue: 0,0:16:54.37,0:16:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya dingin sekali!
Dialogue: 0,0:16:57.01,0:16:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei, Sol...?
Dialogue: 0,0:17:00.88,0:17:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak di sini?
Dialogue: 0,0:17:03.56,0:17:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat, biar aku sendiri\Nyang tutup.
Dialogue: 0,0:17:10.67,0:17:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:12.48,0:17:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantainya bergoyang...
Dialogue: 0,0:17:14.38,0:17:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku tidak punya tenaga...
Dialogue: 0,0:17:16.97,0:17:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin...
Dialogue: 0,0:17:18.78,0:17:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak ada siapa pun.
Dialogue: 0,0:17:21.36,0:17:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ini yang dirasakan Iana juga...
Dialogue: 0,0:17:23.31,0:17:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pula dengan Satou...
Dialogue: 0,0:17:25.06,0:17:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini juga...
Dialogue: 0,0:17:26.32,0:17:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, sepertinya tidak ada yang\Naneh dengan kondisi Nona Konoha.
Dialogue: 0,0:17:29.54,0:17:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya itu hanya salah paham.
Dialogue: 0,0:17:32.60,0:17:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, Nona Iana.
Dialogue: 0,0:17:35.35,0:17:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iana?
Dialogue: 0,0:17:38.40,0:17:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iana!!
Dialogue: 0,0:17:43.69,0:17:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu, tadi aku sangat senang...
Dialogue: 0,0:17:47.68,0:17:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ada seseorang di dekatku...
Dialogue: 0,0:17:49.62,0:17:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bertahanlah!
Dialogue: 0,0:17:51.03,0:17:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya akan mengantar Anda\Nke tempat Tuan Yatori.
Dialogue: 0,0:17:54.77,0:17:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia baik, dan hangat...
Dialogue: 0,0:17:57.75,0:17:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat senang.
Dialogue: 0,0:18:00.56,0:18:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Jadi itu cuma kebohongan\Nyang dibuat-buat.
Dialogue: 0,0:18:02.64,0:18:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:03.20,0:18:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pergi ke tempat Nona Konoha
Dialogue: 0,0:18:06.55,0:18:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengarang cerita\Nbahwa Nona Konoha pingsan.
Dialogue: 0,0:18:08.77,0:18:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menyangka pelayan Count\NMagnolia mengincar Nona Iana...
Dialogue: 0,0:18:13.05,0:18:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka butuh dididik ulang.
Dialogue: 0,0:18:14.77,0:18:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak memiliki kata-kata\Nuntuk membela diri.
Dialogue: 0,0:18:16.82,0:18:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Iana adalah orang yang kuat.
Dialogue: 0,0:18:18.74,0:18:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan permata yang paling keras\Ndan kuat sekalipun,
Dialogue: 0,0:18:21.09,0:18:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada akhirnya akan hancur\Njika terus-menerus dipukul.
Dialogue: 0,0:18:24.67,0:18:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan ada celah sedikit pun...
Dialogue: 0,0:18:26.32,0:18:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:18:28.48,0:18:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa mendengar ada suara...
Dialogue: 0,0:18:32.46,0:18:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iana...
Dialogue: 0,0:18:33.56,0:18:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah Anda tidak apa-apa.
Dialogue: 0,0:18:35.01,0:18:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sol?
Dialogue: 0,0:18:36.22,0:18:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tak akan membiarkanmu\Nmengalami hal seperti itu lagi!
Dialogue: 0,0:18:40.38,0:18:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Nona Iana...
Dialogue: 0,0:18:45.92,0:18:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih karena sudah datang.
Dialogue: 0,0:18:50.57,0:18:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fluku menular ke Sol?
Dialogue: 0,0:18:53.04,0:18:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:18:54.37,0:18:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai kata Tuan Yatori, dia tak apa,\Njadi jangan cemas.
Dialogue: 0,0:18:57.18,0:18:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi sebentar!
Dialogue: 0,0:18:58.93,0:18:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Iana!
Dialogue: 0,0:19:00.27,0:19:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah sakit.
Dialogue: 0,0:19:02.17,0:19:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai tertular,
Dialogue: 0,0:19:03.21,0:19:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bukan hanya akan membuat\NNona Iana merasa bersalah...
Dialogue: 0,0:19:05.57,0:19:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, pekerjaanku juga jadi terbengkalai.
Dialogue: 0,0:19:07.51,0:19:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berusaha berhati-hati, tapi...
Dialogue: 0,0:19:09.53,0:19:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku memang\Nmudah tertular penyakit.
Dialogue: 0,0:19:12.18,0:19:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sering sekali kena flu\Nsewaktu kecil.
Dialogue: 0,0:19:14.31,0:19:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di panti asuhan dulu,
Dialogue: 0,0:19:16.38,0:19:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}satu suster harus mengurus\Nbanyak anak sendirian.
Dialogue: 0,0:19:18.46,0:19:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah, hal seperti\N"dirawat saat sakit" itu tidak pernah ada.
Dialogue: 0,0:19:20.43,0:19:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya hal yang terasa spesial
Dialogue: 0,0:19:21.50,0:19:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat itu adalah menu apel parut itu,
Dialogue: 0,0:19:24.53,0:19:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dan keberadaan.\N- Cepat sembuh...
Dialogue: 0,0:19:25.73,0:19:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}si bodoh Ougnisse di sisiku.
Dialogue: 0,0:19:28.06,0:19:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah, aku tidak\Ntahu harus berbuat apa.
Dialogue: 0,0:19:31.13,0:19:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa membawa apa pun yang
Dialogue: 0,0:19:32.50,0:19:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin berguna ke hadapan\NNona Iana saat dia sakit.
Dialogue: 0,0:19:34.72,0:19:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir dia akan menganggapku konyol\Nkarena melakukan hal tak perlu...
Dialogue: 0,0:19:38.05,0:19:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sedang sakit,\Ntapi rasanya seperti berulang tahun, ya.
Dialogue: 0,0:19:41.26,0:19:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pelayan itu mengatakan\NNona Konoha pingsan...
Dialogue: 0,0:19:44.78,0:19:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian diriku menganggap\Nbergegas ke sisinya adalah hal wajar.
Dialogue: 0,0:19:47.52,0:19:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di satu sisi, ada juga bagian\Ndiriku yang menyesali itu.
Dialogue: 0,0:19:49.79,0:19:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau bisa sampai salah mengira\Nbahwa Nona Konoha pingsan?
Dialogue: 0,0:19:53.14,0:19:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini Nona Iana...
Dialogue: 0,0:19:54.08,0:19:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Konoha lebih penting daripada\NNona Iana!
Dialogue: 0,0:19:56.30,0:19:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:19:58.35,0:20:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan itu dengan mudah mengaku...
Dialogue: 0,0:20:00.61,0:20:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua pernah mendapat\Nperlakuan buruk dari Nona Iana.
Dialogue: 0,0:20:04.04,0:20:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan berniat suatu hari membalasnya.
Dialogue: 0,0:20:07.32,0:20:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iana yang dulu, ya?
Dialogue: 0,0:20:09.85,0:20:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, dia selalu ada di Kediaman Dahlia...
Dialogue: 0,0:20:11.76,0:20:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, rasanya aku tidak\Npernah punya kesempatan
Dialogue: 0,0:20:13.08,0:20:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk bertatap muka\Ndan berbicara dengannya.
Dialogue: 0,0:20:16.25,0:20:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku hanya pernah mendengar...\N- Apa maksudmu?!
Dialogue: 0,0:20:18.10,0:20:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dari jauh dia berteriak.\N- Dasar pelayan...
Dialogue: 0,0:20:19.55,0:20:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak berguna!
Dialogue: 0,0:20:21.44,0:20:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, aku selalu merasa kehadirannya\Nbagaikan gemuruh petir di kejauhan.
Dialogue: 0,0:20:22.97,0:20:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sol, kau tidak apa-apa?
Dialogue: 0,0:20:25.64,0:20:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iana?
Dialogue: 0,0:20:26.75,0:20:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng... Kompres untuk es...
Dialogue: 0,0:20:28.29,0:20:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa itu suaranya dari jauh...
Dialogue: 0,0:20:30.46,0:20:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu memang suara Nona Iana.
Dialogue: 0,0:20:32.49,0:20:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, aku angkat kepalamu, ya.\NAku tambahkan bantal.
Dialogue: 0,0:20:35.79,0:20:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku letakkan handuk basah di dahimu, ya.
Dialogue: 0,0:20:37.92,0:20:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rapikan ponimu, ya.
Dialogue: 0,0:20:40.37,0:20:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak...
Dialogue: 0,0:20:41.34,0:20:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya.
Dialogue: 0,0:20:42.77,0:20:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal lain yang kau mau?
Dialogue: 0,0:20:44.77,0:20:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang aku mau...
Dialogue: 0,0:20:47.23,0:20:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi... Ini mimpi.
Dialogue: 0,0:20:49.67,0:20:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini cuma mimpi...\NTidak apa-apa, kan?
Dialogue: 0,0:20:52.12,0:20:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegang tanganku...
Dialogue: 0,0:20:56.65,0:20:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik. Tidurlah yang nyenyak, Sol.
Dialogue: 0,0:20:59.74,0:21:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang kulihat dulu,\Nseperti gemuruh petir...
Dialogue: 0,0:21:03.51,0:21:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, saat ini, dirimu\Nyang ada di sampingku...
Dialogue: 0,0:21:05.83,0:21:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hangat seperti matahari setelah hujan.
Dialogue: 0,0:21:09.00,0:21:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin dan enak...
Dialogue: 0,0:21:13.92,0:21:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Sol.
Dialogue: 0,0:21:21.44,0:21:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Argh! Nisse!
Dialogue: 0,0:21:23.26,0:21:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau bangun juga, ya.
Dialogue: 0,0:21:25.69,0:21:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisimu?
Dialogue: 0,0:21:30.24,0:21:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:21:31.27,0:21:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memberimu obat\Nselagi kau tidur tadi.
Dialogue: 0,0:21:34.21,0:21:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu terasa lebih ringan, kan?\NItu obat rahasia yang manjur.
Dialogue: 0,0:21:36.62,0:21:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kau di sini?
Dialogue: 0,0:21:37.86,0:21:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal.
Dialogue: 0,0:21:39.17,0:21:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin...
Dialogue: 0,0:21:40.25,0:21:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak...
Dialogue: 0,0:21:40.91,0:21:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lupakan itu!\N- Hentikan!
Dialogue: 0,0:21:42.13,0:21:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah! Lupakan saja!
Dialogue: 0,0:21:43.84,0:21:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Ougnisse menjaganya dengan baik?
Dialogue: 0,0:21:46.16,0:21:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkatnya aku bisa keluar berbelanja.
Dialogue: 0,0:21:47.97,0:21:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Rasakan ini!
Dialogue: 0,0:21:56.32,0:21:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu. Saya sudah melihat\Nsesuatu yang sangat menarik...
Dialogue: 0,0:21:58.43,0:21:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iana!
Dialogue: 0,0:21:59.15,0:22:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda salah paham! Nona Iana!
Dialogue: 0,0:22:00.58,0:22:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nona Iana!\N- Oh, kau jadi sehat, ya.
Dialogue: 0,0:22:03.36,0:22:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sol dan Nisse! Sol dan Nisse!
Dialogue: 0,0:22:06.33,0:22:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalaku jadi sakit gara-gara\Nmaksudnya berbeda.
