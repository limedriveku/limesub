Dialogue: 0,0:03:08.19,0:03:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, gawat!
Dialogue: 0,0:03:11.03,0:03:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shocker mulai bergerak!
Dialogue: 0,0:03:16.79,0:03:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:22.54,0:03:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:03:23.75,0:03:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:03:24.88,0:03:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:03:39.27,0:03:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka babak belur.
