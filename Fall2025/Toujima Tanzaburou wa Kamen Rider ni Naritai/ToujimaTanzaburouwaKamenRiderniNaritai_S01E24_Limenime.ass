Dialogue: 0,0:16:50.34,0:16:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rider
Dialogue: 0,0:16:53.80,0:16:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punch!
Dialogue: 0,0:17:04.40,0:17:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak percaya
Dialogue: 0,0:17:07.78,0:17:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa kalah dari manusia biasa.
Dialogue: 0,0:17:13.10,0:17:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:17:15.24,0:17:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:17:22.86,0:17:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rider
Dialogue: 0,0:17:29.17,0:17:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kick!
Dialogue: 0,0:17:40.06,0:17:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:18:27.19,0:18:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ke sini untuk menghentikan
Dialogue: 0,0:18:30.77,0:18:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rencana Shocker menaklukkan dunia?
Dialogue: 0,0:18:43.41,0:18:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:19:01.89,0:19:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang manusia mengalahkan monster.
Dialogue: 0,0:19:08.31,0:19:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:19:09.86,0:19:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:19:33.96,0:19:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucunya!
Dialogue: 0,0:19:37.17,0:19:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa wajahmu seperti itu?
Dialogue: 0,0:19:41.10,0:19:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini air mata kebahagiaan.
Dialogue: 0,0:21:05.51,0:21:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin merokok.
Dialogue: 0,0:21:07.43,0:21:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak boleh merokok di sini.
Dialogue: 0,0:21:12.48,0:21:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuba, kau bisa memakannya sendiri?
Dialogue: 0,0:21:14.86,0:21:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu kusuapi dari mulut ke mulut?
Dialogue: 0,0:21:19.07,0:21:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Tidak apa-apa.
Dialogue: 0,0:21:21.61,0:21:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malu-malu.
Dialogue: 0,0:21:34.67,0:21:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tubuhku babak belur,
Dialogue: 0,0:21:36.96,0:21:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa sangat lega.
Dialogue: 0,0:21:41.51,0:21:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udaranya
Dialogue: 0,0:21:43.97,0:21:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}segar.
Dialogue: 0,0:21:47.43,0:21:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau.
Dialogue: 0,0:21:51.10,0:21:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman.
Dialogue: 0,0:21:56.65,0:21:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:22:01.78,0:22:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau babak belur, ya.
Dialogue: 0,0:22:05.86,0:22:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:22:07.45,0:22:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau menang, 'kan?
Dialogue: 0,0:22:09.91,0:22:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:22:15.92,0:22:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah untuk kemenanganmu.
Dialogue: 0,0:22:17.79,0:22:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:22:19.30,0:22:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Paman!
Dialogue: 0,0:22:27.97,0:22:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:22:33.98,0:22:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:22:35.60,0:22:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:37.44,0:22:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak boleh meniru Rider Kick.
Dialogue: 0,0:22:41.78,0:22:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapannya ternyata benar, ya.
Dialogue: 0,0:22:46.86,0:22:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:22:50.16,0:22:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah sembuh, langsung latihan khusus!
Dialogue: 0,0:22:52.87,0:22:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:22:55.75,0:22:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamen Rider tidak akan kalah!
Dialogue: 0,0:22:57.54,0:22:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, V3 tidak akan kalah!
Dialogue: 0,0:22:59.63,0:23:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini aku pasti menang!
Dialogue: 0,0:23:01.50,0:23:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalian...\N- Tidak, aku akan menang!
Dialogue: 0,0:23:03.05,0:23:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia cuma pakai topeng Kamen Rider.\N- Kamen Rider terkuat!
Dialogue: 0,0:23:04.76,0:23:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia hanya pria tua yang sangat kuat.\N- Tidak, V3 yang terkuat!
Dialogue: 0,0:23:07.43,0:23:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Kamen Rider!
Dialogue: 0,0:23:08.39,0:23:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lihat!\N- Tidak, V3 terkuat!
Dialogue: 0,0:23:10.10,0:23:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melaporkan dari
Dialogue: 0,0:23:11.01,0:23:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat kejadian perampokan Shocker.
Dialogue: 0,0:23:15.73,0:23:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Perampok Shocker!\N- Pagi tadi,
Dialogue: 0,0:23:16.81,0:23:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebuah toko perhiasan di kota\Ntelah dirampok oleh empat orang.
Dialogue: 0,0:23:20.52,0:23:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi mengaitkan kejadian ini\Ndengan perampokan sebelumnya
Dialogue: 0,0:23:23.28,0:23:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan meningkatkan kewaspadaan karena\Nperampokan mungkin akan berlanjut.
Dialogue: 0,0:23:33.95,0:23:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah, Shocker!
Dialogue: 0,0:23:36.66,0:23:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
