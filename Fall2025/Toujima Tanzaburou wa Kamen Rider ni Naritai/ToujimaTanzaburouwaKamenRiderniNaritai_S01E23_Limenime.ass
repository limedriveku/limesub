Dialogue: 0,0:15:37.07,0:15:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakanku...
Dialogue: 0,0:15:40.74,0:15:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih cepat!
Dialogue: 0,0:15:50.96,0:15:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin Denpa Nage!
Dialogue: 0,0:16:12.19,0:16:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya.
Dialogue: 0,0:16:15.23,0:16:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rainmaker milik Okada Kazuchika,
Dialogue: 0,0:16:18.36,0:16:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dibalas dengan STO milik Ogawa Naoya.
Dialogue: 0,0:16:26.20,0:16:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tadi Shin Denpa Nage!
Dialogue: 0,0:16:52.31,0:16:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah lagi
Dialogue: 0,0:16:57.15,0:17:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh orang biasa yang bahkan bukan Shocker.
Dialogue: 0,0:17:06.45,0:17:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:17:07.95,0:17:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan itu
Dialogue: 0,0:17:10.66,0:17:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}takkan bisa dicapai hanya dengan main-main.
Dialogue: 0,0:17:15.42,0:17:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan tekadnya
Dialogue: 0,0:17:18.63,0:17:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat berbeda.
Dialogue: 0,0:17:24.30,0:17:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga...
Dialogue: 0,0:17:26.22,0:17:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin jadi lebih kuat.
Dialogue: 0,0:17:40.77,0:17:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, sudah siap?
Dialogue: 0,0:17:43.49,0:17:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:17:45.24,0:17:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:17:46.66,0:17:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:17:48.20,0:17:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:17:50.08,0:17:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini juga sudah di posisi.
Dialogue: 0,0:17:52.75,0:17:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti menang.
Dialogue: 0,0:17:54.41,0:17:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuriko memang hebat.
Dialogue: 0,0:17:58.50,0:17:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:18:16.60,0:18:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang hari ini.
Dialogue: 0,0:18:20.44,0:18:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir, untuk semua yang kami sayangi,\Nkami siapkan hadiah terbaik.
Dialogue: 0,0:18:59.52,0:19:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:19:11.53,0:19:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebakaran?
Dialogue: 0,0:19:14.16,0:19:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keadaan darurat.
Dialogue: 0,0:19:17.41,0:19:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah terjadi kebakaran di sini.
Dialogue: 0,0:19:19.62,0:19:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konser hari ini dibatalkan.
Dialogue: 0,0:19:22.29,0:19:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para penonton, silakan ikuti arahan staf
Dialogue: 0,0:19:25.88,0:19:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan keluar dengan tenang melalui\Npintu darurat terdekat.
Dialogue: 0,0:19:30.76,0:19:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ulangi.
Dialogue: 0,0:19:33.97,0:19:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semuanya, harap tenang!\N- Tolong jangan berlari!
Dialogue: 0,0:19:37.43,0:19:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikuti orang di depan Anda!
Dialogue: 0,0:19:39.14,0:19:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan panik\Ndan keluarlah dengan tenang!
Dialogue: 0,0:19:41.69,0:19:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini!
Dialogue: 0,0:19:44.98,0:19:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua.
Dialogue: 0,0:19:46.57,0:19:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan mereka lolos!
Dialogue: 0,0:19:48.36,0:19:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:19:56.62,0:19:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan harap!
Dialogue: 0,0:20:06.67,0:20:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reiko!
Dialogue: 0,0:20:08.21,0:20:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menyelamatkanmu,\Nakan kukalahkan bosmu!
Dialogue: 0,0:20:13.01,0:20:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tojima! Kakak!
Dialogue: 0,0:20:14.64,0:20:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:20:22.77,0:20:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah, Shocker!
Dialogue: 0,0:20:31.40,0:20:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:20:40.12,0:20:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Rider!
Dialogue: 0,0:20:43.33,0:20:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Double Kick!
Dialogue: 0,0:20:52.88,0:20:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Koomori Otoko!
Dialogue: 0,0:20:54.39,0:20:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kalian?
Dialogue: 0,0:20:58.56,0:20:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamen Rider!
Dialogue: 0,0:21:00.56,0:21:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah lama menunggu saat ini!
Dialogue: 0,0:21:02.89,0:21:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan Shocker lolos lagi!
Dialogue: 0,0:21:17.12,0:21:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini benar-benar...
Dialogue: 0,0:21:34.84,0:21:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh kalian semua!
Dialogue: 0,0:21:43.98,0:21:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali.
Dialogue: 0,0:21:47.02,0:21:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:21:48.48,0:21:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kali ini...
Dialogue: 0,0:21:51.23,0:21:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kalian bisa selamat?
