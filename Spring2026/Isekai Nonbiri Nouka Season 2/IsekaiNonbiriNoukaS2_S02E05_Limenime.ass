Dialogue: 0,0:01:38.31,0:01:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabut.
Dialogue: 0,0:01:40.83,0:01:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, untung masih utuh.
Dialogue: 0,0:01:43.08,0:01:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersihkan, ya.
Dialogue: 0,0:01:49.19,0:01:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:01:50.44,0:01:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:01:51.77,0:01:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah...
Dialogue: 0,0:01:57.03,0:01:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis dan enak.
Dialogue: 0,0:01:58.81,0:02:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak dimakan mentah jadi salad.
Dialogue: 0,0:02:01.60,0:02:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, aku juga mau coba.
Dialogue: 0,0:02:04.36,0:02:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, tapi sudah kugigit sedikit.
Dialogue: 0,0:02:10.49,0:02:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:02:13.49,0:02:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedas!
Dialogue: 0,0:02:15.56,0:02:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu gigit bagian yang itu, ya.
Dialogue: 0,0:02:18.12,0:02:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas.
Dialogue: 0,0:02:19.76,0:02:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian ujungnya pedas,
Dialogue: 0,0:02:21.88,0:02:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih cocok dijadikan acar.
Dialogue: 0,0:02:23.79,0:02:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri tahu dari awal.
Dialogue: 0,0:02:25.80,0:02:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:02:27.13,0:02:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya stok makanan itu harus,
Dialogue: 0,0:02:29.63,0:02:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita buat acarnya agak banyak.
Dialogue: 0,0:02:34.36,0:02:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahas soal lobak,\Nbisa dibuat jadi suwir goreng kering.
Dialogue: 0,0:02:38.39,0:02:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara buatnya?
Dialogue: 0,0:02:40.84,0:02:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipotong lalu dijemur?
Dialogue: 0,0:02:42.80,0:02:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades!
Dialogue: 0,0:02:45.57,0:02:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:02:46.65,0:02:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada orang-orang aneh.
Dialogue: 0,0:02:49.97,0:02:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang aneh?
Dialogue: 0,0:02:56.01,0:02:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang aneh!
Dialogue: 0,0:02:59.63,0:03:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Leluhur.
Dialogue: 0,0:03:02.77,0:03:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Kades!\NKamu kelihatan sehat, ya!
Dialogue: 0,0:03:05.65,0:03:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:06.54,0:03:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga terlihat sehat.
Dialogue: 0,0:03:08.56,0:03:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bahkan kalau dibunuh pun,\Nmungkin aku tak akan mati.
Dialogue: 0,0:03:12.32,0:03:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mungkin bisa mati.
Dialogue: 0,0:03:14.11,0:03:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu karena belum pernah mati.
Dialogue: 0,0:03:17.35,0:03:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Alfred! Lama tak bertemu,\Nsudah 20 tahun, ya?
Dialogue: 0,0:03:22.29,0:03:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setahun pun belum.
Dialogue: 0,0:03:24.29,0:03:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku sering lupa\Nkarena sudah hidup lama.
Dialogue: 0,0:03:27.29,0:03:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, apa dia istrimu?
Dialogue: 0,0:03:31.47,0:03:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:03:32.65,0:03:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu kehormatan dibilang begitu, tapi bukan.
Dialogue: 0,0:03:36.32,0:03:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Foosh.
Dialogue: 0,0:03:38.60,0:03:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu pendeta dari agama Korin.
Dialogue: 0,0:03:41.33,0:03:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Hiraku, kades di sini.
Dialogue: 0,0:03:43.92,0:03:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agama Korin itu apa?
Dialogue: 0,0:03:45.53,0:03:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku belum cerita, ya?
Dialogue: 0,0:03:49.05,0:03:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat diberi piano waktu itu,\Naku pernah dengar namanya saja.
Dialogue: 0,0:03:52.56,0:03:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya, semacam pemersatu aliran\Nyang menyembah berbagai dewa.
Dialogue: 0,0:03:59.60,0:04:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajarannya bebas, selama memuliakan\Ndewanya masing-masing.
Dialogue: 0,0:04:03.23,0:04:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih seperti itu ajaran agama Korin.
Dialogue: 0,0:04:06.11,0:04:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya cukup santai, ya.
Dialogue: 0,0:04:08.49,0:04:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Leluhur salah satu pendirinya.
Dialogue: 0,0:04:11.75,0:04:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir dia cuma orang penting,\Nternyata dia hebat sekali, ya.
Dialogue: 0,0:04:15.27,0:04:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:04:16.72,0:04:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendeta Agung Foosh juga tokoh penting
Dialogue: 0,0:04:18.99,0:04:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bahkan disambut parade\Nkalau dia berkunjung ke kota.
Dialogue: 0,0:04:23.24,0:04:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kita harus menjamunya dengan benar.
Dialogue: 0,0:04:26.79,0:04:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hormat!
Dialogue: 0,0:04:28.37,0:04:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu, justru aku sudah\Nmerepotkan datang ke sini.
Dialogue: 0,0:04:33.27,0:04:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, hari ini kami ke sini\Nkarena dia punya permintaan.
Dialogue: 0,0:04:37.13,0:04:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permintaan?
Dialogue: 0,0:04:39.88,0:04:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong
Dialogue: 0,0:04:41.76,0:04:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selamatkan nyawa anakku.
Dialogue: 0,0:04:47.91,0:04:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar di desa ini bukan hanya
Dialogue: 0,0:04:53.00,0:04:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada Putri Vampir Luulucy
Dialogue: 0,0:04:55.92,0:04:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terkenal sebagai ahli herbal,
Dialogue: 0,0:04:59.53,0:05:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi juga ada peneliti yang tak tertandingi\Ndalam meracik obat penyembuh
Dialogue: 0,0:05:04.28,0:05:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mencatat banyak sejarah,\NProfesor Flora Sactu.
Dialogue: 0,0:05:08.62,0:05:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa denganku?
Dialogue: 0,0:05:11.47,0:05:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya hebat, ya.
Dialogue: 0,0:05:13.32,0:05:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya bermaksud sombong,
Dialogue: 0,0:05:15.29,0:05:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi buku yang kutulis,
Dialogue: 0,0:05:16.99,0:05:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipakai sebagai buku pelajaran
Dialogue: 0,0:05:18.43,0:05:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sekolah sihir mana pun.
Dialogue: 0,0:05:21.30,0:05:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal penyakit anakmu, kalau gejalanya\Ndijelaskan, mungkin bisa diatasi!
Dialogue: 0,0:05:26.80,0:05:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini akan merepotkan...
Dialogue: 0,0:05:28.81,0:05:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kasus yang sangat langka.
Dialogue: 0,0:05:31.87,0:05:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ini lebih rumit\Ndari kasus-kasus yang sulit.
Dialogue: 0,0:05:35.47,0:05:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar, ya.
Dialogue: 0,0:05:37.32,0:05:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ahli obat dan penyembuh\Njuga bilang hal yang sama.
Dialogue: 0,0:05:42.32,0:05:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kalian pun kesulitan, ya.
Dialogue: 0,0:05:45.55,0:05:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada cara agar bisa menyembuhkannya?
Dialogue: 0,0:05:48.97,0:05:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang sulit,\Ntapi kita tak bisa diam dan biarkan.
Dialogue: 0,0:05:53.07,0:05:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kita harus cari cara!
Dialogue: 0,0:05:56.33,0:05:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, mereka berdua
Dialogue: 0,0:05:58.07,0:06:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}fokus di pondok dan mulai riset.
Dialogue: 0,0:06:00.59,0:06:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumpulkan bahan dari bagian ini\Nsampai sini di buku ini!
Dialogue: 0,0:06:04.76,0:06:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:06:06.10,0:06:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Holy Drop, bunga putih\Nyang tumbuh di gunung salju...
Dialogue: 0,0:06:10.50,0:06:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini, ya?
Dialogue: 0,0:06:12.75,0:06:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah diberi ini saat menjenguk Luu.
Dialogue: 0,0:06:14.51,0:06:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:06:15.86,0:06:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi mengambilnya, ya.
Dialogue: 0,0:06:20.00,0:06:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, jamur pengembara malam\Ndi Hutan Gelap.
Dialogue: 0,0:06:24.36,0:06:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal hutan, serahkan pada kami!
Dialogue: 0,0:06:28.72,0:06:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta rahasia yang tak seorang pun\Nbisa mendapatkannya.
Dialogue: 0,0:06:33.77,0:06:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya serius, ya.
Dialogue: 0,0:06:36.52,0:06:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya
Dialogue: 0,0:06:37.88,0:06:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air Mata Naga.
Dialogue: 0,0:06:43.63,0:06:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelitik!
Dialogue: 0,0:06:45.89,0:06:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Geli!
Dialogue: 0,0:06:53.77,0:06:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa benar ini barangnya?
Dialogue: 0,0:06:57.65,0:07:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, batu hitam dari Gunung Gullguld.
Dialogue: 0,0:07:00.97,0:07:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku pernah dengar.
Dialogue: 0,0:07:02.90,0:07:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu.
Dialogue: 0,0:07:04.83,0:07:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu dipakai Doraimu
Dialogue: 0,0:07:06.78,0:07:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengganjal pintu belakang
Dialogue: 0,0:07:09.28,0:07:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gudang sarangnya.
Dialogue: 0,0:07:11.84,0:07:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kuambilkan?
Dialogue: 0,0:07:13.21,0:07:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tolong.
Dialogue: 0,0:07:16.60,0:07:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kembali!
Dialogue: 0,0:07:18.42,0:07:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baik-baik saja?
Dialogue: 0,0:07:21.27,0:07:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamur pengembara malam,\Nternyata lebih kuat dari yang dirumorkan!
Dialogue: 0,0:07:25.68,0:07:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamur punya kekuatan fisik?
Dialogue: 0,0:07:28.41,0:07:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:07:29.79,0:07:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih kecil dari yang kubayangkan.
Dialogue: 0,0:07:32.80,0:07:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua bahan yang dikumpulkan semuanya.
Dialogue: 0,0:07:35.94,0:07:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pot tanaman ini,\Nkupesan dari Michael.
Dialogue: 0,0:07:39.71,0:07:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang hebat,\Npadahal ini herbal langka.
Dialogue: 0,0:07:43.44,0:07:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencabutnya harus hati-hati.
Dialogue: 0,0:07:46.09,0:07:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah banyak peneliti yang jadi korban.
Dialogue: 0,0:07:48.91,0:07:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kalau dicabut,\Nmuncul wajah
Dialogue: 0,0:07:51.77,0:07:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu teriak dan berbahaya?
Dialogue: 0,0:07:54.59,0:07:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah langsung dicabut!
Dialogue: 0,0:07:59.33,0:08:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terjadi apa pun.
Dialogue: 0,0:08:03.75,0:08:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dicabut, keluar bau menyengat\Nyang membuat monster pun kabur.
Dialogue: 0,0:08:06.76,0:08:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlambat beri tahu, ya.
Dialogue: 0,0:08:08.33,0:08:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya sangat menyengat!
Dialogue: 0,0:08:10.34,0:08:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas, baunya tidak berbahaya,\Ncukup hilangkan dengan mandi.
Dialogue: 0,0:08:13.91,0:08:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya kuserahkan pada kalian.
Dialogue: 0,0:08:18.27,0:08:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, semua bahan sudah terkumpul,
Dialogue: 0,0:08:20.76,0:08:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bagian sulitnya baru dimulai sekarang.
Dialogue: 0,0:08:23.13,0:08:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang! Tutup lalu putar ke kanan\Ndan panaskan sepuluh detik!
Dialogue: 0,0:08:26.15,0:08:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudutnya kurang pas!
Dialogue: 0,0:08:28.11,0:08:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah berhari-hari mencoba dan gagal,
Dialogue: 0,0:08:30.41,0:08:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Foosh berdoa pada patung dewa\Ndari pagi sampai malam.
Dialogue: 0,0:08:36.12,0:08:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jangan dilepas begitu!
Dialogue: 0,0:08:37.75,0:08:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur ke sana!
Dialogue: 0,0:08:38.89,0:08:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam dan terbakar saja!
Dialogue: 0,0:08:42.09,0:08:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah malam, sebaiknya ke penginapan.
Dialogue: 0,0:08:44.97,0:08:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, tak perlu cemaskan aku.
Dialogue: 0,0:08:49.24,0:08:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa kulakukan hanyalah berdoa.
Dialogue: 0,0:08:52.89,0:08:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini!\NFokuskan semua kekuatan sihir!
Dialogue: 0,0:08:54.91,0:08:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa!\NDengan api sebesar ini...
Dialogue: 0,0:08:57.09,0:09:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima, empat, tiga, dua, satu...
Dialogue: 0,0:09:01.57,0:09:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ledakkan!
Dialogue: 0,0:09:08.80,0:09:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jadi ini...
Dialogue: 0,0:09:10.91,0:09:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:09:13.36,0:09:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah susah payah dan lelah.
Dialogue: 0,0:09:15.56,0:09:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, cepat berikan itu pada anakmu.
Dialogue: 0,0:09:18.66,0:09:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan segera membaik!
Dialogue: 0,0:09:21.15,0:09:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:09:22.75,0:09:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebaikan ini, pasti akan kubalas!
Dialogue: 0,0:09:28.73,0:09:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, sampai jumpa lagi dalam waktu dekat.
Dialogue: 0,0:09:31.72,0:09:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sepuluh tahun lagi.
Dialogue: 0,0:09:33.76,0:09:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bicara soal waktu,\Ndia sudah pikun.
Dialogue: 0,0:09:36.69,0:09:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah bisa selesai.\NKalian berdua, kerja bagus.
Dialogue: 0,0:09:40.13,0:09:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang melelahkan.
Dialogue: 0,0:09:42.28,0:09:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat ini saja bisa jadi beberapa buku.
Dialogue: 0,0:09:45.79,0:09:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kita harus mengatasi masalah sisanya.
Dialogue: 0,0:09:50.07,0:09:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Foosh terus berdoa setiap hari,
Dialogue: 0,0:09:53.72,0:09:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}patung dewa jadi bersinar terang.
Dialogue: 0,0:09:57.77,0:10:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini karena kasih sayang\Norang tua pada anaknya,
Dialogue: 0,0:10:00.68,0:10:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau mukjizat dari dewa.
Dialogue: 0,0:10:03.08,0:10:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun alasannya,
Dialogue: 0,0:10:04.84,0:10:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena terus bersinar sampai malam,\NZabuton dan yang lainnya jadi sulit tidur.
Dialogue: 0,0:10:10.34,0:10:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus minta maaf pada dewa,
Dialogue: 0,0:10:13.60,0:10:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi selain untuk berdoa,\Npintunya harus kututup.
Dialogue: 0,0:10:18.85,0:10:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isekai Nonbiri Nouka 2.
Dialogue: 0,0:10:25.10,0:10:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau matangnya begitu,\Nkatanya lebih enak dipanggang.
Dialogue: 0,0:10:28.21,0:10:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:10:29.87,0:10:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya jadi tidak asam\Ndan lebih lembut.
Dialogue: 0,0:10:34.20,0:10:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:35.81,0:10:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pohon apa, ya?
Dialogue: 0,0:10:37.73,0:10:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai lupa soal area percobaan ini.
Dialogue: 0,0:10:42.33,0:10:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan Alat Bertani Mahabisa dari dewa,
Dialogue: 0,0:10:45.29,0:10:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami bisa menanam apa pun\Nsesuai yang dibayangkan.
Dialogue: 0,0:10:48.37,0:10:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama tahu apa yang ingin ditanam,
Dialogue: 0,0:10:50.48,0:10:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak perlu cemas soal benih
Dialogue: 0,0:10:51.88,0:10:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ataupun cara menanamnya.
Dialogue: 0,0:10:53.03,0:10:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saat sudah tumbuh,
Dialogue: 0,0:10:54.13,0:10:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bentuknya kadang beda dari yang dibayangkan.
Dialogue: 0,0:10:58.64,0:11:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanam wijen!\NTanam, tanam, tanam!
Dialogue: 0,0:11:02.16,0:11:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi wijen tumbuhnya seperti ini.
Dialogue: 0,0:11:05.69,0:11:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pohon apa?
Dialogue: 0,0:11:07.96,0:11:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku juga tidak tahu.
Dialogue: 0,0:11:10.72,0:11:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat mencoba menanam\Nbanyak tanaman baru,
Dialogue: 0,0:11:14.64,0:11:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau yang ini...
Dialogue: 0,0:11:16.72,0:11:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak perlu terlalu dibatasi.\NKarena ini untuk percobaan,
Dialogue: 0,0:11:21.66,0:11:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebaiknya semua yang ditanam\Ndi desa harus dicatat, ya.
Dialogue: 0,0:11:25.41,0:11:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti bisa tercampur dengan tanaman lain.
Dialogue: 0,0:11:28.93,0:11:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:11:30.45,0:11:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini apa, ya?
Dialogue: 0,0:11:32.92,0:11:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada buah hijau.
Dialogue: 0,0:11:35.77,0:11:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, mirip plum, tapi kebesaran.
Dialogue: 0,0:11:39.68,0:11:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiwi juga bukan, kelihatannya keras.
Dialogue: 0,0:11:42.93,0:11:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:11:44.40,0:11:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buah dari pohon ini, kan?
Dialogue: 0,0:11:46.40,0:11:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jangan-jangan...
Dialogue: 0,0:11:48.44,0:11:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:11:50.40,0:11:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacang kenari!
Dialogue: 0,0:11:51.94,0:11:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir selama ini kacang kenari\Ntumbuh di pohon yang biasa kulihat.
Dialogue: 0,0:11:55.59,0:11:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bijinya?
Dialogue: 0,0:11:57.81,0:11:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:11:59.72,0:12:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa makan isi cangkangnya.
Dialogue: 0,0:12:02.18,0:12:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena keras, kita perlu alat.
Dialogue: 0,0:12:06.76,0:12:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terbuka.
Dialogue: 0,0:12:07.72,0:12:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuat!
Dialogue: 0,0:12:09.33,0:12:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh dimakan?
Dialogue: 0,0:12:11.28,0:12:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Entahlah, mungkin dimasak dulu.\N- Kacang kenari.
Dialogue: 0,0:12:16.19,0:12:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pohon yang ini juga ada buahnya.
Dialogue: 0,0:12:18.96,0:12:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini lebih kecil dari kacang kenari.
Dialogue: 0,0:12:22.60,0:12:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalamnya juga ada bijinya, ya.
Dialogue: 0,0:12:25.52,0:12:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibuka, ya?
Dialogue: 0,0:12:30.17,0:12:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancur.
Dialogue: 0,0:12:31.61,0:12:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini kacang almon!
Dialogue: 0,0:12:33.61,0:12:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini kacang almon.
Dialogue: 0,0:12:35.99,0:12:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenari lalu almon.
Dialogue: 0,0:12:38.51,0:12:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polanya mulai kelihatan.
Dialogue: 0,0:12:40.36,0:12:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini tidak ada buahnya, ya.
Dialogue: 0,0:12:43.63,0:12:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti ini daun sayuran?
Dialogue: 0,0:12:46.21,0:12:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin seperti kentang?
Dialogue: 0,0:12:49.31,0:12:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini mungkin umbi.
Dialogue: 0,0:12:53.20,0:12:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kacang yang tumbuh di dalam tanah.
Dialogue: 0,0:12:55.88,0:12:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacang tanah.
Dialogue: 0,0:12:57.47,0:12:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuknya unik, ya.
Dialogue: 0,0:12:59.63,0:13:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacang tanah.\NDari luar, seperti kacang biasa.
Dialogue: 0,0:13:03.39,0:13:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, ini jenisnya apa, ya?
Dialogue: 0,0:13:07.21,0:13:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacang kenari, kacang almon,\Ndan kacang tanah.
Dialogue: 0,0:13:10.15,0:13:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah begini, jawabannya satu.
Dialogue: 0,0:13:12.40,0:13:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kacang, kacang, kacang!\N- Saat itu, mungkin aku
Dialogue: 0,0:13:14.90,0:13:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kacang, kacang, kacang!\N- ingin makan kacang campur.
Dialogue: 0,0:13:17.67,0:13:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kacang, kacang, kacang!\N- Juga sekalian ingin minum bir,
Dialogue: 0,0:13:20.40,0:13:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bir! Bir!\N- mungkin tempat ini sudah jadi ladang gandum.
Dialogue: 0,0:13:23.78,0:13:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau ini ladang kacang campur,
Dialogue: 0,0:13:28.35,0:13:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}buah yang paling mencolok itu apa?
Dialogue: 0,0:13:30.69,0:13:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warnanya merah cantik,\Nmungkin mirip apel?
Dialogue: 0,0:13:34.79,0:13:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang pedas bisa dipakai buat bumbu kari.\NApa namanya, ya?
Dialogue: 0,0:13:39.40,0:13:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabai?
Dialogue: 0,0:13:40.83,0:13:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi paprika juga bukan.
Dialogue: 0,0:13:44.81,0:13:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ladang kacang campur.
Dialogue: 0,0:13:47.09,0:13:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin jawabannya sudah jelas.
Dialogue: 0,0:13:50.29,0:13:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu di bawah buahnya, ya.
Dialogue: 0,0:13:53.36,0:13:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk melengkungnya khas.
Dialogue: 0,0:13:56.04,0:14:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tetap saja sulit dipercaya bisa begini.
Dialogue: 0,0:14:00.35,0:14:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ini juga dimakan\Nbagian dalam cangkangnya?
Dialogue: 0,0:14:04.21,0:14:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya kuat!
Dialogue: 0,0:14:06.45,0:14:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga ini kacang mete.
Dialogue: 0,0:14:09.47,0:14:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka bentuknya seperti ini.
Dialogue: 0,0:14:12.23,0:14:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa tumbuh seperti ini?
Dialogue: 0,0:14:14.46,0:14:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk buah merahnya,\Nrasanya mirip apel yang agak sepat.
Dialogue: 0,0:14:18.36,0:14:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin mirip buah pir.
Dialogue: 0,0:14:21.12,0:14:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipanggang, hasilnya seperti ini.
Dialogue: 0,0:14:23.47,0:14:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma harumnya enak, ya.
Dialogue: 0,0:14:25.81,0:14:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok jadi teman minum teh.
Dialogue: 0,0:14:28.60,0:14:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibawa ke Kerajaan Iblis,\Npasti lalu keras.
Dialogue: 0,0:14:31.79,0:14:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, ini semua tahan lama\Ndan mudah diperdagangkan.
Dialogue: 0,0:14:35.67,0:14:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke depannya, kalau senggang,\Naku akan tanam tanaman baru lagi.
Dialogue: 0,0:14:39.79,0:14:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ke depannya,
Dialogue: 0,0:14:42.55,0:14:44.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan ada yang lebih aneh dari kacang mete?
Dialogue: 0,0:14:44.99,0:14:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isekai Nouka 2!
Dialogue: 0,0:14:55.53,0:14:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita bahas slime.
Dialogue: 0,0:14:58.89,0:15:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu slime yang membersihkan\Nair di semua desa,
Dialogue: 0,0:15:03.13,0:15:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}suatu hari jatuh ke tong anggur.
Dialogue: 0,0:15:05.38,0:15:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerapnya dan jadi slime sake.
Dialogue: 0,0:15:08.15,0:15:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu,
Dialogue: 0,0:15:08.89,0:15:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiap ada pesta, slime sake selalu muncul
Dialogue: 0,0:15:11.47,0:15:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiba-tiba untuk ikut minum.
Dialogue: 0,0:15:15.64,0:15:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, sifatnya masih jadi misteri.
Dialogue: 0,0:15:20.33,0:15:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai, ya!
Dialogue: 0,0:15:22.45,0:15:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:15:24.27,0:15:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lempar!
Dialogue: 0,0:15:26.53,0:15:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, berhasil, ya.
Dialogue: 0,0:15:29.01,0:15:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kades!
Dialogue: 0,0:15:31.54,0:15:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi apa?
Dialogue: 0,0:15:33.43,0:15:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uji coba parasut.
Dialogue: 0,0:15:34.95,0:15:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parasut?\NApa itu?
Dialogue: 0,0:15:37.54,0:15:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk jaga-jaga
Dialogue: 0,0:15:39.69,0:15:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau jatuh saat di punggung naga.
Dialogue: 0,0:15:43.19,0:15:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa itu pun, tinggal mendarat biasa saja.
Dialogue: 0,0:15:47.29,0:15:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak semuanya bisa melakukan itu.
Dialogue: 0,0:15:50.43,0:15:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi berhasil,
Dialogue: 0,0:15:52.83,0:15:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi belum bisa bawa yang terlalu berat, ya.
Dialogue: 0,0:15:55.61,0:15:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin harus dibuat lebih besar lagi.
Dialogue: 0,0:15:58.19,0:16:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi nanti repot dan gampang tersangkut.
Dialogue: 0,0:16:04.08,0:16:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Slime sake?
Dialogue: 0,0:16:07.64,0:16:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba naik?
Dialogue: 0,0:16:09.93,0:16:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahaya tidak, ya?
Dialogue: 0,0:16:11.60,0:16:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, tingginya masih aman.
Dialogue: 0,0:16:14.71,0:16:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:16:17.17,0:16:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai apresiasi atas nyalinya,\Nkami biarkan sake slime mencoba.
Dialogue: 0,0:16:22.03,0:16:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai, ya.
Dialogue: 0,0:16:24.46,0:16:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lempar!
Dialogue: 0,0:16:33.11,0:16:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir dia cuma tertarik pada sake.
Dialogue: 0,0:16:36.67,0:16:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang dia bisa jadi pilot uji coba.
Dialogue: 0,0:16:39.98,0:16:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:42.36,0:16:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:16:46.11,0:16:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia baik-baik saja.
Dialogue: 0,0:16:47.81,0:16:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sudah bosan.
Dialogue: 0,0:16:49.33,0:16:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung lompat memang lebih cepat.
Dialogue: 0,0:16:52.33,0:16:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosoknya masih penuh misteri,
Dialogue: 0,0:16:55.04,0:16:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia bertindak sesuka hati.
Dialogue: 0,0:17:11.49,0:17:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:17:12.52,0:17:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Yaa.
Dialogue: 0,0:17:14.22,0:17:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal rencana kerja ke depannya...
Dialogue: 0,0:17:17.11,0:17:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NBagus, kan?
Dialogue: 0,0:17:19.28,0:17:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesanannya harusnya untuk wadah makan biasa.
Dialogue: 0,0:17:22.39,0:17:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk banyak orang!\NIni bisa menampung bahan
Dialogue: 0,0:17:25.19,0:17:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukuran besar lebih unggul dari yang kecil!
Dialogue: 0,0:17:29.74,0:17:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagal, ya.\NSepertinya harus dibuat lebih tebal dan kuat.
Dialogue: 0,0:17:34.01,0:17:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong buat ukuran yang kecil dulu.
Dialogue: 0,0:17:36.60,0:17:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Elf Gunung, Hiterto.
Dialogue: 0,0:17:39.33,0:17:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asisten Nona Yaa.
Dialogue: 0,0:17:42.19,0:17:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil, kami berdua tumbuh bersama.
Dialogue: 0,0:17:45.75,0:17:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku yang jadi pemimpin.
Dialogue: 0,0:17:49.26,0:17:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku menolak dan merasa posisi wakil\Nlebih cocok dengan sifatku.
Dialogue: 0,0:17:53.97,0:17:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang menyerahkan\Ntanggung jawab pada Nona Yaa,
Dialogue: 0,0:17:56.51,0:17:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hasilnya justru bagus.
Dialogue: 0,0:17:59.85,0:18:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, karena berbagai hal,
Dialogue: 0,0:18:03.90,0:18:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang ras kami hidup\Ndi Desa Pohon Besar.
Dialogue: 0,0:18:07.83,0:18:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku lihat
Dialogue: 0,0:18:09.49,0:18:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada makanan enak,\N- ada makanan sebanyak ini.
Dialogue: 0,0:18:11.28,0:18:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- ada mandi air hangat,\N- Airnya tidak dingin!
Dialogue: 0,0:18:14.03,0:18:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- ada tempat tidur nyaman.\N- Punggungku tidak sakit!
Dialogue: 0,0:18:16.15,0:18:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini pertama kalinya\N- Punggungku tidak sakit!
Dialogue: 0,0:18:19.23,0:18:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ras kami bisa hidup nyaman.
Dialogue: 0,0:18:21.54,0:18:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat berterima kasih\Npada Desa Pohon Besar
Dialogue: 0,0:18:24.71,0:18:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sudah menerima kami.
Dialogue: 0,0:18:26.97,0:18:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai wakil pemimpin ras,
Dialogue: 0,0:18:29.25,0:18:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus memikirkan bagaimana
Dialogue: 0,0:18:33.09,0:18:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cara mempertahankan kehidupan ini.
Dialogue: 0,0:18:34.80,0:18:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Minum segelas saja dunia langsung berputar!\N- Nona Yaa tak terlalu memikirkan hal itu.
Dialogue: 0,0:18:40.56,0:18:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang paling penting baginya,
Dialogue: 0,0:18:42.48,0:18:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menunjukkan kemampuan\Nyang berguna bagi desa.
Dialogue: 0,0:18:46.12,0:18:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya, kami punya kemampuan terampil,
Dialogue: 0,0:18:49.33,0:18:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi bisa berkontribusi.
Dialogue: 0,0:18:52.49,0:18:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk tugas kalian masing-masing...
Dialogue: 0,0:18:53.99,0:18:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:18:54.99,0:18:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal penting lainnya\Nadalah hubungan dengan Kades,
Dialogue: 0,0:18:59.96,0:19:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang paling penting di desa.
Dialogue: 0,0:19:02.83,0:19:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari yang kuamati,
Dialogue: 0,0:19:08.07,0:19:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau tak pilih kasih pada warganya.
Dialogue: 0,0:19:11.12,0:19:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,\Ndapat kesan baik darinya itu harus.
Dialogue: 0,0:19:15.76,0:19:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya, Nona Yaa juga tak keberatan\Nuntuk menarik perhatiannya.
Dialogue: 0,0:19:21.88,0:19:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:19:22.89,0:19:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang memikirkan sesuatu?
Dialogue: 0,0:19:25.61,0:19:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaa?
Dialogue: 0,0:19:27.15,0:19:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!
Dialogue: 0,0:19:29.08,0:19:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:19:30.01,0:19:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja!
Dialogue: 0,0:19:31.40,0:19:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:19:32.69,0:19:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang ditebak.
Dialogue: 0,0:19:34.65,0:19:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku kagum padanya.
Dialogue: 0,0:19:42.33,0:19:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tujuannya sudah jelas!
Dialogue: 0,0:19:44.64,0:19:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus lebih berusaha lagi\Nagar bisa makin dekat dengan Kades!
Dialogue: 0,0:19:47.57,0:19:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:48.40,0:19:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan bantu!
Dialogue: 0,0:19:52.27,0:19:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:20:01.56,0:20:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:20:02.63,0:20:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:20:04.06,0:20:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku latihan keras agar Kades melirik padaku!
Dialogue: 0,0:20:07.93,0:20:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:09.06,0:20:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap kali mencoba,
Dialogue: 0,0:20:11.06,0:20:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bebannya kutambah,
Dialogue: 0,0:20:11.73,0:20:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sekarang,
Dialogue: 0,0:20:12.57,0:20:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa angkat
Dialogue: 0,0:20:14.07,0:20:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}batu sebesar ini!
Dialogue: 0,0:20:14.84,0:20:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caranya tidak harus begini!
Dialogue: 0,0:20:16.82,0:20:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau menarik perhatian Kades,\Ntak perlu pamer kekuatan otot!
Dialogue: 0,0:20:19.56,0:20:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:20.82,0:20:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:22.31,0:20:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dari dulu rumornya kalau ingin\Ndapat pria, kita harus melatih otot?
Dialogue: 0,0:20:26.97,0:20:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu kalau mau menculiknya dengan paksa!\N- Wah!
Dialogue: 0,0:20:29.68,0:20:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu kalau mau menculiknya dengan paksa!\N- Culik saja!
Dialogue: 0,0:20:31.59,0:20:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di legenda elf memang tidak bisa\Ndipastikan pernah terjadi hal seperti itu.
Dialogue: 0,0:20:37.21,0:20:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melakukan kekerasan seperti itu,\Nnyawa kita saja tak akan cukup!
Dialogue: 0,0:20:43.07,0:20:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:20:44.60,0:20:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang di sini sangat kuat.
Dialogue: 0,0:20:48.56,0:20:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakannya saat turnamen!
Dialogue: 0,0:20:50.85,0:20:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak menang,\Naku tetap tak bisa mendapatkannya!
Dialogue: 0,0:20:54.83,0:20:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti pakai cara paksa!
Dialogue: 0,0:20:57.73,0:21:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah begini,\Nlebih baik langsung bicara.
Dialogue: 0,0:21:02.44,0:21:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Yaa?
Dialogue: 0,0:21:03.99,0:21:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin menunjukkan apa?
Dialogue: 0,0:21:06.44,0:21:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Nona Yaa.
Dialogue: 0,0:21:09.63,0:21:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:13.76,0:21:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NIni batu terbesar yang pernah kuangkat!
Dialogue: 0,0:21:18.69,0:21:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku masih bisa!
Dialogue: 0,0:21:21.63,0:21:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba begitu?\NBahaya, cepat turunkan!
Dialogue: 0,0:21:27.75,0:21:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah paham?
Dialogue: 0,0:21:29.44,0:21:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:21:30.27,0:21:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ada hal yang tak bisa diselesaikan\Ndengan kekuatan, ya.
Dialogue: 0,0:21:34.21,0:21:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah yang bisa diselesaikan\Ndengan kekuatan itu sedikit.
Dialogue: 0,0:21:37.80,0:21:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pikirkan ulang dan cari cara lain.
Dialogue: 0,0:21:40.99,0:21:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:42.28,0:21:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, jangan pakai kekuatan,
Dialogue: 0,0:21:44.85,0:21:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi pamer perut indahku\Nuntuk menarik perhatiannya!
Dialogue: 0,0:21:47.55,0:21:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu terlalu pede soal ototmu?
Dialogue: 0,0:21:50.72,0:21:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, kita harus hadapi langsung.
Dialogue: 0,0:21:54.29,0:21:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menunjukkan\Nkelebihan yang kita punya.
Dialogue: 0,0:21:58.80,0:22:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus pada kaki dan pinggulmu.
Dialogue: 0,0:22:00.63,0:22:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, kamu lihat ke mana?\NAku jadi kepikiran!
Dialogue: 0,0:22:04.27,0:22:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, ini demi ras kita.
Dialogue: 0,0:22:09.06,0:22:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagian dadaku harus dilatih!
Dialogue: 0,0:22:13.29,0:22:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti latihan otot!
