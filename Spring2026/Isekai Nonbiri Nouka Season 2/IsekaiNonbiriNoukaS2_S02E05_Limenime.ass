Dialogue: 0,0:03:36.32,0:03:41.33,tanda,,0000,0000,0000,,FOOSH, PENDETA AGUNG GEREJA KORIN
Dialogue: 0,0:04:23.24,0:04:28.37,tanda,,0000,0000,0000,,PENDETA
Dialogue: 0,0:05:16.99,0:05:18.43,tanda,,0000,0000,0000,,BUKU BARU PROF. FLORA SACTU
Dialogue: 0,0:05:18.43,0:05:21.30,tanda,,0000,0000,0000,,POTENSI FERMENTASI
Dialogue: 0,0:10:17.85,0:10:22.85,tanda,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
