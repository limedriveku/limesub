Dialogue: 0,0:00:11.49,0:00:17.50,sign,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:02:02.87,0:02:05.40,sign,,0000,0000,0000,,RAS MERCURY
Dialogue: 0,0:04:09.15,0:04:15.40,sign,,0000,0000,0000,,HOT STONE, BATU PANAS
Dialogue: 0,0:08:54.18,0:08:56.58,sign,,0000,0000,0000,,MAKANAN KHAS KASTEL MATAHARI
Dialogue: 0,0:08:56.58,0:09:00.31,sign,,0000,0000,0000,,KENTANG DUNGEON REBUS
Dialogue: 0,0:09:40.60,0:09:45.36,sign,,0000,0000,0000,,KENTANG DUNGEON
Dialogue: 0,0:10:26.36,0:10:32.74,sign,,0000,0000,0000,,TAKTIK
Dialogue: 0,0:10:34.36,0:10:36.12,sign,,0000,0000,0000,,PERTEMPURAN JARAK DEKAT
Dialogue: 0,0:13:18.78,0:13:21.61,sign,,0000,0000,0000,,PISANG
Dialogue: 0,0:14:37.36,0:14:39.15,sign,,0000,0000,0000,,MAKURA, ZABUTON, FUTON
Dialogue: 0,0:15:35.07,0:15:38.08,sign,,0000,0000,0000,,SLIME KENTANG
Dialogue: 0,0:17:47.71,0:17:49.97,sign,,0000,0000,0000,,KADES, KADES BESAR
Dialogue: 0,0:17:49.97,0:17:51.97,sign,,0000,0000,0000,,RAJA KADES
Dialogue: 0,0:18:09.81,0:18:12.74,sign,,0000,0000,0000,,KAISAR
Dialogue: 0,0:18:22.65,0:18:25.25,sign,,0000,0000,0000,,KAISAR KADES AGUNG, MARKIS HIRAKIEL (DEWA)
Dialogue: 0,0:01:32.39,0:01:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun!\NKenapa jadi begini?
Dialogue: 0,0:01:35.12,0:01:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah sekian lama aku bisa keluar\Ndari ruang mesin,
Dialogue: 0,0:01:38.29,0:01:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}situasinya malah seperti ini!
Dialogue: 0,0:01:39.75,0:01:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjamu apa saja sebagai pengelola, Gou?
Dialogue: 0,0:01:43.29,0:01:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan marah begitu.
Dialogue: 0,0:01:45.25,0:01:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berusaha semampuku.
Dialogue: 0,0:01:47.57,0:01:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjamu seperti tak ada hasilnya!
Dialogue: 0,0:01:49.88,0:01:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kristal itu namanya Gou, ya?
Dialogue: 0,0:01:53.07,0:01:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:01:54.51,0:01:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Catatan operasional apaan ini?\NKenapa asal-asalan?
Dialogue: 0,0:01:56.85,0:01:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jangan lihat!
Dialogue: 0,0:01:59.35,0:02:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bell, wakil pengurus Kastel Matahari,\Ndan Gou
Dialogue: 0,0:02:02.87,0:02:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rupanya makhluk hidup buatan
Dialogue: 0,0:02:03.79,0:02:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang disebut Mercury.
Dialogue: 0,0:02:05.40,0:02:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Catatan ini bisa diperiksa nanti,
Dialogue: 0,0:02:08.15,0:02:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kenapa bahan bakarnya hampir habis?
Dialogue: 0,0:02:11.11,0:02:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa berkurang sebanyak ini\Ndalam sepuluh tahun?
Dialogue: 0,0:02:13.43,0:02:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, mau dengar alasannya?
Dialogue: 0,0:02:15.88,0:02:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:02:16.78,0:02:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang membangun kastel ini\Nraja manusia, kan?
Dialogue: 0,0:02:20.92,0:02:25.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, orang payah yang memberiku tugas\Ntak jelas lalu mengurungku itu, kan?
Dialogue: 0,0:02:25.67,0:02:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangsawan genit yang mewarisi\Nkastel ini dan raja itu
Dialogue: 0,0:02:29.91,0:02:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehabisan uang lalu menjual\Nsemua cadangan bahan bakarnya.
Dialogue: 0,0:02:33.55,0:02:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:02:34.55,0:02:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi uangnya masih kurang,\Npada akhirnya kastel ini dijual.
Dialogue: 0,0:02:38.55,0:02:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu hak miliknya berpindah ke ras Dewa.
Dialogue: 0,0:02:41.57,0:02:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, ras Malaikat!
Dialogue: 0,0:02:43.56,0:02:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, kastel ini dipakai untuk perang,\Nlalu bahan bakar daruratnya juga habis...
Dialogue: 0,0:02:48.94,0:02:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, nanti akan kukutuk\Nbangsawan itu sampai ke keturunannya.
Dialogue: 0,0:02:52.92,0:02:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong maafkan keturunannya.
Dialogue: 0,0:02:55.23,0:02:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan bakarnya tinggal sisa sedikit.
Dialogue: 0,0:02:58.83,0:03:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:03:01.28,0:03:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia Kuzden, penguasa kastel saat ini.
Dialogue: 0,0:03:04.69,0:03:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.\NSalam kenal.
Dialogue: 0,0:03:07.45,0:03:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi\Nkalau bahan bakarnya habis?
Dialogue: 0,0:03:09.77,0:03:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, daya apungnya akan hilang\Ndan kastel ini langsung jatuh.
Dialogue: 0,0:03:13.76,0:03:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:14.34,0:03:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tak ada fungsi pendaratan,\Nentah akan seperti apa nantinya.
Dialogue: 0,0:03:17.65,0:03:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:18.85,0:03:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, tinggal isi bahan bakarnya, kan?
Dialogue: 0,0:03:22.60,0:03:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak semudah itu!
Dialogue: 0,0:03:25.43,0:03:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami butuh batu yang sangat langka.
Dialogue: 0,0:03:28.59,0:03:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus mengumpulkan Batu Matahari,\Nyang selalu mengeluarkan panas.
Dialogue: 0,0:03:33.34,0:03:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda selangka itu...
Dialogue: 0,0:03:35.97,0:03:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Michael tahu kalau kita cerita?\NAtau Leluhur juga tahu?
Dialogue: 0,0:03:39.87,0:03:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, kita tinggal hitung mundur\Nkapan jatuhnya dan berharap minim kerusakan!
Dialogue: 0,0:03:45.11,0:03:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:46.49,0:03:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekarang jatuh ke daratan,\Nbagaimana aku bisa hidup?
Dialogue: 0,0:03:49.83,0:03:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuhkan ke tengah hutan?\NTidak, apa ke laut saja?
Dialogue: 0,0:03:52.47,0:03:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tabrakkan ke gunung saja.
Dialogue: 0,0:03:54.28,0:03:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di laut atau gunung pun, aku tak mau!
Dialogue: 0,0:03:56.13,0:03:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia luar penuh monster mengerikan!
Dialogue: 0,0:03:58.88,0:04:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tak ada solusi lain?
Dialogue: 0,0:04:00.84,0:04:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:04:01.75,0:04:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:02.51,0:04:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Batu Matahari, kan?
Dialogue: 0,0:04:04.89,0:04:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Iya, benar.
Dialogue: 0,0:04:07.76,0:04:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu ini...
Dialogue: 0,0:04:09.15,0:04:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hot Stone yang kita temukan di onsen?
Dialogue: 0,0:04:11.51,0:04:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya. Di langit, batu ini dingin, jadi kubawa.
Dialogue: 0,0:04:15.40,0:04:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu batu ini disebut Batu Matahari\Ndan sangat berharga,
Dialogue: 0,0:04:19.27,0:04:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sekarang sudah banyak ditambang
Dialogue: 0,0:04:21.89,0:04:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dipakai sebagai alat penghangat.
Dialogue: 0,0:04:24.52,0:04:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bisa mengambilnya di sekitar onsen\Ndan segera mengumpulkannya!
Dialogue: 0,0:04:28.16,0:04:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:04:30.60,0:04:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zaman sudah berubah, ya.
Dialogue: 0,0:04:33.17,0:04:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kami akan pergi\Nmengumpulkan Hot Stone.
Dialogue: 0,0:04:36.88,0:04:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira butuh berapa banyak?
Dialogue: 0,0:04:39.11,0:04:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, bawa sebanyak yang bisa\NHakuren bawa dalam sekali angkut.
Dialogue: 0,0:04:43.24,0:04:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bisa bawa beberapa barel,
Dialogue: 0,0:04:45.18,0:04:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku boleh sekalian\Nberendam di onsen juga?
Dialogue: 0,0:04:47.68,0:04:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, kita sedang butuh cepat.
Dialogue: 0,0:04:51.28,0:04:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan bakar yang tersisa\Nbisa bertahan berapa lama?
Dialogue: 0,0:04:53.67,0:04:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar tiga tahun masih aman.
Dialogue: 0,0:04:55.61,0:04:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata irit, ya.
Dialogue: 0,0:04:58.36,0:05:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tak segenting yang kukira,\Ntapi sebaiknya selesaikan secepatnya.
Dialogue: 0,0:05:02.64,0:05:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya!\N- Baik!
Dialogue: 0,0:05:04.22,0:05:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita mandi dulu.
Dialogue: 0,0:05:07.21,0:05:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Tuan Hiraku.
Dialogue: 0,0:05:09.97,0:05:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah diskusi dengan Gou\Ndan yang lainnya...
Dialogue: 0,0:05:14.76,0:05:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuzden menawarkan diri untuk bergabung\Ndengan Desa Pohon Besar.
Dialogue: 0,0:05:18.71,0:05:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:05:20.49,0:05:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bersedia menyerahkan Kastel Matahari\Ndan meminta kebutuhan hidup mereka dijamin.
Dialogue: 0,0:05:24.44,0:05:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tawaran mereka.
Dialogue: 0,0:05:25.72,0:05:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti para pengungsi datang\Nbersama tempat tinggalnya sekaligus.
Dialogue: 0,0:05:30.00,0:05:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita perlakukan mereka\Nseperti para pengungsi sebelumnya.
Dialogue: 0,0:05:34.36,0:05:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju, tapi yang kucemaskan itu\Ntempat yang mereka bawa.
Dialogue: 0,0:05:39.11,0:05:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, siapa yang punya\Nhak kepemilikan kastel itu?
Dialogue: 0,0:05:42.56,0:05:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang ingin membantu\Npenduduk Kastel Matahari,
Dialogue: 0,0:05:45.75,0:05:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tak mau ada masalah baru.
Dialogue: 0,0:05:48.87,0:05:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, tak perlu rumit memikirkannya.
Dialogue: 0,0:05:53.52,0:05:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini kastel itu terbengkalai\Ndan tak ada yang peduli.
Dialogue: 0,0:05:57.01,0:06:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, pemiliknya yang dari ras Dewa...
Dialogue: 0,0:06:00.13,0:06:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah punah.
Dialogue: 0,0:06:01.60,0:06:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi...\N- Sudah punah.
Dialogue: 0,0:06:03.63,0:06:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang protes, bilang saja...
Dialogue: 0,0:06:07.68,0:06:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kalau ada yang tak terima,\Nsilakan diskusi dengan kami!"
Dialogue: 0,0:06:10.60,0:06:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:06:11.77,0:06:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun, kita tak bisa\Nmembiarkan mereka, kan?
Dialogue: 0,0:06:14.65,0:06:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:06:16.33,0:06:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, tak perlu cemas.
Dialogue: 0,0:06:18.43,0:06:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar!
Dialogue: 0,0:06:19.17,0:06:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:06:21.44,0:06:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dukungan semuanya,\Nkami menerima Kastel Matahari.
Dialogue: 0,0:06:25.04,0:06:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Kades...
Dialogue: 0,0:06:27.03,0:06:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, tolong bawa kentang dungeon itu.
Dialogue: 0,0:06:30.89,0:06:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin buat sake dari bahan itu.
Dialogue: 0,0:06:32.61,0:06:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal sake, dia selalu semangat.
Dialogue: 0,0:06:36.08,0:06:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah keputusan diambil,\Nkami langsung bertindak.
Dialogue: 0,0:06:39.25,0:06:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuzden menerima surat pengakuan sebagai wakil\Nbahwa wilayahnya bagian dari Desa Pohon Besar.
Dialogue: 0,0:06:44.61,0:06:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jabatan sebagai pelaksana Desa Empat
Dialogue: 0,0:06:47.35,0:06:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah aku terima.
Dialogue: 0,0:06:49.06,0:06:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah kalian secara resmi\Njadi Desa Empat,
Dialogue: 0,0:06:51.57,0:06:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalian tetap boleh\Nmenyebutnya Kastel Matahari.
Dialogue: 0,0:06:54.69,0:06:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik! Dimengerti!
Dialogue: 0,0:06:56.94,0:07:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, seluruh penduduk\NDesa Empat akan setia padamu!
Dialogue: 0,0:07:01.12,0:07:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan bekerja sekuat tenaga\Ndemi Tuan Hiraku!
Dialogue: 0,0:07:08.70,0:07:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi Tuan Hiraku!
Dialogue: 0,0:07:11.35,0:07:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya bukan demi aku,\Ntapi kerja keras demi semuanya.
Dialogue: 0,0:07:15.64,0:07:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perayaan peresmiannya\Nkami lakukan seperlunya.
Dialogue: 0,0:07:18.29,0:07:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini bukan misi penaklukan lagi,
Dialogue: 0,0:07:19.96,0:07:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi misi meningkatkan\Nkualitas hidup di Kastel Matahari.
Dialogue: 0,0:07:23.31,0:07:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kastelnya sudah kami periksa.
Dialogue: 0,0:07:25.63,0:07:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prioritas kita memperkuat bagian\Nyang hampir runtuh.
Dialogue: 0,0:07:28.84,0:07:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada membangun ulang tempat tinggal,
Dialogue: 0,0:07:31.61,0:07:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memperbaiki bangunan yang rusak lebih ringan.
Dialogue: 0,0:07:35.27,0:07:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kita lakukan itu.
Dialogue: 0,0:07:37.58,0:07:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Target kita sekarang,
Dialogue: 0,0:07:39.73,0:07:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyediakan tempat tinggal
Dialogue: 0,0:07:42.61,0:07:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk semua penghuni kastel.
Dialogue: 0,0:07:46.32,0:07:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades, kami boleh memeriksa\Nsemua yang ada di sini, kan?
Dialogue: 0,0:07:51.16,0:07:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kalian bebas melakukannya.
Dialogue: 0,0:07:53.87,0:07:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja masih ada yang bisa dipakai.
Dialogue: 0,0:07:56.52,0:07:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, benda apa ini?
Dialogue: 0,0:07:59.13,0:08:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, hati-hati.
Dialogue: 0,0:08:04.44,0:08:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara, mungkin ini cukup.
Dialogue: 0,0:08:06.38,0:08:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ladang subur muncul dalam sekejap?
Dialogue: 0,0:08:09.52,0:08:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir macam apa itu?
Dialogue: 0,0:08:11.68,0:08:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan sihir, aku cuma mencangkul.
Dialogue: 0,0:08:15.67,0:08:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus tanam apa di sini?
Dialogue: 0,0:08:17.60,0:08:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NMungkin yang cepat panen seperti selada.
Dialogue: 0,0:08:23.01,0:08:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau cuma sayuran daun saja kurang.
Dialogue: 0,0:08:25.48,0:08:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa taman lobak juga?
Dialogue: 0,0:08:27.13,0:08:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!\NLalu tambah tomat kecil?
Dialogue: 0,0:08:29.78,0:08:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lobak, lobak...
Dialogue: 0,0:08:31.25,0:08:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Anu, Tuan Hiraku sedang apa?\N- Lobak, lobak...
Dialogue: 0,0:08:34.03,0:08:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau dia mencangkul sambil membayangkannya,\N- Lobak, lobak...
Dialogue: 0,0:08:37.52,0:08:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- sayurannya akan tumbuh tanpa perlu benih.\N- Lobak, lobak...
Dialogue: 0,0:08:39.28,0:08:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, zaman sekarang sudah begitu, ya?
Dialogue: 0,0:08:42.25,0:08:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya pengetahuanku\Nsudah ketinggalan zaman.
Dialogue: 0,0:08:45.29,0:08:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, hanya Kades yang bisa begitu.
Dialogue: 0,0:08:51.05,0:08:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga memikirkan cara\Nmemanfaatkan tanaman yang sudah ada.
Dialogue: 0,0:08:54.18,0:08:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang Dungeon rebus.
Dialogue: 0,0:08:56.58,0:09:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, bentuknya mirip talas.
Dialogue: 0,0:09:02.15,0:09:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menjelaskannya, ya?
Dialogue: 0,0:09:04.65,0:09:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengket saat dimakan, tapi anehnya\Nterasa kasar di dalam mulut.
Dialogue: 0,0:09:08.01,0:09:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu rasanya pahit.\NBukan, lebih tepatnya sepat.
Dialogue: 0,0:09:11.91,0:09:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menghormati ciri khas Kentang Dungeon,\Nkami tambah bumbu agar lebih enak dimakan.
Dialogue: 0,0:09:16.05,0:09:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya menambahkan bubuk ajaib.
Dialogue: 0,0:09:18.55,0:09:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Kentang Dungeon?
Dialogue: 0,0:09:21.52,0:09:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keajaiban apa yang kamu lakukan?
Dialogue: 0,0:09:23.51,0:09:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bumbu kari racikan khusus.
Dialogue: 0,0:09:25.36,0:09:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang mengerikan...
Dialogue: 0,0:09:27.15,0:09:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa kari memang tak terkalahkan.
Dialogue: 0,0:09:29.47,0:09:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Enak! Hiraku, ini sangat enak!\N- Kami juga meneliti
Dialogue: 0,0:09:31.05,0:09:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Enak! Hiraku, ini sangat enak!\N- cara mengolah Kentang Dungeon.
Dialogue: 0,0:09:34.29,0:09:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Enak! Hiraku, ini sangat enak!\N- Tolong, ya.
Dialogue: 0,0:09:35.61,0:09:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri Donovan jatah juga\Nuntuk bahan membuat sake.
Dialogue: 0,0:09:39.12,0:09:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:09:40.60,0:09:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Kentang Dungeon
Dialogue: 0,0:09:43.11,0:09:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa tumbuh di tempat gelap.
Dialogue: 0,0:09:45.97,0:09:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi rasanya mungkin akan lebih enak\Nkalau ditanam di tempat terang.
Dialogue: 0,0:09:49.83,0:09:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita coba tanam di ladang luar.
Dialogue: 0,0:09:52.63,0:09:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara,\Nkami sudah bawa ini semuanya.
Dialogue: 0,0:09:55.24,0:09:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, terima kasih.
Dialogue: 0,0:09:56.97,0:09:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ju-Jumlahnya luar biasa...
Dialogue: 0,0:09:59.70,0:10:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih kurang?\NMau ambil lagi?
Dialogue: 0,0:10:02.94,0:10:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau punya Batu Matahari sebanyak ini\Nsaat kastelnya masih dibangun,
Dialogue: 0,0:10:07.21,0:10:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami mungkin bisa menaklukkan dunia!
Dialogue: 0,0:10:09.20,0:10:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma mengoperasikan kastel,\Nsemua persenjataan juga bisa aktif,
Dialogue: 0,0:10:12.29,0:10:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan bisa diperkuat\Nberkali-kali lipat, kan, Gou?
Dialogue: 0,0:10:15.29,0:10:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, soal persenjataan, semuanya\Njuga dijual oleh bangsawan itu.
Dialogue: 0,0:10:19.29,0:10:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu bilang?
Dialogue: 0,0:10:20.60,0:10:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian saat itu sedang berperang, kan?
Dialogue: 0,0:10:23.36,0:10:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa bertarung tanpa senjata?
Dialogue: 0,0:10:26.36,0:10:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua energinya dialihkan ke barier sihir,
Dialogue: 0,0:10:29.36,0:10:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu kastelnya ditabrakkan ke kastel musuh!
Dialogue: 0,0:10:31.17,0:10:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditabrakkan begitu saja?
Dialogue: 0,0:10:32.74,0:10:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, ras Malaikat
Dialogue: 0,0:10:34.36,0:10:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyerbu masuk sambil membawa tombak.
Dialogue: 0,0:10:36.12,0:10:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja kastelnya\Nsering berguncang hebat...
Dialogue: 0,0:10:40.07,0:10:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah beres?\NAku lapar.
Dialogue: 0,0:10:42.69,0:10:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, kerja bagus.\NDi sana banyak kentang rebus rasa kari.
Dialogue: 0,0:10:47.80,0:10:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masalah bahan bakar\Nsudah teratasi untuk ribuan tahun ke depan,
Dialogue: 0,0:10:51.77,0:10:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tantangan berikutnya\Nadalah transportasi dari darat.
Dialogue: 0,0:10:55.43,0:10:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah buat berdasarkan cetak biru\Nyang ditemukan di bengkel Kastel Matahari!
Dialogue: 0,0:10:59.64,0:11:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini prototipe kecilnya!
Dialogue: 0,0:11:02.27,0:11:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini parasut yang dulu pernah dicoba, kan?
Dialogue: 0,0:11:05.20,0:11:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu...
Dialogue: 0,0:11:08.89,0:11:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balon udara.
Dialogue: 0,0:11:09.97,0:11:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:11:10.88,0:11:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu dipakai untuk mengirim barang\Ndari daratan ke Kastel Matahari.
Dialogue: 0,0:11:16.03,0:11:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:11:17.63,0:11:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang butuh sarana angkut barang, ya.
Dialogue: 0,0:11:21.16,0:11:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antusiasnya sampai terasa ke sini.
Dialogue: 0,0:11:27.04,0:11:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:11:28.23,0:11:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda itu betulan bisa terbang, ya?
Dialogue: 0,0:11:30.76,0:11:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya memperbesar ukurannya.
Dialogue: 0,0:11:33.61,0:11:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma melayang saja?
Dialogue: 0,0:11:36.43,0:11:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara mengendalikan balon udara?
Dialogue: 0,0:11:39.23,0:11:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau apinya dikecilkan,\Nbalonnya bisa turun!
Dialogue: 0,0:11:41.87,0:11:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa kita atur\Nhanya besar kecil apinya, ya?
Dialogue: 0,0:11:44.56,0:11:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, baru bisa naik turun saja?
Dialogue: 0,0:11:47.17,0:11:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:11:48.31,0:11:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nkita belum bisa sampai tujuan...
Dialogue: 0,0:11:51.36,0:11:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung arah angin juga, ya?
Dialogue: 0,0:11:53.57,0:11:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah, sekarang tak bisa turun, ya?
Dialogue: 0,0:11:56.83,0:11:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia malah terjun.
Dialogue: 0,0:11:59.11,0:12:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu benda ini bisa digunakan,\Npasti ada caranya.
Dialogue: 0,0:12:03.04,0:12:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpikir keras!
Dialogue: 0,0:12:05.36,0:12:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yang penting berhasil terbang dulu.\N- Eh?
Dialogue: 0,0:12:08.35,0:12:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tenang dan pikirkan pelan-pelan.\N- Tunggu!
Dialogue: 0,0:12:18.05,0:12:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuacanya dingin, sebaiknya pulang.
Dialogue: 0,0:12:19.80,0:12:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:21.99,0:12:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kembali ke desa\Nsebelum saljunya menumpuk.
Dialogue: 0,0:12:24.49,0:12:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati dengan jalan berlumpur.
Dialogue: 0,0:12:26.04,0:12:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:27.89,0:12:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat sibuk bolak-balik\Ndari Desa Pohon Besar ke Kastel Matahari,
Dialogue: 0,0:12:31.64,0:12:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musim dingin pun tiba.
Dialogue: 0,0:12:33.97,0:12:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekitar Kastel Matahari\Nselalu terasa hangat seperti musim semi.
Dialogue: 0,0:12:37.22,0:12:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana sangat nyaman.
Dialogue: 0,0:12:39.24,0:12:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin raja yang membangun kastel ini dulu,
Dialogue: 0,0:12:41.85,0:12:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga menjadikannya tempat beristirahat\Nsaat musim dingin.
Dialogue: 0,0:12:45.24,0:12:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Tuan Hiraku, kamu ada di sini.
Dialogue: 0,0:12:49.15,0:12:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini juga ladang?
Dialogue: 0,0:12:51.00,0:12:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ini taman bunga.
Dialogue: 0,0:12:53.07,0:12:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tiap hari hangat, aku ingin\Nsuasananya terasa seperti musim semi.
Dialogue: 0,0:12:56.88,0:12:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sayuran apa?
Dialogue: 0,0:12:59.33,0:13:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan untuk dimakan.\NIni tanaman hias untuk dinikmati bunganya.
Dialogue: 0,0:13:03.01,0:13:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya? Selama ini, aku hanya\Nmemikirkan cara dapat makanan.
Dialogue: 0,0:13:08.29,0:13:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buah-buahan juga ada bunga yang cantik.\NBuahnya banyak dan rasanya juga enak.
Dialogue: 0,0:13:12.45,0:13:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:13.75,0:13:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prioritasku saat ini\Nmasih menanam yang cepat panen.
Dialogue: 0,0:13:16.31,0:13:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sudah waktunya\Nmenanam pohon buah.
Dialogue: 0,0:13:18.78,0:13:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena hangat, mungkin pisang tropis?
Dialogue: 0,0:13:21.61,0:13:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pisang bukan pohon, ya?
Dialogue: 0,0:13:23.84,0:13:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti semangka atau stroberi\Nyang sebenarnya termasuk tanaman lain?
Dialogue: 0,0:13:27.04,0:13:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Tuan Hiraku!
Dialogue: 0,0:13:28.99,0:13:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencarimu karena ada hal\Nyang ingin kutunjukkan!
Dialogue: 0,0:13:35.63,0:13:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ini?
Dialogue: 0,0:13:37.17,0:13:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sadar, sudah jadi seperti ini.
Dialogue: 0,0:13:39.89,0:13:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal hanya ditinggal tiga hari.
Dialogue: 0,0:13:41.76,0:13:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Jadi begini hanya dalam tiga hari?
Dialogue: 0,0:13:44.03,0:13:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini batang Kentang Dungeon.
Dialogue: 0,0:13:48.41,0:13:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Kentang Dungeon yang terkena\Nsinar matahari bisa tumbuh sebesar ini.
Dialogue: 0,0:13:52.19,0:13:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kentangnya juga\Ntumbuh dengan sangat cepat?
Dialogue: 0,0:13:55.69,0:13:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inginnya begitu.
Dialogue: 0,0:13:58.43,0:13:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata jadi begini, ya.
Dialogue: 0,0:13:59.96,0:14:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentangnya tidak ada, ya?
Dialogue: 0,0:14:01.95,0:14:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon tak akan tumbuh dengan baik\Ndi tempat yang terkena sinar matahari.
Dialogue: 0,0:14:05.64,0:14:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun dan batangnya terlalu rimbun,\Njadi tak ada nutrisi untuk kentangnya.
Dialogue: 0,0:14:09.95,0:14:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada gunanya kalau tak bisa dimakan.
Dialogue: 0,0:14:11.96,0:14:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mungkin ini bisa jadi tanaman hias?
Dialogue: 0,0:14:14.21,0:14:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, harus kita bersihkan.
Dialogue: 0,0:14:16.59,0:14:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibiarkan,\Nseluruh kastel bisa tertelan sulurnya.
Dialogue: 0,0:14:19.84,0:14:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lempar, ya.
Dialogue: 0,0:14:21.28,0:14:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:14:22.65,0:14:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Kastel Matahari, perbaikan bangunan
Dialogue: 0,0:14:25.20,0:14:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan produksi makanan terus dilakukan\Ndi tengah cuaca yang hangat.
Dialogue: 0,0:14:29.35,0:14:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya karena hangat,\Nbukan berarti kami bisa terus di sana.
Dialogue: 0,0:14:33.35,0:14:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:14:34.21,0:14:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga harus memperhatikan desa lain\Nyang mengalami kesulitan
Dialogue: 0,0:14:37.36,0:14:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama musim dingin
Dialogue: 0,0:14:40.41,0:14:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin.
Dialogue: 0,0:14:42.48,0:14:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagal.\NSudah berapa kali coba masih gagal.
Dialogue: 0,0:14:47.00,0:14:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:14:48.28,0:14:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah disuling pun, rasa khas\NKentang Dungeon-nya tak hilang.
Dialogue: 0,0:14:51.63,0:14:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti menjilat batu.
Dialogue: 0,0:14:54.09,0:14:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar, terasa aneh dan kasar di mulut.
Dialogue: 0,0:14:57.31,0:14:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya menyerah saja.
Dialogue: 0,0:14:59.20,0:15:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memaksakan yang tak cocok\Nkesannya tak menghargai bahan.
Dialogue: 0,0:15:04.20,0:15:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Ann dan yang lainnya bilang\Nsedang mencari cara mengolahnya.
Dialogue: 0,0:15:08.81,0:15:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah coba berbagai cara,\Nseperti menghilangkan rasa sepatnya
Dialogue: 0,0:15:11.56,0:15:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melakukan banyak percobaan...
Dialogue: 0,0:15:14.57,0:15:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya seperti ini.
Dialogue: 0,0:15:15.64,0:15:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kan konyaku?
Dialogue: 0,0:15:18.88,0:15:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kupotong.
Dialogue: 0,0:15:22.03,0:15:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa kentangnya jadi seperti ini?
Dialogue: 0,0:15:24.19,0:15:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hasil yang di luar dugaan.
Dialogue: 0,0:15:26.93,0:15:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dipikir, kentang konyaku juga\Ntak bisa dimakan mentah.
Dialogue: 0,0:15:31.27,0:15:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat mengira\Nmalah menciptakan slime spesies baru.
Dialogue: 0,0:15:35.07,0:15:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dilihat, memang mirip.
Dialogue: 0,0:15:40.59,0:15:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel Matahari yang datang dari arah tenggara,\Nkini berpindah ke sebelah utara desa.
Dialogue: 0,0:15:46.01,0:15:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gou yang mengoperasikannya tak tenang kalau\Nkastelnya hanya diam melayang.
Dialogue: 0,0:15:51.39,0:15:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi rencananya, musim dingin di utara,\Nmusim semi di barat,
Dialogue: 0,0:15:54.28,0:15:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musim panas di selatan,\Ndan musim gugur di timur.
Dialogue: 0,0:15:56.71,0:16:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam setahun, kastel itu akan mengelilingi\NDesa Pohon Besar satu putaran penuh.
Dialogue: 0,0:16:00.61,0:16:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisi Kastel Matahari akan jadi\Nsemacam kalender raksasa
Dialogue: 0,0:16:05.24,0:16:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menunjukkan berjalannya waktu.
Dialogue: 0,0:16:07.40,0:16:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei.
Dialogue: 0,0:16:09.68,0:16:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidur?
Dialogue: 0,0:16:10.79,0:16:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidur!
Dialogue: 0,0:16:12.08,0:16:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir, setelah mulai\Nmembangun desa baru,
Dialogue: 0,0:16:15.89,0:16:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak disangka, kami juga membangun\Ndesa kedua dan ketiga.
Dialogue: 0,0:16:19.76,0:16:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan desa keempat\Nsampai datang terbang ke sini.
Dialogue: 0,0:16:23.12,0:16:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diriku tahun lalu mendengarnya,\Ndia pasti akan kaget.
Dialogue: 0,0:16:30.89,0:16:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belok!
Dialogue: 0,0:16:34.97,0:16:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak memang antusias, ya.
Dialogue: 0,0:16:36.52,0:16:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kuat menghadapi cuaca,\Natau aku yang saja yang sudah tua?
Dialogue: 0,0:16:42.05,0:16:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari demi hari pun berlalu.
Dialogue: 0,0:16:44.52,0:16:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel Matahari mulai bergerak\Ndari utara menuju barat.
Dialogue: 0,0:16:49.78,0:16:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Kades.
Dialogue: 0,0:16:51.78,0:16:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada usul.
Dialogue: 0,0:16:54.20,0:16:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, apa?
Dialogue: 0,0:16:55.89,0:16:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang desa kita sudah bertambah\Nsampai Desa Empat,
Dialogue: 0,0:16:59.13,0:17:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kita perlu simbol bahwa semuanya\Nada di bawah naungan Desa Pohon Besar?
Dialogue: 0,0:17:05.03,0:17:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:17:06.05,0:17:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penduduk pasti akan terus bertambah,
Dialogue: 0,0:17:08.97,0:17:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Kastel Matahari juga baru bergabung.
Dialogue: 0,0:17:11.80,0:17:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusarankan kita buat lambang\Npemersatu untuk semua desa.
Dialogue: 0,0:17:16.95,0:17:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita buat\Npatung Kades di tiap desa?
Dialogue: 0,0:17:20.63,0:17:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita buat sangat besar\Nsampai kepala kita lihat ke atas!
Dialogue: 0,0:17:24.31,0:17:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat potret untuk menghormati Kades.
Dialogue: 0,0:17:26.77,0:17:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap rumah harus punya satu!
Dialogue: 0,0:17:29.08,0:17:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:17:29.95,0:17:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kades. Kades. Oh, Kades!\N- setiap pagi baca pujian untuk Kades!
Dialogue: 0,0:17:33.17,0:17:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kades. Kades.\N- Itu seram, sebaiknya jangan.
Dialogue: 0,0:17:34.80,0:17:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kades. Kades.\N- Di potretnya harus berekspresi seperti apa?
Dialogue: 0,0:17:37.70,0:17:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, meski dipuja seperti itu,\Naku ini cuma kades.
Dialogue: 0,0:17:42.11,0:17:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu!
Dialogue: 0,0:17:43.59,0:17:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:44.46,0:17:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}antara kamu dan perwakilan desa lainnya,\NUntuk memperjelas perbedaan
Dialogue: 0,0:17:47.71,0:17:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami sempat bahas dan menentukan gelar baru
Dialogue: 0,0:17:49.97,0:17:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengganti "Kades",
Dialogue: 0,0:17:51.03,0:17:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bahasan itu tertunda dan tak ada keputusan.
Dialogue: 0,0:17:54.59,0:17:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ada bahasan seperti itu?
Dialogue: 0,0:17:57.85,0:17:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades Sejati!
Dialogue: 0,0:17:59.39,0:18:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades Super!
Dialogue: 0,0:18:00.87,0:18:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadesnya kades?\NKades Agung Desa Utama?
Dialogue: 0,0:18:05.39,0:18:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan pelesetan.
Dialogue: 0,0:18:07.83,0:18:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau simpel,
Dialogue: 0,0:18:09.81,0:18:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}contohnya kaisar.
Dialogue: 0,0:18:10.88,0:18:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah jadi berlebihan.
Dialogue: 0,0:18:12.74,0:18:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau gelar bangsawan\Ndari Kerajaan Iblis?
Dialogue: 0,0:18:14.99,0:18:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau minta diakui\Nsebagai orang suci?
Dialogue: 0,0:18:17.52,0:18:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan dewa, ya?
Dialogue: 0,0:18:18.79,0:18:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades itu dewa.
Dialogue: 0,0:18:20.25,0:18:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dirangkum, jadinya begini.
Dialogue: 0,0:18:22.65,0:18:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirangkum bukan berarti cocok.
Dialogue: 0,0:18:25.25,0:18:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, menurutku memuja seseorang\Nberlebihan itu tidak baik.
Dialogue: 0,0:18:31.11,0:18:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk soal simbol desa,\Nyang terpenting itu
Dialogue: 0,0:18:34.19,0:18:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita semua hidup bersama di desa ini.
Dialogue: 0,0:18:38.92,0:18:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya!
Dialogue: 0,0:18:40.96,0:18:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau simbol desanya\Nkita buat begini?
Dialogue: 0,0:18:44.64,0:18:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:18:46.09,0:18:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita dengarkan juga\Npendapat para perwakilan ras.
Dialogue: 0,0:18:49.40,0:18:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk julukannya, sementara\Naku ingin tetap dipanggil kades.
Dialogue: 0,0:18:53.07,0:18:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:18:54.15,0:18:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berubah pikiran, beri tahu kami, ya.
Dialogue: 0,0:18:56.96,0:18:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:18:58.75,0:19:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuacanya cerah.
Dialogue: 0,0:19:00.17,0:19:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saljunya sudah mencair.
Dialogue: 0,0:19:02.28,0:19:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Zabuton juga\Nsudah bangun dari hibernasi.
Dialogue: 0,0:19:05.33,0:19:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai lalai atau ceroboh.
Dialogue: 0,0:19:08.07,0:19:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap hati-hati dan fokus.
Dialogue: 0,0:19:14.17,0:19:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:19:15.00,0:19:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit lagi...
Dialogue: 0,0:19:17.95,0:19:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah!
Dialogue: 0,0:19:21.44,0:19:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, dengar!
Dialogue: 0,0:19:24.72,0:19:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kita akhirnya bisa mengadakan\Npesta besar yang sulit terlaksana!
Dialogue: 0,0:19:29.04,0:19:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kalian semua\Nbersenang-senang dan makin akrab!
Dialogue: 0,0:19:34.75,0:19:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum bersulang, ada hal yang ingin\Nkutunjukkan pada kalian semua!
Dialogue: 0,0:19:39.93,0:19:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain Desa Pohon Besar,\Nada Desa Satu,
Dialogue: 0,0:19:43.03,0:19:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Dua,
Dialogue: 0,0:19:44.40,0:19:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Tiga,
Dialogue: 0,0:19:45.71,0:19:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Kastel Matahari\Nyang sekarang menjadi Desa Empat.
Dialogue: 0,0:19:49.36,0:19:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu simbol bersama yang kupikirkan\Nuntuk semuanya...
Dialogue: 0,0:19:56.31,0:19:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendera ini!
Dialogue: 0,0:19:59.57,0:20:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan simbol bahwa\NDesa Pohon Besar lebih tinggi,
Dialogue: 0,0:20:02.24,0:20:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kalian harus tunduk pada seseorang.
Dialogue: 0,0:20:04.85,0:20:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini simbol bagi semua orang\Nyang hidup bersama di sini.
Dialogue: 0,0:20:08.15,0:20:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukti bahwa kita satu keluarga\NDesa Pohon Besar.
Dialogue: 0,0:20:10.36,0:20:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendera desa milik kita bersama!
Dialogue: 0,0:20:15.80,0:20:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, mari bersulang untuk bendera ini!
Dialogue: 0,0:20:19.11,0:20:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:20:26.96,0:20:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Minum yang banyak.\N- Rasanya lumayan kuat, ya.
Dialogue: 0,0:20:28.69,0:20:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Rasanya lumayan kuat, ya.\N- Tidak perlu takut.
Dialogue: 0,0:20:29.75,0:20:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian minum juga?
Dialogue: 0,0:20:31.55,0:20:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya!\NJadi ini kekuatan sake...
Dialogue: 0,0:20:36.85,0:20:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang Dungeon, ya.\NMendengarnya membuat nostalgia.
Dialogue: 0,0:20:41.08,0:20:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, dulu pernah dianjurkan\Nsebagai antisipasi menghadapi kelaparan.
Dialogue: 0,0:20:46.55,0:20:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski untuk darurat, tetap tak populer\Nkarena rasanya yang sulit dimakan.
Dialogue: 0,0:20:50.59,0:20:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka cara memasak\Nbisa mengubah rasanya.
Dialogue: 0,0:20:53.91,0:20:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, soal memberikan\Ngelar bangsawan untuk Kades...
Dialogue: 0,0:20:57.61,0:21:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, putriku pernah mengusulkan hal itu,
Dialogue: 0,0:21:00.96,0:21:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Kades menolaknya dengan tegas.
Dialogue: 0,0:21:03.59,0:21:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:21:05.04,0:21:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gelar bangsawan saja\N- Aku Rasutismoon!
Dialogue: 0,0:21:06.69,0:21:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- bukan imbalan yang berarti untuknya.\N- Aku Doraimu!
Dialogue: 0,0:21:08.44,0:21:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian minum juga.
Dialogue: 0,0:21:10.24,0:21:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawa tambahannya.
Dialogue: 0,0:21:12.29,0:21:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau memberikan\Nposisi Empat Jenderal padanya?
Dialogue: 0,0:21:15.24,0:21:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengundurkan diri!
Dialogue: 0,0:21:16.96,0:21:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan berhenti\Ndan tinggal di desa ini!
Dialogue: 0,0:21:19.65,0:21:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bicara begitu lagi?
Dialogue: 0,0:21:21.93,0:21:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadikan dia Raja Iblis berikutnya...
Dialogue: 0,0:21:24.18,0:21:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:21:26.18,0:21:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades, mau jadi Raja Iblis?
Dialogue: 0,0:21:28.76,0:21:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan Gullguld!\N- Biar aku saja yang berhenti!
Dialogue: 0,0:21:33.06,0:21:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kaldu campuran.
Dialogue: 0,0:21:34.61,0:21:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hangat sampai ke badan!
Dialogue: 0,0:21:37.49,0:21:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya icip.
Dialogue: 0,0:21:39.82,0:21:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas!
Dialogue: 0,0:21:41.82,0:21:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luncurkan!
Dialogue: 0,0:21:45.74,0:21:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lempar!
Dialogue: 0,0:21:49.08,0:21:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, kastel akan beroperasi mode festival!
Dialogue: 0,0:21:57.09,0:22:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bahagia karena kalian ada di sini!
Dialogue: 0,0:22:00.89,0:22:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya...
Dialogue: 0,0:22:02.00,0:22:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia baik-baik saja?
Dialogue: 0,0:22:03.11,0:22:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:22:06.20,0:22:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga minum, Raja Hiraku?
Dialogue: 0,0:22:09.15,0:22:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dengar itu dari Frau dan yang lainnya?
Dialogue: 0,0:22:11.00,0:22:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah, kan?\NKamu bisa dipanggil apa pun.
Dialogue: 0,0:22:14.23,0:22:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukti rasa hormat mereka, kan?
Dialogue: 0,0:22:16.88,0:22:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu.
Dialogue: 0,0:22:18.85,0:22:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kades saja sudah berat.
Dialogue: 0,0:22:22.60,0:22:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pantas ada di posisi tinggi,\Ntapi aku tak bisa bilang begitu, ya?
Dialogue: 0,0:22:27.36,0:22:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah menerima\Nbanyak penduduk baru,
Dialogue: 0,0:22:30.48,0:22:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus berusaha\Nagar semuanya bisa hidup tenang.
Dialogue: 0,0:22:34.00,0:22:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus lakukan
Dialogue: 0,0:22:36.29,0:22:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang biasa kamu lakukan.
Dialogue: 0,0:22:39.07,0:22:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubah kedudukan tak akan mengubah dirimu.
Dialogue: 0,0:22:43.19,0:22:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tetaplah dirimu.
Dialogue: 0,0:22:45.93,0:22:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:22:46.89,0:22:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:22:49.88,0:22:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa!
Dialogue: 0,0:22:51.39,0:22:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, apa?
Dialogue: 0,0:22:55.64,0:22:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:56.23,0:22:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Papa bau sake.
Dialogue: 0,0:22:58.77,0:23:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Begitu, ya?
Dialogue: 0,0:23:00.52,0:23:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda, dia cuma ngantuk.
Dialogue: 0,0:23:03.13,0:23:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:23:04.03,0:23:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ngantuk, ya?
Dialogue: 0,0:23:06.91,0:23:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tidur bareng Mbak Flora!
Dialogue: 0,0:23:10.63,0:23:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga dia, ya!
Dialogue: 0,0:23:12.17,0:23:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luu, kamu sedang apa?
Dialogue: 0,0:23:14.91,0:23:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ikut minum!
Dialogue: 0,0:23:16.79,0:23:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kuterima tantanganmu!
Dialogue: 0,0:23:19.11,0:23:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sekali lagi!
Dialogue: 0,0:23:21.42,0:23:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!
Dialogue: 0,0:23:45.81,0:23:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo kerja!
