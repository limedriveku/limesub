Dialogue: 0,0:22:37.88,0:22:45.76,tanda,,0000,0000,0000,,SEDANG BERBICARA DI SANA
Dialogue: 0,0:23:45.90,0:23:50.91,tanda,,0000,0000,0000,,SELANJUTNYA:\NEPISODE 2: PARA PENDATANG
Dialogue: 0,0:00:05.95,0:00:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan!
Dialogue: 0,0:00:07.38,0:00:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Rasutisumoon, yang mengurus diplomasi.
Dialogue: 0,0:00:09.78,0:00:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil aku Rusty.
Dialogue: 0,0:00:11.82,0:00:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Fraurem.
Dialogue: 0,0:00:13.94,0:00:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan mengajak kalian keliling desa.
Dialogue: 0,0:00:19.43,0:00:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari sini sampai jauh ke sana,\Nsemuanya ladang!
Dialogue: 0,0:00:23.47,0:00:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking luasnya, sulit digambarkan, ya.
Dialogue: 0,0:00:28.58,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, aku tomat!
Dialogue: 0,0:00:30.63,0:00:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maksudnya, aku Sena.
Dialogue: 0,0:00:34.29,0:00:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tomat!
Dialogue: 0,0:00:45.53,0:00:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Donovan, ras Elder Dwarf.
Dialogue: 0,0:00:47.66,0:00:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas kami membuat sake.
Dialogue: 0,0:00:52.28,0:00:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Ya, ras Elf Gunung.
Dialogue: 0,0:00:54.30,0:00:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pandai membuat barang.
Dialogue: 0,0:00:56.16,0:00:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai!
Dialogue: 0,0:00:57.44,0:00:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:01:07.42,0:01:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, silakan santai dulu.
Dialogue: 0,0:01:10.21,0:01:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlalu berlebihan.
Dialogue: 0,0:01:12.06,0:01:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kesan awal itu penting, kan?
Dialogue: 0,0:01:14.22,0:01:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu untuk menyambut tamu luar.
Dialogue: 0,0:01:17.05,0:01:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau untuk para pendatang,
Dialogue: 0,0:01:19.38,0:01:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kesannya kaku disapa begitu tiap hari.
Dialogue: 0,0:01:21.75,0:01:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:01:22.69,0:01:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku bilang santai saja cukup.
Dialogue: 0,0:01:25.44,0:01:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudahi sambutannya.
Dialogue: 0,0:01:27.23,0:01:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri kata penutup.
Dialogue: 0,0:01:30.19,0:01:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku, ya?
Dialogue: 0,0:01:31.59,0:01:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:01:36.57,0:01:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kuperkenalkan sekali lagi.
Dialogue: 0,0:01:38.35,0:01:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Hiraku, kades.
Dialogue: 0,0:01:40.08,0:01:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Desa Pohon Besar.
Dialogue: 0,0:03:28.98,0:03:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin hidup santai dengan bertani!
Dialogue: 0,0:03:31.98,0:03:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Dewa, aku bisa memulai kehidupan
Dialogue: 0,0:03:34.99,0:03:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai petani di dunia lain.
Dialogue: 0,0:03:40.37,0:03:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bertemu banyak teman
Dialogue: 0,0:03:46.97,0:03:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjadi kades Desa Pohon Besar\Nyang kami bangun bersama.
Dialogue: 0,0:03:54.51,0:03:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:03:55.68,0:03:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa yang santai tapi ramai ini...
Dialogue: 0,0:03:58.26,0:03:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:03:59.20,0:04:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Agak ke sana.\N- Makin ramai dari biasanya karena...
Dialogue: 0,0:04:00.82,0:04:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Makin ramai dari biasanya karena...\N- Eh?
Dialogue: 0,0:04:06.77,0:04:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari tempat tinggal.
Dialogue: 0,0:04:08.34,0:04:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang.
Dialogue: 0,0:04:09.46,0:04:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak pengungsi.
Dialogue: 0,0:04:11.62,0:04:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak pendatang ingin kemari.
Dialogue: 0,0:04:15.01,0:04:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari jumlahnya, kita sepertinya\Nbutuh satu desa lagi.
Dialogue: 0,0:04:18.89,0:04:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita bangun lagi.
Dialogue: 0,0:04:20.51,0:04:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bangun desa baru untuk para pendatang.
Dialogue: 0,0:04:23.66,0:04:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita cari tempat untuk membangun desa!
Dialogue: 0,0:04:25.74,0:04:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagusnya di mana, ya?
Dialogue: 0,0:04:26.98,0:04:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu...
Dialogue: 0,0:04:27.91,0:04:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebang pohonnya, ya!
Dialogue: 0,0:04:29.21,0:04:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:04:30.40,0:04:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kita butuh stok makanan.\N- Semua penduduk sibuk untuk persiapan.
Dialogue: 0,0:04:33.23,0:04:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan langsung berburu.
Dialogue: 0,0:04:37.50,0:04:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking semangatnya,
Dialogue: 0,0:04:38.93,0:04:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami sampai latihan dulu.
Dialogue: 0,0:04:41.17,0:04:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresinya lebih ramah lagi.
Dialogue: 0,0:04:42.64,0:04:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah semaksimal ini masih kurang?
Dialogue: 0,0:04:44.68,0:04:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini anggur!
Dialogue: 0,0:04:48.01,0:04:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini yang baru, ya?
Dialogue: 0,0:04:49.69,0:04:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tujuan kita membuat makanan awet,
Dialogue: 0,0:04:52.37,0:04:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami pakai bahan yang awetnya singkat dulu.
Dialogue: 0,0:04:55.26,0:04:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sayurnya banyak, ya?
Dialogue: 0,0:04:57.85,0:05:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kasih ini ke mereka juga.
Dialogue: 0,0:05:00.40,0:05:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ini mudah dimakan sambil kerja.
Dialogue: 0,0:05:04.01,0:05:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang antar.
Dialogue: 0,0:05:05.43,0:05:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:05:07.29,0:05:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Frau bilang mereka sedang sibuk.
Dialogue: 0,0:05:13.09,0:05:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sanggup.
Dialogue: 0,0:05:14.09,0:05:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kuat.
Dialogue: 0,0:05:15.94,0:05:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal jadi hantu.
Dialogue: 0,0:05:17.34,0:05:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawa makanan buat kalian...
Dialogue: 0,0:05:19.33,0:05:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang agak sibuk.
Dialogue: 0,0:05:20.86,0:05:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak, ya?
Dialogue: 0,0:05:21.84,0:05:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah makanan dan bahannya
Dialogue: 0,0:05:23.41,0:05:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah tak bisa kita hitung lagi.
Dialogue: 0,0:05:25.28,0:05:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama banyak, bukan masalah.
Dialogue: 0,0:05:27.17,0:05:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak ditambah banyak, jadi makin banyak.
Dialogue: 0,0:05:38.38,0:05:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, beres!
Dialogue: 0,0:05:39.58,0:05:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:05:42.00,0:05:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, tadi Frau bilang akan cari bantuan.
Dialogue: 0,0:05:45.12,0:05:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu!
Dialogue: 0,0:05:46.87,0:05:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bala bantuan dari Kerajaan Iblis.
Dialogue: 0,0:05:49.50,0:05:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Fraurem bilang butuh bantuan.
Dialogue: 0,0:05:51.89,0:05:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau bilang ini bermanfaat\Nuntuk bermasyarakat.
Dialogue: 0,0:05:54.01,0:05:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau bilang ini pekerjaan\Nyang siapa pun bisa lakukan.
Dialogue: 0,0:05:58.50,0:06:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bantu!
Dialogue: 0,0:06:00.51,0:06:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, pisahkan berkas sesuai jenisnya.
Dialogue: 0,0:06:04.21,0:06:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan apel sepuasnya?
Dialogue: 0,0:06:05.43,0:06:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elus yang lembut sepuasnya?
Dialogue: 0,0:06:08.25,0:06:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dari keluarga Pugyal?
Dialogue: 0,0:06:10.20,0:06:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya mereka sempat hilang\Nsetelah diserang Lamia.
Dialogue: 0,0:06:12.83,0:06:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:14.02,0:06:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalian masih hidup, ya?\N- Urusan administrasi akhirnya teratasi.
Dialogue: 0,0:06:18.13,0:06:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka sudah tenang, suruh makan.
Dialogue: 0,0:06:20.26,0:06:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:06:36.48,0:06:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades!
Dialogue: 0,0:06:38.54,0:06:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami selesai patroli di sepanjang perjalanan.
Dialogue: 0,0:06:41.23,0:06:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ditemukan bahaya apa pun.
Dialogue: 0,0:06:44.57,0:06:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta tolong padanya.
Dialogue: 0,0:06:46.66,0:06:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi lihat calon lokasi desa baru.
Dialogue: 0,0:06:49.61,0:06:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, baik.
Dialogue: 0,0:06:51.93,0:06:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu persiapan?\NBawal bekal?
Dialogue: 0,0:06:54.40,0:06:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya tidak terlalu jauh.
Dialogue: 0,0:06:56.90,0:06:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk lokasinya,
Dialogue: 0,0:06:58.10,0:06:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau dari posisi Desa Pohon Besar
Dialogue: 0,0:06:59.11,0:07:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}letaknya ada di hilir sungai.
Dialogue: 0,0:07:01.39,0:07:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hulu dan hilir?
Dialogue: 0,0:07:02.63,0:07:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu agar mudah dipertahankan saat darurat,\Nlokasinya di seberang sungai.
Dialogue: 0,0:07:06.67,0:07:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita beri jarak agar sungai tak mudah dikuasai.
Dialogue: 0,0:07:09.50,0:07:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat darurat?
Dialogue: 0,0:07:10.63,0:07:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemberontakan.
Dialogue: 0,0:07:12.64,0:07:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti terjadi?
Dialogue: 0,0:07:13.71,0:07:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus dipertimbangkan sebagai kemungkinan.
Dialogue: 0,0:07:16.12,0:07:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai terjadi, kita terlambat.
Dialogue: 0,0:07:18.46,0:07:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:07:22.63,0:07:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak sebesar Pohon Besar,\Ntapi cukup mencolok.
Dialogue: 0,0:07:26.14,0:07:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, gampang dikenali.
Dialogue: 0,0:07:29.26,0:07:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasinya sudah ditentukan.
Dialogue: 0,0:07:30.75,0:07:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami membuka hutan dan membuat jalan.
Dialogue: 0,0:07:33.14,0:07:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo mulai.
Dialogue: 0,0:07:34.91,0:07:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:07:37.14,0:07:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebang!
Dialogue: 0,0:07:40.16,0:07:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah, ya.
Dialogue: 0,0:07:41.15,0:07:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kami tidak sanggup.
Dialogue: 0,0:07:42.86,0:07:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lebih keras dari besi.
Dialogue: 0,0:07:44.59,0:07:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, kuserahkan padamu.
Dialogue: 0,0:07:46.39,0:07:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:47.57,0:07:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapak.
Dialogue: 0,0:07:51.41,0:07:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wantanmen!
Dialogue: 0,0:07:54.06,0:07:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beres.
Dialogue: 0,0:07:56.66,0:07:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tantanmen!
Dialogue: 0,0:07:58.89,0:08:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chanponmen!
Dialogue: 0,0:08:01.17,0:08:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan Alat Bertani Mahabisa,\Nsemuanya cepat beres.
Dialogue: 0,0:08:05.37,0:08:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kami memasang jembatan kayu di sungai.
Dialogue: 0,0:08:09.34,0:08:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya buat lebih kokoh.
Dialogue: 0,0:08:11.74,0:08:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terlalu lebar...
Dialogue: 0,0:08:13.68,0:08:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasang!
Dialogue: 0,0:08:15.99,0:08:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster besar bisa lewat.
Dialogue: 0,0:08:18.13,0:08:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:08:20.40,0:08:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:08:21.79,0:08:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami membuka area sekitar.
Dialogue: 0,0:08:23.68,0:08:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mabomen!
Dialogue: 0,0:08:26.99,0:08:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, membuat saluran air dari hulu.
Dialogue: 0,0:08:36.58,0:08:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam waktu singkat, progresnya pesat, ya.
Dialogue: 0,0:08:40.09,0:08:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kurang kayu, kita tak bisa\Nlanjut pekerjaan selanjutnya.
Dialogue: 0,0:08:44.09,0:08:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami yang lanjut merakit.
Dialogue: 0,0:08:46.89,0:08:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda sebaiknya istirahat.
Dialogue: 0,0:08:48.91,0:08:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:58.06,0:08:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:08:59.58,0:09:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku coba membuat patung Zabuton.
Dialogue: 0,0:09:01.60,0:09:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin harusnya lebih besar lagi.
Dialogue: 0,0:09:03.95,0:09:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh.
Dialogue: 0,0:09:06.09,0:09:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kamu sedang istirahat.
Dialogue: 0,0:09:07.99,0:09:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini cuma selingan sebentar.
Dialogue: 0,0:09:10.73,0:09:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa memang gila kerja, ya.
Dialogue: 0,0:09:13.99,0:09:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan istirahat.
Dialogue: 0,0:09:21.89,0:09:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:09:23.18,0:09:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya lancar.
Dialogue: 0,0:09:24.50,0:09:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kamu menyiapkan banyak kayu,\Nternyata untuk ini, ya?
Dialogue: 0,0:09:29.09,0:09:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini kita harus bangun banyak rumah.
Dialogue: 0,0:09:33.43,0:09:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan disiapkan sesuai desain,
Dialogue: 0,0:09:37.14,0:09:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu semuanya rakit bersama-sama.
Dialogue: 0,0:09:41.02,0:09:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu saat buat gubuk sendirian, aku kesulitan.\NTidak ada paku juga.
Dialogue: 0,0:09:45.82,0:09:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi nostalgia.\NGubuk yang itu, ya?
Dialogue: 0,0:09:48.22,0:09:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, saat itu aku kesulitan angkat kayu.
Dialogue: 0,0:09:53.11,0:09:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:54.87,0:09:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebarnya...
Dialogue: 0,0:09:55.97,0:09:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pindahkan ke sini.
Dialogue: 0,0:09:57.55,0:09:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh! Iya.
Dialogue: 0,0:10:00.37,0:10:01.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:10:01.94,0:10:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman.
Dialogue: 0,0:10:02.89,0:10:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir itu hebat, ya.
Dialogue: 0,0:10:13.73,0:10:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya.
Dialogue: 0,0:10:15.28,0:10:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:10:16.64,0:10:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih butuh papan, ya?
Dialogue: 0,0:10:18.58,0:10:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:19.42,0:10:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:10:20.14,0:10:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:10:23.02,0:10:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kamu baik-baik saja?
Dialogue: 0,0:10:24.81,0:10:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman.
Dialogue: 0,0:10:26.49,0:10:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita utamakan keselamatan.
Dialogue: 0,0:10:32.40,0:10:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat semuanya, sudah mulai terbentuk, ya.
Dialogue: 0,0:10:35.28,0:10:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pendatangnya berapa banyak?
Dialogue: 0,0:10:38.46,0:10:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, jumlah pastinya belum tahu.
Dialogue: 0,0:10:43.60,0:10:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades!
Dialogue: 0,0:10:44.92,0:10:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu!\NAda pesan dari Tuan Doraimu.
Dialogue: 0,0:10:48.94,0:10:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau bilang mereka\Nakan segera dibawa ke sini.
Dialogue: 0,0:10:55.70,0:10:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, maaf mendadak, Kades.
Dialogue: 0,0:11:01.34,0:11:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya lebih mendesak dari perkiraan.
Dialogue: 0,0:11:04.69,0:11:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya beri kabar dulu.
Dialogue: 0,0:11:07.78,0:11:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah.
Dialogue: 0,0:11:09.62,0:11:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kirim wyvern kecil sebagai kurir.
Dialogue: 0,0:11:12.47,0:11:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, mungkin aku mendahuluinya.
Dialogue: 0,0:11:14.19,0:11:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku bergegas.
Dialogue: 0,0:11:17.19,0:11:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:11:18.20,0:11:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka ini calon pendatang, ras Minotaurus.
Dialogue: 0,0:11:21.70,0:11:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minotaurus.
Dialogue: 0,0:11:23.87,0:11:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira kepalanya sapi.
Dialogue: 0,0:11:29.12,0:11:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Gordon, perwakilan ras.
Dialogue: 0,0:11:31.21,0:11:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Hiraku, kades.
Dialogue: 0,0:11:34.05,0:11:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia besar.\NTingginya lebih dari dua meter.
Dialogue: 0,0:11:38.39,0:11:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, terima kasih.
Dialogue: 0,0:11:39.97,0:11:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami diusir dari desa
Dialogue: 0,0:11:42.46,0:11:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu diselamatkan saat mengembara.
Dialogue: 0,0:11:46.47,0:11:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisi mereka sudah kekurangan\Nmakanan dan juga ada anak-anak.
Dialogue: 0,0:11:49.98,0:11:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kami bergegas.
Dialogue: 0,0:11:52.27,0:11:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya untuk mengobrol.
Dialogue: 0,0:11:54.95,0:11:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera siapkan makanan.
Dialogue: 0,0:11:56.82,0:11:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:58.30,0:11:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berapa orang?
Dialogue: 0,0:11:59.71,0:12:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}22 orang.
Dialogue: 0,0:12:04.06,0:12:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan makan dengan tenang.
Dialogue: 0,0:12:06.02,0:12:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:12:08.75,0:12:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, kita bagikan bubur.
Dialogue: 0,0:12:12.00,0:12:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada makanan\Nyang tidak bisa mereka makan?
Dialogue: 0,0:12:14.35,0:12:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami tidak tahu kebiasaan Minotaurus.
Dialogue: 0,0:12:18.27,0:12:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang paham tentang mereka?
Dialogue: 0,0:12:21.59,0:12:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades, kalau boleh bantu...
Dialogue: 0,0:12:24.14,0:12:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:25.27,0:12:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku sempat tinggal bersama Minotaurus.
Dialogue: 0,0:12:30.27,0:12:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan merangkum kebutuhan mereka.
Dialogue: 0,0:12:33.99,0:12:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tolong, ya.
Dialogue: 0,0:12:35.69,0:12:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian dari daerah pegunungan?\NKudengar anginnya sejuk saat musim panas.
Dialogue: 0,0:12:39.22,0:12:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:39.95,0:12:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sangat sejuk.\N- Untung saja.
Dialogue: 0,0:12:41.45,0:12:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat tinggalnya sudah kita siapkan.\NUntuk sekarang, kita bisa lega.
Dialogue: 0,0:12:46.03,0:12:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja begitu.
Dialogue: 0,0:12:47.97,0:12:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ada yang salah?
Dialogue: 0,0:12:52.79,0:12:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukurannya tidak cocok.
Dialogue: 0,0:12:54.96,0:12:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya
Dialogue: 0,0:12:57.45,0:12:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ukurannya agak sempit, ya?
Dialogue: 0,0:12:59.09,0:13:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak, ya?
Dialogue: 0,0:13:03.26,0:13:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi penuh.
Dialogue: 0,0:13:05.30,0:13:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di penginapan tamu juga sama penuhnya.
Dialogue: 0,0:13:08.42,0:13:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera cari solusi.
Dialogue: 0,0:13:11.33,0:13:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa baru akan dipakai\Nuntuk pendatang lain...
Dialogue: 0,0:13:14.89,0:13:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menghubungi ayahku.
Dialogue: 0,0:13:17.34,0:13:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau bilang akan bawa para pendatang.
Dialogue: 0,0:13:20.86,0:13:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mendadak, Kades.
Dialogue: 0,0:13:23.99,0:13:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu kenapa?
Dialogue: 0,0:13:25.37,0:13:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu sedang berbicara\Ndengan para pengungsi perang soal relokasi?
Dialogue: 0,0:13:29.55,0:13:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya mendadak berubah.
Dialogue: 0,0:13:31.89,0:13:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk evakuasi banyak orang,\Nbutuh sihir teleportasi berkali-kali.
Dialogue: 0,0:13:36.50,0:13:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri, Ayah,\Nkamu sudah tidak muda lagi.
Dialogue: 0,0:13:40.74,0:13:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti bilang begitu,\Nhatiku serasa ditusuk.
Dialogue: 0,0:13:43.81,0:13:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebaiknya istirahat dulu.
Dialogue: 0,0:13:45.76,0:13:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, permisi.
Dialogue: 0,0:13:49.66,0:13:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi para pendatangnya
Dialogue: 0,0:13:52.02,0:13:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manusia setengah kuda, Centaurus?
Dialogue: 0,0:13:56.19,0:13:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa lihat kami begitu?
Dialogue: 0,0:13:58.89,0:14:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan dirimu dulu.
Dialogue: 0,0:14:00.74,0:14:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku Hiraku, kades di sini.
Dialogue: 0,0:14:03.78,0:14:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Gruwald dari ras Centaurus.
Dialogue: 0,0:14:06.65,0:14:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keluarga Viscount Beig.\NKerabat kepala pengawal
Dialogue: 0,0:14:09.79,0:14:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount Beig?\NBangsawan dari Kerajaan Iblis?
Dialogue: 0,0:14:14.17,0:14:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa diam saja?
Dialogue: 0,0:14:16.24,0:14:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memberi tahu statusku,
Dialogue: 0,0:14:18.13,0:14:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perlakukan kami dengan pantas!
Dialogue: 0,0:14:24.07,0:14:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih membuat kami menunggu?
Dialogue: 0,0:14:27.34,0:14:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:14:29.70,0:14:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti lelah dari perjalanan jauh.
Dialogue: 0,0:14:31.80,0:14:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini
Dialogue: 0,0:14:32.72,0:14:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada relasi dengan Count Chrome
Dialogue: 0,0:14:35.09,0:14:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mengantar kalian.
Dialogue: 0,0:14:36.85,0:14:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:14:38.44,0:14:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:14:40.69,0:14:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak paham etika bangsawan.
Dialogue: 0,0:14:43.42,0:14:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, hal seperti ini akan kuserahkan\Npada yang lebih paham.
Dialogue: 0,0:14:46.70,0:14:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount Beig?
Dialogue: 0,0:14:48.41,0:14:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, itu wilayah barat.
Dialogue: 0,0:14:50.18,0:14:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak ada relasi, ya?
Dialogue: 0,0:14:51.89,0:14:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, biar aku saja.
Dialogue: 0,0:14:54.97,0:14:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah dengar soal pindah kalian,\Nsayangnya saat ini kami sibuk.
Dialogue: 0,0:14:59.50,0:15:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantas lakukan sesuatu, kami lelah!
Dialogue: 0,0:15:02.40,0:15:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuanmu ke desa ini, Gruwald?
Dialogue: 0,0:15:07.06,0:15:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian datang untuk minta bantuan, kan?
Dialogue: 0,0:15:09.64,0:15:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan wilayah yang bisa kamu kuasai.
Dialogue: 0,0:15:13.91,0:15:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jaga sikapmu.
Dialogue: 0,0:15:15.64,0:15:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu cuma gadis desa!\NDasar lancang!
Dialogue: 0,0:15:18.39,0:15:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf, aku belum memperkenalkan diri.
Dialogue: 0,0:15:22.02,0:15:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku putri kedua keluarga Count Dorowa\Ndari Kerajaan Iblis,
Dialogue: 0,0:15:26.47,0:15:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rashashi Dorowa.
Dialogue: 0,0:15:29.44,0:15:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari keluarga count?
Dialogue: 0,0:15:30.91,0:15:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, kamu dari keluarga mana?
Dialogue: 0,0:15:35.21,0:15:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh bicara sebentar di sana?
Dialogue: 0,0:15:46.33,0:15:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya
Dialogue: 0,0:15:47.93,0:15:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar minta maaf!
Dialogue: 0,0:15:49.43,0:15:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak apa-apa.
Dialogue: 0,0:15:51.29,0:15:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga minta maaf atas sikap tak sopan ini.
Dialogue: 0,0:15:53.84,0:15:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maafkan kami!
Dialogue: 0,0:15:55.95,0:15:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tidak apa-apa.
Dialogue: 0,0:15:57.19,0:16:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh, biar aku yang urus mereka.
Dialogue: 0,0:16:02.38,0:16:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ada relasi dengan keluargaku.
Dialogue: 0,0:16:04.78,0:16:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu akan sangat membantu.
Dialogue: 0,0:16:07.01,0:16:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, keluargamu baik-baik saja?
Dialogue: 0,0:16:10.21,0:16:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya sampai ada pengungsi,\Nberarti perang besar terjadi.
Dialogue: 0,0:16:13.30,0:16:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:16:14.61,0:16:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah perhatian.
Dialogue: 0,0:16:16.89,0:16:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya, untuk saat ini\Nmereka baik-baik saja.
Dialogue: 0,0:16:20.45,0:16:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia belum kembali.
Dialogue: 0,0:16:22.00,0:16:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia memanfaatkan kesempatan.
Dialogue: 0,0:16:24.43,0:16:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah ada bala bantuan.
Dialogue: 0,0:16:31.19,0:16:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi ukurannya tidak cocok.
Dialogue: 0,0:16:33.10,0:16:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bakal sempit.
Dialogue: 0,0:16:35.47,0:16:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tubuh kalian bisa diperkecil dengan sihir?
Dialogue: 0,0:16:38.93,0:16:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah batasnya.
Dialogue: 0,0:16:41.23,0:16:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak bisa seperti Luu.
Dialogue: 0,0:16:44.73,0:16:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua bangunan besar sudah penuh.
Dialogue: 0,0:16:48.03,0:16:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengecil...
Dialogue: 0,0:16:49.20,0:16:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, semuanya berapa orang?
Dialogue: 0,0:16:50.77,0:16:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}40 orang dewasa, 64 anak-anak.
Dialogue: 0,0:16:53.42,0:16:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya 104 orang.
Dialogue: 0,0:16:54.88,0:16:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:16:55.62,0:16:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara,\Nbagaimana kalau di dungeon selatan dulu?
Dialogue: 0,0:16:59.12,0:17:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mungkin bisa menumpang ke ras Lamia.
Dialogue: 0,0:17:02.94,0:17:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya desa ini dibangun untuk apa?
Dialogue: 0,0:17:06.41,0:17:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bahas itu.
Dialogue: 0,0:17:08.81,0:17:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Minotaurus dan Centaurus,\Nberikutnya taurus apa lagi?
Dialogue: 0,0:17:13.06,0:17:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat memikirkan itu,\Ndatanglah rombongan gadis muda.
Dialogue: 0,0:17:18.32,0:17:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Lamia menemukan mereka\Nsedang jalan kaki di hutan.
Dialogue: 0,0:17:22.02,0:17:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka cuma jalan kaki santai,\Nkami langsung bawa ke sini.
Dialogue: 0,0:17:26.43,0:17:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan kaki?\NHutan di sini penuh monster.
Dialogue: 0,0:17:31.47,0:17:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggul pohon?\NKenapa bawa tunggul pohon?
Dialogue: 0,0:17:34.09,0:17:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin untuk istirahat duduk?
Dialogue: 0,0:17:36.43,0:17:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, aku Hiraku, kades di sini.
Dialogue: 0,0:17:40.79,0:17:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pendiam, ya?
Dialogue: 0,0:17:42.32,0:17:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka tegang?
Dialogue: 0,0:17:43.87,0:17:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami belum terbiasa berbicara.
Dialogue: 0,0:17:47.30,0:17:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku perwakilan mereka, Igu.\NTerima kasih sudah menerima kami.
Dialogue: 0,0:17:50.23,0:17:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggul pohonnya bicara?
Dialogue: 0,0:17:51.99,0:17:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, hal seperti ini bisa terjadi.
Dialogue: 0,0:17:54.98,0:17:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, mereka adalah ras Nyunyudaphne.
Dialogue: 0,0:17:58.10,0:18:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semacam roh pohon.
Dialogue: 0,0:18:01.06,0:18:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa menyatu dengan tumbuhan,
Dialogue: 0,0:18:04.45,0:18:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan saat bertemu monster,\Nmereka menghindar menjadi pohon.
Dialogue: 0,0:18:09.94,0:18:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terluka, mereka butuh waktu\Nuntuk kembali ke wujud manusia.
Dialogue: 0,0:18:13.57,0:18:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu jadi tunggul pohon?
Dialogue: 0,0:18:15.60,0:18:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mudah dibawa.
Dialogue: 0,0:18:17.33,0:18:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Portabel.
Dialogue: 0,0:18:18.33,0:18:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat asal kami banjir karena manusia\Nmenebang terlalu banyak pohon.
Dialogue: 0,0:18:24.08,0:18:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kami dengar soal desa ini\Ndari pedagang Tuan Michael
Dialogue: 0,0:18:28.34,0:18:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan datang kemari melewati Hutan Kematian.
Dialogue: 0,0:18:30.48,0:18:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:18:31.75,0:18:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka ke sini sendiri,\NMichael tidak tahu kondisi mereka.
Dialogue: 0,0:18:35.84,0:18:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jalan kaki jarak jauh,\Nkalian pasti lapar, kan?
Dialogue: 0,0:18:38.86,0:18:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sekalian mengadakan pesta?
Dialogue: 0,0:18:40.40,0:18:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pestanya nanti saja.
Dialogue: 0,0:18:42.22,0:18:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan menyiapkan makanan,\Nada hal lain yang kalian inginkan?
Dialogue: 0,0:18:45.85,0:18:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:18:48.14,0:18:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu sungkan.
Dialogue: 0,0:18:49.59,0:18:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buah.
Dialogue: 0,0:18:50.61,0:18:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau buah akan segera kami siapkan.
Dialogue: 0,0:18:53.60,0:18:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah melihat buah di sini\Ndari Tuan Michael.
Dialogue: 0,0:18:57.81,0:19:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau buah sebagus itu bisa tumbuh,
Dialogue: 0,0:19:02.87,0:19:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti tanah di sini pasti bagus.
Dialogue: 0,0:19:06.01,0:19:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian makan tanah?
Dialogue: 0,0:19:11.55,0:19:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengantar mereka ke ladang\Nsesuai yang mereka minta.
Dialogue: 0,0:19:14.57,0:19:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pemandangannya aneh.
Dialogue: 0,0:19:17.02,0:19:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kuduga, tanahnya harum.
Dialogue: 0,0:19:20.56,0:19:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak perlu makan.
Dialogue: 0,0:19:23.61,0:19:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya butuh air bersih\Ndan sinar matahari.
Dialogue: 0,0:19:26.84,0:19:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:19:30.15,0:19:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhenti.
Dialogue: 0,0:19:34.30,0:19:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanahnya bagus.
Dialogue: 0,0:19:35.70,0:19:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka roh pohon,\Nmungkin cara berjalannya waktu berbeda?
Dialogue: 0,0:19:40.33,0:19:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya!
Dialogue: 0,0:19:41.65,0:19:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebutuhan makanan kalian sudah jelas.\NBagaimana dengan tempat tinggal?
Dialogue: 0,0:19:45.38,0:19:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:19:46.27,0:19:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya ada pendatang\Nyang bisa tinggal di rumah baru!
Dialogue: 0,0:19:49.99,0:19:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kami sudah menyiapkan rumah!
Dialogue: 0,0:19:52.30,0:19:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami lebih suka tempat terbuka\Nyang terkena sinar matahari.
Dialogue: 0,0:19:55.30,0:19:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal cahaya,\Nkami bisa buat jendela besar...
Dialogue: 0,0:19:58.80,0:20:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin di luar.
Dialogue: 0,0:20:00.39,0:20:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di luar terus, kalian nanti\Nkena hujan dan cuaca lainnya.
Dialogue: 0,0:20:03.89,0:20:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar.
Dialogue: 0,0:20:09.41,0:20:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara, kami utamakan\Nanak-anak Minotaurus di Balai Desa.
Dialogue: 0,0:20:14.76,0:20:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk para Centaurus,\Nmereka menumpang di kandang sapi.
Dialogue: 0,0:20:18.42,0:20:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk Nyunyudaphne...\Nmereka masih berdiri di ladang.
Dialogue: 0,0:20:22.74,0:20:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam.
Dialogue: 0,0:20:26.49,0:20:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa suatu hari aku akan terbiasa\Ndengan pemandangan ini?
Dialogue: 0,0:20:31.27,0:20:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, kita biarkan dulu\Nsoal desa yang masih kosong.
Dialogue: 0,0:20:36.94,0:20:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera siapkan\Ntempat tinggal untuk semuanya.
Dialogue: 0,0:20:39.41,0:20:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara, ini bakal ramai, ya.
Dialogue: 0,0:20:41.43,0:20:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma makanan,
Dialogue: 0,0:20:43.19,0:20:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pakaian dan kebutuhan harian juga\Nharus disiapkan.
Dialogue: 0,0:20:45.91,0:20:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, kita mulai\Ndari yang bisa dilakukan dulu.
Dialogue: 0,0:20:48.70,0:20:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:49.44,0:20:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat.
Dialogue: 0,0:20:51.69,0:20:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita diskusikan lagi soal desain rumahnya.
Dialogue: 0,0:20:54.07,0:20:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap! Ayo kita bangun rumah besar!
Dialogue: 0,0:20:57.02,0:21:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, 72 rumah untuk Minotaurus\Ndan 104 rumah untuk Centaurus.
Dialogue: 0,0:21:01.52,0:21:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, gawat, ya!
Dialogue: 0,0:21:03.79,0:21:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita cari cara!
Dialogue: 0,0:22:37.30,0:22:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah,
Dialogue: 0,0:22:37.88,0:22:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gruwald.
Dialogue: 0,0:22:39.37,0:22:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Maaf atas sikap lancangku tadi!
Dialogue: 0,0:22:43.12,0:22:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak minta kamu bilang maaf.
Dialogue: 0,0:22:45.76,0:22:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kamu bersikap tegas
Dialogue: 0,0:22:49.25,0:22:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi keselamatan kelompokmu, kan?
Dialogue: 0,0:22:52.43,0:22:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi padaku, aku terima.
Dialogue: 0,0:22:55.74,0:22:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:22:57.19,0:23:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, tolong terima anak-anak.
Dialogue: 0,0:23:01.28,0:23:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menentukan itu bukan aku, tapi Kades.
Dialogue: 0,0:23:04.46,0:23:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu yang bernama Hiraku tadi?
Dialogue: 0,0:23:07.28,0:23:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, yang paling berkuasa\Ndi desa ini adalah kades.
Dialogue: 0,0:23:11.29,0:23:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya posisi apa pun,\Nbahkan lebih rendah dari pasir.
Dialogue: 0,0:23:15.54,0:23:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Meski kamu putri keluarga Count?
Dialogue: 0,0:23:18.40,0:23:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu Empat Raja Iblis, Count Chrome,
Dialogue: 0,0:23:21.27,0:23:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai turun tangan mengangkut\Nbarang seperti kuda angkut.
Dialogue: 0,0:23:24.30,0:23:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jelas tidak biasa.
Dialogue: 0,0:23:26.55,0:23:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghadapi orang seperti itu,
Dialogue: 0,0:23:28.55,0:23:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pasti paham\Nharus bersikap seperti apa, kan?
Dialogue: 0,0:23:36.33,0:23:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya benar-benar minta maaf!
Dialogue: 0,0:23:39.76,0:23:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tidak apa-apa!\NTenang, berdiri lagi.
Dialogue: 0,0:23:43.62,0:23:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Permintaan maaf yang bagus.\N- Jangan dipikirkan.
