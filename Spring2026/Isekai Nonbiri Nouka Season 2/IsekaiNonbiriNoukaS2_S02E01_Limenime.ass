Dialogue: 0,0:09:32.26,0:09:34.89,tanda,,0000,0000,0000,,FONDASI, PAPAN PANJANG, PAPAN PENDEK
Dialogue: 0,0:10:25.77,0:10:28.77,tanda,,0000,0000,0000,,DILARANG LEMPAR KAYU
Dialogue: 0,0:11:01.93,0:11:04.69,tanda,,0000,0000,0000,,NAGA PENJAGA GERBANG, DORAIMU
