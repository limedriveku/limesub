Dialogue: 0,0:00:33.43,0:00:39.52,sign,,0,0,0,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:08:55.77,0:08:56.41,sign,,0,0,0,,BATU HITAM
Dialogue: 0,0:08:56.41,0:08:59.81,sign,,0,0,0,,PERTEMUAN DENGAN RAJA ARWAH
Dialogue: 0,0:12:52.88,0:12:58.13,sign,,0,0,0,,PERKIRAAN
Dialogue: 0,0:18:34.97,0:18:36.97,sign,,0,0,0,,PROGRES
Dialogue: 0,0:19:02.75,0:19:07.50,sign,,0,0,0,,BATU
Dialogue: 0,0:19:35.28,0:19:38.28,sign,,0,0,0,,BATU, BATU, BATU?
Dialogue: 0,0:20:36.42,0:20:39.43,sign,,0,0,0,,SENJATA RAHASIA
Dialogue: 0,0:23:44.99,0:23:49.99,sign,,0,0,0,,SELANJUTNYA:\NEPISODE 9: KEMBALI KE RUTINITAS HARIAN
Dialogue: 0,0:00:12.20,0:00:14.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namaku Raja Arwah.
Dialogue: 0,0:00:16.68,0:00:19.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan menghancurkan
Dialogue: 0,0:00:19.51,0:00:21.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}segel terkutuk itu.
Dialogue: 0,0:01:54.76,0:01:56.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keesokan harinya,
Dialogue: 0,0:01:56.74,0:02:00.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Leluhur dan yang lainnya\Nyang menyelidiki lorong kembali.
Dialogue: 0,0:02:01.29,0:02:04.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, tadi itu merepotkan.
Dialogue: 0,0:02:04.52,0:02:08.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa penyebab munculnya\Npara monster sudah ketemu?
Dialogue: 0,0:02:08.50,0:02:10.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, sudah.
Dialogue: 0,0:02:10.15,0:02:14.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya ada penjahat\Nyang sedang merencanakan sesuatu,
Dialogue: 0,0:02:14.94,0:02:16.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi Hakuren menendangnya.
Dialogue: 0,0:02:16.66,0:02:17.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menendangnya?
Dialogue: 0,0:02:17.90,0:02:22.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Undead yang jumlahnya banyak pun,\Nsemuanya ditendang Hakuren.
Dialogue: 0,0:02:22.29,0:02:23.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu...
Dialogue: 0,0:02:23.48,0:02:27.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah mencoba menyelidikinya lagi.
Dialogue: 0,0:02:27.06,0:02:30.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi tak ada hasil,\Nsemua petunjuknya sudah hancur.
Dialogue: 0,0:02:30.97,0:02:32.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu Hakuren di mana?
Dialogue: 0,0:02:32.97,0:02:34.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di sana.
Dialogue: 0,0:02:35.69,0:02:37.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia bilang mengantuk.
Dialogue: 0,0:02:37.78,0:02:40.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin dia lelah karena terus menendang.
Dialogue: 0,0:02:40.43,0:02:44.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Intinya, berkat dia,\Nbahaya di sini sudah hilang.
Dialogue: 0,0:02:44.33,0:02:46.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:02:46.09,0:02:47.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, iya...
Dialogue: 0,0:02:51.44,0:02:52.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:02:52.42,0:02:55.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia dalang yang kubilang barusan,\Npengendali para monster di sana.
Dialogue: 0,0:02:55.64,0:02:56.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:57.62,0:03:01.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia dalangnya?\NTapi sosoknya tidak kelihatan begitu.
Dialogue: 0,0:03:01.11,0:03:01.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soal itu,
Dialogue: 0,0:03:02.92,0:03:06.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}awalnya dia Undead yang menyeramkan.
Dialogue: 0,0:03:06.21,0:03:07.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tendang!
Dialogue: 0,0:03:07.50,0:03:10.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi karena Hakuren\Nterus menendang, menginjak,
Dialogue: 0,0:03:10.97,0:03:15.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan menyemburkan api,\Ndampaknya melewati pemurnian...
Dialogue: 0,0:03:16.97,0:03:19.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu jadi seperti ini?
Dialogue: 0,0:03:19.02,0:03:22.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya ingatan dia sebelumnya\Nsudah hilang sepenuhnya.
Dialogue: 0,0:03:22.47,0:03:26.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia juga tak bisa berbuat jahat lagi.\NKita juga tak bisa membiarkannya, kan?
Dialogue: 0,0:03:26.98,0:03:30.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anu, siapa namamu?\NAku lupa ingatan dia sudah hilang.
Dialogue: 0,0:03:30.57,0:03:33.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kondisi dia seperti ini bahkan sebelum\Nmenyebutkan namanya.
Dialogue: 0,0:03:34.09,0:03:36.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagusnya dipanggil apa, ya?
Dialogue: 0,0:03:39.51,0:03:40.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Urza.
Dialogue: 0,0:03:40.49,0:03:44.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh! Urza, apa ada hal lain\Nyang masih kamu ingat?
Dialogue: 0,0:03:44.50,0:03:45.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada!
Dialogue: 0,0:03:45.50,0:03:47.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:03:47.75,0:03:49.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:03:49.94,0:03:52.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku Hiraku.\NSalam kenal.
Dialogue: 0,0:03:54.58,0:03:55.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:04:02.62,0:04:06.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku Raja Arwah.\NTerbangun dari tidur panjang.
Dialogue: 0,0:04:07.56,0:04:10.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku bahkan sudah tak tahu lagi\Nsiapa diriku sebenarnya.
Dialogue: 0,0:04:10.71,0:04:14.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya dibangunkan\Nsebagai Raja Mayat Hidup.
Dialogue: 0,0:04:14.84,0:04:18.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}"Sesuatu" membangunkanku\Nlalu memberi perintah.
Dialogue: 0,0:04:18.30,0:04:21.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}"Lepaskan segel di tanah ini."
Dialogue: 0,0:04:22.30,0:04:25.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena tak ada hal yang bisa kulakukan,\Naku mematuhi perintahnya.
Dialogue: 0,0:04:28.95,0:04:33.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan kekuatan ini, aku mengendalikan\Npasukan untuk menghancurkan segelnya.
Dialogue: 0,0:04:37.34,0:04:38.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia kelihatan lemah.
Dialogue: 0,0:04:40.23,0:04:41.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lantas, aku akan mengandalkan jumlah.
Dialogue: 0,0:04:44.58,0:04:46.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku memerintahkan para golem tanah
Dialogue: 0,0:04:46.93,0:04:49.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}untuk terus menggali tanpa henti.
Dialogue: 0,0:04:50.19,0:04:54.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sendiri tak tahu alasannya,\Ntapi kurasa segelnya ada di arah sini.
Dialogue: 0,0:04:56.47,0:04:59.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ketemu.\NBatu Hitam mencurigakan.
Dialogue: 0,0:04:59.50,0:05:01.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hasilnya cukup memuaskan.
Dialogue: 0,0:05:01.70,0:05:05.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, ini belum selesai.
Dialogue: 0,0:05:05.18,0:05:08.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya masih ada batu lain yang mirip.
Dialogue: 0,0:05:08.78,0:05:10.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gali lagi.
Dialogue: 0,0:05:10.39,0:05:14.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para golem tanah bekerja\Ndengan rajin tanpa mengeluh.
Dialogue: 0,0:05:17.67,0:05:20.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sayangnya mereka terlalu pendiam.
Dialogue: 0,0:05:21.64,0:05:24.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tak lama kemudian,\Nkami mencapai rongga bawah tanah.
Dialogue: 0,0:05:24.35,0:05:27.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menemukan banyak mayat.
Dialogue: 0,0:05:27.60,0:05:30.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kukendalikan mereka dengan kekuatanku\Ndan kujadikan bawahan.
Dialogue: 0,0:05:30.97,0:05:34.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagus, mereka terlihat kuat.\NTapi masih pendiam.
Dialogue: 0,0:05:34.97,0:05:38.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku terus memerintahkan\Nbawahanku untuk menggali.
Dialogue: 0,0:05:38.11,0:05:42.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena aku Raja Mayat Hidup, aku harus\Nmemimpin bawahan layaknya raja.
Dialogue: 0,0:05:42.61,0:05:45.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa menggali lubang memang tugasnya raja?
Dialogue: 0,0:05:45.40,0:05:48.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dipikirkan pun percuma.\NTak ada kegiatan lain juga.
Dialogue: 0,0:05:49.67,0:05:51.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bawahanku bertambah lagi.
Dialogue: 0,0:05:51.62,0:05:54.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Monster yang ahli menggali.
Dialogue: 0,0:05:54.66,0:05:57.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagus, dengan ini\Npekerjaannya jadi lebih cepat.
Dialogue: 0,0:05:58.62,0:06:00.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami sudah beberapa tahun terus menggali.
Dialogue: 0,0:06:00.79,0:06:03.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, mungkin sudah puluhan tahun.
Dialogue: 0,0:06:06.07,0:06:08.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami menemukan batu hitam berikutnya.
Dialogue: 0,0:06:09.35,0:06:13.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku memuji mereka dan berbagi\Nkebahagiaan bersama.
Dialogue: 0,0:06:13.15,0:06:16.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk batu yang masih tersisa,\Naku masih belum tahu.
Dialogue: 0,0:06:16.50,0:06:20.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi bersama para bawahanku,\Naku yakin kami bisa menyelesaikannya.
Dialogue: 0,0:06:20.20,0:06:22.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sampai merasa yakin begitu...
Dialogue: 0,0:06:23.06,0:06:26.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, ada ribut apa?
Dialogue: 0,0:06:26.02,0:06:29.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jarang para bawahanku\Nyang pendiam ribut begini.
Dialogue: 0,0:06:32.47,0:06:35.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Tunggu, tunggu dulu!
Dialogue: 0,0:06:43.74,0:06:47.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini di mana?\NSiapa aku?
Dialogue: 0,0:06:47.54,0:06:49.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasanya seperti terjadi banyak hal...
Dialogue: 0,0:06:49.72,0:06:51.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:06:55.26,0:06:57.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak ingat apa pun.
Dialogue: 0,0:06:57.56,0:07:02.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mbak yang bertanduk\Ndan Abang yang kelihatan lelah
Dialogue: 0,0:07:03.99,0:07:07.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}mengeluarkanku dari gua.
Dialogue: 0,0:07:21.78,0:07:24.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Entah kenapa aku benci Mbak yang ini!
Dialogue: 0,0:07:26.46,0:07:29.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, begini...
Dialogue: 0,0:07:29.47,0:07:31.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, ada apa?
Dialogue: 0,0:07:31.74,0:07:33.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku lupa.
Dialogue: 0,0:07:33.06,0:07:35.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, bocah itu akan tinggal di desa ini?
Dialogue: 0,0:07:35.83,0:07:38.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setidaknya sampai dia ingat sesuatu.
Dialogue: 0,0:07:38.28,0:07:40.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia menyebut dirinya Urza, ya?
Dialogue: 0,0:07:40.36,0:07:43.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, cuma itu yang bisa\Nkami tahu tentang dirinya.
Dialogue: 0,0:07:43.99,0:07:46.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat dengar namanya, aku jadi ingat.
Dialogue: 0,0:07:47.13,0:07:52.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rambutnya yang berkilau berubah warna\Nsaat terkena cahaya, seperti permata...
Dialogue: 0,0:07:53.13,0:07:55.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu legenda sang Ratu Pahlawan, ya?
Dialogue: 0,0:07:55.59,0:07:58.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ratu Pahlawan?\NMaksudnya Nona Urbarza?
Dialogue: 0,0:07:58.58,0:07:59.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu tidak mungkin...
Dialogue: 0,0:07:59.77,0:08:02.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin itu cuma kebetulan?
Dialogue: 0,0:08:02.01,0:08:03.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa dia terkenal?
Dialogue: 0,0:08:03.63,0:08:05.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, eh.
Dialogue: 0,0:08:05.01,0:08:08.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Warna rambutnya memang agak aneh.\N- Eh, Mbak!
Dialogue: 0,0:08:08.87,0:08:12.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kades, kudengar kamu membuat\Npemandian di sini.
Dialogue: 0,0:08:12.64,0:08:16.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau boleh,\Naku ingin memandikan Urza.
Dialogue: 0,0:08:16.89,0:08:19.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja boleh.\NPakai sepuasnya.
Dialogue: 0,0:08:20.46,0:08:22.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Pemandian itu apa?\N- Kamu juga ikut, Leluhur?
Dialogue: 0,0:08:22.74,0:08:24.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Boleh, terima kasih, ya.\N- Mbak!
Dialogue: 0,0:08:24.47,0:08:26.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti juga tahu setelah di sana.
Dialogue: 0,0:08:33.00,0:08:35.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, nikmatnya tiada tara.
Dialogue: 0,0:08:35.94,0:08:39.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pemandian di Desa Pohon Besar juga bagus,\Ntapi yang ini beda kelas.
Dialogue: 0,0:08:39.85,0:08:41.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku setuju.
Dialogue: 0,0:08:41.46,0:08:43.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, iya, Kades.
Dialogue: 0,0:08:43.93,0:08:47.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soal lorong yang terhubung\Ndari dungeon itu...
Dialogue: 0,0:08:47.14,0:08:48.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:08:48.30,0:08:52.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada beberapa hal penting\Nyang cukup mengejutkan.
Dialogue: 0,0:08:52.07,0:08:53.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:08:53.30,0:08:55.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah dengar cerita rangkuman Leluhur,
Dialogue: 0,0:08:56.41,0:08:59.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}lorong bawah tanahnya kurang lebih seperti ini.
Dialogue: 0,0:09:00.38,0:09:03.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang membuat penasaran itu\Nsoal Batu Hitam.
Dialogue: 0,0:09:03.57,0:09:06.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Raja Arwah yang mengendalikan mereka\Nsudah tidak ada,
Dialogue: 0,0:09:06.43,0:09:09.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita pun tak perlu cemas lagi\Ndiserang Earth Rat.
Dialogue: 0,0:09:09.80,0:09:15.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Demi keamanan ras Raksasa,\Nlorong di samping itu sebaiknya ditutup.
Dialogue: 0,0:09:15.43,0:09:17.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, sebelum itu,
Dialogue: 0,0:09:18.04,0:09:22.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}izinkan aku menikmati onsen ini\Nsedikit lebih lama.
Dialogue: 0,0:09:22.06,0:09:23.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, silakan nikmati.
Dialogue: 0,0:09:23.79,0:09:28.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin aku memang sudah lelah.\NWajar sering lupa, aku sudah tua.
Dialogue: 0,0:09:28.65,0:09:30.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi sosokmu tak kelihatan begitu.
Dialogue: 0,0:09:33.58,0:09:35.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mulai, ya.
Dialogue: 0,0:09:39.27,0:09:40.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:09:40.82,0:09:43.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan begitu, kita harus bersihkan tubuhmu.
Dialogue: 0,0:09:43.81,0:09:46.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rambutmu ini sangat indah.
Dialogue: 0,0:09:51.57,0:09:54.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nah, selesai.
Dialogue: 0,0:09:57.48,0:09:58.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:10:04.58,0:10:08.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tahan sebentar lagi,\Njangan sampai tubuhmu kedinginan.
Dialogue: 0,0:10:09.07,0:10:11.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mbak tidak ikut berendam?
Dialogue: 0,0:10:11.29,0:10:13.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ini pelayan.
Dialogue: 0,0:10:13.14,0:10:15.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Curang!\NCuma aku yang harus tahan!
Dialogue: 0,0:10:15.85,0:10:18.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kita lomba.
Dialogue: 0,0:10:18.74,0:10:21.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa yang bisa berendam lebih lama?
Dialogue: 0,0:10:22.60,0:10:25.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mandi nanti saja juga tidak apa-apa.
Dialogue: 0,0:10:26.63,0:10:28.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi mumpung senggang...
Dialogue: 0,0:10:42.07,0:10:44.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan lari begitu.
Dialogue: 0,0:10:44.62,0:10:46.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tubuhmu harus dikeringkan dulu.
Dialogue: 0,0:10:46.47,0:10:48.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:10:48.63,0:10:50.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong diam dulu.
Dialogue: 0,0:10:50.87,0:10:53.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Geli!\N- Dia sepertinya ceria, ya.
Dialogue: 0,0:10:53.27,0:10:56.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin aku berpikir begitu\Nkarena sudah tua, ya?
Dialogue: 0,0:10:56.33,0:11:00.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau itu, aku juga sempat berpikir begitu.
Dialogue: 0,0:11:02.27,0:11:05.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sangat puas dengan onsennya!
Dialogue: 0,0:11:05.51,0:11:07.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sayangnya, aku harus pulang.
Dialogue: 0,0:11:07.91,0:11:09.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kembali ke Desa Pohon Besar?
Dialogue: 0,0:11:09.51,0:11:11.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ke Kerajaan Garlet.
Dialogue: 0,0:11:11.28,0:11:13.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ada tugas sebagai miko.
Dialogue: 0,0:11:13.11,0:11:17.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jabatan itu cukup tinggi sampai raja pun\Nmengandalkanku dan aku bakal sibuk.
Dialogue: 0,0:11:17.82,0:11:20.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, pasti repot, ya?
Dialogue: 0,0:11:20.01,0:11:23.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski sibuk begitu,\Nkamu tetap datang ke desa, ya?
Dialogue: 0,0:11:23.61,0:11:25.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku kebetulan libur.
Dialogue: 0,0:11:25.79,0:11:28.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya sudah, nanti aku mampir lagi, ya!
Dialogue: 0,0:11:28.25,0:11:31.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah bilang begitu, Kupid pun pulang.
Dialogue: 0,0:11:31.85,0:11:34.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena pembangunan\Nfasilitas onsen sudah selesai,
Dialogue: 0,0:11:34.58,0:11:39.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}kami pergi melihat Batu Hitam aneh\Nyang diceritakan Leluhur.
Dialogue: 0,0:11:39.75,0:11:42.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Batunya memang terlihat mencurigakan...
Dialogue: 0,0:11:42.93,0:11:45.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasir itu...\NBukan, benda mirip abu itu apa?
Dialogue: 0,0:11:45.91,0:11:49.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya ada dua orang yang lebih dulu\Nmasuk dan mengalahkan sisa monster.
Dialogue: 0,0:11:49.61,0:11:51.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini terlihat dihancurkan tanpa sisa.
Dialogue: 0,0:11:55.99,0:11:59.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada sesuatu seperti kabut hitam...
Dialogue: 0,0:12:02.81,0:12:04.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:05.43,0:12:07.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Suasananya terasa sangat buruk.
Dialogue: 0,0:12:08.41,0:12:10.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa Luu tak bisa melihatnya?
Dialogue: 0,0:12:20.97,0:12:22.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:22.74,0:12:25.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada sesuatu yang hitam\Nkeluar dari batu itu.
Dialogue: 0,0:12:25.10,0:12:27.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabut itu...
Dialogue: 0,0:12:29.10,0:12:30.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada monster?\NApa?
Dialogue: 0,0:12:30.55,0:12:32.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa melihatnya.
Dialogue: 0,0:12:32.68,0:12:37.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabut hitam memanjang dari bawah batu itu,\Nseperti mencari sesuatu di sekitarnya.
Dialogue: 0,0:12:38.61,0:12:43.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin masalah ini tak akan selesai\Ndengan mengubur batu ini saja?
Dialogue: 0,0:12:43.70,0:12:45.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana kalau dihancurkan saja?
Dialogue: 0,0:12:45.87,0:12:46.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:12:46.71,0:12:50.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu dulu! Saat kita menemukannya,\Naku sempat menyentuhnya,
Dialogue: 0,0:12:50.56,0:12:52.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan batunya terasa sangat keras...
Dialogue: 0,0:12:52.88,0:12:54.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalaupun dihancurkan...
Dialogue: 0,0:12:54.12,0:12:55.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tendang!
Dialogue: 0,0:12:55.16,0:12:58.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Area sekitarnya bisa runtuh.
Dialogue: 0,0:12:58.13,0:13:01.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berarti, kita tak bisa sembarangan bertindak?
Dialogue: 0,0:13:01.18,0:13:02.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:13:03.10,0:13:05.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa aku boleh ukir batu ini?
Dialogue: 0,0:13:05.02,0:13:08.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memangnya bisa?\NBahkan naga pun tak bisa menghancurkannya.
Dialogue: 0,0:13:08.52,0:13:10.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku coba dulu.
Dialogue: 0,0:13:12.54,0:13:17.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau batu ini dipakai menyegel hal jahat,\Nmungkin kekuatan Dewa bisa membantu.
Dialogue: 0,0:13:17.78,0:13:19.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku terpikirkan ingin mencoba mengukirnya.
Dialogue: 0,0:13:21.78,0:13:24.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, efeknya langsung keluar?
Dialogue: 0,0:13:26.63,0:13:28.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana kalau begini?
Dialogue: 0,0:13:30.10,0:13:32.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya ini berhasil.
Dialogue: 0,0:13:32.04,0:13:34.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Patung ini mau diapakan?
Dialogue: 0,0:13:34.47,0:13:37.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebaiknya dikubur agar tak ada\Nyang menggerakkannya.
Dialogue: 0,0:13:37.88,0:13:41.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan begitu!\NMengubur Dewa Pencipta?
Dialogue: 0,0:13:41.75,0:13:45.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sosok seperti ini hilang,\Ndunia akan sangat rugi!
Dialogue: 0,0:13:46.18,0:13:48.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:13:48.09,0:13:49.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sampai menangis begitu?
Dialogue: 0,0:13:49.56,0:13:54.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk sementara, patung dewa ini\Ntak jadi dikubur, lalu Leluhur
Dialogue: 0,0:13:54.14,0:13:56.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}akan membuat patung\Npenolak roh jahat dengan sihir.
Dialogue: 0,0:13:56.47,0:13:59.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Patungnya akan bergerak\Ndan bertarung kalau terjadi sesuatu.
Dialogue: 0,0:14:00.04,0:14:03.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami juga memasang patung yang sama\Ndi permukaan tanah.
Dialogue: 0,0:14:03.58,0:14:05.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih sudah banyak membantu.
Dialogue: 0,0:14:05.13,0:14:08.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, aku yang minta jangan dikubur.
Dialogue: 0,0:14:08.98,0:14:10.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, iya, Kades.
Dialogue: 0,0:14:10.33,0:14:14.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya, lorong bawah tanah itu\Nmasih ada lanjutannya.
Dialogue: 0,0:14:14.83,0:14:19.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau menemukan Batu Hitam lagi,\Ntolong bantu mengukirnya lagi.
Dialogue: 0,0:14:19.59,0:14:21.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, bukan masalah.
Dialogue: 0,0:14:22.65,0:14:24.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:14:24.59,0:14:26.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:14:28.58,0:14:34.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ke onsen dulu untuk persiapan,\Nlalu pergi menyelidiki lorong lanjutannya.
Dialogue: 0,0:14:34.07,0:14:37.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kades tolong jaga mereka berdua.
Dialogue: 0,0:14:37.58,0:14:39.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka sudah bekerja keras.
Dialogue: 0,0:14:39.86,0:14:41.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, ayo kita pergi.
Dialogue: 0,0:14:41.59,0:14:42.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:46.86,0:14:48.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:14:59.83,0:15:01.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:01.45,0:15:03.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kades.
Dialogue: 0,0:15:08.84,0:15:10.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:15:11.39,0:15:13.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ikut menyelidiki lorong?
Dialogue: 0,0:15:13.05,0:15:14.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami bisa berangkat kapan saja.
Dialogue: 0,0:15:14.98,0:15:16.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga harus ikut?
Dialogue: 0,0:15:16.65,0:15:18.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, tolong bantu.
Dialogue: 0,0:15:18.52,0:15:21.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, banyak yang bantu, aku tertolong.
Dialogue: 0,0:15:21.90,0:15:23.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya...
Dialogue: 0,0:15:24.23,0:15:27.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?\NApa ada masalah?
Dialogue: 0,0:15:28.09,0:15:29.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:15:29.16,0:15:32.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, kenapa?\NTak perlu minta maaf begitu.
Dialogue: 0,0:15:33.61,0:15:35.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sama sekali tak membantu.
Dialogue: 0,0:15:35.67,0:15:39.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu tidak benar, kudengar kalian\Nmengalahkan banyak monster.
Dialogue: 0,0:15:39.82,0:15:44.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah dilarang pun aku malah menyemburkan api\Ndan membuat hutan ini terbakar...
Dialogue: 0,0:15:44.22,0:15:47.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apinya sudah padam,\Ntanahnya juga bisa diolah lagi.
Dialogue: 0,0:15:47.94,0:15:52.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebaliknya, aku yang salah karena menyuruh\Nkalian menyelidiki tempat berbahaya.
Dialogue: 0,0:15:52.22,0:15:53.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:15:53.70,0:15:56.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan minta maaf begitu!
Dialogue: 0,0:15:56.44,0:15:57.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:57.69,0:16:00.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kades tak melakukan kesalahan apa pun!
Dialogue: 0,0:16:00.12,0:16:02.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Niatku ingin membantumu...
Dialogue: 0,0:16:02.84,0:16:05.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi malah membuatmu minta maaf...
Dialogue: 0,0:16:07.20,0:16:11.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamilah yang menghancurkan\Ndungeon ras Raksasa.
Dialogue: 0,0:16:11.72,0:16:13.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kamu menundukkan\Nkepalamu pada mereka...
Dialogue: 0,0:16:13.90,0:16:15.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi itu yang kamu risaukan?
Dialogue: 0,0:16:16.71,0:16:20.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menurutku mewakilkan minta maaf\Nuntuk rekan itu tugas pemimpin.
Dialogue: 0,0:16:20.71,0:16:21.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak boleh begitu!
Dialogue: 0,0:16:21.96,0:16:25.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang penting jangan gampang minta maaf!
Dialogue: 0,0:16:25.40,0:16:26.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah...
Dialogue: 0,0:16:32.23,0:16:34.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana menjelaskannya, ya?\NMaaf.
Dialogue: 0,0:16:34.89,0:16:37.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begini, sudah jadi kebiasaan.
Dialogue: 0,0:16:38.55,0:16:41.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Intinya kalian sudah banyak membantu.\NTerima kasih.
Dialogue: 0,0:16:42.15,0:16:43.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:43.23,0:16:48.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisanya tolong bantu, ya.\NYang paling risau itu Mbak Hakuren.
Dialogue: 0,0:16:48.62,0:16:52.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini aku sering dimintai tolong.
Dialogue: 0,0:16:53.14,0:16:55.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku boleh duduk di sampingmu?
Dialogue: 0,0:16:55.68,0:16:57.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terserah.
Dialogue: 0,0:17:00.12,0:17:01.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:17:01.70,0:17:04.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kali ini aku merepotkan banyak orang, ya?
Dialogue: 0,0:17:05.46,0:17:07.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu dimarahi Rusty, ya?
Dialogue: 0,0:17:07.99,0:17:10.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, dimarahi sampai habis.
Dialogue: 0,0:17:11.36,0:17:14.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian sebenarnya cemas padaku, kan?
Dialogue: 0,0:17:16.22,0:17:18.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Malah jadi rumit, ya?
Dialogue: 0,0:17:18.60,0:17:21.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi wakil semua orang
Dialogue: 0,0:17:21.06,0:17:24.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}harus peka agar tak merepotkan siapa pun.
Dialogue: 0,0:17:24.06,0:17:26.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini bukan soal merepotkan!
Dialogue: 0,0:17:26.90,0:17:31.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang penting itu tugasnya penting!\NKalau berhasil, bilang kerja bagus!
Dialogue: 0,0:17:31.03,0:17:33.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau gagal, bilang gagal!
Dialogue: 0,0:17:33.16,0:17:35.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya begitu!\NMudah, kan?
Dialogue: 0,0:17:38.46,0:17:40.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.\NKalau begitu...
Dialogue: 0,0:17:40.92,0:17:43.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kerja bagus, Hakuren.
Dialogue: 0,0:17:48.09,0:17:50.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, puji aku.
Dialogue: 0,0:17:50.87,0:17:53.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi tidak sesimpel itu, ya?
Dialogue: 0,0:17:55.78,0:17:57.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:17:58.65,0:18:01.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di sini juga ada Batu Hitam yang sama, ya.
Dialogue: 0,0:18:01.44,0:18:03.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi ini yang kedua, ya?
Dialogue: 0,0:18:03.90,0:18:07.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk ukiran batunya,\Nnanti minta bantuan Kades lagi.
Dialogue: 0,0:18:07.44,0:18:10.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anu, di sini juga ada lorong.
Dialogue: 0,0:18:11.97,0:18:13.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buntu, ya?
Dialogue: 0,0:18:13.70,0:18:16.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belum selesai digali?
Dialogue: 0,0:18:16.02,0:18:20.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, sepertinya di balik sana\Nada sesuatu, ya?
Dialogue: 0,0:18:24.46,0:18:26.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah terpasang!
Dialogue: 0,0:18:26.42,0:18:27.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ledakkan!
Dialogue: 0,0:18:29.46,0:18:31.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah sejauh mana?
Dialogue: 0,0:18:31.88,0:18:33.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin sekitar 30 langkah?
Dialogue: 0,0:18:33.99,0:18:34.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begini,
Dialogue: 0,0:18:34.97,0:18:36.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita tak akan pernah sampai.
Dialogue: 0,0:18:36.97,0:18:39.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sudah begini,\Nharus keluarkan yang paling kuat.
Dialogue: 0,0:18:39.83,0:18:41.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana kalau nanti runtuh?
Dialogue: 0,0:18:41.98,0:18:45.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pilihan kita hanya pakai sihir\Nuntuk menggalinya pelan-pelan, ya?
Dialogue: 0,0:18:45.23,0:18:48.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo, semuanya kerja sama!
Dialogue: 0,0:18:51.24,0:18:53.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, ada batu lain?
Dialogue: 0,0:18:53.24,0:18:55.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jumlahnya dua?
Dialogue: 0,0:18:55.14,0:18:58.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berarti totalnya ada tiga, ya?
Dialogue: 0,0:18:58.24,0:19:00.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk sementara, iya.
Dialogue: 0,0:19:00.01,0:19:02.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk sementara?\NMaksudmu...
Dialogue: 0,0:19:02.75,0:19:04.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Batu yang ditemukan sejauh ini
Dialogue: 0,0:19:04.73,0:19:05.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}posisinya begini?
Dialogue: 0,0:19:05.91,0:19:07.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:19:07.50,0:19:11.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berarti, kalau dihubungkan begini,\Nhasilnya seperti ini.
Dialogue: 0,0:19:11.80,0:19:16.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kemungkinan begitu, empat lokasi sisanya,\Nkita gali dari permukaan saja.
Dialogue: 0,0:19:18.51,0:19:20.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau gali lubang, aku juga bisa bantu.
Dialogue: 0,0:19:20.49,0:19:24.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan, kami tak tahu apa\Nyang akan muncul, terlalu berbahaya.
Dialogue: 0,0:19:24.52,0:19:27.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, ayo langsung menuju\Nlokasi yang diperkirakan!
Dialogue: 0,0:19:27.52,0:19:28.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:19:28.97,0:19:30.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:19:32.53,0:19:35.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Proyek besar yang belum pernah\Ndilakukan akhirnya dimulai.
Dialogue: 0,0:19:35.28,0:19:38.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lokasi tujuannya ada jauh di bawah tanah.
Dialogue: 0,0:19:40.44,0:19:43.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Batu yang dicari,\Nmungkin ada, mungkin tidak.
Dialogue: 0,0:19:44.36,0:19:47.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}dalam gelap pun terus berlanjut.\NProyek penggalian buta
Dialogue: 0,0:19:49.98,0:19:52.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tiba-tiba, kami menemukan mata air.
Dialogue: 0,0:19:53.91,0:19:56.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dungeon bawah tanah di sana juga\Ndipenuhi monster mengerikan.
Dialogue: 0,0:19:56.68,0:19:58.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo, Granmaria!
Dialogue: 0,0:19:58.26,0:20:00.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Julukan Malaikat Pembasmi-mu\Nmalah menangis!
Dialogue: 0,0:20:00.17,0:20:03.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini mustahil!\NNona Tia saja yang habisi mereka!
Dialogue: 0,0:20:04.01,0:20:05.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masih harus ke bawah lagi?
Dialogue: 0,0:20:05.22,0:20:07.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka bahkan tak tahu\Nsekarang siang atau malam.
Dialogue: 0,0:20:08.39,0:20:13.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mental para penggali, mulai menurun.
Dialogue: 0,0:20:13.40,0:20:14.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:20:14.90,0:20:16.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menu spesial hari ini,
Dialogue: 0,0:20:16.90,0:20:19.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}rebusan pemulih sihir.
Dialogue: 0,0:20:22.66,0:20:26.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian baik-baik saja?\NAku harus ikut bantu juga?
Dialogue: 0,0:20:27.88,0:20:31.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maksudku, aku tak akan memaksa ikut.
Dialogue: 0,0:20:31.42,0:20:33.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku malah mancing perkara!
Dialogue: 0,0:20:33.75,0:20:36.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk mengatasi situasi sulit\Nyang tak ada ujungnya,
Dialogue: 0,0:20:36.42,0:20:39.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}senjata rahasia pun dikerahkan.
Dialogue: 0,0:20:39.43,0:20:41.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gali di sini?
Dialogue: 0,0:20:44.36,0:20:46.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, nanti runtuh!
Dialogue: 0,0:20:46.02,0:20:47.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lubang yang sudah kami gali susah payah!
Dialogue: 0,0:20:47.93,0:20:49.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Harga yang harus dibayar sangat besar.
Dialogue: 0,0:20:50.30,0:20:52.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pilihan kita hanya lanjut terus.
Dialogue: 0,0:20:52.06,0:20:54.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan bahan peledak andalan.
Dialogue: 0,0:20:54.66,0:20:56.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita harus segel sihirnya dulu.
Dialogue: 0,0:20:57.35,0:21:00.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tekanan mulai dirasakan para penggali.
Dialogue: 0,0:21:02.54,0:21:06.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasa gelisah mereka, mulai di ambang batas.
Dialogue: 0,0:21:11.96,0:21:15.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Batu terakhir, akhirnya tersinari cahaya.
Dialogue: 0,0:21:19.45,0:21:21.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sesuai dugaan,
Dialogue: 0,0:21:21.22,0:21:23.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}jumlah batu yang ditemukan ada tujuh.
Dialogue: 0,0:21:25.98,0:21:28.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, ternyata ini jauh lebih berat, ya.
Dialogue: 0,0:21:29.51,0:21:32.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di akhir, kami merasa merinding.
Dialogue: 0,0:21:32.15,0:21:33.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Syukurlah semuanya selesai dengan selamat.
Dialogue: 0,0:21:35.48,0:21:39.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya bilang kerja bagus saja\Ntak akan cukup.
Dialogue: 0,0:21:39.85,0:21:42.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku harus pikirkan cara lain\Nuntuk menghargai usaha mereka.
Dialogue: 0,0:21:42.49,0:21:46.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian sudah bekerja sangat keras.\NDengan ini, semuanya selesai.
Dialogue: 0,0:21:46.49,0:21:49.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, mulai sekarang giliran Kades.
Dialogue: 0,0:21:49.83,0:21:50.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:21:50.75,0:21:54.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya, bukan cuma Dewa Pencipta saja.
Dialogue: 0,0:21:54.52,0:21:58.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat, aku juga ingin kamu\Nmengukir wujud dewa-dewa lain!
Dialogue: 0,0:21:58.76,0:22:01.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Satu batu sudah dipakai\Nuntuk Dewa Pencipta,
Dialogue: 0,0:22:01.26,0:22:03.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}jadi sisanya enam lagi.
Dialogue: 0,0:22:03.26,0:22:07.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dewa mana yang harus diukir, ya?\NAku bingung!
Dialogue: 0,0:22:07.01,0:22:09.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang ini?\NAtau yang ini?
Dialogue: 0,0:22:09.18,0:22:11.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Apa yang ini saja?\N- Jangan-jangan...
Dialogue: 0,0:22:11.62,0:22:15.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Yang mana, ya? Yang ini juga bagus!\N- Ini tujuannya mencari batu-batu itu?
