Dialogue: 0,0:00:11.49,0:00:17.66,tanda,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:02:20.33,0:02:24.08,tanda,,0000,0000,0000,,PARA GADIS BIROKRAT
Dialogue: 0,0:02:50.41,0:02:52.69,tanda,,0000,0000,0000,,701! 702!
Dialogue: 0,0:04:36.67,0:04:38.72,tanda,,0000,0000,0000,,ARENA
Dialogue: 0,0:04:38.72,0:04:40.42,tanda,,0000,0000,0000,,TEMPAT DUDUK PENONTON
Dialogue: 0,0:04:40.42,0:04:43.68,tanda,,0000,0000,0000,,AREA STAN MAKAN
Dialogue: 0,0:05:10.83,0:05:13.96,tanda,,0000,0000,0000,,PUTRI RAJA IBLIS, YUURI
Dialogue: 0,0:05:25.18,0:05:27.97,tanda,,0000,0000,0000,,RAJA IBLIS
Dialogue: 0,0:05:59.61,0:06:01.38,tanda,,0000,0000,0000,,KAISAR NAGA
Dialogue: 0,0:07:07.82,0:07:12.55,tanda,,0000,0000,0000,,ATURAN KATEGORI UMUM
Dialogue: 0,0:07:41.98,0:07:45.99,tanda,,0000,0000,0000,,ASUMSI DIA
Dialogue: 0,0:08:08.43,0:08:14.18,tanda,,0000,0000,0000,,MEMULIHKAN
Dialogue: 0,0:08:25.07,0:08:26.82,tanda,,0000,0000,0000,,DUEL KEDUA
Dialogue: 0,0:11:45.27,0:11:49.71,tanda,,0000,0000,0000,,KATEGORI PRAJURIT, DUEL PERTAMA
Dialogue: 0,0:11:49.71,0:11:51.98,tanda,,0000,0000,0000,,INFERNO WOLF - UNO, LAMIA - JUNEA
Dialogue: 0,0:13:06.81,0:13:08.81,tanda,,0000,0000,0000,,KILAS BALIK
Dialogue: 0,0:13:19.78,0:13:21.94,tanda,,0000,0000,0000,,DIBERI NAMA MAKURA
Dialogue: 0,0:16:59.63,0:17:03.57,tanda,,0000,0000,0000,,KATEGORI PRAJURIT, DUEL KELIMA
Dialogue: 0,0:17:03.57,0:17:04.17,tanda,,0000,0000,0000,,TIER, KUDEL
Dialogue: 0,0:17:15.43,0:17:17.43,tanda,,0000,0000,0000,,KATEGORI PRAJURIT, DUEL KEENAM\NCORONE, LUULUCY
Dialogue: 0,0:17:25.44,0:17:30.20,tanda,,0000,0000,0000,,SUDAH DIOBATI
Dialogue: 0,0:20:32.92,0:20:37.17,tanda,,0000,0000,0000,,PROTES
Dialogue: 0,0:23:45.99,0:23:50.99,tanda,,0000,0000,0000,,SELANJUTNYA:\NEPISODE 5: HARI INI JUGA DAMAI
Dialogue: 0,0:01:33.31,0:01:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya musim semi tiba.
Dialogue: 0,0:01:44.09,0:01:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, rusak!
Dialogue: 0,0:01:45.87,0:01:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:01:46.79,0:01:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, sudah lelah?
Dialogue: 0,0:01:48.90,0:01:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih kuat!
Dialogue: 0,0:01:49.99,0:01:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan!
Dialogue: 0,0:01:50.94,0:01:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya terlihat semangat.
Dialogue: 0,0:01:52.78,0:01:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu, wa, tu, wa, tu, wa!
Dialogue: 0,0:02:00.94,0:02:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menyerah?
Dialogue: 0,0:02:02.28,0:02:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai warga Kerajaan Iblis,\Nkalian malah buat malu!
Dialogue: 0,0:02:04.81,0:02:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambah sepuluh lap lagi!
Dialogue: 0,0:02:05.91,0:02:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:08.44,0:02:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua semangat, ya.
Dialogue: 0,0:02:09.83,0:02:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan sudah jadi kebiasaan\Npara bangsawan.
Dialogue: 0,0:02:12.90,0:02:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi alasan semuanya giat latihan...
Dialogue: 0,0:02:15.31,0:02:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja untuk persiapan\NTurnamen Bela Diri.
Dialogue: 0,0:02:17.76,0:02:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para gadis birokrat juga ikut?
Dialogue: 0,0:02:20.85,0:02:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka terlihat bukan tipe petarung.
Dialogue: 0,0:02:24.08,0:02:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Kerajaan Iblis, agar bisa memimpin,
Dialogue: 0,0:02:26.61,0:02:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemampuan bertarung juga diperlukan.
Dialogue: 0,0:02:29.18,0:02:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:02:30.38,0:02:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, jangan mangkir!
Dialogue: 0,0:02:31.93,0:02:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ketahuan.
Dialogue: 0,0:02:33.34,0:02:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, permisi.
Dialogue: 0,0:02:40.68,0:02:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo duel!
Dialogue: 0,0:02:42.08,0:02:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah.
Dialogue: 0,0:02:43.38,0:02:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:43.94,0:02:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan kami dengan serius!
Dialogue: 0,0:02:46.90,0:02:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya terlihat menantikan\NTurnamen Bela Diri, ya.
Dialogue: 0,0:02:53.33,0:02:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pulang sebentar untuk latihan.
Dialogue: 0,0:02:55.20,0:02:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan?
Dialogue: 0,0:02:56.56,0:03:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak datang ke sini, aku belum pernah\Nserius dan merasa mulai tumpul.
Dialogue: 0,0:03:01.27,0:03:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah sekuat itu?
Dialogue: 0,0:03:02.45,0:03:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu masih jauh.
Dialogue: 0,0:03:06.31,0:03:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kalau mengeluarkan kekuatan penuh...
Dialogue: 0,0:03:08.32,0:03:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembur!
Dialogue: 0,0:03:10.46,0:03:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini!
Dialogue: 0,0:03:12.81,0:03:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turnamen Bela Diri butuh wasit!
Dialogue: 0,0:03:15.25,0:03:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak paham soal bela diri.
Dialogue: 0,0:03:17.59,0:03:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak seru.
Dialogue: 0,0:03:18.63,0:03:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wasit itu harus kuat, kan?
Dialogue: 0,0:03:21.75,0:03:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus jadi contoh bagi semuanya\Ndan paling kuat!
Dialogue: 0,0:03:24.87,0:03:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ada benarnya.
Dialogue: 0,0:03:27.35,0:03:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades.
Dialogue: 0,0:03:28.86,0:03:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pulang sebentar untuk latihan.
Dialogue: 0,0:03:30.86,0:03:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gao!
Dialogue: 0,0:03:32.26,0:03:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembur!
Dialogue: 0,0:03:34.31,0:03:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh dua wasit!
Dialogue: 0,0:03:36.61,0:03:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya pilih ahli?
Dialogue: 0,0:03:38.87,0:03:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, cocok seperti kalian berdua yang ahli!
Dialogue: 0,0:03:42.89,0:03:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin.
Dialogue: 0,0:03:43.70,0:03:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada benarnya.
Dialogue: 0,0:03:44.77,0:03:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, tolong, ya!
Dialogue: 0,0:03:46.21,0:03:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku juga mau bertarung.
Dialogue: 0,0:03:47.68,0:03:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:03:49.20,0:03:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil menjadi wasit, mereka berdua\Njuga boleh latihan tanding.
Dialogue: 0,0:03:54.80,0:03:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?\NKetawamu seram.
Dialogue: 0,0:03:57.01,0:04:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama akhirnya\Naku bisa menghajarmu, Tier.
Dialogue: 0,0:04:00.94,0:04:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Luulucy, memangnya\Nkamu pernah memukulku?
Dialogue: 0,0:04:06.02,0:04:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah, ya?
Dialogue: 0,0:04:09.19,0:04:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Benar juga, mereka berdua itu rival.\N- Tadi kamu sudah makan, kan?
Dialogue: 0,0:04:11.21,0:04:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Benar juga, mereka berdua itu rival.\N- Sudah, ya?
Dialogue: 0,0:04:12.77,0:04:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cup, cup.\NKedengarannya bahaya, ya.
Dialogue: 0,0:04:16.45,0:04:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak ikut, Flora?
Dialogue: 0,0:04:18.41,0:04:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi tim medis,\Nmenyembuhkan kalau ada yang terluka.
Dialogue: 0,0:04:22.02,0:04:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi kelihatannya kamu ingin\N- Siap untuk ledakan besar!
Dialogue: 0,0:04:23.84,0:04:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- meledakkan sesuatu.\N- Siap untuk ledakan besar
Dialogue: 0,0:04:25.78,0:04:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan peledak tidak digunakan\Npada manusia.
Dialogue: 0,0:04:28.48,0:04:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:04:30.63,0:04:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian, kami buat tempat\Nyang bisa dinikmati semua warga,
Dialogue: 0,0:04:33.85,0:04:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekaligus tempat mengundang para tamu.
Dialogue: 0,0:04:37.27,0:04:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita siapkan arena pertandingan,
Dialogue: 0,0:04:38.72,0:04:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat duduk penonton,
Dialogue: 0,0:04:40.42,0:04:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu stan dan area makan.
Dialogue: 0,0:04:43.68,0:04:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menonton sambil makan?
Dialogue: 0,0:04:46.68,0:04:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan mewah.
Dialogue: 0,0:04:48.43,0:04:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus memikirkan menu\Nyang nuansanya festival.
Dialogue: 0,0:04:52.59,0:04:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segar.
Dialogue: 0,0:04:55.45,0:04:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:04:56.94,0:04:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hari Turnamen Bela Diri.
Dialogue: 0,0:05:05.08,0:05:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke sana!
Dialogue: 0,0:05:06.25,0:05:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:05:09.79,0:05:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengundang kami hari ini.
Dialogue: 0,0:05:13.96,0:05:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, lama tak jumpa.
Dialogue: 0,0:05:15.89,0:05:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau ayahku.
Dialogue: 0,0:05:18.69,0:05:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Gullguld.
Dialogue: 0,0:05:20.72,0:05:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis dari Kerajaan Iblis Gullguld.
Dialogue: 0,0:05:23.72,0:05:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis?
Dialogue: 0,0:05:25.18,0:05:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini? Aku tak tahu etiket.
Dialogue: 0,0:05:28.39,0:05:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, tak perlu terlalu kaku.
Dialogue: 0,0:05:31.03,0:05:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:05:32.60,0:05:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku ayahnya Yuuri.\NSalam kenal.
Dialogue: 0,0:05:35.63,0:05:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, salam kenal juga.
Dialogue: 0,0:05:37.54,0:05:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa para putriku merepotkanmu?
Dialogue: 0,0:05:40.11,0:05:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sama sekali.
Dialogue: 0,0:05:41.83,0:05:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata orangnya ramah,\Ntapi dia petinggi Kerajaan Iblis.
Dialogue: 0,0:05:45.65,0:05:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti pasti hebat.
Dialogue: 0,0:05:48.37,0:05:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:05:50.12,0:05:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu kadesnya?
Dialogue: 0,0:05:52.02,0:05:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, anu...
Dialogue: 0,0:05:54.13,0:05:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau ayahku.
Dialogue: 0,0:05:55.93,0:05:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau pamanku.
Dialogue: 0,0:05:57.63,0:05:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:05:59.61,0:06:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaisar Naga?
Dialogue: 0,0:06:01.38,0:06:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma gelar.
Dialogue: 0,0:06:04.00,0:06:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil aku Doss.
Dialogue: 0,0:06:05.39,0:06:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Tuan Doss.
Dialogue: 0,0:06:06.63,0:06:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Beliau dari ras naga legendaris?\N- Tak perlu pakai tuan.
Dialogue: 0,0:06:09.97,0:06:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, jangan dibahas lagi.
Dialogue: 0,0:06:11.98,0:06:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia siapa?
Dialogue: 0,0:06:12.86,0:06:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, beliau Raja Iblis.
Dialogue: 0,0:06:15.15,0:06:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:06:16.35,0:06:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, beliau ayahnya Yuuri.
Dialogue: 0,0:06:19.68,0:06:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu pemimpin Kerajaan Iblis.
Dialogue: 0,0:06:22.09,0:06:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:23.74,0:06:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:26.70,0:06:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadirin, terima kasih sudah menunggu!
Dialogue: 0,0:06:30.04,0:06:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, Turnamen Bela Diri\NDesa Pohon Besar pertama akan dimulai!
Dialogue: 0,0:06:38.43,0:06:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak sabar, ya.
Dialogue: 0,0:06:39.77,0:06:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:06:41.55,0:06:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramai, ya.
Dialogue: 0,0:06:43.17,0:06:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini kita punya acara\Nsebesar ini sejak desa kita ada.
Dialogue: 0,0:06:47.93,0:06:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya tempat ini\Ndibuat untuk kursi tamu...
Dialogue: 0,0:06:51.18,0:06:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa,\Nduduk percaya diri saja di situ.
Dialogue: 0,0:06:54.70,0:06:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya,\Ntolong hati-hati agar tidak terluka.
Dialogue: 0,0:06:59.70,0:07:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tengah sorakan...
Dialogue: 0,0:07:01.79,0:07:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku jadi grogi.\N- Dimulai dari kategori umum
Dialogue: 0,0:07:03.51,0:07:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo berjuang!\N- yang bisa diikuti siapa pun.
Dialogue: 0,0:07:05.23,0:07:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aturannya simpel,
Dialogue: 0,0:07:06.77,0:07:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}duel satu lawan satu berdasarkan undian.
Dialogue: 0,0:07:09.39,0:07:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan dianggap kalah kalau keluar arena
Dialogue: 0,0:07:12.55,0:07:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau ikat kepalanya lepas.
Dialogue: 0,0:07:14.90,0:07:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikatannya diberi sihir pelindung.
Dialogue: 0,0:07:16.96,0:07:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terkena serangan,\Ncuma ikat kepalanya saja yang lepas.
Dialogue: 0,0:07:21.02,0:07:24.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel pertama, Rosalind dari keluarga birokrat
Dialogue: 0,0:07:24.17,0:07:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melawan Mamu dari ras Manusia Binatang.
Dialogue: 0,0:07:26.25,0:07:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:07:27.34,0:07:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap!
Dialogue: 0,0:07:28.84,0:07:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:07:40.07,0:07:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel pertama sudah serius.
Dialogue: 0,0:07:41.98,0:07:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira duelnya saling pukul pakai tongkat.
Dialogue: 0,0:08:01.37,0:08:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenangnya,
Dialogue: 0,0:08:02.42,0:08:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosalind!
Dialogue: 0,0:08:06.35,0:08:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong pulihkan aku.
Dialogue: 0,0:08:08.43,0:08:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, lukanya lumayan parah, ya.
Dialogue: 0,0:08:11.03,0:08:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, maaf!
Dialogue: 0,0:08:13.09,0:08:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:08:14.64,0:08:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tim penyembuh untuk para peserta!
Dialogue: 0,0:08:17.06,0:08:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau luka patah, masih bisa dipulihkan.\NTapi kalau putus, susah disambung lagi.
Dialogue: 0,0:08:21.29,0:08:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan sampai terluka parah!
Dialogue: 0,0:08:23.65,0:08:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengumuman macam apa itu?\NSeram.
Dialogue: 0,0:08:37.46,0:08:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenangnya Donovan.
Dialogue: 0,0:08:39.10,0:08:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat payah.
Dialogue: 0,0:08:40.86,0:08:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kamu ini? Kamu pasti hebat\Nkalau latihan 30 tahun lagi.
Dialogue: 0,0:08:44.96,0:08:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan seperti itu\Ntak akan mempan ke Elder Dwarf.
Dialogue: 0,0:08:48.74,0:08:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ke sini saja\Nmelewati hutan penuh monster.
Dialogue: 0,0:08:51.99,0:08:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:08:52.72,0:08:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba wajah baru juga bertambah.
Dialogue: 0,0:08:55.13,0:08:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar di sini ada sake.
Dialogue: 0,0:08:56.62,0:08:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu lama ke sini.
Dialogue: 0,0:08:58.35,0:09:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gruwald Raby Coll!
Dialogue: 0,0:09:00.69,0:09:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap maju!
Dialogue: 0,0:09:02.10,0:09:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tunggu, jangan mendekat!
Dialogue: 0,0:09:05.36,0:09:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:09:06.48,0:09:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenangnya, Loage.
Dialogue: 0,0:09:08.38,0:09:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NBisa tembus?
Dialogue: 0,0:09:18.77,0:09:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menang!
Dialogue: 0,0:09:19.67,0:09:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puas.
Dialogue: 0,0:09:21.01,0:09:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga duel yang santai.
Dialogue: 0,0:09:26.44,0:09:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel terakhir kategori umum,\NFrau melawan Sena.
Dialogue: 0,0:09:30.26,0:09:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:09:31.18,0:09:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frau pakai pedang dan sihir.
Dialogue: 0,0:09:34.76,0:09:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan Sena,
Dialogue: 0,0:09:37.83,0:09:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma tangan kosong?
Dialogue: 0,0:09:41.27,0:09:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frau, kamu keren!
Dialogue: 0,0:09:43.99,0:09:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mendukungmu!
Dialogue: 0,0:09:45.59,0:09:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu idolaku!
Dialogue: 0,0:09:46.77,0:09:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah!
Dialogue: 0,0:09:48.35,0:09:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:09:51.12,0:09:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angin!
Dialogue: 0,0:10:12.30,0:10:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang!
Dialogue: 0,0:10:13.04,0:10:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:10:15.26,0:10:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya kelihatan beda dari biasanya.
Dialogue: 0,0:10:17.81,0:10:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka terlihat lebih agresif.
Dialogue: 0,0:10:20.65,0:10:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Sena tipe yang suka melempar, ya.
Dialogue: 0,0:10:23.06,0:10:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frau!
Dialogue: 0,0:10:24.70,0:10:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Serang! Jatuhkan dia!\N- Kamu keren!
Dialogue: 0,0:10:31.03,0:10:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:10:32.65,0:10:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilempar balik?
Dialogue: 0,0:10:38.57,0:10:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:10:40.81,0:10:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena keduanya jatuh, hasilnya seri.
Dialogue: 0,0:10:45.60,0:10:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel yang bagus.
Dialogue: 0,0:10:47.54,0:10:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, kategori umum selesai!
Dialogue: 0,0:10:50.96,0:10:54.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus!\NDuel kalian semua hebat.
Dialogue: 0,0:10:54.93,0:10:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pemenang diberi medali penghargaan.
Dialogue: 0,0:10:58.56,0:10:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi,
Dialogue: 0,0:10:59.68,0:11:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- mari beri apresiasi untuk para peserta.\N- Kalian hebat.
Dialogue: 0,0:11:01.78,0:11:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris menang.
Dialogue: 0,0:11:02.53,0:11:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:11:04.10,0:11:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:11:04.69,0:11:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini masih kategori umum.
Dialogue: 0,0:11:09.09,0:11:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira kategori prajurit akan seperti apa?
Dialogue: 0,0:11:11.94,0:11:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, nama Kades tak ada di daftar peserta.
Dialogue: 0,0:11:17.04,0:11:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, dia pasti akan muncul di akhir.
Dialogue: 0,0:11:20.22,0:11:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku hampir saja membocorkannya.
Dialogue: 0,0:11:23.45,0:11:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku bukan karakter rahasia.
Dialogue: 0,0:11:28.59,0:11:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kita mulai kategori prajurit!
Dialogue: 0,0:11:33.07,0:11:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kategori prajurit lebih simpel.
Dialogue: 0,0:11:35.55,0:11:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenangnya ditentukan kalau ada\Nyang tumbang atau menyerah.
Dialogue: 0,0:11:38.19,0:11:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada batasan senjata.
Dialogue: 0,0:11:39.97,0:11:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya yang benar-benar kuat\Nyang boleh ikut.
Dialogue: 0,0:11:44.31,0:11:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel turnamen pertama:
Dialogue: 0,0:11:47.42,0:11:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uno dari ras Inferno Wolf
Dialogue: 0,0:11:49.71,0:11:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melawan Junea dari ras Lamia.
Dialogue: 0,0:11:54.49,0:11:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas,\Nduel satu lawan satu masih aman.
Dialogue: 0,0:11:58.74,0:12:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kelihatannya berat sekali.
Dialogue: 0,0:12:00.99,0:12:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu sarang mereka pernah diserang\Nsampai nyaris musnah.
Dialogue: 0,0:12:05.03,0:12:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku jadi tidak enak sama mereka.
Dialogue: 0,0:12:09.13,0:12:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel pertama dimulai!
Dialogue: 0,0:12:22.43,0:12:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengandalkan tubuh gesitnya.
Dialogue: 0,0:12:26.86,0:12:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan selama ini akhirnya berbuah hasil!\NKamu menyerah, kan?
Dialogue: 0,0:12:42.28,0:12:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:12:43.28,0:12:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyerah.
Dialogue: 0,0:12:47.04,0:12:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata mereka punya kemampuan seperti itu.
Dialogue: 0,0:12:49.06,0:12:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi rumor satu Inferno Wolf\Nbisa menghancurkan satu kota
Dialogue: 0,0:12:53.04,0:12:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu benar, ya.
Dialogue: 0,0:12:54.46,0:12:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uno menang!
Dialogue: 0,0:12:58.14,0:13:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semangat!\N- Duel selanjutnya, Daga dari ras Lizardman
Dialogue: 0,0:13:03.52,0:13:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melawan Makura, salah satu anak Zabuton.
Dialogue: 0,0:13:07.57,0:13:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau partisipasi?
Dialogue: 0,0:13:09.46,0:13:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:13:10.96,0:13:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kurang cocok\Nkalau dipanggil anak Zabuton.
Dialogue: 0,0:13:13.91,0:13:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya beri dia nama...
Dialogue: 0,0:13:15.82,0:13:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu lebih bulat dari Zabuton,\Nbagaimana kalau Makura?
Dialogue: 0,0:13:19.78,0:13:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sepertinya kamu setuju.
Dialogue: 0,0:13:28.08,0:13:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma menghindar.\NDaga lebih unggul, ya.
Dialogue: 0,0:13:31.60,0:13:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:13:37.59,0:13:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa kabur lagi.
Dialogue: 0,0:13:42.07,0:13:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah.
Dialogue: 0,0:13:43.47,0:13:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenangnya Makura!
Dialogue: 0,0:13:46.70,0:13:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat disayangkan.
Dialogue: 0,0:13:50.27,0:13:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu kuat?
Dialogue: 0,0:13:51.48,0:13:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:13:52.19,0:13:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bisa!
Dialogue: 0,0:13:53.46,0:13:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, duel ketiga!
Dialogue: 0,0:13:56.02,0:13:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaa dari ras Elf Gunung
Dialogue: 0,0:13:57.92,0:14:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melawan Gulf dari Desa Howling!
Dialogue: 0,0:14:02.85,0:14:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap!
Dialogue: 0,0:14:04.62,0:14:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:14:06.63,0:14:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai.
Dialogue: 0,0:14:16.66,0:14:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gulf terlihat tenang.
Dialogue: 0,0:14:19.04,0:14:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karismanya terasa.
Dialogue: 0,0:14:20.88,0:14:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia prajurit terkuat di Desa Howling!
Dialogue: 0,0:14:24.88,0:14:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara lawannya, senjata beratnya\Nmungkin jadi kelemahannya.
Dialogue: 0,0:14:28.81,0:14:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dia bertemu lawan yang tak cocok.
Dialogue: 0,0:14:31.28,0:14:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi incaran dia cuma satu.
Dialogue: 0,0:14:34.54,0:14:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengumpulkan sihir\Ndan melepaskan serangan pemungkas!
Dialogue: 0,0:14:46.71,0:14:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:14:48.72,0:14:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris saja.
Dialogue: 0,0:14:50.49,0:14:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sudutnya kurang pas!
Dialogue: 0,0:14:53.31,0:14:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaa menyerah, duel ketiga dimenangkan Gulf.
Dialogue: 0,0:14:57.83,0:14:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, duel keempat...
Dialogue: 0,0:14:59.53,0:15:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya,
Dialogue: 0,0:15:01.55,0:15:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perwakilan High Elf, Ria
Dialogue: 0,0:15:05.22,0:15:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melawan Granmaria\Ndari ras Malaikat Pembasmi!
Dialogue: 0,0:15:09.20,0:15:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai dari sini ada aturan khusus,
Dialogue: 0,0:15:11.41,0:15:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jatuh dari arena tidak dianggap kalah!
Dialogue: 0,0:15:13.91,0:15:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa terbang terlalu diuntungkan.
Dialogue: 0,0:15:16.96,0:15:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan senjata yang biasa dipakai, ya.
Dialogue: 0,0:15:19.43,0:15:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:20.65,0:15:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai tombak,\Naku tak bisa menahan diri.
Dialogue: 0,0:15:23.90,0:15:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan\Nkalau kamu tak menahan diri.
Dialogue: 0,0:15:27.62,0:15:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap!
Dialogue: 0,0:15:29.03,0:15:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:15:43.45,0:15:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembunyimu hebat, ya.
Dialogue: 0,0:15:45.29,0:15:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:15:49.53,0:15:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dari atas, kamu mudah dilihat.
Dialogue: 0,0:16:07.57,0:16:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, mau menyerah?
Dialogue: 0,0:16:10.82,0:16:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:16:12.43,0:16:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tubuhku kecil, kamu pikir\Nbisa mengalahkanku lewat gulat?
Dialogue: 0,0:16:16.33,0:16:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beban seperti ini, masih belum\Nsetengahnya dari tombakku!
Dialogue: 0,0:16:24.02,0:16:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri!
Dialogue: 0,0:16:26.84,0:16:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat!
Dialogue: 0,0:16:38.29,0:16:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi siapa yang memaksakan diri?
Dialogue: 0,0:16:42.71,0:16:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bisa berdiri,\Naku yang menang...
Dialogue: 0,0:16:49.38,0:16:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak bisa...
Dialogue: 0,0:16:53.82,0:16:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seri?
Dialogue: 0,0:16:55.47,0:16:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duelnya sengit, ya.
Dialogue: 0,0:16:58.25,0:16:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:16:59.63,0:17:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}duel sesungguhnya,
Dialogue: 0,0:17:01.82,0:17:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baru dimulai sekarang.
Dialogue: 0,0:17:04.17,0:17:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu menahan diri.
Dialogue: 0,0:17:06.14,0:17:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya...
Dialogue: 0,0:17:09.06,0:17:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:17:12.05,0:17:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tier menang.
Dialogue: 0,0:17:12.99,0:17:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!\NMustahil!
Dialogue: 0,0:17:17.43,0:17:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo serang aku.
Dialogue: 0,0:17:19.18,0:17:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:17:20.44,0:17:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai...
Dialogue: 0,0:17:22.89,0:17:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenangnya, Luu!
Dialogue: 0,0:17:25.44,0:17:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kupikir akan mati.
Dialogue: 0,0:17:27.58,0:17:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:28.77,0:17:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya!
Dialogue: 0,0:17:30.20,0:17:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus merekam semua aksi mbak!
Dialogue: 0,0:17:33.66,0:17:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin tim penyembuh malah nonton di sini?
Dialogue: 0,0:17:36.15,0:17:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:17:36.95,0:17:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak tidak akan terluka.
Dialogue: 0,0:17:39.37,0:17:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:17:44.96,0:17:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:17:53.90,0:17:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari mulai.
Dialogue: 0,0:17:57.44,0:17:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:59.02,0:18:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap!
Dialogue: 0,0:18:01.86,0:18:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:18:07.43,0:18:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:09.60,0:18:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu? Aku sama sekali\Ntak tahu apa yang terjadi!
Dialogue: 0,0:18:13.36,0:18:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:18:15.10,0:18:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalian semua bisa melihatnya?\N- Mbak!
Dialogue: 0,0:18:16.96,0:18:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:18:17.92,0:18:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau begitu...\N- Mbak!
Dialogue: 0,0:18:25.33,0:18:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan!
Dialogue: 0,0:18:28.38,0:18:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tombak ini memang\Nmeningkatkan kemampuan fisik!
Dialogue: 0,0:18:31.93,0:18:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bisa lihat pergerakan mereka.
Dialogue: 0,0:18:41.73,0:18:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat sengit!
Dialogue: 0,0:18:42.95,0:18:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang di situ!\NLedakkan!
Dialogue: 0,0:18:44.64,0:18:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah!
Dialogue: 0,0:18:52.90,0:18:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:56.29,0:18:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bilang, kan?\NSudah lama tidak menghajarmu.
Dialogue: 0,0:19:00.14,0:19:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kuladeni!
Dialogue: 0,0:19:06.17,0:19:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:19:07.18,0:19:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sangat niat memukulnya!
Dialogue: 0,0:19:10.31,0:19:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kelihatan menikmatinya!
Dialogue: 0,0:19:12.57,0:19:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti di komik remaja
Dialogue: 0,0:19:13.89,0:19:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- yang bisa menumbuhkan persahabatan.\N- Kamu boleh juga.
Dialogue: 0,0:19:14.81,0:19:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- yang bisa menumbuhkan persahabatan.\N- Kamu juga.
Dialogue: 0,0:19:16.54,0:19:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berani, ya!
Dialogue: 0,0:19:17.93,0:19:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Yah, makin akrab sampai saling pukul.
Dialogue: 0,0:19:20.31,0:19:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sekali juga cukup, kan?\N- Yah, makin akrab sampai saling pukul.
Dialogue: 0,0:19:21.66,0:19:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak ada aturan seperti itu!\N- Begitulah...
Dialogue: 0,0:19:30.61,0:19:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:19:31.69,0:19:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan!
Dialogue: 0,0:19:33.94,0:19:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tier menang.\N- Sebal!
Dialogue: 0,0:19:35.95,0:19:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:19:37.26,0:19:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duelnya selesai...
Dialogue: 0,0:19:39.01,0:19:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang!
Dialogue: 0,0:19:40.45,0:19:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tier curang!
Dialogue: 0,0:19:42.48,0:19:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit, sakit!
Dialogue: 0,0:19:44.14,0:19:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Curang, malah mengadu!\N- Sakit!
Dialogue: 0,0:19:46.88,0:19:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah duel hebat dan mengalahkan Luu,
Dialogue: 0,0:19:51.22,0:19:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lawan Tier di final...
Dialogue: 0,0:19:57.01,0:19:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:58.76,0:20:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawannya tidak cocok!
Dialogue: 0,0:20:01.91,0:20:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pemandangan nostalgia.
Dialogue: 0,0:20:05.78,0:20:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makura, selamat jadi juara kategori prajurit.
Dialogue: 0,0:20:10.02,0:20:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku buat mahkota ini sebagai hadiah, tapi...
Dialogue: 0,0:20:13.03,0:20:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipasang di situ, ya?
Dialogue: 0,0:20:17.30,0:20:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tak ada peluang melawannya.
Dialogue: 0,0:20:21.37,0:20:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, kerja bagus, semuanya!
Dialogue: 0,0:20:24.35,0:20:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa kukatakan cuma satu,
Dialogue: 0,0:20:26.49,0:20:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua duel kalian sangat hebat!
Dialogue: 0,0:20:29.04,0:20:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat yang cukup hari ini...
Dialogue: 0,0:20:31.11,0:20:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:20:32.92,0:20:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Giliran kami kapan?
Dialogue: 0,0:20:34.49,0:20:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau cepat duel!
Dialogue: 0,0:20:37.17,0:20:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:20:38.89,0:20:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel terakhir yang ditunggu-tunggu!
Dialogue: 0,0:20:40.58,0:20:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel peragaan akan dilakukan\Noleh dua orang selama ini menjadi wasit!
Dialogue: 0,0:20:47.78,0:20:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap!
Dialogue: 0,0:20:49.31,0:20:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju sini!
Dialogue: 0,0:21:06.14,0:21:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya ledakannya sampai terlihat\Ndari Kerajaan Iblis.
Dialogue: 0,0:21:13.86,0:21:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapaknya hancur,
Dialogue: 0,0:21:16.17,0:21:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi untung sakenya selamat.
Dialogue: 0,0:21:18.51,0:21:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:19.84,0:21:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, Rusty terlalu semangat.
Dialogue: 0,0:21:22.64,0:21:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Hakuren juga.
Dialogue: 0,0:21:24.35,0:21:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya tahan diri kalian!
Dialogue: 0,0:21:25.92,0:21:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah!
Dialogue: 0,0:21:26.64,0:21:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, kok!
Dialogue: 0,0:21:27.35,0:21:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, lebih tahan lagi!
Dialogue: 0,0:21:28.67,0:21:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, aku yang mengizinkan mereka.
Dialogue: 0,0:21:30.85,0:21:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, pemenangnya Hakuren.
Dialogue: 0,0:21:33.29,0:21:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih kurang.
Dialogue: 0,0:21:36.14,0:21:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekilas aku lihat pukulan Rusty meledak,
Dialogue: 0,0:21:39.70,0:21:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi posisi kakinya mungkin di titik buta.
Dialogue: 0,0:21:42.61,0:21:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama tidak merasakan duel panas!
Dialogue: 0,0:21:45.85,0:21:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba melawanku, Tuan Raja Iblis?
Dialogue: 0,0:21:50.14,0:21:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda.
Dialogue: 0,0:21:51.12,0:21:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada sedikit masalah,
Dialogue: 0,0:21:53.36,0:21:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa menyelesaikannya dengan baik.
Dialogue: 0,0:21:55.65,0:21:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:57.01,0:21:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini disebut lancar, apa boleh buat.
Dialogue: 0,0:22:00.09,0:22:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya terlihat menikmatinya,\Nmungkin festivalnya berhasil.
Dialogue: 0,0:22:04.17,0:22:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nsambil evaluasi ketahanan tempat,
Dialogue: 0,0:22:07.82,0:22:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kapan kita adakan lagi?
Dialogue: 0,0:22:10.08,0:22:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:12.18,0:22:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara, tidak dulu...
