Dialogue: 0,0:00:11.45,0:00:17.50,sign,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:04:41.64,0:04:43.72,sign,,0000,0000,0000,,POSE MENYESAL
Dialogue: 0,0:04:51.48,0:04:54.73,sign,,0000,0000,0000,,POSE MEMINTA MAAF
Dialogue: 0,0:05:51.13,0:05:53.56,sign,,0000,0000,0000,,OPERASI PEREBUTAN KASTEL MATAHARI
Dialogue: 0,0:05:53.56,0:05:56.49,sign,,0000,0000,0000,,TIM PERTAMA
Dialogue: 0,0:05:56.49,0:05:59.80,sign,,0000,0000,0000,,TIM KEDUA
Dialogue: 0,0:06:13.06,0:06:16.06,sign,,0000,0000,0000,,MARKAS KOMANDO\NOPERASI PEREBUTAN KASTEL MATAHARI
Dialogue: 0,0:08:07.80,0:08:10.18,sign,,0000,0000,0000,,KENTANG DUNGEON
Dialogue: 0,0:09:10.49,0:09:11.53,sign,,0000,0000,0000,,MARKAS KOMANDO
Dialogue: 0,0:09:11.53,0:09:13.74,sign,,0000,0000,0000,,OPERASI PEREBUTAN KASTEL MATAHARI
Dialogue: 0,0:14:46.91,0:14:48.99,sign,,0000,0000,0000,,SERAM, BAHAYA, KUAT
Dialogue: 0,0:14:50.04,0:14:52.04,sign,,0000,0000,0000,,TIDAK SERAM, AMAN, LEMAH
Dialogue: 0,0:15:21.37,0:15:23.57,sign,,0000,0000,0000,,PENDETA NAGA
Dialogue: 0,0:17:41.58,0:17:45.46,sign,,0000,0000,0000,,KASTEL, DISTRIK KOTA
Dialogue: 0,0:23:45.95,0:23:50.95,sign,,0000,0000,0000,,SELANJUTNYA:\NEPISODE 12: DESA KITA SEMUA
Dialogue: 0,0:01:37.10,0:01:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah datang tiba-tiba.
Dialogue: 0,0:01:40.52,0:01:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sadar, tapi seringnya lupa.
Dialogue: 0,0:01:44.81,0:01:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru ingat lagi saat dihadapkan masalah.
Dialogue: 0,0:01:50.13,0:01:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya ada sesuatu yang melayang,
Dialogue: 0,0:01:53.57,0:01:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kurang jelas karena terlalu jauh.
Dialogue: 0,0:01:56.80,0:01:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:01:58.65,0:01:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:02:02.15,0:02:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu... batu besar?\NDi atasnya seperti ada sesuatu...
Dialogue: 0,0:02:07.92,0:02:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel?
Dialogue: 0,0:02:09.07,0:02:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kastel batu terbang itu\Nterbang di atas hutan...
Dialogue: 0,0:02:14.39,0:02:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin di sini,\Nlalu pagi ini di sekitar sini.
Dialogue: 0,0:02:17.95,0:02:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang mendekat ke sini?
Dialogue: 0,0:02:19.67,0:02:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang,
Dialogue: 0,0:02:21.20,0:02:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami menjaga jarak sambil terus memantau...
Dialogue: 0,0:02:24.46,0:02:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastelnya terlihat cukup tua.
Dialogue: 0,0:02:26.83,0:02:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak bisa menentukan apa itu reruntuhan\Natau ada yang menaikinya.
Dialogue: 0,0:02:31.82,0:02:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Tia, jangan-jangan itu kastel dulu...
Dialogue: 0,0:02:35.13,0:02:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum bisa kita pastikan.
Dialogue: 0,0:02:37.47,0:02:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin selidiki lebih lanjut,\Ntapi mendekat sembarangan juga berbahaya.
Dialogue: 0,0:02:42.51,0:02:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:02:43.73,0:02:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel terbang itu hal yang menarik\Ndan aku ingin jalan-jalan ke sana!
Dialogue: 0,0:02:49.16,0:02:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berpikir tenang begitu\Nkalau tak ada bahaya di sana.
Dialogue: 0,0:02:57.49,0:03:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai para manusia bodoh, namaku Kuzden!
Dialogue: 0,0:03:01.51,0:03:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel terbang ini sudah kami kuasai!
Dialogue: 0,0:03:04.75,0:03:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harapan kalian sudah hancur!
Dialogue: 0,0:03:07.71,0:03:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia musuh?
Dialogue: 0,0:03:09.16,0:03:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya iya.
Dialogue: 0,0:03:11.85,0:03:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan musuh,
Dialogue: 0,0:03:13.47,0:03:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah kaget.
Dialogue: 0,0:03:14.88,0:03:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nsebelum dia makin dekat ke desa...
Dialogue: 0,0:03:18.17,0:03:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arahnya kurang lebih sebegini, ya?
Dialogue: 0,0:03:19.91,0:03:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:03:23.14,0:03:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:27.77,0:03:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:03:28.85,0:03:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena bagian bawah batunya!
Dialogue: 0,0:03:30.52,0:03:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kurang naik sedikit, ya.
Dialogue: 0,0:03:33.40,0:03:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!\NAmpun!
Dialogue: 0,0:03:36.45,0:03:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:39.05,0:03:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut pria dari ras Iblis\Nbernama Kuzden ini...
Dialogue: 0,0:03:41.87,0:03:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini dan begitu.
Dialogue: 0,0:03:43.87,0:03:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel di atas batu terbang itu\Nnamanya Kastel Matahari.
Dialogue: 0,0:03:48.43,0:03:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar seribu tahun lalu,\Nsaat manusia perang dengan ras Iblis,
Dialogue: 0,0:03:53.78,0:03:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kastel itu dipakai ras Dewa\Nyang memihak manusia.
Dialogue: 0,0:03:58.80,0:04:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah perang panjang,
Dialogue: 0,0:04:01.04,0:04:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ras Iblis mengusir ras Dewa\Ndan menguasai kastel itu.
Dialogue: 0,0:04:04.96,0:04:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu mereka tinggal di sana...\NLalu kami keturunannya.
Dialogue: 0,0:04:09.36,0:04:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesampingkan dulu cerita itu,\Nkenapa tiba-tiba datang ke desa ini?
Dialogue: 0,0:04:13.57,0:04:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:04:14.73,0:04:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:15.24,0:04:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel itu bergerak otomatis.
Dialogue: 0,0:04:17.32,0:04:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pengumuman bilang:\NSesuai kontrak kuno, kastel akan bergerak
Dialogue: 0,0:04:21.82,0:04:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memihak manusia.
Dialogue: 0,0:04:23.49,0:04:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, sekarang Kastel Matahari\Nakan bergerak menuju pertempuran.
Dialogue: 0,0:04:27.95,0:04:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengumumannya seperti wahana taman hiburan.
Dialogue: 0,0:04:30.92,0:04:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situasi seperti itu,\Ndia tenang sekali menyatakan perang.
Dialogue: 0,0:04:34.09,0:04:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kesempatan seperti ini langka.
Dialogue: 0,0:04:37.09,0:04:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ingin heboh!
Dialogue: 0,0:04:39.09,0:04:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada rasa menyesal sama sekali, ya.
Dialogue: 0,0:04:41.64,0:04:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:43.72,0:04:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah tahu siapa mereka,
Dialogue: 0,0:04:46.03,0:04:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cepat tembak dan jatuhkan.
Dialogue: 0,0:04:48.37,0:04:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, barusan dia bilang menyerah.
Dialogue: 0,0:04:52.33,0:04:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dengar penjelasan lanjutnya,
Dialogue: 0,0:04:54.73,0:04:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tampaknya mereka memang menyerah.
Dialogue: 0,0:04:57.74,0:05:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian besar kastelnya\Nmungkin sudah jadi sarang monster.
Dialogue: 0,0:05:03.19,0:05:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau asal tembak, monster di dalamnya\Nbisa berhamburan ke sekitar desa.
Dialogue: 0,0:05:07.47,0:05:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita masuk ke sana\Ndan cari cara untuk mengendalikannya.
Dialogue: 0,0:05:10.99,0:05:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihannya cuma itu, ya?
Dialogue: 0,0:05:12.80,0:05:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, biar kami\Nyang mencari cara mengendalikannya.
Dialogue: 0,0:05:17.13,0:05:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja kastel itu\Nperlu verifikasi dari ras Malaikat.
Dialogue: 0,0:05:22.11,0:05:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya?
Dialogue: 0,0:05:24.44,0:05:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, yang disebut ras Dewa itu\Nnama lama dari ras Malaikat.
Dialogue: 0,0:05:30.02,0:05:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa namanya berubah?
Dialogue: 0,0:05:32.12,0:05:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya sengaja diganti.
Dialogue: 0,0:05:35.00,0:05:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu ras Malaikat itu...\Nagak sedikit arogan.
Dialogue: 0,0:05:40.68,0:05:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka masih ada\Nyang memanggil begitu.
Dialogue: 0,0:05:43.52,0:05:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kita harus luruskan sampai tuntas.
Dialogue: 0,0:05:47.16,0:05:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu diselidiki dulu.
Dialogue: 0,0:05:49.54,0:05:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil diskusi,
Dialogue: 0,0:05:51.13,0:05:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tim yang masuk ke Kastel Matahari,
Dialogue: 0,0:05:53.56,0:05:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terbagi jadi tim pertama yang masuk dari atas,
Dialogue: 0,0:05:56.49,0:05:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tim kedua yang masuk dari bawah.
Dialogue: 0,0:05:59.80,0:06:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada apa-apa, nanti kukabari.
Dialogue: 0,0:06:01.69,0:06:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:02.31,0:06:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya, tidak boleh gagal!
Dialogue: 0,0:06:04.80,0:06:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku!
Dialogue: 0,0:06:06.60,0:06:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, ya.
Dialogue: 0,0:06:08.72,0:06:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, di sini juga harus\Nmelakukan persiapan.
Dialogue: 0,0:06:16.06,0:06:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya tak ada yang perlu dipersiapkan.
Dialogue: 0,0:06:18.29,0:06:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:06:18.99,0:06:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, terima kasih.
Dialogue: 0,0:06:21.05,0:06:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalau sampai terjadi situasi\Nmereka yang kuat kalah,
Dialogue: 0,0:06:24.27,0:06:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak akan bisa melakukan apa pun.
Dialogue: 0,0:06:27.12,0:06:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sedang bertempur, ya.
Dialogue: 0,0:06:29.05,0:06:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dilihat lagi,\Nbentuknya seperti es krim.
Dialogue: 0,0:06:32.79,0:06:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu sekarang,\Nbagian kerucutnya meledak.
Dialogue: 0,0:06:35.85,0:06:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rusty dan yang lainnya\Nmengalahkan monster yang di sana.
Dialogue: 0,0:06:40.09,0:06:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang apa?
Dialogue: 0,0:06:41.55,0:06:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sedang mengomando strategi.
Dialogue: 0,0:06:44.34,0:06:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayak lagi gabut.
Dialogue: 0,0:06:45.25,0:06:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi gabut itu.
Dialogue: 0,0:06:46.01,0:06:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabut katanya.
Dialogue: 0,0:06:46.93,0:06:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang begitu.
Dialogue: 0,0:06:50.31,0:06:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daruma...
Dialogue: 0,0:06:51.97,0:06:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:06:54.21,0:06:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian berusaha, ya.
Dialogue: 0,0:06:56.23,0:06:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Daruma...
Dialogue: 0,0:06:58.67,0:07:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daruma itu siapa?
Dialogue: 0,0:07:01.29,0:07:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang hebat dari zaman dulu?
Dialogue: 0,0:07:03.49,0:07:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai!
Dialogue: 0,0:07:04.59,0:07:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Cepat!
Dialogue: 0,0:07:05.99,0:07:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades kalah.
Dialogue: 0,0:07:07.08,0:07:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:08.21,0:07:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sekali lagi!
Dialogue: 0,0:07:13.69,0:07:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kecil!
Dialogue: 0,0:07:15.13,0:07:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kamu tak bisa makan malam.
Dialogue: 0,0:07:17.00,0:07:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tetap akan berusaha!
Dialogue: 0,0:07:18.24,0:07:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kubuatkan lagi.
Dialogue: 0,0:07:21.83,0:07:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketinggiannya makin turun, ya.
Dialogue: 0,0:07:23.97,0:07:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah miring seperti itu,\Napa tidak akan jungkir balik?
Dialogue: 0,0:07:27.47,0:07:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tegak lagi.
Dialogue: 0,0:07:29.36,0:07:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sore harinya, semuanya pulang dulu.
Dialogue: 0,0:07:33.09,0:07:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membawa Kuzden\Nyang tadi hanya muncul di layar.
Dialogue: 0,0:07:36.20,0:07:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf!
Dialogue: 0,0:07:38.40,0:07:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadi terlalu antusias!
Dialogue: 0,0:07:40.19,0:07:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tidak apa-apa.
Dialogue: 0,0:07:42.15,0:07:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka,\Naku akan mengalami hal seperti itu.
Dialogue: 0,0:07:45.49,0:07:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski telanjang sujud minta maaf pun,\Ntak ada yang bahagia, jadi hentikan.
Dialogue: 0,0:07:50.55,0:07:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya pasti lapar,
Dialogue: 0,0:07:52.66,0:07:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kusiapkan makanan siap saji.
Dialogue: 0,0:07:55.52,0:07:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini!\NRasanya bisa seenak ini?
Dialogue: 0,0:07:59.97,0:08:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Kastel Matahari biasanya makan apa?
Dialogue: 0,0:08:03.03,0:08:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang dungeon.
Dialogue: 0,0:08:05.00,0:08:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikelilingi monster\Nmembuatku tak bisa keluar.
Dialogue: 0,0:08:07.25,0:08:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terpaksa menanam kentang yang ada di situ.
Dialogue: 0,0:08:10.59,0:08:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi makananmu cuma itu?
Dialogue: 0,0:08:12.45,0:08:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dari lahir sampai sekarang.
Dialogue: 0,0:08:14.68,0:08:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kentang?
Dialogue: 0,0:08:16.12,0:08:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kentang.
Dialogue: 0,0:08:17.56,0:08:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, makan yang banyak.
Dialogue: 0,0:08:20.72,0:08:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:08:22.57,0:08:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, aku juga ingin berikan ini\Nke teman-temanku di kastel.
Dialogue: 0,0:08:27.57,0:08:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa sekotak utuh.
Dialogue: 0,0:08:30.21,0:08:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:08:32.07,0:08:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, malah kasihan ke musuh,\Nkamu terlalu lembek.
Dialogue: 0,0:08:34.84,0:08:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyerah,\Njadi sudah bukan musuh lagi.
Dialogue: 0,0:08:37.55,0:08:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana Kastel Mataharinya?
Dialogue: 0,0:08:39.13,0:08:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih rumit dari yang diperkirakan,\Nsepertinya butuh waktu.
Dialogue: 0,0:08:42.96,0:08:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi cara mengendalikannya tak akan\Nketemu dalam waktu dekat.
Dialogue: 0,0:08:47.04,0:08:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal itu...
Dialogue: 0,0:08:48.85,0:08:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin, kalau ada perwakilan\Nras Dewa dari kalian—
Dialogue: 0,0:08:52.03,0:08:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuzden, tadi kita sudah membahasnya, kan?
Dialogue: 0,0:08:55.51,0:08:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:08:56.10,0:08:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kami ini apa?
Dialogue: 0,0:08:57.56,0:08:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ras Malaikat!
Dialogue: 0,0:08:58.60,0:08:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ras Dewa?
Dialogue: 0,0:08:59.44,0:09:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah punah!
Dialogue: 0,0:09:00.73,0:09:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.\NSilakan lanjutkan makannya.
Dialogue: 0,0:09:05.99,0:09:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sebenarnya bahas apa?
Dialogue: 0,0:09:10.49,0:09:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasi penaklukan Kastel Matahari, hari kedua.
Dialogue: 0,0:09:15.91,0:09:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyiapkan makanan manis\Nuntuk semuanya yang pulang lelah.
Dialogue: 0,0:09:20.48,0:09:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku buat krep isi selai dan krim.\NMudah dimakan juga.
Dialogue: 0,0:09:24.63,0:09:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, progres operasinya...
Dialogue: 0,0:09:28.92,0:09:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:29.76,0:09:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bezel?
Dialogue: 0,0:09:31.15,0:09:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Kades!
Dialogue: 0,0:09:33.26,0:09:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya ada serangan,\Njadi aku kemari untuk memastikan.
Dialogue: 0,0:09:38.52,0:09:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini enak,\Naroma buahnya menyatu dengan teh.
Dialogue: 0,0:09:43.21,0:09:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau mencicipi selai yang baru dibuat.
Dialogue: 0,0:09:45.81,0:09:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih terlalu awal untuk camilan.
Dialogue: 0,0:09:48.28,0:09:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku coba buat teh...
Dialogue: 0,0:09:52.09,0:09:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata enak.
Dialogue: 0,0:09:54.45,0:09:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah telat,\Napa kastel itu milik Kerajaan Iblis?
Dialogue: 0,0:09:58.32,0:10:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, sepertinya itu milik musuh.
Dialogue: 0,0:10:01.54,0:10:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya direbut ras Iblis.
Dialogue: 0,0:10:04.03,0:10:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak ada di catatan kami.
Dialogue: 0,0:10:06.99,0:10:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain Kerajaan Iblis,\Nmasih ada ras Iblis lain.
Dialogue: 0,0:10:10.80,0:10:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku permisi.
Dialogue: 0,0:10:14.16,0:10:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bezel membawa pulang selainya dengan botol.
Dialogue: 0,0:10:17.31,0:10:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tak ada masalah,\Noperasinya terus lanjut.
Dialogue: 0,0:10:22.01,0:10:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada serangan?\NBukan.
Dialogue: 0,0:10:25.40,0:10:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kode dari Hakuren dan Rusty.
Dialogue: 0,0:10:29.61,0:10:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, tembak ke arah itu.
Dialogue: 0,0:10:37.68,0:10:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, batunya runtuh.
Dialogue: 0,0:10:39.83,0:10:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa akan jatuh?\NBelum.
Dialogue: 0,0:10:42.59,0:10:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerucut es krimnya sudah hilang,\Ntapi masih bisa melayang.
Dialogue: 0,0:10:50.93,0:10:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades!
Dialogue: 0,0:10:54.99,0:10:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang sebentar lagi selesai,\Njadi aku disuruh menjemputmu.
Dialogue: 0,0:10:58.16,0:10:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:11:06.61,0:11:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!\NBetulan Kastel Terbang!
Dialogue: 0,0:11:15.31,0:11:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udaranya terasa berubah?
Dialogue: 0,0:11:17.35,0:11:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah terasa hangat?
Dialogue: 0,0:11:19.49,0:11:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin agar bisa terbang di ketinggian,\Nudara di sekitar kastel dikendalikan sihir.
Dialogue: 0,0:11:33.43,0:11:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu bagian tengah kastelnya.
Dialogue: 0,0:11:36.20,0:11:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai laporan, bangunannya tua,\Nbanyak reruntuhan, dan tak berpenghuni.
Dialogue: 0,0:11:42.24,0:11:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggumu.
Dialogue: 0,0:11:43.56,0:11:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:44.63,0:11:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:11:46.52,0:11:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alun-alun depan kastel?
Dialogue: 0,0:11:48.67,0:11:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunannya bobrok, ya.
Dialogue: 0,0:11:52.88,0:11:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ras Iblis yang dibilang Kuzden?
Dialogue: 0,0:11:55.55,0:11:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon!\NHentikan!
Dialogue: 0,0:11:57.13,0:11:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dilindungi!
Dialogue: 0,0:11:58.68,0:11:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:11:59.91,0:12:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak akan mengamuk!
Dialogue: 0,0:12:02.16,0:12:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa hidup bersama monster!
Dialogue: 0,0:12:05.24,0:12:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jangan keluar!
Dialogue: 0,0:12:07.48,0:12:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa itu?
Dialogue: 0,0:12:09.42,0:12:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Monster itu membawa bencana bagi manusia!\N- Sejak kapan mereka begini?
Dialogue: 0,0:12:12.32,0:12:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia tak pernah berbuat jahat!\N- Sejak kamu ke sini.
Dialogue: 0,0:12:14.67,0:12:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mereka terlihat jelas\Nmelihat ke arah kita.
Dialogue: 0,0:12:17.93,0:12:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bawa dia pergi!
Dialogue: 0,0:12:20.21,0:12:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sampai kapan ini berlanjut?
Dialogue: 0,0:12:22.25,0:12:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kamu yang menghentikannya.
Dialogue: 0,0:12:25.33,0:12:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau membasminya\Ntapi ingin memeliharanya, dipelihara saja.
Dialogue: 0,0:12:30.94,0:12:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:12:32.23,0:12:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:12:33.04,0:12:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena kami\Nmenyuruh membasmi monster kastel,
Dialogue: 0,0:12:35.81,0:12:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka sungkan untuk terus terang.
Dialogue: 0,0:12:38.81,0:12:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kades Hiraku!
Dialogue: 0,0:12:40.92,0:12:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:12:42.95,0:12:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk ke ruang singgasana.
Dialogue: 0,0:12:45.73,0:12:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya.
Dialogue: 0,0:12:54.41,0:12:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggumu.
Dialogue: 0,0:12:56.42,0:12:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu yang akan menjadi tuanku?
Dialogue: 0,0:12:59.17,0:13:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara barusan itu... dari kristal?
Dialogue: 0,0:13:02.28,0:13:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, dia seperti roh\Nyang mengatur kendali kastel ini.
Dialogue: 0,0:13:06.72,0:13:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, minta bantuan dia\Nuntuk mengendalikan kastelnya.
Dialogue: 0,0:13:09.49,0:13:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:13:11.19,0:13:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi agar dapat hak kendali,\Nharus ada yang diakui sebagai tuannya.
Dialogue: 0,0:13:15.63,0:13:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berkali-kali membujuknya,
Dialogue: 0,0:13:18.37,0:13:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia tetap tak memberi izin.
Dialogue: 0,0:13:21.30,0:13:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang layak kuakui dan kulayani\Nsebagai tuan hanya satu,
Dialogue: 0,0:13:24.63,0:13:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yaitu ras Dewa, ras yang terpilih.
Dialogue: 0,0:13:27.58,0:13:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga,\Npemilik aslinya dari ras Dewa, ya?
Dialogue: 0,0:13:31.53,0:13:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:13:32.71,0:13:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:33.58,0:13:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebisa mungkin, aku ingin bantu.
Dialogue: 0,0:13:36.32,0:13:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, kami bukan ras Dewa.
Dialogue: 0,0:13:39.15,0:13:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi untuk masalah itu, aku mohon...
Dialogue: 0,0:13:41.03,0:13:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:13:42.59,0:13:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Kristal.\NApa kamu punya nama?
Dialogue: 0,0:13:46.97,0:13:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau tanya nama,\Nperkenalkan dirimu dulu.
Dialogue: 0,0:13:49.43,0:13:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku Hiraku.
Dialogue: 0,0:13:50.81,0:13:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Kastel Matahari.\NYang Mulia Kastel Matahari.
Dialogue: 0,0:13:54.64,0:13:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sepertinya tipe yang ribet.
Dialogue: 0,0:13:56.36,0:13:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Yang Mulia Kastel Matahari.
Dialogue: 0,0:13:58.24,0:14:00.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Yang Mulia itu bukan namaku.
Dialogue: 0,0:14:00.37,0:14:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hak kendalinya bisa diberikan\Npada ras Malaikat yang di sana?
Dialogue: 0,0:14:03.61,0:14:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ras Malaikat?
Dialogue: 0,0:14:05.87,0:14:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata ras Dewa masih ada!
Dialogue: 0,0:14:08.65,0:14:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sekarang mereka tak mau\Ndipanggil dengan nama itu.
Dialogue: 0,0:14:11.80,0:14:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ini bicara apa?\NRas Dewa, ya ras De—
Dialogue: 0,0:14:17.47,0:14:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ras Malaikat.
Dialogue: 0,0:14:19.51,0:14:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ras Dewa sudah punah.
Dialogue: 0,0:14:21.88,0:14:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:14:23.88,0:14:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ras Malaikat, ya.\NAku ceroboh.
Dialogue: 0,0:14:27.61,0:14:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kamu mudah paham.
Dialogue: 0,0:14:29.45,0:14:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu maksudnya yang dibahas?
Dialogue: 0,0:14:31.77,0:14:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Kuz!
Dialogue: 0,0:14:33.55,0:14:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:34.27,0:14:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka yang mengalahkan monster\Nyang bersarang di kastel?
Dialogue: 0,0:14:37.27,0:14:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:14:38.77,0:14:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau yang menghancurkan\Nbatu di bawah kastel?
Dialogue: 0,0:14:41.27,0:14:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu, Kades.
Dialogue: 0,0:14:42.78,0:14:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, ya.
Dialogue: 0,0:14:44.03,0:14:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Hiraku?
Dialogue: 0,0:14:52.04,0:14:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kastel diberikan pada Kuz!
Dialogue: 0,0:14:54.25,0:14:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tapi dari dulu kamu\Ntak mau mengakuiku!
Dialogue: 0,0:14:58.12,0:15:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Registrasi selesai!\NSekarang tak bisa diganti!
Dialogue: 0,0:15:00.52,0:15:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:02.12,0:15:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kastelnya bisa dikendalikan, bukan?
Dialogue: 0,0:15:05.18,0:15:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kalau ada permintaan,\Nsampaikan ke Kuz.
Dialogue: 0,0:15:08.25,0:15:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ribet, bisa langsung padaku.
Dialogue: 0,0:15:10.75,0:15:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Kastel Matahari,\Naku mau dengar penjelasannya.
Dialogue: 0,0:15:13.68,0:15:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil yang mulia,\Npanggil saja butiran debu.
Dialogue: 0,0:15:16.04,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tiba-tiba merendah.
Dialogue: 0,0:15:17.81,0:15:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini dan begitu.
Dialogue: 0,0:15:19.23,0:15:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari penjelasan Kastel Matahari,
Dialogue: 0,0:15:21.37,0:15:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau naga berkumpul di sekitar pendeta naga,
Dialogue: 0,0:15:24.64,0:15:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada perjanjian bahwa Kastel Matahari akan pergi\Nke sana dan meminjamkan kekuatannya.
Dialogue: 0,0:15:28.89,0:15:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi sampai!
Dialogue: 0,0:15:30.47,0:15:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti pengumuman\Nada peristiwa di dalam gim, ya?
Dialogue: 0,0:15:33.08,0:15:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilangnya meminjamkan kekuatan,\Ntapi itu sudah ketinggalan zaman.
Dialogue: 0,0:15:36.01,0:15:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri yang memprovokasi kami\Ndan bilang perang menyelamatkan dunia
Dialogue: 0,0:15:39.33,0:15:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan dimulai!
Dialogue: 0,0:15:40.91,0:15:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:15:41.84,0:15:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku menyatakan perang!
Dialogue: 0,0:15:44.04,0:15:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Catatan seperti itu tidak ada.
Dialogue: 0,0:15:46.73,0:15:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, apa ke depannya\Nperjanjian itu terus berlaku?
Dialogue: 0,0:15:50.31,0:15:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, anggap saja itu sudah tercapai!\NBatalkan saja!
Dialogue: 0,0:15:53.60,0:15:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara,\Nkastel tak akan ada di atas desa lagi.
Dialogue: 0,0:15:59.61,0:16:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masalahnya sudah selesai,
Dialogue: 0,0:16:02.29,0:16:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jalan-jalan di kastel.
Dialogue: 0,0:16:04.81,0:16:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam kastel sangat luas,\Nbangunannya pun megah.
Dialogue: 0,0:16:08.45,0:16:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi banyak ladang di sekitarnya\Ndan terasa aneh.
Dialogue: 0,0:16:12.13,0:16:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka menanam kentang dungeon\Nyang kudengar kemarin.
Dialogue: 0,0:16:18.56,0:16:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para ras Iblis tinggal berkumpul\Ndi satu sudut kastel.
Dialogue: 0,0:16:22.60,0:16:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya kurus dan hidupnya tampak berat.
Dialogue: 0,0:16:26.39,0:16:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyuruh Rusty dan Hakuren\Nmembawa bahan makanan.
Dialogue: 0,0:16:29.68,0:16:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:31.25,0:16:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah.
Dialogue: 0,0:16:33.81,0:16:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kastel ternyata ada juga\Npenghuni selain ras Iblis.
Dialogue: 0,0:16:36.55,0:16:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ras Sukubus.
Dialogue: 0,0:16:38.64,0:16:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:16:39.45,0:16:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulit mereka lebih bagus dari ras Iblis lain
Dialogue: 0,0:16:42.40,0:16:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena mereka hidup\Ndengan memakan cinta dalam mimpi.
Dialogue: 0,0:16:46.92,0:16:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti ras yang romantis, ya?\NSebaiknya jangan terlalu dipikirkan.
Dialogue: 0,0:16:53.87,0:16:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi di perjalanan aku sempat melihatnya.
Dialogue: 0,0:16:55.91,0:16:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekitar kastel ada apa saja?
Dialogue: 0,0:16:58.31,0:17:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak bangunan berdekatan seperti kota.
Dialogue: 0,0:17:01.53,0:17:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, seperti kota di bawah kastel, ya?
Dialogue: 0,0:17:04.29,0:17:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada air mancur yang rusak,
Dialogue: 0,0:17:06.55,0:17:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bekas kolam yang kering.
Dialogue: 0,0:17:08.55,0:17:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin jadi begini karena perang zaman dulu.
Dialogue: 0,0:17:11.39,0:17:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang batu besarnya sudah lepas semua,\Nmungkin itu bekas sabotase
Dialogue: 0,0:17:15.81,0:17:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dilakukan ras Iblis zaman dulu.
Dialogue: 0,0:17:20.17,0:17:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya mereka berhasil menyusupkan\Ntelur monster ke dalam batu.
Dialogue: 0,0:17:24.19,0:17:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya, mereka tak menyangka itu membuat\Nmereka sendiri terkurung di dalam kastel.
Dialogue: 0,0:17:30.45,0:17:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya banyak,\Ntapi sudah kukalahkan semuanya.
Dialogue: 0,0:17:33.00,0:17:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kerja bagus.
Dialogue: 0,0:17:35.71,0:17:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa kastel sebesar ini bisa melayang?
Dialogue: 0,0:17:39.60,0:17:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran soal mekanismenya.
Dialogue: 0,0:17:41.58,0:17:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa di bagian bawah kastelnya ada sesuatu?
Dialogue: 0,0:17:45.46,0:17:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahas soal penasaran, ada satu tempat\Ndi kastel yang menarik perhatianku.
Dialogue: 0,0:17:50.83,0:17:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu di sini?
Dialogue: 0,0:17:52.67,0:17:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya jalan buntu.
Dialogue: 0,0:17:54.48,0:17:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku penasaran.
Dialogue: 0,0:17:56.41,0:18:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di jalan buntu yang misterius ini,\Nada guci yang sengaja ditaruh.
Dialogue: 0,0:18:00.23,0:18:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendanya tua,\Ntapi kelihatannya tidak berharga.
Dialogue: 0,0:18:04.73,0:18:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jangan-jangan ini monster?
Dialogue: 0,0:18:07.27,0:18:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guci itu bukan monster.
Dialogue: 0,0:18:09.11,0:18:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi di tempat lain ada, ya?
Dialogue: 0,0:18:16.37,0:18:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga ada mekanisme rahasia!
Dialogue: 0,0:18:19.15,0:18:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... ruang belajar?
Dialogue: 0,0:18:21.87,0:18:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ensiklopedia praktis, busana masa kini,
Dialogue: 0,0:18:25.63,0:18:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kumpulan teori percintaan?
Dialogue: 0,0:18:26.99,0:18:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buku umum semua.
Dialogue: 0,0:18:28.93,0:18:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk ukuran ruangan rahasia,\Nini terlalu biasa, ya.
Dialogue: 0,0:18:31.69,0:18:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada sesuatu yang mencurigakan?
Dialogue: 0,0:18:35.49,0:18:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:18:40.91,0:18:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini alun-alun dalam kastel, ya?
Dialogue: 0,0:18:43.27,0:18:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini jalur keluar dari ruang rahasia, ya?
Dialogue: 0,0:18:46.17,0:18:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades hebat bisa menemukan mekanisme ini.
Dialogue: 0,0:18:51.21,0:18:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih penasaran dengan guci ini?
Dialogue: 0,0:18:54.83,0:19:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian pintu depannya sudah ketahuan,\Npercuma kalau pasang di pintu keluar juga.
Dialogue: 0,0:19:13.79,0:19:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:19:16.95,0:19:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita terus turun ke bawah.
Dialogue: 0,0:19:22.40,0:19:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti?
Dialogue: 0,0:19:24.40,0:19:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini...
Dialogue: 0,0:19:29.73,0:19:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski lebih cepat sekitar\Nsepuluh tahun dari ramalan...
Dialogue: 0,0:19:33.49,0:19:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:19:36.05,0:19:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan ke sini.
Dialogue: 0,0:19:42.08,0:19:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku asisten utama penguasa\NKastel Matahari, Bell Forgma.
Dialogue: 0,0:19:47.33,0:19:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, asisten utama?
Dialogue: 0,0:19:49.68,0:19:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja aku penanggung jawab\Nyang mengatur operasional Kastel Matahari.
Dialogue: 0,0:19:54.34,0:19:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas, aku tidak berbahaya.
Dialogue: 0,0:19:57.27,0:20:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kristal yang di singgasana bilang\Ndia penanggung jawab...
Dialogue: 0,0:20:00.10,0:20:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang dia Kastel Matahari.
Dialogue: 0,0:20:02.40,0:20:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma wakil.
Dialogue: 0,0:20:04.23,0:20:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sudah lama mengurung diri di sini.
Dialogue: 0,0:20:07.98,0:20:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung saja, aku ingin memberikan\Nyang harus diberikan,
Dialogue: 0,0:20:11.57,0:20:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyampaikan hal yang harus disampaikan,
Dialogue: 0,0:20:13.73,0:20:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyelesaikan ramalan ini.
Dialogue: 0,0:20:17.49,0:20:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramalan?
Dialogue: 0,0:20:18.61,0:20:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Engkau yang telah melewati\Nberbagai rintangan sampai ke sini,
Dialogue: 0,0:20:23.12,0:20:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuberikan Pedang Matahari ini.
Dialogue: 0,0:20:26.12,0:20:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah,
Dialogue: 0,0:20:27.75,0:20:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wahai Pahlawan!
Dialogue: 0,0:20:29.20,0:20:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:30.25,0:20:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan?
Dialogue: 0,0:20:31.75,0:20:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelemahan raja iblis\Nada di satu sisik di punggungnya.
Dialogue: 0,0:20:35.76,0:20:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu membidiknya,\Ndia pasti bisa dikalahkan.
Dialogue: 0,0:20:39.25,0:20:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, begini...
Dialogue: 0,0:20:40.51,0:20:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, cepat ambil pedangnya.
Dialogue: 0,0:20:43.25,0:20:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal baik harus segera dilakukan, Pahlawan.
Dialogue: 0,0:20:45.35,0:20:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu salah orang?\NAku bukan pahlawan.
Dialogue: 0,0:20:48.64,0:20:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:20:49.97,0:20:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:50.59,0:20:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, di kitab ramalan,\Ntertulis bahwa pahlawan akan datang.
Dialogue: 0,0:20:54.40,0:20:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, karena kamu datang ke sini,\Nkamulah pahlawannya.
Dialogue: 0,0:20:57.09,0:21:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bilang begitu, aku tak ada niat\Nuntuk mengalahkan raja iblis.
Dialogue: 0,0:21:00.84,0:21:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk hal itu, terserah dirimu.\NSudah, ambil saja.
Dialogue: 0,0:21:05.41,0:21:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah muak dipaksa\Nmenjalankan tugas yang tak jelas ini.
Dialogue: 0,0:21:10.17,0:21:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu menerimanya, tugasku selesai.
Dialogue: 0,0:21:12.91,0:21:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tolong ambil.
Dialogue: 0,0:21:15.04,0:21:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:21:16.37,0:21:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tak akan membuatku terkutuk, kan?
Dialogue: 0,0:21:18.04,0:21:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak.
Dialogue: 0,0:21:19.39,0:21:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bebas memakai pedang ini?
Dialogue: 0,0:21:21.25,0:21:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:21:22.12,0:21:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kubuang?
Dialogue: 0,0:21:22.75,0:21:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh!
Dialogue: 0,0:21:23.84,0:21:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:28.06,0:21:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, berat!
Dialogue: 0,0:21:29.84,0:21:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai Pahlawan!
Dialogue: 0,0:21:31.31,0:21:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasib dunia ada di tanganmu!
Dialogue: 0,0:21:37.99,0:21:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, terima kasih!\NAkhirnya tugasku selesai!
Dialogue: 0,0:21:42.05,0:21:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir seribu tahun aku terkurung di sini.
Dialogue: 0,0:21:44.82,0:21:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah cemas\Ntak bisa keluar lagi dari sini.
Dialogue: 0,0:21:48.01,0:21:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?\NKerja bagus.
Dialogue: 0,0:21:50.58,0:21:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sesuai saranmu...
Dialogue: 0,0:21:52.95,0:21:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cangkul!
Dialogue: 0,0:21:55.79,0:21:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangnya kubajak menjadi tanah.
Dialogue: 0,0:21:58.59,0:22:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sayang.
Dialogue: 0,0:22:00.32,0:22:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat ingin mencobanya.
Dialogue: 0,0:22:02.61,0:22:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak butuh pedang\Nuntuk mengalahkan iblis yang kukenal.
Dialogue: 0,0:22:05.31,0:22:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:22:06.72,0:22:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benda penting dihancurkan di depan matanya,\Nmembuatku tidak enak.
Dialogue: 0,0:22:13.13,0:22:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia sangat benci dengan tugasnya.
