Dialogue: 0,0:00:11.49,0:00:17.46,tanda,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:01:31.53,0:01:34.99,tanda,,0000,0000,0000,,REKAP CERITA SEJAUH INI
Dialogue: 0,0:02:30.42,0:02:32.42,tanda,,0000,0000,0000,,BALASNYA LEBIH AROGAN LAGI
Dialogue: 0,0:02:43.18,0:02:47.06,tanda,,0000,0000,0000,,KADES MEMANG HEBAT, AKTINGMU BAGUS
Dialogue: 0,0:03:05.46,0:03:08.96,tanda,,0000,0000,0000,,RAS MANUSIA BINATANG, MAMU
Dialogue: 0,0:03:56.63,0:03:57.04,tanda,,0000,0000,0000,,RENCANA RUTE
Dialogue: 0,0:03:57.04,0:04:00.14,tanda,,0000,0000,0000,,USULAN LOKASI 2 & 3
Dialogue: 0,0:04:42.18,0:04:44.93,tanda,,0000,0000,0000,,HUTAN KEMATIAN
Dialogue: 0,0:04:44.93,0:04:46.18,tanda,,0000,0000,0000,,MATI
Dialogue: 0,0:05:18.46,0:05:20.47,tanda,,0000,0000,0000,,PADA WAKTU ITU
Dialogue: 0,0:06:12.02,0:06:15.52,tanda,,0000,0000,0000,,KASUR NYAMAN ALA MINOTAURUS
Dialogue: 0,0:07:50.87,0:07:57.25,tanda,,0000,0000,0000,,DESA ATAS, DESA TENGAH, DESA BAWAH
Dialogue: 0,0:07:57.25,0:08:00.60,tanda,,0000,0000,0000,,DESA SATU, DESA DUA, DESA TIGA
Dialogue: 0,0:08:32.28,0:08:34.28,tanda,,0000,0000,0000,,KADES UTAMA
Dialogue: 0,0:08:34.28,0:08:35.78,tanda,,0000,0000,0000,,KADES BESAR
Dialogue: 0,0:08:35.78,0:08:40.28,tanda,,0000,0000,0000,,RAJA KADES
Dialogue: 0,0:08:55.81,0:08:59.31,tanda,,0000,0000,0000,,SEDIH
Dialogue: 0,0:10:03.62,0:10:06.13,tanda,,0000,0000,0000,,PINGSAN
Dialogue: 0,0:10:13.38,0:10:18.89,tanda,,0000,0000,0000,,MANGSA UTAMA
Dialogue: 0,0:10:55.43,0:10:58.23,tanda,,0000,0000,0000,,PENGAWAL TEPERCAYA
Dialogue: 0,0:10:58.23,0:10:58.93,tanda,,0000,0000,0000,,BOLEH JUGA
Dialogue: 0,0:11:13.34,0:11:15.85,tanda,,0000,0000,0000,,KURANG LINCAH
Dialogue: 0,0:12:33.90,0:12:40.16,tanda,,0000,0000,0000,,KAMI TANAM SENDIRI
Dialogue: 0,0:14:05.95,0:14:07.62,tanda,,0000,0000,0000,,AKU DISEMBAH SEBAGAI OM-OM LAGI!
Dialogue: 0,0:14:07.62,0:14:10.95,tanda,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:14:22.97,0:14:28.47,tanda,,0000,0000,0000,,KURIR CENTAURUS
Dialogue: 0,0:14:32.60,0:14:33.57,tanda,,0000,0000,0000,,KURIR CENTAURUS, DESA POHON BESAR,
Dialogue: 0,0:14:33.57,0:14:34.23,tanda,,0000,0000,0000,,DESA DUA, DESA TIGA
Dialogue: 0,0:15:07.26,0:15:09.58,tanda,,0000,0000,0000,,REKOMENDASI! KUDA
Dialogue: 0,0:15:09.58,0:15:12.27,tanda,,0000,0000,0000,,MBE~ KAMBING, AYAM
Dialogue: 0,0:16:25.09,0:16:26.72,tanda,,0000,0000,0000,,DI HARI LAINNYA
Dialogue: 0,0:19:53.34,0:19:58.09,tanda,,0000,0000,0000,,WANITA, PRIA
Dialogue: 0,0:20:27.62,0:20:33.88,tanda,,0000,0000,0000,,MENJELASKAN
Dialogue: 0,0:23:45.95,0:23:50.95,tanda,,0000,0000,0000,,SELANJUTNYA:\NEPISODE 3: MUSIM DINGIN
Dialogue: 0,0:01:35.40,0:01:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak pendatang baru yang datang\Nke Desa Pohon Besar.
Dialogue: 0,0:01:39.75,0:01:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ras Minotaurus yang tubuhnya sangat besar.
Dialogue: 0,0:01:44.13,0:01:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ras Centaurus yang setengah manusia,\Nsetengah kuda.
Dialogue: 0,0:01:48.01,0:01:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ras Nyunyudaphne yang mirip roh pohon.
Dialogue: 0,0:01:51.38,0:01:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menerima lebih dari\Ndua ratus penduduk baru,
Dialogue: 0,0:01:55.42,0:01:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami memanggil perwakilan masing-masing\Nuntuk berdiskusi.
Dialogue: 0,0:02:00.87,0:02:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf rumah yang akan kalian huni\Nbelum kami siapkan dengan baik.
Dialogue: 0,0:02:04.80,0:02:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa cepat kembali hidup stabil lagi,
Dialogue: 0,0:02:07.41,0:02:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku butuh bantuan kalian, tapi...
Dialogue: 0,0:02:10.57,0:02:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu kaku begitu.
Dialogue: 0,0:02:12.67,0:02:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sama sekali!
Dialogue: 0,0:02:14.15,0:02:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Statusku di sini hanya seperti\Nserpihan debu di pojokan!
Dialogue: 0,0:02:18.29,0:02:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Debu rumah.
Dialogue: 0,0:02:20.27,0:02:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, jangan terlalu tegang.
Dialogue: 0,0:02:24.19,0:02:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan isyarat?
Dialogue: 0,0:02:27.91,0:02:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, khusus untuk kali ini,\Nkamu kuampuni.
Dialogue: 0,0:02:30.42,0:02:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kuampuni.
Dialogue: 0,0:02:32.86,0:02:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkat kepalamu, Gruwald Raby Coll.
Dialogue: 0,0:02:37.97,0:02:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, aku berharap banyak\Npada kerja kerasmu!
Dialogue: 0,0:02:43.65,0:02:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:02:44.39,0:02:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bersyukur!
Dialogue: 0,0:02:46.11,0:02:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:47.06,0:02:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, kita akan hidup bersama.
Dialogue: 0,0:02:49.49,0:02:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalani dengan santai, tak perlu tegang.
Dialogue: 0,0:02:52.81,0:02:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk tiap ras, sudah kutunjuk\Npenanggung jawabnya.
Dialogue: 0,0:02:57.35,0:03:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Narf akan mengurus Minotaurus,\NRashashi akan mengurus Centaurus.
Dialogue: 0,0:03:01.16,0:03:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya.
Dialogue: 0,0:03:03.22,0:03:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang mengurus Nyunyudaphne...
Dialogue: 0,0:03:05.46,0:03:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Mamu!
Dialogue: 0,0:03:07.14,0:03:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya!
Dialogue: 0,0:03:08.96,0:03:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, mohon kerja samanya.
Dialogue: 0,0:03:11.71,0:03:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, mari berjuang bersama-sama!
Dialogue: 0,0:03:15.28,0:03:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mamu dulu gadis yang pindah
Dialogue: 0,0:03:17.24,0:03:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari Desa Howlin\Nbersama Sena dan yang lainnya.
Dialogue: 0,0:03:20.46,0:03:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mamu pasti bisa mengatasinya.
Dialogue: 0,0:03:22.77,0:03:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat rekomendasi Sena, Mamu bilang ingin\Nbekerja yang ada tanggung jawabnya.
Dialogue: 0,0:03:27.11,0:03:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pun memberinya kesempatan.
Dialogue: 0,0:03:30.01,0:03:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, untuk masalah\Ntempat tinggal masing-masing...
Dialogue: 0,0:03:33.73,0:03:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa yang selama ini dibangun\Nuntuk ukuran manusia biasa,
Dialogue: 0,0:03:37.20,0:03:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditunda sementara.
Dialogue: 0,0:03:39.33,0:03:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar Minotaurus dan Centaurus\Nbisa tinggal nyaman,
Dialogue: 0,0:03:41.90,0:03:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perlu membangun desa khusus untuk mereka.
Dialogue: 0,0:03:44.72,0:03:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah memutuskan,\Ndaripada membangun satu tempat,
Dialogue: 0,0:03:48.63,0:03:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami membangunnya terpisah\Nagar mereka lebih nyaman.
Dialogue: 0,0:03:52.60,0:03:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami langsung ke lokasi\Nyang ditemukan Ria dan yang lainnya.
Dialogue: 0,0:03:57.04,0:03:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan dan saluran air akan dihubungkan.
Dialogue: 0,0:04:00.49,0:04:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya cukup jauh,\Njadi tolong bantu membuka hutan.
Dialogue: 0,0:04:04.78,0:04:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:04:05.32,0:04:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:06.36,0:04:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:04:07.29,0:04:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berubah!
Dialogue: 0,0:04:13.83,0:04:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau dibakar sampai mana?
Dialogue: 0,0:04:15.24,0:04:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dibakar.
Dialogue: 0,0:04:17.27,0:04:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuulangi lagi,\Nkita bangun jalan ke arah sana.
Dialogue: 0,0:04:21.64,0:04:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:04:27.34,0:04:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:04:28.63,0:04:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arahnya sudah benar.
Dialogue: 0,0:04:36.67,0:04:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih kurang, ya, Rusty.
Dialogue: 0,0:04:38.67,0:04:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum serius!
Dialogue: 0,0:04:40.93,0:04:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang!
Dialogue: 0,0:04:42.18,0:04:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus begini, hutannya bisa habis.
Dialogue: 0,0:04:46.65,0:04:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan dengan santai.
Dialogue: 0,0:04:48.10,0:04:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pelan-pelan dan tenang, ya?\N- Sebisa mungkin tahan diri kalian
Dialogue: 0,0:04:51.07,0:04:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Paham?\N- dan lanjutkan pekerjaannya.
Dialogue: 0,0:04:52.10,0:04:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu tarian apa?\N- Pelan-pelan.
Dialogue: 0,0:04:53.56,0:04:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara, kita ikuti jalur sungai.
Dialogue: 0,0:04:56.22,0:04:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di sini juga tolong dibantu!
Dialogue: 0,0:05:09.58,0:05:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potong!
Dialogue: 0,0:05:15.19,0:05:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjaan ini ribet, kita bakar saja?
Dialogue: 0,0:05:17.56,0:05:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:05:21.78,0:05:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:05:24.47,0:05:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karya baru dari Zabuton
Dialogue: 0,0:05:28.54,0:05:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk Tuan Alfred.
Dialogue: 0,0:05:31.24,0:05:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ukurannya agak kebesaran.
Dialogue: 0,0:05:33.91,0:05:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, itu karena kalian buru-buru.
Dialogue: 0,0:05:40.94,0:05:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di desa kedua, kami membuat\Nbangunan untuk Minotaurus.
Dialogue: 0,0:05:45.38,0:05:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Postur mereka sangat tinggi,
Dialogue: 0,0:05:48.23,0:05:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi dibuat rumah satu lantai yang tinggi.
Dialogue: 0,0:05:52.35,0:05:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bangunannya besar,\Nperabotannya juga besar.
Dialogue: 0,0:05:57.59,0:06:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan meja, tapi kursi.
Dialogue: 0,0:06:00.03,0:06:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di sana itu meja.
Dialogue: 0,0:06:02.53,0:06:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti kembali jadi anak kecil.
Dialogue: 0,0:06:06.56,0:06:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... tempat tidur?
Dialogue: 0,0:06:09.92,0:06:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuknya unik.
Dialogue: 0,0:06:11.41,0:06:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:12.54,0:06:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibuat begini agar tanduk kami tak terbentur.
Dialogue: 0,0:06:16.66,0:06:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara itu, ini desa ketiga.
Dialogue: 0,0:06:19.75,0:06:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah untuk Centaurus.
Dialogue: 0,0:06:22.58,0:06:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tubuh mereka mirip kuda,
Dialogue: 0,0:06:24.47,0:06:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bentuk rumahnya kami bangun\Nseperti kandang kuda.
Dialogue: 0,0:06:28.22,0:06:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalamnya juga luas, ya.
Dialogue: 0,0:06:30.35,0:06:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintunya nanti akan dipasang?
Dialogue: 0,0:06:32.31,0:06:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tapi...
Dialogue: 0,0:06:34.30,0:06:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak bisa membuka\Ndan menutup pintu dengan benar.
Dialogue: 0,0:06:39.76,0:06:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi di pintu masuknya, kami akan pasang\Ntirai yang bisa dibuka dengan tali.
Dialogue: 0,0:06:43.80,0:06:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:06:45.82,0:06:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat hujan, pintu geser\Nyang besar akan ditutup.
Dialogue: 0,0:06:50.83,0:06:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NSedang murung?
Dialogue: 0,0:06:53.93,0:06:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:06:57.11,0:06:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku mulai.
Dialogue: 0,0:07:06.32,0:07:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, barusan kamu apakan dia?\NContohkan ke sini padaku.
Dialogue: 0,0:07:10.70,0:07:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia.
Dialogue: 0,0:07:15.86,0:07:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar satu bulan berlalu.
Dialogue: 0,0:07:18.22,0:07:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kerja keras semuanya,\Ntiap desa mulai terbentuk.
Dialogue: 0,0:07:28.53,0:07:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari jumlah langkahnya,\Njaraknya kurang lebih sebegini.
Dialogue: 0,0:07:32.25,0:07:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini desa ketiga, ya.
Dialogue: 0,0:07:36.28,0:07:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung selesai sebelum musim dingin.
Dialogue: 0,0:07:39.03,0:07:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:40.75,0:07:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa membiarkan mereka tidur di luar.
Dialogue: 0,0:07:43.70,0:07:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu.
Dialogue: 0,0:07:45.38,0:07:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan nama desanya?
Dialogue: 0,0:07:47.76,0:07:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:07:49.85,0:07:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dari posisi,
Dialogue: 0,0:07:50.87,0:07:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Atas, Desa Tengah, Desa Bawah.
Dialogue: 0,0:07:53.52,0:07:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kedengaran seperti nama orang.
Dialogue: 0,0:07:56.14,0:07:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara,
Dialogue: 0,0:07:57.25,0:08:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Satu, Desa Dua, dan Desa Tiga saja.
Dialogue: 0,0:08:00.60,0:08:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau nanti ada usulan nama\Nyang lebih bagus...
Dialogue: 0,0:08:02.63,0:08:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan diubah lagi.
Dialogue: 0,0:08:05.13,0:08:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menulis ulang semua berkas itu merepotkan.
Dialogue: 0,0:08:09.71,0:08:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:08:10.96,0:08:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Desa Satu masih kosong,
Dialogue: 0,0:08:14.56,0:08:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Dua kadesnya Gordon,
Dialogue: 0,0:08:17.17,0:08:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Desa Tiga kadesnya Gruwald.
Dialogue: 0,0:08:20.82,0:08:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya begitu.
Dialogue: 0,0:08:22.16,0:08:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau semuanya disebut kades...
Dialogue: 0,0:08:26.07,0:08:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, dari posisi dan kejelasan,
Dialogue: 0,0:08:29.92,0:08:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya kita ganti nama jabatannya.
Dialogue: 0,0:08:32.28,0:08:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kades Utama?
Dialogue: 0,0:08:34.28,0:08:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades Besar?
Dialogue: 0,0:08:35.78,0:08:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Kades?
Dialogue: 0,0:08:37.47,0:08:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hindari nama yang kesannya berkuasa.
Dialogue: 0,0:08:40.28,0:08:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:08:42.28,0:08:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan desa kami akan dibangun?
Dialogue: 0,0:08:45.37,0:08:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf, kami tidak jadi membangun\Ndesa khusus untuk Nyunyudaphne.
Dialogue: 0,0:08:51.09,0:08:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:08:53.05,0:08:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi impian kami untuk tinggal di sini
Dialogue: 0,0:08:55.81,0:08:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan terwujud?
Dialogue: 0,0:08:57.50,0:08:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan asal menyimpulkan!
Dialogue: 0,0:08:59.31,0:09:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tugas yang ingin kupercayakan\Npada kalian di tiap desa.
Dialogue: 0,0:09:04.77,0:09:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyunyudaphne sepertinya lebih nyaman\Ndiam di satu tempat
Dialogue: 0,0:09:07.73,0:09:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di luar ruangan daripada\Nharus pergi bolak-balik.
Dialogue: 0,0:09:11.59,0:09:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kami usulkan mereka\Nmenjadi penjaga tetap.
Dialogue: 0,0:09:14.97,0:09:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjaga keamanan dan menyampaikan pesan.
Dialogue: 0,0:09:18.12,0:09:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa menyampaikan pesan\Nke temannya yang jauh lewat telepati.
Dialogue: 0,0:09:23.60,0:09:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini aman.
Dialogue: 0,0:09:27.30,0:09:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka cocok sebagai kurir pesan.
Dialogue: 0,0:09:29.67,0:09:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lembut.
Dialogue: 0,0:09:31.45,0:09:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lembut?
Dialogue: 0,0:09:33.09,0:09:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau sekalian mengurus Desa Satu\Nyang belum ada penghuninya?
Dialogue: 0,0:09:37.04,0:09:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga.
Dialogue: 0,0:09:38.69,0:09:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:09:40.11,0:09:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah dibangun,
Dialogue: 0,0:09:41.76,0:09:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sayang kalau dibiarkan terbengkalai.
Dialogue: 0,0:09:45.52,0:09:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, di malam hari, mereka juga\Nberfungsi sebagai penerangan.
Dialogue: 0,0:09:50.90,0:09:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, semua tempat tinggal\Nmereka sudah ditentukan.
Dialogue: 0,0:09:54.37,0:09:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mulai membagi tugas
Dialogue: 0,0:09:56.94,0:09:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk warga Desa Dua dan Tiga, tapi...
Dialogue: 0,0:10:06.13,0:10:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades.
Dialogue: 0,0:10:08.45,0:10:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sedikit masalah.
Dialogue: 0,0:10:10.19,0:10:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga sama.
Dialogue: 0,0:10:12.14,0:10:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:10:13.94,0:10:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Minotaurus dan Centaurus
Dialogue: 0,0:10:16.28,0:10:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kesulitan berburu di hutan.
Dialogue: 0,0:10:20.60,0:10:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari yang kulihat,\Nmereka semua sepertinya kuat.
Dialogue: 0,0:10:23.89,0:10:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minotaurus itu ras yang lembut,
Dialogue: 0,0:10:27.01,0:10:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beberapa dari kami memang ada\Nyang bisa bertarung,
Dialogue: 0,0:10:29.32,0:10:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau soal berburu rutin...
Dialogue: 0,0:10:31.90,0:10:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Centaurus pun kebanyakannya pengungsi,
Dialogue: 0,0:10:35.04,0:10:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat ini mereka hanya sanggup membela diri.
Dialogue: 0,0:10:38.41,0:10:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini yang biasa berburu itu\NKuro dan yang lainnya.
Dialogue: 0,0:10:41.00,0:10:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sadar ternyata ada kesulitan.
Dialogue: 0,0:10:42.96,0:10:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Kuro dan yang lainnya\Nsudah di luar level normal.
Dialogue: 0,0:10:47.12,0:10:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita larang mereka masuk ke hutan
Dialogue: 0,0:10:49.69,0:10:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tambah penjaga di Desa Dua dan Tiga.
Dialogue: 0,0:10:54.02,0:10:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:55.43,0:10:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kita diskusikan dengan Kuro dan Zabuton.
Dialogue: 0,0:10:59.31,0:11:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Nyunyudaphne juga perlu pengawal?
Dialogue: 0,0:11:01.96,0:11:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon mereka pandai menghindari pertarungan.
Dialogue: 0,0:11:04.37,0:11:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, yang kami perlukan bukan pengawal.
Dialogue: 0,0:11:07.69,0:11:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, kami bisa.
Dialogue: 0,0:11:08.89,0:11:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sepertinya sangat kuat.
Dialogue: 0,0:11:11.07,0:11:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mereka mengandalkan penyergapan,
Dialogue: 0,0:11:13.34,0:11:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kurang bisa berburu.
Dialogue: 0,0:11:15.85,0:11:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran bagaimana\Ncara mereka bertarung.
Dialogue: 0,0:11:21.50,0:11:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk tugas berburu, kami tetap serahkan\Npada Kuro dan yang lainnya.
Dialogue: 0,0:11:25.42,0:11:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, kami mulai\Nmembuat ladang di tiap desa.
Dialogue: 0,0:11:28.63,0:11:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tu, wa! Tu, wa!\N- Meski mereka kesulitan berburu,
Dialogue: 0,0:11:30.78,0:11:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebisa mungkin aku menyarankan mereka\Nuntuk bisa mandiri soal pangan, tapi...
Dialogue: 0,0:11:35.78,0:11:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benihnya sulit tumbuh, ya?
Dialogue: 0,0:11:39.46,0:11:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:11:41.74,0:11:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benih ini biasanya ditanam di musim apa?
Dialogue: 0,0:11:45.80,0:11:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah menanam benih, ya.
Dialogue: 0,0:11:47.68,0:11:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim?\NKita biasanya kapan?
Dialogue: 0,0:11:50.36,0:11:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar.
Dialogue: 0,0:11:51.47,0:11:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:11:53.27,0:11:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada alasan kami yang sudah\Nbertahun-tahun bertani
Dialogue: 0,0:11:56.01,0:11:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kebingungan dengan situasi ini.
Dialogue: 0,0:11:59.17,0:12:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa hidup di tengah hutan
Dialogue: 0,0:12:01.49,0:12:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan makan hasil bertani,
Dialogue: 0,0:12:05.00,0:12:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya berkat Alat Bertani Mahabisa\Npemberian dewa.
Dialogue: 0,0:12:09.37,0:12:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengubah tanah menjadi subur,
Dialogue: 0,0:12:12.22,0:12:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menanam benih sesuai yang dibayangkan,
Dialogue: 0,0:12:15.05,0:12:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan sampai mempercepat\Nwaktu tumbuhnya.
Dialogue: 0,0:12:18.20,0:12:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bisa panen tanpa bergantung\Npada musim atau cuaca,
Dialogue: 0,0:12:21.75,0:12:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa hidup bersama\Nbanyak orang sampai sekarang.
Dialogue: 0,0:12:25.40,0:12:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekurangannya, hanya aku\Nyang bisa menggunakan alat itu.
Dialogue: 0,0:12:29.14,0:12:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi kewalahan\Nsoal menanam dan mengolah.
Dialogue: 0,0:12:31.22,0:12:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, luas sekali!
Dialogue: 0,0:12:34.59,0:12:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi di desa baru,
Dialogue: 0,0:12:36.32,0:12:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin mereka bertani
Dialogue: 0,0:12:37.83,0:12:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa bergantung pada alat itu.
Dialogue: 0,0:12:40.16,0:12:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak semudah yang dibayangkan, ya.
Dialogue: 0,0:12:42.78,0:12:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita coba banyak cara.
Dialogue: 0,0:12:44.79,0:12:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:12:46.50,0:12:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}coba dialas dengan jerami
Dialogue: 0,0:12:48.47,0:12:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar tidak dingin dan bisa tumbuh.
Dialogue: 0,0:12:52.35,0:12:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi musim dingin,
Dialogue: 0,0:12:53.88,0:12:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau mau menanam gandum,\Nsebaiknya sekarang.
Dialogue: 0,0:12:56.98,0:12:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu banyak hal, ya.
Dialogue: 0,0:12:58.55,0:13:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak seberapa.
Dialogue: 0,0:13:00.03,0:13:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya pernah membantu\Ndi ladang desa sebelumnya.
Dialogue: 0,0:13:03.63,0:13:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah pengalaman, ya!
Dialogue: 0,0:13:05.66,0:13:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Senior dalam bertani!\N- Kami lanjut membuat ladang
Dialogue: 0,0:13:07.05,0:13:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Senior!\N- sambil mendengar
Dialogue: 0,0:13:08.68,0:13:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Senior! Senior!\Nsaran dari Gordon.
Dialogue: 0,0:13:10.73,0:13:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanam gandumnya sekarang,\Nlalu panen sebelum musim panas tiba.
Dialogue: 0,0:13:17.42,0:13:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setengah tahun, ya.\NMenunggunya akan lama, ya.
Dialogue: 0,0:13:21.10,0:13:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kita sudah terbiasa\Ncara bertani di Desa Pohon Besar.
Dialogue: 0,0:13:24.11,0:13:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:26.01,0:13:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menanam nanas di tempat bersalju
Dialogue: 0,0:13:28.97,0:13:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jelas bukan hal biasa.
Dialogue: 0,0:13:31.62,0:13:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, aku bersyukur pada dewa\Nyang memberiku Alat Bertani Mahabisa.
Dialogue: 0,0:13:36.17,0:13:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:13:37.83,0:13:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini patung Dewa Pencipta\Ndan Dewa Pertanian.
Dialogue: 0,0:13:42.03,0:13:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencanaku membuat kuil kecil\Nuntuk tempat sembah.
Dialogue: 0,0:13:45.36,0:13:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tolong lakukan.
Dialogue: 0,0:13:49.82,0:13:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini patung yang luar biasa, ya.
Dialogue: 0,0:13:51.91,0:13:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang pegang tongkat itu Dewa Pencipta
Dialogue: 0,0:13:54.77,0:13:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan yang di sebelahnya?
Dialogue: 0,0:13:56.17,0:13:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon itu Dewa Pertanian.
Dialogue: 0,0:13:58.31,0:14:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, penafsirannya cukup unik, ya.
Dialogue: 0,0:14:00.92,0:14:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:01.70,0:14:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung tempatnya,\Ngambaran tentang dewa juga berbeda.
Dialogue: 0,0:14:07.62,0:14:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isekai Nonbiri Nouka 2.
Dialogue: 0,0:14:12.74,0:14:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat Minotaurus aktif sebagai\Npenanggung jawab mengurus ladang...
Dialogue: 0,0:14:16.21,0:14:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertinggal!
Dialogue: 0,0:14:17.75,0:14:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:14:18.63,0:14:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Centaurus juga membuat pekerjaan baru\Ndengan kemampuan mereka.
Dialogue: 0,0:14:24.00,0:14:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengurus pengiriman antardesa.
Dialogue: 0,0:14:26.47,0:14:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau disebut layanan kurir Centaurus.
Dialogue: 0,0:14:29.06,0:14:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sulit berburu di hutan,
Dialogue: 0,0:14:31.21,0:14:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kecepatan mereka melebihi monster.
Dialogue: 0,0:14:34.23,0:14:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Centaurus dewasa
Dialogue: 0,0:14:36.88,0:14:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diberi tugas mengantar barang secara rutin.
Dialogue: 0,0:14:45.11,0:14:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekor baru di rute ini!
Dialogue: 0,0:14:50.59,0:14:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita terlalu ngebut.
Dialogue: 0,0:14:52.60,0:14:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong utamakan keselamatan.
Dialogue: 0,0:14:57.00,0:14:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades.
Dialogue: 0,0:14:58.25,0:15:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh minta waktunya sebentar?
Dialogue: 0,0:15:00.24,0:15:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:01.26,0:15:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di desa ini,\Naku lihat ada kuda di peternakan.
Dialogue: 0,0:15:05.40,0:15:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, memang ada.
Dialogue: 0,0:15:07.26,0:15:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedagang Michael membawanya
Dialogue: 0,0:15:09.58,0:15:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekalian dengan kambing dan ayam.
Dialogue: 0,0:15:12.78,0:15:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya dari dulu aku\Ningin sekali menunggang kuda.
Dialogue: 0,0:15:16.27,0:15:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:15:17.98,0:15:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:15:19.27,0:15:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, ini wortel!
Dialogue: 0,0:15:22.53,0:15:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sama sekali tak mau menurut.
Dialogue: 0,0:15:25.81,0:15:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu bisa bicara dengan kuda,
Dialogue: 0,0:15:27.92,0:15:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa bantu aku agar bisa\Nmenungganginya sekali saja?
Dialogue: 0,0:15:31.69,0:15:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak paham bahasa kuda.
Dialogue: 0,0:15:36.20,0:15:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:15:37.84,0:15:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau itu bukan kudamu...
Dialogue: 0,0:15:47.58,0:15:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku sudah naik.
Dialogue: 0,0:15:49.47,0:15:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, permisi.
Dialogue: 0,0:15:55.99,0:15:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi sekali, ya!
Dialogue: 0,0:15:58.24,0:15:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, pegang bahuku.
Dialogue: 0,0:15:59.92,0:16:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:00.79,0:16:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegang yang erat, ya.
Dialogue: 0,0:16:05.37,0:16:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, goyang, ya.
Dialogue: 0,0:16:07.80,0:16:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percepat sedikit, ya.
Dialogue: 0,0:16:09.22,0:16:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:14.33,0:16:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:16:15.20,0:16:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:16:17.33,0:16:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:16:19.48,0:16:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya pertama kali naik di atas punggung?
Dialogue: 0,0:16:21.84,0:16:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini terbaik.
Dialogue: 0,0:16:28.62,0:16:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tiba-tiba begitu?
Dialogue: 0,0:16:31.17,0:16:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu sudah tahu\Ncara membawa orang?
Dialogue: 0,0:16:34.75,0:16:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, maju!
Dialogue: 0,0:16:37.20,0:16:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, bagus! Teruskan!
Dialogue: 0,0:16:42.37,0:16:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak...
Dialogue: 0,0:16:44.46,0:16:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu anak baik.
Dialogue: 0,0:16:46.64,0:16:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, bagus.
Dialogue: 0,0:16:49.65,0:16:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:54.72,0:16:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kelihatannya kamu senang, ya.
Dialogue: 0,0:16:56.57,0:16:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:17:02.11,0:17:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Kades!\NPagi ini segar, ya!
Dialogue: 0,0:17:07.59,0:17:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang apa?
Dialogue: 0,0:17:09.07,0:17:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan naik ke punggungku!\NKamu mau pergi, kan?
Dialogue: 0,0:17:12.51,0:17:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti bahaya kalau naik\Nkuda tak jelas seperti dia!
Dialogue: 0,0:17:17.52,0:17:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kuda kami.
Dialogue: 0,0:17:18.89,0:17:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat! Bahaya!
Dialogue: 0,0:17:20.15,0:17:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tenangkan dirimu.
Dialogue: 0,0:17:21.52,0:17:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai dan harus akur.
Dialogue: 0,0:17:24.20,0:17:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Harus akrab, ya!\N- Itu tarian apa?
Dialogue: 0,0:17:26.82,0:17:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pasti bisa!
Dialogue: 0,0:17:29.33,0:17:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti repot kalau tiap pagi terus menunggu.
Dialogue: 0,0:17:32.28,0:17:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya jadi gantian menunggangi mereka.
Dialogue: 0,0:17:40.70,0:17:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu!
Dialogue: 0,0:17:42.00,0:17:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian ada kesulitan\Natau butuh bantuan?
Dialogue: 0,0:17:47.21,0:17:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, mungkin kalian butuh sesuatu\Natau ada yang belum paham.
Dialogue: 0,0:17:51.96,0:17:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan bilang dan jangan sungkan!
Dialogue: 0,0:17:55.35,0:17:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langit.
Dialogue: 0,0:17:56.46,0:17:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:17:59.11,0:18:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biru.
Dialogue: 0,0:18:00.14,0:18:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!\NCuacanya bagus, ya!
Dialogue: 0,0:18:08.29,0:18:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akar tanaman panjangnya\Nbisa tumbuh di luar perkiraan,
Dialogue: 0,0:18:11.59,0:18:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi bagusnya tanahnya dibajak agak dalam.
Dialogue: 0,0:18:13.92,0:18:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap, Senior Gordon!
Dialogue: 0,0:18:15.62,0:18:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya berjalan lancar, ya.
Dialogue: 0,0:18:17.80,0:18:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:19.57,0:18:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku cemas karena\Nbanyak pendatang datang sekaligus.
Dialogue: 0,0:18:24.72,0:18:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisinya?
Dialogue: 0,0:18:25.97,0:18:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehat.
Dialogue: 0,0:18:27.87,0:18:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga nantinya tiap desa\Nbisa hidup mandiri.
Dialogue: 0,0:18:32.74,0:18:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang semuanya masih bergantung padamu.
Dialogue: 0,0:18:35.54,0:18:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak keberatan.
Dialogue: 0,0:18:37.51,0:18:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi baiknya, mereka bisa\Nmenyelesaikan keperluannya sendiri.
Dialogue: 0,0:18:42.71,0:18:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:44.15,0:18:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terlalu bergantung pada\NAlat Bertani Mahabisa,
Dialogue: 0,0:18:47.33,0:18:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke depannya bisa jadi masalah.
Dialogue: 0,0:18:49.99,0:18:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dewa, sekarang kami bisa hidup sehat.
Dialogue: 0,0:18:56.86,0:19:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari, bisa saja aku sakit\Ndan susah bangun.
Dialogue: 0,0:19:03.27,0:19:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusan nanti, ya hadapi nanti.
Dialogue: 0,0:19:07.11,0:19:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada memikirkan banyak hal,
Dialogue: 0,0:19:09.07,0:19:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hari kamu bisa santai pensiun itu\Nmasih lama.
Dialogue: 0,0:19:13.72,0:19:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu cemas.
Dialogue: 0,0:19:17.31,0:19:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:19:18.83,0:19:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:20.61,0:19:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:19:26.19,0:19:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:19:28.57,0:19:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bau.\NKamu sengaja beol, ya.
Dialogue: 0,0:19:31.53,0:19:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kita ganti popoknya!
Dialogue: 0,0:19:35.34,0:19:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku memikirkan masa depan\Nyang biasanya jarang kulakukan,
Dialogue: 0,0:19:39.22,0:19:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi ingat ada masalah penting\Nyang belum diselesaikan.
Dialogue: 0,0:19:43.65,0:19:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Desa Pohon Besar kami,
Dialogue: 0,0:19:45.71,0:19:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada banyak sekali wanita.
Dialogue: 0,0:19:48.08,0:19:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak, intinya sangat banyak!
Dialogue: 0,0:19:52.09,0:19:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara itu,
Dialogue: 0,0:19:53.34,0:19:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}prianya sedikit.
Dialogue: 0,0:19:55.23,0:19:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa depan desa jadi mengkhawatirkan.
Dialogue: 0,0:19:58.09,0:20:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku mencoba\Nmerekrut pendatang pria.
Dialogue: 0,0:20:01.10,0:20:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak berjalan lancar.
Dialogue: 0,0:20:03.70,0:20:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sekarang ada banyak pendatang!
Dialogue: 0,0:20:06.69,0:20:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya ini bisa menghilangkan\Nkekhawatiran di masa depan!
Dialogue: 0,0:20:09.72,0:20:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria, ya.
Dialogue: 0,0:20:12.44,0:20:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kelompok kami, ada 28 pria.
Dialogue: 0,0:20:16.83,0:20:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya!
Dialogue: 0,0:20:18.89,0:20:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, ini soal kekuatan militer?
Dialogue: 0,0:20:21.62,0:20:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kami juga akan dikerahkan\Nuntuk bertarung?
Dialogue: 0,0:20:25.80,0:20:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan untuk itu.
Dialogue: 0,0:20:27.62,0:20:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, begini dan begitu.
Dialogue: 0,0:20:30.25,0:20:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjelasannya panjang!
Dialogue: 0,0:20:32.50,0:20:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:20:33.88,0:20:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kami Minotaurus
Dialogue: 0,0:20:36.94,0:20:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biasanya menikah dengan ras yang sama.
Dialogue: 0,0:20:40.22,0:20:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena perbedaan ukuran\Ntubuhnya terlalu jauh.
Dialogue: 0,0:20:43.26,0:20:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu masalahnya, ya.
Dialogue: 0,0:20:45.95,0:20:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, Minotaurus hanya bisa
Dialogue: 0,0:20:49.63,0:20:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan ras yang sama.\Nmembangun keluarga bahagia
Dialogue: 0,0:20:52.52,0:20:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya Centaurus.
Dialogue: 0,0:20:54.69,0:20:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menanyakan hal seperti ini\Nke wanita agak sulit,
Dialogue: 0,0:20:57.34,0:20:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini demi masa depan desa!
Dialogue: 0,0:20:59.78,0:21:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria, ya?
Dialogue: 0,0:21:02.51,0:21:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kami, ada 30 pria.
Dialogue: 0,0:21:05.86,0:21:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi semuanya masih anak-anak.
Dialogue: 0,0:21:08.19,0:21:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dewasa sedang pergi berperang.
Dialogue: 0,0:21:10.68,0:21:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:21:12.02,0:21:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski anak-anak, setidaknya ada pria.
Dialogue: 0,0:21:15.40,0:21:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini sulit kamu jawab,
Dialogue: 0,0:21:17.30,0:21:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini masalah penting\Ndan aku harus tahu.
Dialogue: 0,0:21:21.05,0:21:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pernikahan ras Centaurus.
Dialogue: 0,0:21:23.18,0:21:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih lajang!
Dialogue: 0,0:21:25.03,0:21:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kesampingkan dulu statusmu!
Dialogue: 0,0:21:27.29,0:21:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Centaurus bisa menikah dengan ras lain?
Dialogue: 0,0:21:31.55,0:21:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, biasanya tidak bisa.
Dialogue: 0,0:21:33.99,0:21:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbedaan ras memang jadi penghalang, ya.
Dialogue: 0,0:21:36.89,0:21:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, Centaurus\Nsulit berpasangan dengan ras lain.
Dialogue: 0,0:21:42.13,0:21:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:21:43.52,0:21:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kamu meminta kami menyerahkan\Nwanita sebagai syarat di sini...
Dialogue: 0,0:21:47.64,0:21:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, maksudku bukan itu.
Dialogue: 0,0:21:49.66,0:21:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ambil aku!\NAku sudah siap!
Dialogue: 0,0:21:52.78,0:21:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:53.83,0:21:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak minta hal seperti itu,\Ntenang saja.
Dialogue: 0,0:21:56.72,0:21:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:58.21,0:22:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah pria suka\Nmenaklukkan wanita tangguh?
Dialogue: 0,0:22:02.15,0:22:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat info itu dari mana?
Dialogue: 0,0:22:03.70,0:22:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, tenang dulu.
Dialogue: 0,0:22:05.70,0:22:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu tarian apa?\N- Tenang dan santai.
Dialogue: 0,0:22:06.97,0:22:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semoga Centaurus juga bisa bahagia\N- Napas pelan-pelan, ya.
Dialogue: 0,0:22:09.35,0:22:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dengan Centaurus lainnya.\N- Napas pelan-pelan, ya.
Dialogue: 0,0:22:11.48,0:22:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu lebih suka yang galak?
Dialogue: 0,0:22:13.84,0:22:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan soal selera!
