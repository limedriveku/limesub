Dialogue: 0,0:00:11.49,0:00:17.16,tanda,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:02:00.09,0:02:04.27,tanda,,0000,0000,0000,,DUNGEON UTARA BAWAH TANAH
Dialogue: 0,0:02:34.80,0:02:36.84,tanda,,0000,0000,0000,,RAHASIA BLOODY VIPER
Dialogue: 0,0:02:36.84,0:02:39.31,tanda,,0000,0000,0000,,ISINYA TULANG RUSUK SEMUA
Dialogue: 0,0:03:26.97,0:03:30.48,tanda,,0000,0000,0000,,SARANG ULAR PEMBUNUH
Dialogue: 0,0:03:30.48,0:03:31.23,tanda,,0000,0000,0000,,JAUH DI DALAM HUTAN KEMATIAN\NADA RAS RAKSASA MISTERIUS!
Dialogue: 0,0:03:58.43,0:04:00.51,tanda,,0000,0000,0000,,ONSEN
Dialogue: 0,0:04:19.02,0:04:35.80,tanda,,0000,0000,0000,,TIM PENCARI ONSEN
Dialogue: 0,0:05:12.11,0:05:15.53,tanda,,0000,0000,0000,,RAS RAKSASA, KE DESA POHON BESAR
Dialogue: 0,0:05:15.53,0:05:17.46,tanda,,0000,0000,0000,,DATANG UNTUK MENYAPA!
Dialogue: 0,0:08:07.26,0:08:08.76,tanda,,0000,0000,0000,,GANTI PAKAIAN
Dialogue: 0,0:09:39.48,0:09:42.23,tanda,,0000,0000,0000,,TIM PENCARI LUBANG, TIM PENCARI ONSEN
Dialogue: 0,0:12:03.08,0:12:08.48,tanda,,0000,0000,0000,,HOT STONE (BATU PANAS)
Dialogue: 0,0:12:08.48,0:12:10.92,tanda,,0000,0000,0000,,PANAS
Dialogue: 0,0:14:15.54,0:14:18.03,tanda,,0000,0000,0000,,SUNGAI, MATA AIR
Dialogue: 0,0:14:18.03,0:14:18.55,tanda,,0000,0000,0000,,DINGIN, PANAS
Dialogue: 0,0:14:18.55,0:14:20.30,tanda,,0000,0000,0000,,HANGAT
Dialogue: 0,0:15:53.52,0:15:59.98,tanda,,0000,0000,0000,,SEMENTARA ITU
Dialogue: 0,0:18:29.42,0:18:31.88,tanda,,0000,0000,0000,,ONSEN PRIA, ONSEN WANITA
Dialogue: 0,0:18:31.88,0:18:33.84,tanda,,0000,0000,0000,,AREA ISTIRAHAT, RUANG GANTI
Dialogue: 0,0:18:33.84,0:18:35.43,tanda,,0000,0000,0000,,KOLAM PENAMPUNGAN, TOILET, GUBUK
Dialogue: 0,0:23:45.99,0:23:50.99,tanda,,0000,0000,0000,,SELANJUTNYA:\NEPISODE 8: LANJUTAN: TIM PENCARI ONSEN
Dialogue: 0,0:01:54.45,0:01:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah kembali.
Dialogue: 0,0:01:57.14,0:01:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali.\NKerja bagus.
Dialogue: 0,0:02:00.09,0:02:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Pencari kembali dari dungeon utara
Dialogue: 0,0:02:02.17,0:02:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ditemukan sebelumnya.
Dialogue: 0,0:02:04.27,0:02:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:02:08.02,0:02:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil buruannya luar biasa, ya.
Dialogue: 0,0:02:09.55,0:02:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kita dapat banyak.
Dialogue: 0,0:02:11.31,0:02:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang!
Dialogue: 0,0:02:15.76,0:02:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:02:16.78,0:02:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:02:18.55,0:02:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangannya mewah, ya.
Dialogue: 0,0:02:23.79,0:02:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya bikin nagih.
Dialogue: 0,0:02:26.77,0:02:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betulan nagih, ya.
Dialogue: 0,0:02:28.80,0:02:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan yang banyak, ya.
Dialogue: 0,0:02:30.59,0:02:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ann dan yang lainnya sudah\Nsusah payah memasaknya.
Dialogue: 0,0:02:33.23,0:02:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:02:34.80,0:02:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, ular itu
Dialogue: 0,0:02:36.84,0:02:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau dipotong bagian mana pun,
Dialogue: 0,0:02:38.15,0:02:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}isinya tulang rusuk semua.
Dialogue: 0,0:02:39.31,0:02:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena hasil buruannya banyak,\Nsementara kita makan ular.
Dialogue: 0,0:02:42.77,0:02:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, katanya tak perlu dimakan buru-buru.
Dialogue: 0,0:02:45.56,0:02:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vitalitasnya kuat,\Ndagingnya juga tak gampang busuk.
Dialogue: 0,0:02:49.79,0:02:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bloody Viper itu, kalau kepalanya\Nmasih utuh, tubuhnya bisa pulih.
Dialogue: 0,0:02:55.15,0:02:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sulit membayangkan situasi seperti itu.
Dialogue: 0,0:02:57.95,0:03:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, apa Bloody Viper-nya\Nmasih banyak untuk bisa kita buru?
Dialogue: 0,0:03:01.71,0:03:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, untuk ukuran besar,\Nsudah tak ada lagi.
Dialogue: 0,0:03:05.56,0:03:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan mengganggu\Nrencana kebangkitan ras kita!
Dialogue: 0,0:03:07.83,0:03:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kalahkan mereka dengan cepat, ya.
Dialogue: 0,0:03:10.07,0:03:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pemanasan pun masih kurang.
Dialogue: 0,0:03:12.21,0:03:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lebih baik begitu daripada bahaya.
Dialogue: 0,0:03:14.97,0:03:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kalian berdua,
Dialogue: 0,0:03:16.60,0:03:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami juga berhasil menyelamatkan warga\Nyang diserang Bloody Viper.
Dialogue: 0,0:03:20.84,0:03:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ada yang tinggal di dungeon?
Dialogue: 0,0:03:22.61,0:03:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, konon mereka ras\Nyang disebut Raksasa.
Dialogue: 0,0:03:25.68,0:03:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:03:26.97,0:03:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mirip acara eksplorasi hutan belantara!
Dialogue: 0,0:03:31.89,0:03:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dipikir,
Dialogue: 0,0:03:33.97,0:03:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang aku hidup di dunia\Nyang jauh lebih aneh
Dialogue: 0,0:03:37.33,0:03:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari acara TV yang dulu kutonton\Ndi rumah sakit.
Dialogue: 0,0:03:41.13,0:03:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, ada hal aneh lainnya?
Dialogue: 0,0:03:43.59,0:03:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal langka?
Dialogue: 0,0:03:45.65,0:03:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langka tidaknya, kami tidak tahu,
Dialogue: 0,0:03:47.71,0:03:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi menurut ras Raksasa, di utara dungeon\Nada tempat yang menyemburkan air panas.
Dialogue: 0,0:03:52.81,0:03:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air panas?
Dialogue: 0,0:03:55.49,0:03:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:04:00.51,0:04:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera menyelidikinya!
Dialogue: 0,0:04:02.26,0:04:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya pergi ke tempat mata air itu?
Dialogue: 0,0:04:05.02,0:04:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau air, kita sudah punya cukup banyak.
Dialogue: 0,0:04:08.02,0:04:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:04:09.57,0:04:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen itu khusus!
Dialogue: 0,0:04:11.54,0:04:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen itu,
Dialogue: 0,0:04:13.19,0:04:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu hal yang sehat dan berbudaya,\Nbukan cuma air panas biasa,
Dialogue: 0,0:04:16.32,0:04:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga bagus untuk peredaran darah!
Dialogue: 0,0:04:19.02,0:04:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah membujuk semuanya,
Dialogue: 0,0:04:21.14,0:04:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Pencari Onsen pun dibentuk.
Dialogue: 0,0:04:23.89,0:04:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga ikut? Tumben.
Dialogue: 0,0:04:26.73,0:04:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu, ya?
Dialogue: 0,0:04:28.67,0:04:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir kamu tak suka pergi keluar.
Dialogue: 0,0:04:31.48,0:04:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:04:33.69,0:04:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma sibuk saja.
Dialogue: 0,0:04:36.21,0:04:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Desa Dua dan Desa Tiga\Njuga sudah stabil,
Dialogue: 0,0:04:39.24,0:04:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi sedikit penasaran\Ndengan tempat baru.
Dialogue: 0,0:04:43.30,0:04:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit, ya?
Dialogue: 0,0:04:45.06,0:04:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai minta kostum ke Zabuton.
Dialogue: 0,0:04:47.56,0:04:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan langka!\NKita juga Tim Pencari!
Dialogue: 0,0:04:49.96,0:04:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada onsen di daerah terpencil\Ndan ras Raksasa!
Dialogue: 0,0:04:52.43,0:04:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus buat persiapan matang!
Dialogue: 0,0:04:54.36,0:04:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa kurang etis kita mendatangi mereka?
Dialogue: 0,0:04:57.52,0:05:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke sana itu Kades.\NTerlebih, yang datang langsung
Dialogue: 0,0:05:02.09,0:05:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya kita sapa mereka dulu?
Dialogue: 0,0:05:04.89,0:05:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau minta mereka datang ke sini,\Nkesannya kurang sopan.
Dialogue: 0,0:05:08.87,0:05:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalau mereka yang datang,
Dialogue: 0,0:05:12.11,0:05:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nuansa spesial Tim Pencari jadi berkurang.
Dialogue: 0,0:05:15.53,0:05:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spesial?
Dialogue: 0,0:05:17.46,0:05:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, kita tidak tahu\Napa yang menunggu di depan!
Dialogue: 0,0:05:21.13,0:05:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga keselamatan itu prioritas!
Dialogue: 0,0:05:22.72,0:05:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jadi tak sabar, ya.
Dialogue: 0,0:05:25.10,0:05:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leluhur, sejak kapan kamu ada di sini?
Dialogue: 0,0:05:27.48,0:05:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kemari ingin lihat\Npatung Dewa Pencipta,
Dialogue: 0,0:05:30.55,0:05:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalian sepertinya\Nmenemukan hal seru, ya?
Dialogue: 0,0:05:32.80,0:05:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku juga boleh ikut?
Dialogue: 0,0:05:34.36,0:05:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, boleh.
Dialogue: 0,0:05:37.16,0:05:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, Tim Pencari Onsen, berangkat!
Dialogue: 0,0:05:40.33,0:05:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:05:42.36,0:05:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita pakai sihir teleportasi.
Dialogue: 0,0:05:44.68,0:05:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Iya.
Dialogue: 0,0:05:53.25,0:05:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata lumayan menegangkan, ya.
Dialogue: 0,0:05:56.01,0:05:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aman, pelan-pelan keluarnya.
Dialogue: 0,0:06:02.49,0:06:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini sihir teleportasi?\NLangsung pindah tempat dalam sekejap.
Dialogue: 0,0:06:06.51,0:06:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:06:07.19,0:06:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oh, gampang.\N- Betulan sampai dalam sekejap.
Dialogue: 0,0:06:10.25,0:06:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, jalan kaki ke sini memang mustahil.
Dialogue: 0,0:06:13.24,0:06:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunungnya terasa sangat dekat,\Nsuasananya pun beda kalau dari dekat desa.
Dialogue: 0,0:06:18.07,0:06:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah keluar?
Dialogue: 0,0:06:19.51,0:06:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:06:20.29,0:06:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:21.78,0:06:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunung batu itu...\Natau gunung dari batu itu apa?
Dialogue: 0,0:06:26.51,0:06:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pintu masuk dungeon-nya!
Dialogue: 0,0:06:28.45,0:06:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, apa kita bisa langsung\Nketemu ras Raksasa?
Dialogue: 0,0:06:33.93,0:06:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:06:36.03,0:06:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mendekat...
Dialogue: 0,0:06:39.60,0:06:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ras Raksasa...
Dialogue: 0,0:06:41.81,0:06:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:42.67,0:06:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata mereka berbulu.
Dialogue: 0,0:06:44.60,0:06:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkah mereka terlihat aneh.\NSeperti sedang panik.
Dialogue: 0,0:06:47.93,0:06:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, aku ingin bicara sebentar.
Dialogue: 0,0:06:51.81,0:06:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka dalam masalah, ya.
Dialogue: 0,0:06:55.36,0:06:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:06:58.64,0:07:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bloody Viper!
Dialogue: 0,0:07:00.44,0:07:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang besar harusnya sudah kami kalahkan!
Dialogue: 0,0:07:02.76,0:07:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi masih ada, ya!
Dialogue: 0,0:07:08.15,0:07:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:15.67,0:07:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:07:16.65,0:07:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Earth Rat!
Dialogue: 0,0:07:17.83,0:07:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati!
Dialogue: 0,0:07:35.10,0:07:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, terpental jauh, ya.
Dialogue: 0,0:07:37.69,0:07:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini agak berlebihan.
Dialogue: 0,0:07:45.53,0:07:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada lagi?
Dialogue: 0,0:07:53.49,0:07:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:07:57.80,0:07:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah.
Dialogue: 0,0:07:59.67,0:08:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kamu lengket.
Dialogue: 0,0:08:03.88,0:08:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menolong kami.
Dialogue: 0,0:08:07.26,0:08:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:08:09.32,0:08:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dilihat lagi, sosok raksasa mereka\Nmirip kostum acara bocah.
Dialogue: 0,0:08:15.19,0:08:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Earth Rat tadi\Nbanyak di sekitar sini?
Dialogue: 0,0:08:19.40,0:08:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, biasanya kami jarang lihat mereka.
Dialogue: 0,0:08:22.27,0:08:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian dungeon\Ntempat kami tinggal runtuh,
Dialogue: 0,0:08:25.93,0:08:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu mereka keluar dari lubang itu.
Dialogue: 0,0:08:28.01,0:08:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Runtuh?\NEarth Rat yang melakukannya?
Dialogue: 0,0:08:30.52,0:08:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, saat Bloody Viper\Ndikalahkan beberapa hari lalu...
Dialogue: 0,0:08:35.28,0:08:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akibat dari pertarungan itu...
Dialogue: 0,0:08:37.36,0:08:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu...
Dialogue: 0,0:08:40.41,0:08:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham situasinya.
Dialogue: 0,0:08:42.54,0:08:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya wargaku membuat masalah.
Dialogue: 0,0:08:47.47,0:08:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan kami.
Dialogue: 0,0:08:49.18,0:08:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung saja kami kebetulan ada di sini.
Dialogue: 0,0:08:52.05,0:08:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, situasi ini bisa lebih parah.
Dialogue: 0,0:08:54.71,0:08:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan begitu, angkat kepalamu!
Dialogue: 0,0:08:59.59,0:09:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan salah mereka.
Dialogue: 0,0:09:02.04,0:09:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tak runtuh pun, cepat atau lambat\Nkami pasti akan bertemu mereka.
Dialogue: 0,0:09:08.80,0:09:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sekarang bagaimana?
Dialogue: 0,0:09:10.99,0:09:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ras Raksasa bilang ini bukan salah kita,
Dialogue: 0,0:09:15.04,0:09:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kita tak bisa membiarkan lubang itu\Njadi jalan keluar monster berbahaya.
Dialogue: 0,0:09:18.70,0:09:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya menutup lubangnya,\Nmereka akan menggali lagi.
Dialogue: 0,0:09:22.67,0:09:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik kita basmi dengan benar.
Dialogue: 0,0:09:25.23,0:09:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang pergi.
Dialogue: 0,0:09:27.91,0:09:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu akan sangat membantu.
Dialogue: 0,0:09:30.13,0:09:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:09:32.76,0:09:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:09:35.11,0:09:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil musyawarah.
Dialogue: 0,0:09:36.97,0:09:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memutuskan untuk membagi kelompok,
Dialogue: 0,0:09:39.48,0:09:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Pencari Lubang dan Pencari Onsen.
Dialogue: 0,0:09:42.69,0:09:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami pergi dulu.
Dialogue: 0,0:09:44.87,0:09:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku sebaiknya ikut Tim Pencari Lubang?
Dialogue: 0,0:09:48.44,0:09:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu,\Ntujuan awalmu kan mencari onsen.
Dialogue: 0,0:09:52.92,0:09:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus saja pada tujuanmu.
Dialogue: 0,0:09:56.74,0:09:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:09:58.64,0:10:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka akan baik-baik saja?
Dialogue: 0,0:10:05.88,0:10:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh.
Dialogue: 0,0:10:09.31,0:10:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena dekat gunung,\Nmedan di sini juga naik turun.
Dialogue: 0,0:10:15.76,0:10:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita sudah dekat\Ndengan sumber airnya.
Dialogue: 0,0:10:18.53,0:10:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara airnya mulai terdengar jelas!
Dialogue: 0,0:10:21.52,0:10:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Granmaria sedang mencari\Nlokasi tepatnya dari atas,
Dialogue: 0,0:10:25.61,0:10:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita berangkat setelah dia kembali...
Dialogue: 0,0:10:29.15,0:10:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu di pohon ini?
Dialogue: 0,0:10:37.41,0:10:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bekas cakar, kan?
Dialogue: 0,0:10:39.28,0:10:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada di ketinggian seperti itu...
Dialogue: 0,0:10:41.68,0:10:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti?
Dialogue: 0,0:10:43.09,0:10:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang membuat bekas cakar itu\Nmonster yang sangat besar.
Dialogue: 0,0:10:52.28,0:10:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang!
Dialogue: 0,0:10:56.73,0:10:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu,\Nsebentar lagi kita sampai tujuan...
Dialogue: 0,0:10:59.56,0:11:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, apa ini?
Dialogue: 0,0:11:01.62,0:11:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kades yang melakukannya.
Dialogue: 0,0:11:03.36,0:11:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin kaget saja.
Dialogue: 0,0:11:09.40,0:11:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mirip seperti onsen, tapi...
Dialogue: 0,0:11:12.17,0:11:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya sangat panas, ya.
Dialogue: 0,0:11:13.95,0:11:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ragu menyentuhnya, ya.
Dialogue: 0,0:11:17.55,0:11:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uap yang naik sepertinya tidak beracun.
Dialogue: 0,0:11:20.31,0:11:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ada kemungkinan keluar gas beracun?\NAku malah kurang waspada.
Dialogue: 0,0:11:26.29,0:11:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:11:27.21,0:11:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa airnya sepanas ini?
Dialogue: 0,0:11:30.60,0:11:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada gunung berapi\Nmeletus di dekat sini?
Dialogue: 0,0:11:32.85,0:11:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bukan karena itu.
Dialogue: 0,0:11:35.16,0:11:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena sifat batu di sekitar sini.
Dialogue: 0,0:11:38.07,0:11:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifat batu?
Dialogue: 0,0:11:39.13,0:11:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ayo kita coba.
Dialogue: 0,0:11:48.35,0:11:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba sentuh.
Dialogue: 0,0:11:50.07,0:11:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, pasti panas, kan?
Dialogue: 0,0:11:52.49,0:11:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat sendiri...
Dialogue: 0,0:11:53.97,0:11:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas!
Dialogue: 0,0:11:55.09,0:11:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak panas?
Dialogue: 0,0:11:58.57,0:12:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah pelan-pelan jadi hangat.
Dialogue: 0,0:12:00.32,0:12:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hot Stone, ya?
Dialogue: 0,0:12:02.24,0:12:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:03.08,0:12:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu ini punya sifat menyimpan panas
Dialogue: 0,0:12:05.36,0:12:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diterimanya lalu melepasnya perlahan.
Dialogue: 0,0:12:08.48,0:12:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi air matanya tetap panas, ya?
Dialogue: 0,0:12:10.92,0:12:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon bagus juga untuk menghangatkan\Nbadan saat musim dingin.
Dialogue: 0,0:12:14.85,0:12:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghangat, ya?
Dialogue: 0,0:12:16.04,0:12:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bisa dipakai untuk rumah kaca\Natau penghangat makanan juga.
Dialogue: 0,0:12:18.97,0:12:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat mata airnya sudah ketemu,\Nsetelah ini apa?
Dialogue: 0,0:12:23.88,0:12:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:12:26.12,0:12:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada sumber air dingin di dekat sini?
Dialogue: 0,0:12:28.33,0:12:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sungai.
Dialogue: 0,0:12:29.98,0:12:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:12:31.25,0:12:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mungkin ini bisa berhasil.
Dialogue: 0,0:12:49.96,0:12:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu atau tidak, ya?
Dialogue: 0,0:12:52.02,0:12:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada atau tidak, sama saja.
Dialogue: 0,0:12:55.32,0:12:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, hentikan!\NKalau begitu terus, aku sulit bernapas!
Dialogue: 0,0:13:01.64,0:13:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas!
Dialogue: 0,0:13:03.25,0:13:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa terpanggang!
Dialogue: 0,0:13:06.75,0:13:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Padamkan apinya!\N- Kalau begini terus,
Dialogue: 0,0:13:09.12,0:13:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siapa pun!\N- kita yang akan matang duluan.
Dialogue: 0,0:13:10.52,0:13:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dengar tidak? Apinya tidak padam!\N- Jadi jangan terlalu sering pakai api.
Dialogue: 0,0:13:14.52,0:13:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apinya nanti menyebar!\N- Iya.
Dialogue: 0,0:13:16.76,0:13:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apinya nanti menyebar!\N- Bukannya tinggal terbang saja?
Dialogue: 0,0:13:20.83,0:13:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, lorong samping\Nyang sudah ada dari awal
Dialogue: 0,0:13:24.16,0:13:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terhubung ke dungeon yang runtuh, ya.
Dialogue: 0,0:13:27.51,0:13:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Earth Rat yang menggalinya?
Dialogue: 0,0:13:29.73,0:13:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tujuan mereka\Nharus terus menggali.
Dialogue: 0,0:13:34.32,0:13:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak belok, lurus terus.
Dialogue: 0,0:13:36.57,0:13:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini barat, yang itu timur, ya?
Dialogue: 0,0:13:39.75,0:13:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, sekarang bagaimana?
Dialogue: 0,0:13:41.80,0:13:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rusty ke sana!
Dialogue: 0,0:13:43.72,0:13:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini!
Dialogue: 0,0:13:46.06,0:13:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kita bagi dua.
Dialogue: 0,0:13:48.75,0:13:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruu dan Flora, pergi ke arah barat, ya.
Dialogue: 0,0:13:51.39,0:13:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:52.59,0:13:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bareng Rusty, ya.
Dialogue: 0,0:13:54.73,0:13:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hati-hati!
Dialogue: 0,0:13:57.13,0:13:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga semuanya selamat.
Dialogue: 0,0:13:58.81,0:14:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga tak ada musuh merepotkan.
Dialogue: 0,0:14:01.75,0:14:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau...
Dialogue: 0,0:14:03.65,0:14:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya ada?
Dialogue: 0,0:14:12.72,0:14:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, sepertinya ini akan berhasil.
Dialogue: 0,0:14:15.54,0:14:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena airnya terlalu panas,
Dialogue: 0,0:14:18.03,0:14:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami campur dengan air sungai.
Dialogue: 0,0:14:18.55,0:14:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami campur dengan air sungai.
Dialogue: 0,0:14:20.86,0:14:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suhunya harusnya bisa diatur dengan mengubah\Njumlah air yang mengalir ke saluran.
Dialogue: 0,0:14:24.93,0:14:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita buat pemandiannya sekarang.
Dialogue: 0,0:14:27.23,0:14:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi onsen itu maksudnya tempat mandi?
Dialogue: 0,0:14:30.07,0:14:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, onsen itu bagus!
Dialogue: 0,0:14:32.44,0:14:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita juga harus buat\Nruang ganti dan area istirahat!
Dialogue: 0,0:14:35.85,0:14:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yahuy, ayo kita mulai!\N- Dia terlihat antusias, ya.
Dialogue: 0,0:14:38.44,0:14:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pemandian,\Ndi desa juga sudah ada yang bagus.
Dialogue: 0,0:14:41.52,0:14:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu buat di tempat jauh begini.
Dialogue: 0,0:14:43.59,0:14:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang dulu pasti akan bilang begitu.
Dialogue: 0,0:14:46.73,0:14:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah tahu nikmatnya mandi,\Naku jadi tak sabar.
Dialogue: 0,0:14:49.61,0:14:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:50.43,0:14:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ketemu!
Dialogue: 0,0:14:53.08,0:14:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupid?
Dialogue: 0,0:14:56.19,0:14:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya ketemu juga!
Dialogue: 0,0:14:57.77,0:14:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa?
Dialogue: 0,0:14:59.17,0:15:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:15:00.09,0:15:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Kades pergi bawa banyak orang.
Dialogue: 0,0:15:03.33,0:15:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingin lihat.
Dialogue: 0,0:15:04.99,0:15:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi cuma penasaran, ya.
Dialogue: 0,0:15:06.27,0:15:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:15:08.01,0:15:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kalian sedang apa?
Dialogue: 0,0:15:11.52,0:15:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kupid!\NKebetulan kamu di sini!
Dialogue: 0,0:15:14.69,0:15:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bantu Tia dan yang lainnya\Nbawa kayu dari seberang sungai?
Dialogue: 0,0:15:17.60,0:15:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa aku harus bantu?
Dialogue: 0,0:15:19.84,0:15:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bantu, kamu pasti\Nakan dapat hal seru.
Dialogue: 0,0:15:23.37,0:15:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kamu\Ncuma ingin memanfaatkanku.
Dialogue: 0,0:16:02.67,0:16:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya lorong ini untuk apa?
Dialogue: 0,0:16:05.43,0:16:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus lurus tak ada ujungnya.
Dialogue: 0,0:16:07.61,0:16:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita masih di bawah Hutan Kematian.\NDilihat dari jaraknya,
Dialogue: 0,0:16:11.56,0:16:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini tak ada makanan,\Ntapi mereka terus menggali?
Dialogue: 0,0:16:16.54,0:16:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan mereka dikendalikan sesuatu?
Dialogue: 0,0:16:19.40,0:16:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya juga tidak ketemu.\NApa sebaiknya kita kembali?
Dialogue: 0,0:16:23.19,0:16:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:24.32,0:16:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, kita tak boleh pulang\Ntanpa tahu apa pun!
Dialogue: 0,0:16:28.05,0:16:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh apa pun yang muncul,\Nharus kita habisi!
Dialogue: 0,0:16:40.76,0:16:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada sesuatu.
Dialogue: 0,0:16:48.49,0:16:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, batu itu terlihat sangat mencurigakan.
Dialogue: 0,0:16:54.37,0:16:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ukiran?
Dialogue: 0,0:16:56.52,0:16:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti tulisan.
Dialogue: 0,0:16:59.08,0:17:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kelihatannya sudah sangat tua.
Dialogue: 0,0:17:01.04,0:17:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma batu?\NTidak ada apa pun?
Dialogue: 0,0:17:03.49,0:17:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita bisa keluar lewat atas sini.
Dialogue: 0,0:17:07.21,0:17:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih baik mundur\Ndan atur ulang strategi.
Dialogue: 0,0:17:11.31,0:17:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Apa itu?
Dialogue: 0,0:17:16.79,0:17:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan, jumlahnya banyak sekali!
Dialogue: 0,0:17:18.92,0:17:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undead?\NIni merepotkan!
Dialogue: 0,0:17:21.48,0:17:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur!
Dialogue: 0,0:17:23.47,0:17:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rusty, jangan pakai api!
Dialogue: 0,0:17:25.10,0:17:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diarahkan ke atas,\Nbukan masalah, kan?
Dialogue: 0,0:17:34.93,0:17:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas itu hutan!\NDasar, hentikan, Rusty!
Dialogue: 0,0:17:43.45,0:17:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:17:48.47,0:17:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:17:49.76,0:17:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tia, bantu padamkan apinya!
Dialogue: 0,0:17:52.12,0:17:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:17:57.39,0:18:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apinya tidak padam!
Dialogue: 0,0:18:05.17,0:18:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apinya sudah padam?
Dialogue: 0,0:18:07.91,0:18:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, kami berhasil padamkan.
Dialogue: 0,0:18:10.12,0:18:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang jangan.
Dialogue: 0,0:18:11.79,0:18:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:18:12.92,0:18:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, lupakan.
Dialogue: 0,0:18:15.16,0:18:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, onsennya berhasil dibuat.
Dialogue: 0,0:18:17.95,0:18:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam ini kita nikmati bersama-sama!
Dialogue: 0,0:18:23.15,0:18:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, bagus.
Dialogue: 0,0:18:25.91,0:18:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski buru-buru, hasilnya lumayan, kan?
Dialogue: 0,0:18:29.42,0:18:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen pria dan wanita sudah dipisah,
Dialogue: 0,0:18:31.88,0:18:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kalian bebas memakainya.
Dialogue: 0,0:18:33.84,0:18:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:18:46.44,0:18:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang terbaik!
Dialogue: 0,0:18:53.17,0:18:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:56.63,0:19:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda dengan yang di dalam ruangan,\Nanginnya segar, ya.
Dialogue: 0,0:19:01.20,0:19:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di desa, kita tak bisa begini.
Dialogue: 0,0:19:03.83,0:19:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau buat gubuk riset di sini juga,
Dialogue: 0,0:19:06.48,0:19:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiap hari aku bisa riset\Nsambil menikmati onsen.
Dialogue: 0,0:19:10.19,0:19:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita sebaiknya pindah desa?
Dialogue: 0,0:19:12.00,0:19:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak harus setiap hari,\Nsesekali ke sini juga bagus.
Dialogue: 0,0:19:25.98,0:19:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas!
Dialogue: 0,0:19:29.92,0:19:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru sebegini sudah menyerah?
Dialogue: 0,0:19:31.91,0:19:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku masih kuat!
Dialogue: 0,0:19:34.17,0:19:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini latihan untuk apa?
Dialogue: 0,0:19:37.61,0:19:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ini bagus untuk kulit.
Dialogue: 0,0:19:40.00,0:19:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:19:41.37,0:19:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan tahan.
Dialogue: 0,0:19:43.76,0:19:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai calon kepala ras Malaikat,
Dialogue: 0,0:19:46.52,0:19:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus dapat suami yang pantas.
Dialogue: 0,0:19:50.33,0:19:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih memikirkan adat itu?
Dialogue: 0,0:19:52.47,0:19:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun adatnya, jangan sampai\Nmenikah dengan pria aneh.
Dialogue: 0,0:19:57.29,0:19:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jujur sekali, ya.
Dialogue: 0,0:19:58.89,0:20:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dapat yang seperti Kades,\Npasti bakal sempurna.
Dialogue: 0,0:20:03.29,0:20:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang sudah terlambat\Nuntuk mendekatinya, ya.
Dialogue: 0,0:20:05.72,0:20:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sayang nyawa.
Dialogue: 0,0:20:09.76,0:20:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sebaiknya menunggu saja.
Dialogue: 0,0:20:11.97,0:20:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putranya Kades.
Dialogue: 0,0:20:13.90,0:20:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kelewat parah!
Dialogue: 0,0:20:16.81,0:20:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengincar bayi\Nyang pernah kamu gendong?
Dialogue: 0,0:20:19.40,0:20:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?\NDia calon yang menjanjikan!
Dialogue: 0,0:20:23.66,0:20:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak salah.
Dialogue: 0,0:20:25.64,0:20:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bicara begitu di desa,\Nnyawamu saja masih kurang.
Dialogue: 0,0:20:30.36,0:20:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya pengawalan\Nuntuk Tuan Alfred harus diperketat, ya.
Dialogue: 0,0:20:33.92,0:20:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar tak ada serangga pengganggu,\Nkita pasang jebakan di jendela.
Dialogue: 0,0:20:36.89,0:20:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini bicara apa?\NLangsung jujur saja!
Dialogue: 0,0:20:46.51,0:20:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen memang terbaik.
Dialogue: 0,0:20:48.93,0:20:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memaksakan ikut ke sini\Nternyata pilihan tepat.
Dialogue: 0,0:20:52.33,0:20:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin melengkapi fasilitasnya
Dialogue: 0,0:20:54.44,0:20:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar warga di desa\Nbisa ikut menikmatinya juga.
Dialogue: 0,0:20:58.61,0:21:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, leluhur dan yang lainnya...
Dialogue: 0,0:21:12.16,0:21:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu kami.
Dialogue: 0,0:21:15.83,0:21:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi!
Dialogue: 0,0:21:27.60,0:21:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi! Pergilah!
Dialogue: 0,0:21:33.79,0:21:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Earth Rat, kita disambut\Npasukan Undead bersenjata.
Dialogue: 0,0:21:39.04,0:21:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada hal seperti ini di dungeon?
Dialogue: 0,0:21:42.96,0:21:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka ingin bicara.\NApa sebaiknya hentikan dia?
Dialogue: 0,0:21:45.79,0:21:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, apa kita bisa menghentikannya?
Dialogue: 0,0:21:47.80,0:21:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sakit!\N- Tidak.
Dialogue: 0,0:21:55.84,0:21:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut karena berpikir akan seru.
Dialogue: 0,0:21:59.40,0:22:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kejadian kali ini,
Dialogue: 0,0:22:01.89,0:22:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya ada kaitannya\Ndengan konspirasi besar.
Dialogue: 0,0:22:05.67,0:22:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, untuk sementara...
Dialogue: 0,0:22:11.68,0:22:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita biarkan dia sampai puas!
