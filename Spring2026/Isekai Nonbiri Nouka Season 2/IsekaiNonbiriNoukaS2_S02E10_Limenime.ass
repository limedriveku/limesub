Dialogue: 0,0:00:11.49,0:00:17.50,sign,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:02:24.79,0:02:26.79,sign,,0000,0000,0000,,TURNAMEN BELA DIRI, MELUNCUR
Dialogue: 0,0:02:44.19,0:02:46.19,sign,,0000,0000,0000,,MELUNCUR, TURNAMEN BELA DIRI
Dialogue: 0,0:02:52.00,0:02:55.92,sign,,0000,0000,0000,,TATA TERTIB
Dialogue: 0,0:02:55.92,0:02:57.62,sign,,0000,0000,0000,,JANGAN MENDORONG
Dialogue: 0,0:02:57.62,0:02:59.89,sign,,0000,0000,0000,,JANGAN BERLARI
Dialogue: 0,0:02:59.89,0:03:01.33,sign,,0000,0000,0000,,JANGAN MENYELA
Dialogue: 0,0:03:03.22,0:03:05.54,sign,,0000,0000,0000,,KANDIDAT LOKASI
Dialogue: 0,0:04:01.26,0:04:02.76,sign,,0000,0000,0000,,JARAK LOMPATAN
Dialogue: 0,0:05:26.43,0:05:28.43,sign,,0000,0000,0000,,AYO
Dialogue: 0,0:05:34.06,0:05:35.94,sign,,0000,0000,0000,,BERHASIL
Dialogue: 0,0:09:00.02,0:09:02.77,sign,,0000,0000,0000,,REKOR PEMENANG PERTAMA
Dialogue: 0,0:09:02.77,0:09:03.90,sign,,0000,0000,0000,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:10:57.53,0:11:00.43,sign,,0000,0000,0000,,PALING UJUNG
Dialogue: 0,0:12:43.41,0:12:48.91,sign,,0000,0000,0000,,BEBERAPA WAKTU SEBELUMNYA
Dialogue: 0,0:12:48.91,0:12:51.67,sign,,0000,0000,0000,,KERAJAAN REYWALT, KEDIAMAN FOOSH
Dialogue: 0,0:13:47.47,0:13:49.73,sign,,0000,0000,0000,,DICARI PENDATANG BARU!\NHUTAN KEMATIAN PENUH HARAPAN!
Dialogue: 0,0:15:16.69,0:15:18.19,sign,,0000,0000,0000,,DISITA
Dialogue: 0,0:15:46.43,0:15:50.97,sign,,0000,0000,0000,,BASMI
Dialogue: 0,0:18:54.65,0:18:56.66,sign,,0000,0000,0000,,NYUNYUDAPHNE, RAS YANG MIRIP ROH POHON
Dialogue: 0,0:19:15.30,0:19:16.03,sign,,0000,0000,0000,,SELAMAT DATANG DI DESA POHON BESAR
Dialogue: 0,0:21:27.77,0:21:32.54,sign,,0000,0000,0000,,MARAH
Dialogue: 0,0:23:45.90,0:23:50.91,sign,,0000,0000,0000,,SELANJUTNYA:\NEPISODE 11: KASTEL DI ATAS AWAN
Dialogue: 0,0:01:35.24,0:01:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bahas festival musim gugur,\Npilihannya hanya Chomuchomu.
Dialogue: 0,0:01:38.49,0:01:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru pesta malam\Nsebelum Mikemike lebih meriah.
Dialogue: 0,0:01:42.50,0:01:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan panggang Mikemike\Nmemang yang paling dinanti.
Dialogue: 0,0:01:45.88,0:01:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, itu!
Dialogue: 0,0:01:47.38,0:01:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang paling enak tetap Makemukemake\Ndari Mokemakemuke, kan?
Dialogue: 0,0:01:50.94,0:01:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kan Mikemakemoke\Ndari Mokimekemake?
Dialogue: 0,0:01:53.89,0:01:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalau lihat sejarah Mikemike—
Dialogue: 0,0:01:56.46,0:01:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma sejarah yang cerita begitu, kan?
Dialogue: 0,0:01:58.62,0:02:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mulai panas berdebat lagi, ya.
Dialogue: 0,0:02:00.32,0:02:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Make ini, Moke itu,\Nmereka sebenarnya bahas apa?
Dialogue: 0,0:02:03.50,0:02:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak tahu?\NAku juga tidak tahu.
Dialogue: 0,0:02:06.30,0:02:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, bahas masalah ini\Ntak akan selesai dengan diskusi saja.
Dialogue: 0,0:02:10.41,0:02:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:02:12.21,0:02:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama seperti sebelumnya,\Ntulis ide acara festival lalu kita undi.
Dialogue: 0,0:02:16.35,0:02:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turnamen Bela Diri jangan ditulis\Nkarena sudah kita lakukan.
Dialogue: 0,0:02:20.54,0:02:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita mulai!
Dialogue: 0,0:02:22.17,0:02:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa dinikmati semuanya\Ndan tidak berbahaya...
Dialogue: 0,0:02:26.79,0:02:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meluncur?\NApa maksudnya?
Dialogue: 0,0:02:28.93,0:02:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival dari daerah Burgan,\Norang-orang meluncur menuruni lereng.
Dialogue: 0,0:02:32.74,0:02:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi balapan jalan menurun, ya?
Dialogue: 0,0:02:35.28,0:02:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya, terkenal karena para pria kekar\N- Soiya, soiya!
Dialogue: 0,0:02:39.01,0:02:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- latihan habis-habisan untuk saling bertabrakan.\N- Soiya, soiya!
Dialogue: 0,0:02:40.96,0:02:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu sangat berbahaya.\N- Soiya, soiya!
Dialogue: 0,0:02:42.68,0:02:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undi ulang.
Dialogue: 0,0:02:47.69,0:02:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tak ada pilihan lain,\Nkami buat festival meluncur yang aman.
Dialogue: 0,0:02:52.00,0:02:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, tidak boleh saling tabrakan.
Dialogue: 0,0:02:54.22,0:02:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meluncur satu per satu menuruni lereng...
Dialogue: 0,0:02:55.92,0:02:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau para pria kekarnya?
Dialogue: 0,0:02:57.62,0:02:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu tidak ada batasan khusus.
Dialogue: 0,0:02:59.89,0:03:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah arah acaranya ditentukan,
Dialogue: 0,0:03:01.33,0:03:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}persiapan tempat festival pun dimulai.
Dialogue: 0,0:03:03.22,0:03:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena di desa tak ada gunung atau bukit,
Dialogue: 0,0:03:05.54,0:03:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami harus membuat lereng.
Dialogue: 0,0:03:07.66,0:03:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanah hasil galian digunakan\Nuntuk membuat bukit
Dialogue: 0,0:03:10.34,0:03:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar ada perbedaan ketinggian.
Dialogue: 0,0:03:12.37,0:03:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dibuat jalur meluncur dari bukit itu\Nmenuju lubang galian.
Dialogue: 0,0:03:17.52,0:03:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dikerjakan beberapa hari...
Dialogue: 0,0:03:22.16,0:03:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, akhirnya selesai juga.
Dialogue: 0,0:03:27.04,0:03:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat acaranya jadi besar, ya.
Dialogue: 0,0:03:29.61,0:03:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rasa hasilnya jauh berbeda\Ndari festival meluncur yang asli.
Dialogue: 0,0:03:33.68,0:03:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita membuat ini bersama-sama.\NAnggap ini festival khas Desa Pohon Besar.
Dialogue: 0,0:03:39.84,0:03:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tibalah hari festival.
Dialogue: 0,0:03:44.34,0:03:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, Festival Lomba Meluncur Desa Pohon Besar\Nyang pertama resmi dimulai!
Dialogue: 0,0:03:50.46,0:03:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aturannya sederhana.
Dialogue: 0,0:03:52.16,0:03:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari titik start di atas gunung,\Npeserta naik papan luncur melewati lintasan.
Dialogue: 0,0:03:56.26,0:03:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meluncur dari tepi lubang.\NLomba mengukur jarak melompat.
Dialogue: 0,0:03:59.76,0:04:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini mirip dengan
Dialogue: 0,0:04:01.26,0:04:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lomba luncur ski.
Dialogue: 0,0:04:03.33,0:04:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dekat kolam,\Nada tim pengukur jarak lompatan
Dialogue: 0,0:04:05.77,0:04:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ada tim penyelamat yang bersiaga.
Dialogue: 0,0:04:09.65,0:04:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peserta pertama, Ronana dari Desa Kedua!
Dialogue: 0,0:04:13.10,0:04:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:04:14.34,0:04:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua peserta akan meluncur ke kolam,\Njadi wajib memakai baju renang.
Dialogue: 0,0:04:18.64,0:04:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa buat baju yang tahan air\Ndan juga berenang?
Dialogue: 0,0:04:22.11,0:04:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah minta bantuan Zabuton,
Dialogue: 0,0:04:24.91,0:04:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia langsung semangat membuatkannya.
Dialogue: 0,0:04:27.41,0:04:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai!
Dialogue: 0,0:04:34.62,0:04:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ronana meluncur dengan penuh semangat!
Dialogue: 0,0:04:40.46,0:04:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:41.65,0:04:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kecepatannya kurang.
Dialogue: 0,0:04:43.93,0:04:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lagi dengan lebih cepat
Dialogue: 0,0:04:47.31,0:04:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melompat!
Dialogue: 0,0:04:50.56,0:04:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tepuk tangan untuk peserta Ronana!
Dialogue: 0,0:04:54.62,0:04:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peserta kedua, Daga!
Dialogue: 0,0:04:56.62,0:04:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daga, mulai!
Dialogue: 0,0:05:02.32,0:05:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengendalian papannya hebat!
Dialogue: 0,0:05:04.66,0:05:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini akan jadi rekor.
Dialogue: 0,0:05:06.83,0:05:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:05:09.58,0:05:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Flora!
Dialogue: 0,0:05:12.50,0:05:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai!
Dialogue: 0,0:05:16.05,0:05:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putaran satu kali yang sangat indah!
Dialogue: 0,0:05:22.24,0:05:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jarak loncatnya tidak bertambah.
Dialogue: 0,0:05:26.43,0:05:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai, ya.
Dialogue: 0,0:05:29.43,0:05:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mencetak rekor hebat dan unik.
Dialogue: 0,0:05:30.98,0:05:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para peserta terus memamerkan\Nlompatannya masing-masing.
Dialogue: 0,0:05:35.94,0:05:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai!
Dialogue: 0,0:05:42.07,0:05:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tia melompat!
Dialogue: 0,0:05:44.94,0:05:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu!\NDia terbang!
Dialogue: 0,0:05:47.20,0:05:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu boleh?
Dialogue: 0,0:05:48.93,0:05:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak boleh.
Dialogue: 0,0:05:50.96,0:05:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang menggunakan kemampuan terbang!
Dialogue: 0,0:05:52.77,0:05:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:54.46,0:05:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Tia, curang itu tidak baik.
Dialogue: 0,0:05:58.00,0:06:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Luulucy!
Dialogue: 0,0:06:00.21,0:06:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melompat!
Dialogue: 0,0:06:01.47,0:06:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu memantul!\NMemantul lagi!
Dialogue: 0,0:06:04.59,0:06:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rekor yang sangat bagus!
Dialogue: 0,0:06:06.60,0:06:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, harusnya bisa lebih jauh lagi.
Dialogue: 0,0:06:09.85,0:06:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peserta berikutnya, Sena!
Dialogue: 0,0:06:13.38,0:06:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia sepertinya ragu-ragu.
Dialogue: 0,0:06:16.82,0:06:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, ya?
Dialogue: 0,0:06:18.37,0:06:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin takut ketinggian?
Dialogue: 0,0:06:21.11,0:06:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malu.\NPusarku kelihatan.
Dialogue: 0,0:06:25.11,0:06:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang begitu.
Dialogue: 0,0:06:26.77,0:06:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:06:29.23,0:06:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi penampilannya tidak jauh berbeda.
Dialogue: 0,0:06:31.79,0:06:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu memaksakan diri.
Dialogue: 0,0:06:33.50,0:06:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan melompat!
Dialogue: 0,0:06:34.99,0:06:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha!
Dialogue: 0,0:06:39.13,0:06:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tepuk tangan untuk peserta Sena\Nyang sudah memberanikan diri!
Dialogue: 0,0:06:48.64,0:06:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:06:50.34,0:06:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku!
Dialogue: 0,0:06:51.77,0:06:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!\NTiga peserta meluncur sekaligus!
Dialogue: 0,0:06:57.52,0:07:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya tidak jauh,\Ntapi mereka berusaha maksimal!
Dialogue: 0,0:07:00.24,0:07:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para penonton juga menyukainya!
Dialogue: 0,0:07:02.28,0:07:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lumayan menghibur.
Dialogue: 0,0:07:04.53,0:07:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, selanjutnya...
Dialogue: 0,0:07:06.29,0:07:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Giliranmu.
Dialogue: 0,0:07:08.96,0:07:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NAku tidak bisa berenang!
Dialogue: 0,0:07:12.29,0:07:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peserta Rashashi memakai\Nperlengkapan yang repot.
Dialogue: 0,0:07:16.03,0:07:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diberi baju yang seperti bocah begini...
Dialogue: 0,0:07:18.67,0:07:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu memaksakan diri!
Dialogue: 0,0:07:21.14,0:07:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dengan perlengkapan begitu...
Dialogue: 0,0:07:24.51,0:07:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim penyelamat, bergerak!
Dialogue: 0,0:07:25.98,0:07:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:07:27.18,0:07:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah...
Dialogue: 0,0:07:29.22,0:07:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:07:30.18,0:07:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sedikit insiden,\Ntapi berhasil diselamatkan.
Dialogue: 0,0:07:34.01,0:07:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lombanya kita lanjutkan!
Dialogue: 0,0:07:35.23,0:07:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliranmu.
Dialogue: 0,0:07:37.17,0:07:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku harus jadi pembawa acara.
Dialogue: 0,0:07:39.81,0:07:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, cepat.
Dialogue: 0,0:07:44.96,0:07:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keraguannya barusan sudah lenyap!\NPeserta Fraurem sangat bersemangat!
Dialogue: 0,0:07:49.95,0:07:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa berharap hasilnya akan bagus!
Dialogue: 0,0:07:53.20,0:07:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angin!
Dialogue: 0,0:07:58.21,0:07:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, itu tidak boleh.
Dialogue: 0,0:07:59.94,0:08:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir juga dilarang!
Dialogue: 0,0:08:02.59,0:08:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aturannya ketat, ya.
Dialogue: 0,0:08:05.98,0:08:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lanjutkan!
Dialogue: 0,0:08:07.47,0:08:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kandidat terkuat untuk jarak terjauh, Rusty!
Dialogue: 0,0:08:19.73,0:08:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat spektakuler!
Dialogue: 0,0:08:22.54,0:08:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melompat terlalu jauh!
Dialogue: 0,0:08:24.75,0:08:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, semua lombanya selesai,\Nkita sekarang akan umumkan hasilnya.
Dialogue: 0,0:08:29.42,0:08:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juaranya adalah Daga!
Dialogue: 0,0:08:31.49,0:08:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:08:32.22,0:08:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:33.10,0:08:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada peserta lain.
Dialogue: 0,0:08:35.67,0:08:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... Sosok itu!
Dialogue: 0,0:08:38.75,0:08:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, Zabuton?\NApa dia peserta dadakan?
Dialogue: 0,0:08:42.55,0:08:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu!
Dialogue: 0,0:08:44.75,0:08:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zabuton?
Dialogue: 0,0:08:46.59,0:08:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zabuton!
Dialogue: 0,0:08:51.23,0:08:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya, lompatan putar raksasa\NZabuton mengalahkan Daga.
Dialogue: 0,0:08:56.13,0:08:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu beberapa waktu setelah itu,
Dialogue: 0,0:08:58.51,0:09:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}arena ramai oleh penduduk
Dialogue: 0,0:09:00.02,0:09:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ingin mencoba memecahkan rekor.
Dialogue: 0,0:09:03.90,0:09:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isekai Nonbiri Nouka 2.
Dialogue: 0,0:09:09.78,0:09:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdiri!
Dialogue: 0,0:09:11.03,0:09:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alfred sudah bisa berdiri!
Dialogue: 0,0:09:15.03,0:09:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:09:16.54,0:09:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini gendong.
Dialogue: 0,0:09:19.66,0:09:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kamu bisa berdiri?
Dialogue: 0,0:09:22.72,0:09:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sering bilang sini gendong.
Dialogue: 0,0:09:25.54,0:09:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.\NDia sekarang sudah berat, ya.
Dialogue: 0,0:09:29.05,0:09:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu dia mungil.
Dialogue: 0,0:09:35.62,0:09:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:09:38.86,0:09:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayi tumbuhnya sangat cepat.
Dialogue: 0,0:09:42.56,0:09:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari,\Naku terlintas memikirkan begitu...
Dialogue: 0,0:09:45.76,0:09:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Alfred belum bisa bicara?
Dialogue: 0,0:09:49.07,0:09:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga, dia belum bisa\Nbicara dengan benar, ya.
Dialogue: 0,0:09:53.07,0:09:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dari yang selama aku amati.
Dialogue: 0,0:09:56.33,0:09:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan dia akan memanggilku papa, ya?
Dialogue: 0,0:09:58.87,0:10:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia akan bilang mama duluan.
Dialogue: 0,0:10:01.46,0:10:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau itu, kita belum tahu.
Dialogue: 0,0:10:03.33,0:10:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, pertama dia pasti\Nakan bilang Mbak Flora!
Dialogue: 0,0:10:07.34,0:10:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, coba bilang Urza.
Dialogue: 0,0:10:09.57,0:10:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang Mbak, kan?
Dialogue: 0,0:10:11.62,0:10:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urza.\NYa?
Dialogue: 0,0:10:13.34,0:10:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu.
Dialogue: 0,0:10:16.18,0:10:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih bayi mungil.
Dialogue: 0,0:10:21.55,0:10:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}An.
Dialogue: 0,0:10:28.32,0:10:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sepertiku... tidak pantas.
Dialogue: 0,0:10:31.38,0:10:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:10:33.61,0:10:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}An!
Dialogue: 0,0:10:35.61,0:10:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, ini Papa!
Dialogue: 0,0:10:36.93,0:10:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bilang Mama.
Dialogue: 0,0:10:41.60,0:10:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zabu!
Dialogue: 0,0:10:50.16,0:10:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa waktu kemudian.
Dialogue: 0,0:10:53.90,0:10:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena para penduduk terus berdatangan\Nberharap namanya dipanggil,
Dialogue: 0,0:10:57.53,0:11:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}suasana di sekitar Alfred selalu ramai.
Dialogue: 0,0:11:09.28,0:11:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ketiduran.
Dialogue: 0,0:11:13.46,0:11:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah lama tidak mampir.
Dialogue: 0,0:11:15.45,0:11:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu.
Dialogue: 0,0:11:17.33,0:11:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang.
Dialogue: 0,0:11:19.39,0:11:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah janji akan balas budi.
Dialogue: 0,0:11:22.67,0:11:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat obat yang kalian buat,
Dialogue: 0,0:11:25.71,0:11:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penyakit putraku berhasil sembuh.
Dialogue: 0,0:11:28.46,0:11:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapannya memakan waktu...
Dialogue: 0,0:11:31.71,0:11:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka para pendatang\Nyang kalian inginkan.
Dialogue: 0,0:11:34.90,0:11:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengumpulkan para\Nsukarelawan pemuda dan pemudi.
Dialogue: 0,0:11:37.14,0:11:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:11:38.22,0:11:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya!\NAda pendatang pria muda yang datang!
Dialogue: 0,0:11:42.85,0:11:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah terbesar desa ini,
Dialogue: 0,0:11:44.77,0:11:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekurangan jumlah pria\Nyang sangat timpang akhirnya teratasi!
Dialogue: 0,0:11:48.10,0:11:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah sesuai yang kamu inginkan?
Dialogue: 0,0:11:50.45,0:11:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!\NTerima kasih banyak!
Dialogue: 0,0:11:53.11,0:11:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka betulan akan menerima kita?
Dialogue: 0,0:11:55.97,0:11:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, pasti akan baik-baik saja.
Dialogue: 0,0:12:00.51,0:12:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku Hiraku, kades Desa Pohon Besar.
Dialogue: 0,0:12:03.62,0:12:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mungkin masih cemas\Nkarena ada di tempat asing,
Dialogue: 0,0:12:06.52,0:12:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak perlu khawatir.
Dialogue: 0,0:12:12.10,0:12:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami pamit.
Dialogue: 0,0:12:15.30,0:12:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kalian bisa tinggal lebih lama.
Dialogue: 0,0:12:18.21,0:12:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada pekerjaan\Nyang harus kami selesaikan.
Dialogue: 0,0:12:20.96,0:12:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:12:22.51,0:12:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jaga mereka.
Dialogue: 0,0:12:25.06,0:12:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:27.18,0:12:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo kita pergi.
Dialogue: 0,0:12:28.70,0:12:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:29.77,0:12:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, sekarang akan kuajak\Nkalian keliling desa.
Dialogue: 0,0:12:33.74,0:12:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku berhasil memenuhi janjiku.
Dialogue: 0,0:12:36.38,0:12:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya beban di pundakku lepas juga.
Dialogue: 0,0:12:40.37,0:12:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ini sungguh melelahkan.
Dialogue: 0,0:12:52.26,0:12:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Foosh.\NPendeta Agung Gereja Korin.
Dialogue: 0,0:12:56.05,0:13:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang memikirkan cara balas budi\Nkarena putraku sudah disembuhkan.
Dialogue: 0,0:13:01.80,0:13:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balas budi adalah ungkapan\Nrasa terima kasih kami.
Dialogue: 0,0:13:04.56,0:13:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, aku ingin beri sesuatu\Nyang membuat mereka senang.
Dialogue: 0,0:13:07.31,0:13:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku memutuskan untuk langsung\Nmenanyakan apa yang mereka inginkan.
Dialogue: 0,0:13:15.32,0:13:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, mereka sedang mencari\Npendatang untuk desa mereka.
Dialogue: 0,0:13:19.60,0:13:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera kumpulkan para sukarelawan.
Dialogue: 0,0:13:21.82,0:13:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.\NApa kita boleh mengirim budak?
Dialogue: 0,0:13:24.67,0:13:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, bagaimana kalau mereka\Nmemberontak di Desa Pohon Besar?
Dialogue: 0,0:13:29.33,0:13:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau pilih beberapa orang dari penjara?
Dialogue: 0,0:13:32.11,0:13:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa hanya menyarankan\Norang-orang bermasalah?
Dialogue: 0,0:13:34.71,0:13:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan memindahkan mereka\Nke Hutan Kematian!
Dialogue: 0,0:13:36.88,0:13:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi orang biasa,\Nitu seperti dijatuhi hukuman mati!
Dialogue: 0,0:13:39.23,0:13:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat di sana memang\Ndipenuhi rumor mengerikan,
Dialogue: 0,0:13:42.97,0:13:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kenyataannya di desa itu berbeda!
Dialogue: 0,0:13:45.32,0:13:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dijelaskan, mereka pasti mengerti!
Dialogue: 0,0:13:51.98,0:13:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang datang.
Dialogue: 0,0:13:53.44,0:13:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun kita menjelaskannya,\Ntetap saja namanya Hutan Kematian.
Dialogue: 0,0:13:57.44,0:13:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:13:58.99,0:14:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita memilih\Npara pemuda kota?
Dialogue: 0,0:14:03.18,0:14:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuda kota, mereka anak-anak muda\Nyang selama ini disubsidi oleh kota.
Dialogue: 0,0:14:08.24,0:14:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lokasinya dirahasiakan,
Dialogue: 0,0:14:10.52,0:14:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka pasti tertarik kalau dengar\Nakan diberi rumah dan ladang.
Dialogue: 0,0:14:14.51,0:14:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka langsung kami kumpulkan.
Dialogue: 0,0:14:16.63,0:14:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syaratnya pasangan\Nyang sudah memiliki kekasih tetap.
Dialogue: 0,0:14:19.78,0:14:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa mereka sangat waspada?
Dialogue: 0,0:14:21.68,0:14:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rela nanti akan diapakan,\Ntapi tolong lepaskan yang lainnya!
Dialogue: 0,0:14:25.14,0:14:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Jack!
Dialogue: 0,0:14:26.32,0:14:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan sok keren!\N- Kenapa?
Dialogue: 0,0:14:28.14,0:14:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melawan perburuan manusia Foosh.\NKalau kabur, semua warga akan dibantai.
Dialogue: 0,0:14:32.88,0:14:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon Foosh mengambil hati anak-anak\Nuntuk dijadikan bahan sihir.
Dialogue: 0,0:14:35.94,0:14:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.\NMustahil aku melakukan hal seperti itu.
Dialogue: 0,0:14:39.47,0:14:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya aku ini monster?
Dialogue: 0,0:14:42.10,0:14:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menyebarkan rumor aneh itu\Nnanti akan kucari dan kuberi penjelasan.
Dialogue: 0,0:14:47.79,0:14:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para kandidat diajarkan baca tulis\Ndan berbagai pengetahuan umum.
Dialogue: 0,0:14:51.55,0:14:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:14:53.16,0:14:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memperlakukan mereka\Ndengan tulus memang yang terbaik.
Dialogue: 0,0:14:56.42,0:15:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus begini, mereka akan\Njadi pendatang yang membanggakan.
Dialogue: 0,0:15:01.68,0:15:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak tidak sah bangsawan?
Dialogue: 0,0:15:02.92,0:15:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ini dari hasil penyelidikan.
Dialogue: 0,0:15:05.31,0:15:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyelidiki latar belakang untuk jaga-jaga,\Ntapi hasilnya begini.
Dialogue: 0,0:15:08.43,0:15:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya, orang yang bersangkutan\Ntidak tertarik dengan status bangsawan.
Dialogue: 0,0:15:13.18,0:15:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar tak menimbulkan masalah\Ndi kemudian hari,
Dialogue: 0,0:15:15.16,0:15:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bangsawan itu dicopot dari gelarnya.
Dialogue: 0,0:15:18.74,0:15:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang menelantarkan anaknya,\Ntidak pantas menjadi bangsawan.
Dialogue: 0,0:15:23.41,0:15:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, semuanya beres.
Dialogue: 0,0:15:25.25,0:15:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Foosh!
Dialogue: 0,0:15:26.22,0:15:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata belum selesai.
Dialogue: 0,0:15:27.82,0:15:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada dua anak bangsawan lagi?
Dialogue: 0,0:15:30.32,0:15:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keturunan keluarga kerajaan\Nyang kabur dari negeri tetangga?
Dialogue: 0,0:15:32.90,0:15:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kuurus sampai tuntas.
Dialogue: 0,0:15:35.58,0:15:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja tetangga yang terkenal tiran\Nakan dilengserkan.
Dialogue: 0,0:15:40.58,0:15:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, grup bandit dan sekte mencurigakan\Nyang datang karena kabar keturunan
Dialogue: 0,0:15:46.43,0:15:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pencuri legendaris
Dialogue: 0,0:15:47.57,0:15:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau pemilik pedang suci
Dialogue: 0,0:15:49.08,0:15:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan dibasmi satu per satu.
Dialogue: 0,0:15:51.46,0:15:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunya peri?\NAda sisik naga di punggungnya?
Dialogue: 0,0:15:54.75,0:15:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu bukan masalah.\NItu hal kecil yang lucu.
Dialogue: 0,0:15:57.86,0:15:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap orang berbeda, dan harus begitu.
Dialogue: 0,0:16:00.50,0:16:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru orang yang tak punya\Nlatar belakang aneh itu paling mencurigakan.
Dialogue: 0,0:16:05.26,0:16:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ternyata,\Ndia memang hanya orang biasa.
Dialogue: 0,0:16:08.88,0:16:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, tujuan kami sebenarnya apa?
Dialogue: 0,0:16:11.84,0:16:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan pergi ke tempat yang akan\Nmenjadi kampung halaman baru kalian.
Dialogue: 0,0:16:15.87,0:16:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, aku tak memberi tahu mereka\Nbahwa tujuannya adalah Hutan Kematian.
Dialogue: 0,0:16:21.04,0:16:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah susah payah sejauh ini.\NAku hanya ingin mereka hidup bahagia.
Dialogue: 0,0:16:26.00,0:16:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa-sisa keluarga kerajaan tetangga,\Nakan kubasmi habis.
Dialogue: 0,0:16:31.07,0:16:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang dan seterusnya,\NAgama Korin akan selalu berpihak pada rakyat!
Dialogue: 0,0:16:38.94,0:16:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kami betulan boleh tinggal di desa ini?
Dialogue: 0,0:16:43.15,0:16:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:16:44.77,0:16:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga senang desa yang susah payah\Ndibangun ini tidak jadi terbengkalai.
Dialogue: 0,0:16:48.78,0:16:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Satu selama ini dikelola\Npara Igu dan yang lainnya,
Dialogue: 0,0:16:51.87,0:16:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau tak ada penduduk,\Nlama-lama jadi desa kosong.
Dialogue: 0,0:16:55.76,0:16:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancur?
Dialogue: 0,0:16:56.79,0:16:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Mamu,\Nyang akan membantu kalian semua!
Dialogue: 0,0:16:59.79,0:17:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sungkan untuk minta bantuan!
Dialogue: 0,0:17:02.29,0:17:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas rekomendasi Igu,
Dialogue: 0,0:17:03.72,0:17:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mamu ditunjuk merangkap\N- Menurutku dia bagus.
Dialogue: 0,0:17:05.38,0:17:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai pengurus para pendatang.
Dialogue: 0,0:17:07.89,0:17:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan membantu mereka agar cepat\Nberadaptasi dengan desa ini.
Dialogue: 0,0:17:16.75,0:17:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayunya keras sekali!
Dialogue: 0,0:17:19.50,0:17:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:17:20.48,0:17:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tunggu sebentar?
Dialogue: 0,0:17:22.31,0:17:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:23.25,0:17:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat angkut.
Dialogue: 0,0:17:24.93,0:17:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lenganku...
Dialogue: 0,0:17:26.56,0:17:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengah sebentar,\NKiller Rabbit-nya tumbang.
Dialogue: 0,0:17:30.19,0:17:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana para makhluk lemah ini\Nbertahan hidup sampai sekarang?
Dialogue: 0,0:17:33.58,0:17:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang terlihat dari tatapan Kuro.
Dialogue: 0,0:17:36.35,0:17:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, keamanan desa harus diperkuat.
Dialogue: 0,0:17:38.88,0:17:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pendatang tak terbiasa\Ndengan pekerjaan berat ataupun bertani.
Dialogue: 0,0:17:43.10,0:17:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tanpa Alat Bertani Mahabisa,\Nmungkin aku juga tak jauh beda.
Dialogue: 0,0:17:46.59,0:17:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sisi lain, mereka bisa baca tulis,\Njadi kami manfaatkan
Dialogue: 0,0:17:49.83,0:17:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyalin buku dan dokumen.
Dialogue: 0,0:17:52.05,0:17:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabungkan seperti ini, lalu begini.
Dialogue: 0,0:17:58.42,0:18:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka membuat cetakan huruf\Ndari kayu dan mencoba teknik percetakan.
Dialogue: 0,0:18:02.48,0:18:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil,\Nini bisa menjadi industri khas desa.
Dialogue: 0,0:18:06.48,0:18:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga yang pandai menggambar.
Dialogue: 0,0:18:09.38,0:18:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga yang mahir menjahit.
Dialogue: 0,0:18:13.36,0:18:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, sementara berbagai bakat\Nmereka mulai terlihat...
Dialogue: 0,0:18:17.12,0:18:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:18:18.62,0:18:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon!
Dialogue: 0,0:18:23.97,0:18:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:18:25.13,0:18:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meminjam kekuatan roh air.
Dialogue: 0,0:18:28.37,0:18:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, ada roh api juga.
Dialogue: 0,0:18:30.90,0:18:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada air dan api.\NBagaimana dengan tanah?
Dialogue: 0,0:18:33.88,0:18:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di daerah sini kekuatannya lemah...
Dialogue: 0,0:18:36.77,0:18:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin roh pohon bisa dipanggil!
Dialogue: 0,0:18:44.24,0:18:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terjadi apa-apa.
Dialogue: 0,0:18:45.71,0:18:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, padahal aku bisa merasakan\Nmereka ada di dekat sini.
Dialogue: 0,0:18:54.65,0:18:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini karena ada yang memanggilku.
Dialogue: 0,0:18:56.66,0:19:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, tapi saat ini\Ntidak ada yang ingin kuminta.
Dialogue: 0,0:19:00.67,0:19:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:02.53,0:19:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa lagi.
Dialogue: 0,0:19:06.94,0:19:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia bisa jalan.
Dialogue: 0,0:19:09.90,0:19:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir roh kekuatan yang langka, tapi tampaknya\Nlebih cocok untuk kegiatan sehari-hari.
Dialogue: 0,0:19:16.03,0:19:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mereka mulai terbiasa,
Dialogue: 0,0:19:18.37,0:19:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diadakan pesta penyambutan\Nuntuk para pendatang.
Dialogue: 0,0:19:21.93,0:19:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ini semua makanan?
Dialogue: 0,0:19:24.48,0:19:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah, seperti hiasan.
Dialogue: 0,0:19:26.50,0:19:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berpikir begitu\Nsaat pertama kali melihatnya.
Dialogue: 0,0:19:29.94,0:19:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi semuanya siap.
Dialogue: 0,0:19:33.69,0:19:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita akan baik-baik saja?
Dialogue: 0,0:19:35.46,0:19:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan mendekat.
Dialogue: 0,0:19:38.54,0:19:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:19:39.95,0:19:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut?\NPada High Elf?
Dialogue: 0,0:19:42.29,0:19:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:19:44.58,0:19:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kalian itu pemangsa manusia\Nyang suka menculik pria muda.
Dialogue: 0,0:19:48.33,0:19:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, itu salah paham!
Dialogue: 0,0:19:50.69,0:19:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya itu rumor yang muncul\Nakibat ulah sebagian ras kami,
Dialogue: 0,0:19:54.69,0:19:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jangan samakan kami\Ndengan mereka yang lemah itu.
Dialogue: 0,0:19:57.95,0:19:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:19:58.59,0:20:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalau ketahuan dan jadi rumor,\Nberarti mereka masih amatiran.
Dialogue: 0,0:20:02.41,0:20:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, harus rapi dan cepat!
Dialogue: 0,0:20:04.26,0:20:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih cepat!
Dialogue: 0,0:20:05.39,0:20:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu makin membuat mereka takut?
Dialogue: 0,0:20:11.98,0:20:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.\NBisa selesai dengan cepat.
Dialogue: 0,0:20:15.99,0:20:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata repot, ya.
Dialogue: 0,0:20:20.74,0:20:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:22.39,0:20:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau diobati dulu sedikit.
Dialogue: 0,0:20:23.90,0:20:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa ada yang sakit?
Dialogue: 0,0:20:25.87,0:20:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu cemas.
Dialogue: 0,0:20:28.54,0:20:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urza.
Dialogue: 0,0:20:30.00,0:20:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikut denganku.
Dialogue: 0,0:20:32.37,0:20:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Ada apa?
Dialogue: 0,0:20:36.54,0:20:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah aman.
Dialogue: 0,0:20:38.43,0:20:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah kembali.
Dialogue: 0,0:20:39.84,0:20:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sampai semenit.
Dialogue: 0,0:20:41.95,0:20:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang apa itu?\NDapat dari mana?
Dialogue: 0,0:20:43.78,0:20:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, bahaya!
Dialogue: 0,0:20:46.06,0:20:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini boneka tanahnya Urza.
Dialogue: 0,0:20:48.00,0:20:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, nanti akan\Nkusuruh membereskannya.
Dialogue: 0,0:20:50.96,0:20:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:20:53.86,0:20:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kades.
Dialogue: 0,0:20:55.26,0:20:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:56.08,0:20:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tahu sesuatu soal gadis itu?
Dialogue: 0,0:20:58.66,0:21:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak tahu.\NKamu kenal dia?
Dialogue: 0,0:21:01.54,0:21:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:21:04.16,0:21:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dari tadi, dia terus melihat\Nke sini dan aku penasaran.
Dialogue: 0,0:21:07.07,0:21:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, dulu aku pernah\Ndengar cerita dari kakek.
Dialogue: 0,0:21:11.15,0:21:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada orang\Nyang meminum darah naga,
Dialogue: 0,0:21:13.34,0:21:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan keturunannya disebut Pendeta Naga.
Dialogue: 0,0:21:17.92,0:21:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia merasakan kehadiranku\Ndan terus melihat ke sini?
Dialogue: 0,0:21:21.16,0:21:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pendeta itu punya kekuatan khusus?
Dialogue: 0,0:21:23.93,0:21:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, keturunannya ada sisik\Ndi punggungnya.
Dialogue: 0,0:21:27.77,0:21:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga bisa menenangkan amarah naga.
Dialogue: 0,0:21:30.77,0:21:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gao.
Dialogue: 0,0:21:31.54,0:21:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?
Dialogue: 0,0:21:32.54,0:21:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, mungkin menyanyikan lagu?
Dialogue: 0,0:21:37.32,0:21:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita tanyakan langsung.
Dialogue: 0,0:21:39.15,0:21:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tunggu...
Dialogue: 0,0:21:40.61,0:21:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:21:41.95,0:21:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, halo.\NKami naga.
Dialogue: 0,0:21:44.82,0:21:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Rasutismoon.\NPanggil aku Rusty, ya.
Dialogue: 0,0:21:47.66,0:21:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, lagu seperti apa yang kamu nyanyikan?
Dialogue: 0,0:21:49.55,0:21:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:50.62,0:21:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tenang saja.\NMereka tidak berbahaya.
