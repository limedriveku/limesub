Dialogue: 0,0:00:39.52,0:00:45.53,sign,,0,0,0,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:05:07.08,0:05:10.33,sign,,0,0,0,,KILAS BALIK
Dialogue: 0,0:07:39.36,0:07:43.61,sign,,0,0,0,,PASRAH
Dialogue: 0,0:09:12.45,0:09:17.08,sign,,0,0,0,,LANSIA
Dialogue: 0,0:09:17.08,0:09:18.12,sign,,0,0,0,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:14:19.46,0:14:25.47,sign,,0,0,0,,SISIK NAGA
Dialogue: 0,0:15:09.64,0:15:10.28,sign,,0,0,0,,ISEKAI NONBIRI NOUKA 2
Dialogue: 0,0:15:55.56,0:15:59.93,sign,,0,0,0,,ELF GUNUNG
Dialogue: 0,0:16:35.69,0:16:38.73,sign,,0,0,0,,DIVISI PENGEMBANGAN ELF GUNUNG
Dialogue: 0,0:18:07.51,0:18:09.74,sign,,0,0,0,,DIVISI PENGEMBANGAN ELF GUNUNG
Dialogue: 0,0:19:21.97,0:19:25.44,sign,,0,0,0,,DIVISI PENGEMBANGAN ELF GUNUNG
Dialogue: 0,0:23:45.11,0:23:50.12,sign,,0,0,0,,SELANJUTNYA:\NEPISODE 10: FESTIVAL DAN BALAS BUDI FOOSH
Dialogue: 0,0:00:06.82,0:00:09.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dulu aku dewa yang dijuluki Dewa Iblis.
Dialogue: 0,0:00:16.41,0:00:19.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Demi bisa balas dendam
Dialogue: 0,0:00:19.74,0:00:22.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}pada para dewa yang menyegel tubuhku,
Dialogue: 0,0:00:22.26,0:00:28.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}ribuan, atau puluhan ribu tahun pun,\Naku tak akan menyerah!
Dialogue: 0,0:02:02.17,0:02:05.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya, minum dan makan sampai puas!
Dialogue: 0,0:02:05.27,0:02:06.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:02:06.66,0:02:09.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami pulang dari onsen\Nke Desa Pohon Besar.
Dialogue: 0,0:02:09.03,0:02:13.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Hari ini kami pesta besar setelah sekian lama.\N- Meski lelah, onsennya segar!
Dialogue: 0,0:02:13.03,0:02:16.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tiba-tiba muncul monster raksasa\Ndari dalam tanah!
Dialogue: 0,0:02:17.03,0:02:19.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Terutama untuk Tim Pencari Onsen,\N- Bloody Viper yang langka langsung ditelan!
Dialogue: 0,0:02:19.72,0:02:22.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku ingin mereka senang-senang dan rehat.
Dialogue: 0,0:02:27.30,0:02:29.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku masih hidup...
Dialogue: 0,0:02:29.17,0:02:32.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa sangka kita bisa pulang selamat, ya?
Dialogue: 0,0:02:32.82,0:02:36.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya, kali ini kalian\Nsudah bekerja sangat keras.
Dialogue: 0,0:02:36.06,0:02:38.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, sangat keras.
Dialogue: 0,0:02:38.78,0:02:43.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hampir saja menghajarnya dari belakang.
Dialogue: 0,0:02:44.66,0:02:47.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah, kita minum dan lupakan.
Dialogue: 0,0:02:48.41,0:02:53.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pada akhirnya, tujuh Batu Hitam\Nmisterius itu digali Ruu dan yang lainnya.
Dialogue: 0,0:02:53.07,0:02:56.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya diukir menjadi patung dewa.
Dialogue: 0,0:02:56.57,0:02:58.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabut anehnya juga sudah hilang.
Dialogue: 0,0:02:58.93,0:03:01.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sementara kuanggap masalahnya\Nsudah selesai.
Dialogue: 0,0:03:01.58,0:03:03.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo, teguk.
Dialogue: 0,0:03:05.32,0:03:06.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong tenang.
Dialogue: 0,0:03:08.36,0:03:10.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, Kades!
Dialogue: 0,0:03:10.26,0:03:12.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tumben kamu datang ke pesta, ya.
Dialogue: 0,0:03:12.66,0:03:17.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, meski selalu diundang,\Naku biasanya tak bisa datang.
Dialogue: 0,0:03:17.59,0:03:21.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi hari ini,\Nsemua masalahnya sudah selesai.
Dialogue: 0,0:03:21.10,0:03:23.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akhirnya bisa istirahat setelah sekian lama.
Dialogue: 0,0:03:23.74,0:03:24.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:03:24.63,0:03:26.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Ronana!
Dialogue: 0,0:03:26.35,0:03:28.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Garis depan akhirnya sudah tenang!
Dialogue: 0,0:03:28.84,0:03:31.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku bergegas kembali menemuimu!
Dialogue: 0,0:03:31.61,0:03:33.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Syukurlah kamu selamat.
Dialogue: 0,0:03:34.36,0:03:35.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Apa kamu baik-baik saja?\N- Dia juga terus merengek
Dialogue: 0,0:03:35.96,0:03:38.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}- minta diajak karena ada waktu luang.\N- Iya, berkat doa kamu.
Dialogue: 0,0:03:38.89,0:03:41.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Syukurlah mereka kelihatan akrab.
Dialogue: 0,0:03:42.37,0:03:44.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Akhirnya kamu paham juga!\N- Siapa yang sedang minum dengan Doraimu?
Dialogue: 0,0:03:44.07,0:03:45.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tentu saja aku paham!\N- Siapa yang sedang minum dengan Doraimu?
Dialogue: 0,0:03:45.18,0:03:48.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tentu saja aku paham!\N- Dia pengurus dalam negeri
Dialogue: 0,0:03:48.01,0:03:49.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Empat Kerajaan Iblis, Randan.
Dialogue: 0,0:03:50.06,0:03:53.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para penjahat yang merajalela\Ndi dalam negeri,
Dialogue: 0,0:03:53.21,0:03:55.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}tiba-tiba berubah sikap.
Dialogue: 0,0:03:55.63,0:04:01.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di tempatku juga, lawan yang dulu konflik\Ndengan ayahku tiba-tiba minta maaf.
Dialogue: 0,0:04:01.89,0:04:04.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tak tahu apa alasannya,\Nyang penting harus dirayakan!
Dialogue: 0,0:04:04.55,0:04:06.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini kita minum sampai puas!
Dialogue: 0,0:04:06.33,0:04:09.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, tentu!
Dialogue: 0,0:04:12.04,0:04:13.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:04:14.28,0:04:17.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf sudah membuat kesalahan!\NAku mengundurkan diri dan memohon maaf!
Dialogue: 0,0:04:17.72,0:04:21.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan begitu, Randan!\NKamu sudah merepotkan rekan kita!
Dialogue: 0,0:04:21.18,0:04:22.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, tidak apa-apa!
Dialogue: 0,0:04:22.53,0:04:24.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Permintaan maafnya sangat tajam!
Dialogue: 0,0:04:24.73,0:04:26.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya dia sudah terlatih, ya!
Dialogue: 0,0:04:26.66,0:04:28.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya!\NTerima kasih!
Dialogue: 0,0:04:28.17,0:04:29.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Halo, Kades.
Dialogue: 0,0:04:29.90,0:04:31.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Leluhur.
Dialogue: 0,0:04:31.04,0:04:32.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:04:32.86,0:04:37.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lelah, ya?\NTapi, onsennya membuatku pulih.
Dialogue: 0,0:04:37.96,0:04:40.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini lebih ramai dari biasanya, ya?
Dialogue: 0,0:04:40.38,0:04:44.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya semuanya\Nmendadak masalahnya selesai.
Dialogue: 0,0:04:44.26,0:04:47.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di cabang kami juga ada kabar begitu.
Dialogue: 0,0:04:47.58,0:04:51.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, hal baik memang harus disyukuri.
Dialogue: 0,0:04:51.19,0:04:54.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, iya, Kades.\NSoal dia...
Dialogue: 0,0:04:55.42,0:04:57.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, dia slime sake.
Dialogue: 0,0:04:57.67,0:04:59.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan dia, yang di sampingnya.
Dialogue: 0,0:04:59.21,0:05:02.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maksudmu, kucing?
Dialogue: 0,0:05:02.12,0:05:05.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu dia kucing,\Ntapi dia sudah lama ada di sini?
Dialogue: 0,0:05:05.70,0:05:07.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soal itu...
Dialogue: 0,0:05:07.08,0:05:09.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat kembali ke desa...
Dialogue: 0,0:05:11.37,0:05:13.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kucing.
Dialogue: 0,0:05:13.09,0:05:14.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia kucing, kan?
Dialogue: 0,0:05:14.84,0:05:16.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari mana datangnya?
Dialogue: 0,0:05:18.31,0:05:19.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:05:23.90,0:05:25.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menyerah?
Dialogue: 0,0:05:27.99,0:05:32.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku kira ada yang bawa,\Ntapi semuanya bilang tidak tahu.
Dialogue: 0,0:05:34.10,0:05:36.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia sepertinya kucing misterius, ya?
Dialogue: 0,0:05:36.42,0:05:39.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para Kuro dan Zabuton kelihatannya\Ntidak merasa terganggu.
Dialogue: 0,0:05:39.22,0:05:41.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semoga dia betah tinggal di sini.
Dialogue: 0,0:05:59.34,0:06:01.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku Dewa Iblis.
Dialogue: 0,0:06:02.15,0:06:06.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dulu aku kalah perang melawan\Npara dewa yang menyebalkan.
Dialogue: 0,0:06:07.14,0:06:10.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu disegel di tanah ini\Nselama bertahun-tahun.
Dialogue: 0,0:06:10.98,0:06:14.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Harusnya tubuhku sudah membusuk\Ndi dasar bumi ini.
Dialogue: 0,0:06:17.46,0:06:18.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:06:18.40,0:06:23.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}tak akan kubiarkan itu terjadi,\Naku sudah menyiapkan strategi.
Dialogue: 0,0:06:23.67,0:06:28.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat aku bangkit kembali,\Nitu akan jadi akhir para dewa yang kubenci!
Dialogue: 0,0:06:32.57,0:06:34.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:06:35.91,0:06:38.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa ini?\NSakit!
Dialogue: 0,0:06:38.80,0:06:41.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Salah satu batu yang menyegelku
Dialogue: 0,0:06:41.80,0:06:45.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}berubah menjadi wujud Dewa Pencipta\Nyang kubenci dan makin kuat!
Dialogue: 0,0:06:45.80,0:06:49.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menggunakan sisa-sisa\Nkekuatanku lewat celah segel,
Dialogue: 0,0:06:49.31,0:06:53.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}menghasut banyak orang di sekitarku,\Ndan merencanakan banyak hal!
Dialogue: 0,0:06:53.53,0:06:54.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, tenang dulu!
Dialogue: 0,0:06:54.95,0:06:58.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku bukan sosok yang tumbang\Nkarena satu segel menjadi kuat.
Dialogue: 0,0:07:01.32,0:07:04.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi sakit ini sangat menyiksa!
Dialogue: 0,0:07:04.57,0:07:08.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ini Dewa Iblis!\NTapi, bahkan dewa sekalipun,
Dialogue: 0,0:07:08.58,0:07:11.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}tetap sakit kalau disakiti!
Dialogue: 0,0:07:12.44,0:07:15.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perlahan kesadaranku hilang...
Dialogue: 0,0:07:23.58,0:07:24.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:25.84,0:07:27.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu datang dari mana?
Dialogue: 0,0:07:27.34,0:07:30.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat kembali sadar,\Naku berubah menjadi kucing.
Dialogue: 0,0:07:30.98,0:07:35.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seluruh kekuatan Dewa Iblis-ku lenyap,\Ndan hanya menjadi kucing biasa.
Dialogue: 0,0:07:35.96,0:07:38.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya sisa satu jalan untukku.
Dialogue: 0,0:07:39.36,0:07:42.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sudah begini, sebaiknya pasrah.
Dialogue: 0,0:07:49.67,0:07:52.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini, kita harus bagaimana?
Dialogue: 0,0:07:54.06,0:07:56.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Patung yang dia pahat\Nsepertinya menjadi hukuman dewa,
Dialogue: 0,0:07:56.57,0:07:59.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}sekaligus menjadi pengampunan\Nbagi Dewa Iblis itu, ya.
Dialogue: 0,0:07:59.88,0:08:04.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia menjadi kucing\Ndianggap sebagai pengampunan?
Dialogue: 0,0:08:04.12,0:08:08.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, Dewa Iblis akan menjalani hidup\Ndalam sosok itu,
Dialogue: 0,0:08:08.14,0:08:11.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}- nantinya akan diberi tugas sebagai dewa lagi.\N- Elus, elus, elus.
Dialogue: 0,0:08:11.98,0:08:14.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Enak?\N- Machio Hiraku.
Dialogue: 0,0:08:14.22,0:08:17.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang dia sudah layak\Nmenjadi wakil dewa?
Dialogue: 0,0:08:17.64,0:08:19.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia sendiri tidak punya niat begitu.
Dialogue: 0,0:08:19.98,0:08:24.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita biarkan dia menjalani\Nkehidupan keduanya dengan bebas.
Dialogue: 0,0:08:24.01,0:08:27.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga,\Nawalnya itu karena kesalahanmu, kan?
Dialogue: 0,0:08:27.65,0:08:30.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tak sengaja mengirimnya\Nke Hutan Kematian berbahaya.
Dialogue: 0,0:08:30.71,0:08:33.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu benar, tapi...
Dialogue: 0,0:08:34.42,0:08:37.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang, dia sudah hebat hidup seperti itu!
Dialogue: 0,0:08:37.88,0:08:40.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Justru, mungkin ini semua berkat aku.
Dialogue: 0,0:08:40.91,0:08:45.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena itu, apa aku yang dihukum duduk sila\Nselama 30 tahun, layak diampuni?
Dialogue: 0,0:08:48.31,0:08:49.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:49.93,0:08:51.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:08:51.93,0:08:54.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aduh, kakiku!
Dialogue: 0,0:08:54.93,0:08:57.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Aduh, kakiku...\N- Meski manusia,
Dialogue: 0,0:08:57.35,0:09:00.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}dia bisa menyelamatkan satu dewa.
Dialogue: 0,0:09:00.69,0:09:02.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Semoga perjalanan hidupnya\N- Wah, kamu memanjang.
Dialogue: 0,0:09:02.82,0:09:05.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}- diberkati takdir.\N- Aku mau hidup seperti kucing.
Dialogue: 0,0:09:05.94,0:09:09.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, aku berharap...
Dialogue: 0,0:09:10.60,0:09:12.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semoga patungku
Dialogue: 0,0:09:13.26,0:09:16.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}dipahat ulang!
Dialogue: 0,0:09:18.12,0:09:20.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Isekai Nonbiri Nouka...
Dialogue: 0,0:09:20.14,0:09:21.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meong.
Dialogue: 0,0:09:28.84,0:09:30.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:09:30.84,0:09:34.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, ayo main!
Dialogue: 0,0:09:34.10,0:09:37.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku masih harus membereskan sarapan.
Dialogue: 0,0:09:37.10,0:09:39.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo main!
Dialogue: 0,0:09:39.51,0:09:40.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Hei!\N- Aku!
Dialogue: 0,0:09:40.81,0:09:43.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku senggang.
Dialogue: 0,0:09:48.41,0:09:50.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti aku bacakan buku.
Dialogue: 0,0:09:50.95,0:09:52.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:09:52.06,0:09:55.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, bacakan buku\Ntentang putri di atas menara!
Dialogue: 0,0:09:55.95,0:09:58.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih atas makanannya!\NAku mau tidur!
Dialogue: 0,0:09:58.68,0:10:00.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski baru selesai sarapan?
Dialogue: 0,0:10:00.34,0:10:02.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:10:02.33,0:10:05.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Putri itu, dia temanku!
Dialogue: 0,0:10:05.33,0:10:06.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi aku sudah lupa.
Dialogue: 0,0:10:12.98,0:10:15.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Urza yang datang ke Desa Pohon Besar,
Dialogue: 0,0:10:15.35,0:10:18.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}- meski ingatannya hilang, dia tetap riang!\N- Ayo!
Dialogue: 0,0:10:18.35,0:10:20.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Ke sini!\N- Tidak takut melihat apa pun,
Dialogue: 0,0:10:20.85,0:10:23.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}cepat adaptasi dengan kehidupan di sini.
Dialogue: 0,0:10:29.14,0:10:31.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Suty Suty Mun?
Dialogue: 0,0:10:31.90,0:10:35.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasutisumoon.\NPanggil aku Rusty, ya.
Dialogue: 0,0:10:36.68,0:10:37.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tanduk!
Dialogue: 0,0:10:38.92,0:10:41.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga.\NTanduk!
Dialogue: 0,0:10:42.00,0:10:43.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tanduk, tanduk!
Dialogue: 0,0:10:43.88,0:10:45.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tanduk!
Dialogue: 0,0:10:47.00,0:10:49.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, bisa berubah?
Dialogue: 0,0:10:49.25,0:10:50.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berubah?
Dialogue: 0,0:10:50.60,0:10:55.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, kamu melihatnya saat aku\Nmengantar Kades ke onsen, ya?
Dialogue: 0,0:10:55.02,0:10:56.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:11:00.64,0:11:03.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:11:03.27,0:11:04.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:11:06.31,0:11:07.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berubah!
Dialogue: 0,0:11:09.40,0:11:12.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gya!\NAku naga!
Dialogue: 0,0:11:12.90,0:11:14.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gao!
Dialogue: 0,0:11:14.25,0:11:15.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gao, gao!
Dialogue: 0,0:11:17.19,0:11:19.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu lihat Hakuren?
Dialogue: 0,0:11:19.05,0:11:21.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anak-anak kelas baca tulis mencarinya.
Dialogue: 0,0:11:21.46,0:11:23.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabarnya hari ini belajar mandiri.
Dialogue: 0,0:11:23.82,0:11:24.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:11:25.48,0:11:27.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin dia tidur?
Dialogue: 0,0:11:27.24,0:11:28.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia suka tidur, ya.
Dialogue: 0,0:11:29.51,0:11:33.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya Hakuren masih\Nbelum bisa akrab dengan Urza.
Dialogue: 0,0:11:33.42,0:11:37.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin Urza belum nyaman\Ndengan Nona Hakuren.
Dialogue: 0,0:11:38.90,0:11:41.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Waktu itu dia dihajar habis-habisan.
Dialogue: 0,0:11:42.43,0:11:46.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa ada cara agar mereka bisa akrab?
Dialogue: 0,0:11:49.59,0:11:50.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu suatu hari.
Dialogue: 0,0:11:55.45,0:11:57.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sedang apa?
Dialogue: 0,0:12:02.18,0:12:03.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boneka, ya?
Dialogue: 0,0:12:07.78,0:12:09.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, dia bergerak!
Dialogue: 0,0:12:10.74,0:12:13.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, dia bangun!
Dialogue: 0,0:12:15.43,0:12:19.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hancur, ya.\NMungkin kurang kuat?
Dialogue: 0,0:12:19.45,0:12:22.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau kuambilkan tanah liat\Nuntuk kerajinan?
Dialogue: 0,0:12:23.29,0:12:26.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa ada yang lihat slime sake?
Dialogue: 0,0:12:30.87,0:12:32.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang bagaimana?
Dialogue: 0,0:12:37.83,0:12:41.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masih hancur.\NHarus diapakan, ya?
Dialogue: 0,0:12:41.10,0:12:45.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ehem! Ehem!
Dialogue: 0,0:12:46.36,0:12:50.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku, pakai kepalaku, untuk menyerang?
Dialogue: 0,0:12:50.84,0:12:52.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Salah?
Dialogue: 0,0:12:52.28,0:12:55.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ada ide.
Dialogue: 0,0:12:55.51,0:12:57.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, itu maksudnya.
Dialogue: 0,0:12:57.75,0:13:00.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Urza, bisa berhenti sebentar.
Dialogue: 0,0:13:01.94,0:13:03.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:13:03.14,0:13:05.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini sisikku.
Dialogue: 0,0:13:05.53,0:13:06.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisik?
Dialogue: 0,0:13:06.73,0:13:10.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, saat menjadi wujud naga,\Nkadang sisikku lepas.
Dialogue: 0,0:13:10.89,0:13:12.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dihancurkan,
Dialogue: 0,0:13:13.16,0:13:14.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}jadi seperti ini.
Dialogue: 0,0:13:15.14,0:13:16.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu haluskan seperti ini
Dialogue: 0,0:13:16.90,0:13:19.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan campurkan ke tanah...
Dialogue: 0,0:13:25.61,0:13:27.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:13:28.68,0:13:30.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:13:30.85,0:13:33.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih, Hakuren!
Dialogue: 0,0:13:39.05,0:13:41.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:13:42.44,0:13:43.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coba lihat.
Dialogue: 0,0:13:43.80,0:13:44.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini!
Dialogue: 0,0:13:44.78,0:13:46.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, hebat, ya!
Dialogue: 0,0:13:46.39,0:13:48.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa dia sedang menyapa?
Dialogue: 0,0:14:00.66,0:14:02.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:14:02.07,0:14:04.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, serang!
Dialogue: 0,0:14:04.26,0:14:06.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuat!
Dialogue: 0,0:14:06.08,0:14:09.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sebenarnya makhluk apa?
Dialogue: 0,0:14:09.58,0:14:12.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makhluk yang dibuat Urza bersama Hakuren.
Dialogue: 0,0:14:12.49,0:14:13.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tanah dicampur sisik naga.
Dialogue: 0,0:14:13.61,0:14:15.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisik?\NMaksudmu sisik naga?
Dialogue: 0,0:14:15.78,0:14:17.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.\NApa itu bahaya?
Dialogue: 0,0:14:17.83,0:14:19.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan soal bahaya,
Dialogue: 0,0:14:19.46,0:14:22.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}sisik naga itu bahan paling berkualitas.
Dialogue: 0,0:14:22.79,0:14:25.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Efeknya bisa meningkatkan energi sihir,
Dialogue: 0,0:14:25.47,0:14:29.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi mengolahnya perlu tungku sihir\Nsebesar rumah.
Dialogue: 0,0:14:29.97,0:14:31.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi dia menghancurkannya dengan mudah.
Dialogue: 0,0:14:31.85,0:14:33.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:33.48,0:14:37.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisik naga Hakuren dan Rusty sering rontok.
Dialogue: 0,0:14:37.61,0:14:39.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di gudang pun sudah segunung.
Dialogue: 0,0:14:39.95,0:14:41.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu menyimpannya?
Dialogue: 0,0:14:41.10,0:14:43.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sayang kalau dibuang.
Dialogue: 0,0:14:43.61,0:14:48.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau semua sisiknya sampai tersebar,\Ndunia bisa kacau.
Dialogue: 0,0:14:48.12,0:14:52.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Simpan dulu dan kita pikirkan\Ncara mengolah semuanya.
Dialogue: 0,0:14:52.09,0:14:53.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:58.55,0:14:59.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka kelihatan senang, ya.
Dialogue: 0,0:14:59.93,0:15:03.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, membuat kita lega.
Dialogue: 0,0:15:04.63,0:15:06.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:15:10.28,0:15:14.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Isekai Nonbiri Nouka 2.
Dialogue: 0,0:15:22.28,0:15:24.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada suara keras!
Dialogue: 0,0:15:24.53,0:15:26.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian sedang apa?
Dialogue: 0,0:15:26.20,0:15:29.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eksperimen!\NAlat pelontar batu!
Dialogue: 0,0:15:29.78,0:15:31.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini katapel raksasa!
Dialogue: 0,0:15:32.25,0:15:34.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau dipakai untuk apa?
Dialogue: 0,0:15:34.22,0:15:35.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belum terpikirkan.
Dialogue: 0,0:15:35.85,0:15:40.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kalau pakai alat seperti ini,\Nbarang berat bisa dilontarkan.
Dialogue: 0,0:15:40.31,0:15:41.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Yaa.
Dialogue: 0,0:15:41.30,0:15:43.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa, Hiterto?
Dialogue: 0,0:15:43.75,0:15:47.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dibuat lebih besar lagi,\Nmungkin bisa dipakai untuk bertarung.
Dialogue: 0,0:15:47.72,0:15:49.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Misalnya untuk menghantam pos musuh.
Dialogue: 0,0:15:49.46,0:15:50.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya!
Dialogue: 0,0:15:50.56,0:15:54.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kades, kalau ada rencana\Nmenyerang ke suatu tempat...
Dialogue: 0,0:15:54.10,0:15:55.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja tidak ada.
Dialogue: 0,0:15:55.56,0:15:57.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Beberapa waktu setelah para Elf Gunung
Dialogue: 0,0:15:57.77,0:15:59.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}pindah ke Desa Pohon Besar.
Dialogue: 0,0:15:59.93,0:16:02.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka yang punya rasa penasaran tinggi,
Dialogue: 0,0:16:03.77,0:16:06.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}memanfaatkan kecekatan mereka
Dialogue: 0,0:16:07.56,0:16:10.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan mulai mengembangkan alat-alat baru.
Dialogue: 0,0:16:11.33,0:16:12.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dipakai untuk berburu...
Dialogue: 0,0:16:12.94,0:16:15.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin tak akan kena\Nsasaran yang bergerak?
Dialogue: 0,0:16:15.27,0:16:18.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lontarkan saja banyak batu kecil\Nagar tak bisa dihindari.
Dialogue: 0,0:16:18.63,0:16:20.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan gunakan untuk hal-hal berbahaya.
Dialogue: 0,0:16:21.51,0:16:23.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, jangan coba alat itu untuk terbang.
Dialogue: 0,0:16:25.50,0:16:28.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Intinya jangan, itu berbahaya.
Dialogue: 0,0:16:31.22,0:16:32.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dicoba, pasti berhasil!
Dialogue: 0,0:16:32.47,0:16:34.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak dicoba, tak akan berhasil!
Dialogue: 0,0:16:34.06,0:16:35.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mungkin berhasil, layak dicoba!
Dialogue: 0,0:16:35.69,0:16:38.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maju, Divisi Pengembangan Elf Gunung!
Dialogue: 0,0:16:41.86,0:16:45.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang ingin minta kubuatkan\Nkali ini adalah alat masak.
Dialogue: 0,0:16:45.76,0:16:49.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat merebus sayuran atau daging,\Nbegitu ditutup, cepat matang, kan?
Dialogue: 0,0:16:49.99,0:16:55.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau bisa buat panci yang tutupnya rapat,\Nmasak rebusan akan makin mudah.
Dialogue: 0,0:16:55.83,0:16:59.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, panasnya harus tetap di dalam, ya?
Dialogue: 0,0:16:59.77,0:17:02.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perlu alat untuk mengunci tutupnya, ya?
Dialogue: 0,0:17:02.38,0:17:06.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah!\NSerahkan pada kami!
Dialogue: 0,0:17:06.13,0:17:09.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perbaiki bagian yang ini...
Dialogue: 0,0:17:10.71,0:17:12.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita mulai.
Dialogue: 0,0:17:18.89,0:17:20.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Uapnya keluar, ya.
Dialogue: 0,0:17:20.74,0:17:22.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita harus hilangkan celahnya.
Dialogue: 0,0:17:24.77,0:17:27.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah coba berapa kali,\Ntutupnya masih lepas.
Dialogue: 0,0:17:27.21,0:17:28.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang kurang itu
Dialogue: 0,0:17:29.09,0:17:30.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}kekuatannya!
Dialogue: 0,0:17:34.12,0:17:35.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana progresnya?
Dialogue: 0,0:17:35.54,0:17:38.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kebetulan kami sedang coba prototipe baru.
Dialogue: 0,0:17:38.34,0:17:40.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah... Kokoh, ya?
Dialogue: 0,0:17:40.82,0:17:43.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akhirnya kami bisa buat\Nuapnya tidak keluar!
Dialogue: 0,0:17:43.50,0:17:46.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu, kalau tidak ada lubang,\Nbisa berbahaya.
Dialogue: 0,0:17:47.30,0:17:50.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, masih bocor, ya?
Dialogue: 0,0:17:57.11,0:18:00.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin ini bisa dipakai\Nmengusir musuh yang menyerang?
Dialogue: 0,0:18:00.49,0:18:02.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu berbahaya, sebaiknya jangan.
Dialogue: 0,0:18:02.98,0:18:04.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tak pernah patah semangat!
Dialogue: 0,0:18:04.52,0:18:05.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pantang menyerah!
Dialogue: 0,0:18:05.70,0:18:07.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hal mustahil itu nyaris tidak ada!
Dialogue: 0,0:18:07.51,0:18:09.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Divisi Pengembangan Elf Gunung!
Dialogue: 0,0:18:12.46,0:18:17.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini kursi penghilang pegal\Nyang dulu pernah Kades bahas!
Dialogue: 0,0:18:17.12,0:18:21.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kursi pijat...\NTepatnya, kursi pemukul bahu, ya?
Dialogue: 0,0:18:21.19,0:18:24.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar!\NDengan ini, lelah akan hilang!
Dialogue: 0,0:18:27.45,0:18:29.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, gerak!
Dialogue: 0,0:18:29.13,0:18:33.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini kami minta bantuan\Nsukarelawan untuk eksperimen!
Dialogue: 0,0:18:33.10,0:18:35.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eksperimennya kami harus apa?
Dialogue: 0,0:18:35.50,0:18:38.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami pilih dua orang yang kelihatan\Nbahunya sering pegal.
Dialogue: 0,0:18:38.91,0:18:41.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soalnya bahuku jarang pegal.
Dialogue: 0,0:18:41.39,0:18:43.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Putar!
Dialogue: 0,0:18:45.00,0:18:46.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:18:47.90,0:18:50.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita coba dulu dengan benda mati.
Dialogue: 0,0:18:50.25,0:18:52.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, baik.
Dialogue: 0,0:18:52.65,0:18:54.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo mulai.
Dialogue: 0,0:18:54.20,0:18:55.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Putar!
Dialogue: 0,0:18:56.52,0:18:57.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuat!
Dialogue: 0,0:18:57.41,0:18:59.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kekuatannya cukup!
Dialogue: 0,0:18:59.21,0:19:00.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa ini untuk hukuman mati?
Dialogue: 0,0:19:00.38,0:19:04.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat mengembangkan, Nona Yaa\Nterus bilang kekuatannya kurang.
Dialogue: 0,0:19:04.20,0:19:06.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lebih kuat!\NLebih kuat lagi!
Dialogue: 0,0:19:08.87,0:19:10.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana efeknya?
Dialogue: 0,0:19:10.55,0:19:13.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya harus atur posisi lagi.
Dialogue: 0,0:19:13.18,0:19:15.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:19:15.06,0:19:15.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:19:15.99,0:19:19.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, tidak perlu, bahuku sudah pasti\Nlebih lembut dari labu.
Dialogue: 0,0:19:20.76,0:19:21.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimanapun,
Dialogue: 0,0:19:21.97,0:19:23.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}harus kami selesaikan!
Dialogue: 0,0:19:23.25,0:19:25.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Divisi Pengembangan Elf Gunung!
Dialogue: 0,0:19:27.67,0:19:28.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:19:28.94,0:19:31.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Alat apa?
Dialogue: 0,0:19:31.16,0:19:33.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Alat untuk meredam guncangan.
Dialogue: 0,0:19:34.09,0:19:37.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Awalnya, aku minta buatkan per\Nuntuk matras kasur atau sofa.
Dialogue: 0,0:19:37.45,0:19:39.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi hasilnya terlalu besar.
Dialogue: 0,0:19:40.17,0:19:43.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kerasnya pun di luar perkiraan.
Dialogue: 0,0:19:43.29,0:19:45.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi aku cari cara\Nyang cocok dipakai untuk apa.
Dialogue: 0,0:19:46.46,0:19:48.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kegunaannya untuk apa?
Dialogue: 0,0:19:48.07,0:19:51.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin bisa dipakai untuk kendaraan besar.\NSeperti kereta kuda.
Dialogue: 0,0:19:51.88,0:19:52.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu!
Dialogue: 0,0:19:52.96,0:19:54.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita segera kerjakan!
Dialogue: 0,0:19:54.65,0:19:55.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:19:55.47,0:19:57.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:19:57.99,0:20:01.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi di desa tidak ada kereta kuda.\NLalu harus dibuat untuk apa?
Dialogue: 0,0:20:01.83,0:20:03.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami pergi dulu!
Dialogue: 0,0:20:04.98,0:20:07.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tiba-tiba Rusty diajak.
Dialogue: 0,0:20:07.27,0:20:09.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu langsung beli dari Michael.
Dialogue: 0,0:20:11.98,0:20:13.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami sudah beli!
Dialogue: 0,0:20:13.66,0:20:14.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:20:14.47,0:20:19.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, coba pasang alat ini\Ndi antara roda dan badan kereta.
Dialogue: 0,0:20:19.74,0:20:21.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa!
Dialogue: 0,0:20:21.24,0:20:24.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pernya terlalu lemah,\Ntidak bisa menahan badan kereta!
Dialogue: 0,0:20:25.30,0:20:28.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita sudah menghabiskan\Ntabungan ras untuk membelinya...
Dialogue: 0,0:20:28.31,0:20:30.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita harus bagaimana?
Dialogue: 0,0:20:30.00,0:20:31.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan cemas.
Dialogue: 0,0:20:31.88,0:20:33.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Yaa.
Dialogue: 0,0:20:33.05,0:20:34.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini mudah.
Dialogue: 0,0:20:35.21,0:20:37.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau lemah, buat jadi kuat!
Dialogue: 0,0:20:37.56,0:20:39.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Yaa!
Dialogue: 0,0:20:40.76,0:20:43.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, jadi bagus, ya!
Dialogue: 0,0:20:43.26,0:20:44.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah selesai?
Dialogue: 0,0:20:44.90,0:20:45.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:20:45.93,0:20:49.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mulai sekarang, kami akan\Nuji coba tahan guncangan.
Dialogue: 0,0:20:49.77,0:20:51.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kades mau ikut naik?
Dialogue: 0,0:20:51.26,0:20:53.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, kuserahkan padamu.
Dialogue: 0,0:21:07.93,0:21:09.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akhirnya!
Dialogue: 0,0:21:11.42,0:21:13.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita mulai!
Dialogue: 0,0:21:31.19,0:21:32.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:21:35.82,0:21:37.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi hasilnya bagaimana?
Dialogue: 0,0:21:37.53,0:21:42.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Agar pernya kuat,\Nkami pakai bubuk sisik naga.
Dialogue: 0,0:21:42.14,0:21:44.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh! Lalu...
Dialogue: 0,0:21:46.29,0:21:49.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masih belum.\NMasih bisa melompat lebih tinggi lagi.
Dialogue: 0,0:21:49.67,0:21:52.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu bisa melompat.
Dialogue: 0,0:21:52.79,0:21:56.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hasil uji coba: Untuk kereta kuda,\Nakhirnya pakai per daun,
Dialogue: 0,0:21:56.55,0:21:58.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}bukan per ulir.
Dialogue: 0,0:21:59.11,0:22:03.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hasilnya juga bisa dipakai gerobak dorong,\Nlangsung tren karena mudah ditarik sambil lari.
Dialogue: 0,0:22:03.55,0:22:06.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini tantangan kami belum berakhir.
Dialogue: 0,0:22:06.33,0:22:08.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selama masih ada ruang untuk perbaikan...
Dialogue: 0,0:22:08.81,0:22:12.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maju, Divisi Pengembangan Elf Gunung!
