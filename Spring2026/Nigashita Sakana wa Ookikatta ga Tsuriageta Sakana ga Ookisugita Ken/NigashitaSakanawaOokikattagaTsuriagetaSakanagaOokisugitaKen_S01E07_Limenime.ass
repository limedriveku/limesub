Dialogue: 0,0:00:28.80,0:00:32.68,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:00:32.68,0:00:36.52,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:01:46.00,0:01:51.01,tanda,,0000,0000,0000,,EPISODE 7:\NTINJU IKAN YANG TERTANGKAP
Dialogue: 0,0:02:33.38,0:02:34.88,tanda,,0000,0000,0000,,SINI, SINI
Dialogue: 0,0:06:10.27,0:06:11.52,tanda,,0000,0000,0000,,ENDUS, ENDUS
Dialogue: 0,0:11:51.23,0:11:52.73,tanda,,0000,0000,0000,,NOMOR 41, SURIASHI
Dialogue: 0,0:12:50.96,0:12:51.83,tanda,,0000,0000,0000,,BUANG
Dialogue: 0,0:13:20.15,0:13:21.95,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:13:21.95,0:13:25.95,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:23:35.56,0:23:36.81,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA:
Dialogue: 0,0:23:36.81,0:23:38.69,tanda,,0000,0000,0000,,IKAN LEPAS YANG DIAM-DIAM KENCAN
Dialogue: 0,0:00:01.19,0:00:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jepit rambut tradisi keluarga Annovazzi ini\Nmenyimpan sebuah rahasia.
Dialogue: 0,0:00:07.99,0:00:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipasang di tangan,
Dialogue: 0,0:00:09.74,0:00:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini akan jadi senjata keling\Npenambah daya pukul.
Dialogue: 0,0:01:53.01,0:01:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Mimi.
Dialogue: 0,0:01:56.43,0:01:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin oleh-oleh untuk Pangeran cuma ini?
Dialogue: 0,0:01:59.77,0:02:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita punya banyak domba dan sapi\Nyang bisa dipanggang utuh.
Dialogue: 0,0:02:03.06,0:02:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pilihannya harus\Nhewan ternak berukuran besar?
Dialogue: 0,0:02:05.61,0:02:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa saja boleh, asal muat di kereta kencana.
Dialogue: 0,0:02:07.77,0:02:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jumlahnya cuma sebegini,\Npasti cepat habis!
Dialogue: 0,0:02:10.49,0:02:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan!
Dialogue: 0,0:02:12.90,0:02:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa lapar itu musuh utama otot.
Dialogue: 0,0:02:14.99,0:02:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran tidak berniat melatih ototnya!
Dialogue: 0,0:02:17.74,0:02:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi dan Ayah\Nsudah kembali akrab seperti dulu.
Dialogue: 0,0:02:21.62,0:02:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:02:24.29,0:02:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri mahkota yang sangat gaduh, ya.
Dialogue: 0,0:02:28.13,0:02:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak akan pergi, ya?\NAku kesepian.
Dialogue: 0,0:02:34.88,0:02:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo!
Dialogue: 0,0:02:36.89,0:02:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja,\Naku akan segera pulang ke sini.
Dialogue: 0,0:02:40.52,0:02:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:02:41.72,0:02:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Naku akan jadi anak baik dan menunggu.
Dialogue: 0,0:02:44.85,0:02:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku antar Mbak\Nsampai ke kereta kencana, ya.
Dialogue: 0,0:02:48.90,0:02:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, dia sangat imut.\NAku jadi ingin membawanya bersamaku.
Dialogue: 0,0:02:52.82,0:02:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu seram.
Dialogue: 0,0:02:56.86,0:02:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, Nona.\NPegang tanganku.
Dialogue: 0,0:02:59.99,0:03:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:03:01.70,0:03:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berangkat, Tuan Duke di masa depan.
Dialogue: 0,0:03:06.10,0:03:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka pintunya!
Dialogue: 0,0:03:10.63,0:03:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengantarku.
Dialogue: 0,0:03:15.22,0:03:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal latihan, lakukan sesukamu.\NSantai saja.
Dialogue: 0,0:03:19.44,0:03:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:03:21.47,0:03:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati di jalan, ya!
Dialogue: 0,0:03:23.43,0:03:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titip salam untuk Pangeran, ya!
Dialogue: 0,0:03:26.27,0:03:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk merayakan kehidupan baru Nona Maria...
Dialogue: 0,0:03:30.44,0:03:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga kesehatan!
Dialogue: 0,0:03:33.40,0:03:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maria, Maria, Maria!\N- Aku akan segera pulang ke sini lagi!
Dialogue: 0,0:03:38.91,0:03:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.\NIni bukan perpisahan seumur hidup.
Dialogue: 0,0:03:46.46,0:03:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, apa putri kades\Nyang waktu itu sudah ditemukan?
Dialogue: 0,0:03:52.30,0:03:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Desa Navarro, ya?
Dialogue: 0,0:03:54.84,0:03:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri yang baik hati!
Dialogue: 0,0:03:57.59,0:03:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita akan berhasil.
Dialogue: 0,0:03:59.43,0:04:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita beruntung!
Dialogue: 0,0:04:02.35,0:04:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada kemajuan setelah itu, ya?
Dialogue: 0,0:04:04.81,0:04:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi ada kesempatan,\Nkita mampir ke sana saja!
Dialogue: 0,0:04:17.64,0:04:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harum sekali.
Dialogue: 0,0:04:20.87,0:04:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang!
Dialogue: 0,0:04:23.62,0:04:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri?\NKenapa ada di sini?
Dialogue: 0,0:04:29.96,0:04:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.\NGadis itu masih belum ditemukan.
Dialogue: 0,0:04:33.71,0:04:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:35.13,0:04:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian tahu\Nkira-kira dia pergi ke mana?
Dialogue: 0,0:04:39.59,0:04:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ada yang melihat\Nputri Pak Kades, Veronica,
Dialogue: 0,0:04:42.80,0:04:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}disuruh menaiki kereta kencana\Nmilik Count Nardi.
Dialogue: 0,0:04:48.10,0:04:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya...
Dialogue: 0,0:04:49.60,0:04:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, ini gawat!
Dialogue: 0,0:04:54.61,0:04:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, rupanya ada Tuan Putri.
Dialogue: 0,0:04:57.07,0:04:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak\Natas bantuanmu tempo hari.
Dialogue: 0,0:04:59.32,0:05:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:05:00.74,0:05:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tadi aku pergi untuk memeriksa\Nsituasi di kediaman Count Nardi...
Dialogue: 0,0:05:06.91,0:05:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, serahkan semua\Nhasil panennya pada kami!
Dialogue: 0,0:05:10.67,0:05:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, pergi dari sini!
Dialogue: 0,0:05:12.04,0:05:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, kalian yakin ingin\Nberbicara seperti itu pada kami?
Dialogue: 0,0:05:15.84,0:05:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kulaporkan ke Count Vesentini, ya?
Dialogue: 0,0:05:21.30,0:05:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya mereka sedang bertengkar\Ndengan para preman.
Dialogue: 0,0:05:25.93,0:05:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada berandalan seperti itu\Nyang datang ke sini?
Dialogue: 0,0:05:28.68,0:05:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa, sih, Count Vesentini ini?
Dialogue: 0,0:05:32.14,0:05:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau orang yang ingin membeli\Nhasil panen desa kami dari Count Nardi.
Dialogue: 0,0:05:37.86,0:05:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:05:39.24,0:05:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Count Nardi itu orang\Nyang mengumpulkan hasil panen desa ini
Dialogue: 0,0:05:42.99,0:05:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ingin menjualnya ke Count Vesentini?
Dialogue: 0,0:05:45.99,0:05:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:05:46.99,0:05:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...\NPerseteruan antarbangsawan, ya?
Dialogue: 0,0:05:51.91,0:05:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bau-bau tak sedap.
Dialogue: 0,0:05:53.33,0:05:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ada bau apa?
Dialogue: 0,0:05:55.63,0:05:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tadi aku keceplosan, ya?
Dialogue: 0,0:05:58.75,0:06:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.\NTadi itu...
Dialogue: 0,0:06:01.38,0:06:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tanaman di kebun kami, ya?
Dialogue: 0,0:06:03.01,0:06:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:03.80,0:06:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menanam ini.\NBaunya memang cukup khas.
Dialogue: 0,0:06:08.76,0:06:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba aku cium...
Dialogue: 0,0:06:11.52,0:06:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau!
Dialogue: 0,0:06:13.52,0:06:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau, kan?
Dialogue: 0,0:06:14.81,0:06:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanah kami kurang bagus,\Njadi cuma bisa menanam ini.
Dialogue: 0,0:06:17.98,0:06:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanaman ini bisa diolah\Njadi rempah-rempah.
Dialogue: 0,0:06:21.03,0:06:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa, ya?
Dialogue: 0,0:06:22.53,0:06:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal saat masuk ke desa ini,\Naku mencium wangi sesuatu.
Dialogue: 0,0:06:25.99,0:06:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga tidak tahu alasannya,
Dialogue: 0,0:06:28.49,0:06:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau dihirup bersama bunga,\Ntanaman ini beraroma sitrus.
Dialogue: 0,0:06:34.79,0:06:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kamu benar.\NIni harum.
Dialogue: 0,0:06:38.63,0:06:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa kami hanya punya ini.
Dialogue: 0,0:06:41.21,0:06:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:06:43.59,0:06:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti cemas putri kades menghilang\Ntanpa jejak di desa sedamai ini.
Dialogue: 0,0:06:48.72,0:06:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:50.18,0:06:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdasarkan cerita kalian tadi,\Naku yakin Count Nardi tahu sesuatu.
Dialogue: 0,0:06:55.94,0:06:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kemungkinannya dia diculik...
Dialogue: 0,0:06:59.94,0:07:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kami semua berniat\Nmenyerbu kediaman Tuan Count!
Dialogue: 0,0:07:04.24,0:07:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!\NKalau sampai ada preman yang terlibat,
Dialogue: 0,0:07:06.95,0:07:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tidak bisa tinggal diam!
Dialogue: 0,0:07:10.28,0:07:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan ikut dengan kalian.
Dialogue: 0,0:07:13.12,0:07:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya pasti berbeda\Nkalau ada bangsawan yang menemani.
Dialogue: 0,0:07:15.67,0:07:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, sepertinya itu...
Dialogue: 0,0:07:18.42,0:07:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, karena sudah mendengarnya,\Naku tak bisa tutup mata.
Dialogue: 0,0:07:23.76,0:07:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona pasti akan...
Dialogue: 0,0:07:25.63,0:07:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara seperti itu, ya?
Dialogue: 0,0:07:28.14,0:07:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:07:31.68,0:07:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kalian?\NPulang sana!
Dialogue: 0,0:07:38.19,0:07:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku putri keluarga Duke Annovazzi.
Dialogue: 0,0:07:41.23,0:07:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertemu Tuan Count sekarang.
Dialogue: 0,0:07:43.53,0:07:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Manmacchiri?\NTidak kenal!
Dialogue: 0,0:07:46.53,0:07:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Count sedang tak menerima tamu!
Dialogue: 0,0:07:49.53,0:07:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kenal, katanya?
Dialogue: 0,0:07:51.66,0:07:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja tidak kenal,\Nkami cuma bangsawan dari kerajaan kecil.
Dialogue: 0,0:07:57.04,0:07:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Putri.
Dialogue: 0,0:07:58.87,0:08:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda baik-baik saja?
Dialogue: 0,0:08:00.58,0:08:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, aku sudah menduga ini.
Dialogue: 0,0:08:05.13,0:08:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak bisa tembus dari depan...
Dialogue: 0,0:08:11.10,0:08:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak tahu dia ada di mana,\Nbagaimana sekarang?
Dialogue: 0,0:08:15.14,0:08:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia disekap di dalam bangunan ini,
Dialogue: 0,0:08:18.14,0:08:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pastinya ada di ruangan\Npaling ujung di lantai atas.
Dialogue: 0,0:08:22.98,0:08:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, di sana!
Dialogue: 0,0:08:25.07,0:08:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goffred dan penduduk desa,\Ntetap di sini dan buat keributan
Dialogue: 0,0:08:28.49,0:08:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengalihkan perhatian penjaga.
Dialogue: 0,0:08:30.36,0:08:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, pancing semua\Npengawal berkumpul di lantai satu.
Dialogue: 0,0:08:33.08,0:08:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri,\NAnda berniat menyusup sendirian?
Dialogue: 0,0:08:36.03,0:08:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlalu berbahaya!
Dialogue: 0,0:08:37.40,0:08:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal lebih mencurigakan\Nkalau pria berotot yang menyusup, kan?
Dialogue: 0,0:08:40.91,0:08:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pintar bersembunyi.
Dialogue: 0,0:08:46.46,0:08:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Macchio, kamu ikut denganku.\NBantu aku memanjat.
Dialogue: 0,0:08:52.55,0:08:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Nona.\NTolong jangan memaksakan diri.
Dialogue: 0,0:08:56.89,0:08:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:08:59.73,0:09:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku punya ini.
Dialogue: 0,0:09:04.06,0:09:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,\Nkeling ini cuma buat jaga-jaga.
Dialogue: 0,0:09:08.74,0:09:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, aku tak mau pakai kekerasan.
Dialogue: 0,0:09:11.36,0:09:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku pilih kamar kosong\Ndan masuk dari sana...
Dialogue: 0,0:09:22.00,0:09:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Halo.
Dialogue: 0,0:09:25.67,0:09:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:09:28.76,0:09:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah mengganggu.
Dialogue: 0,0:09:35.10,0:09:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengagetkan saja.\NTernyata ada orangnya.
Dialogue: 0,0:09:41.77,0:09:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa,\Nyang penting sampai di koridor.
Dialogue: 0,0:09:45.02,0:09:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus maju sampai ke ujung.
Dialogue: 0,0:09:46.44,0:09:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, aman terkendali.
Dialogue: 0,0:09:47.78,0:09:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya.
Dialogue: 0,0:09:48.82,0:09:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kita belum ke lantai atas, kan?
Dialogue: 0,0:09:51.28,0:09:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:52.78,0:09:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua orang di tangga.
Dialogue: 0,0:09:56.33,0:09:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu orang sedang bersantai di sofa.
Dialogue: 0,0:09:59.04,0:10:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kapan kira-kira Tuan Count pulang?
Dialogue: 0,0:10:03.08,0:10:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah, kudengar beliau\Npergi rapat ke ibu kota.
Dialogue: 0,0:10:07.29,0:10:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hampir dua bulan, ya?\NLama juga.
Dialogue: 0,0:10:10.38,0:10:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Berarti, Count Nardi\Ntak pernah ada di rumah?
Dialogue: 0,0:10:14.22,0:10:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nsiapa yang menculik putri Pak Kades?
Dialogue: 0,0:10:19.77,0:10:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini, ya.\NJangan kentut.
Dialogue: 0,0:10:24.44,0:10:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau banget!
Dialogue: 0,0:10:25.77,0:10:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, siapa kamu?
Dialogue: 0,0:10:27.82,0:10:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:28.48,0:10:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kentut tadi...
Dialogue: 0,0:10:32.36,0:10:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentut yang tadi itu bukan aku!
Dialogue: 0,0:10:39.58,0:10:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ribut-ribut apa ini?
Dialogue: 0,0:10:42.75,0:10:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahmu!
Dialogue: 0,0:10:48.96,0:10:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi refleks melompat ke luar.
Dialogue: 0,0:10:51.34,0:10:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak bisa membiarkan mereka mengira\Nseorang putri bangsawan yang kentut.
Dialogue: 0,0:10:55.09,0:10:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya tidak boleh!
Dialogue: 0,0:10:56.93,0:10:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Pak Kades ada di lantai atas?
Dialogue: 0,0:10:58.39,0:10:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya, ya.
Dialogue: 0,0:11:00.71,0:11:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bergegas.
Dialogue: 0,0:11:14.65,0:11:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Pak Kades pasti ada di lantai ini.
Dialogue: 0,0:11:16.70,0:11:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, siapa kalian?
Dialogue: 0,0:11:19.99,0:11:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai ada keributan di lantai bawah.
Dialogue: 0,0:11:22.33,0:11:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goffred dan yang lain\Nberhasil menjalankan tugas.
Dialogue: 0,0:11:30.46,0:11:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai banyak penjaga di sini.
Dialogue: 0,0:11:32.71,0:11:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh ketahuan.
Dialogue: 0,0:11:36.18,0:11:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tak bisa pakai ini,
Dialogue: 0,0:11:39.09,0:11:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau cuma merangkak, aku akan\Ntelat bereaksi saat ketahuan pengawal.
Dialogue: 0,0:11:42.97,0:11:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini...
Dialogue: 0,0:11:48.56,0:11:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor 41, Suriashi!
Dialogue: 0,0:11:52.73,0:11:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salah satu teknik "Sumo"\Ndari negeri jauh di Timur.
Dialogue: 0,0:11:57.53,0:11:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan ini jadi teknik rahasia...
Dialogue: 0,0:12:02.28,0:12:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena posenya lumayan memalukan!
Dialogue: 0,0:12:04.79,0:12:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik sebagai putri bangsawan\Nataupun gadis biasa,
Dialogue: 0,0:12:07.75,0:12:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak ingin siapa pun melihatku begini!
Dialogue: 0,0:12:09.63,0:12:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, bagaimanapun caranya.\NPokoknya malu!
Dialogue: 0,0:12:15.76,0:12:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:18.76,0:12:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo!
Dialogue: 0,0:12:24.35,0:12:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, karena sudah telanjur melihatnya,\Nkamu tak boleh pergi begitu saja.
Dialogue: 0,0:12:28.44,0:12:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang,\Nkamu masuk ke gudang ini dulu.
Dialogue: 0,0:12:44.87,0:12:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, kamu siapa?
Dialogue: 0,0:12:53.29,0:12:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Veronica dari Desa Navarro?
Dialogue: 0,0:12:56.63,0:12:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar.
Dialogue: 0,0:12:58.47,0:13:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah! Aku datang untuk menolongmu.\NApa kamu terluka?
Dialogue: 0,0:13:02.05,0:13:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Menolong?
Dialogue: 0,0:13:05.35,0:13:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang datang.\NMundur!
Dialogue: 0,0:13:10.19,0:13:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau bertunangan denganmu!
Dialogue: 0,0:13:13.81,0:13:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku dapat pembatalan pertunangan kedua!
Dialogue: 0,0:13:26.62,0:13:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembatalan pertunangan yang kedua.
Dialogue: 0,0:13:32.46,0:13:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dua kali aku menerima pembatalan\Npertunangan dari hubungan yang fiktif...
Dialogue: 0,0:13:37.96,0:13:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Veronica, kamu baik-baik saja?
Dialogue: 0,0:13:39.97,0:13:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dia...
Dialogue: 0,0:13:43.26,0:13:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan Nona Ella?
Dialogue: 0,0:13:45.72,0:13:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu... Siapa namamu?
Dialogue: 0,0:13:49.35,0:13:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Mimi.
Dialogue: 0,0:13:51.52,0:13:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf.
Dialogue: 0,0:13:52.55,0:13:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Hugo Nardi,\Nputra Count Nardi penguasa wilayah ini.
Dialogue: 0,0:13:57.57,0:13:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ada bangsawan yang memaksaku
Dialogue: 0,0:13:59.69,0:14:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menikahi putrinya sebagai syarat\Npembelian hasil panen wilayah kami.
Dialogue: 0,0:14:04.82,0:14:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, orang itu Count Vesentini?
Dialogue: 0,0:14:08.41,0:14:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:09.66,0:14:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, pantas saja kamu mengira aku putrinya.
Dialogue: 0,0:14:14.71,0:14:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, periksa dulu
Dialogue: 0,0:14:16.79,0:14:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajah lawan bicaramu\Nsebelum membatalkan pertunangan.
Dialogue: 0,0:14:19.76,0:14:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah punya Veronica\Nyang sangat kucintai.
Dialogue: 0,0:14:24.72,0:14:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hugo, sebaiknya kamu menikah\Ndengan Nona Ella demi desa ini...
Dialogue: 0,0:14:29.93,0:14:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kamu ini?
Dialogue: 0,0:14:31.10,0:14:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak butuh masa depan\Ntanpa dirimu di sampingku!
Dialogue: 0,0:14:33.77,0:14:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hugo.
Dialogue: 0,0:14:34.94,0:14:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Veronica.
Dialogue: 0,0:14:36.15,0:14:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hugo.
Dialogue: 0,0:14:37.52,0:14:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Veronica.
Dialogue: 0,0:14:38.52,0:14:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf...\NJadi, ini bukan kasus penculikan?
Dialogue: 0,0:14:42.74,0:14:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan,\Nwarga desa meminta tolong padamu?
Dialogue: 0,0:14:46.95,0:14:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena sudah merepotkanmu.
Dialogue: 0,0:14:50.87,0:14:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku berniat membawanya kabur\Nsaat ayahku sedang tidak ada di rumah.
Dialogue: 0,0:14:56.00,0:15:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kalian mau kawin lari?
Dialogue: 0,0:15:01.30,0:15:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta terlarang, cinta tak direstui!
Dialogue: 0,0:15:04.38,0:15:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobaan untuk dua sejoli!
Dialogue: 0,0:15:06.84,0:15:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka banget ceritanya!
Dialogue: 0,0:15:11.81,0:15:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Mimi...
Dialogue: 0,0:15:14.73,0:15:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi kalian berdua!
Dialogue: 0,0:15:16.98,0:15:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kubiarkan\Nada yang memisahkan kalian!
Dialogue: 0,0:15:19.57,0:15:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara batalkan dulu rencana kawin larinya
Dialogue: 0,0:15:21.69,0:15:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kita pikirkan cara lain\Nuntuk masa depan kalian.
Dialogue: 0,0:15:25.24,0:15:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak,\Naku senang mendengarnya.
Dialogue: 0,0:15:32.45,0:15:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Veronica!
Dialogue: 0,0:15:33.62,0:15:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:15:35.08,0:15:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, maaf sudah membuat cemas.
Dialogue: 0,0:15:37.75,0:15:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lega Nona baik-baik saja.
Dialogue: 0,0:15:40.21,0:15:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kami tak terlalu cemas.
Dialogue: 0,0:15:41.92,0:15:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:43.13,0:15:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hugo, gawat!
Dialogue: 0,0:15:45.22,0:15:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gudang kita diserang!
Dialogue: 0,0:15:47.18,0:15:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:48.80,0:15:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:15:51.14,0:15:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi mereka.
Dialogue: 0,0:15:53.39,0:15:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua barang yang ada di gudang ini\Nakan jadi milik kami!
Dialogue: 0,0:15:56.81,0:16:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Count Vesentini akan membelinya\Ndengan harga tinggi!
Dialogue: 0,0:16:00.90,0:16:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita merampoknya,\Nkita tak butuh modal dan meraup untung utuh!
Dialogue: 0,0:16:07.82,0:16:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat serahkan hasil panen kalian juga!
Dialogue: 0,0:16:09.91,0:16:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tawaran ini akan\Nmemengaruhi masa depan kalian!
Dialogue: 0,0:16:15.58,0:16:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hugo, jangan terima tawaran mereka!
Dialogue: 0,0:16:19.25,0:16:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak akan menyerahkan hasil panen\Nyang berharga pada kalian.
Dialogue: 0,0:16:21.88,0:16:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu... yang waktu itu.\NKenapa ada di sini?
Dialogue: 0,0:16:26.76,0:16:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa perempuan itu?
Dialogue: 0,0:16:28.47,0:16:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga bicaramu!
Dialogue: 0,0:16:29.89,0:16:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau adalah putri mahkota\NKerajaan Rubini masa depan.
Dialogue: 0,0:16:33.64,0:16:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Maria Annovazzi!
Dialogue: 0,0:16:39.23,0:16:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia putri bangsawan betulan.
Dialogue: 0,0:16:41.73,0:16:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana ini?\NAku sudah lancang memanggilnya "Mimi".
Dialogue: 0,0:16:46.86,0:16:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NAku dan Veronica sudah jadi teman.
Dialogue: 0,0:16:50.86,0:16:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan menghajar mereka semua.
Dialogue: 0,0:16:53.33,0:16:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku ingin kalian bahagia.
Dialogue: 0,0:16:56.04,0:16:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria.
Dialogue: 0,0:16:59.33,0:17:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.\NPergilah dari tempat ini.
Dialogue: 0,0:17:01.46,0:17:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencari pembeli baru\Ntanpa bantuan Count.
Dialogue: 0,0:17:05.63,0:17:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan berbisnis dengan kalian lagi!
Dialogue: 0,0:17:08.92,0:17:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar!\NKami tak akan serahkan hasil panen kami!
Dialogue: 0,0:17:12.01,0:17:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggalkan seluruh barang kalian!
Dialogue: 0,0:17:13.80,0:17:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya, dia benar!\N- Pergi dari sini!
Dialogue: 0,0:17:20.81,0:17:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bang, bagaimana ini?
Dialogue: 0,0:17:23.73,0:17:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh, jangan takut!
Dialogue: 0,0:17:28.31,0:17:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, kalian cuma disuruh menghajar\Nsatu tuan muda, kenapa lama sekali?
Dialogue: 0,0:17:32.16,0:17:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, ma-maaf!
Dialogue: 0,0:17:34.45,0:17:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berani melawan kami!
Dialogue: 0,0:17:36.49,0:17:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi perempuan itu.\NDia yang mengganggu kita waktu itu!
Dialogue: 0,0:17:40.12,0:17:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:42.54,0:17:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goffred, Macchio.
Dialogue: 0,0:17:45.54,0:17:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu bukan preman biasa,\Npengalamannya jauh lebih banyak.
Dialogue: 0,0:17:50.30,0:17:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah dengar rumornya,
Dialogue: 0,0:17:52.09,0:17:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak kusangka dia cuma gadis kecil.
Dialogue: 0,0:17:53.84,0:17:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?\NDia putri baru Rubini!
Dialogue: 0,0:17:57.75,0:17:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga sopan santunmu!
Dialogue: 0,0:17:59.77,0:18:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan serang dia!
Dialogue: 0,0:18:05.61,0:18:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang kampung sepertimu\Nberani-beraninya menentang kami.
Dialogue: 0,0:18:10.99,0:18:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, cepat angkut barang-barangnya!
Dialogue: 0,0:18:16.20,0:18:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:18:17.62,0:18:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, kamu bukan orang bodoh\Nyang tak paham situasi, kan?
Dialogue: 0,0:18:22.41,0:18:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tak ingin dia mati,\Njangan bergerak.
Dialogue: 0,0:18:27.00,0:18:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka.
Dialogue: 0,0:18:29.46,0:18:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kesatria, di sana!
Dialogue: 0,0:18:33.22,0:18:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NPasukan kesatria Kerajaan Rubini?
Dialogue: 0,0:18:37.43,0:18:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan
Dialogue: 0,0:18:38.60,0:18:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia!
Dialogue: 0,0:18:44.23,0:18:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:18:45.06,0:18:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos!
Dialogue: 0,0:18:48.73,0:18:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:18:50.07,0:18:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri, terima kasih banyak.
Dialogue: 0,0:18:52.99,0:18:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sungkan.
Dialogue: 0,0:18:54.32,0:18:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang harus minta maaf\Nkarena membuatmu celaka.
Dialogue: 0,0:18:57.20,0:18:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga tak ada tulang yang patah.
Dialogue: 0,0:18:58.62,0:19:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat beri dia pertolongan.
Dialogue: 0,0:19:00.04,0:19:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengerti.
Dialogue: 0,0:19:00.83,0:19:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria memang hebat.
Dialogue: 0,0:19:03.41,0:19:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor 10 tadi sangat keren.
Dialogue: 0,0:19:05.29,0:19:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.\NTernyata kamu datang.
Dialogue: 0,0:19:07.75,0:19:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kami datang setelah mendengar\Nlaporan warga desa yang ke istana.
Dialogue: 0,0:19:12.63,0:19:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kita masih sempat.
Dialogue: 0,0:19:14.59,0:19:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, bukan cuma kesatria.
Dialogue: 0,0:19:19.01,0:19:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kamu baik-baik saja?
Dialogue: 0,0:19:20.35,0:19:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato!\NKenapa ada di sini?
Dialogue: 0,0:19:23.18,0:19:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia datang untuk menjemputku, ya?
Dialogue: 0,0:19:25.73,0:19:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Macchio, Goffred, biar kuperkenalkan...
Dialogue: 0,0:19:31.40,0:19:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, bahaya!
Dialogue: 0,0:19:40.45,0:19:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir!
Dialogue: 0,0:19:44.25,0:19:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan sempat!
Dialogue: 0,0:19:49.46,0:19:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:19:53.71,0:19:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renato!
Dialogue: 0,0:19:55.72,0:19:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghindar!
Dialogue: 0,0:19:59.30,0:20:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga puluh...
Dialogue: 0,0:20:00.80,0:20:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}delapan!
Dialogue: 0,0:20:10.23,0:20:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aduh...
Dialogue: 0,0:20:14.23,0:20:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran!\NKamu baik-baik saja?
Dialogue: 0,0:20:16.49,0:20:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu terluka?
Dialogue: 0,0:20:17.74,0:20:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku baik-baik saja.
Dialogue: 0,0:20:19.82,0:20:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkap dia!
Dialogue: 0,0:20:21.32,0:20:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jatuh pingsan.
Dialogue: 0,0:20:23.16,0:20:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:25.58,0:20:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku melakukannya dengan baik?
Dialogue: 0,0:20:27.83,0:20:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diam-diam berlatih nomor 38 sejak kamu\Nperlihatkan pagi itu sebelum berangkat.
Dialogue: 0,0:20:34.38,0:20:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal cuma kuperlihatkan sekali.
Dialogue: 0,0:20:37.59,0:20:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Pangeran meninju orang\Ndengan tangan kosong...
Dialogue: 0,0:20:44.43,0:20:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Raimondo, bertahanlah!
Dialogue: 0,0:20:50.48,0:20:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lega kamu tak terluka,\Ntapi tolong jangan diulangi.
Dialogue: 0,0:20:54.57,0:20:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.
Dialogue: 0,0:20:55.82,0:20:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai terjadi sesuatu padamu, aku...
Dialogue: 0,0:21:00.41,0:21:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar lega Mimi tak terluka.
Dialogue: 0,0:21:06.83,0:21:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku baru tahu kalau\Nmeninju orang ternyata sesakit ini.
Dialogue: 0,0:21:12.79,0:21:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran.
Dialogue: 0,0:21:14.34,0:21:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari segi fisik maupun kekuasaan,\NPangeran jauh lebih unggul.
Dialogue: 0,0:21:17.59,0:21:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ingat bahwa rasa sakit
Dialogue: 0,0:21:19.76,0:21:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kamu berikan, punya dampak\Nlebih besar dari yang terlihat.
Dialogue: 0,0:21:23.55,0:21:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pernah lupakan rasa sakit ini.
Dialogue: 0,0:21:27.72,0:21:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ingat selalu berat tinju ini.
Dialogue: 0,0:21:32.52,0:21:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kekuatan itu juga\Nmampu melindungi orang lain.
Dialogue: 0,0:21:38.15,0:21:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang menolongku,\NPangeran Renato.
Dialogue: 0,0:21:47.66,0:21:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:23:26.80,0:23:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikku, Teo, sangat suka daging.
Dialogue: 0,0:23:28.85,0:23:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia anak hebat yang makan apa pun\Ndengan lahap!
Dialogue: 0,0:23:31.68,0:23:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti akan tumbuh besar.
Dialogue: 0,0:23:33.27,0:23:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara Ayah, malah suka yang manis.
Dialogue: 0,0:23:35.56,0:23:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal wajahnya seram begitu.
Dialogue: 0,0:23:36.81,0:23:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku keceplosan lagi!
