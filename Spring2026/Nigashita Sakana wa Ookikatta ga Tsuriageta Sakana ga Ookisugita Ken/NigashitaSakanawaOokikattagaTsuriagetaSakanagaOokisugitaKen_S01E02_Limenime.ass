Dialogue: 0,0:01:02.04,0:01:05.30,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:01:05.30,0:01:08.55,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP MALAH TERLALU BESAR
Dialogue: 0,0:02:17.99,0:02:23.00,tanda,,0000,0000,0000,,EPISODE 2: IKAN LEPAS YANG TERTANGKAP
Dialogue: 0,0:03:48.75,0:03:52.96,tanda,,0000,0000,0000,,BUK, BUK, BUK
Dialogue: 0,0:04:34.38,0:04:34.80,tanda,,0000,0000,0000,,AAAAAAAAH
Dialogue: 0,0:06:54.98,0:06:56.15,tanda,,0000,0000,0000,,SENYUM
Dialogue: 0,0:10:25.44,0:10:27.23,tanda,,0000,0000,0000,,BINGUNG
Dialogue: 0,0:10:34.74,0:10:37.20,tanda,,0000,0000,0000,,CRING!
Dialogue: 0,0:11:12.44,0:11:14.53,tanda,,0000,0000,0000,,BENGONG
Dialogue: 0,0:11:40.10,0:11:42.14,tanda,,0000,0000,0000,,SYUT
Dialogue: 0,0:12:25.02,0:12:29.02,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:12:29.02,0:12:33.02,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP MALAH TERLALU BESAR
Dialogue: 0,0:13:10.98,0:13:12.02,tanda,,0000,0000,0000,,GLEK...
Dialogue: 0,0:17:15.72,0:17:17.02,tanda,,0000,0000,0000,,PERLAHAN...
Dialogue: 0,0:20:42.35,0:20:44.25,tanda,,0000,0000,0000,,UGH... NGGH!
Dialogue: 0,0:23:35.02,0:23:35.73,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA:
Dialogue: 0,0:23:35.73,0:23:37.15,tanda,,0000,0000,0000,,LATIHAN SEBAGAI
Dialogue: 0,0:23:37.15,0:23:39.77,tanda,,0000,0000,0000,,NONA BANGSAWAN IKAN YANG TERLEPAS
Dialogue: 0,0:00:00.52,0:00:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Maria Annovazzi alias Mimi,
Dialogue: 0,0:00:03.57,0:00:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dibesarkan untuk menjadi pewaris keluarga,
Dialogue: 0,0:00:05.86,0:00:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kini hidup bebas sejak adikku lahir.
Dialogue: 0,0:00:08.86,0:00:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah cukup umur,\Naku tak kunjung menemukan calon suami!
Dialogue: 0,0:00:13.79,0:00:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun meminta tolong pada kerabat jauhku,
Dialogue: 0,0:00:15.79,0:00:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Ametis,\Nagar bisa bersekolah di Kerajaan Rubini...
Dialogue: 0,0:00:18.50,0:00:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Pangeran Pertama Kerajaan Rubini,\NRenato di Rubini,
Dialogue: 0,0:00:22.38,0:00:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membatalkan pertunangan kita\Nsekarang juga!
Dialogue: 0,0:00:31.30,0:00:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, hal pertama yang harus\NAnda lakukan adalah...
Dialogue: 0,0:00:34.56,0:00:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beli kacamata!
Dialogue: 0,0:00:36.56,0:00:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya, ya.
Dialogue: 0,0:00:42.52,0:00:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Duke!
Dialogue: 0,0:00:43.69,0:00:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:00:44.40,0:00:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa?
Dialogue: 0,0:00:45.15,0:00:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil dokter!
Dialogue: 0,0:00:45.98,0:00:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Duke!
Dialogue: 0,0:02:25.12,0:02:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta tadi benar-benar kacau.
Dialogue: 0,0:02:27.34,0:02:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mohon maaf yang sebesar-besarnya!
Dialogue: 0,0:02:30.00,0:02:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai asisten Yang Mulia Renato,\Naku benar-benar minta maaf.
Dialogue: 0,0:02:33.93,0:02:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duke Ametis telah kami antar pulang\Nbersama dokter keluarga kerajaan.
Dialogue: 0,0:02:38.85,0:02:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami sudah menyakiti kalian berdua!
Dialogue: 0,0:02:41.52,0:02:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tak perlu meminta maaf\Nsampai seperti itu.
Dialogue: 0,0:02:44.44,0:02:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yang Mulia!\N- Kakak!
Dialogue: 0,0:02:46.88,0:02:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Da-Dalam hal ini,\Nsaya tak punya pembelaan apa-apa...
Dialogue: 0,0:02:53.47,0:02:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu merasa bersalah,\Nitu sudah cukup bagiku.
Dialogue: 0,0:02:57.66,0:02:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:02:58.99,0:03:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan kami menyampaikan\Npermintaan maaf resmi di lain hari.
Dialogue: 0,0:03:03.60,0:03:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai bingung sendiri.
Dialogue: 0,0:03:06.17,0:03:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang seperti itu.
Dialogue: 0,0:03:08.17,0:03:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato benar-benar\Nmerasa bersalah atas tindakannya.
Dialogue: 0,0:03:13.61,0:03:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:03:15.76,0:03:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena keributan ini,
Dialogue: 0,0:03:16.97,0:03:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengangkatannya menjadi putra mahkota\Nmungkin akan diundur.
Dialogue: 0,0:03:20.10,0:03:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri tidak apa-apa?
Dialogue: 0,0:03:22.05,0:03:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya hari ini penampilan resmi kalian\Nsebagai pasangan, kan?
Dialogue: 0,0:03:25.35,0:03:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena pertunangan itu...
Dialogue: 0,0:03:29.73,0:03:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal, Pangeran Renato tak terlalu\Nantusias dengan pertunangan kami.
Dialogue: 0,0:03:35.33,0:03:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:37.81,0:03:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur, aku sudah punya firasat\Nini akan dibatalkan.
Dialogue: 0,0:03:41.78,0:03:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tak perlu cemaskan aku.
Dialogue: 0,0:03:43.37,0:03:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak antusias?
Dialogue: 0,0:03:45.32,0:03:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu bukan alasan\Ndia boleh mengumumkannya di pesta!
Dialogue: 0,0:03:48.75,0:03:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:03:49.63,0:03:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak merundung si Eleonora itu!
Dialogue: 0,0:03:52.96,0:03:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat mengenalmu, dan kamu\Ntak akan melakukan hal seperti itu!
Dialogue: 0,0:03:56.55,0:03:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih, kenapa dia sampai\Ntidak mengenali tunangannya sendiri?
Dialogue: 0,0:03:59.99,0:04:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kami jarang bertemu.
Dialogue: 0,0:04:02.76,0:04:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti dia tidak ingat wajahmu?
Dialogue: 0,0:04:04.89,0:04:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keterlaluan!
Dialogue: 0,0:04:07.37,0:04:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, Mimi...
Dialogue: 0,0:04:09.90,0:04:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan terlalu menyalahkan\NPangeran Renato.
Dialogue: 0,0:04:12.86,0:04:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau adalah pribadi yang cerdas\Ndan bijaksana.
Dialogue: 0,0:04:16.11,0:04:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerdas?
Dialogue: 0,0:04:18.20,0:04:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kalau itu memang keinginanmu.
Dialogue: 0,0:04:20.99,0:04:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:21.91,0:04:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya, aku lebih mencemaskanmu.
Dialogue: 0,0:04:24.37,0:04:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:04:25.50,0:04:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, kamu sudah menarik perhatian\Nyang tak perlu.
Dialogue: 0,0:04:29.04,0:04:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga ini tak memengaruhi pencarian\Nkandidat berkualitasmu...
Dialogue: 0,0:04:34.80,0:04:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:04:36.13,0:04:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya gadis sisaan yang cari jodoh
Dialogue: 0,0:04:38.13,0:04:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai sekolah di luar negeri\Nkarena tak laku di negeri sendiri!
Dialogue: 0,0:04:41.05,0:04:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu, aku menerima pembatalan\Npertunangan yang tak pernah terjadi.
Dialogue: 0,0:04:44.60,0:04:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancur sudah harga diriku!
Dialogue: 0,0:04:46.27,0:04:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku adalah gadis bangsawan\Npaling hina dan tak bermartabat!
Dialogue: 0,0:04:50.77,0:04:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rasa tak akan sampai seburuk itu.
Dialogue: 0,0:04:53.77,0:04:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, rupanya kuucapkan kencang-kencang!
Dialogue: 0,0:04:55.94,0:04:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato pasti akan meluruskan\Nkesalahpahaman ini.
Dialogue: 0,0:04:59.57,0:05:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan berkeliling\Ndan menjelaskan duduk perkaranya.
Dialogue: 0,0:05:02.37,0:05:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:03.81,0:05:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Andai saja Pangeran sialan itu tidak ada!\N- Semua perempuan terlihat sama di mataku.
Dialogue: 0,0:05:06.33,0:05:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau bertemu lagi, bakal kuhajar pria itu.\N- Semua perempuan terlihat sama di mataku.
Dialogue: 0,0:05:09.21,0:05:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:05:10.54,0:05:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menghajarnya.
Dialogue: 0,0:05:14.00,0:05:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dibandingkan Pangeran Renato,\NPangeran Placido benar-benar baik, ya.
Dialogue: 0,0:05:19.22,0:05:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum ini, dia pernah menyapaku\Nyang sedang sendirian.
Dialogue: 0,0:05:23.18,0:05:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini pun dia meminta maaf dengan tulus\Npadahal tidak salah apa-apa.
Dialogue: 0,0:05:27.47,0:05:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:05:28.85,0:05:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akrab dengan Pangeran Placido, kan?
Dialogue: 0,0:05:32.34,0:05:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada akrab,
Dialogue: 0,0:05:34.43,0:05:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami sudah kenal lama\Nkarena berteman sejak kecil, jadi...
Dialogue: 0,0:05:38.65,0:05:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:05:40.26,0:05:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku kalian berdua pasangan yang serasi.
Dialogue: 0,0:05:48.37,0:05:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, sebenarnya...\Nkamu menaksir Pangeran Placido?
Dialogue: 0,0:05:53.21,0:05:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, berarti pangeran sialan itu...
Dialogue: 0,0:05:55.84,0:06:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ralat, kalau Pangeran Renato batalkan\Npertunangannya, kamu yang beruntung?
Dialogue: 0,0:06:01.30,0:06:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa reputasimu akan turun\Nkarena pembatalan itu?
Dialogue: 0,0:06:05.40,0:06:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau pembatalan pertunangannya\Nditarik kembali...
Dialogue: 0,0:06:07.97,0:06:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, pasangannya Pangeran Renato?
Dialogue: 0,0:06:14.60,0:06:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya aku tidur saja.
Dialogue: 0,0:06:16.65,0:06:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:06:21.19,0:06:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf.\NMohon tunggu sebentar.
Dialogue: 0,0:06:25.32,0:06:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat urusan Yang Mulia Renato selesai,\Nbeliau pasti akan segera ke sini.
Dialogue: 0,0:06:30.66,0:06:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka dia benar-benar mengundangku.
Dialogue: 0,0:06:34.27,0:06:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, ruang tamu istana
Dialogue: 0,0:06:37.59,0:06:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar mewah, ya.
Dialogue: 0,0:06:40.43,0:06:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma mentega
Dialogue: 0,0:06:43.55,0:06:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan rasa manis yang berkelas dari krim...
Dialogue: 0,0:06:46.11,0:06:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koki pastri mereka pasti berkualitas tinggi.
Dialogue: 0,0:06:51.14,0:06:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah membuatmu menunggu,
Dialogue: 0,0:06:53.05,0:06:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Annovazzi.
Dialogue: 0,0:06:56.15,0:06:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:57.22,0:06:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengingat margaku dengan benar,
Dialogue: 0,0:06:59.86,0:07:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padahal kebanyakan orang pasti salah.
Dialogue: 0,0:07:02.19,0:07:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh duduk?
Dialogue: 0,0:07:03.49,0:07:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, silakan.
Dialogue: 0,0:07:05.20,0:07:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat orang ini, sepertinya dia ingin\Nmeminta maaf dengan tulus.
Dialogue: 0,0:07:10.66,0:07:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melakukan hal yang tak pantas.
Dialogue: 0,0:07:13.03,0:07:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:07:14.03,0:07:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar alasanmu sekolah\Ndi sini dari Placido.
Dialogue: 0,0:07:16.96,0:07:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar menyesal\Nkarena telah mencoreng
Dialogue: 0,0:07:20.04,0:07:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehormatan dan latar belakangmu.
Dialogue: 0,0:07:21.96,0:07:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kenalkan aku\Ndengan kandidat berkualitas.
Dialogue: 0,0:07:26.37,0:07:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kandidat berkualitas, ya?\NBiar kuatur.
Dialogue: 0,0:07:28.66,0:07:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keceplosan lagi!
Dialogue: 0,0:07:30.89,0:07:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Nona Duke Annovazzi.
Dialogue: 0,0:07:33.77,0:07:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maafkan aku.
Dialogue: 0,0:07:36.23,0:07:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama Annovazzi pasti susah disebut, kan?
Dialogue: 0,0:07:39.19,0:07:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil aku Maria.\NKalau masih susah, panggil saja Mimi.
Dialogue: 0,0:07:43.36,0:07:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Nona Maria.
Dialogue: 0,0:07:46.24,0:07:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kamu sudah dengar dari Nona Aida,
Dialogue: 0,0:07:48.99,0:07:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku selalu menghindarinya.
Dialogue: 0,0:07:51.70,0:07:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:52.70,0:07:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyuruh Placido selalu mendampinginya
Dialogue: 0,0:07:55.45,0:07:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kami sangat jarang bertemu.
Dialogue: 0,0:07:57.71,0:08:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku tak tahu\Npenampilan Nona Aida saat ini.
Dialogue: 0,0:08:02.00,0:08:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa kamu perlu menghindarinya\Nsampai seperti itu?
Dialogue: 0,0:08:05.80,0:08:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, Pangeran dan Aida\Nadalah teman masa kecil.
Dialogue: 0,0:08:09.59,0:08:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:10.72,0:08:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih ingat warna rambutnya...
Dialogue: 0,0:08:13.39,0:08:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pula yang membuatku yakin\Nkamu adalah Aida.
Dialogue: 0,0:08:15.60,0:08:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena jarang ada yang memiliki\Nrambut pirang secantik kalian.
Dialogue: 0,0:08:19.65,0:08:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:22.09,0:08:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap saja, ya.
Dialogue: 0,0:08:23.85,0:08:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Pangeran Renato lakukan itu?
Dialogue: 0,0:08:26.57,0:08:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu di hadapan umum dan pesta kelulusan\Nyang sangat penting!
Dialogue: 0,0:08:31.47,0:08:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin Pangeran yang bijak\Nsudah paham konsekuensinya.
Dialogue: 0,0:08:37.71,0:08:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mungkin batal menjadi putra mahkota.
Dialogue: 0,0:08:40.78,0:08:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tak terpikir sampai ke sana?
Dialogue: 0,0:08:44.80,0:08:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir semua akan baik-baik saja
Dialogue: 0,0:08:47.17,0:08:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau aku tak menjadi putra mahkota.
Dialogue: 0,0:08:49.68,0:08:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:51.59,0:08:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu sampai berkata seperti itu,\Ncoba jelaskan!
Dialogue: 0,0:08:54.81,0:08:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan membocorkannya!
Dialogue: 0,0:08:56.64,0:08:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi tergantung isinya.
Dialogue: 0,0:09:01.19,0:09:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sudahlah!
Dialogue: 0,0:09:06.65,0:09:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, bisikkan saja ke telingaku.
Dialogue: 0,0:09:09.36,0:09:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan orang sini,\Njadi akan pergi cepat atau lambat.
Dialogue: 0,0:09:16.58,0:09:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mau cerita?
Dialogue: 0,0:09:19.46,0:09:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya...
Dialogue: 0,0:09:20.66,0:09:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Placido menaksir Nona Aida.
Dialogue: 0,0:09:25.80,0:09:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tunggu,
Dialogue: 0,0:09:27.21,0:09:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti Aida dan Pangeran Placido saling suka?
Dialogue: 0,0:09:30.53,0:09:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh katakan itu\Npada Pangeran Renato sekarang?
Dialogue: 0,0:09:33.09,0:09:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak boleh!
Dialogue: 0,0:09:34.60,0:09:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rahasia penting milik Aida.
Dialogue: 0,0:09:37.14,0:09:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tapi...
Dialogue: 0,0:09:39.06,0:09:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong rahasiakan saja.
Dialogue: 0,0:09:41.81,0:09:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu mudah ditebak.
Dialogue: 0,0:09:43.94,0:09:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah menaksir gadis itu\Nsejak mereka masih kecil.
Dialogue: 0,0:09:47.69,0:09:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ayah Nona Aida memutuskan\Nbahwa putrinya
Dialogue: 0,0:09:50.69,0:09:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus menjadi tunangan "putra mahkota".
Dialogue: 0,0:09:54.16,0:09:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:09:55.74,0:09:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,\Nkalau aku tak menjadi putra mahkota,
Dialogue: 0,0:09:59.05,0:10:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}putra kedua, Placido,\Nyang akan naik takhta.
Dialogue: 0,0:10:01.23,0:10:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya akan selesai dengan damai...
Dialogue: 0,0:10:03.65,0:10:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, itu perkiraanku.
Dialogue: 0,0:10:04.96,0:10:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:06.25,0:10:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini ternyata baik banget?
Dialogue: 0,0:10:09.37,0:10:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku gagal di bagian\Nyang paling penting.
Dialogue: 0,0:10:12.59,0:10:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu, aku melibatkanmu\Nyang tak ada hubungannya...
Dialogue: 0,0:10:15.76,0:10:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran, kamu ingin memberi kompensasi, kan?
Dialogue: 0,0:10:19.35,0:10:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu saja.
Dialogue: 0,0:10:20.81,0:10:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nlupakan soal kandidat berkualitas,
Dialogue: 0,0:10:23.27,0:10:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan traktir aku makan enak saja!
Dialogue: 0,0:10:25.44,0:10:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Makanan enak?
Dialogue: 0,0:10:28.98,0:10:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu terpikir sesuatu?
Dialogue: 0,0:10:31.36,0:10:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin steik dari Paviliun Marble?
Dialogue: 0,0:10:34.74,0:10:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Steik! Ide bagus!
Dialogue: 0,0:10:37.20,0:10:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari makan sampai kenyang!
Dialogue: 0,0:10:39.08,0:10:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran, kamu harus perbaiki jam tidurmu\Nsebelum kita makan steik.
Dialogue: 0,0:10:42.71,0:10:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya mata panda.
Dialogue: 0,0:10:45.02,0:10:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:10:46.42,0:10:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain sibuk,\Naku juga tak bisa tidur nyenyak.
Dialogue: 0,0:10:49.48,0:10:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku bisa tidur dalam tiga detik.
Dialogue: 0,0:10:51.84,0:10:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iri padamu.
Dialogue: 0,0:10:54.84,0:10:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan secara khusus
Dialogue: 0,0:10:57.43,0:11:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengajarkanmu lagu hitung domba\Nala keluarga Annovazzi.
Dialogue: 0,0:11:01.71,0:11:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu! Dua, tiga, empat!\NLima, enam, tujuh! Delapan!
Dialogue: 0,0:11:07.56,0:11:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembilan! Sepuluh!
Dialogue: 0,0:11:16.53,0:11:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum tidur,\Ntolong ingat gerakanku barusan.
Dialogue: 0,0:11:19.62,0:11:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:20.77,0:11:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tadi pada adikku,\NSaat kunyanyikan lagu hitung domba
Dialogue: 0,0:11:23.20,0:11:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia akan tertawa terbahak-bahak\Ndan tidur nyenyak.
Dialogue: 0,0:11:25.79,0:11:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran juga pasti bisa.
Dialogue: 0,0:11:27.79,0:11:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik?
Dialogue: 0,0:11:29.00,0:11:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar! Tahun ini,\Ndia genap berusia empat tahun.
Dialogue: 0,0:11:31.92,0:11:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Teodorico.
Dialogue: 0,0:11:37.30,0:11:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu menyamakanku dengan adikmu?
Dialogue: 0,0:11:40.10,0:11:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo juga suka sekali ini.
Dialogue: 0,0:11:42.60,0:11:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga.\NKalau ini?
Dialogue: 0,0:11:44.73,0:11:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, hentikan.\NA-Aku mengalah.
Dialogue: 0,0:11:47.56,0:11:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai capek\Nkarena tertawa terbahak-bahak.
Dialogue: 0,0:11:50.01,0:11:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:11:52.07,0:11:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapar dan kurang tidur\Nadalah musuh utama manusia.
Dialogue: 0,0:11:55.40,0:11:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran juga harus istirahat\Nyang banyak, ya.
Dialogue: 0,0:11:58.53,0:11:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengerti.
Dialogue: 0,0:12:02.79,0:12:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengingat wajahmu\Nsebelum tidur malam ini.
Dialogue: 0,0:12:11.34,0:12:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida benar, dia pria yang pintar.
Dialogue: 0,0:12:14.76,0:12:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga memperhatikan Pangeran Placido...
Dialogue: 0,0:12:23.18,0:12:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kucing garong!
Dialogue: 0,0:12:33.02,0:12:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kelihatannya lezat!
Dialogue: 0,0:12:35.78,0:12:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Restoran rekomendasi pangeran memang beda.
Dialogue: 0,0:12:38.48,0:12:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dimakan sampai kenyang.
Dialogue: 0,0:12:40.24,0:12:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:12:41.47,0:12:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:12:44.65,0:12:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:12:46.45,0:12:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:12:47.83,0:12:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat khawatir kalau kamu tak suka.
Dialogue: 0,0:12:50.71,0:12:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak mungkin!
Dialogue: 0,0:12:53.01,0:12:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu yakin ingin mentraktirku saja?
Dialogue: 0,0:12:55.50,0:12:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan kalau mau patungan.
Dialogue: 0,0:12:58.30,0:13:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong izinkan aku mentraktirmu hari ini.
Dialogue: 0,0:13:00.47,0:13:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berterima kasih untuk hari itu.
Dialogue: 0,0:13:02.49,0:13:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa?
Dialogue: 0,0:13:03.43,0:13:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku terasa hangat setiap mengingat
Dialogue: 0,0:13:06.89,0:13:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lagu hitung domba yang kamu ajarkan hari itu.
Dialogue: 0,0:13:09.10,0:13:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tak tidur senyenyak itu.
Dialogue: 0,0:13:18.01,0:13:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget.
Dialogue: 0,0:13:19.95,0:13:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah lama tak menikmati\Nhidangan seperti ini.
Dialogue: 0,0:13:23.49,0:13:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Upacara peresmian putra mahkotanya\Nakan diundur, ya?
Dialogue: 0,0:13:27.75,0:13:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya begitu.
Dialogue: 0,0:13:29.52,0:13:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pribadi tidak keberatan\Nkalau dilepaskan dari posisi.
Dialogue: 0,0:13:35.00,0:13:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia.
Dialogue: 0,0:13:38.80,0:13:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf, Nona Maria,\Naku ada urusan mendadak.
Dialogue: 0,0:13:42.34,0:13:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tak bisa mengantar,\Naku sudah siapkan kereta kencana.
Dialogue: 0,0:13:45.64,0:13:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah cukup.\NBahkan aku bisa pulang sambil lari.
Dialogue: 0,0:13:52.44,0:13:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Kereta kencananya berbeda\Ndengan saat datang.
Dialogue: 0,0:14:00.40,0:14:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya Aida mengungkapkan\Nperasaannya pada Pangeran Placido, ya?
Dialogue: 0,0:14:04.63,0:14:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tidak enak karena selalu\Ndiperlakukan dengan baik.
Dialogue: 0,0:14:07.99,0:14:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia sudah memintaku rahasiakan...
Dialogue: 0,0:14:13.59,0:14:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal orang lain,\Nkenapa semuanya jadi serumit ini, ya?
Dialogue: 0,0:14:18.61,0:14:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ini...
Dialogue: 0,0:14:22.26,0:14:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana?
Dialogue: 0,0:14:30.60,0:14:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar!
Dialogue: 0,0:14:31.35,0:14:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa disuruh pun aku akan keluar.
Dialogue: 0,0:14:35.81,0:14:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sungguh bodoh sampai tak sadar\Nsudah diculik, ya, Maria Antabatti?
Dialogue: 0,0:14:41.57,0:14:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar Annovazzi!
Dialogue: 0,0:14:43.78,0:14:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato saja tidak salah sebut.
Dialogue: 0,0:14:46.32,0:14:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar ahlinya\Nbikin orang jengkel, ya.
Dialogue: 0,0:14:48.53,0:14:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peka dan lancang.
Dialogue: 0,0:14:50.37,0:14:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar, kakak-kakakku sering\Nmenyuruhku menjaga sikap.
Dialogue: 0,0:14:55.00,0:14:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu ada perlu denganku,\NNona Eleonora Casciari?
Dialogue: 0,0:14:59.17,0:15:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu ada!
Dialogue: 0,0:15:00.80,0:15:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan mendekati orang sepertimu\Nkalau tidak ada perlu!
Dialogue: 0,0:15:04.17,0:15:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah hampir\Nmenggaet Pangeran Renato!
Dialogue: 0,0:15:07.43,0:15:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran hanya tertarik pada ayahku.
Dialogue: 0,0:15:10.43,0:15:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertanya dia bertemu dengan siapa,\Ndan pergi ke mana.
Dialogue: 0,0:15:13.39,0:15:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:15:14.35,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, dia ditangkap\Nkarena kasus gratifikasinya ketahuan.
Dialogue: 0,0:15:17.81,0:15:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gratifikasi?
Dialogue: 0,0:15:19.02,0:15:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan urusanmu!
Dialogue: 0,0:15:20.82,0:15:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham sekarang.
Dialogue: 0,0:15:22.11,0:15:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya Pangeran Renato membiarkanmu\Nmenempelinya karena sudah tahu semuanya.
Dialogue: 0,0:15:27.03,0:15:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menempeli, katamu?
Dialogue: 0,0:15:28.78,0:15:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sengaja mengabaikan Aida
Dialogue: 0,0:15:30.91,0:15:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena setengahnya untuk Pangeran Placido,
Dialogue: 0,0:15:33.04,0:15:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan setengahnya lagi untuk menggali\Ninformasi dari putri Baron.
Dialogue: 0,0:15:36.54,0:15:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya dia sangat memikirkan negaranya.
Dialogue: 0,0:15:38.79,0:15:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan abaikan aku!
Dialogue: 0,0:15:41.00,0:15:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bermaksud mengancammu,
Dialogue: 0,0:15:42.84,0:15:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mulai sekarang, kamu harus hidup jujur\Ntanpa melakukan kecurangan lagi.
Dialogue: 0,0:15:46.97,0:15:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang bodoh, ya?
Dialogue: 0,0:15:49.26,0:15:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulislah surat untuk Pangeran.
Dialogue: 0,0:15:51.76,0:15:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu menolak...
Dialogue: 0,0:15:55.43,0:15:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tunggu, tulis surat untuk apa?
Dialogue: 0,0:15:58.00,0:15:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapan terima kasih untuk steik tadi?
Dialogue: 0,0:15:59.69,0:16:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas bukan itu!
Dialogue: 0,0:16:01.02,0:16:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajukan permintaan
Dialogue: 0,0:16:02.69,0:16:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menolong Baron Casciari dan putrinya,\Natau kamu akan dibunuh!
Dialogue: 0,0:16:07.78,0:16:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan kujadikan sandera\Ndan kabur ke luar negeri.
Dialogue: 0,0:16:10.53,0:16:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil!
Dialogue: 0,0:16:11.95,0:16:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Naku akan kirim potongan jarimu.
Dialogue: 0,0:16:15.06,0:16:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Metodemu terlalu sadis.
Dialogue: 0,0:16:16.81,0:16:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?\NNona Maria belum pulang?
Dialogue: 0,0:16:19.88,0:16:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kupikir Pangeran tahu\NMimi pergi ke mana.
Dialogue: 0,0:16:24.00,0:16:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku makan siang bersamanya...
Dialogue: 0,0:16:27.05,0:16:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita terpaksa kembali karena Baron Casciari\Nakan memberikan keterangan.
Dialogue: 0,0:16:32.04,0:16:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pulang sendiri.\NSeharusnya aku tak membiarkannya
Dialogue: 0,0:16:34.89,0:16:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran, tolong jangan menyalahkan diri.
Dialogue: 0,0:16:37.77,0:16:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, kita harus memprioritaskan\Npencarian Nona Maria.
Dialogue: 0,0:16:41.48,0:16:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kalian berdua benar.
Dialogue: 0,0:16:44.90,0:16:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raimondo, siapkan kuda.
Dialogue: 0,0:16:47.36,0:16:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kembali ke Paviliun Marble.
Dialogue: 0,0:16:49.20,0:16:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada orang di sekitar restoran\Nyang melihat sesuatu.
Dialogue: 0,0:16:52.85,0:16:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Placido.
Dialogue: 0,0:16:53.58,0:16:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Kakak.
Dialogue: 0,0:16:54.99,0:16:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku titip Nona Aida.
Dialogue: 0,0:16:57.79,0:16:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:17:03.54,0:17:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jariku baik-baik saja.\NTapi aku harus apa sekarang?
Dialogue: 0,0:17:12.58,0:17:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya pilihanku hanya kabur.
Dialogue: 0,0:17:24.73,0:17:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:17:26.05,0:17:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan sesuatu.
Dialogue: 0,0:17:28.44,0:17:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalaku tiba-tiba dipukul...
Dialogue: 0,0:17:30.81,0:17:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu ingat hal lain?
Dialogue: 0,0:17:33.03,0:17:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa saja boleh.
Dialogue: 0,0:17:34.07,0:17:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar suara\Nkereta kencana yang besar.
Dialogue: 0,0:17:38.66,0:17:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kudengar mereka akan pergi ke utara.
Dialogue: 0,0:17:41.56,0:17:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utara, ya?
Dialogue: 0,0:17:43.57,0:17:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kota ini hanya ada satu jalur\Nmenuju utara.
Dialogue: 0,0:17:45.71,0:17:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin masih terkejar.
Dialogue: 0,0:17:47.80,0:17:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diwi!
Dialogue: 0,0:17:48.55,0:17:49.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia!
Dialogue: 0,0:17:49.46,0:17:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, siapkan kereta.\NKita harus menyusul Yang Mulia!
Dialogue: 0,0:17:55.47,0:17:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kubiarkan kamu lari.
Dialogue: 0,0:18:00.52,0:18:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:01.10,0:18:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, di sana!
Dialogue: 0,0:18:02.23,0:18:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan?\NCepat kejar dia!
Dialogue: 0,0:18:04.52,0:18:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:18:13.75,0:18:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis bangsawan itu larinya cepat sekali!
Dialogue: 0,0:18:18.81,0:18:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah menyerah?
Dialogue: 0,0:18:21.20,0:18:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kamu patuhi kata-kata kami.
Dialogue: 0,0:18:25.46,0:18:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salahkan kami, ya, Nona!
Dialogue: 0,0:18:29.00,0:18:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu!
Dialogue: 0,0:18:30.51,0:18:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua!
Dialogue: 0,0:18:32.55,0:18:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga, empat!
Dialogue: 0,0:18:33.93,0:18:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima!
Dialogue: 0,0:18:34.84,0:18:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam!
Dialogue: 0,0:18:41.52,0:18:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat hajar dia!
Dialogue: 0,0:18:49.36,0:18:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Annovazzi\Nadalah keluarga ahli bela diri.
Dialogue: 0,0:18:51.99,0:18:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuh, delapan, sembilan!
Dialogue: 0,0:18:54.82,0:18:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan aku, si anak bungsu, dibesarkan\Nmenjadi pewaris keluarga Annovazzi...
Dialogue: 0,0:18:59.62,0:19:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan kakak-kakak perempuanku,\Nakulah yang terkuat!
Dialogue: 0,0:19:04.04,0:19:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh!
Dialogue: 0,0:19:20.76,0:19:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak!\NAku takut sekali!
Dialogue: 0,0:19:22.68,0:19:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kamu baik-baik saja.
Dialogue: 0,0:19:24.10,0:19:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lelaki yang tiba-tiba menyerangku,
Dialogue: 0,0:19:27.10,0:19:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tiba-tiba terkapar seperti itu!
Dialogue: 0,0:19:30.19,0:19:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, gerakanmu tadi sangat hebat.
Dialogue: 0,0:19:35.03,0:19:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran sudah lihat sejak kapan?
Dialogue: 0,0:19:36.99,0:19:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kamu menangkis tangan\Nbawahan Eleonora dan kabur.
Dialogue: 0,0:19:40.89,0:19:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lihat semuanya!
Dialogue: 0,0:19:42.62,0:19:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berakhir sudah!
Dialogue: 0,0:19:43.63,0:19:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamat sudah kehidupan gadis bangsawanku!
Dialogue: 0,0:19:47.29,0:19:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bawa mereka.
Dialogue: 0,0:19:48.63,0:19:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berdiri!
Dialogue: 0,0:19:53.00,0:19:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu terluka?
Dialogue: 0,0:19:54.30,0:19:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:55.59,0:19:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang sakit?
Dialogue: 0,0:19:56.97,0:19:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:19:58.72,0:20:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:20:01.26,0:20:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, kenapa aku dipangku Pangeran?
Dialogue: 0,0:20:04.93,0:20:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Eleonora akan diperiksa juga.
Dialogue: 0,0:20:08.31,0:20:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya dia menggunakan\Nbeberapa uang hasil gratifikasi.
Dialogue: 0,0:20:11.02,0:20:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah ganti topik!
Dialogue: 0,0:20:17.78,0:20:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti ketakutan.\NKasihan.
Dialogue: 0,0:20:23.35,0:20:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru sekali ini ada\Nyang mengatakan hal itu padaku.
Dialogue: 0,0:20:29.42,0:20:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus berterima kasih\Nkarena kamu datang menolongku.
Dialogue: 0,0:20:33.30,0:20:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya lakukan yang seharusnya.
Dialogue: 0,0:20:35.30,0:20:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, begitu, ya.
Dialogue: 0,0:20:37.63,0:20:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, apa aku sudah boleh turun?
Dialogue: 0,0:20:41.47,0:20:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:20:42.35,0:20:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu...
Dialogue: 0,0:20:45.31,0:20:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ini?\NTidak bisa lepas!
Dialogue: 0,0:20:49.60,0:20:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku memanggilmu Mimi juga?
Dialogue: 0,0:20:52.11,0:20:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu saja boleh.
Dialogue: 0,0:20:56.11,0:21:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah bilang aku bisa tidur nyenyak\Nsetelah mengingat wajahmu, kan?
Dialogue: 0,0:21:01.20,0:21:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berkata jujur.
Dialogue: 0,0:21:03.37,0:21:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sejak aku bisa tidur\Nnyenyak dan nyaman,
Dialogue: 0,0:21:07.45,0:21:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melupakan kewajiban putra mahkota,\Nkondisi politik dan ekonomi negara.
Dialogue: 0,0:21:11.75,0:21:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti seluruh kabut di depanku\Nlenyap begitu saja.
Dialogue: 0,0:21:17.96,0:21:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya seperti dapat petunjuk\Ndari Tuhan, ya.
Dialogue: 0,0:21:21.22,0:21:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mungkin ini memang petunjuk dari Tuhan.
Dialogue: 0,0:21:25.60,0:21:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:21:28.64,0:21:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikahlah denganku.
Dialogue: 0,0:21:33.40,0:21:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:23:04.99,0:23:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu bicara apa?
Dialogue: 0,0:23:07.91,0:23:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah janji akan kenalkan\Nkandidat berkualitas, kan?
Dialogue: 0,0:23:10.87,0:23:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada kandidat yang lebih berkualitas\Ndari Yang Mulia Renato.
Dialogue: 0,0:23:14.41,0:23:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sejak kapan kamu ada di sana?
Dialogue: 0,0:23:16.04,0:23:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal.
Dialogue: 0,0:23:16.69,0:23:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada!\NAku bersumpah kamu tadi tidak ada!
Dialogue: 0,0:23:19.25,0:23:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada di sini.
Dialogue: 0,0:23:19.96,0:23:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada!
Dialogue: 0,0:23:20.75,0:23:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:23:21.34,0:23:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak lihat!
Dialogue: 0,0:23:22.38,0:23:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:23:22.96,0:23:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak lihat!
Dialogue: 0,0:23:27.01,0:23:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diajari makan dengan bersih dan rapi,\Nlayaknya berlatih bela diri.
Dialogue: 0,0:23:29.97,0:23:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, semuanya kaget
Dialogue: 0,0:23:31.72,0:23:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bilang, "Kapan kamu makannya?\NSudah habis lagi!"
Dialogue: 0,0:23:34.02,0:23:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya aku makan secepat itu, ya?
Dialogue: 0,0:23:35.73,0:23:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari, Aida juga...
Dialogue: 0,0:23:37.15,0:23:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku keceplosan lagi!
