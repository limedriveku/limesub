Dialogue: 0,0:00:29.93,0:00:34.03,tanda,,0000,0000,0000,,38!
Dialogue: 0,0:02:07.77,0:02:11.15,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:02:11.15,0:02:14.53,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:03:23.98,0:03:28.98,tanda,,0000,0000,0000,,EPISODE 6:\NIKAN LEPAS DAN AYAH YANG BERTARUNG
Dialogue: 0,0:03:37.11,0:03:40.20,tanda,,0000,0000,0000,,- 21, 22!
Dialogue: 0,0:03:40.20,0:03:42.45,tanda,,0000,0000,0000,,23, 24...
Dialogue: 0,0:03:43.29,0:03:45.84,tanda,,0000,0000,0000,,25!
Dialogue: 0,0:04:11.23,0:04:12.19,tanda,,0000,0000,0000,,JREENG!
Dialogue: 0,0:05:03.49,0:05:03.85,tanda,,0000,0000,0000,,JLEB
Dialogue: 0,0:06:28.78,0:06:33.96,tanda,,0000,0000,0000,,BAK, BUK, BAK, BUK
Dialogue: 0,0:08:42.03,0:08:44.55,tanda,,0000,0000,0000,,GOGOGOGO...
Dialogue: 0,0:12:12.67,0:12:15.00,tanda,,0000,0000,0000,,TUANG
Dialogue: 0,0:12:17.47,0:12:18.93,tanda,,0000,0000,0000,,SET
Dialogue: 0,0:13:16.94,0:13:20.95,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:13:20.95,0:13:24.95,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:14:15.25,0:14:15.70,tanda,,0000,0000,0000,,ITU
Dialogue: 0,0:15:00.50,0:15:06.97,tanda,,0000,0000,0000,,AYAH - POTRET SAAT 3 TAHUN
Dialogue: 0,0:15:06.97,0:15:07.55,tanda,,0000,0000,0000,,ELUS, ELUS, ELUS
Dialogue: 0,0:15:20.65,0:15:22.99,tanda,,0000,0000,0000,,KYA, KYA
Dialogue: 0,0:15:26.53,0:15:29.95,tanda,,0000,0000,0000,,GOGOGO...
Dialogue: 0,0:17:33.53,0:17:34.27,tanda,,0000,0000,0000,,SENYUM
Dialogue: 0,0:21:13.54,0:21:16.96,tanda,,0000,0000,0000,,PUTRI PAK KADES - PENDUDUK DESA
Dialogue: 0,0:21:16.96,0:21:20.47,tanda,,0000,0000,0000,,PEMIMPIN WILAYAH
Dialogue: 0,0:21:51.46,0:21:54.92,tanda,,0000,0000,0000,,BERSAMBUNG
Dialogue: 0,0:23:34.93,0:23:37.31,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA:
Dialogue: 0,0:23:37.31,0:23:39.60,tanda,,0000,0000,0000,,TINJU IKAN YANG TERTANGKAP
Dialogue: 0,0:00:03.73,0:00:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:00:06.26,0:00:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah ini bisa membantu kalian atau tidak,
Dialogue: 0,0:00:09.03,0:00:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi perlihatkanlah saputangan ini\Npada pengawal di gerbang istana.
Dialogue: 0,0:00:13.37,0:00:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak bisa melawan lagi, kan?
Dialogue: 0,0:00:16.00,0:00:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, akan kusiksa kamu pelan-pelan!
Dialogue: 0,0:00:21.65,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa penjahat selalu memikirkan\Nhal yang sama?
Dialogue: 0,0:00:48.57,0:00:50.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, semoga perjalananmu menyenangkan.
Dialogue: 0,0:00:50.73,0:00:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:00:52.37,0:00:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa nama kalian?
Dialogue: 0,0:00:55.06,0:00:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya orang asing\Nyang kebetulan lewat!
Dialogue: 0,0:01:00.79,0:01:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku harus pulang ke Kerajaan Muro.
Dialogue: 0,0:01:04.50,0:01:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam perjalanan,\Naku menolong warga desa yang kesusahan.
Dialogue: 0,0:01:08.32,0:01:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghajar bandit yang menyerang pedagang
Dialogue: 0,0:01:12.09,0:01:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan akhirnya sampai di rumah.
Dialogue: 0,0:01:34.45,0:01:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:01:36.03,0:01:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Mimi!
Dialogue: 0,0:01:39.41,0:01:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini...
Dialogue: 0,0:01:42.04,0:01:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Mimi!
Dialogue: 0,0:01:45.07,0:01:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:01:48.92,0:01:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah besar, ya,
Dialogue: 0,0:01:50.80,0:01:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teodorico!
Dialogue: 0,0:03:28.98,0:03:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga,
Dialogue: 0,0:03:30.06,0:03:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}empat,
Dialogue: 0,0:03:31.02,0:03:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lima,
Dialogue: 0,0:03:32.15,0:03:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- enam, tujuh, delapan!\N- Kalau kuingat lagi,
Dialogue: 0,0:03:34.69,0:03:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- enam, tujuh, delapan!\N- aku sudah menerima pendidikan berbeda
Dialogue: 0,0:03:37.11,0:03:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dari kakak-kakakku sejak kecil.
Dialogue: 0,0:03:48.71,0:03:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah hafal sampai gerakan 25\Ndi usia tiga tahun.
Dialogue: 0,0:03:52.63,0:03:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini berbakat!
Dialogue: 0,0:03:54.13,0:03:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Annovazzi tak punya anak lelaki,
Dialogue: 0,0:03:56.34,0:03:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bisa mengangkat pewaris perempuan\Nsebagai pengecualian.
Dialogue: 0,0:03:59.76,0:04:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, kita harus ajarkan\Nilmu bela diri pada Nona Maria!
Dialogue: 0,0:04:03.22,0:04:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Master!
Dialogue: 0,0:04:09.31,0:04:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian benar.
Dialogue: 0,0:04:12.19,0:04:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maria, kamu harus jadi pewaris\Nkeluarga Annovazzi!
Dialogue: 0,0:04:16.32,0:04:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Ayah!
Dialogue: 0,0:04:21.52,0:04:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelahnya, empat kakakku\Nyang lepas dari posisi pewaris
Dialogue: 0,0:04:26.31,0:04:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai diajarkan etiket serta tata krama,
Dialogue: 0,0:04:28.33,0:04:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan segera bertunangan atau mencari calon.
Dialogue: 0,0:04:32.71,0:04:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan aku,
Dialogue: 0,0:04:34.95,0:04:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sering dikerumuni orang dewasa\Nmeski di pesta kakakku.
Dialogue: 0,0:04:40.97,0:04:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena terus belajar ilmu bela diri,
Dialogue: 0,0:04:43.72,0:04:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku baru masuk sekolah bangsawan
Dialogue: 0,0:04:46.22,0:04:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di tingkat menengah.
Dialogue: 0,0:04:48.77,0:04:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hari pertama sekolah yang kutunggu!
Dialogue: 0,0:04:50.94,0:04:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi...
Dialogue: 0,0:04:53.27,0:04:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam sejahtera.
Dialogue: 0,0:04:56.11,0:04:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Riasanmu hari ini sangat bagus.
Dialogue: 0,0:04:59.59,0:05:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat gadis bangsawan sebayaku di sana,
Dialogue: 0,0:05:03.85,0:05:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sadar sudah dibesarkan\Nseperti anak lelaki.
Dialogue: 0,0:05:07.91,0:05:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bukan hanya Aida
Dialogue: 0,0:05:09.25,0:05:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menyapa dengan "salam sejahtera".
Dialogue: 0,0:05:11.92,0:05:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam sejahtera.
Dialogue: 0,0:05:16.00,0:05:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Mimi!
Dialogue: 0,0:05:17.21,0:05:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku tidak populer di kalangan lelaki,\N- Cetak dua atau tiga poin lagi, ya!
Dialogue: 0,0:05:19.80,0:05:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- karena mereka menganggapku bak sesama pria.\N- Cetak dua atau tiga poin lagi, ya!
Dialogue: 0,0:05:28.22,0:05:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi keren sekali!
Dialogue: 0,0:05:30.73,0:05:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari-hariku dipenuhi\Nsorakan histeris para gadis.
Dialogue: 0,0:05:34.02,0:05:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,\Nsebagai "pewaris keluarga Duke",
Dialogue: 0,0:05:36.57,0:05:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tentu punya beberapa calon tunangan.
Dialogue: 0,0:05:38.57,0:05:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jelas semuanya hanya mengincar status.
Dialogue: 0,0:05:42.91,0:05:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga suatu hari...
Dialogue: 0,0:05:46.03,0:05:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan punya adik lelaki atau perempuan?
Dialogue: 0,0:05:48.74,0:05:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:52.96,0:05:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi akan jadi kakak, ya.
Dialogue: 0,0:05:55.87,0:05:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau punya adik lelaki atau perempuan?
Dialogue: 0,0:06:00.59,0:06:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik lelaki atau perempuan,\Naku akan senang.
Dialogue: 0,0:06:08.47,0:06:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:06:10.71,0:06:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beberapa bulan setelah itu...
Dialogue: 0,0:06:17.48,0:06:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, dia lembut dan hangat.
Dialogue: 0,0:06:25.49,0:06:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil!\NDia resmi jadi pewaris keluarga!
Dialogue: 0,0:06:28.78,0:06:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar otak otot!
Dialogue: 0,0:06:30.01,0:06:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peka situasi!
Dialogue: 0,0:06:31.95,0:06:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keterlaluan!
Dialogue: 0,0:06:32.79,0:06:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian?
Dialogue: 0,0:06:33.96,0:06:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku orang tua kalian!
Dialogue: 0,0:06:35.50,0:06:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh!
Dialogue: 0,0:06:44.80,0:06:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tunggu.
Dialogue: 0,0:06:46.26,0:06:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh...
Dialogue: 0,0:06:58.31,0:07:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bela diri keluarga Annovazzi\Nada untuk melindungi orang tersayang.
Dialogue: 0,0:07:07.96,0:07:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu melindungimu.
Dialogue: 0,0:07:13.62,0:07:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:07:15.33,0:07:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak Teodorico lahir,
Dialogue: 0,0:07:18.00,0:07:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak perlu jadi pewaris\Nkeluarga lagi, tapi...
Dialogue: 0,0:07:21.05,0:07:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang, aku senang!
Dialogue: 0,0:07:23.34,0:07:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku
Dialogue: 0,0:07:24.55,0:07:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- ingin diperlakukan seperti perempuan,\N- Biar kubawakan barangmu.
Dialogue: 0,0:07:26.80,0:07:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- bak gadis bangsawan lain.\N- Ya ampun.
Dialogue: 0,0:07:28.63,0:07:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah terlambat,
Dialogue: 0,0:07:30.64,0:07:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau belajar etiket,
Dialogue: 0,0:07:48.85,0:07:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga
Dialogue: 0,0:07:50.43,0:07:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti akan menemukan tunangan menawan.
Dialogue: 0,0:07:56.83,0:07:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:07:58.31,0:08:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Mbak?
Dialogue: 0,0:08:01.25,0:08:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua sudah menunggu.
Dialogue: 0,0:08:02.88,0:08:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:08:05.53,0:08:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:07.51,0:08:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku tak seperti biasanya.
Dialogue: 0,0:08:09.89,0:08:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedikit grogi melihat wajah\Nkeluargaku sendiri.
Dialogue: 0,0:08:14.39,0:08:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Ayah dan kakak-kakakku
Dialogue: 0,0:08:16.35,0:08:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar merestui pernikahanku\Ndengan Pangeran Renato?
Dialogue: 0,0:08:27.43,0:08:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, selamat datang!
Dialogue: 0,0:08:31.82,0:08:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Idea, Mbak Nina,
Dialogue: 0,0:08:34.58,0:08:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Sandra, Mbak Gionna...\NLalu, Ibu.
Dialogue: 0,0:08:45.21,0:08:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak langsung masuk rumah?
Dialogue: 0,0:08:48.38,0:08:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah menggendong Macchio\Nkarena mengira itu kamu.
Dialogue: 0,0:08:52.24,0:08:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya Ayah sadar sebelum menggendongnya.
Dialogue: 0,0:08:55.06,0:08:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:08:56.31,0:08:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, Mimi.\NKita makan enak hari ini!
Dialogue: 0,0:08:59.52,0:09:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra Mahkota Muro,\NPangeran Bartholomew juga berkunjung.
Dialogue: 0,0:09:03.65,0:09:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu harus berterima kasih pada Bart.\N- Aku Bart.
Dialogue: 0,0:09:05.52,0:09:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia yang membuktikan
Dialogue: 0,0:09:08.07,0:09:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}surat dari Rubini itu asli.
Dialogue: 0,0:09:11.16,0:09:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu peka sekali, ya.
Dialogue: 0,0:09:13.49,0:09:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dia jadi suami Mbak Nina.
Dialogue: 0,0:09:16.37,0:09:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sandra.
Dialogue: 0,0:09:17.54,0:09:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang apa tadi?
Dialogue: 0,0:09:18.48,0:09:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Ibu, hari ini ada pai daging, kan?
Dialogue: 0,0:09:21.17,0:09:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, Ibu sudah buat lima\Nkhusus untuk hari ini.
Dialogue: 0,0:09:23.96,0:09:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah,
Dialogue: 0,0:09:24.88,0:09:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya seperti di rumah.
Dialogue: 0,0:09:27.92,0:09:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ada yang ingin kamu katakan?
Dialogue: 0,0:09:31.30,0:09:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku dan Pangeran Renato...
Dialogue: 0,0:09:33.97,0:09:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu!
Dialogue: 0,0:09:39.67,0:09:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, aku pulang!
Dialogue: 0,0:09:47.40,0:09:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku bawa oleh-oleh untuk kalian.
Dialogue: 0,0:09:50.53,0:09:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada minyak wangi dan sabun\Nrekomendasi Aida...
Dialogue: 0,0:09:53.22,0:09:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:09:54.32,0:09:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia duduk dengan kaki tertutup.
Dialogue: 0,0:09:57.41,0:09:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi yang itu!
Dialogue: 0,0:09:59.33,0:10:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya hari ini tiba juga.
Dialogue: 0,0:10:01.73,0:10:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tetap minum jus sayur seperti dulu.
Dialogue: 0,0:10:04.33,0:10:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan,\Nkamu minum jus sayur juga di Rubini?
Dialogue: 0,0:10:07.74,0:10:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih tak sangka\Ndia dapat Putra Mahkota Rubini.
Dialogue: 0,0:10:12.34,0:10:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato pria yang baik, kan?
Dialogue: 0,0:10:15.93,0:10:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar ingin bertemu.
Dialogue: 0,0:10:18.01,0:10:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu serius?
Dialogue: 0,0:10:19.91,0:10:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin bertemu\Nputra mahkota kerajaan besar.
Dialogue: 0,0:10:23.14,0:10:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ketahuan bobroknya.
Dialogue: 0,0:10:24.31,0:10:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, aku tak tahu cara menjamunya.
Dialogue: 0,0:10:28.30,0:10:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei,
Dialogue: 0,0:10:29.36,0:10:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sini ada putra mahkota kerajaan ini juga.
Dialogue: 0,0:10:32.70,0:10:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ramai kalau semua berkumpul.
Dialogue: 0,0:10:35.20,0:10:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Mimi.
Dialogue: 0,0:10:37.32,0:10:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Bartholomew pernah bertemu\NPangeran Renato?
Dialogue: 0,0:10:42.03,0:10:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sekadar menyapa.
Dialogue: 0,0:10:44.32,0:10:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau terkesan sebagai pria\Nyang rupawan dan tekun.
Dialogue: 0,0:10:49.35,0:10:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena dia memilih Mimi,
Dialogue: 0,0:10:51.59,0:10:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti bukan sekadar tekun saja.
Dialogue: 0,0:10:55.13,0:10:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, Pangeran Renato\Ndan negaranya aneh
Dialogue: 0,0:10:58.64,0:11:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena ingin menjadikanku ratu selanjutnya.
Dialogue: 0,0:11:02.31,0:11:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak merasa bisa gantikan Aida...
Dialogue: 0,0:11:07.02,0:11:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena tidak ada penggantimu,\Nkamu yang dipilih.
Dialogue: 0,0:11:10.65,0:11:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyahuti isi hatiku sesantai itu.
Dialogue: 0,0:11:14.11,0:11:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin banyak tanya ke Mbak Nina.
Dialogue: 0,0:11:16.53,0:11:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pernikahan dengan putra mahkota\Ndan sebagainya...
Dialogue: 0,0:11:19.37,0:11:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skalanya terlalu besar\Nuntuk dijadikan referensi.
Dialogue: 0,0:11:24.41,0:11:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya kamu suka pria\Nyang lebih lemah darimu.
Dialogue: 0,0:11:28.17,0:11:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:11:29.75,0:11:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakan Pangeran Renato elegan,\Ntapi sulit dihindari.
Dialogue: 0,0:11:33.71,0:11:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga pernah tiba-tiba ada di belakangku.
Dialogue: 0,0:11:37.22,0:11:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:38.93,0:11:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa menyelinap ke belakang Mimi?
Dialogue: 0,0:11:41.47,0:11:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sering tersenyum,
Dialogue: 0,0:11:43.39,0:11:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi cukup kuat\Nsampai pelukannya sulit dilepas.
Dialogue: 0,0:11:46.06,0:11:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali itu aku bertemu pria sepertinya.
Dialogue: 0,0:11:49.94,0:11:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:51.73,0:11:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak punya kelemahan\Ndan bisa membunuhmu dalam sekejap.
Dialogue: 0,0:11:54.93,0:11:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah dengar pembunuh bayaran\Nlegendaris seperti itu.
Dialogue: 0,0:11:59.24,0:12:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Pangeran Renato itu\Nketurunan mereka?
Dialogue: 0,0:12:02.99,0:12:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumpulkan semua guru\Ndi negeri ini besok pagi!
Dialogue: 0,0:12:06.08,0:12:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus siap hadapi serangannya sekarang!
Dialogue: 0,0:12:08.08,0:12:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Ayah bicara apa?
Dialogue: 0,0:12:11.61,0:12:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Duke,
Dialogue: 0,0:12:12.67,0:12:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong jangan serang Yang Mulia Pangeran.
Dialogue: 0,0:12:17.47,0:12:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:12:19.49,0:12:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga...
Dialogue: 0,0:12:21.43,0:12:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus siapkan diri\Nuntuk konferensi perdamaian.
Dialogue: 0,0:12:25.60,0:12:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan berangkat menyapa\Nsebelum pernikahan.
Dialogue: 0,0:12:28.17,0:12:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikah?
Dialogue: 0,0:12:29.23,0:12:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada yang aneh dengan Ayah.
Dialogue: 0,0:12:31.40,0:12:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih syok dengan pernikahan Mimi.
Dialogue: 0,0:12:33.98,0:12:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian anehnya memang sudah bawaan lahir.
Dialogue: 0,0:12:38.65,0:12:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin main dengan Mbak.
Dialogue: 0,0:12:41.32,0:12:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, tapi habiskan dulu\Ndaging di piringmu.
Dialogue: 0,0:12:45.41,0:12:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum juga jus sayurnya.
Dialogue: 0,0:12:47.71,0:12:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:58.16,0:13:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo hebat!
Dialogue: 0,0:13:00.51,0:13:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi malam, kita ke taman sekarang.
Dialogue: 0,0:13:04.01,0:13:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Mimi.\NBicara kita belum selesai!
Dialogue: 0,0:13:08.11,0:13:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblisnya marah, tuh.
Dialogue: 0,0:13:09.81,0:13:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabur!
Dialogue: 0,0:13:26.66,0:13:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:13:28.16,0:13:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi, tinggi!
Dialogue: 0,0:13:30.29,0:13:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:13:34.50,0:13:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo, tiga belas!
Dialogue: 0,0:13:35.84,0:13:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:13:40.51,0:13:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, anak hebat!
Dialogue: 0,0:13:42.63,0:13:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, aku mau lempar putar!
Dialogue: 0,0:13:45.14,0:13:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.\NHup!
Dialogue: 0,0:13:53.04,0:13:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa lebih cepat, lo!
Dialogue: 0,0:13:58.03,0:14:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku mau tidur bersama Mbak.
Dialogue: 0,0:14:00.34,0:14:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:14:02.36,0:14:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:14:03.61,0:14:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan itu, ya.
Dialogue: 0,0:14:05.70,0:14:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu hitung wajah aneh!
Dialogue: 0,0:14:08.58,0:14:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:14:11.37,0:14:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa menceritakan "itu" adalah\Nawal pertemuanku dengan Pangeran.
Dialogue: 0,0:14:15.70,0:14:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus minta dia merahasiakannya.
Dialogue: 0,0:14:20.94,0:14:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak, begini...
Dialogue: 0,0:14:23.80,0:14:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru bisa sampai gerakan 18.
Dialogue: 0,0:14:27.18,0:14:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sampai 18?\NKamu hebat.
Dialogue: 0,0:14:29.81,0:14:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:14:32.43,0:14:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, saat Mbak Mimi seusiaku\Nsudah sampai 25.
Dialogue: 0,0:14:36.93,0:14:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang bilang begitu?
Dialogue: 0,0:14:39.57,0:14:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa.\NAku akan berusaha.
Dialogue: 0,0:14:43.70,0:14:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kamu mendengarnya, ya?
Dialogue: 0,0:14:49.41,0:14:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, Teo akan tumbuh lebih besar
Dialogue: 0,0:14:52.20,0:14:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan lebih kuat dariku.
Dialogue: 0,0:14:54.87,0:14:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:14:55.86,0:14:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tumbuh besar?
Dialogue: 0,0:14:57.16,0:14:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti, pasti!
Dialogue: 0,0:14:58.38,0:14:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga sebesar Ayah?
Dialogue: 0,0:15:01.09,0:15:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, pasti bisa karena bawaan gen.
Dialogue: 0,0:15:05.03,0:15:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski rasanya sedih...
Dialogue: 0,0:15:07.55,0:15:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, semoga kakimu\Nsepanjang Pangeran Renato.
Dialogue: 0,0:15:12.14,0:15:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu Renato?
Dialogue: 0,0:15:13.77,0:15:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Calon suamiku.
Dialogue: 0,0:15:16.52,0:15:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kuat?
Dialogue: 0,0:15:17.27,0:15:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan jadi orang paling berpengaruh\Ndi Kerajaan Rubini.
Dialogue: 0,0:15:20.65,0:15:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat!
Dialogue: 0,0:15:22.99,0:15:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kan?
Dialogue: 0,0:15:24.70,0:15:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar keren,
Dialogue: 0,0:15:26.53,0:15:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan baik hati.
Dialogue: 0,0:15:32.37,0:15:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo, kamu bisa kembali ke dalam?
Dialogue: 0,0:15:35.52,0:15:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:15:43.51,0:15:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu sembunyi.
Dialogue: 0,0:15:46.68,0:15:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah mau ikut main juga?
Dialogue: 0,0:15:49.47,0:15:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkinlah!
Dialogue: 0,0:15:51.39,0:15:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pastikan kalian benar berlatih...
Dialogue: 0,0:15:55.89,0:15:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inspeksi dadakan.
Dialogue: 0,0:16:02.55,0:16:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu betulan
Dialogue: 0,0:16:04.45,0:16:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menikah dengan Putra Mahkota Rubini?
Dialogue: 0,0:16:10.78,0:16:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:13.66,0:16:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku gadis tomboi sepertimu\Ntak bisa jadi putri mahkota.
Dialogue: 0,0:16:18.43,0:16:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, aku setuju.
Dialogue: 0,0:16:24.53,0:16:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasang kuda-kuda.
Dialogue: 0,0:16:27.42,0:16:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hidup sendiri
Dialogue: 0,0:16:34.10,0:16:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di luar negeri dan butuh adaptasi!
Dialogue: 0,0:16:38.48,0:16:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat dan cepat.\NAyah memang hebat.
Dialogue: 0,0:16:43.36,0:16:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu
Dialogue: 0,0:16:45.15,0:16:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah mau bilang apa?
Dialogue: 0,0:16:47.24,0:16:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski negeri tetangga,
Dialogue: 0,0:16:49.35,0:16:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak bisa cepat menolongmu!
Dialogue: 0,0:16:51.82,0:16:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sendirian!
Dialogue: 0,0:17:02.58,0:17:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Pangeran dan Aida,\Nsemua orang baik padaku.
Dialogue: 0,0:17:06.30,0:17:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang istana juga melindungiku!
Dialogue: 0,0:17:10.82,0:17:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melindungimu?
Dialogue: 0,0:17:12.01,0:17:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka yang lemah bisa melakukannya?
Dialogue: 0,0:17:16.72,0:17:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa.
Dialogue: 0,0:17:18.34,0:17:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi mereka
Dialogue: 0,0:17:22.04,0:17:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar mereka bisa melindungiku\Ndengan tenang!
Dialogue: 0,0:17:26.53,0:17:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:17:27.28,0:17:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang membesarkanku agar kuat\Nmelindungi orang tersayang adalah...
Dialogue: 0,0:17:34.27,0:17:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, bukan orang lain!
Dialogue: 0,0:17:39.29,0:17:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bela diri keluarga Annovazzi\Nada untuk melindungi orang tersayang.
Dialogue: 0,0:17:50.88,0:17:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tak jelas!
Dialogue: 0,0:17:54.01,0:17:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:59.06,0:18:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah keturunan keluarga Duke Annovazzi!
Dialogue: 0,0:18:04.90,0:18:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semenjak Teo lahir,
Dialogue: 0,0:18:08.15,0:18:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah selalu tampak merasa bersalah padaku.
Dialogue: 0,0:18:13.16,0:18:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia sebenarnya
Dialogue: 0,0:18:16.20,0:18:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selalu menertawakanku dengan lagak jagoan,
Dialogue: 0,0:18:19.69,0:18:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersuara lantang,
Dialogue: 0,0:18:22.21,0:18:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sangat belagu.
Dialogue: 0,0:18:24.61,0:18:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria yang tertawa lebar
Dialogue: 0,0:18:26.71,0:18:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seolah siap menelanmu bulat-bulat.
Dialogue: 0,0:18:31.28,0:18:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa tenang\Ndan biarkan mereka melindungimu.
Dialogue: 0,0:18:36.76,0:18:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu!
Dialogue: 0,0:18:38.43,0:18:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti sekarang.
Dialogue: 0,0:18:41.33,0:18:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini, ya.
Dialogue: 0,0:18:42.56,0:18:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyuruhmu cari kandidat berkualitas,\Ntapi ini terlalu tinggi.
Dialogue: 0,0:18:48.19,0:18:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kubilang bawa anak kedua\Natau ketiga bangsawan biasa saja.
Dialogue: 0,0:18:52.61,0:18:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak menyimak bagian itu.
Dialogue: 0,0:18:57.57,0:19:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tak berniat\Nmembiarkanmu menikah ke luar negeri.
Dialogue: 0,0:19:03.04,0:19:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu, tidak?
Dialogue: 0,0:19:05.17,0:19:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato...
Dialogue: 0,0:19:06.96,0:19:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin buat jepit rambut baru\Nberdasarkan lambang kerajaan.
Dialogue: 0,0:19:10.92,0:19:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi empat lubang ini akan tetap ada,
Dialogue: 0,0:19:14.22,0:19:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena percuma saja kalau dihilangkan.
Dialogue: 0,0:19:18.43,0:19:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini
Dialogue: 0,0:19:20.31,0:19:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}desain jepit rambut yang kubuat\Nbersama Ayah
Dialogue: 0,0:19:24.94,0:19:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah diskusi panjang.
Dialogue: 0,0:19:27.94,0:19:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bentuknya berubah suatu saat nanti,
Dialogue: 0,0:19:32.07,0:19:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menjaganya seumur hidupku.
Dialogue: 0,0:19:36.15,0:19:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena inilah kebanggaanku.
Dialogue: 0,0:19:39.99,0:19:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Ayah mengizinkanku\Nsekolah di luar negeri,
Dialogue: 0,0:19:42.91,0:19:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa bertemu Pangeran.
Dialogue: 0,0:19:45.21,0:19:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:51.96,0:19:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Pangeran datang, tolong sambut dia, ya?
Dialogue: 0,0:19:56.45,0:19:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:20:04.47,0:20:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, permisi.
Dialogue: 0,0:20:06.31,0:20:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal darurat yang perlu kamu dengar.
Dialogue: 0,0:20:08.90,0:20:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:10.53,0:20:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, tadi...
Dialogue: 0,0:20:12.07,0:20:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda yang bernama Tuan Raimondo?
Dialogue: 0,0:20:15.40,0:20:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NAh, benar.
Dialogue: 0,0:20:18.24,0:20:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada warga Desa Navarro yang ingin\Nsegera bertemu denganku,
Dialogue: 0,0:20:22.20,0:20:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membawa surat rekomendasi Count Falzone.
Dialogue: 0,0:20:27.06,0:20:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu mereka
Dialogue: 0,0:20:29.04,0:20:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyerahkan saputangan Nona Maria\Nbernoda merah kehitaman.
Dialogue: 0,0:20:33.55,0:20:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noda merah kehitaman katamu?
Dialogue: 0,0:20:35.92,0:20:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira darah, jadi segera kuanalisis.
Dialogue: 0,0:20:39.72,0:20:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bekas anggur.
Dialogue: 0,0:20:41.39,0:20:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggur...
Dialogue: 0,0:20:43.39,0:20:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia sedang makan anggur saat itu.
Dialogue: 0,0:20:45.39,0:20:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena menyerahkan saputangan kotor,\Nitu pasti Nona Maria.
Dialogue: 0,0:20:49.94,0:20:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut kesaksian warga desa,
Dialogue: 0,0:20:51.65,0:20:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria mengenalkan mereka\Npada Count Falzone
Dialogue: 0,0:20:56.36,0:20:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan minta mereka ajukan permintaan\Nbertemu denganku.
Dialogue: 0,0:20:59.95,0:21:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya Mimi kenal Count Falzone?
Dialogue: 0,0:21:04.37,0:21:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria menolong kereta kuda\Npedagang yang disewa
Dialogue: 0,0:21:07.83,0:21:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Count Falzone dari serangan.
Dialogue: 0,0:21:09.87,0:21:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:21:11.25,0:21:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka perlu apa?
Dialogue: 0,0:21:13.54,0:21:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya putri kades mereka menghilang,
Dialogue: 0,0:21:16.96,0:21:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bangsawan penguasa tak bertindak,
Dialogue: 0,0:21:20.47,0:21:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu Nona Maria bantu mereka\Nyang kebingungan.
Dialogue: 0,0:21:23.60,0:21:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, orang berlogat kental\Nmenceritakan mirip itu.
Dialogue: 0,0:21:28.81,0:21:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemimpin wilayah Desa Navarro...
Dialogue: 0,0:21:31.39,0:21:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Count Nadir.
Dialogue: 0,0:21:34.06,0:21:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raimondo, kita berangkat sekarang!
Dialogue: 0,0:21:36.44,0:21:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah siapkan semua.
Dialogue: 0,0:21:38.07,0:21:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku bisa segera bertemu Mimi.
Dialogue: 0,0:21:41.74,0:21:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berniat pergi malam ini juga?
Dialogue: 0,0:21:46.76,0:21:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri kades menghilang,
Dialogue: 0,0:21:49.16,0:21:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus bergegas.
Dialogue: 0,0:21:50.94,0:21:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, kamu tersenyum.
Dialogue: 0,0:23:26.47,0:23:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anjing milik Ibu Suri sangat imut.
Dialogue: 0,0:23:29.18,0:23:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pernah punya peliharaan.
Dialogue: 0,0:23:31.26,0:23:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat imut dan menemaniku latihan.
Dialogue: 0,0:23:33.52,0:23:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan anjing, sih, tapi beruang.
Dialogue: 0,0:23:34.93,0:23:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku ketahuan Ibu...
Dialogue: 0,0:23:37.31,0:23:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku keceplosan lagi!
