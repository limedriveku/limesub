Dialogue: 0,0:00:28.76,0:00:32.14,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:00:32.14,0:00:35.52,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:01:45.00,0:01:50.01,tanda,,0000,0000,0000,,EPISODE 5: IKAN LEPAS PULANG KAMPUNG
Dialogue: 0,0:04:18.57,0:04:19.49,tanda,,0000,0000,0000,,DIAM
Dialogue: 0,0:09:58.45,0:10:02.67,tanda,,0000,0000,0000,,BUK, BUK, BUK
Dialogue: 0,0:12:41.78,0:12:45.66,tanda,,0000,0000,0000,,JENG JEEENG!
Dialogue: 0,0:13:21.95,0:13:25.95,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:13:25.95,0:13:29.96,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:15:40.92,0:15:43.92,tanda,,0000,0000,0000,,DIAM-DIAM...
Dialogue: 0,0:16:11.41,0:16:15.45,tanda,,0000,0000,0000,,SERET, SERET
Dialogue: 0,0:16:23.00,0:16:23.88,tanda,,0000,0000,0000,,TOK
Dialogue: 0,0:23:34.93,0:23:36.03,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA:
Dialogue: 0,0:23:36.03,0:23:39.40,tanda,,0000,0000,0000,,IKAN LEPAS DAN AYAH YANG BERTARUNG
Dialogue: 0,0:00:00.56,0:00:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu mencolok, ya.
Dialogue: 0,0:00:02.44,0:00:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:00:05.61,0:00:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat!
Dialogue: 0,0:00:08.53,0:00:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bertunangan dengan Pangeran Renato,
Dialogue: 0,0:00:11.07,0:00:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pulang ke kediaman keluargaku\Ndi Kerajaan Muro.
Dialogue: 0,0:01:56.35,0:02:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanan dari ibu kota Kerajaan Rubini\Nke Kerajaan Muro memakan waktu tiga hari.
Dialogue: 0,0:02:02.39,0:02:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, aku naik kereta keluarga Ametis\Nmenuju kota di dekat perbatasan.
Dialogue: 0,0:02:06.69,0:02:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, pindah ke kereta keluarga Annovazzi\Nyang datang menjemputku.
Dialogue: 0,0:02:18.49,0:02:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kelihatannya seru.
Dialogue: 0,0:02:23.57,0:02:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No-Nona Maria,\Ntolong jangan pergi terlalu jauh...
Dialogue: 0,0:02:26.92,0:02:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa. Masih ada waktu\Nsampai jemputanku datang.
Dialogue: 0,0:02:35.64,0:02:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:02:40.35,0:02:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru dipetik tadi pagi.\NSilakan dicoba.
Dialogue: 0,0:02:49.19,0:02:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:02:51.08,0:02:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin Pangeran Renato mencobanya juga.
Dialogue: 0,0:02:54.78,0:02:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski makan hidangan lezat setiap hari,
Dialogue: 0,0:02:57.07,0:03:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin dia jarang makan buah\Nyang baru saja dipetik.
Dialogue: 0,0:03:02.56,0:03:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:03:08.13,0:03:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melakukannya\Nsetelah kami menikah nanti!
Dialogue: 0,0:03:11.96,0:03:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin...
Dialogue: 0,0:03:13.63,0:03:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, mau mencicipi anggurnya?
Dialogue: 0,0:03:16.43,0:03:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggur?\NMau!
Dialogue: 0,0:03:22.72,0:03:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa manis dan asam yang seimbang
Dialogue: 0,0:03:25.44,0:03:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diikuti cita rasa yang tertinggal\Ndi dalam mulut!
Dialogue: 0,0:03:28.94,0:03:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, tentu!
Dialogue: 0,0:03:30.77,0:03:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau beli sekarang, bisa diisi sepuasnya\Nke dalam keranjang ini.
Dialogue: 0,0:03:34.11,0:03:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli!
Dialogue: 0,0:03:42.29,0:03:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona!
Dialogue: 0,0:03:44.45,0:03:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan sekali kalau mereka jemputanku.
Dialogue: 0,0:03:52.67,0:03:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goffred, Macchio!
Dialogue: 0,0:03:56.55,0:03:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona!
Dialogue: 0,0:03:58.80,0:04:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu.\NKalian sehat-sehat saja, kan?
Dialogue: 0,0:04:04.35,0:04:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Hore!
Dialogue: 0,0:04:07.23,0:04:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, putri mahkota!
Dialogue: 0,0:04:09.77,0:04:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, aku lega kamu masih sama seperti dulu.
Dialogue: 0,0:04:13.94,0:04:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bicara apa?\NHentikan, kami baru bertunangan.
Dialogue: 0,0:04:19.49,0:04:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:04:21.30,0:04:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri mahkota.
Dialogue: 0,0:04:23.08,0:04:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:04:25.08,0:04:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona membuat panik orang rumah\Nkarena surat dari Kerajaan Rubini itu!
Dialogue: 0,0:04:32.13,0:04:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Ayah marah?
Dialogue: 0,0:04:34.80,0:04:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:04:36.17,0:04:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baru melihat ekspresi yang seperti itu.
Dialogue: 0,0:04:41.80,0:04:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kakak-kakakku?
Dialogue: 0,0:04:43.68,0:04:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para nona yang sudah pindah\Ndatang untuk menunggumu.
Dialogue: 0,0:04:49.14,0:04:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bakal berisik sekali.\NAku jadi tidak ingin pulang.
Dialogue: 0,0:04:53.06,0:04:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah.
Dialogue: 0,0:04:54.57,0:04:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona harus jelaskan sendiri kejadiannya.
Dialogue: 0,0:04:57.57,0:05:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Muda Teodorico juga bilang,\N"Aku tak sabar ingin bertemu Mbak."
Dialogue: 0,0:05:04.78,0:05:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo pulang sekarang juga!
Dialogue: 0,0:05:07.70,0:05:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.\NSelamat tinggal!
Dialogue: 0,0:05:17.59,0:05:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona mungkin lelah menempuh perjalanan,\Ntapi kita hanya istirahat makan siang, ya.
Dialogue: 0,0:05:22.64,0:05:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kami ingin segera\Nmelewati perbatasan.
Dialogue: 0,0:05:24.72,0:05:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:05:28.85,0:05:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia putri bangsawan?
Dialogue: 0,0:05:31.03,0:05:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia ada di tempat seperti ini?
Dialogue: 0,0:05:33.73,0:05:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona sudah terbiasa tinggal\Ndi Kerajaan Rubini?
Dialogue: 0,0:05:36.36,0:05:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, di sana benar-benar seru.
Dialogue: 0,0:05:38.86,0:05:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang memperlakukanku dengan baik.
Dialogue: 0,0:05:41.07,0:05:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:05:42.91,0:05:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:05:44.67,0:05:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:50.00,0:05:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:05:52.92,0:05:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:05:55.29,0:05:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena makin dekat Kerajaan Muro,\Nrasa makanannya jadi mulai mirip.
Dialogue: 0,0:05:58.75,0:06:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya masakan di Kerajaan Rubini\Nitu berbeda, ya?
Dialogue: 0,0:06:03.13,0:06:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:06:04.97,0:06:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip, tapi masakan Kerajaan Rubini\Nterasa agak hambar?
Dialogue: 0,0:06:13.79,0:06:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, apa boleh makan sebanyak itu?
Dialogue: 0,0:06:17.06,0:06:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona saat lapar memang jadi perut karet, ya.
Dialogue: 0,0:06:20.65,0:06:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembarangan, bilang aku perut karet.
Dialogue: 0,0:06:26.41,0:06:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona tidak berubah, ya.
Dialogue: 0,0:06:29.24,0:06:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya? Aku merasa diriku\Nsudah sedikit lebih anggun.
Dialogue: 0,0:06:35.00,0:06:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona pasti bercanda.
Dialogue: 0,0:06:36.08,0:06:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:06:37.08,0:06:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:52.68,0:06:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, jalan pegunungan menuju\NKerajaan Muro rawan bandit gunung.
Dialogue: 0,0:06:58.15,0:07:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya daerah ini, ya?
Dialogue: 0,0:07:01.01,0:07:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lewat jalan ini setengah tahun lalu,\Ntapi tidak terjadi apa-apa.
Dialogue: 0,0:07:05.78,0:07:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal baru setengah tahun berlalu,\Nentah kenapa terasa bernostalgia.
Dialogue: 0,0:07:12.54,0:07:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena banyak hal yang terjadi...
Dialogue: 0,0:07:18.79,0:07:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, anggurnya...
Dialogue: 0,0:07:23.21,0:07:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ada apa?
Dialogue: 0,0:07:25.22,0:07:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Nona.\NItu...
Dialogue: 0,0:07:29.68,0:07:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian ingin melewati jalan ini,\Nlangkahi dulu mayat kami!
Dialogue: 0,0:07:38.69,0:07:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?\NJangan-jangan mereka banditnya?
Dialogue: 0,0:07:43.40,0:07:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membujuk mereka\Nagar membiarkan kita lewat.
Dialogue: 0,0:07:46.15,0:07:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona tunggu saja di dalam kereta.
Dialogue: 0,0:07:48.87,0:07:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak terlihat seperti bandit.\NJangan sampai berkelahi, ya.
Dialogue: 0,0:07:52.87,0:07:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tergantung reaksi mereka.
Dialogue: 0,0:08:00.08,0:08:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?\NSiapa kalian?
Dialogue: 0,0:08:06.76,0:08:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan kami, tuan-nona bangsawan!
Dialogue: 0,0:08:09.47,0:08:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tangkap dan bawa kami\Nke istana kerajaan!
Dialogue: 0,0:08:13.39,0:08:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mohon!
Dialogue: 0,0:08:19.60,0:08:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, ada apa ini?
Dialogue: 0,0:08:24.61,0:08:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Tuan Putri Bangsawan!
Dialogue: 0,0:08:27.95,0:08:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi, dia Tuan Putri!
Dialogue: 0,0:08:33.45,0:08:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri, kami mohon!
Dialogue: 0,0:08:35.83,0:08:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bawa alat pertanian\Nyang dirawat dengan sangat apik.
Dialogue: 0,0:08:39.83,0:08:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti alat yang masih terus dipakai.\NMereka juga tak berniat membunuh.
Dialogue: 0,0:08:45.12,0:08:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka tidak berniat menipu kami.
Dialogue: 0,0:08:49.47,0:08:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong angkat kepala kalian,\Naku akan mendengarkannya.
Dialogue: 0,0:08:54.51,0:08:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Tuan Putri yang baik hati.
Dialogue: 0,0:08:56.81,0:08:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita akan berhasil.
Dialogue: 0,0:08:58.81,0:09:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita beruntung.
Dialogue: 0,0:09:01.73,0:09:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu orang yang bicara medok sekali.
Dialogue: 0,0:09:05.61,0:09:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya...
Dialogue: 0,0:09:06.82,0:09:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa alasan kalian melakukan ini,\Ntapi pilih-pilihlah target sasaranmu.
Dialogue: 0,0:09:13.32,0:09:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyerang kereta yang dikusiri\Norang berotot seperti mereka.
Dialogue: 0,0:09:18.79,0:09:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan kami.
Dialogue: 0,0:09:20.92,0:09:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, putri kepala desa Navarro\Ntiba-tiba menghilang.
Dialogue: 0,0:09:26.42,0:09:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghilang?
Dialogue: 0,0:09:29.42,0:09:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:31.34,0:09:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tiba-tiba tidak terlihat\Nsejak beberapa hari yang lalu.
Dialogue: 0,0:09:35.97,0:09:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sering mengunjungi kediaman penguasa,\Ntapi tak kunjung ditanggapi.
Dialogue: 0,0:09:41.27,0:09:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pemilik wilayah ini?
Dialogue: 0,0:09:44.15,0:09:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Count Nardi.
Dialogue: 0,0:09:47.73,0:09:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah bertemu.
Dialogue: 0,0:09:50.19,0:09:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bangsawan di sini tidak bertindak,\Npolisi dan kesatria tak akan menyelidiki.
Dialogue: 0,0:09:58.45,0:10:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bangsawan kejam
Dialogue: 0,0:10:00.04,0:10:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena mengabaikan rakyatnya!
Dialogue: 0,0:10:02.67,0:10:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja yang menyerbu langsung\Nke rumahnya!
Dialogue: 0,0:10:04.88,0:10:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nona, tenang dulu.\N- Benar-benar sulit dipercaya!
Dialogue: 0,0:10:08.00,0:10:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau Nona menyerbu rumah Count sekarang,\N- Rakyatnya sedang tertimpa bencana!
Dialogue: 0,0:10:10.26,0:10:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu hanya akan merepotkan Pangeran Renato.
Dialogue: 0,0:10:13.34,0:10:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, kita dengarkan\Nceritanya sampai akhir.
Dialogue: 0,0:10:20.47,0:10:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian menyerang kereta bangsawan\Nsupaya ditangkap dan dibawa ke istana?
Dialogue: 0,0:10:26.36,0:10:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:27.40,0:10:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pikir, cara itu bisa membantu kami\Nbicara dengan petinggi kepolisian.
Dialogue: 0,0:10:33.53,0:10:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi kami tak punya pilihan lain.
Dialogue: 0,0:10:38.62,0:10:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Kenapa orang-orang di negeri ini\Nselalu berencana mengorbankan diri?
Dialogue: 0,0:10:44.50,0:10:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memanggilku?
Dialogue: 0,0:10:49.63,0:10:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:10:52.30,0:10:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah ini bisa membantu kalian atau tidak,
Dialogue: 0,0:10:55.01,0:10:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi perlihatkanlah sapu tangan ini\Npada pengawal di gerbang istana.
Dialogue: 0,0:10:59.64,0:11:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raimondo, yang akan menemui kalian.\NMungkin, asisten andalan putra mahkota,
Dialogue: 0,0:11:07.35,0:11:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kerjanya cepat dan baik hati.
Dialogue: 0,0:11:11.11,0:11:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi cepat marah juga.
Dialogue: 0,0:11:13.65,0:11:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, sepertinya tadi aku mendengar sesuatu.
Dialogue: 0,0:11:16.82,0:11:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri mengenal Putra Mahkota, ya?
Dialogue: 0,0:11:20.24,0:11:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bisa dibilang begitu.
Dialogue: 0,0:11:23.15,0:11:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Tuan Putri.
Dialogue: 0,0:11:25.62,0:11:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih banyak, ya.
Dialogue: 0,0:11:27.83,0:11:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak tahu harus balas budi seperti apa.
Dialogue: 0,0:11:30.21,0:11:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya. Jangan pernah bertindak\Ngegabah seperti ini lagi.
Dialogue: 0,0:11:34.01,0:11:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:11:35.30,0:11:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini tidak dipenuhi orang jahat saja.
Dialogue: 0,0:11:40.72,0:11:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gadis baik hati kebanggaan kami.
Dialogue: 0,0:11:44.60,0:11:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan berusaha mencari orang\Nyang mau membantu mencari dirinya.
Dialogue: 0,0:11:49.19,0:11:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja semua berjalan lancar.
Dialogue: 0,0:11:56.15,0:11:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada masalah lain?
Dialogue: 0,0:11:58.74,0:12:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, selesai satu masalah,\Ndatang lagi yang baru.
Dialogue: 0,0:12:01.87,0:12:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dari sana.
Dialogue: 0,0:12:03.41,0:12:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita lihat!
Dialogue: 0,0:12:07.33,0:12:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkapan besar!
Dialogue: 0,0:12:08.79,0:12:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga, kereta ke ibu kota pasti\Ndipenuhi barang-barang bagus!
Dialogue: 0,0:12:12.17,0:12:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kita untung besar!
Dialogue: 0,0:12:14.34,0:12:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, lihat ini.
Dialogue: 0,0:12:15.71,0:12:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, ada daging kualitas tinggi.\N- Lihat juga sebelah sini.
Dialogue: 0,0:12:18.43,0:12:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengantar barang tanpa pengawal\Nsama saja dengan menyuruh kami mencurinya!
Dialogue: 0,0:12:26.14,0:12:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren, mereka itu contoh nyata\Ndari bandit gunung, ya.
Dialogue: 0,0:12:29.31,0:12:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya untuk kagum.
Dialogue: 0,0:12:31.77,0:12:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?\NKita sudah lihat.
Dialogue: 0,0:12:35.28,0:12:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lihat?
Dialogue: 0,0:12:38.03,0:12:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian ada di sini?
Dialogue: 0,0:12:40.16,0:12:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:12:41.78,0:12:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya ide bagus.
Dialogue: 0,0:12:43.78,0:12:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengaran seperti masalah.
Dialogue: 0,0:12:46.12,0:12:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ide cemerlang!
Dialogue: 0,0:12:48.33,0:12:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kereta kuda milik bangsawan\Ndi ibu kota, kan?
Dialogue: 0,0:12:52.25,0:12:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, bandit itu sendiri\Nyang menjelaskannya.
Dialogue: 0,0:12:56.71,0:13:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulanglah ke desa, lalu bawa alat\Nuntuk memperbaiki kereta kuda.
Dialogue: 0,0:13:01.09,0:13:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian bantu dan membuat dia\Nberutang budi,
Dialogue: 0,0:13:04.10,0:13:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin polisi akan lebih cepat\Ndatang membantu!
Dialogue: 0,0:13:06.52,0:13:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami harus melewati jalan ini\Nuntuk kembali ke desa...
Dialogue: 0,0:13:10.56,0:13:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?
Dialogue: 0,0:13:13.02,0:13:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak mampu mengusir\Npara penjahat itu...
Dialogue: 0,0:13:17.44,0:13:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:13:18.94,0:13:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada kami!
Dialogue: 0,0:13:38.34,0:13:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Mimi sudah tiba di Kerajaan Muro\Ndengan selamat?
Dialogue: 0,0:13:42.89,0:13:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, aku sudah menegaskan\Npada Nona Maria agar tidak,
Dialogue: 0,0:13:49.06,0:13:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dilarang keras ikut campur masalah\Nberbahaya, apa pun yang terjadi.
Dialogue: 0,0:13:55.90,0:13:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:07.41,0:14:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka akan baik-baik saja?
Dialogue: 0,0:14:10.12,0:14:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Tuan Putri juga ke sana?
Dialogue: 0,0:14:12.66,0:14:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya yang akan berkelahi\Nhanya dua pria berotot itu.
Dialogue: 0,0:14:18.63,0:14:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, dengar baik-baik.
Dialogue: 0,0:14:20.67,0:14:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita lakukan seperti ini...
Dialogue: 0,0:14:22.76,0:14:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Macchio akan mengepung kereta\Nlalu diskusi dengan mereka.
Dialogue: 0,0:14:25.98,0:14:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gagal, kami akan hajar mereka\Nsatu per satu.
Dialogue: 0,0:14:29.41,0:14:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian!
Dialogue: 0,0:14:30.81,0:14:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku?
Dialogue: 0,0:14:32.14,0:14:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona sembunyi saja di sini.
Dialogue: 0,0:14:34.35,0:14:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa?
Dialogue: 0,0:14:36.69,0:14:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri bangsawan yang bertarung memakai\Ngaun itu terlalu mencolok.
Dialogue: 0,0:14:39.98,0:14:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Nona sudah dilarang\Nikut campur masalah apa pun?
Dialogue: 0,0:14:45.61,0:14:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya tidak boleh!
Dialogue: 0,0:14:47.62,0:14:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, baiklah, aku akan berjaga\Nkalau-kalau ada yang kabur.
Dialogue: 0,0:14:52.50,0:14:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona tak perlu cemas!
Dialogue: 0,0:14:54.50,0:14:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berangkat, Goffred!
Dialogue: 0,0:14:56.75,0:14:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:15:05.18,0:15:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kalian?
Dialogue: 0,0:15:06.84,0:15:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti mencuri, kalau tidak,
Dialogue: 0,0:15:14.85,0:15:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kutinju!
Dialogue: 0,0:15:16.52,0:15:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka payah bernegosiasi, ya.
Dialogue: 0,0:15:20.31,0:15:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal kemampuan bertarung,\Nmereka tidak akan kalah.
Dialogue: 0,0:15:26.16,0:15:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diperhatikan, sepertinya mereka\Nhanya ingin menguji kemampuan.
Dialogue: 0,0:15:34.41,0:15:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bosan kalau menonton saja.
Dialogue: 0,0:15:51.26,0:15:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga puluh!
Dialogue: 0,0:16:00.19,0:16:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:16:01.69,0:16:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang tak perlu cemas?
Dialogue: 0,0:16:04.30,0:16:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya ada satu yang berhasil kabur.
Dialogue: 0,0:16:08.20,0:16:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ada satu orang di sini.
Dialogue: 0,0:16:11.41,0:16:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, sudah kubilang sembunyi saja.
Dialogue: 0,0:16:17.21,0:16:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang!
Dialogue: 0,0:16:18.33,0:16:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!\NKamu apakan abangku?
Dialogue: 0,0:16:27.30,0:16:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, itu titik kelemahan milik Benkei.
Dialogue: 0,0:16:30.84,0:16:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu, ada pria besar bernama Benkei\Nyang sekujur tubuhnya tertancap panah.
Dialogue: 0,0:16:36.43,0:16:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masuk akal!\NKenapa dia sudah tertancap anak panah?
Dialogue: 0,0:16:44.48,0:16:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena kamu, gadis bodoh!
Dialogue: 0,0:16:46.19,0:16:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pura-pura pingsan supaya kamu lengah.
Dialogue: 0,0:16:50.49,0:16:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, jangan bergerak\Nkalau tak ingin gadis ini terluka.
Dialogue: 0,0:16:56.79,0:16:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak bisa melawan lagi, kan?
Dialogue: 0,0:16:59.46,0:17:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, akan kusiksa kamu pelan-pelan!
Dialogue: 0,0:17:04.25,0:17:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang!
Dialogue: 0,0:17:05.75,0:17:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Putri!
Dialogue: 0,0:17:07.30,0:17:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya!
Dialogue: 0,0:17:10.83,0:17:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa penjahat selalu memikirkan\Nhal yang sama?
Dialogue: 0,0:17:19.63,0:17:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga puluh
Dialogue: 0,0:17:21.84,0:17:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}delapan!
Dialogue: 0,0:17:50.01,0:17:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bertiga monster!
Dialogue: 0,0:17:51.80,0:17:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabur!
Dialogue: 0,0:18:02.77,0:18:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lemah sekali.\NPangeran Renato saja tidak terlempar.
Dialogue: 0,0:18:07.67,0:18:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:18:09.90,0:18:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato lihat jurus nomor 38-mu?
Dialogue: 0,0:18:13.61,0:18:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa beliau baik-baik saja?
Dialogue: 0,0:18:21.41,0:18:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, butuh satu gelas teh lagi?
Dialogue: 0,0:18:24.29,0:18:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku baik-baik saja.
Dialogue: 0,0:18:26.99,0:18:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut mitos timur, bersin artinya\Nada yang sedang membicarakan kita.
Dialogue: 0,0:18:34.75,0:18:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Mimi sedang membicarakan aku.
Dialogue: 0,0:18:45.81,0:18:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu, kalian sudah menyelamatkanku.
Dialogue: 0,0:18:48.07,0:18:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:18:49.69,0:18:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu apes sekali, ya.
Dialogue: 0,0:18:51.49,0:18:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, pastikan sewa pengawal untukmu.
Dialogue: 0,0:18:55.53,0:18:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memasang roda di kereta kudamu.
Dialogue: 0,0:18:58.03,0:19:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah perlahan ke desa terdekat\Ndan perbaiki keretamu di sana.
Dialogue: 0,0:19:03.25,0:19:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, namanya Desa Navarro.
Dialogue: 0,0:19:06.58,0:19:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penduduk di desa itu terkenal ramah.
Dialogue: 0,0:19:16.13,0:19:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh tak tahu harus membalas\Nbudi kalian dengan cara apa.
Dialogue: 0,0:19:21.50,0:19:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, semoga perjalananmu menyenangkan.
Dialogue: 0,0:19:23.43,0:19:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!\NSiapa nama kalian?
Dialogue: 0,0:19:29.33,0:19:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya orang asing\Nyang kebetulan lewat!
Dialogue: 0,0:19:39.34,0:19:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantiknya!\NDi sana Desa Navarro, ya?
Dialogue: 0,0:19:43.45,0:19:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, sebentar lagi perbatasan negara.
Dialogue: 0,0:19:46.50,0:19:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa penduduk desa tadi sudah berangkat\Nmenuju ibu kota, ya?
Dialogue: 0,0:19:50.71,0:19:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja semua lancar.
Dialogue: 0,0:19:53.38,0:19:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga, Nona sama seperti dulu.
Dialogue: 0,0:19:57.22,0:20:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?\NMungkin benar.
Dialogue: 0,0:20:15.32,0:20:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku sampai di Kerajaan Muro.
Dialogue: 0,0:20:31.67,0:20:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tolong berhenti setelah lewat\Ngerbang rumah, ya.
Dialogue: 0,0:20:35.38,0:20:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jalan kaki karena\Nsudah lama tidak pulang.
Dialogue: 0,0:20:38.92,0:20:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengerti.
Dialogue: 0,0:21:08.31,0:21:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu terbiasa di rumah Aida,\Ntempat ini malah terasa seperti rumah asing.
Dialogue: 0,0:21:14.06,0:21:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini tempatku lahir dan dibesarkan.
Dialogue: 0,0:21:18.21,0:21:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sudah lama\Naku tidak menghirup aroma ini.
Dialogue: 0,0:21:21.83,0:21:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya hangat seperti sedang dipeluk.
Dialogue: 0,0:21:37.44,0:21:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan!
Dialogue: 0,0:21:41.10,0:21:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan!
Dialogue: 0,0:21:43.16,0:21:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan!
Dialogue: 0,0:21:52.62,0:21:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:23:26.59,0:23:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya empat kakak perempuan.
Dialogue: 0,0:23:28.55,0:23:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena cuma aku yang pandai bela diri,\Nkalian pikir semuanya patuh padaku?
Dialogue: 0,0:23:31.72,0:23:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak!
Dialogue: 0,0:23:32.85,0:23:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak-kakakku seram saat marah.
Dialogue: 0,0:23:34.93,0:23:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama...
Dialogue: 0,0:23:36.03,0:23:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku keceplosan lagi, tapi masih aman!
