Dialogue: 0,0:01:56.01,0:01:58.59,sign,,0000,0000,0000,,EPISODE 12: IKAN YANG LEPAS\NDARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:01:58.59,0:02:01.02,sign,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:03:15.26,0:03:19.64,sign,,0000,0000,0000,,SYOK
Dialogue: 0,0:04:36.67,0:04:42.26,sign,,0000,0000,0000,,SALTING
Dialogue: 0,0:04:54.98,0:04:56.15,sign,,0000,0000,0000,,KYA KYA
Dialogue: 0,0:05:09.62,0:05:12.50,sign,,0000,0000,0000,,ASTAGA!
Dialogue: 0,0:05:30.14,0:05:32.90,sign,,0000,0000,0000,,DEG
Dialogue: 0,0:08:09.51,0:08:10.26,sign,,0000,0000,0000,,MENTARI!
Dialogue: 0,0:08:32.03,0:08:36.03,sign,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:08:36.03,0:08:40.03,sign,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:20:17.07,0:20:19.57,sign,,0000,0000,0000,,MERAJUK
Dialogue: 0,0:20:41.60,0:20:42.68,sign,,0000,0000,0000,,WAAAAA!
Dialogue: 0,0:00:04.61,0:00:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Ratu, bahaya!
Dialogue: 0,0:00:14.49,0:00:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang masih ingat
Dialogue: 0,0:00:15.37,0:00:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kasus penyerangan Baginda Ratu\Nbeberapa waktu lalu?
Dialogue: 0,0:00:19.42,0:00:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tahu kenyataan di baliknya!
Dialogue: 0,0:00:21.91,0:00:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelakunya Tuan Ireneo...
Dialogue: 0,0:00:24.34,0:00:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bukan.
Dialogue: 0,0:00:25.38,0:00:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelakunya Zaila yang menaruh hati\Npada Tuan Ireneo.
Dialogue: 0,0:00:27.84,0:00:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, dia bukan mengincar Baginda Ratu,\Ntapi mengincarku.
Dialogue: 0,0:00:32.72,0:00:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Tuan Ireneo\Nsedang menggoda gadis bangsawan muda.
Dialogue: 0,0:00:37.52,0:00:42.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang dikendalikan emosi\Nberniat menakutinya...
Dialogue: 0,0:00:42.52,0:00:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak berniat membunuhnya.
Dialogue: 0,0:00:46.03,0:00:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kamu pergi\Nke kamar Tuan Ireneo bersama kesatria
Dialogue: 0,0:00:50.70,0:00:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengayunkan pisau kertas\Nke arah Nona Maria, kan?
Dialogue: 0,0:00:53.83,0:00:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... Kamu benar.
Dialogue: 0,0:00:57.58,0:01:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena melihatnya bermesraan dengan\NTuan Ireneo, aku jadi sangat marah...
Dialogue: 0,0:01:04.70,0:01:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu tindakan yang gegabah,\Ntapi kalau tidak melakukannya,
Dialogue: 0,0:01:09.13,0:01:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa Tuan Ireneo akan kabur,\Ndan tak mau menemuiku lagi.
Dialogue: 0,0:01:14.35,0:01:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang paling menyakitkan bagiku adalah\Ndia tak memercayai perasaanku.
Dialogue: 0,0:01:20.85,0:01:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melaporkan hasil penyelidikan\Npada Yang Mulia Renato.
Dialogue: 0,0:01:29.99,0:01:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon sampaikan bahwa aku\Nsiap menerima hukuman apa pun.
Dialogue: 0,0:01:36.24,0:01:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak terlalu paham\Nsoal hubungan orang dewasa
Dialogue: 0,0:01:39.04,0:01:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti selingkuhan dan semacamnya,
Dialogue: 0,0:01:41.54,0:01:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi yang terpenting,\NZaila kapok dan mulai lagi dari awal.
Dialogue: 0,0:01:46.42,0:01:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, Tuan Ireneo juga.
Dialogue: 0,0:01:48.84,0:01:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, ini bukan waktunya\Nmencemaskan orang lain!
Dialogue: 0,0:01:52.84,0:01:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta malamnya akan segera dimulai!
Dialogue: 0,0:02:01.02,0:02:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasangan Yang Mulia Renato itu\Nputri Duke Ametis, kan?
Dialogue: 0,0:02:05.48,0:02:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak.\NKabarnya bukan.
Dialogue: 0,0:02:07.52,0:02:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dia orang yang berbeda dan menawan.
Dialogue: 0,0:02:11.65,0:02:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orangnya seperti apa, ya?
Dialogue: 0,0:02:13.70,0:02:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga belum pernah lihat secara langsung.
Dialogue: 0,0:02:17.41,0:02:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti wanita tercantik di dunia.
Dialogue: 0,0:02:20.24,0:02:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak sabar.
Dialogue: 0,0:02:27.04,0:02:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida...
Dialogue: 0,0:02:28.09,0:02:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, kepalaku sakit sekali.
Dialogue: 0,0:02:31.38,0:02:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Mimi.\NMinum dulu.
Dialogue: 0,0:02:42.23,0:02:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segarnya.
Dialogue: 0,0:02:43.39,0:02:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sekarang jam berapa?
Dialogue: 0,0:02:45.35,0:02:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku pergi ke balkon, lalu...
Dialogue: 0,0:02:47.73,0:02:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melihat wanita yang mencurigakan,\Nlalu terjadi satu-dua hal
Dialogue: 0,0:02:50.98,0:02:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membuatmu terseret pertengkaran\Nantara Tuan Ireneo dan kekasihnya.
Dialogue: 0,0:02:54.95,0:02:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kamu juga mabuk\Ndan membuat keributan besar.
Dialogue: 0,0:02:57.53,0:02:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:03:01.04,0:03:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mendengar ceritamu,\Ningatanku perlahan...
Dialogue: 0,0:03:07.29,0:03:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida, bagaimana pesta malamnya?\NDansa pertamanya?
Dialogue: 0,0:03:11.63,0:03:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi mulai.
Dialogue: 0,0:03:13.21,0:03:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah...
Dialogue: 0,0:03:15.26,0:03:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu! Bagaimana ini?
Dialogue: 0,0:03:17.51,0:03:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilanku benar-benar berantakan.
Dialogue: 0,0:03:19.64,0:03:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku, Mimi.
Dialogue: 0,0:03:21.43,0:03:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan keluarga Ametis bisa diandalkan.
Dialogue: 0,0:03:24.48,0:03:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada kami!
Dialogue: 0,0:03:34.82,0:03:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida benar.
Dialogue: 0,0:03:37.57,0:03:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan keluarga Ametis\Nmemang yang terbaik!
Dialogue: 0,0:03:40.62,0:03:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cantik, Mimi.
Dialogue: 0,0:03:42.41,0:03:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga...
Dialogue: 0,0:03:44.83,0:03:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu pucat.\NLapar, ya?
Dialogue: 0,0:03:48.33,0:03:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah sibuk sejak pagi
Dialogue: 0,0:03:51.13,0:03:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sekarang dibuat repot\Nmasalah Tuan Ireneo...
Dialogue: 0,0:03:55.55,0:03:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu belum makan apa-apa, kan?
Dialogue: 0,0:03:59.14,0:04:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NAku tidak lapar.
Dialogue: 0,0:04:02.51,0:04:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mau minum teh?
Dialogue: 0,0:04:04.27,0:04:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:05.64,0:04:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sungguh, aku baik-baik saja.
Dialogue: 0,0:04:11.02,0:04:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku sampai pangling, Mimi.
Dialogue: 0,0:04:15.15,0:04:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran.
Dialogue: 0,0:04:16.57,0:04:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku sudah merepotkan\Ndan membuat kalian cemas.
Dialogue: 0,0:04:20.62,0:04:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:04:22.16,0:04:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya sudah lewat.\NAngkat kepalamu.
Dialogue: 0,0:04:31.17,0:04:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga,\Ntak salah aku memilih warna emas.
Dialogue: 0,0:04:34.42,0:04:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat cocok pakai itu.
Dialogue: 0,0:04:36.67,0:04:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pangeran juga tampan.
Dialogue: 0,0:04:39.09,0:04:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida juga cantik.
Dialogue: 0,0:04:40.59,0:04:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:42.26,0:04:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida bilang aku sudah\Nmembuat keributan besar,
Dialogue: 0,0:04:45.43,0:04:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tak terlalu ingat kejadiannya.
Dialogue: 0,0:04:47.93,0:04:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat mimpi soal Pangeran Renato,
Dialogue: 0,0:04:51.52,0:04:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku yang tidak tahu malu\Nkarena memimpikan itu?
Dialogue: 0,0:04:56.15,0:04:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.\NAku ini membayangkan apa?
Dialogue: 0,0:04:57.82,0:05:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.\NKalian sedang makan, ya?
Dialogue: 0,0:05:00.53,0:05:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.\NIni...
Dialogue: 0,0:05:03.91,0:05:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir... Aida mau makan...
Dialogue: 0,0:05:09.62,0:05:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dimasukkan ke mulutku?
Dialogue: 0,0:05:12.50,0:05:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan sibuk dan tak sempat\Nmakan saat pesta nanti,
Dialogue: 0,0:05:16.59,0:05:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya kamu makan sesuatu sekarang.
Dialogue: 0,0:05:19.26,0:05:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti lipstiknya luntur!
Dialogue: 0,0:05:21.47,0:05:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lipstik?\NBenar juga.
Dialogue: 0,0:05:25.76,0:05:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku jadi tidak sopan, ya?
Dialogue: 0,0:05:28.35,0:05:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sudah kebiasaan.
Dialogue: 0,0:05:34.44,0:05:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu kalian mengobrol.
Dialogue: 0,0:05:36.65,0:05:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya seluruh tamu undangan telah tiba,\Nmari berangkat menuju tempat acara.
Dialogue: 0,0:05:42.66,0:05:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:05:43.74,0:05:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Pangeran,\Naku jadi lebih percaya diri.
Dialogue: 0,0:05:47.87,0:05:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi.
Dialogue: 0,0:05:49.16,0:05:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari tunjukkan hasil latihan kita!
Dialogue: 0,0:06:01.67,0:06:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, orangnya banyak sekali.
Dialogue: 0,0:06:05.43,0:06:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini pesta terbesar pertama\Nyang diadakan sejak kamu datang.
Dialogue: 0,0:06:11.98,0:06:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan ramai, ya.
Dialogue: 0,0:06:15.61,0:06:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para bangsawan suka bergosip.
Dialogue: 0,0:06:25.74,0:06:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pedulikan kata-kata mereka.
Dialogue: 0,0:06:28.24,0:06:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, mari pastikan lagi\Nurutan prosesi acara.
Dialogue: 0,0:06:31.87,0:06:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi Baginda Raja\Nakan memberikan sambutan.
Dialogue: 0,0:06:35.17,0:06:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu sudah dengar?\N- Setelah itu,
Dialogue: 0,0:06:36.42,0:06:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentu, kabarnya Nona Aida\N- tirai akan terangkat dan kita akan...
Dialogue: 0,0:06:38.79,0:06:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- berganti pasangan pangeran kedua,\N- tirai akan terangkat dan kita akan...
Dialogue: 0,0:06:40.59,0:06:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Placido.
Dialogue: 0,0:06:44.13,0:06:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Placido juga sama anehnya.
Dialogue: 0,0:06:46.97,0:06:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa dia mau menerima "bekas" orang lain?
Dialogue: 0,0:06:48.97,0:06:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal pertunangannya dengan\NYang Mulia Renato baru saja dibatalkan,
Dialogue: 0,0:06:52.52,0:06:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak muda cepat sekali\Nbuka lembaran baru.
Dialogue: 0,0:06:55.02,0:07:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Nona Maria yang akan\Nmenjadi ratu punya kepribadian nyentrik.
Dialogue: 0,0:07:00.32,0:07:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa merebut Yang Mulia dari Nona Aida,
Dialogue: 0,0:07:03.36,0:07:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya Nona Maria\Nlumayan pandai menggoda.
Dialogue: 0,0:07:07.07,0:07:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini pernikahan\Nuntuk kepentingan politik,
Dialogue: 0,0:07:10.58,0:07:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Muro itu terlalu kecil.
Dialogue: 0,0:07:13.70,0:07:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak melakukan apa pun yang memalukan.
Dialogue: 0,0:07:17.12,0:07:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku tak peduli\Norang mau bilang apa.
Dialogue: 0,0:07:20.42,0:07:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Pangeran Placido...
Dialogue: 0,0:07:23.17,0:07:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah sumpahku, tapi...
Dialogue: 0,0:07:26.55,0:07:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku gemetar.
Dialogue: 0,0:07:29.72,0:07:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu membayangkan kemungkinan terburuk\Nhingga tak bisa tidur sejak kemarin.
Dialogue: 0,0:07:35.98,0:07:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya perlu melakukannya\Nseperti saat latihan.
Dialogue: 0,0:07:38.56,0:07:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu mencemaskan apa pun.
Dialogue: 0,0:07:41.36,0:07:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku yang mengatakan itu,
Dialogue: 0,0:07:43.57,0:07:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya justru aku\Nyang tak bisa seperti biasa.
Dialogue: 0,0:07:50.16,0:07:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida.
Dialogue: 0,0:07:52.66,0:07:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku salah, lindungi aku, ya.
Dialogue: 0,0:07:59.46,0:08:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan yang hangat.
Dialogue: 0,0:08:02.46,0:08:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terjadi sesuatu,\Naku akan membantumu.
Dialogue: 0,0:08:04.67,0:08:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Placido...
Dialogue: 0,0:08:07.34,0:08:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sini, Pangeran Renato juga.\N- Kakak juga!
Dialogue: 0,0:08:12.43,0:08:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida,\Nkalau ada hal yang bisa kulakukan...
Dialogue: 0,0:08:19.31,0:08:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:08:21.02,0:08:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menerima semua dukungan kalian.
Dialogue: 0,0:08:24.61,0:08:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja sekarang.
Dialogue: 0,0:08:28.28,0:08:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tak sendirian lagi.
Dialogue: 0,0:08:46.42,0:08:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kuucapkan terima kasih\Natas kehadiran sekalian.
Dialogue: 0,0:08:51.89,0:08:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini adalah hari istimewa\Nkarena kedua putraku
Dialogue: 0,0:08:54.60,0:08:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}resmi mengikat pertunangan\Ndengan kekasih mereka.
Dialogue: 0,0:08:58.35,0:09:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rayakan dan berkahilah mereka\Ndengan sepenuh hati.
Dialogue: 0,0:09:01.23,0:09:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran kedua Placido dan calon putri,
Dialogue: 0,0:09:05.11,0:09:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Duke Aida Ametis.
Dialogue: 0,0:09:07.69,0:09:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, putra mahkota Renato,\Ndan calon putri mahkota,
Dialogue: 0,0:09:12.70,0:09:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Duke Maria Annovazzi.
Dialogue: 0,0:09:24.88,0:09:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Renato tampan sekali hari ini!
Dialogue: 0,0:09:27.84,0:09:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diakah Nona Maria itu?
Dialogue: 0,0:09:30.13,0:09:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya dia putri Duke dari pedesaan.
Dialogue: 0,0:09:32.97,0:09:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Muro.
Dialogue: 0,0:09:34.55,0:09:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana hanya ada gunung dan desa petani.
Dialogue: 0,0:09:37.47,0:09:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah melihatnya di pesta malam.
Dialogue: 0,0:09:39.81,0:09:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya dia ahli bela diri dan sejenisnya.
Dialogue: 0,0:09:43.06,0:09:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bela apa?\NOh, mungkin dia ahli berdansa.
Dialogue: 0,0:10:13.05,0:10:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh elegan.
Dialogue: 0,0:10:15.59,0:10:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Placido\Nyang memimpin dengan lembut,
Dialogue: 0,0:10:17.89,0:10:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditambah langkah Nona Aida yang cantik.
Dialogue: 0,0:10:20.06,0:10:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida memang hebat.
Dialogue: 0,0:10:24.19,0:10:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, bagaimana dengan pasangan satu lagi?
Dialogue: 0,0:10:40.16,0:10:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran memang hebat.
Dialogue: 0,0:10:42.45,0:10:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku terlalu semangat\Nsampai ingin melompat,
Dialogue: 0,0:10:45.17,0:10:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia segera menyesuaikan.
Dialogue: 0,0:10:57.93,0:11:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali melangkah\Nmengikuti alunan musik,
Dialogue: 0,0:11:01.27,0:11:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mataku hanya tertuju pada Pangeran.
Dialogue: 0,0:11:04.69,0:11:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan.
Dialogue: 0,0:11:05.77,0:11:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus berdansa dengan anggun\Nseperti saat latihan.
Dialogue: 0,0:11:11.48,0:11:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru!
Dialogue: 0,0:11:16.53,0:11:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:11:17.45,0:11:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali.
Dialogue: 0,0:11:22.95,0:11:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi memang hebat.
Dialogue: 0,0:11:25.21,0:11:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil mencuri hati para tamu\Nyang skeptis dalam sekejap.
Dialogue: 0,0:11:29.75,0:11:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sadar, dia telah memikat\Norang-orang yang tidak ramah.
Dialogue: 0,0:11:33.84,0:11:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kita yang ikut berdansa bersamanya\Njuga ikut terpukau.
Dialogue: 0,0:11:38.51,0:11:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, pilihan Kakak tidak salah.
Dialogue: 0,0:11:42.51,0:11:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kamu benar.
Dialogue: 0,0:11:44.94,0:11:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga kamulah pilihan yang tepat.
Dialogue: 0,0:11:48.81,0:11:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi pasti bisa menjadi ratu\Nyang dicintai semua orang.
Dialogue: 0,0:12:03.62,0:12:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:12:07.21,0:12:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar puas\Nbisa melihat mereka dipuji orang-orang.
Dialogue: 0,0:12:13.42,0:12:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:12:14.88,0:12:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:17.05,0:12:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menyangka anak itu\Nbisa berdansa seanggun itu.
Dialogue: 0,0:12:20.30,0:12:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya.
Dialogue: 0,0:12:21.76,0:12:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sering berlatih.
Dialogue: 0,0:12:24.01,0:12:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia berjuang dengan sangat keras.
Dialogue: 0,0:12:27.39,0:12:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak cantik sekali!
Dialogue: 0,0:12:34.19,0:12:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau lihat!
Dialogue: 0,0:12:35.72,0:12:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wajahnya bening!
Dialogue: 0,0:12:38.70,0:12:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badannya kelihatan langsing.
Dialogue: 0,0:12:40.78,0:12:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu pasti karunia cinta.
Dialogue: 0,0:12:44.49,0:12:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan dorong-dorong!
Dialogue: 0,0:12:47.50,0:12:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo?\NEh, semuanya datang?
Dialogue: 0,0:12:51.38,0:12:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejutannya sukses.
Dialogue: 0,0:12:53.29,0:12:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran yang memanggil mereka?
Dialogue: 0,0:12:56.26,0:12:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:04.14,0:13:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentunya Tuan Raimondo sudah...
Dialogue: 0,0:13:06.64,0:13:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, aku sudah tahu.
Dialogue: 0,0:13:14.27,0:13:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Raja, kuharap kamu berkunjung\Nke Kerajaan Muro.
Dialogue: 0,0:13:19.36,0:13:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, aku juga ingin ke sana.
Dialogue: 0,0:13:21.41,0:13:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Teodorico,\Nsaat kamu sudah lebih besar nanti,
Dialogue: 0,0:13:25.12,0:13:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersekolahlah di kerajaan ini.
Dialogue: 0,0:13:28.08,0:13:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Nona Aida!
Dialogue: 0,0:13:31.04,0:13:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang suka kue tar persik ini.
Dialogue: 0,0:13:34.63,0:13:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar ayah kalian senang jus sayur,\Njadi kami siapkan juga.
Dialogue: 0,0:13:39.47,0:13:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jus sayur Kerajaan Rubini enak banget!
Dialogue: 0,0:13:43.47,0:13:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?\NAku mau juga.
Dialogue: 0,0:13:47.14,0:13:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!\NAku mau tambah!
Dialogue: 0,0:13:49.64,0:13:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu minum secepat itu.
Dialogue: 0,0:13:52.60,0:13:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi,
Dialogue: 0,0:13:55.48,0:13:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kamu bersenang-senang?
Dialogue: 0,0:13:57.32,0:13:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, Baginda Ratu.
Dialogue: 0,0:14:02.74,0:14:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, Renato hanya memikirkan negara,\Nsampai mengabaikan dirinya sendiri.
Dialogue: 0,0:14:10.75,0:14:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat kaget saat mendengar dia\Nmenemukan calon tunangannya sendiri.
Dialogue: 0,0:14:18.67,0:14:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sepertinya ini pertama kalinya\N- Jangan terlalu banyak, ya.
Dialogue: 0,0:14:21.26,0:14:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia memilih untuk diri sendiri.
Dialogue: 0,0:14:24.22,0:14:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Placido anak yang sangat baik hati,
Dialogue: 0,0:14:27.30,0:14:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini!\N- tapi kerap mengalah demi orang lain.
Dialogue: 0,0:14:28.64,0:14:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, terima kasih banyak.\N- tapi kerap mengalah demi orang lain.
Dialogue: 0,0:14:31.48,0:14:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:14:33.02,0:14:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku yakin dia memendam perasaannya pada Aida\N- Apa ada juga untukku?
Dialogue: 0,0:14:35.60,0:14:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- karena tahu penderitaan yang Renato hadapi.\N- Ini khusus untuk nona bangsawan.
Dialogue: 0,0:14:40.03,0:14:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:41.11,0:14:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu pula, aku senang bisa melihat\Nkedua putraku berbahagia saat pesta malam.
Dialogue: 0,0:14:48.58,0:14:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahagia bisa punya dua menantu\Nyang begitu cantik.
Dialogue: 0,0:14:53.41,0:14:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus langgeng, ya.
Dialogue: 0,0:14:55.50,0:14:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mohon bimbingannya.
Dialogue: 0,0:14:58.84,0:15:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Ratu.
Dialogue: 0,0:15:02.09,0:15:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan bunganya.
Dialogue: 0,0:15:07.43,0:15:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo, terima kasih, ya.
Dialogue: 0,0:15:09.47,0:15:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesayanganku bertambah lagi!
Dialogue: 0,0:15:17.56,0:15:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ireneo akan menjalani masa hukuman
Dialogue: 0,0:15:19.82,0:15:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di rumah keluarga bibi\Nuntuk sementara waktu.
Dialogue: 0,0:15:22.69,0:15:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zaila juga menerima hukuman yang sama, kan?
Dialogue: 0,0:15:26.78,0:15:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka berdua tidak akan bertemu lagi?
Dialogue: 0,0:15:29.49,0:15:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.\NIreneo itu baik pada perempuan,
Dialogue: 0,0:15:33.29,0:15:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti dia akan lakukan sesuatu.
Dialogue: 0,0:15:50.51,0:15:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, aku boleh cerita sesuatu?
Dialogue: 0,0:15:54.10,0:15:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal apa?
Dialogue: 0,0:15:58.56,0:16:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat cemas.
Dialogue: 0,0:16:00.65,0:16:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pertunangan kita?
Dialogue: 0,0:16:03.11,0:16:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu.
Dialogue: 0,0:16:05.03,0:16:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang menjadi putra mahkota.
Dialogue: 0,0:16:09.28,0:16:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku sudah sadar bahwa aku\Nberbeda dengan orang lain sejak lahir.
Dialogue: 0,0:16:16.71,0:16:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku sadar bahwa\Norang-orang akan bahagia
Dialogue: 0,0:16:19.67,0:16:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau aku tumbuh pintar dan sehat.
Dialogue: 0,0:16:22.42,0:16:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau semua orang senang,\Naku juga senang.
Dialogue: 0,0:16:26.49,0:16:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku berusaha\Nuntuk selalu pintar dan sehat.
Dialogue: 0,0:16:31.85,0:16:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham perasaanmu.
Dialogue: 0,0:16:38.44,0:16:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, Mimi!
Dialogue: 0,0:16:39.48,0:16:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kamu sudah menguasai\Nsampai nomor 36!
Dialogue: 0,0:16:43.40,0:16:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa depan keluarga Annovazzi pasti terjamin!
Dialogue: 0,0:16:47.11,0:16:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:16:48.99,0:16:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspektasi orang-orang\Nmenjadi alasanku berusaha.
Dialogue: 0,0:16:53.83,0:16:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apa kamu pernah cemas?
Dialogue: 0,0:16:57.20,0:17:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membahas soal ini,\Nmungkin kamu akan membenciku.
Dialogue: 0,0:17:01.25,0:17:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku terkadang merasa cemas.
Dialogue: 0,0:17:05.96,0:17:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpikir, "Apa aku sudah\Nmenjawab ekspektasi semua orang?"
Dialogue: 0,0:17:11.80,0:17:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu! Bukankah Pangeran\Nselalu memikirkan semua orang?
Dialogue: 0,0:17:16.35,0:17:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, semoga saja begitu...
Dialogue: 0,0:17:19.02,0:17:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kalau Pangeran cemas soal sesuatu,\Ntanyakan saja padaku.
Dialogue: 0,0:17:24.19,0:17:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjawabnya dengan benar!
Dialogue: 0,0:17:26.28,0:17:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab apa?
Dialogue: 0,0:17:27.31,0:17:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku akan mengatakan berulang kali\Nbahwa Pangeran Renato yang terbaik!
Dialogue: 0,0:17:32.99,0:17:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kalaupun kamu bukan yang terbaik,\Nmari menjadi yang terbaik bersama.
Dialogue: 0,0:17:40.08,0:17:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diingat lagi, aku beberapa kali cemas\Nmemikirkan jabatan putra mahkota,
Dialogue: 0,0:17:45.34,0:17:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku hanya pernah menyesal satu kali.
Dialogue: 0,0:17:47.67,0:17:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyesal karena apa?
Dialogue: 0,0:17:49.76,0:17:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bertemu denganmu di pesta akademi.
Dialogue: 0,0:17:53.76,0:17:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kegagalan itu membuat Pangeran\Nyang sempurna tak terkalahkan trauma, ya?
Dialogue: 0,0:17:59.43,0:18:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu.
Dialogue: 0,0:18:01.73,0:18:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku tak akan sempat hadir\Nke pesta kelulusan.
Dialogue: 0,0:18:05.31,0:18:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu harus berterima kasih\Nseperti apa atas pertolonganmu, Pangeran.
Dialogue: 0,0:18:10.86,0:18:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu dipikirkan.
Dialogue: 0,0:18:12.28,0:18:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NApa kamu mau mampir ke rumahku?
Dialogue: 0,0:18:15.45,0:18:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah pasti senang.
Dialogue: 0,0:18:18.54,0:18:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Baron Casciari sedang sibuk.
Dialogue: 0,0:18:21.08,0:18:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau pergi ke mana minggu ini?
Dialogue: 0,0:18:22.54,0:18:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tanyakan detailnya!
Dialogue: 0,0:18:26.59,0:18:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi Tuan Renato bersama Nona Eleonora.
Dialogue: 0,0:18:29.71,0:18:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa benar hubungannya\Ndengan Nona Aida tidak lancar?
Dialogue: 0,0:18:35.51,0:18:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dengar itu?\NMereka selalu memusuhi aku.
Dialogue: 0,0:18:44.35,0:18:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Nona Aida melotot ke arahku.
Dialogue: 0,0:18:49.73,0:18:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalau dia orang yang Placido cintai.
Dialogue: 0,0:18:53.32,0:18:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu,
Dialogue: 0,0:18:55.74,0:18:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku sempat menyesal...
Dialogue: 0,0:18:57.78,0:19:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyesal karena harus\Nmembatalkan pertunangan kami saat itu.
Dialogue: 0,0:19:02.37,0:19:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu sendiri kelanjutannya.
Dialogue: 0,0:19:05.12,0:19:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat.
Dialogue: 0,0:19:06.88,0:19:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida Ametis.
Dialogue: 0,0:19:12.30,0:19:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran pertama Kerajaan Rubini,\NRenato di Rubini
Dialogue: 0,0:19:17.55,0:19:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membatalkan pertunangan kita di sini,\Nsekarang juga.
Dialogue: 0,0:19:22.60,0:19:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku benar-benar iri pada Placido.
Dialogue: 0,0:19:27.02,0:19:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Placido bersanding\Ndengan wanita secantik dirinya.
Dialogue: 0,0:19:31.27,0:19:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, ah...
Dialogue: 0,0:19:33.28,0:19:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak hari itu,\Nhanya ada kamu di depan mataku.
Dialogue: 0,0:19:37.95,0:19:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Hasilnya bagus!
Dialogue: 0,0:19:39.78,0:19:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan Aida, dan bisa\Nmakan daging enak berkat Pangeran.
Dialogue: 0,0:19:46.21,0:19:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, jadi dekat dengan Pangeran...
Dialogue: 0,0:19:51.17,0:19:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh protes soal satu hal, tidak?
Dialogue: 0,0:19:54.34,0:19:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan sebagai putra mahkota,\Ntapi Renato di Rubini.
Dialogue: 0,0:19:59.68,0:20:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-Boleh.
Dialogue: 0,0:20:01.60,0:20:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sejak aku memanggilmu Mimi,\Nbukan Maria.
Dialogue: 0,0:20:07.52,0:20:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa kamu masih saja\Nmemanggilku Pangeran Renato?
Dialogue: 0,0:20:12.36,0:20:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau ditanya kenapa...\NPokoknya begitu?
Dialogue: 0,0:20:17.07,0:20:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong berhenti memanggilku "pangeran".
Dialogue: 0,0:20:20.57,0:20:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berarti aku harus panggil Pangeran...\NRenato saja?
Dialogue: 0,0:20:26.41,0:20:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:27.29,0:20:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah. Panggil langsung nama...\NKesannya sok akrab.
Dialogue: 0,0:20:31.59,0:20:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini tunanganmu.
Dialogue: 0,0:20:35.84,0:20:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih ingat bilang\N"mau lakukan apa saja" di Desa Navarro?
Dialogue: 0,0:20:42.68,0:20:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:20:43.93,0:20:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lakukan apa saja,\Ntolong ampuni aku!
Dialogue: 0,0:20:47.48,0:20:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, Raimondo juga catat.
Dialogue: 0,0:20:50.60,0:20:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba cek catatannya?
Dialogue: 0,0:20:52.73,0:20:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:20:53.90,0:20:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong pergi dulu untuk hari ini!
Dialogue: 0,0:21:01.16,0:21:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku usahakan.\NPangeran... Renato.
Dialogue: 0,0:21:06.50,0:21:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya aku tidak dengar.
Dialogue: 0,0:21:09.00,0:21:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Re-Renato.
Dialogue: 0,0:21:11.63,0:21:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renato!
Dialogue: 0,0:21:13.00,0:21:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi.
Dialogue: 0,0:21:14.25,0:21:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renato!
Dialogue: 0,0:21:16.76,0:21:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipanggil berkali-kali\Npakai nama itu memang istimewa.
Dialogue: 0,0:21:21.97,0:21:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dengar...
Dialogue: 0,0:21:24.26,0:21:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:22:49.01,0:22:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih ingat aku bilang apa\Nsaat kamu pulang tempo hari?
Dialogue: 0,0:22:53.81,0:22:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Ayah cemas aku betah\Ndi Kerajaan Rubini atau tidak.
Dialogue: 0,0:22:58.02,0:23:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato mengirimkan undangan,
Dialogue: 0,0:23:00.94,0:23:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sempat berbicara langsung\Ndengan Baginda Raja.
Dialogue: 0,0:23:04.57,0:23:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Teodorico resmi menjadi\Npenerus keluarga Annovazzi,
Dialogue: 0,0:23:08.49,0:23:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menyuruhmu untuk mencari\Nkandidat berkualitas, kan?
Dialogue: 0,0:23:13.46,0:23:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:23:14.33,0:23:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kamu berhasil memenuhi\Npermintaanku dengan baik.
Dialogue: 0,0:23:18.75,0:23:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikan yang lepas\Ndari pancingnya memang besar,
Dialogue: 0,0:23:21.71,0:23:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ikan yang kamu tangkap\Nsetelahnya terlalu besar.
Dialogue: 0,0:23:31.43,0:23:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju!
