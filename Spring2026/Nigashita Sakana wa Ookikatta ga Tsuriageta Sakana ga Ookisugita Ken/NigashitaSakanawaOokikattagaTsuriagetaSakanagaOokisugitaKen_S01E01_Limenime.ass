Dialogue: 0,0:00:31.01,0:00:36.02,tanda,,0000,0000,0000,,EPISODE 1: IKAN YANG TERLEPAS\NMENCARI CALON SUAMI BERKUALITAS
Dialogue: 0,0:00:36.68,0:00:38.64,tanda,,0000,0000,0000,,IBU KOTA KERAJAAN RUBINI
Dialogue: 0,0:01:20.52,0:01:22.31,tanda,,0000,0000,0000,,BWUNG
Dialogue: 0,0:02:22.75,0:02:28.50,tanda,,0000,0000,0000,,WUS
Dialogue: 0,0:03:47.37,0:03:50.71,tanda,,0000,0000,0000,,DRAP, DRAP, DRAP
Dialogue: 0,0:07:53.70,0:07:54.66,tanda,,0000,0000,0000,,PLUK, PLUK
Dialogue: 0,0:10:31.03,0:10:31.60,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR
Dialogue: 0,0:10:31.60,0:10:32.31,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:10:35.03,0:10:37.03,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR
Dialogue: 0,0:10:37.03,0:10:39.03,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:16:15.00,0:16:16.62,tanda,,0000,0000,0000,,MENATAP
Dialogue: 0,0:17:34.74,0:17:35.74,tanda,,0000,0000,0000,,TERBUAI
Dialogue: 0,0:20:51.73,0:20:54.90,tanda,,0000,0000,0000,,PANIK
Dialogue: 0,0:23:35.02,0:23:36.60,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA:
Dialogue: 0,0:23:36.60,0:23:39.07,tanda,,0000,0000,0000,,IKAN LEPAS YANG TERTANGKAP
Dialogue: 0,0:00:14.95,0:00:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Pangeran Pertama Kerajaan Rubini,
Dialogue: 0,0:00:17.44,0:00:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renato di Rubini,
Dialogue: 0,0:00:19.54,0:00:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membatalkan pertunangan kita\Ndi sini, sekarang juga!
Dialogue: 0,0:00:25.46,0:00:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah ini bermula
Dialogue: 0,0:00:27.13,0:00:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari batalnya pertunangan secara mendadak.
Dialogue: 0,0:00:46.81,0:00:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta kencana\Nkeluarga Duke Annovazzi telah tiba.
Dialogue: 0,0:01:04.95,0:01:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:01:05.75,0:01:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida!
Dialogue: 0,0:01:12.80,0:01:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa!
Dialogue: 0,0:01:14.14,0:01:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Mimi tampak sehat.
Dialogue: 0,0:01:15.93,0:01:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dua tahun, ya?\NSenang bisa bertemu lagi!
Dialogue: 0,0:01:19.10,0:01:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehem.
Dialogue: 0,0:01:20.52,0:01:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duke Ametis,
Dialogue: 0,0:01:22.31,0:01:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terima kasih sudah bersedia\Nmenjadi wali saya!
Dialogue: 0,0:01:25.65,0:01:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah menitipkan salam untuk Anda!
Dialogue: 0,0:01:28.36,0:01:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di kediaman Ametis,\NNona Maria.
Dialogue: 0,0:01:31.80,0:01:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:01:32.66,0:01:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, Nona!
Dialogue: 0,0:01:35.41,0:01:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf, Tuan Duke.
Dialogue: 0,0:01:39.91,0:01:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu sungkan, Nona Maria.
Dialogue: 0,0:01:42.28,0:01:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mungkin tak menyadarinya,
Dialogue: 0,0:01:44.17,0:01:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida tertolong oleh sifat santaimu.
Dialogue: 0,0:01:47.17,0:01:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:01:49.26,0:01:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kalian berdua tetap akrab.
Dialogue: 0,0:01:51.92,0:01:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kini Aida\Nbukanlah gadis bangsawan biasa.
Dialogue: 0,0:01:56.26,0:01:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon jaga sikap saat bersamanya.
Dialogue: 0,0:01:59.56,0:02:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bisa dapat masalah
Dialogue: 0,0:02:00.64,0:02:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kamu tiba-tiba mengajak Aida\Nberkuda ke tempat jauh seperti dulu.
Dialogue: 0,0:02:04.98,0:02:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, ini Kerajaan Rubini.
Dialogue: 0,0:02:07.86,0:02:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu berbeda dengan tempat kelahiran Mimi,\NKerajaan Muro.
Dialogue: 0,0:02:11.78,0:02:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida, Ayah hanya mencemaskanmu.
Dialogue: 0,0:02:15.11,0:02:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi, kamu akan dipinang\Nkeluarga kerajaan.
Dialogue: 0,0:02:18.12,0:02:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Ayah.
Dialogue: 0,0:02:22.75,0:02:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku, Tuan Duke!
Dialogue: 0,0:02:25.17,0:02:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Aida sekuat tenaga!
Dialogue: 0,0:02:30.42,0:02:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah waktunya aku pergi\Nmenemui Baginda Raja.
Dialogue: 0,0:02:34.68,0:02:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria, anggap saja\Nseperti rumah sendiri.
Dialogue: 0,0:02:39.15,0:02:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida, kuserahkan sisanya padamu.
Dialogue: 0,0:02:42.18,0:02:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagal total...
Dialogue: 0,0:02:44.94,0:02:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, maafkan ayahku\Nyang bicara lancang, ya.
Dialogue: 0,0:02:48.27,0:02:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja!
Dialogue: 0,0:02:49.65,0:02:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Aida...
Dialogue: 0,0:02:51.32,0:02:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bertunangan dengan\NPangeran Kerajaan Rubini?
Dialogue: 0,0:02:54.20,0:02:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orangnya seperti apa?\NBagaimana awalnya?
Dialogue: 0,0:02:57.61,0:03:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Ametis dan Annovazzi\Nmemang kerabat jauh,
Dialogue: 0,0:03:01.24,0:03:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku bangga sekali.
Dialogue: 0,0:03:02.79,0:03:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida memang hebat!
Dialogue: 0,0:03:06.69,0:03:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah yang memaksakan keputusan itu.
Dialogue: 0,0:03:09.00,0:03:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Jadi, kamu sendiri...
Dialogue: 0,0:03:12.94,0:03:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja ini kehormatan bagiku.
Dialogue: 0,0:03:16.41,0:03:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut kualat kalau menolak.
Dialogue: 0,0:03:25.03,0:03:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara soal itu,\Naku ingin dengar ceritamu, Mimi.
Dialogue: 0,0:03:27.94,0:03:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba sekolah di luar negeri?
Dialogue: 0,0:03:30.03,0:03:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu harus mengurus keluarga?
Dialogue: 0,0:03:31.90,0:03:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya boleh?
Dialogue: 0,0:03:34.39,0:03:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida, aku lakukan semua ini\Ndemi kandidat berkualitas.
Dialogue: 0,0:03:38.51,0:03:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kandidat berkualitas?
Dialogue: 0,0:03:41.28,0:03:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah cerita ke kamu lewat surat...
Dialogue: 0,0:03:44.91,0:03:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu, dua, tiga! Satu!
Dialogue: 0,0:03:47.37,0:03:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona! Nona Mimi!
Dialogue: 0,0:03:53.71,0:03:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Muda sudah lahir.
Dialogue: 0,0:03:56.72,0:03:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adik lelakimu!
Dialogue: 0,0:03:58.26,0:03:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik lelaki!
Dialogue: 0,0:04:04.67,0:04:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, dia adik lelakimu.
Dialogue: 0,0:04:11.17,0:04:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lembut dan hangat.
Dialogue: 0,0:04:16.07,0:04:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:04:17.95,0:04:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil.\NDia resmi pewaris keluarga!
Dialogue: 0,0:04:21.33,0:04:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kamu cari suami saja,
Dialogue: 0,0:04:23.95,0:04:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pastikan cari pasangan berkualitas, ya!
Dialogue: 0,0:04:26.20,0:04:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkualitas... Berkualitas... Berkualitas.
Dialogue: 0,0:04:29.25,0:04:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!\NAku sama sekali tidak tahu.
Dialogue: 0,0:04:33.05,0:04:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku turut sedih mendengarnya.
Dialogue: 0,0:04:35.46,0:04:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turut sedih?\NKenapa?
Dialogue: 0,0:04:37.59,0:04:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, selama ini kamu berjuang keras\Nmenjadi pewaris keluarga Annovazzi.
Dialogue: 0,0:04:43.68,0:04:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar, latihan, bimbingan ketat...
Dialogue: 0,0:04:46.18,0:04:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melakukan banyak hal yang umumnya\Ntak dibutuhkan gadis bangsawan.
Dialogue: 0,0:04:49.35,0:04:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Aida, hal itu tetap kubutuhkan.
Dialogue: 0,0:04:52.86,0:04:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bukan pewaris keluarga,
Dialogue: 0,0:04:54.19,0:04:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu tetap berguna\Nuntuk kehidupan sehari-hari.
Dialogue: 0,0:04:56.33,0:04:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:01.13,0:05:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pewaris keluarga memang\Nlebih baik laki-laki,
Dialogue: 0,0:05:04.16,0:05:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi karena keluargaku\Nselalu dikaruniai anak perempuan,
Dialogue: 0,0:05:06.62,0:05:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akulah yang terpilih.
Dialogue: 0,0:05:08.70,0:05:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu terdengar sangat santai?
Dialogue: 0,0:05:12.17,0:05:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpiku bukan menjadi\Npewaris keluarga Annovazzi.
Dialogue: 0,0:05:18.34,0:05:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang lebih membahagiakan\Nselain melihat Teo tumbuh
Dialogue: 0,0:05:21.09,0:05:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi pewaris yang hebat!
Dialogue: 0,0:05:23.30,0:05:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama orang lain bahagia,\Naku juga bahagia!
Dialogue: 0,0:05:26.47,0:05:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifatmu tidak berubah, ya.
Dialogue: 0,0:05:28.22,0:05:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa terus-menerus\Nbergantung pada orang tua, kan?
Dialogue: 0,0:05:31.77,0:05:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku harus pastikan\Ndapat pasangan berkualitas!
Dialogue: 0,0:05:35.13,0:05:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tak cari dari yang dekat dulu?
Dialogue: 0,0:05:37.48,0:05:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu sudah!
Dialogue: 0,0:05:39.86,0:05:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi calon yang lumayan\Nsudah punya pasangan semua.
Dialogue: 0,0:05:44.49,0:05:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bisa saja memang aura jomloku\Nyang terlalu kuat.
Dialogue: 0,0:05:47.27,0:05:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:05:48.70,0:05:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku keceplosan lagi!
Dialogue: 0,0:05:51.21,0:05:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kebiasaan burukmu, ya.
Dialogue: 0,0:05:53.70,0:05:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku sekolah di luar negeri
Dialogue: 0,0:05:56.42,0:05:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi mencari kandidat berkualitas.
Dialogue: 0,0:05:58.30,0:06:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kamu segera bertemu\Norang yang cocok.
Dialogue: 0,0:06:00.42,0:06:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:01.96,0:06:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupandu kamu ke Akademi Kerajaan.
Dialogue: 0,0:06:04.76,0:06:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati!
Dialogue: 0,0:06:08.10,0:06:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya akademi ini dikhususkan\Nuntuk mendidik keturunan kerajaan.
Dialogue: 0,0:06:13.19,0:06:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, raja terdahulu memutuskan\Nagar mereka belajar
Dialogue: 0,0:06:17.09,0:06:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersama para bangsawan\Ndan mengizinkan pendaftaran umum.
Dialogue: 0,0:06:21.28,0:06:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, lebih baik kalau para bangsawan
Dialogue: 0,0:06:23.99,0:06:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memiliki teman akrab sejak muda.
Dialogue: 0,0:06:26.62,0:06:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:06:29.39,0:06:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena kamu bertunangan\Ndengan pangeran?
Dialogue: 0,0:06:32.12,0:06:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang terlihat sangat sopan padamu.
Dialogue: 0,0:06:35.50,0:06:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tidak juga.
Dialogue: 0,0:06:42.17,0:06:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Aida.
Dialogue: 0,0:06:44.15,0:06:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia siswi pindahan?
Dialogue: 0,0:06:46.76,0:06:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, benar.
Dialogue: 0,0:06:49.26,0:06:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperkenalkan.
Dialogue: 0,0:06:50.57,0:06:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Maria Annovazzi, dan dia Pangeran...
Dialogue: 0,0:06:53.81,0:06:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.\NPanggil saja aku Mimi!
Dialogue: 0,0:06:55.77,0:06:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Placido...
Dialogue: 0,0:06:58.65,0:07:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran?
Dialogue: 0,0:07:00.44,0:07:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti... orang terhormat?
Dialogue: 0,0:07:04.13,0:07:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil aku Placido saja.
Dialogue: 0,0:07:07.34,0:07:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NKamu Mimi, ya?
Dialogue: 0,0:07:09.91,0:07:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu.
Dialogue: 0,0:07:12.03,0:07:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering dengar tentangmu dari Aida.
Dialogue: 0,0:07:14.39,0:07:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Dengar tentangku?
Dialogue: 0,0:07:17.22,0:07:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bercerita bahwa kamu\Nsahabat terdekatku.
Dialogue: 0,0:07:20.75,0:07:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu putri bangsawan yang Aida kunjungi\Nsaat pemulihan asma, kan?
Dialogue: 0,0:07:25.47,0:07:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Aida sempat bingung karena\Ntak tahu kamu laki-laki atau perempuan.
Dialogue: 0,0:07:30.47,0:07:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran!
Dialogue: 0,0:07:31.68,0:07:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:07:32.97,0:07:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu aku tak tahu cara memakai gaun.
Dialogue: 0,0:07:36.41,0:07:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, sekarang pun\Naku agak memaksakan diri.
Dialogue: 0,0:07:38.98,0:07:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:07:41.37,0:07:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lebih baik dari cerita Aida.
Dialogue: 0,0:07:43.68,0:07:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Aida memang hebat!
Dialogue: 0,0:07:45.61,0:07:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, begini...
Dialogue: 0,0:07:48.09,0:07:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski penampilanku begini,\NAida gadis bangsawan yang paling anggun.
Dialogue: 0,0:07:52.41,0:07:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya?
Dialogue: 0,0:07:54.66,0:07:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aida juga dulu pernah\N- Jangan mendekat!
Dialogue: 0,0:07:55.91,0:07:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- melempar kastanya ke arahku.\N- Jangan dekati aku!
Dialogue: 0,0:07:57.50,0:07:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- melempar kastanya ke arahku.\N- Jangan sentuh!
Dialogue: 0,0:07:58.54,0:08:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan yang masih ada kulit durinya.
Dialogue: 0,0:08:00.13,0:08:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:01.25,0:08:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong, ah!
Dialogue: 0,0:08:01.92,0:08:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, sudah kubilang itu\Nkarena kamu mengusiliku.
Dialogue: 0,0:08:05.46,0:08:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang aku gembul dan rakus.
Dialogue: 0,0:08:07.72,0:08:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih, itu cerita\Nbelasan tahun yang lalu, kan?
Dialogue: 0,0:08:10.14,0:08:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menyangka.
Dialogue: 0,0:08:11.30,0:08:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira Aida sudah anggun dari lahir.
Dialogue: 0,0:08:15.35,0:08:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, hentikan.
Dialogue: 0,0:08:22.90,0:08:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:08:24.95,0:08:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah paham situasi dan tujuan Mimi.
Dialogue: 0,0:08:27.82,0:08:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba carikan bangsawan\Nyang sesuai kriteria, ya.
Dialogue: 0,0:08:30.67,0:08:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:08:32.20,0:08:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:08:35.75,0:08:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:08:41.75,0:08:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin tidak kedengaran.
Dialogue: 0,0:08:43.89,0:08:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, ya.
Dialogue: 0,0:08:46.54,0:08:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Pangeran Renato tak akan ke sini.
Dialogue: 0,0:08:54.87,0:08:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagal.
Dialogue: 0,0:08:56.16,0:08:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku ingin kenalkan Mimi\Npada kakakku.
Dialogue: 0,0:08:59.32,0:09:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang ada pekerjaan lain.
Dialogue: 0,0:09:01.58,0:09:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini dia makin sibuk.
Dialogue: 0,0:09:04.61,0:09:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:09:05.92,0:09:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak memang jauh lebih kompeten\Ndibandingkan aku.
Dialogue: 0,0:09:08.71,0:09:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi orangnya agak kaku.
Dialogue: 0,0:09:11.86,0:09:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia perfeksionis yang gila kerja.
Dialogue: 0,0:09:14.55,0:09:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diminta membantu asisten Kakak,\NRaimondo.
Dialogue: 0,0:09:18.20,0:09:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti, Aida, Mimi.
Dialogue: 0,0:09:22.71,0:09:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tur akademinya\Ncukup sampai di sini.
Dialogue: 0,0:09:25.96,0:09:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman!
Dialogue: 0,0:09:28.09,0:09:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, ya.
Dialogue: 0,0:09:30.05,0:09:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya kamu buat keributan di sini,\Ndasar tak tahu adab!
Dialogue: 0,0:09:33.30,0:09:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong maafkan dia, Nona Eleonora.
Dialogue: 0,0:09:35.97,0:09:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga minta maaf.
Dialogue: 0,0:09:38.14,0:09:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tunangan Pangeran Rubini\Nyang meminta maaf,
Dialogue: 0,0:09:41.69,0:09:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak punya pilihan selain memaafkan.
Dialogue: 0,0:09:43.98,0:09:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai menolak,\Naku pasti akan dianggap jahat.
Dialogue: 0,0:09:47.94,0:09:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lebih berhati-hati nanti.
Dialogue: 0,0:09:50.07,0:09:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph!
Dialogue: 0,0:09:52.79,0:09:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tenaga orang itu besar sekali?
Dialogue: 0,0:09:55.16,0:09:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dimasukkan ke hati, ya.
Dialogue: 0,0:09:57.05,0:10:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Eleonora terkadang memang\Nbermulut tajam seperti tadi.
Dialogue: 0,0:10:00.45,0:10:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan.
Dialogue: 0,0:10:01.66,0:10:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terlihat enggan, dia sudah memaafkanku.
Dialogue: 0,0:10:05.21,0:10:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak!
Dialogue: 0,0:10:11.07,0:10:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida dan Pangeran Placido tampak akrab,\Ntapi mereka tak bertunangan...
Dialogue: 0,0:10:16.50,0:10:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, dia bertunangan dengan kakaknya,\NPangeran Renato.
Dialogue: 0,0:10:21.90,0:10:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, entah kenapa,\Ndia tak terlihat begitu bahagia.
Dialogue: 0,0:10:26.86,0:10:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus semangat mencari
Dialogue: 0,0:10:32.31,0:10:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kandidat berkualitas.
Dialogue: 0,0:10:41.29,0:10:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, Ibu, apa kabar?
Dialogue: 0,0:10:44.43,0:10:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua bulan sejak sekolah di luar negeri,\Naku sehat-sehat saja!
Dialogue: 0,0:10:47.71,0:10:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida memperlakukanku dengan baik,\Ndan aku juga punya teman baru.
Dialogue: 0,0:10:51.42,0:10:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam sejahtera, Nona Anggabazzi.
Dialogue: 0,0:10:54.09,0:10:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Nona Pandavatti\Ntinggal di kediaman Ametis, ya?
Dialogue: 0,0:10:57.51,0:10:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batti, kamu senggang hari ini?
Dialogue: 0,0:10:59.18,0:11:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andogattya, kamu lihat Aida hari ini?
Dialogue: 0,0:11:06.27,0:11:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka semua orang baik.
Dialogue: 0,0:11:08.45,0:11:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk urusan mencari jodoh, aku masih...
Dialogue: 0,0:11:25.82,0:11:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Mimi?
Dialogue: 0,0:11:27.79,0:11:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Placido!
Dialogue: 0,0:11:30.55,0:11:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Aida?\NTak bersamamu?
Dialogue: 0,0:11:33.70,0:11:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia agak demam sejak semalam,
Dialogue: 0,0:11:36.49,0:11:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sayangnya harus absen di pesta kali ini.
Dialogue: 0,0:11:39.90,0:11:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NMembuatku cemas saja.
Dialogue: 0,0:11:42.00,0:11:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.\NPangeran juga pasti cemas, kan?
Dialogue: 0,0:11:45.39,0:11:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tentu saja aku cemas!
Dialogue: 0,0:11:50.65,0:11:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:11:53.65,0:11:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria Annovazzi.
Dialogue: 0,0:11:56.15,0:11:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila berkenan, maukah kamu berdansa
Dialogue: 0,0:11:59.28,0:12:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan Placido di Rubini?
Dialogue: 0,0:12:01.74,0:12:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tapi aku belum terbiasa berdansa,
Dialogue: 0,0:12:06.79,0:12:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti akan merepotkanmu.
Dialogue: 0,0:12:09.00,0:12:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:12:10.50,0:12:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terpenting\Nkamu bersenang-senang dulu.
Dialogue: 0,0:12:17.93,0:12:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Pangeran.
Dialogue: 0,0:12:45.04,0:12:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, ya!
Dialogue: 0,0:12:55.18,0:12:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi lapar setelah berolahraga.
Dialogue: 0,0:12:58.41,0:13:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida pasti bahagia
Dialogue: 0,0:13:00.68,0:13:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena punya teman sepertimu.
Dialogue: 0,0:13:04.81,0:13:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa alasan Aida pergi ke tempatmu
Dialogue: 0,0:13:08.52,0:13:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena lelah dengan ketatnya\Npelatihan etiket dan tata krama.
Dialogue: 0,0:13:13.47,0:13:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin alasan dia absen hari ini juga...
Dialogue: 0,0:13:15.90,0:13:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu.
Dialogue: 0,0:13:18.07,0:13:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Aida selalu terlihat disiplin\Ndan sangat anggun.
Dialogue: 0,0:13:23.13,0:13:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, Aida pasti sangat terbantu
Dialogue: 0,0:13:25.60,0:13:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena ada kamu di sampingnya.
Dialogue: 0,0:13:28.12,0:13:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!\NAku akan melindungi Aida!
Dialogue: 0,0:13:31.45,0:13:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar bisa diandalkan.
Dialogue: 0,0:13:35.47,0:13:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka berdua hadir\Ndi pesta kelulusan,
Dialogue: 0,0:13:38.59,0:13:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kesehatannya akan membaik?
Dialogue: 0,0:13:41.88,0:13:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta kelulusan?
Dialogue: 0,0:13:45.53,0:13:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa tingkat akhir akan lulus.
Dialogue: 0,0:13:49.27,0:13:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di semester ini, sepertinya Pangeran Renato\Nakan jadi pusat perhatian.
Dialogue: 0,0:13:53.30,0:13:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita yang siswa aktif juga boleh hadir\Ndi pesta kelulusan.
Dialogue: 0,0:13:57.78,0:14:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin pestanya sangat megah.
Dialogue: 0,0:14:01.90,0:14:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta hari ini juga sangat keren.
Dialogue: 0,0:14:04.07,0:14:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa makan daging sepuasnya.
Dialogue: 0,0:14:06.69,0:14:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:14:07.99,0:14:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Pangeran Placido\Nbenar-benar ramah.
Dialogue: 0,0:14:11.21,0:14:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:14:13.43,0:14:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Aida...
Dialogue: 0,0:14:17.53,0:14:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:14:18.96,0:14:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak...
Dialogue: 0,0:14:21.55,0:14:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jadi.
Dialogue: 0,0:14:22.97,0:14:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak! Aku akan berusaha keras menemukan\Ncalon suami di pesta!
Dialogue: 0,0:14:28.06,0:14:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat di pesta nanti, kamu harus\Nmenahan diri agar tak asal bicara, ya.
Dialogue: 0,0:14:31.93,0:14:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berhati-hati, Aida.
Dialogue: 0,0:14:34.62,0:14:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari-hariku kuhabiskan dengan belajar\Netiket dan tata krama dari Aida
Dialogue: 0,0:14:37.61,0:14:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menunggu Pangeran Placido\Nmengenalkan seseorang.
Dialogue: 0,0:14:40.65,0:14:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo, pastikan dengarkan kata-kata\NAyah, Ibu, dan kakak-kakak, ya.
Dialogue: 0,0:14:45.11,0:14:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga kesehatan, ya.\NBeres!
Dialogue: 0,0:14:57.21,0:14:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah siap?
Dialogue: 0,0:15:01.75,0:15:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutmu tampak bersinar\Nbak bulir gandum di musim gugur.
Dialogue: 0,0:15:05.97,0:15:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut pirangmu juga terlihat
Dialogue: 0,0:15:07.93,0:15:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lembut dan mengilap.
Dialogue: 0,0:15:09.89,0:15:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:15:11.47,0:15:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna emas cantik, seperti...
Dialogue: 0,0:15:13.52,0:15:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti...
Dialogue: 0,0:15:14.94,0:15:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti warna emas.
Dialogue: 0,0:15:16.44,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:17.81,0:15:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepulang dari pesta,\Nmari belajar bahasa nasional.
Dialogue: 0,0:15:22.39,0:15:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, sudah selesai.\NAyo berangkat.
Dialogue: 0,0:15:32.35,0:15:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida, yakin tak mau berangkat\Nbersama Pangeran Renato?
Dialogue: 0,0:15:36.08,0:15:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dia tunanganmu?
Dialogue: 0,0:15:38.91,0:15:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran sangat sibuk.
Dialogue: 0,0:15:42.13,0:15:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NYah, dia memang putra mahkota.
Dialogue: 0,0:15:45.55,0:15:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku, pasti akan\Nmenyempatkan diri untuk menemuimu.
Dialogue: 0,0:15:48.64,0:15:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini, ya.
Dialogue: 0,0:15:55.90,0:15:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:16:00.71,0:16:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kereta kencana milik Nona Eleonora.
Dialogue: 0,0:16:03.73,0:16:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eleonora?
Dialogue: 0,0:16:05.36,0:16:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, orang yang waktu itu\Nbertabrakan denganku, ya?
Dialogue: 0,0:16:10.42,0:16:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Eleonora, ada apa?
Dialogue: 0,0:16:13.42,0:16:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu.
Dialogue: 0,0:16:15.00,0:16:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau keretamu rusak...
Dialogue: 0,0:16:16.62,0:16:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tuli, ya?
Dialogue: 0,0:16:17.89,0:16:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak butuh bantuanmu!
Dialogue: 0,0:16:20.86,0:16:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida.
Dialogue: 0,0:16:22.90,0:16:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf.
Dialogue: 0,0:16:24.67,0:16:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami duluan.
Dialogue: 0,0:16:34.14,0:16:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa keretanya akan baik-baik saja?
Dialogue: 0,0:16:37.79,0:16:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka sifatmu yang seperti ini.
Dialogue: 0,0:16:40.90,0:16:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:43.44,0:16:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kamu yang tak pernah\Nmembicarakan keburukan orang lain!
Dialogue: 0,0:16:49.27,0:16:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:08.17,0:17:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ramai sekali.
Dialogue: 0,0:17:11.18,0:17:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menteri dari Kerajaan Giharth, kan?
Dialogue: 0,0:17:15.01,0:17:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sepenting dia datang ke pesta ini juga?
Dialogue: 0,0:17:17.56,0:17:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ayahmu juga hadir.
Dialogue: 0,0:17:22.65,0:17:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Pertama, Yang Mulia Renato,
Dialogue: 0,0:17:25.30,0:17:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Pangeran Kedua,\NYang Mulia Placido telah tiba.
Dialogue: 0,0:17:35.74,0:17:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sangat tampan hari ini.
Dialogue: 0,0:17:38.58,0:17:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah lulus nanti, beliau akan resmi\Nmenjadi putra mahkota, bukan?
Dialogue: 0,0:17:44.54,0:17:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerut di keningnya juga indah.
Dialogue: 0,0:17:46.84,0:17:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Placido sangat manis.
Dialogue: 0,0:17:54.25,0:17:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Pangeran Renato
Dialogue: 0,0:17:56.21,0:17:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersama wanita yang bukan tunangannya?
Dialogue: 0,0:18:01.38,0:18:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida, kamu tak mendampinginya?
Dialogue: 0,0:18:04.06,0:18:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau lagi-lagi ditempeli Nona Eleonora.
Dialogue: 0,0:18:06.40,0:18:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.\NBeliau mengabaikan tunangannya.
Dialogue: 0,0:18:08.61,0:18:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar hubunganmu dan Pangeran Renato\Nsedang renggang.
Dialogue: 0,0:18:12.15,0:18:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan.
Dialogue: 0,0:18:13.36,0:18:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersedia jadi teman berbagi\Nkeluh kesahmu.
Dialogue: 0,0:18:21.65,0:18:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida, aku haus.
Dialogue: 0,0:18:23.92,0:18:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita minum yang banyak di taman, yuk!
Dialogue: 0,0:18:29.06,0:18:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, padahal aku masih ingin\Nmenanyakan banyak hal.
Dialogue: 0,0:18:34.26,0:18:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Mimi.
Dialogue: 0,0:18:36.47,0:18:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya menanyakan hal seperti itu,\Ndi mana sopan santun mereka?
Dialogue: 0,0:18:41.48,0:18:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini, ya.
Dialogue: 0,0:18:42.98,0:18:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang memperhatikan Pangeran Renato,
Dialogue: 0,0:18:46.73,0:18:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa sadar, aku juga.
Dialogue: 0,0:18:50.35,0:18:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, melelahkan kalau tak tahu mereka\Nbenar-benar cemas atau tidak, kan?
Dialogue: 0,0:18:56.13,0:18:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, terkadang.
Dialogue: 0,0:18:58.53,0:19:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu jujur.
Dialogue: 0,0:19:01.29,0:19:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tenang saja!
Dialogue: 0,0:19:03.55,0:19:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga harus belajar menjaga ucapan.
Dialogue: 0,0:19:06.38,0:19:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:19:11.39,0:19:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato?
Dialogue: 0,0:19:12.92,0:19:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menemani Nona Eleonora?
Dialogue: 0,0:19:14.92,0:19:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?
Dialogue: 0,0:19:16.05,0:19:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dia sedang kesusahan\Nkarena keretanya rusak.
Dialogue: 0,0:19:18.47,0:19:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya, Pangeran mengizinkan\Nberangkat bersama.
Dialogue: 0,0:19:20.56,0:19:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia yang mengusir Aida.
Dialogue: 0,0:19:23.43,0:19:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?
Dialogue: 0,0:19:28.98,0:19:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami saling bertatapan.
Dialogue: 0,0:19:33.99,0:19:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ke sini.
Dialogue: 0,0:19:44.69,0:19:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:19:55.58,0:19:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan lebih cepat kalau kamu melihatnya.
Dialogue: 0,0:19:58.09,0:20:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida Ametis.
Dialogue: 0,0:20:03.86,0:20:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Pangeran Pertama Kerajaan Rubini,
Dialogue: 0,0:20:06.02,0:20:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renato di Rubini,
Dialogue: 0,0:20:07.94,0:20:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membatalkan pertunangan kita\Ndi sini, sekarang juga!
Dialogue: 0,0:20:17.56,0:20:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pangeran ini malah mengumumkan\Npembatalan pertunangannya padaku?
Dialogue: 0,0:20:23.62,0:20:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:20:25.30,0:20:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi di sini?
Dialogue: 0,0:20:27.62,0:20:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Placido, kamu sudah ditipu.
Dialogue: 0,0:20:30.29,0:20:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis ini cemburu dengan hubunganku\Ndan Nona Eleonora, merundungnya,
Dialogue: 0,0:20:35.05,0:20:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan selalu menguntitnya ke mana pun.
Dialogue: 0,0:20:37.13,0:20:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pangeran, orangnya bukan yang itu.
Dialogue: 0,0:20:41.30,0:20:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan ampuni orang yang mencelakai\Norang lain dengan kekuasaannya!
Dialogue: 0,0:20:44.97,0:20:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu, Kak.
Dialogue: 0,0:20:47.64,0:20:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida bukan orang seperti itu.
Dialogue: 0,0:20:50.15,0:20:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, Placido.
Dialogue: 0,0:20:51.73,0:20:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asistenku sudah menyelidikinya
Dialogue: 0,0:20:53.27,0:20:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membawa bukti.
Dialogue: 0,0:20:56.11,0:20:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak bisa mengelak lagi!
Dialogue: 0,0:20:57.64,0:21:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,\Nkamu diskors dari Akademi Kerajaan.
Dialogue: 0,0:21:00.95,0:21:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, minta maaflah pada Nona Eleonora\Nsekarang juga!
Dialogue: 0,0:21:04.03,0:21:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?
Dialogue: 0,0:21:05.29,0:21:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembatalan pertunangan?
Dialogue: 0,0:21:06.47,0:21:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:21:07.54,0:21:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi perempuan itu...\N- Aku harus bagaimana?
Dialogue: 0,0:21:12.51,0:21:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida.
Dialogue: 0,0:21:14.54,0:21:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Aida sekuat tenaga!
Dialogue: 0,0:21:17.05,0:21:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bercerita bahwa kamu\Nsahabat terdekatku.
Dialogue: 0,0:21:25.26,0:21:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Pangeran!
Dialogue: 0,0:21:26.68,0:21:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda sadar dengan tindakan Anda?
Dialogue: 0,0:21:30.02,0:21:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tentu saja.
Dialogue: 0,0:21:31.85,0:21:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NAnda sama sekali tidak paham!
Dialogue: 0,0:21:37.65,0:21:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Maria Annovazzi.
Dialogue: 0,0:21:40.70,0:21:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunangan Anda, Nona Aida Ametis,\Nadalah gadis di sebelah sini!
Dialogue: 0,0:21:45.38,0:21:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, hal pertama yang harus\NAnda lakukan adalah...
Dialogue: 0,0:21:48.66,0:21:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beli kacamata!
Dialogue: 0,0:21:51.46,0:21:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:27.18,0:23:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Maria Annovazzi.
Dialogue: 0,0:23:29.51,0:23:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil saja Mimi!
Dialogue: 0,0:23:30.81,0:23:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penasaran kenapa aku dipanggil Mimi?
Dialogue: 0,0:23:33.77,0:23:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rahasia yang tak bisa kuceritakan...
Dialogue: 0,0:23:36.60,0:23:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku keceplosan lagi!
