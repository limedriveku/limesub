Dialogue: 0,0:01:11.55,0:01:12.43,sign,,0000,0000,0000,,AAAAAAAH
Dialogue: 0,0:01:48.80,0:01:53.80,sign,,0000,0000,0000,,EPISODE 9:\NIKAN LEPAS YANG MALAH JADI MAK COMBLANG
Dialogue: 0,0:08:49.01,0:08:50.93,sign,,0000,0000,0000,,BUK, BUK, BUK, BUK
Dialogue: 0,0:09:29.67,0:09:32.05,sign,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:09:32.05,0:09:36.06,sign,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:12:05.87,0:12:09.21,sign,,0000,0000,0000,,PLUK PLUK
Dialogue: 0,0:23:37.44,0:23:38.27,sign,,0000,0000,0000,,EPISODE SELANJUTNYA:
Dialogue: 0,0:23:38.27,0:23:40.02,sign,,0000,0000,0000,,PERSIAPAN PESTA MALAM IKAN LEPAS
Dialogue: 0,0:00:01.11,0:00:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi,
Dialogue: 0,0:00:02.19,0:00:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pertunangan Yang Mulia dan Nona Maria\Nakan diumumkan secara resmi.
Dialogue: 0,0:00:06.32,0:00:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itu, aku sudah merangkum\Njadwal ke depannya.
Dialogue: 0,0:00:15.62,0:00:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:00:16.70,0:00:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:00:24.75,0:00:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, kamu memanggilku?
Dialogue: 0,0:00:26.67,0:00:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Placido.\NMaaf sudah memanggilmu.
Dialogue: 0,0:00:29.84,0:00:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NKakak jauh lebih sibuk dariku.
Dialogue: 0,0:00:35.56,0:00:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ada jadwal apa saja?
Dialogue: 0,0:00:38.85,0:00:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadwalku?
Dialogue: 0,0:00:41.35,0:00:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:42.48,0:00:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar... Minggu ini, aku ikut kompetisi\Nmenunggangi kuda sebagai konsultan,
Dialogue: 0,0:00:47.99,0:00:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ada kegiatan OSIS Akademi Kerajaan,
Dialogue: 0,0:00:50.49,0:00:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah itu...
Dialogue: 0,0:00:51.49,0:00:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu.
Dialogue: 0,0:00:52.45,0:00:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kamu berniat tunangan\Ndengan Nona Aida Ametis?
Dialogue: 0,0:01:03.00,0:01:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Mimi,\Nsedang sekolah di Kerajaan Rubini.
Dialogue: 0,0:01:07.21,0:01:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah menyuruhku,\N"Cari calon suami berkualitas, sana!"
Dialogue: 0,0:01:11.55,0:01:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur, awalnya kupikir itu mustahil!
Dialogue: 0,0:01:14.80,0:01:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena hal tak terduga,
Dialogue: 0,0:01:15.76,0:01:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berpacaran dengan putra mahkota,\NPangeran Renato...
Dialogue: 0,0:01:19.43,0:01:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sedang bahagia sekali!
Dialogue: 0,0:01:22.73,0:01:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar kalau kubilang ini momen\Npaling hoki dalam hidupku!
Dialogue: 0,0:01:27.85,0:01:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, hati-hati saat melangkah.
Dialogue: 0,0:01:35.37,0:01:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:01:39.79,0:01:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:01:41.41,0:01:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya senang-senang.
Dialogue: 0,0:01:44.50,0:01:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Aida belum dilamar.
Dialogue: 0,0:01:54.55,0:01:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba katakan alasannya padaku.
Dialogue: 0,0:01:58.14,0:02:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, jangan bahas itu lagi.
Dialogue: 0,0:02:02.81,0:02:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang jangan dibahas lagi?
Dialogue: 0,0:02:04.98,0:02:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Placido, aku tahu kamu menaksir Nona Aida.
Dialogue: 0,0:02:09.86,0:02:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin Duke Ametis pun senang kalau kamu,\Npangeran kedua, menjadi tunangan putrinya.
Dialogue: 0,0:02:16.37,0:02:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku sudah...
Dialogue: 0,0:02:18.95,0:02:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tanya, kenapa begitu?
Dialogue: 0,0:02:21.79,0:02:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak puas dengan Nona Aida?
Dialogue: 0,0:02:23.92,0:02:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak!
Dialogue: 0,0:02:25.21,0:02:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantas, kenapa?
Dialogue: 0,0:02:26.58,0:02:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pribadi yang tenang dan cerdas.
Dialogue: 0,0:02:29.63,0:02:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasangan yang sempurna.
Dialogue: 0,0:02:33.01,0:02:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.\NAku tahu itu.
Dialogue: 0,0:02:37.60,0:02:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:02:38.97,0:02:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Placido adalah pribadi\Nyang tulus dan mengagumkan.
Dialogue: 0,0:02:43.52,0:02:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kenapa?\NSelanjutnya giliranmu.
Dialogue: 0,0:02:47.06,0:02:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu bahagia.
Dialogue: 0,0:02:51.23,0:02:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu benci Pangeran Placido?
Dialogue: 0,0:02:56.53,0:02:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak!
Dialogue: 0,0:02:58.03,0:03:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka.\NSangat suka dia!
Dialogue: 0,0:03:05.08,0:03:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pula yang membuatku\Ntak boleh mengganggunya.
Dialogue: 0,0:03:09.75,0:03:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengganggu?\NApa maksudmu?
Dialogue: 0,0:03:13.38,0:03:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku perempuan tak tahu adab\Nyang pernah
Dialogue: 0,0:03:17.09,0:03:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertunangan dengan kakaknya,
Dialogue: 0,0:03:18.64,0:03:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan saat pertunangan itu dibatalkan,\Naku malah mau bertunangan dengan adiknya.
Dialogue: 0,0:03:22.56,0:03:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kamu bukan orang\Nyang membatalkannya!
Dialogue: 0,0:03:25.94,0:03:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi korbannya!
Dialogue: 0,0:03:28.56,0:03:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bilang padanya tak usah cemas,
Dialogue: 0,0:03:31.40,0:03:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku akan menghajar\Norang yang mengejeknya.
Dialogue: 0,0:03:35.15,0:03:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Placido juga sama.
Dialogue: 0,0:03:36.99,0:03:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya sama-sama\Ningin pasangannya bahagia,
Dialogue: 0,0:03:41.20,0:03:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi malah saling menjauh.
Dialogue: 0,0:03:43.89,0:03:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku gemas kalau hanya melihat saja!
Dialogue: 0,0:03:46.91,0:03:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah coba pikirkan sebentar,
Dialogue: 0,0:03:49.42,0:03:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sepertinya paham perasaan keduanya.
Dialogue: 0,0:03:51.88,0:03:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Pangeran rela membiarkan mereka\Ntidak bahagia seperti sekarang?
Dialogue: 0,0:03:56.49,0:03:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida benar.
Dialogue: 0,0:03:58.43,0:04:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perilaku keluarga kerajaan, baik atau buruk,\Nakan menjadi pusat perhatian.
Dialogue: 0,0:04:02.51,0:04:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya,
Dialogue: 0,0:04:03.72,0:04:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti tak sanggup melihat pasangan mereka\Ndiejek macam-macam karena satu sama lain.
Dialogue: 0,0:04:08.02,0:04:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyataannya,
Dialogue: 0,0:04:08.90,0:04:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida pernah jatuh sakit saat mulai\Ndipertimbangkan menjadi calon putri mahkota.
Dialogue: 0,0:04:17.05,0:04:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat.
Dialogue: 0,0:04:18.61,0:04:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat usiaku 12 tahun,
Dialogue: 0,0:04:19.99,0:04:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayahku pernah bilang ada kerabat jauh dari\NKerajaan Rubini yang akan datang berobat.
Dialogue: 0,0:04:30.29,0:04:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu...
Dialogue: 0,0:04:31.04,0:04:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia Nona Aida!
Dialogue: 0,0:04:34.75,0:04:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida, aku putri kelima\Ndari keluarga Duke Annovazzi, Maria!
Dialogue: 0,0:04:39.01,0:04:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurus andalanku adalah Nomor 38!
Dialogue: 0,0:04:42.51,0:04:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Nona Aida cantik sekali!
Dialogue: 0,0:04:45.56,0:04:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persis seperti tuan putri di buku dongeng!
Dialogue: 0,0:04:47.64,0:04:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:04:49.02,0:04:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida sampai kaget.
Dialogue: 0,0:04:51.27,0:04:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia datang ke rumah kita\Nuntuk memulihkan fisik dan mentalnya.
Dialogue: 0,0:04:54.23,0:04:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah kamu kagetkan?
Dialogue: 0,0:04:56.48,0:04:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sakit?\NSakit apa?
Dialogue: 0,0:04:59.32,0:05:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:05:01.07,0:05:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... susah tidur belakangan ini.
Dialogue: 0,0:05:04.78,0:05:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan!\NKalau aku, langsung pulas setelah latihan.
Dialogue: 0,0:05:11.21,0:05:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku"?
Dialogue: 0,0:05:15.59,0:05:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti Nona Aida mengira kamu lelaki.
Dialogue: 0,0:05:19.05,0:05:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar! Saat itu rambutku masih pendek,\Nmungkin karena itu.
Dialogue: 0,0:05:25.01,0:05:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:25.81,0:05:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kami cepat akrab.
Dialogue: 0,0:05:28.89,0:05:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar.
Dialogue: 0,0:05:29.73,0:05:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi berkuda ke tempat jauh,
Dialogue: 0,0:05:31.77,0:05:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memasak,
Dialogue: 0,0:05:33.56,0:05:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belajar,
Dialogue: 0,0:05:35.40,0:05:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengobrol semalaman penuh,
Dialogue: 0,0:05:37.90,0:05:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dimarahi...
Dialogue: 0,0:05:39.69,0:05:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat sedih saat hari Aida pulang tiba.
Dialogue: 0,0:05:44.77,0:05:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku,
Dialogue: 0,0:05:46.45,0:05:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida adalah teman yang sangat berharga,
Dialogue: 0,0:05:48.87,0:05:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berutang padanya\Nyang mendukungku selama sekolah,
Dialogue: 0,0:05:51.50,0:05:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia juga guru yang mengajariku\Ntata krama dan etiket...
Dialogue: 0,0:05:55.08,0:05:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ingin dia bahagia.
Dialogue: 0,0:05:58.50,0:05:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:06:00.42,0:06:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita harus apa?
Dialogue: 0,0:06:03.97,0:06:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengundang mereka makan bersama,\Ntapi keduanya tidak datang.
Dialogue: 0,0:06:09.10,0:06:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, mereka menghindari saling bertemu.
Dialogue: 0,0:06:15.98,0:06:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kenapa buru-buru?\NNapasku tersengal-sengal.
Dialogue: 0,0:06:20.90,0:06:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa mengerjakan PR.\NBantu aku, ya.
Dialogue: 0,0:06:27.33,0:06:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, aku mau mengambil pulpen\Ndan buku catatan dulu, ya.
Dialogue: 0,0:06:37.04,0:06:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada orang di sini?
Dialogue: 0,0:06:42.42,0:06:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku, Placido.
Dialogue: 0,0:06:45.97,0:06:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa di sini?
Dialogue: 0,0:06:47.64,0:06:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diminta Raimondo\Nmembereskan ruang arsip.
Dialogue: 0,0:06:51.14,0:06:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, di mana Tuan Raimondo?
Dialogue: 0,0:06:54.06,0:06:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada urusan mendadak.
Dialogue: 0,0:06:58.77,0:07:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Tidak kedengaran apa-apa...
Dialogue: 0,0:07:02.36,0:07:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katalog flora volume empat tidak ketemu.
Dialogue: 0,0:07:05.15,0:07:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya itu ada di rak sebelah sana.
Dialogue: 0,0:07:08.70,0:07:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:09.91,0:07:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah membereskan buku?
Dialogue: 0,0:07:13.50,0:07:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kamu ada di sana, kan?
Dialogue: 0,0:07:16.50,0:07:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kamu bisa bantu kami?
Dialogue: 0,0:07:23.92,0:07:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku yakin tidak akan ketahuan.
Dialogue: 0,0:07:29.89,0:07:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang, ya.\NBerarti, Nona Aida yang lebih unggul.
Dialogue: 0,0:07:36.02,0:07:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah buntu.
Dialogue: 0,0:07:37.77,0:07:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, tidak bisa pakai metode\Nyang berbelit-belit, ya.
Dialogue: 0,0:07:40.56,0:07:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbelit-belit?
Dialogue: 0,0:07:42.07,0:07:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyiapkan situasi sempurna saja\Ntidak mempan,
Dialogue: 0,0:07:45.90,0:07:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya kita harus pinjam\Nkekuatan seseorang.
Dialogue: 0,0:07:49.03,0:07:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan siapa?
Dialogue: 0,0:07:51.03,0:07:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, Baginda Ratu.
Dialogue: 0,0:07:53.95,0:07:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau perintah Baginda Ratu,\Norang seperti mereka pun mau dengar, kan?
Dialogue: 0,0:07:58.79,0:08:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, jangan lakukan itu.
Dialogue: 0,0:08:01.75,0:08:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:08:03.96,0:08:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu menjadi paksaan.
Dialogue: 0,0:08:07.43,0:08:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu bentuk perhatian seorang ibu\Nmasih bisa diterima,
Dialogue: 0,0:08:10.39,0:08:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau itu sebagai kata-kata ratu,\Nbebannya berbeda.
Dialogue: 0,0:08:13.39,0:08:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua pasti akan patuh.
Dialogue: 0,0:08:16.87,0:08:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa mereka akan bahagia\Nsetelah dipaksa menghadapi satu sama lain?
Dialogue: 0,0:08:26.57,0:08:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran benar.
Dialogue: 0,0:08:28.53,0:08:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu fokus memikirkan\Ningin bantu mereka...
Dialogue: 0,0:08:32.78,0:08:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\Naku mengabaikan perasaan keduanya.
Dialogue: 0,0:08:36.95,0:08:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham betul kamu\Nmemikirkan kebaikan untuk mereka.
Dialogue: 0,0:08:40.46,0:08:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, hal pentingnya...
Dialogue: 0,0:08:42.33,0:08:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan memutuskan karena perkataan orang lain,\Ntapi karena keputusan sendiri.
Dialogue: 0,0:08:49.01,0:08:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku ini bodoh, bodoh, bodoh!
Dialogue: 0,0:08:50.93,0:08:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menghajar diriku sendiri\Npakai Nomor 38!
Dialogue: 0,0:08:55.51,0:09:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kamu bicarakan\Ndengan Nona Aida sekali lagi?
Dialogue: 0,0:09:00.06,0:09:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia sedang ragu,\Nberikan dorongan sedikit.
Dialogue: 0,0:09:04.11,0:09:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau tekadnya sudah bulat,\Nkita hanya bisa perhatikan dari jauh.
Dialogue: 0,0:09:09.74,0:09:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:09:12.74,0:09:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kue yang secara khusus\Ndibuat koki restoran ini.
Dialogue: 0,0:09:17.12,0:09:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dibawa sebagai oleh-oleh\Nuntuk Nona Aida.
Dialogue: 0,0:09:20.92,0:09:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Tuan Raimondo.
Dialogue: 0,0:09:24.42,0:09:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:09:26.03,0:09:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kalau ini\Nbisa membantumu memulai obrolan.
Dialogue: 0,0:09:38.47,0:09:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida, aku boleh masuk?
Dialogue: 0,0:09:40.64,0:09:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi?
Dialogue: 0,0:09:43.48,0:09:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang belajar, ya?
Dialogue: 0,0:09:45.02,0:09:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sedikit.
Dialogue: 0,0:09:46.80,0:09:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, terima kasih\Nsudah membereskan ruang arsip.
Dialogue: 0,0:09:50.36,0:09:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu repot-repot datang untuk itu?
Dialogue: 0,0:09:52.99,0:09:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...\NPermintaan maaf.
Dialogue: 0,0:09:56.87,0:09:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu meminta maaf.
Dialogue: 0,0:09:59.29,0:10:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kamu melakukan itu demi kebaikanku.
Dialogue: 0,0:10:02.92,0:10:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Raimondo memberikan kudapan.\NKatanya ini kue kastanya.
Dialogue: 0,0:10:07.80,0:10:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastanya?
Dialogue: 0,0:10:10.01,0:10:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari kita makan.
Dialogue: 0,0:10:17.30,0:10:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!\NRasanya kastanya banget.
Dialogue: 0,0:10:21.27,0:10:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:25.44,0:10:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak terlalu suka?
Dialogue: 0,0:10:27.65,0:10:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka, sangat suka.\NBukan.
Dialogue: 0,0:10:31.90,0:10:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya teringat masa lalu.
Dialogue: 0,0:10:35.99,0:10:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa lalu?
Dialogue: 0,0:10:38.03,0:10:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan bahas ini lagi,\Nkamu mau dengar?
Dialogue: 0,0:10:41.08,0:10:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerita masa lalu.
Dialogue: 0,0:10:44.58,0:10:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:10:46.17,0:10:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertemu Pangeran Placido\Nsaat berusia enam tahun.
Dialogue: 0,0:11:02.93,0:11:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perempuan di sana!
Dialogue: 0,0:11:05.85,0:11:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang apa?\NPohon kastanya itu bukan milikmu.
Dialogue: 0,0:11:11.65,0:11:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri siapa?\NKenapa bisa bilang begitu?
Dialogue: 0,0:11:15.20,0:11:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku kenal\Ndengan pemilik pohon kastanya itu.
Dialogue: 0,0:11:18.62,0:11:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kamu siapa?
Dialogue: 0,0:11:19.95,0:11:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kenal dengan orang\Nyang menyetor uang untuk pohon ini!
Dialogue: 0,0:11:25.92,0:11:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat ingin monopoli semua, ya?\NDasar rakus.
Dialogue: 0,0:11:29.88,0:11:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan ingin memonopoli.
Dialogue: 0,0:11:31.88,0:11:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NKamu sendiri malah sok berkuasa!
Dialogue: 0,0:11:34.80,0:11:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sok berkuasa!
Dialogue: 0,0:11:37.01,0:11:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu sebut aku sok berkuasa,\Nberarti kamu si rakus dan pemarah!
Dialogue: 0,0:11:48.73,0:11:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyebalkan!\NPergi, sana.
Dialogue: 0,0:11:51.61,0:11:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak sok berkuasa!
Dialogue: 0,0:11:53.11,0:11:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sini, Anak Sok Berkuasa!\N- Aduh!
Dialogue: 0,0:11:55.11,0:11:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu mau kastanya, kan?\N- Hentikan.
Dialogue: 0,0:11:56.70,0:11:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pergi, sana!\N- Hentikan.
Dialogue: 0,0:11:57.74,0:11:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pergi, sana!\N- Aduh!
Dialogue: 0,0:11:58.28,0:11:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun!
Dialogue: 0,0:12:02.06,0:12:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesal karena dia tiba-tiba bicara\Nseolah aku mencuri kastanya.
Dialogue: 0,0:12:05.87,0:12:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya cerita itu berbeda
Dialogue: 0,0:12:07.67,0:12:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari yang kudengar dulu...
Dialogue: 0,0:12:09.21,0:12:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu juga tomboi saat kecil.
Dialogue: 0,0:12:11.84,0:12:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku bisa terlihat seanggun ini\Nkarena belajar mati-matian.
Dialogue: 0,0:12:16.84,0:12:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida memang keren.
Dialogue: 0,0:12:21.18,0:12:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, apa reaksi Pangeran Placido\Nyang tahu kamu putri Duke saat bertemu lagi?
Dialogue: 0,0:12:29.10,0:12:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya kaget bukan main.
Dialogue: 0,0:12:31.81,0:12:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti itu pertama kalinya ada yang bilang,\N"Pergi, sana!" padanya.
Dialogue: 0,0:12:36.03,0:12:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:12:37.49,0:12:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah akrab,\Ndia mulai terus terang padaku.
Dialogue: 0,0:12:43.08,0:12:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar dari Duke Ametis,
Dialogue: 0,0:12:45.41,0:12:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya kamu akan terpilih\Nmenjadi tunangan Kakak.
Dialogue: 0,0:12:50.08,0:12:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:12:51.04,0:12:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, ya.\NBaginda Ratu di masa depan.
Dialogue: 0,0:12:56.84,0:12:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak...
Dialogue: 0,0:13:00.84,0:13:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran.
Dialogue: 0,0:13:03.55,0:13:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, jadi aku yang menemanimu.
Dialogue: 0,0:13:06.31,0:13:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak terus bertambah sibuk tiap harinya.
Dialogue: 0,0:13:09.85,0:13:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya Pangeran Placido sendiri\Ntidak keberatan?
Dialogue: 0,0:13:13.40,0:13:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak!
Dialogue: 0,0:13:15.69,0:13:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah berteman sejak\N"Insiden Kastanya".
Dialogue: 0,0:13:18.97,0:13:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kan?
Dialogue: 0,0:13:21.32,0:13:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan disebut seperti itu.
Dialogue: 0,0:13:27.83,0:13:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sejak hari itu juga aku berpikir\Nbisa langgeng denganmu.
Dialogue: 0,0:13:33.04,0:13:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya intuisiku tepat sasaran.
Dialogue: 0,0:13:42.08,0:13:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku...
Dialogue: 0,0:13:46.64,0:13:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Aida.
Dialogue: 0,0:13:48.29,0:13:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, aku orang yang paling paham\Nbetapa baiknya dirimu.
Dialogue: 0,0:13:52.60,0:13:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu memikirkan orang lain\Nsebelum dirimu sendiri, kan?
Dialogue: 0,0:13:56.23,0:14:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untuk sekali saja,\Nbagaimana kalau coba utamakan diri sendiri?
Dialogue: 0,0:14:02.36,0:14:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diri sendiri?
Dialogue: 0,0:14:05.66,0:14:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak usah pikirkan gosip di sekitar,\Nharapan keluarga,
Dialogue: 0,0:14:08.74,0:14:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau perasaan Pangeran Placido.
Dialogue: 0,0:14:11.96,0:14:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirkan saja hal yang ingin kamu lakukan!
Dialogue: 0,0:14:16.09,0:14:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang ingin... kulakukan.
Dialogue: 0,0:14:19.13,0:14:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!\NKamu ingin apa?
Dialogue: 0,0:14:26.14,0:14:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ingin kulakukan...
Dialogue: 0,0:14:31.98,0:14:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku sudah mengatakan hal\Nyang tidak perlu ke Aida, ya?
Dialogue: 0,0:14:36.27,0:14:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:14:37.02,0:14:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keceplosan lagi, ya?
Dialogue: 0,0:14:39.15,0:14:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kencang sekali.
Dialogue: 0,0:14:41.53,0:14:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida!\NAda kabar gembira.
Dialogue: 0,0:14:45.31,0:14:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada beberapa putra bangsawan\Nyang ingin menikah denganmu.
Dialogue: 0,0:14:50.87,0:14:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:14:52.33,0:14:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berasal dari keluarga\Nyang cukup terpandang
Dialogue: 0,0:14:56.00,0:15:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak mempermasalahkan batalnya\Npertunanganmu dengan Pangeran Renato.
Dialogue: 0,0:15:01.96,0:15:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Tuan Duke Ametis...
Dialogue: 0,0:15:04.09,0:15:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:15:12.31,0:15:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, terima kasih\Nsudah memikirkan soal aku.
Dialogue: 0,0:15:16.10,0:15:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh kupertimbangkan sebentar?
Dialogue: 0,0:15:19.69,0:15:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu.\NKita harus pilih pasangannya baik-baik.
Dialogue: 0,0:15:32.70,0:15:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Duke Ametis pasti bisa\Nmenambah mas kawin bawaan.
Dialogue: 0,0:15:36.83,0:15:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pintar juga, ya.
Dialogue: 0,0:15:38.67,0:15:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reputasi Nona Aida mungkin sedikit ternoda,\Ntapi dia tetap calon istri yang berharga.
Dialogue: 0,0:15:42.71,0:15:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa meraup keuntungan\Ndengan menikahinya,
Dialogue: 0,0:15:45.80,0:15:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}barang bagus harga murah.
Dialogue: 0,0:15:52.28,0:15:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat pagi.\N- Salam sejahtera.
Dialogue: 0,0:15:57.90,0:15:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujan.
Dialogue: 0,0:16:03.32,0:16:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu serius?
Dialogue: 0,0:16:05.15,0:16:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, orang-orang ribut karena ada duel.
Dialogue: 0,0:16:10.20,0:16:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida, ini gawat!
Dialogue: 0,0:16:18.08,0:16:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Placido di Rubini
Dialogue: 0,0:16:20.58,0:16:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menantangmu berduel dengan kehormatan\Ndan nyawa sebagai taruhannya!
Dialogue: 0,0:16:24.84,0:16:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Placido melakukan duel\Ndengan orang yang kabarnya menghinamu.
Dialogue: 0,0:16:33.56,0:16:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!\NHal seperti itu...
Dialogue: 0,0:16:35.89,0:16:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, pagi tadi Duke Ametis\Nsudah mencarikan pasangan baru...
Dialogue: 0,0:16:41.81,0:16:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat, Yang Mulia Renato!
Dialogue: 0,0:16:43.73,0:16:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Tuan Raimondo?
Dialogue: 0,0:16:46.44,0:16:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, Yang Mulia.
Dialogue: 0,0:16:48.82,0:16:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda pasti bercanda soal duel ini, kan?
Dialogue: 0,0:16:50.99,0:16:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal saya tidak sedang\Nmenjelek-jelekkan Anda.
Dialogue: 0,0:16:54.33,0:16:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria sejati tidak menghina seorang wanita!
Dialogue: 0,0:16:57.62,0:17:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka Pangeran Placido\Nbisa semarah itu.
Dialogue: 0,0:17:00.29,0:17:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku melihatnya.
Dialogue: 0,0:17:03.96,0:17:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:17:07.92,0:17:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida?
Dialogue: 0,0:17:09.47,0:17:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sudah mendengar situasinya.
Dialogue: 0,0:17:11.55,0:17:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kehormatan saya\Nadalah milik saya sendiri.
Dialogue: 0,0:17:14.93,0:17:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia tidak perlu melindungi saya.
Dialogue: 0,0:17:18.39,0:17:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali,\Ntapi saya berniat menolak tawaran Anda.
Dialogue: 0,0:17:23.44,0:17:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:17:24.69,0:17:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau putri Duke tak kunjung menikah,\Nnama keluarganya akan ternoda...
Dialogue: 0,0:17:29.95,0:17:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Ametis tidak akan goyah\Nkarena hal seperti itu.
Dialogue: 0,0:17:33.82,0:17:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda tak perlu cemas.
Dialogue: 0,0:17:37.33,0:17:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi...
Dialogue: 0,0:17:38.58,0:17:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.\NJangan katakan apa-apa lagi.
Dialogue: 0,0:17:43.83,0:17:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas tawaran Anda.
Dialogue: 0,0:17:46.25,0:17:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon izinkan saya memberi penolakan.
Dialogue: 0,0:17:58.56,0:18:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, silakan kembali ke kelas.
Dialogue: 0,0:18:15.39,0:18:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran, tolong simpan pedangnya.
Dialogue: 0,0:18:25.38,0:18:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memalukan sekali.
Dialogue: 0,0:18:28.59,0:18:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu tak cukup kuat\Nuntuk melindungimu.
Dialogue: 0,0:18:35.26,0:18:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatianmu selama ini selalu menghibur
Dialogue: 0,0:18:40.43,0:18:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyemangatiku.
Dialogue: 0,0:18:42.56,0:18:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:18:45.02,0:18:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:18:48.48,0:18:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Pangeran.
Dialogue: 0,0:18:58.45,0:19:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang melindungiku?
Dialogue: 0,0:19:00.95,0:19:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:19:02.09,0:19:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham bahwa hal yang ingin kulakukan
Dialogue: 0,0:19:04.96,0:19:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah mendukung dan melindungimu.
Dialogue: 0,0:19:08.22,0:19:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu artinya...
Dialogue: 0,0:19:12.03,0:19:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.\NTolong jadikan aku istrimu.
Dialogue: 0,0:19:16.97,0:19:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu...
Dialogue: 0,0:19:20.97,0:19:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja,\Nkalau Pangeran juga ingin menikahiku.
Dialogue: 0,0:19:25.35,0:19:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku ingin!
Dialogue: 0,0:19:32.86,0:19:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida Ametis.
Dialogue: 0,0:19:36.11,0:19:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah akan terus mencintaimu\Nsepanjang hayatku.
Dialogue: 0,0:19:40.49,0:19:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah istriku.
Dialogue: 0,0:19:45.37,0:19:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati.
Dialogue: 0,0:19:56.63,0:20:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget mendengar kata melindungi\Ndari mulut Aida.
Dialogue: 0,0:20:00.57,0:20:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya?
Dialogue: 0,0:20:02.56,0:20:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran tidak kaget?
Dialogue: 0,0:20:04.89,0:20:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Mimi yang bilang\Nkamu teman Nona Aida?
Dialogue: 0,0:20:09.48,0:20:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kalian punya kemiripan.
Dialogue: 0,0:20:12.65,0:20:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bisa lapor ke Ayah dan Ibu.
Dialogue: 0,0:20:15.82,0:20:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:16.74,0:20:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua sudah menunggu hari ini datang.
Dialogue: 0,0:20:27.25,0:20:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami merestui pertunangan kalian.
Dialogue: 0,0:20:29.71,0:20:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat.
Dialogue: 0,0:20:32.00,0:20:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Baginda Raja.
Dialogue: 0,0:20:35.55,0:20:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Baginda Ratu.
Dialogue: 0,0:20:38.68,0:20:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kamu sempat\Nmembuatku gelisah, Placido.
Dialogue: 0,0:20:42.22,0:20:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:43.46,0:20:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat berpikir ingin menyatukan kalian\Nmelalui titah raja.
Dialogue: 0,0:20:49.31,0:20:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suamiku!
Dialogue: 0,0:20:51.61,0:20:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf.
Dialogue: 0,0:20:53.82,0:20:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku jadi ingat\Nsaat kami masih muda dulu.
Dialogue: 0,0:20:56.82,0:20:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, jangan bahas itu lagi.
Dialogue: 0,0:21:06.58,0:21:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi selalu mengajarkanku\Npentingnya keberanian.
Dialogue: 0,0:21:14.36,0:21:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida!
Dialogue: 0,0:21:16.55,0:21:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisi tubuhmu?
Dialogue: 0,0:21:20.01,0:21:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik dari kemarin.
Dialogue: 0,0:21:21.97,0:21:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.\NWajahmu juga kelihatan lebih segar.
Dialogue: 0,0:21:25.85,0:21:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo pergi.
Dialogue: 0,0:21:29.31,0:21:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NAku tidak akan bisa...
Dialogue: 0,0:21:32.65,0:21:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NKamu yang bilang ingin coba, kan?
Dialogue: 0,0:21:37.53,0:21:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:21:38.32,0:21:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji pasti seru!\NBeranikan dirimu!
Dialogue: 0,0:21:41.99,0:21:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja.\NAda aku di sampingmu!
Dialogue: 0,0:21:50.79,0:21:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Mimi.
Dialogue: 0,0:23:26.93,0:23:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida pernah mengajarkanku\Nyang namanya "bahasa bunga".
Dialogue: 0,0:23:29.76,0:23:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Aida punya yang seperti itu,\Nmungkin "manis".
Dialogue: 0,0:23:32.60,0:23:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Pangeran Placido mungkin "ketulusan".
Dialogue: 0,0:23:34.56,0:23:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Pangeran Renato...\NHm... "Keren"?
Dialogue: 0,0:23:37.44,0:23:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku keceplosan lagi!
