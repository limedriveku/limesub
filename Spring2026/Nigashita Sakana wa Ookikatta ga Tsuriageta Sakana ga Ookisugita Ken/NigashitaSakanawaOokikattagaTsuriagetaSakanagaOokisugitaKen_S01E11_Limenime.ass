Dialogue: 0,0:01:41.96,0:01:45.33,sign,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:01:45.33,0:01:49.51,sign,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:02:59.03,0:03:04.04,sign,,0000,0000,0000,,EPISODE 10:\NPERSIAPAN PESTA MALAM IKAN LEPAS
Dialogue: 0,0:04:30.17,0:04:33.13,sign,,0000,0000,0000,,WAAA!
Dialogue: 0,0:08:20.31,0:08:21.86,sign,,0000,0000,0000,,GYUT
Dialogue: 0,0:10:38.66,0:10:41.08,sign,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:10:41.08,0:10:45.08,sign,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP SETELAHNYA\NMALAH TERLALU BESAR
Dialogue: 0,0:11:48.69,0:11:52.32,sign,,0000,0000,0000,,GEMAS
Dialogue: 0,0:16:41.15,0:16:42.94,sign,,0000,0000,0000,,INGIN LIHAT KALIAN BERDUA
Dialogue: 0,0:16:42.94,0:16:44.52,sign,,0000,0000,0000,,BERDANSA LEBIH LAMA
Dialogue: 0,0:17:15.89,0:17:16.81,sign,,0000,0000,0000,,KENAPA AKU JUGA IKUT-IKUTAN
Dialogue: 0,0:17:16.81,0:17:17.93,sign,,0000,0000,0000,,MENJADI MENTOR DANSA?
Dialogue: 0,0:21:53.83,0:21:55.04,sign,,0000,0000,0000,,BERSAMBUNG
Dialogue: 0,0:23:35.53,0:23:37.65,sign,,0000,0000,0000,,EPISODE SELANJUTNYA:
Dialogue: 0,0:23:37.65,0:23:39.73,sign,,0000,0000,0000,,IKAN LEPAS TERSERET KERIBUTAN SOAL ASMARA
Dialogue: 0,0:00:05.19,0:00:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini,
Dialogue: 0,0:00:06.57,0:00:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengakui pertunangan di antara\NMaria Annovazzi dan Renato di Rubini,
Dialogue: 0,0:00:10.03,0:00:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta Aida Ametis dan Placido di Rubini.
Dialogue: 0,0:00:15.95,0:00:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini surat resmi dari Baginda Raja.
Dialogue: 0,0:00:18.37,0:00:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan diterima.
Dialogue: 0,0:00:20.42,0:00:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik, sudah saya terima.
Dialogue: 0,0:00:23.38,0:00:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demikianlah, Aida dan Pangeran Placido,\Nserta aku dan Pangeran Renato
Dialogue: 0,0:00:28.13,0:00:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kini resmi pasangan tunangan\Nyang diakui oleh raja dan ratu.
Dialogue: 0,0:00:32.39,0:00:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabar gembira!
Dialogue: 0,0:00:34.26,0:00:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra mahkota bersaudara telah bertunangan!
Dialogue: 0,0:00:38.48,0:00:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu Nona Aida.
Dialogue: 0,0:00:40.60,0:00:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta kencananya sering lewat\Ndi depan rumahku.
Dialogue: 0,0:00:43.48,0:00:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kira-kira pasangan Pangeran Renato?
Dialogue: 0,0:00:47.11,0:00:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu Kerajaan Muro, kan?
Dialogue: 0,0:00:49.15,0:00:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya dia putri Duke dari kerajaan itu.
Dialogue: 0,0:00:51.41,0:00:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Pangeran menikahi gadis\Ndari tempat sejauh itu?
Dialogue: 0,0:00:55.12,0:00:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal masih banyak calon istri\Nyang baik di Kerajaan Rubini.
Dialogue: 0,0:00:59.75,0:01:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehem.
Dialogue: 0,0:01:00.83,0:01:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehubungan dengan itu,
Dialogue: 0,0:01:02.42,0:01:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Raja berencana\Nmengadakan pesta malam
Dialogue: 0,0:01:05.00,0:01:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengenalkan kedua pasangan.
Dialogue: 0,0:01:08.05,0:01:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Mengerti.
Dialogue: 0,0:01:09.92,0:01:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detail lainnya akan kusampaikan\Ndi lain waktu.
Dialogue: 0,0:01:12.84,0:01:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mengingat kalian\Nperlu menyiapkan banyak hal,
Dialogue: 0,0:01:15.43,0:01:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuputuskan memberi tahu lebih awal.
Dialogue: 0,0:01:19.35,0:01:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan tetapi, aku tak pernah menyangka
Dialogue: 0,0:01:21.39,0:01:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau "pesta malam" ini\Nlebih sulit dibandingkan berlatih
Dialogue: 0,0:01:25.73,0:01:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menguasai kuda-kuda bela diri.
Dialogue: 0,0:03:05.96,0:03:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah banyak hal terjadi,\Nakhirnya kita bisa santai.
Dialogue: 0,0:03:09.00,0:03:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di buku dongeng pasti sudah,\N"Mereka hidup bahagia selamanya."
Dialogue: 0,0:03:13.46,0:03:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berterima kasih padamu, Mimi.
Dialogue: 0,0:03:15.47,0:03:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai tak tahu\Nharus balas budi dengan cara apa.
Dialogue: 0,0:03:18.97,0:03:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu tak perlu memikirkan soal itu.
Dialogue: 0,0:03:22.27,0:03:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai ucapan terima kasih,
Dialogue: 0,0:03:24.27,0:03:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan melatihmu dengan sangat ketat.
Dialogue: 0,0:03:28.40,0:03:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melatih?
Dialogue: 0,0:03:30.77,0:03:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Raimondo sudah bilang, kan?
Dialogue: 0,0:03:33.15,0:03:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti akan ada pesta malam.
Dialogue: 0,0:03:34.82,0:03:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan didampingi Pangeran Renato,\Nsedangkan aku sama Pangeran Placido.
Dialogue: 0,0:03:39.49,0:03:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan melakukan dansa pertama\Ndi aula besar istana.
Dialogue: 0,0:03:43.49,0:03:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dansa pertama?
Dialogue: 0,0:03:45.62,0:03:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di depan orang-orang?
Dialogue: 0,0:03:47.42,0:03:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:48.67,0:03:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku akan baik-baik saja?
Dialogue: 0,0:03:50.29,0:03:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah berdansa...
Dialogue: 0,0:03:54.71,0:03:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah berdansa\Ndengan Pangeran Placido sekali.
Dialogue: 0,0:03:58.30,0:03:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan dia?
Dialogue: 0,0:03:59.43,0:04:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, di pesta taman,
Dialogue: 0,0:04:02.05,0:04:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku baru datang\Ndan kamu absen karena sakit.
Dialogue: 0,0:04:06.02,0:04:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku yakin orang lain bukan kagum,\Nmalah terkejut,
Dialogue: 0,0:04:09.69,0:04:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang seperti itu pun bisa.
Dialogue: 0,0:04:12.44,0:04:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, aku yakin dansa\Nyang kamu maksud tadi sangat menarik,
Dialogue: 0,0:04:17.61,0:04:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tolong berdansalah dengan normal\Ndi pesta malam.
Dialogue: 0,0:04:21.16,0:04:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa berdansa\Ndengan anggun sepertimu,
Dialogue: 0,0:04:23.74,0:04:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kalau aku tak sengaja\Nmenginjak kaki Pangeran?
Dialogue: 0,0:04:26.33,0:04:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari-H nanti, aku pakai sepatu hak tinggi\Ndi atas lantai licin, kan?
Dialogue: 0,0:04:30.17,0:04:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti bisa dijadikan senjata!
Dialogue: 0,0:04:33.59,0:04:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya kamu cemas pada hal yang salah,
Dialogue: 0,0:04:36.17,0:04:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tenang saja.
Dialogue: 0,0:04:39.59,0:04:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu atletis,\Npasti bisa menguasainya dengan cepat.
Dialogue: 0,0:04:44.01,0:04:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari latihan yang rajin.
Dialogue: 0,0:04:46.14,0:04:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida...
Dialogue: 0,0:04:48.85,0:04:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:04:49.69,0:04:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha!
Dialogue: 0,0:04:51.94,0:04:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi kamu juga!
Dialogue: 0,0:05:05.62,0:05:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa!\NAku tidak akan bisa!
Dialogue: 0,0:05:08.04,0:05:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyerah!\NKamu pasti bisa!
Dialogue: 0,0:05:10.62,0:05:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku bisa bergerak lincah
Dialogue: 0,0:05:12.54,0:05:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama satu jam pakai sepatu seperti ini\Nsambil terus tersenyum!
Dialogue: 0,0:05:16.30,0:05:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kamu pasti cepat menguasainya.
Dialogue: 0,0:05:19.01,0:05:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bela diri dan dansa itu berbeda!
Dialogue: 0,0:05:23.26,0:05:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:05:25.10,0:05:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini metode latihan yang agak klasik...
Dialogue: 0,0:05:28.35,0:05:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari coba habiskan satu hari ini\Ndengan buku di kepala.
Dialogue: 0,0:05:31.64,0:05:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini,\Nkamu bisa menguasai postur berdiri.
Dialogue: 0,0:05:35.15,0:05:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku baru tahu kalau kamu sekeras ini.
Dialogue: 0,0:05:38.53,0:05:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa satu hal penting lainnya.
Dialogue: 0,0:05:41.90,0:05:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada lagi?
Dialogue: 0,0:05:42.95,0:05:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menentukan aksesori yang dipakai
Dialogue: 0,0:05:45.20,0:05:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan parfum untuk pesta malam.
Dialogue: 0,0:05:47.08,0:05:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih sendiri?
Dialogue: 0,0:05:48.16,0:05:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, tidak bisa.\NAku belum pernah pakai parfum...
Dialogue: 0,0:05:51.96,0:05:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kita bisa pikirkan soal itu nanti.
Dialogue: 0,0:05:54.13,0:05:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dansa...
Dialogue: 0,0:05:55.04,0:05:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida.
Dialogue: 0,0:05:55.84,0:05:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi pilih parfum dulu, ya!
Dialogue: 0,0:05:58.21,0:05:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Sekarang?
Dialogue: 0,0:05:59.34,0:06:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, lebih cepat lebih baik, kan?
Dialogue: 0,0:06:02.30,0:06:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dansanya bisa nanti saja!
Dialogue: 0,0:06:04.26,0:06:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byuung!
Dialogue: 0,0:06:09.27,0:06:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi ini, ya.
Dialogue: 0,0:06:14.77,0:06:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu menjadikan parfum sebagai alasan
Dialogue: 0,0:06:17.57,0:06:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk kabur dari latihan\Ndan datang ke tempatku?
Dialogue: 0,0:06:20.99,0:06:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana cerdik khas dirimu.
Dialogue: 0,0:06:23.82,0:06:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan.
Dialogue: 0,0:06:25.32,0:06:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bagaimana kalau kamu\Nmenyantap kuenya dulu?
Dialogue: 0,0:06:29.87,0:06:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti merasa bersalah\Nhingga tak bisa makan sebanyak itu.
Dialogue: 0,0:06:34.04,0:06:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan hubungi Nona Aida.
Dialogue: 0,0:06:36.83,0:06:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah Cannoli ini, masakan di rumah\NMarquess Pinotti lezat-lezat.
Dialogue: 0,0:06:42.38,0:06:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia yang itu\Nmenjamu dengan sepenuh hati?
Dialogue: 0,0:06:45.64,0:06:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja! Biasa!
Dialogue: 0,0:06:47.35,0:06:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keceplosan lagi.
Dialogue: 0,0:06:50.10,0:06:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.\NApa aku boleh menyapa sebentar?
Dialogue: 0,0:06:54.02,0:06:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa?
Dialogue: 0,0:06:55.44,0:06:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang jangan ganggu!
Dialogue: 0,0:06:58.61,0:07:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa?\NBerarti dia Marquess Pinotti?
Dialogue: 0,0:07:02.53,0:07:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku ingin berterima kasih\Ntentang hal itu.
Dialogue: 0,0:07:06.03,0:07:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Desa Navarro, ya?
Dialogue: 0,0:07:07.95,0:07:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona benar.
Dialogue: 0,0:07:10.08,0:07:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Nona Maria?
Dialogue: 0,0:07:11.66,0:07:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya apa, ya?
Dialogue: 0,0:07:18.46,0:07:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanaman yang Nona Maria kirimkan\Nkepada Rosalia.
Dialogue: 0,0:07:22.30,0:07:24.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mencium aromanya,
Dialogue: 0,0:07:24.17,0:07:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mendapat inspirasi bahwa ia bisa diolah.
Dialogue: 0,0:07:27.68,0:07:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku segera berangkat ke Desa Navarro.
Dialogue: 0,0:07:31.47,0:07:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hugo dan Veronica juga
Dialogue: 0,0:07:33.43,0:07:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasutri yang menjanjikan,\Nberpengetahuan luas soal tanaman,
Dialogue: 0,0:07:36.23,0:07:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan penuh semangat.
Dialogue: 0,0:07:38.60,0:07:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantikan perkembangan mereka.
Dialogue: 0,0:07:40.61,0:07:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baru saja memulai transaksi\Nuntuk hasil panennya.
Dialogue: 0,0:07:45.49,0:07:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikut adalah prototipe nomor satu.
Dialogue: 0,0:07:48.11,0:07:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang memikirkan formulanya.
Dialogue: 0,0:07:50.95,0:07:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin mendengar pendapatmu.
Dialogue: 0,0:07:53.62,0:07:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku belum pernah pakai parfum...
Dialogue: 0,0:07:57.87,0:08:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kurang paham apa yang bagus.
Dialogue: 0,0:08:01.17,0:08:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis kampungan sepertimu\Nsudah jelas tidak akan paham!
Dialogue: 0,0:08:04.21,0:08:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kamu tak mampu\Nmemilih parfum yang sesuai
Dialogue: 0,0:08:08.38,0:08:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk acara berkelas seperti pesta malam.
Dialogue: 0,0:08:10.26,0:08:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bisa jadi masalah\Nkalau kamu menyebarkan bau tak sedap!
Dialogue: 0,0:08:14.97,0:08:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa pilihkan sesuatu untukmu.
Dialogue: 0,0:08:20.31,0:08:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:08:21.86,0:08:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kamu pasti mau membantu!
Dialogue: 0,0:08:25.36,0:08:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei...\NJangan menempeli aku!
Dialogue: 0,0:08:29.61,0:08:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya...
Dialogue: 0,0:08:31.91,0:08:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memilih parfum\Nyang cocok dipakai olehmu.
Dialogue: 0,0:08:36.65,0:08:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba cium?
Dialogue: 0,0:08:38.46,0:08:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup satu tetes ke atas kipas.
Dialogue: 0,0:08:41.08,0:08:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah cukup untuk menikmati aromanya.
Dialogue: 0,0:08:51.09,0:08:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma pembukanya harum segar khas sitrus.
Dialogue: 0,0:08:54.14,0:08:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diikuti sentuhan kesturi bunga bakung\Nyang feminin.
Dialogue: 0,0:08:57.06,0:08:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada wangi yang lebih\Nmenggambarkan dirimu daripada ini.
Dialogue: 0,0:08:59.89,0:09:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harumnya...
Dialogue: 0,0:09:02.15,0:09:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingat angin sejuk di Desa Navarro.
Dialogue: 0,0:09:05.23,0:09:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut senang kalau kamu suka.
Dialogue: 0,0:09:07.90,0:09:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu merasa tenang\Nsetelah mencium aroma parfum favorit, kan?
Dialogue: 0,0:09:11.66,0:09:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan saja parfumnya saat kamu tegang.
Dialogue: 0,0:09:19.75,0:09:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, lagi-lagi!
Dialogue: 0,0:09:24.92,0:09:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong berikan ini pada Nona Aida.\NParfum pilihanku, Rosalia Pinotti.
Dialogue: 0,0:09:30.01,0:09:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia tidak suka,\Naku menerima protesnya!
Dialogue: 0,0:09:33.72,0:09:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan racik sampai dia puas!
Dialogue: 0,0:09:35.81,0:09:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia akan suka!
Dialogue: 0,0:09:39.77,0:09:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja.
Dialogue: 0,0:09:44.02,0:09:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kamu sudah tahu,\Ntapi kuingatkan lagi.
Dialogue: 0,0:09:46.52,0:09:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhati-hatilah di pesta malam.
Dialogue: 0,0:09:49.57,0:09:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:50.24,0:09:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain Baginda Raja,\Naku yakin banyak tamu dari negara tetangga.
Dialogue: 0,0:09:55.78,0:10:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua akan memperhatikan\Nsetiap gerak-gerikmu dan Nona Aida.
Dialogue: 0,0:10:01.50,0:10:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, jangan lupakan bahwa\Nada orang dengan niat jahat
Dialogue: 0,0:10:04.63,0:10:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menunggumu membuat kesalahan\Nlalu menyebarkan kabarnya.
Dialogue: 0,0:10:09.00,0:10:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niat jahat...
Dialogue: 0,0:10:11.01,0:10:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Aida benar.
Dialogue: 0,0:10:13.30,0:10:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perilaku keluarga kerajaan, baik atau buruk,
Dialogue: 0,0:10:15.93,0:10:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menjadi pusat perhatian.
Dialogue: 0,0:10:18.10,0:10:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:10:19.06,0:10:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin kamu pasti bisa\Nmengatasi hal itu.
Dialogue: 0,0:10:28.19,0:10:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Aida.
Dialogue: 0,0:10:31.03,0:10:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Pangeran Placido\Ndan Pangeran Renato juga.
Dialogue: 0,0:10:34.86,0:10:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan membiarkan siapa pun\Nmenyakiti mereka.
Dialogue: 0,0:10:45.08,0:10:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tak perlu sekaku itu.
Dialogue: 0,0:10:47.67,0:10:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya pesta malam.
Dialogue: 0,0:10:49.09,0:10:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup berdansa dengan semangat!
Dialogue: 0,0:10:52.13,0:10:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah dansa penuh cinta kami!
Dialogue: 0,0:10:54.88,0:10:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:10:56.47,0:10:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:10:57.39,0:10:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih yang mana, ya?
Dialogue: 0,0:11:00.35,0:11:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih saja yang itu!
Dialogue: 0,0:11:03.68,0:11:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:11:15.45,0:11:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, aku suka sifat jujurmu.
Dialogue: 0,0:11:19.37,0:11:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktif, ceria,
Dialogue: 0,0:11:21.12,0:11:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mampu membuat orang\Ndi sekelilingmu tersenyum.
Dialogue: 0,0:11:24.58,0:11:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tolong jangan bersedih dan murung\Nkarena hal yang membosankan.
Dialogue: 0,0:11:31.92,0:11:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku mengerti.
Dialogue: 0,0:11:33.84,0:11:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, giliran Mimi.
Dialogue: 0,0:11:35.80,0:11:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:39.93,0:11:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:11:41.35,0:11:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku minum teh bersama\NBaginda Ratu di taman ini...
Dialogue: 0,0:11:45.43,0:11:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Ratu, bahaya!
Dialogue: 0,0:11:48.69,0:11:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, saat itu Mimi benar-benar keren.
Dialogue: 0,0:11:52.32,0:11:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu!\NPelakunya sudah tertangkap?
Dialogue: 0,0:11:55.32,0:11:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:11:57.11,0:11:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa penyelidikannya lancar?
Dialogue: 0,0:11:58.53,0:12:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah, kalau ada kemajuan,\Nmereka pasti melapor.
Dialogue: 0,0:12:02.24,0:12:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baginda Ratu memang hebat.\N- Nah, Aida.
Dialogue: 0,0:12:03.99,0:12:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia tak gentar oleh apa pun,\N- Sekarang giliranmu.
Dialogue: 0,0:12:05.58,0:12:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau lebih tepatnya terlalu santai!
Dialogue: 0,0:12:07.83,0:12:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak apa-apa kita bertemu\Ndi tempat terbuka seperti ini?
Dialogue: 0,0:12:11.63,0:12:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:12:13.30,0:12:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menugaskan pengawal.\NKarena Renato sudah diam-diam
Dialogue: 0,0:12:16.42,0:12:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawal?
Dialogue: 0,0:12:19.47,0:12:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya veteran, ya.
Dialogue: 0,0:12:21.93,0:12:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan, kan?
Dialogue: 0,0:12:23.26,0:12:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renato benar-benar pria\Nyang mudah cemas, kan?
Dialogue: 0,0:12:25.60,0:12:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sepertinya dia lebih\Nmencemaskanmu daripada aku.
Dialogue: 0,0:12:29.31,0:12:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NMana mungkin.
Dialogue: 0,0:12:31.61,0:12:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, tak ada orang mencurigakan\Nyang bisa mendekati kita.
Dialogue: 0,0:12:36.03,0:12:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tenang saja.
Dialogue: 0,0:12:37.57,0:12:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:38.24,0:12:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:12:39.41,0:12:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Mimi, Aida, dan Baginda Ratu juga.
Dialogue: 0,0:12:42.70,0:12:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa?\NKumpul-kumpul?
Dialogue: 0,0:12:45.16,0:12:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada orang\Npaling mencurigakan di ibu kota.
Dialogue: 0,0:12:48.33,0:12:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya aku?
Dialogue: 0,0:12:49.92,0:12:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian salah paham.
Dialogue: 0,0:12:51.29,0:12:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada orang yang paling\Nmudah ditebak selain aku.
Dialogue: 0,0:12:54.00,0:12:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang pencari cinta,\Nbangsawan lajang yang memesona!
Dialogue: 0,0:12:57.05,0:12:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kumpul?\NJelas boleh!
Dialogue: 0,0:13:00.18,0:13:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Ireneo.\NDuduk di sana.
Dialogue: 0,0:13:02.76,0:13:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ratu, ada kerut di sini.\NSenyum, senyum.
Dialogue: 0,0:13:06.14,0:13:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbicara tentang kerut, wajah Raimondo\Nmulai berkerut karena perbuatanmu.
Dialogue: 0,0:13:10.73,0:13:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raimondo?\NAh, asisten Renato, ya.
Dialogue: 0,0:13:14.27,0:13:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa wajahnya ada kerutan?
Dialogue: 0,0:13:15.40,0:13:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu ingkar janji,\Ntidak membalas surat...
Dialogue: 0,0:13:19.49,0:13:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada beberapa putri bangsawan\N- Maaf, saya benar-benar minta maaf!
Dialogue: 0,0:13:21.99,0:13:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- yang jatuh sakit karena syok.\N- Maaf, saya benar-benar minta maaf!
Dialogue: 0,0:13:23.53,0:13:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarganya menagih kompensasi.
Dialogue: 0,0:13:25.03,0:13:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bohong!\NAku tidak ingkar janji...
Dialogue: 0,0:13:28.87,0:13:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pernah kalau lupa.
Dialogue: 0,0:13:31.79,0:13:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi... Asisten putra mahkota\Ntidak perlu sampai minta maaf...
Dialogue: 0,0:13:37.50,0:13:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada bahas itu, bagaimana kalau\Nkita mengobrol yang lebih seru?
Dialogue: 0,0:13:41.22,0:13:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, benar juga!
Dialogue: 0,0:13:42.30,0:13:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida, selamat atas pertunanganmu.
Dialogue: 0,0:13:45.01,0:13:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:47.56,0:13:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.\NKarena Placido hanya mencintaimu.
Dialogue: 0,0:13:53.73,0:13:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia sangat bahagia.
Dialogue: 0,0:13:56.32,0:14:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Tuan Ireneo juga sadar\Nsoal Aida dan mendukungnya...
Dialogue: 0,0:14:00.82,0:14:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga, dia bukan orang jahat...
Dialogue: 0,0:14:04.41,0:14:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Mimi?
Dialogue: 0,0:14:05.78,0:14:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cemburu karena aku bicara\Ndengan perempuan lain...
Dialogue: 0,0:14:10.79,0:14:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa?
Dialogue: 0,0:14:12.00,0:14:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NSama sekali tidak!
Dialogue: 0,0:14:13.71,0:14:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang tak bisa dipercaya!
Dialogue: 0,0:14:15.71,0:14:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Sudah, sudah...
Dialogue: 0,0:14:18.30,0:14:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa
Dialogue: 0,0:14:19.30,0:14:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menemanimu
Dialogue: 0,0:14:20.30,0:14:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}latihan dansa!
Dialogue: 0,0:14:21.47,0:14:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terima kasih!
Dialogue: 0,0:14:24.55,0:14:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Aida?
Dialogue: 0,0:14:25.76,0:14:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menolak untuk hari ini dan selamanya.
Dialogue: 0,0:14:29.31,0:14:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ketus sekali.
Dialogue: 0,0:14:31.27,0:14:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya, aku paham.\NAcara khusus wanita, kan?
Dialogue: 0,0:14:34.39,0:14:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pria, aku undur diri saja.
Dialogue: 0,0:14:39.07,0:14:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak satu itu ada-ada saja.
Dialogue: 0,0:14:42.19,0:14:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluyuran seperti pengembara tanpa tujuan,
Dialogue: 0,0:14:43.95,0:14:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}muncul dan pergi tiba-tiba\Ndi berbagai tempat.
Dialogue: 0,0:14:46.74,0:14:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin orang pusing saja.
Dialogue: 0,0:14:49.08,0:14:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dulu dia tidak seperti itu.
Dialogue: 0,0:14:52.04,0:14:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?
Dialogue: 0,0:14:54.12,0:14:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya tariknya memang bawaan lahir.
Dialogue: 0,0:14:56.79,0:15:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disukai semua orang,\Nprestasinya pun tidak buruk-buruk amat.
Dialogue: 0,0:15:00.63,0:15:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada menteri yang memujinya\Ndengan sebutan anak yang cerdas.
Dialogue: 0,0:15:04.84,0:15:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya karena dia\Ncengar-cengir saja sekarang.
Dialogue: 0,0:15:08.01,0:15:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:15:08.93,0:15:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya dia dielu-elukan\Nsebagai calon putra mahkota,
Dialogue: 0,0:15:12.27,0:15:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi posisi itu tiba-tiba dirampas.
Dialogue: 0,0:15:14.69,0:15:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memaklumi karena paham\Nkalau dia pasti tersakiti,
Dialogue: 0,0:15:18.90,0:15:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ternyata itu\Nbukan keputusan yang bijak.
Dialogue: 0,0:15:22.57,0:15:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra mahkota?
Dialogue: 0,0:15:24.82,0:15:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tak kunjung\Ndikaruniai keturunan...
Dialogue: 0,0:15:27.99,0:15:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pun berkata bahwa Ireneo\Npantas menjadi putra mahkota.
Dialogue: 0,0:15:31.66,0:15:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu semacam konflik\Nperebutan kekuasaan keluarga?
Dialogue: 0,0:15:35.12,0:15:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang para pelayan pun ikut terseret\Ndan jadi keributan besar...
Dialogue: 0,0:15:38.04,0:15:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, ayahku juga sempat terseret\Ndan membuatnya kebingungan.
Dialogue: 0,0:15:42.17,0:15:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, pada akhirnya dia tidak resmi\Nmenjadi putra mahkota, kan?
Dialogue: 0,0:15:46.38,0:15:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa semua orang begitu terburu-buru?
Dialogue: 0,0:15:49.26,0:15:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bangsawan yang memikirkan keuntungan\Npribadi sampai melupakan kewajibannya.
Dialogue: 0,0:15:54.47,0:15:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Ternyata Tuan Ireneo\Npunya masalahnya sendiri.
Dialogue: 0,0:16:00.73,0:16:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan topik yang sesuai\Nuntuk kumpul-kumpul seru.
Dialogue: 0,0:16:04.03,0:16:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari ganti suasananya.\NMau minum teh?
Dialogue: 0,0:16:06.95,0:16:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu!
Dialogue: 0,0:16:19.79,0:16:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini yang orang-orang\Nsebut pemandangan indah!
Dialogue: 0,0:16:26.76,0:16:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kompak sekali, ya.
Dialogue: 0,0:16:29.05,0:16:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida dan Pangeran Placido.
Dialogue: 0,0:16:30.72,0:16:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Mimi.
Dialogue: 0,0:16:32.35,0:16:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan pengalamanku\Nmendampingi Aida selama bertahun-tahun...
Dialogue: 0,0:16:35.77,0:16:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda.
Dialogue: 0,0:16:36.64,0:16:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempurna.
Dialogue: 0,0:16:37.98,0:16:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,\Nrasanya malu kalau dilihat Mimi.
Dialogue: 0,0:16:41.15,0:16:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu.
Dialogue: 0,0:16:42.94,0:16:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga demi pesta malam!
Dialogue: 0,0:16:44.52,0:16:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang bilang akan melatihku, kan?
Dialogue: 0,0:16:47.24,0:16:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ada benarnya...
Dialogue: 0,0:16:48.65,0:16:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berdansa dengan sangat indah.
Dialogue: 0,0:16:51.32,0:16:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menikmati dansa bersamamu.
Dialogue: 0,0:16:53.37,0:16:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh...\NPangeran Placido ini...
Dialogue: 0,0:16:56.16,0:17:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur mereka berdua bisa menikah.
Dialogue: 0,0:17:00.12,0:17:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena atmosfer di sekeliling Aida\Ndan Pangeran Placido
Dialogue: 0,0:17:04.67,0:17:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat lembut dan bahagia.
Dialogue: 0,0:17:08.30,0:17:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria, Yang Mulia Renato\Nagak terlambat karena pekerjaan.
Dialogue: 0,0:17:13.22,0:17:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon revisi lagi gerakan langkahnya.
Dialogue: 0,0:17:15.89,0:17:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap, Pak Raimondo!
Dialogue: 0,0:17:20.94,0:17:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria.
Dialogue: 0,0:17:22.59,0:17:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi ada kesempatan, bolehkah aku\Nmenemanimu hingga Kakak datang?
Dialogue: 0,0:17:27.60,0:17:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Boleh?
Dialogue: 0,0:17:29.61,0:17:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:17:30.53,0:17:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu membantumu.
Dialogue: 0,0:17:32.49,0:17:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mohon bantuannya.
Dialogue: 0,0:17:41.71,0:17:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingat saat pesta taman waktu itu.
Dialogue: 0,0:17:44.63,0:17:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran masih ingat?
Dialogue: 0,0:17:47.13,0:17:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku lupa.
Dialogue: 0,0:17:49.13,0:17:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, gerakanmu sangat mena—
Dialogue: 0,0:17:52.26,0:17:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, sangat kreatif.
Dialogue: 0,0:17:54.89,0:17:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:17:56.72,0:17:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida juga mengatakan hal serupa.
Dialogue: 0,0:17:59.27,0:18:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat latihan keras Aida,
Dialogue: 0,0:18:01.85,0:18:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya aku mulai terbiasa\Nberdansa ala Kerajaan Rubini!
Dialogue: 0,0:18:06.44,0:18:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:07.52,0:18:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih jauh, Mimi.
Dialogue: 0,0:18:11.15,0:18:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis bangsawan lain\Ntak akan bisa meniru gerakan Mimi, ya.
Dialogue: 0,0:18:14.95,0:18:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tubuhku bergerak sendiri\Nsaat menikmati dansanya.
Dialogue: 0,0:18:20.45,0:18:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon lebih anggun saat dansa pertama nanti.
Dialogue: 0,0:18:27.29,0:18:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato!
Dialogue: 0,0:18:28.75,0:18:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:18:30.59,0:18:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana latihannya?
Dialogue: 0,0:18:32.47,0:18:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang masih di pertengahan.
Dialogue: 0,0:18:34.93,0:18:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilainya rendah banget!
Dialogue: 0,0:18:37.47,0:18:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nkita tak boleh buang-buang waktu lagi.
Dialogue: 0,0:18:40.22,0:18:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku juga ikut belajar\Ncara mendampingimu?
Dialogue: 0,0:18:48.23,0:18:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:18:54.49,0:18:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat cemas saat melihatnya\Nberdansa dengan Yang Mulia Placido,
Dialogue: 0,0:18:59.20,0:19:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau pasangannya Yang Mulia Renato,\Najaibnya dia terlihat lebih baik.
Dialogue: 0,0:19:02.83,0:19:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena Pangeran\Npandai menghadapi Mimi.
Dialogue: 0,0:19:06.00,0:19:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua kelihatan hebat.
Dialogue: 0,0:19:07.54,0:19:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini,\Ndansa pertama akan aman.
Dialogue: 0,0:19:13.55,0:19:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Capeknya.
Dialogue: 0,0:19:15.71,0:19:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku dapat pengetahuan baru.
Dialogue: 0,0:19:18.14,0:19:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengetahuan?
Dialogue: 0,0:19:19.22,0:19:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengira gadis bangsawan itu\Norang-orang yang lemah,
Dialogue: 0,0:19:23.02,0:19:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata mereka berlatih macam-macam\Ndemi terlihat anggun.
Dialogue: 0,0:19:26.27,0:19:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida bisa terlihat biasa saja\Nsetelah berdansa berjam-jam.
Dialogue: 0,0:19:29.36,0:19:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus berlatih lebih banyak!
Dialogue: 0,0:19:31.86,0:19:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena otot yang dipakai\Nsaat bela diri dan dansa berbeda.
Dialogue: 0,0:19:34.99,0:19:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:19:36.91,0:19:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga belajar banyak hal\Nsejak bertemu Mimi.
Dialogue: 0,0:19:40.37,0:19:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya Nomor 38?\NGerakan Pangeran sangat keren!
Dialogue: 0,0:19:43.87,0:19:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:19:46.33,0:19:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran.
Dialogue: 0,0:19:47.75,0:19:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh bertanya sesuatu?
Dialogue: 0,0:19:52.25,0:19:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai Tuan Ireneo.
Dialogue: 0,0:19:55.88,0:19:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa benar dia pernah menjadi\Ncalon putra mahkota?
Dialogue: 0,0:20:00.47,0:20:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:02.01,0:20:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bukan secara resmi...
Dialogue: 0,0:20:05.52,0:20:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang dewasa yang coba memperalat\NIreneo yang masih kecil.
Dialogue: 0,0:20:12.27,0:20:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar setelah aku dan Placido lahir,
Dialogue: 0,0:20:14.11,0:20:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka yang tadinya menyanjung\NIreneo langsung berpaling pergi.
Dialogue: 0,0:20:19.61,0:20:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya kami dilindungi kedua orang tua.
Dialogue: 0,0:20:23.41,0:20:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kejadian itu yang membuatnya\Nmenjadi seperti sekarang?
Dialogue: 0,0:20:28.33,0:20:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski benar seperti itu,\Nsemuanya cerita lama.
Dialogue: 0,0:20:31.21,0:20:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang mewarisi darah keluarga kerajaan,\Nharus menjadi contoh rakyatnya.
Dialogue: 0,0:20:35.55,0:20:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Raimondo tak bisa\Nterus-menerus membereskan masalahnya.
Dialogue: 0,0:20:40.80,0:20:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kamu penasaran soal Ireneo?
Dialogue: 0,0:20:43.81,0:20:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, begitulah.
Dialogue: 0,0:20:45.06,0:20:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan.
Dialogue: 0,0:20:47.93,0:20:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dekati Ireneo.
Dialogue: 0,0:20:54.07,0:20:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.\NAku salah ucap.
Dialogue: 0,0:20:56.53,0:20:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar seperti ini...
Dialogue: 0,0:20:58.61,0:21:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu mencemaskan Ireneo,\Naku jadi cemburu.
Dialogue: 0,0:21:06.62,0:21:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ireneo tidak akan mengabaikanmu\Nmeski satu menit pun,
Dialogue: 0,0:21:10.62,0:21:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia juga terbiasa menemani perempuan.
Dialogue: 0,0:21:12.92,0:21:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melakukan semua itu.\NJadi, saat terpikir...
Dialogue: 0,0:21:16.96,0:21:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato.
Dialogue: 0,0:21:19.63,0:21:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kamu ini?
Dialogue: 0,0:21:22.97,0:21:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya Pangeran\Nyang bisa menjadi rekan dansaku.
Dialogue: 0,0:21:26.31,0:21:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberikan dansa pertama terbaik\Nyang pernah ada!
Dialogue: 0,0:21:33.73,0:21:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.\NAku akan berusaha.
Dialogue: 0,0:21:38.99,0:21:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan.
Dialogue: 0,0:21:40.78,0:21:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja semua berhasil hari itu...
Dialogue: 0,0:21:43.37,0:21:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal semuanya sudah sempurna.
Dialogue: 0,0:21:45.12,0:21:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa kuampuni.\NPokoknya tak akan kuampuni.
Dialogue: 0,0:21:49.41,0:21:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat kamu menyesal.
Dialogue: 0,0:21:51.83,0:21:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja nanti.
Dialogue: 0,0:23:26.93,0:23:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan beri tahu\Nrekomendasi latihanku, ya.
Dialogue: 0,0:23:29.05,0:23:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, squat 100 kali\Nsambil gendong siswa lain...
Dialogue: 0,0:23:31.81,0:23:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tak ada siswa yang bisa digendong?
Dialogue: 0,0:23:33.39,0:23:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat seperti itu,\Nminta tolong orang di sekitar!
Dialogue: 0,0:23:35.53,0:23:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga waktu itu minta Tuan Raimondo...
Dialogue: 0,0:23:37.65,0:23:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku keceplosan lagi!
