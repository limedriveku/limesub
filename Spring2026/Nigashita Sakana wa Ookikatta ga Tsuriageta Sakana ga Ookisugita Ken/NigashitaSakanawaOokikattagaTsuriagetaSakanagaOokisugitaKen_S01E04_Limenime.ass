Dialogue: 0,0:00:15.12,0:00:17.12,tanda,,0000,0000,0000,,BUK, BUK, BUK, BUK
Dialogue: 0,0:00:37.93,0:00:41.68,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:00:41.68,0:00:45.53,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP MALAH TERLALU BESAR
Dialogue: 0,0:01:55.01,0:02:00.02,tanda,,0000,0000,0000,,EPISODE 4:\NIKAN YANG TERLEPAS DIBUAT GALAU
Dialogue: 0,0:03:06.42,0:03:10.42,tanda,,0000,0000,0000,,HAH!
Dialogue: 0,0:03:30.90,0:03:31.32,tanda,,0000,0000,0000,,SET
Dialogue: 0,0:05:31.73,0:05:32.73,tanda,,0000,0000,0000,,YA, YA
Dialogue: 0,0:06:00.34,0:06:01.05,tanda,,0000,0000,0000,,APA?
Dialogue: 0,0:06:01.97,0:06:04.59,tanda,,0000,0000,0000,,TERSERET
Dialogue: 0,0:06:20.28,0:06:20.94,tanda,,0000,0000,0000,,KOMANDAN KESATRIA
Dialogue: 0,0:06:50.97,0:06:53.85,tanda,,0000,0000,0000,,KOMANDAN KESATRIA
Dialogue: 0,0:07:41.23,0:07:41.94,tanda,,0000,0000,0000,,GYUT, GYUT
Dialogue: 0,0:07:50.45,0:07:51.49,tanda,,0000,0000,0000,,HA
Dialogue: 0,0:08:36.58,0:08:37.83,tanda,,0000,0000,0000,,BRAK!
Dialogue: 0,0:10:44.08,0:10:48.09,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:10:48.09,0:10:52.09,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP MALAH TERLALU BESAR
Dialogue: 0,0:15:53.18,0:15:54.43,tanda,,0000,0000,0000,,30.
Dialogue: 0,0:15:54.43,0:15:57.69,tanda,,0000,0000,0000,,31, 32, 33...
Dialogue: 0,0:15:57.69,0:16:01.36,tanda,,0000,0000,0000,,34, 35, 36...
Dialogue: 0,0:16:01.36,0:16:02.94,tanda,,0000,0000,0000,,37...
Dialogue: 0,0:16:03.28,0:16:05.40,tanda,,0000,0000,0000,,38!
Dialogue: 0,0:16:24.50,0:16:25.38,tanda,,0000,0000,0000,,TRING!
Dialogue: 0,0:16:56.41,0:16:58.08,tanda,,0000,0000,0000,,PAMER
Dialogue: 0,0:17:06.21,0:17:07.33,tanda,,0000,0000,0000,,MALU-MALU
Dialogue: 0,0:20:20.20,0:20:22.25,tanda,,0000,0000,0000,,SERIUS
Dialogue: 0,0:20:47.14,0:20:47.96,tanda,,0000,0000,0000,,NYUT, NYUT
Dialogue: 0,0:23:36.02,0:23:37.44,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA:
Dialogue: 0,0:23:37.44,0:23:39.72,tanda,,0000,0000,0000,,IKAN LEPAS PULANG KAMPUNG
Dialogue: 0,0:00:02.77,0:00:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baginda Ratu, bahaya!\N- Saat menghadiri acara minum teh Ratu,
Dialogue: 0,0:00:06.24,0:00:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tiba-tiba diserang dengan anak panah.
Dialogue: 0,0:00:08.86,0:00:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi keren banget!
Dialogue: 0,0:00:11.89,0:00:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka!
Dialogue: 0,0:00:13.12,0:00:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, Baginda Ratu tak membenciku.
Dialogue: 0,0:00:20.00,0:00:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia lebih menarik dari dugaanku.
Dialogue: 0,0:00:23.60,0:00:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:02:00.02,0:02:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan biarkan dia kabur!\N- Cepat amankan wilayah sekitar!
Dialogue: 0,0:02:03.02,0:02:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:02:04.03,0:02:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelakunya kabur ke luar istana!
Dialogue: 0,0:02:05.69,0:02:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan dia lolos!
Dialogue: 0,0:02:08.97,0:02:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:02:10.99,0:02:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku titip Baginda Ratu, ya!
Dialogue: 0,0:02:14.26,0:02:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:02:15.99,0:02:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:02:22.17,0:02:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini makaron rekomendasi Baginda Ratu.
Dialogue: 0,0:02:26.28,0:02:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kutinju pelakunya\Nsebanyak kudapan yang hancur!
Dialogue: 0,0:02:30.61,0:02:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria!
Dialogue: 0,0:02:32.38,0:02:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami yang bersihkan semuanya.
Dialogue: 0,0:02:35.13,0:02:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari masuk ke istana.
Dialogue: 0,0:02:36.72,0:02:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Pangeran pasti\Nmengkhawatirkan Anda.
Dialogue: 0,0:02:38.89,0:02:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu?
Dialogue: 0,0:02:40.85,0:02:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saya panggilkan kesatria.
Dialogue: 0,0:02:43.14,0:02:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tapi...
Dialogue: 0,0:02:48.80,0:02:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:02:50.15,0:02:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa pergi sendiri.
Dialogue: 0,0:02:53.28,0:02:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria!
Dialogue: 0,0:02:55.53,0:02:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau cepat sekali.
Dialogue: 0,0:02:57.66,0:02:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, kalian baik-baik saja?
Dialogue: 0,0:02:59.28,0:03:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Raimondo!
Dialogue: 0,0:03:01.54,0:03:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf,
Dialogue: 0,0:03:03.00,0:03:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria pergi menghampiri\NPangeran seorang diri.
Dialogue: 0,0:03:06.42,0:03:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia baru saja diserang!
Dialogue: 0,0:03:08.32,0:03:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami benar-benar minta maaf!
Dialogue: 0,0:03:10.42,0:03:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pergi mencarinya.
Dialogue: 0,0:03:12.00,0:03:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong urus sisanya.
Dialogue: 0,0:03:18.55,0:03:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jalan yang benar, kan?
Dialogue: 0,0:03:20.68,0:03:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar.
Dialogue: 0,0:03:22.01,0:03:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:23.28,0:03:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku, aku baru lewat jalan ini.
Dialogue: 0,0:03:25.73,0:03:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku harus belok kanan\Ndi persimpangan tadi.
Dialogue: 0,0:03:28.23,0:03:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:03:29.23,0:03:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:03:31.73,0:03:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu berhasil menghindar.
Dialogue: 0,0:03:33.73,0:03:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam sejahtera, Tuan Ireneo.
Dialogue: 0,0:03:36.15,0:03:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, selamat tinggal.
Dialogue: 0,0:03:38.28,0:03:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, halo lagi.
Dialogue: 0,0:03:41.91,0:03:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ketus sekali, ya.
Dialogue: 0,0:03:43.24,0:03:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita baru bertemu lagi.
Dialogue: 0,0:03:44.77,0:03:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini...
Dialogue: 0,0:03:47.00,0:03:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ireneo dari keluarga Marquess Marchei\Nadalah sepupu Pangeran Renato.
Dialogue: 0,0:03:51.84,0:03:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau memang bukan musuh Pangeran,
Dialogue: 0,0:03:55.21,0:03:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi musuh bagi semua wanita.
Dialogue: 0,0:03:58.43,0:04:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski wajahnya awet muda,
Dialogue: 0,0:04:00.35,0:04:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}usianya sudah awal 30-an.
Dialogue: 0,0:04:03.06,0:04:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Aida saja bilang begitu,\Npria ini benar-benar genit.
Dialogue: 0,0:04:06.85,0:04:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus hati-hati.
Dialogue: 0,0:04:08.27,0:04:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.\NAku melihat aksimu tadi.
Dialogue: 0,0:04:15.09,0:04:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:04:16.95,0:04:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pujian, tahu.
Dialogue: 0,0:04:18.72,0:04:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Mimi benar-benar menarik.
Dialogue: 0,0:04:21.08,0:04:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai jatuh cinta lagi.
Dialogue: 0,0:04:22.45,0:04:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ireneo selalu bilang begitu.
Dialogue: 0,0:04:25.49,0:04:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak jaga sikap,\Nnanti dimarahi Pangeran Renato lagi.
Dialogue: 0,0:04:29.17,0:04:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renato terlalu kaku, ya.
Dialogue: 0,0:04:31.66,0:04:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tidak berniat merebutmu.
Dialogue: 0,0:04:39.49,0:04:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja aku yang lebih dulu\Nbertemu denganmu.
Dialogue: 0,0:04:43.77,0:04:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kamu menaksirku, kan?
Dialogue: 0,0:04:48.50,0:04:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak mungkin!
Dialogue: 0,0:04:50.23,0:04:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, soalnya kelihatan.
Dialogue: 0,0:04:57.90,0:05:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kamu bisa teleportasi, ya?
Dialogue: 0,0:05:00.28,0:05:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, Tuan pasti bercanda.
Dialogue: 0,0:05:02.78,0:05:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ireneo!
Dialogue: 0,0:05:06.37,0:05:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diteruskan, saya terpaksa\Nharus lapor ke Yang Mulia.
Dialogue: 0,0:05:10.71,0:05:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sarankan Anda berhenti di sini.
Dialogue: 0,0:05:15.55,0:05:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jemputanmu sudah datang, ya.
Dialogue: 0,0:05:17.44,0:05:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat, aku pulang saja.
Dialogue: 0,0:05:19.55,0:05:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, kamu tahu toko kue baru di ibu kota?
Dialogue: 0,0:05:25.05,0:05:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya kue tar persik di sana enak.
Dialogue: 0,0:05:27.39,0:05:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan-kapan, mari kencan ke sana.
Dialogue: 0,0:05:29.98,0:05:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diajari untuk tak ikut orang asing!
Dialogue: 0,0:05:36.47,0:05:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja Tuan Ireneo\Ntidak terlalu genit pada wanita.
Dialogue: 0,0:05:39.92,0:05:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju.
Dialogue: 0,0:05:41.43,0:05:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria.
Dialogue: 0,0:05:42.49,0:05:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik.
Dialogue: 0,0:05:43.89,0:05:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menjadi tunangan Putra Mahkota,\Nbanyak orang yang akan mendekatimu.
Dialogue: 0,0:05:47.83,0:05:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau di dalam istana,\Nmohon waspada saat sendirian.
Dialogue: 0,0:05:51.41,0:05:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:05:53.17,0:05:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau orangnya memaksa,\Ntinggal pukul ulu hatinya.
Dialogue: 0,0:05:56.90,0:05:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kamu ini?
Dialogue: 0,0:05:58.63,0:06:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak boleh!
Dialogue: 0,0:06:01.05,0:06:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:06:01.97,0:06:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga sama merepotkannya.
Dialogue: 0,0:06:05.34,0:06:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku yang menyadari keberadaan pelaku
Dialogue: 0,0:06:07.51,0:06:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}segera menendang meja.
Dialogue: 0,0:06:09.43,0:06:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bunyi jleb,\Ndan dua anak panah pun menancap!
Dialogue: 0,0:06:11.52,0:06:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking terkejutnya, bahu rapuh\NBaginda Ratu gemetar ketakutan.
Dialogue: 0,0:06:15.73,0:06:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku mencari posisi pelakunya,\Nternyata dia sudah tidak ada.
Dialogue: 0,0:06:20.94,0:06:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makaron aneka warna terbang di udara,
Dialogue: 0,0:06:23.82,0:06:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu berserakan mengenaskan di atas rumput.
Dialogue: 0,0:06:26.03,0:06:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mubazir sekali!
Dialogue: 0,0:06:30.31,0:06:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru lihat Yang Mulia\Ntertawa seperti itu.
Dialogue: 0,0:06:33.46,0:06:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian cerita dariku.
Dialogue: 0,0:06:37.13,0:06:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritanya benar-benar menegangkan.
Dialogue: 0,0:06:39.13,0:06:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian belum menemukan\Npetunjuk soal pelaku?
Dialogue: 0,0:06:42.88,0:06:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kami masih menyelidiki.
Dialogue: 0,0:06:45.60,0:06:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa serangan ini mengincar Baginda Ratu.
Dialogue: 0,0:06:48.39,0:06:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi cukup sulit\Nkarena ada beberapa kejanggalan.
Dialogue: 0,0:06:50.97,0:06:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjutkan penyelidikannya.
Dialogue: 0,0:06:53.00,0:06:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:06:53.85,0:06:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, saat dengar ceritamu tadi,
Dialogue: 0,0:06:56.35,0:06:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemampuan atletis dan gerakanmu...
Dialogue: 0,0:06:59.23,0:07:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bergabunglah\Nke pasukan kesatria kami!
Dialogue: 0,0:07:01.88,0:07:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:07:02.82,0:07:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, interogasinya selesai, kan?
Dialogue: 0,0:07:05.32,0:07:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak akan menyerah.\NTolong pikirkan sekali lagi!
Dialogue: 0,0:07:10.37,0:07:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, mereka ribut sekali.
Dialogue: 0,0:07:12.33,0:07:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa,\Nsemoga kesaksianku bisa membantu.
Dialogue: 0,0:07:16.50,0:07:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, aku lega kamu baik-baik saja.
Dialogue: 0,0:07:19.43,0:07:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran...
Dialogue: 0,0:07:20.59,0:07:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi kuucapkan,
Dialogue: 0,0:07:22.17,0:07:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terima kasih sudah melindungi ibuku.
Dialogue: 0,0:07:24.34,0:07:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak melakukan apa-apa.
Dialogue: 0,0:07:26.57,0:07:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang berapa kali,
Dialogue: 0,0:07:27.93,0:07:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua ini berkat meja istana yang kokoh.
Dialogue: 0,0:07:34.85,0:07:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu, Yang Mulia!
Dialogue: 0,0:07:37.76,0:07:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:07:41.94,0:07:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu betulan tidak terluka, kan?
Dialogue: 0,0:07:44.78,0:07:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir kamu tidak sadar kalau terluka.
Dialogue: 0,0:07:47.91,0:07:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Pangeran ini mudah cemas.
Dialogue: 0,0:07:51.49,0:07:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahaya pulang hari ini.\NMenginaplah di istana.
Dialogue: 0,0:07:54.72,0:07:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NTidak bisa.
Dialogue: 0,0:07:56.00,0:07:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak enak tiba-tiba\Nmenginap di rumahmu.
Dialogue: 0,0:07:58.62,0:08:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istana selalu siap menjamu tamu.
Dialogue: 0,0:08:02.00,0:08:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Mimi selalu diterima di sini.
Dialogue: 0,0:08:04.80,0:08:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Yang Mulia...
Dialogue: 0,0:08:06.13,0:08:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, sudut kaki Mimi
Dialogue: 0,0:08:08.36,0:08:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- saat menendang sangat sempurna.\N- Iya, aku tahu.
Dialogue: 0,0:08:10.01,0:08:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia benar-benar keren!\N- Aku paham.
Dialogue: 0,0:08:11.72,0:08:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Setelah itu, dia melakukan ini dan itu.\N- Dari laporan yang kuterima tadi,
Dialogue: 0,0:08:14.41,0:08:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pokoknya Mimi benar-benar hebat!\N- Baginda Ratu masih belum tenang...
Dialogue: 0,0:08:17.64,0:08:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey, Mimi!
Dialogue: 0,0:08:18.89,0:08:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, ini adalah hari\NTuan Ireneo menginap.
Dialogue: 0,0:08:21.48,0:08:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih aman\Nkalau Nona Maria pulang hari ini.
Dialogue: 0,0:08:25.19,0:08:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ada benarnya.
Dialogue: 0,0:08:27.05,0:08:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, Ibu juga ada-ada saja.
Dialogue: 0,0:08:30.89,0:08:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi pernah bilang kalau Ibu\Nmungkin membencimu, kan?
Dialogue: 0,0:08:35.08,0:08:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya Ibu sangat tertarik
Dialogue: 0,0:08:36.58,0:08:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan kepribadian dan ilmu bela dirimu.
Dialogue: 0,0:08:38.71,0:08:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, beliau menahan diri agar\Nantusiasmenya tidak terlihat.
Dialogue: 0,0:08:42.16,0:08:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alhasil, ekspresi yang muncul\Nmalah membuatmu takut.
Dialogue: 0,0:08:44.96,0:08:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata begitu.
Dialogue: 0,0:08:47.26,0:08:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong maafkan beliau.
Dialogue: 0,0:08:49.18,0:08:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:08:50.72,0:08:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang ingin akrab\Ndengan Baginda Ratu.
Dialogue: 0,0:08:55.93,0:08:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:08:57.07,0:09:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan pulang sebelum gelap.
Dialogue: 0,0:09:04.07,0:09:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku...
Dialogue: 0,0:09:07.93,0:09:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang karena bisa bertemu\NPangeran dua kali.
Dialogue: 0,0:09:12.78,0:09:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, sebaiknya kamu menginap saja.
Dialogue: 0,0:09:14.53,0:09:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapkan kereta kencana!
Dialogue: 0,0:09:15.59,0:09:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapkan juga lebih banyak pengawal!
Dialogue: 0,0:09:17.40,0:09:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:09:26.41,0:09:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan murung.
Dialogue: 0,0:09:28.09,0:09:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian belum resmi bertunangan.
Dialogue: 0,0:09:30.67,0:09:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:09:34.30,0:09:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Raimondo.
Dialogue: 0,0:09:36.11,0:09:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Mimi pulang ke rumahnya,
Dialogue: 0,0:09:38.67,0:09:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa dia akan pulang lewat jalur itu?
Dialogue: 0,0:09:41.13,0:09:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:42.06,0:09:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rute itu memang mengkhawatirkan.
Dialogue: 0,0:09:44.06,0:09:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kasus bandit gunung\Nsedang marak terjadi,
Dialogue: 0,0:09:48.28,0:09:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak ada jalur lain menuju Kerajaan Muro.
Dialogue: 0,0:09:51.86,0:09:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia baru saja diserang siang ini.
Dialogue: 0,0:09:55.37,0:09:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi Putri Mahkota memang berbahaya.
Dialogue: 0,0:09:58.37,0:10:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu.
Dialogue: 0,0:10:01.62,0:10:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja aku tidak melamarnya,\NMimi tak perlu mengalami semua ini.
Dialogue: 0,0:10:06.38,0:10:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai berpikir seperti itu.
Dialogue: 0,0:10:09.49,0:10:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memerintahkan penambahan pengawal\Ndi rumah keluarga Ametis serta akademi.
Dialogue: 0,0:10:13.68,0:10:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bisa tenang untuk saat ini.
Dialogue: 0,0:10:16.30,0:10:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:17.26,0:10:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ingatkan Nona Maria
Dialogue: 0,0:10:22.02,0:10:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk tak ikut campur urusan berbahaya.
Dialogue: 0,0:10:29.69,0:10:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, mohon berhati-hati.
Dialogue: 0,0:10:31.19,0:10:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawalannya makin ketat.
Dialogue: 0,0:10:33.70,0:10:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tidak enak hati.
Dialogue: 0,0:10:39.95,0:10:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh\Nmembuat Pangeran Renato khawatir.
Dialogue: 0,0:11:06.10,0:11:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengusir pembunuh bayaran itu,\Nkapan pun mereka datang.
Dialogue: 0,0:11:12.07,0:11:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu periksa keamanan sekitar.
Dialogue: 0,0:11:13.86,0:11:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini kurang kokoh\Nkalau dijadikan tameng.
Dialogue: 0,0:11:17.41,0:11:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Annovazzi!
Dialogue: 0,0:11:21.16,0:11:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keceplosan lagi!
Dialogue: 0,0:11:37.37,0:11:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu kepikiran kalau merasa\Nada yang menatapku.
Dialogue: 0,0:11:44.22,0:11:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara semuanya, Nona Rosalia\Nyang paling mudah dikenali.
Dialogue: 0,0:11:47.71,0:11:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, kamu duduk di sini.
Dialogue: 0,0:11:50.69,0:11:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kampung bisa duduk di mana saja, ya.
Dialogue: 0,0:11:53.82,0:11:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia, sketsamu sudah selesai?
Dialogue: 0,0:11:57.78,0:11:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:11:59.03,0:12:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menggambar bunga-bunga cantik\Ndi kebun botani.
Dialogue: 0,0:12:02.95,0:12:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba perlihatkan sketsamu.
Dialogue: 0,0:12:05.56,0:12:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:12:06.86,0:12:09.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu mahir sekali.
Dialogue: 0,0:12:09.37,0:12:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia anggota ekskul seni.
Dialogue: 0,0:12:11.43,0:12:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah menang kompetisi juga.
Dialogue: 0,0:12:13.50,0:12:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia, perlihatkan sketsamu juga.
Dialogue: 0,0:12:16.47,0:12:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak perlu.
Dialogue: 0,0:12:19.72,0:12:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, perlihatkan saja sketsamu.
Dialogue: 0,0:12:21.97,0:12:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum selesai.
Dialogue: 0,0:12:23.26,0:12:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kulihat.
Dialogue: 0,0:12:25.18,0:12:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini lukisan seni eksperimental, ya?
Dialogue: 0,0:12:37.48,0:12:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa aku merasakan
Dialogue: 0,0:12:39.20,0:12:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kegelisahan yang tak bisa dijelaskan\Nsaat melihat lukisan itu.
Dialogue: 0,0:12:42.49,0:12:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, waktunya kembali.
Dialogue: 0,0:12:45.24,0:12:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu pembalasanku, Maria Annovazzi!
Dialogue: 0,0:12:48.04,0:12:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph.
Dialogue: 0,0:12:49.25,0:12:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia.
Dialogue: 0,0:12:53.79,0:12:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia mengingat namaku dengan benar.
Dialogue: 0,0:13:00.76,0:13:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang apa di situ?
Dialogue: 0,0:13:03.16,0:13:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku mengagetkanmu, ya?
Dialogue: 0,0:13:05.26,0:13:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hawa kehadiran Tuan Ireneo\Nlebih mudah dikenali.
Dialogue: 0,0:13:08.53,0:13:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru sebaliknya.\NKamu payah bersembunyi.
Dialogue: 0,0:13:11.87,0:13:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, kenapa ada di akademi ini?
Dialogue: 0,0:13:14.36,0:13:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi di sini, aku ingin melihat-lihat.
Dialogue: 0,0:13:16.44,0:13:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku alumni akademi ini.
Dialogue: 0,0:13:18.78,0:13:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bilang begitu, tapi Tuan Ireneo\Nmengincar gadis-gadis muda, kan?
Dialogue: 0,0:13:23.99,0:13:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, saat ini aku hanya tertarik\Npada Mimi seorang.
Dialogue: 0,0:13:30.75,0:13:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, ini lukisanmu?
Dialogue: 0,0:13:33.16,0:13:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:35.63,0:13:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inovatif, ya.
Dialogue: 0,0:13:37.25,0:13:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karya seni selalu dimulai dengan hal baru.
Dialogue: 0,0:13:41.05,0:13:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aliran Barok atau Neoklasikisme.
Dialogue: 0,0:13:45.01,0:13:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang gadis yang menarik, ya.
Dialogue: 0,0:13:48.08,0:13:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ireneo suka lukisan, ya?
Dialogue: 0,0:13:51.00,0:13:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:51.81,0:13:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.\NAyo pergi ke museum seni nanti.
Dialogue: 0,0:13:58.65,0:13:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:59.99,0:14:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan, gesturmu barusan\Npersis dengan adikku, Teo.
Dialogue: 0,0:14:04.66,0:14:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku dan adikmu?
Dialogue: 0,0:14:06.74,0:14:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya aku imut?
Dialogue: 0,0:14:08.66,0:14:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Teo sangat imut!
Dialogue: 0,0:14:11.87,0:14:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ireneo!
Dialogue: 0,0:14:13.71,0:14:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sayang sekali.
Dialogue: 0,0:14:15.53,0:14:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus kembali.
Dialogue: 0,0:14:17.64,0:14:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Sampai nanti,
Dialogue: 0,0:14:18.80,0:14:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:14:22.19,0:14:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:14:23.43,0:14:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seusai kelas, kamu minum bersama\NBaginda Ratu dan Nona Aida.
Dialogue: 0,0:14:27.43,0:14:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu latihan di siang hari.
Dialogue: 0,0:14:29.31,0:14:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu sibuk setiap hari.
Dialogue: 0,0:14:34.44,0:14:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu begitu sibuk,
Dialogue: 0,0:14:37.65,0:14:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajar sampai ketiduran\Nsaat sedang berbicara denganku.
Dialogue: 0,0:14:42.44,0:14:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku tak akan bilang begitu!
Dialogue: 0,0:14:44.61,0:14:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:14:46.07,0:14:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, aku akan mendengarkan\Ndengan saksama.
Dialogue: 0,0:14:49.43,0:14:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat berterima kasih\Nkalian menambah pengawal,
Dialogue: 0,0:14:53.27,0:14:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi belakangan ini,\Naku lebih tegang dari biasanya.
Dialogue: 0,0:14:58.84,0:15:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:15:00.55,0:15:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bagian yang penting,\Ntolong dengarkan baik-baik.
Dialogue: 0,0:15:03.51,0:15:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, di jalur gunung\Nmenuju Kerajaan Muro
Dialogue: 0,0:15:06.22,0:15:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah menjadi area rawan bandit gunung...
Dialogue: 0,0:15:11.27,0:15:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria, hari keberangkatanmu itu besok!
Dialogue: 0,0:15:32.06,0:15:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakanmu tetap hebat seperti biasanya.
Dialogue: 0,0:15:35.08,0:15:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran.
Dialogue: 0,0:15:37.50,0:15:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini mau nomor berapa?
Dialogue: 0,0:15:39.52,0:15:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa, ya?
Dialogue: 0,0:15:40.69,0:15:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin 30-an.
Dialogue: 0,0:15:42.34,0:15:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:16:20.13,0:16:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daunnya sampai terbang ke sini.
Dialogue: 0,0:16:21.84,0:16:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor 38 sangat keren.
Dialogue: 0,0:16:24.50,0:16:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju!
Dialogue: 0,0:16:25.38,0:16:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga paling suka kuda-kuda ini.
Dialogue: 0,0:16:27.84,0:16:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuncinya adalah pijakan\Nke tanah harus mantap.
Dialogue: 0,0:16:30.97,0:16:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu saat memindahkan berat badan\Ndari kaki kanan ke kiri,
Dialogue: 0,0:16:34.06,0:16:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tumit kanan jangan menempel ke tanah.
Dialogue: 0,0:16:36.85,0:16:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu...
Dialogue: 0,0:16:37.98,0:16:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenangkan dirimu, Mimi.
Dialogue: 0,0:16:40.84,0:16:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku kelepasan karena Pangeran\Ntertarik dengan bela diri keluargaku.
Dialogue: 0,0:16:45.53,0:16:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara soal itu, kamu belum pernah\Nperlihatkan nomor 40-an dan 60-an.
Dialogue: 0,0:16:50.64,0:16:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, bahkan Pangeran pun tak boleh lihat.
Dialogue: 0,0:16:53.99,0:16:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya tak boleh diketahui\Norang luar perguruan.
Dialogue: 0,0:16:56.41,0:16:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di keluargaku saja,
Dialogue: 0,0:16:58.08,0:16:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya aku dan Ayah yang tahu.
Dialogue: 0,0:16:59.41,0:17:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, berarti di dunia ini hanya dua orang\Nyang menguasainya, ya.
Dialogue: 0,0:17:03.96,0:17:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya ilmu bela diri kompleks juga, ya.
Dialogue: 0,0:17:07.81,0:17:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau istirahat sebentar?
Dialogue: 0,0:17:11.97,0:17:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya kamu berjuang keras setiap hari.
Dialogue: 0,0:17:14.24,0:17:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidurmu nyenyak?
Dialogue: 0,0:17:16.56,0:17:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Tuan Raimondo lapor sesuatu padamu?
Dialogue: 0,0:17:20.15,0:17:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ketahuan diam-diam tidur, ya?
Dialogue: 0,0:17:22.59,0:17:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:17:24.01,0:17:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sibuk, tapi tak pernah bolos\Nlatihan pagi setiap hari.
Dialogue: 0,0:17:28.28,0:17:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya sangat berat.
Dialogue: 0,0:17:30.89,0:17:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran tak perlu cemas.
Dialogue: 0,0:17:32.95,0:17:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena keluargaku, keluarga Annovazzi,
Dialogue: 0,0:17:36.83,0:17:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah klan pengawal turun-temurun
Dialogue: 0,0:17:39.59,0:17:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keluarga Kerajaan Muro.
Dialogue: 0,0:17:43.17,0:17:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menjadi pewaris keluarga,
Dialogue: 0,0:17:44.79,0:17:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menerima pelatihan yang sama\Ndengan lelaki sejak kecil.
Dialogue: 0,0:17:49.80,0:17:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi saat kecil...
Dialogue: 0,0:17:52.09,0:17:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sangat aktif dan lucu.
Dialogue: 0,0:17:55.10,0:17:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak.
Dialogue: 0,0:17:56.61,0:18:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking aktifnya,\Naku sering dikira anak lelaki.
Dialogue: 0,0:18:01.00,0:18:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku sangat suka\Nmenggerakkan tubuhku
Dialogue: 0,0:18:05.22,0:18:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyibukkan diri dengan berlatih.
Dialogue: 0,0:18:08.88,0:18:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, suatu hari...
Dialogue: 0,0:18:28.25,0:18:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:18:29.17,0:18:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:18:30.99,0:18:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:18:35.51,0:18:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku belajar...
Dialogue: 0,0:18:37.85,0:18:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmu bela diri keluarga Annovazzi
Dialogue: 0,0:18:39.85,0:18:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada untuk melindungi orang yang kita sayang.
Dialogue: 0,0:18:47.47,0:18:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melindungi orang yang aku sayang.
Dialogue: 0,0:18:50.69,0:18:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mewujudkan itu,\Naku bisa berusaha sekeras apa pun.
Dialogue: 0,0:18:53.61,0:18:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan itu masih ada bahkan setelah\Nlepas dari posisi pewaris.
Dialogue: 0,0:18:57.75,0:19:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, menjalani latihan pagi, senam,\Ndan latihan lainnya setiap hari
Dialogue: 0,0:19:01.70,0:19:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak terasa berat bagiku.
Dialogue: 0,0:19:04.00,0:19:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kekuatan Mimi\Nturunan dari Tuan Duke.
Dialogue: 0,0:19:06.92,0:19:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:19:08.38,0:19:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:19:09.92,0:19:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil!\NDia resmi pewaris keluarga!
Dialogue: 0,0:19:13.92,0:19:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semenjak Teo lahir...
Dialogue: 0,0:19:20.56,0:19:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah terlihat sedikit sungkan padaku.
Dialogue: 0,0:19:30.61,0:19:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, waktunya latihan, Mimi!
Dialogue: 0,0:19:33.57,0:19:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku salah bicara!
Dialogue: 0,0:19:34.90,0:19:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teo... Mi-Mimi ada kelas\Nmenyusun bunga, kan?
Dialogue: 0,0:19:42.31,0:19:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang hubungan kami agak renggang.
Dialogue: 0,0:19:45.08,0:19:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sama sekali tidak keberatan.
Dialogue: 0,0:19:48.51,0:19:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi pasti bisa mengobrol\Ndengan ayahmu seperti dulu.
Dialogue: 0,0:19:54.84,0:19:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi lebih berani setelah dengar\NPangeran mengucapkan itu.
Dialogue: 0,0:19:59.29,0:20:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:20:02.10,0:20:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku pasti akan kesepian.
Dialogue: 0,0:20:05.65,0:20:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pangeran, bajumu kotor kena keringatku!
Dialogue: 0,0:20:09.12,0:20:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:20:10.36,0:20:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera pulang.
Dialogue: 0,0:20:12.44,0:20:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya menginap semalam.
Dialogue: 0,0:20:14.21,0:20:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, perjalanan pulang-perginya enam hari.
Dialogue: 0,0:20:17.05,0:20:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:20:18.74,0:20:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut Pangeran diserang
Dialogue: 0,0:20:20.20,0:20:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku tidak ada.
Dialogue: 0,0:20:22.25,0:20:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku yang bilang begitu.
Dialogue: 0,0:20:27.91,0:20:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, berhati-hatilah.
Dialogue: 0,0:20:30.54,0:20:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mencemaskanku.
Dialogue: 0,0:20:33.71,0:20:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tenang saja.
Dialogue: 0,0:20:35.86,0:20:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan bertindak nekat.
Dialogue: 0,0:20:38.18,0:20:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan baik-baik saja.
Dialogue: 0,0:20:40.25,0:20:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua pasti berjalan lancar.
Dialogue: 0,0:20:43.35,0:20:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu yang bilang,\Nrasanya bisa jadi kenyataan.
Dialogue: 0,0:20:47.96,0:20:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lebih tenang.\NTerima kasih.
Dialogue: 0,0:20:51.13,0:20:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak bisa mengantarmu.
Dialogue: 0,0:20:53.57,0:20:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titip salam untuk Nona Aida dan keluarganya.
Dialogue: 0,0:20:57.15,0:20:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran sangat manis saat tersenyum.
Dialogue: 0,0:20:59.61,0:21:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai dia lebih sering tersenyum\Ndi depan orang lain.
Dialogue: 0,0:21:03.74,0:21:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang bawaannya sudah semua?
Dialogue: 0,0:21:05.66,0:21:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:21:07.66,0:21:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, aku pinjam kereta kencananya, ya.
Dialogue: 0,0:21:10.33,0:21:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, titip salam untuk ayahmu.
Dialogue: 0,0:21:12.96,0:21:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, butuh dua hari\Nsampai perbatasan negara.
Dialogue: 0,0:21:15.63,0:21:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, nanti kereta kencana keluargaku\Nyang akan menjemput.
Dialogue: 0,0:21:19.17,0:21:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami janjian di desa terdekat,
Dialogue: 0,0:21:21.26,0:21:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan setelah itu, butuh sehari penuh.
Dialogue: 0,0:21:24.41,0:21:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Muro jauh, ya.
Dialogue: 0,0:21:27.06,0:21:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah terbiasa.
Dialogue: 0,0:21:29.40,0:21:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati di jalan, Mimi.
Dialogue: 0,0:21:31.81,0:21:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat jalan.
Dialogue: 0,0:21:32.85,0:21:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Aida.
Dialogue: 0,0:21:38.95,0:21:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu mencolok, ya.
Dialogue: 0,0:21:41.07,0:21:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:21:45.77,0:21:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat!
Dialogue: 0,0:21:52.00,0:21:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran, aku berangkat!
Dialogue: 0,0:23:26.93,0:23:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering ditegur saat menyanyikan ini.
Dialogue: 0,0:23:29.18,0:23:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena aku suka lagunya, ya?
Dialogue: 0,0:23:30.71,0:23:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka lagu yang ceria dan bikin semangat.
Dialogue: 0,0:23:33.43,0:23:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu nelayan menangkap ikan tuna besar\Nmemang terbaik!
Dialogue: 0,0:23:36.02,0:23:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan aku pernah naik...
Dialogue: 0,0:23:37.44,0:23:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, keceplosan lagi.
