Dialogue: 0,0:17:18.64,0:17:20.48,tanda,,0000,0000,0000,,MENYERAH
Dialogue: 0,0:17:24.98,0:17:26.65,tanda,,0000,0000,0000,,CUP, CUP, CUP, KEWALAHAN
Dialogue: 0,0:19:13.30,0:19:14.42,tanda,,0000,0000,0000,,TATAP
Dialogue: 0,0:19:32.40,0:19:33.69,tanda,,0000,0000,0000,,SET, SET, SET
Dialogue: 0,0:19:55.17,0:19:56.30,tanda,,0000,0000,0000,,BRAK!
