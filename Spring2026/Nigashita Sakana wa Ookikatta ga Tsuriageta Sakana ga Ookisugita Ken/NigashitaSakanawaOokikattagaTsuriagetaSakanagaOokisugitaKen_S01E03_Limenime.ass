Dialogue: 0,0:01:20.73,0:01:24.61,tanda,,0000,0000,0000,,IKAN YANG LEPAS DARI PANCINGKU MEMANG BESAR,
Dialogue: 0,0:01:24.61,0:01:28.48,tanda,,0000,0000,0000,,TAPI IKAN YANG KUTANGKAP MALAH TERLALU BESAR
Dialogue: 0,0:02:38.01,0:02:43.02,tanda,,0000,0000,0000,,EPISODE 3: LATIHAN SEBAGAI NONA BANGSAWAN\NIKAN YANG TERLEPAS
Dialogue: 0,0:03:04.12,0:03:05.25,tanda,,0000,0000,0000,,MONDAR-MANDIR
Dialogue: 0,0:04:04.68,0:04:06.93,tanda,,0000,0000,0000,,WUS!
Dialogue: 0,0:06:02.38,0:06:03.38,tanda,,0000,0000,0000,,HAHA!
Dialogue: 0,0:06:33.37,0:06:34.46,tanda,,0000,0000,0000,,HMPH
Dialogue: 0,0:07:04.57,0:07:05.32,tanda,,0000,0000,0000,,BERHENTI
