Dialogue: 0,0:23:37.10,0:23:39.67,tanda,,0000,0000,0000,,IKAN YANG TERLEPAS DIBUAT GALAU
Dialogue: 0,0:00:02.57,0:00:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar!
Dialogue: 0,0:00:03.15,0:00:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa disuruh pun aku akan keluar.
Dialogue: 0,0:00:06.82,0:00:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sungguh bodoh sampai tak sadar\Nsudah diculik, ya?
Dialogue: 0,0:00:13.58,0:00:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu!
Dialogue: 0,0:00:15.08,0:00:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua!
Dialogue: 0,0:00:17.06,0:00:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga, empat!
Dialogue: 0,0:00:18.33,0:00:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima!
Dialogue: 0,0:00:19.25,0:00:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam!
Dialogue: 0,0:00:20.29,0:00:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuh, delapan!
Dialogue: 0,0:00:21.75,0:00:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembilan!
Dialogue: 0,0:00:22.54,0:00:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan aku, si anak bungsu, dibesarkan\Nmenjadi pewaris keluarga Annovazzi...
Dialogue: 0,0:00:27.38,0:00:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan kakak-kakak perempuanku,\Nakulah yang terkuat!
Dialogue: 0,0:00:31.34,0:00:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh!
Dialogue: 0,0:00:38.13,0:00:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, gerakanmu tadi sangat hebat.
Dialogue: 0,0:00:41.19,0:00:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lihat semuanya!
Dialogue: 0,0:00:43.11,0:00:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berakhir sudah!
Dialogue: 0,0:00:44.09,0:00:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamat sudah kehidupan gadis bangsawanku!
Dialogue: 0,0:00:51.20,0:00:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti ketakutan.\NKasihan.
Dialogue: 0,0:00:55.67,0:01:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru sekali ini ada\Nyang mengatakan hal itu padaku.
Dialogue: 0,0:01:01.58,0:01:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:01:03.01,0:01:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikahlah denganku.
Dialogue: 0,0:01:06.86,0:01:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:48.48,0:02:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik sekali!
Dialogue: 0,0:02:50.97,0:02:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:02:52.94,0:02:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:53.82,0:02:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari sisi mana pun,\NAnda sangat menawan!
Dialogue: 0,0:02:56.20,0:02:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Raja dan Ratu\Npasti akan memuji Anda.
Dialogue: 0,0:03:00.87,0:03:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?\NAku gugup sekali!
Dialogue: 0,0:03:05.25,0:03:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semenjak itu, semuanya berjalan lancar.
Dialogue: 0,0:03:08.75,0:03:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baron Casciari dan Nona Eleonora
Dialogue: 0,0:03:11.28,0:03:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditahan atas tuduhan\Nmenerima suap serta penculikan.
Dialogue: 0,0:03:14.88,0:03:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelahnya, upacara pengukuhan\Nputra mahkota pun dilaksanakan,
Dialogue: 0,0:03:18.18,0:03:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Renato resmi menjadi putra mahkota.
Dialogue: 0,0:03:27.19,0:03:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai pertemuanmu dengan keluargaku...
Dialogue: 0,0:03:31.23,0:03:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga?
Dialogue: 0,0:03:33.26,0:03:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu anggota keluarga kerajaan, ya?
Dialogue: 0,0:03:36.15,0:03:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikut tanggal dan jamnya.
Dialogue: 0,0:03:38.41,0:03:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga sudah ditentukan?
Dialogue: 0,0:03:42.02,0:03:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang, hari ini adalah\Nhari pengesahan pertunanganku.
Dialogue: 0,0:03:47.04,0:03:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Pangeran Renato itu\Norangnya seperti apa, ya?
Dialogue: 0,0:03:52.01,0:03:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga mereka bukan orang yang kaku\Nseperti Pangeran Placido.
Dialogue: 0,0:04:02.97,0:04:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria!
Dialogue: 0,0:04:12.44,0:04:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bersikap anggun,
Dialogue: 0,0:04:13.69,0:04:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak boleh aneh-aneh.
Dialogue: 0,0:04:15.49,0:04:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas!
Dialogue: 0,0:04:17.07,0:04:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah rutin berlatih bersama Aida.
Dialogue: 0,0:04:23.74,0:04:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di mana?
Dialogue: 0,0:04:26.83,0:04:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria!
Dialogue: 0,0:04:30.12,0:04:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf!
Dialogue: 0,0:04:32.79,0:04:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakannya sangat cepat.\NTahu-tahu beliau sudah menghilang...
Dialogue: 0,0:04:36.84,0:04:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi memang begitu, apa boleh buat.
Dialogue: 0,0:04:39.74,0:04:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia tidak pergi ke luar istana,
Dialogue: 0,0:04:41.97,0:04:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}carilah di seluruh penjuru istana.
Dialogue: 0,0:04:43.97,0:04:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:04:46.93,0:04:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku sudah pernah lewat jalan ini.
Dialogue: 0,0:04:52.73,0:04:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, kami menemukannya!
Dialogue: 0,0:04:57.86,0:04:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat sini.
Dialogue: 0,0:05:05.49,0:05:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi?
Dialogue: 0,0:05:10.06,0:05:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato.
Dialogue: 0,0:05:12.58,0:05:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:05:14.04,0:05:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu terluka?
Dialogue: 0,0:05:14.96,0:05:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sama sekali tidak.
Dialogue: 0,0:05:16.63,0:05:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:05:18.70,0:05:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, ia...
Dialogue: 0,0:05:22.93,0:05:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersangkut di semak belukar.
Dialogue: 0,0:05:25.93,0:05:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Macaron!
Dialogue: 0,0:05:27.81,0:05:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana saja kamu?
Dialogue: 0,0:05:30.35,0:05:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencarimu ke mana-mana!
Dialogue: 0,0:05:32.88,0:05:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NAnjing ini milik Ibu Suri?
Dialogue: 0,0:05:36.36,0:05:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.\NAku sangat mencemaskannya.
Dialogue: 0,0:05:39.40,0:05:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menemukannya,\NMaria Annovazzi.
Dialogue: 0,0:05:43.95,0:05:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:05:46.17,0:05:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah menungguku,\Ntapi gaunku malah...
Dialogue: 0,0:05:52.73,0:05:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gadis yang sangat menarik.
Dialogue: 0,0:05:56.04,0:05:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, tidak sopan tertawa sekencang itu.
Dialogue: 0,0:06:04.89,0:06:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Pangeran Renato, aku...
Dialogue: 0,0:06:11.73,0:06:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi-ku memang hebat.
Dialogue: 0,0:06:21.24,0:06:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini kulihat ekspresi seperti itu\Ndi wajah Renato.
Dialogue: 0,0:06:24.11,0:06:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mencari ke banyak\Ntempat pun tak ketemu.
Dialogue: 0,0:06:26.87,0:06:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, di mana gadis itu menemukannya?
Dialogue: 0,0:06:29.37,0:06:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kan?
Dialogue: 0,0:06:37.92,0:06:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun itu, mulai hari ini\Naku resmi menjadi putri mahkota.
Dialogue: 0,0:06:42.74,0:06:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syalala, syalala.
Dialogue: 0,0:06:49.56,0:06:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus semangat berlatih\Nagar menjadi putri mahkota yang terhormat!
Dialogue: 0,0:06:57.06,0:06:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:06:59.01,0:07:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita terhormat tak akan jingkrak-jingkrak
Dialogue: 0,0:07:01.57,0:07:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di koridor Akademi Kerajaan.
Dialogue: 0,0:07:03.57,0:07:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:07:06.07,0:07:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan jingkrak-jingkrak.
Dialogue: 0,0:07:08.32,0:07:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa lain sampai menempel ke dinding\Nsupaya tidak tertabrak.
Dialogue: 0,0:07:11.79,0:07:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Aida.
Dialogue: 0,0:07:14.61,0:07:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berjuang bersama
Dialogue: 0,0:07:16.37,0:07:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di kelas pelatihan putri mahkota.
Dialogue: 0,0:07:18.25,0:07:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!\NMohon bantuannya.
Dialogue: 0,0:07:24.30,0:07:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu mantan calon putri mahkota, kan?
Dialogue: 0,0:07:29.47,0:07:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau reputasi kebangsawananmu\Ntercoreng karena ini...
Dialogue: 0,0:07:34.31,0:07:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu mencemaskan soal itu.
Dialogue: 0,0:07:36.96,0:07:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida terlihat lebih ceria akhir-akhir ini.
Dialogue: 0,0:07:40.31,0:07:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Aida.\NTerima kasih.
Dialogue: 0,0:07:42.92,0:07:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi aku harap pelatihannya bisa diadakan\Nsaat libur panjang berikutnya.
Dialogue: 0,0:07:48.82,0:07:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pulang ke rumahku!
Dialogue: 0,0:07:51.58,0:07:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bertemu adikku, Teodorico,\Nsetelah sekian lama!
Dialogue: 0,0:07:54.50,0:07:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tanggalnya sudah ditetapkan, ya.
Dialogue: 0,0:07:57.37,0:07:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir akan ditunda lebih lama.
Dialogue: 0,0:08:01.07,0:08:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal banyak yang harus disiapkan,
Dialogue: 0,0:08:03.59,0:08:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kata Pangeran Placido,
Dialogue: 0,0:08:06.84,0:08:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato enggan melepas kepergianmu.
Dialogue: 0,0:08:11.14,0:08:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ternyata aku harus menemui\NPangeran di istana hari ini!
Dialogue: 0,0:08:16.27,0:08:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.\NAku pulang duluan, ya.
Dialogue: 0,0:08:19.20,0:08:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:21.67,0:08:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji akan pulang\Nsebelum waktu makan malam!
Dialogue: 0,0:08:26.82,0:08:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, dia pergi sambil berlari.
Dialogue: 0,0:08:29.61,0:08:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Raimondo, rupanya kamu ada di sini.
Dialogue: 0,0:08:32.24,0:08:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pelatihan putri mahkotanya lancar?
Dialogue: 0,0:08:35.30,0:08:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa lihat sendiri,
Dialogue: 0,0:08:37.20,0:08:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kemampuan atletiknya sangat bagus.
Dialogue: 0,0:08:39.37,0:08:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti cepat menyerap pelajaran\Netiket keluarga kerajaan.
Dialogue: 0,0:08:42.53,0:08:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kebiasaan keceplosannya itu
Dialogue: 0,0:08:45.38,0:08:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa diatasi?
Dialogue: 0,0:08:48.82,0:08:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kalau itu...
Dialogue: 0,0:08:50.80,0:08:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sengaja membiarkannya seperti itu.
Dialogue: 0,0:08:52.97,0:08:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu kelebihannya.
Dialogue: 0,0:08:55.26,0:08:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, saat dia menjadi ratu nanti,\Npasti akan timbul banyak masalah.
Dialogue: 0,0:08:59.46,0:09:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:09:02.15,0:09:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak pernah punya niat\Nuntuk menyakiti orang lain.
Dialogue: 0,0:09:06.98,0:09:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin.
Dialogue: 0,0:09:09.20,0:09:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat sana.\NBaru saja dibicarakan.
Dialogue: 0,0:09:13.87,0:09:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gadis yang pernah mengincar\NYang Mulia Renato,
Dialogue: 0,0:09:16.27,0:09:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Marquess Rosalia Pinotti.
Dialogue: 0,0:09:19.04,0:09:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, dia sering memberikan perlakuan\Ntidak menyenangkan pada Nona Aida.
Dialogue: 0,0:09:24.34,0:09:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah!\NSalam sejahtera, Nona Maria.
Dialogue: 0,0:09:28.26,0:09:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia. Salam sejahtera.
Dialogue: 0,0:09:32.84,0:09:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja aku mencium\Nbau kampung dari tempat ini.
Dialogue: 0,0:09:36.64,0:09:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar, Nona Rosalia.
Dialogue: 0,0:09:39.29,0:09:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bau jerami, ya?
Dialogue: 0,0:09:41.52,0:09:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ingat perkampungan, ya.
Dialogue: 0,0:09:43.73,0:09:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga Pangeran Renato tak membencimu\Nkarena bau kampung yang menyengat ini.
Dialogue: 0,0:09:56.83,0:10:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia harum sekali, ya!
Dialogue: 0,0:10:00.00,0:10:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai parfum?
Dialogue: 0,0:10:01.48,0:10:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tentu saja! Parfum itu cerminan\Nkelas wanita terhormat!
Dialogue: 0,0:10:06.38,0:10:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, dia tak tahu wilayah\NMarquess Pinotti terkenal akan parfumnya.
Dialogue: 0,0:10:10.97,0:10:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia belum pernah lihat
Dialogue: 0,0:10:13.09,0:10:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}parfum padat alami.
Dialogue: 0,0:10:15.34,0:10:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parfum padat alami?
Dialogue: 0,0:10:18.49,0:10:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bawa itu sekarang?
Dialogue: 0,0:10:21.71,0:10:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu butuh edukasi.
Dialogue: 0,0:10:24.35,0:10:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parfum buatan keluargaku\Ntak hanya harum semerbak,
Dialogue: 0,0:10:27.82,0:10:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi juga membantu melembapkan kulit.
Dialogue: 0,0:10:30.36,0:10:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kami juga mencampur bubuk kerang
Dialogue: 0,0:10:33.10,0:10:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membuat kulit tampak lebih cantik.
Dialogue: 0,0:10:35.93,0:10:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:10:39.99,0:10:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harum sekali!
Dialogue: 0,0:10:41.77,0:10:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kulitku terlihat mengilap!
Dialogue: 0,0:10:44.57,0:10:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kubilang?
Dialogue: 0,0:10:45.62,0:10:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parfum padat alami dan keren.\NMau bawa pulang.
Dialogue: 0,0:10:49.49,0:10:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bicaramu jadi kaku?
Dialogue: 0,0:10:51.38,0:10:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kan pakai bahasa yang sama\Ndengan Kerajaan Muro.
Dialogue: 0,0:10:54.87,0:10:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia, kamu tahu Kerajaan Muro?
Dialogue: 0,0:10:59.00,0:11:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:11:00.35,0:11:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai bangsawan,\Naku mempelajari kerajaan-kerajaan di sekitar.
Dialogue: 0,0:11:06.63,0:11:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:11:08.56,0:11:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kamu sudi mempelajari
Dialogue: 0,0:11:10.86,0:11:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kerajaan kecil seperti tempat asalku!
Dialogue: 0,0:11:13.53,0:11:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan sekali, dibesarkan di kampung\Nyang penuh peternakan.
Dialogue: 0,0:11:19.73,0:11:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti...\Nbelum pernah pergi ke pantai, kan?
Dialogue: 0,0:11:23.12,0:11:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:11:24.66,0:11:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia pernah pergi ke sana?
Dialogue: 0,0:11:28.61,0:11:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menikmati liburan ke vila setiap tahun!
Dialogue: 0,0:11:32.93,0:11:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kedengarannya seru!
Dialogue: 0,0:11:36.53,0:11:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ingin melihat laut biru\Ndan cipratan air yang berkilau.
Dialogue: 0,0:11:41.39,0:11:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan baharinya pasti sangat lezat.
Dialogue: 0,0:11:44.60,0:11:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam harinya bisa main kembang api.
Dialogue: 0,0:11:47.23,0:11:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langit berbintangnya pasti sangat indah.
Dialogue: 0,0:11:51.41,0:11:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin pergi ke sana.
Dialogue: 0,0:11:53.36,0:11:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia,
Dialogue: 0,0:11:54.57,0:11:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong jangan anggap itu menyenangkan!
Dialogue: 0,0:11:57.66,0:11:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia, bertahanlah!
Dialogue: 0,0:12:00.46,0:12:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya baju renang,
Dialogue: 0,0:12:02.66,0:12:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maukah kamu membantuku memilihnya
Dialogue: 0,0:12:04.54,0:12:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku pergi ke sana nanti?
Dialogue: 0,0:12:06.79,0:12:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia!
Dialogue: 0,0:12:08.48,0:12:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu kenapa?
Dialogue: 0,0:12:10.33,0:12:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah, aku akan mengajakmu liburan\Npada musim panas nanti!
Dialogue: 0,0:12:14.13,0:12:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghubungi\Ntoko baju renang langgananku!
Dialogue: 0,0:12:16.84,0:12:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu saja
Dialogue: 0,0:12:18.88,0:12:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pembalasanku nanti!
Dialogue: 0,0:12:20.87,0:12:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Rosalia!
Dialogue: 0,0:12:22.50,0:12:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan menantikannya!
Dialogue: 0,0:12:27.29,0:12:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kubilang?
Dialogue: 0,0:12:28.27,0:12:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu harus menjawab apa...
Dialogue: 0,0:12:31.27,0:12:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi bahkan bisa membalas Nona Rosalia\Ndengan cara seperti itu.
Dialogue: 0,0:12:34.65,0:12:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga bisa membalas orang-orang
Dialogue: 0,0:12:37.08,0:12:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang merundungnya secara langsung.
Dialogue: 0,0:12:39.49,0:12:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, dia benar-benar bisa diandalkan.
Dialogue: 0,0:12:41.85,0:12:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertemuan tempo hari\Nberjalan dengan sukses, kan?
Dialogue: 0,0:12:45.29,0:12:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah,
Dialogue: 0,0:12:47.62,0:12:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk sebagian besarnya...
Dialogue: 0,0:12:49.04,0:12:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian besar?
Dialogue: 0,0:12:50.33,0:12:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal yang harus kuserahkan\Npada Nona Maria,
Dialogue: 0,0:12:54.42,0:12:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari mengobrol lagi nanti.
Dialogue: 0,0:12:55.92,0:12:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti!
Dialogue: 0,0:12:59.30,0:13:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Tuan Raimondo!
Dialogue: 0,0:13:01.84,0:13:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan kamu ada di sana.
Dialogue: 0,0:13:03.64,0:13:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria?
Dialogue: 0,0:13:06.18,0:13:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini.
Dialogue: 0,0:13:07.43,0:13:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing ini kelihatannya tersesat.
Dialogue: 0,0:13:11.94,0:13:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi teringat kejadian\Nsaat pertemuan tempo hari.
Dialogue: 0,0:13:14.90,0:13:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah Baginda Ratu...
Dialogue: 0,0:13:17.92,0:13:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku dibenci Baginda Ratu, ya?
Dialogue: 0,0:13:22.56,0:13:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida sudah pernah cerita soal diriku\Npada Baginda Ratu,
Dialogue: 0,0:13:26.58,0:13:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kabarnya beliau tertarik denganku.
Dialogue: 0,0:13:30.62,0:13:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kejadian itu pasti membuatnya kecewa.
Dialogue: 0,0:13:34.46,0:13:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Ratu adalah pribadi\Nyang sangat ketat mengenai etiket.
Dialogue: 0,0:13:37.96,0:13:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau Baginda Raja\Ndan Yang Mulia Ibu Suri menyukaimu,
Dialogue: 0,0:13:42.24,0:13:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa Baginda Ratu menyimpan keraguan
Dialogue: 0,0:13:45.08,0:13:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengenai kepantasanmu menjadi\Nputri mahkota Kerajaan Rubini.
Dialogue: 0,0:13:51.43,0:13:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin akrab dengan beliau.
Dialogue: 0,0:13:53.82,0:13:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, beliau ibu Pangeran Renato.
Dialogue: 0,0:13:57.36,0:14:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja menyesali yang telah berlalu.
Dialogue: 0,0:14:03.10,0:14:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:14:04.32,0:14:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undangan dari Baginda Ratu.
Dialogue: 0,0:14:06.80,0:14:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau ingin mengadakan upacara\Nminum teh berdua denganmu.
Dialogue: 0,0:14:09.33,0:14:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja ini ujian.
Dialogue: 0,0:14:32.89,0:14:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, maaf membuatmu menunggu.
Dialogue: 0,0:14:35.88,0:14:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran, kamu berlari ke sini?
Dialogue: 0,0:14:40.20,0:14:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku buru-buru.
Dialogue: 0,0:14:42.86,0:14:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak. Aku baik-baik saja.
Dialogue: 0,0:14:46.12,0:14:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar sibuk, ya.
Dialogue: 0,0:14:48.83,0:14:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah, pekerjaanku\Nbertambah dalam semalam.
Dialogue: 0,0:14:52.12,0:14:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku benar-benar tak sabar\Ningin bertemu denganmu.
Dialogue: 0,0:15:01.71,0:15:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cocok mengenakan jepit rambut itu.
Dialogue: 0,0:15:04.13,0:15:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NAh, ini...
Dialogue: 0,0:15:07.09,0:15:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seluruh perempuan keluarga Annovazzi.\NIni simbol keturunan langsung yang dipakai
Dialogue: 0,0:15:12.01,0:15:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desainnya dibuat unik, menyesuaikan\Ndengan simbol keluarga kami.
Dialogue: 0,0:15:15.14,0:15:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menikah, kami akan menambahkan\Nsimbol keluarga pasangan kami.
Dialogue: 0,0:15:18.94,0:15:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kamu harus buat yang baru\Ndengan simbol keluarga kerajaan.
Dialogue: 0,0:15:24.01,0:15:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga kerajaan?\NTi-Tidak perlu, itu terlalu bagus untukku!
Dialogue: 0,0:15:28.95,0:15:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak.\NItu tradisi keluargamu, kan?
Dialogue: 0,0:15:33.10,0:15:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran...
Dialogue: 0,0:15:34.91,0:15:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:15:36.75,0:15:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku pasti senang.
Dialogue: 0,0:15:38.61,0:15:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pulang nanti, akan kukabari...
Dialogue: 0,0:15:40.63,0:15:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai itu...
Dialogue: 0,0:15:42.63,0:15:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu akan kembali lagi ke sini?
Dialogue: 0,0:15:45.59,0:15:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:15:47.30,0:15:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masih ada sekolah.
Dialogue: 0,0:15:48.72,0:15:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Karena aku ingin bertemu Pangeran.
Dialogue: 0,0:15:52.83,0:15:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:15:54.47,0:15:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia tak perlu secemas itu.
Dialogue: 0,0:15:57.80,0:16:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, pangeran setampan dirinya\Nmau menyempatkan waktu untukku,
Dialogue: 0,0:16:02.82,0:16:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memperhatikan soal jepit rambut.
Dialogue: 0,0:16:05.14,0:16:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak memalukan, tapi aku sangat senang.
Dialogue: 0,0:16:08.32,0:16:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi agak enggan kembali ke sini.\NAh, tapi setelah bertemu Teodorico nanti,
Dialogue: 0,0:16:13.27,0:16:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda.
Dialogue: 0,0:16:14.60,0:16:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teodorico itu adikmu, kan?
Dialogue: 0,0:16:17.54,0:16:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keceplosan lagi!
Dialogue: 0,0:16:20.79,0:16:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah terbiasa dengan itu.
Dialogue: 0,0:16:22.96,0:16:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:16:25.40,0:16:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, aku membawakan daftarnya.
Dialogue: 0,0:16:27.84,0:16:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:30.76,0:16:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini daftar hadiah yang akan kukirimkan\Nke keluarga Annovazzi.
Dialogue: 0,0:16:34.39,0:16:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja mereka senang menerimanya.
Dialogue: 0,0:16:36.85,0:16:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga kami menerima apa pun
Dialogue: 0,0:16:38.85,0:16:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selain penyakit!
Dialogue: 0,0:16:40.15,0:16:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarnya.
Dialogue: 0,0:16:41.86,0:16:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, apa kamu hanya pulang\Nke rumah untuk satu hari?
Dialogue: 0,0:16:45.57,0:16:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatnya!
Dialogue: 0,0:16:46.44,0:16:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bilang, itu terlalu singkat.
Dialogue: 0,0:16:49.26,0:16:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi perjalanan pulang-pergi\Nbutuh waktu enam hari.
Dialogue: 0,0:16:54.27,0:16:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa bersantai\Nsaat nanti berkunjung bersamaku.
Dialogue: 0,0:16:58.37,0:17:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Pangeran.\NTuan Raimondo melihat kita.
Dialogue: 0,0:17:02.65,0:17:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:17:04.13,0:17:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu... ternyata lumayan
Dialogue: 0,0:17:07.21,0:17:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuat juga, ya?
Dialogue: 0,0:17:09.16,0:17:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:17:10.22,0:17:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi sulit dihindari!\NLebih tepatnya, gerakanmu terlalu lambat
Dialogue: 0,0:17:14.93,0:17:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?\NSeram!
Dialogue: 0,0:17:21.21,0:17:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar ingin menghadiahkan\Njepit rambut itu untukmu.
Dialogue: 0,0:17:26.65,0:17:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu, Pangeran Renato...
Dialogue: 0,0:17:29.95,0:17:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, Nona Maria sudah punya janji
Dialogue: 0,0:17:32.70,0:17:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk minum teh bersama Baginda Ratu.
Dialogue: 0,0:17:35.70,0:17:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lepaskan dia.
Dialogue: 0,0:17:39.06,0:17:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu usil sekali sengaja buat janji
Dialogue: 0,0:17:42.67,0:17:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku sedang bersamanya.
Dialogue: 0,0:17:45.69,0:17:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:17:47.40,0:17:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kelihatannya aku tidak begitu\Ndisukai oleh Baginda Ratu.
Dialogue: 0,0:17:52.61,0:17:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku bukan begitu.
Dialogue: 0,0:17:56.84,0:18:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menemuinya sekali lagi\Nsebelum pulang ke Kerajaan Muro.
Dialogue: 0,0:18:01.58,0:18:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu memaksakan diri, ya.
Dialogue: 0,0:18:04.20,0:18:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti!
Dialogue: 0,0:18:07.64,0:18:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Renato mengutus kesatria,\Nbahkan saat aku ada di dalam istana.
Dialogue: 0,0:18:12.85,0:18:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan untuk mengawal,\Nmelainkan menjagaku agar tidak tersesat.
Dialogue: 0,0:18:16.95,0:18:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin dilindungi.
Dialogue: 0,0:18:24.33,0:18:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku seperti merasakan kehadiran seseorang.
Dialogue: 0,0:18:30.21,0:18:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, rupanya ini taman Baginda Ratu.
Dialogue: 0,0:18:35.47,0:18:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria, kami sudah menunggu Anda.
Dialogue: 0,0:18:41.14,0:18:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Baginda Ratu?
Dialogue: 0,0:18:42.88,0:18:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau akan segera datang.
Dialogue: 0,0:18:44.77,0:18:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tunggu sebentar.
Dialogue: 0,0:18:54.15,0:18:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam sejahtera.
Dialogue: 0,0:18:56.13,0:18:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih sudah mengundang saya.
Dialogue: 0,0:18:59.83,0:19:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga Baginda senantiasa sehat...
Dialogue: 0,0:19:03.81,0:19:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu sekaku itu.
Dialogue: 0,0:19:09.00,0:19:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, cepat duduk.
Dialogue: 0,0:19:11.17,0:19:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:19:14.42,0:19:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memperhatikan aku!
Dialogue: 0,0:19:16.89,0:19:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salamku tadi salah, ya?
Dialogue: 0,0:19:21.10,0:19:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghela napas!
Dialogue: 0,0:19:23.27,0:19:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini? Baru duduk lima detik,\Nbeliau sudah kecewa padaku!
Dialogue: 0,0:19:26.94,0:19:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu... Etiket... Teh... Kudapan...
Dialogue: 0,0:19:35.36,0:19:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan makan dari yang paling lezat.
Dialogue: 0,0:19:38.51,0:19:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:19:40.03,0:19:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, aku harus tenang.
Dialogue: 0,0:19:42.62,0:19:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ingin bersikap anggun,
Dialogue: 0,0:19:45.25,0:19:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus menyantap kudapan\Ndengan satu gigitan kecil.
Dialogue: 0,0:19:47.87,0:19:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum tehnya tanpa bersuara.
Dialogue: 0,0:19:50.75,0:19:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tersenyum.\NRasanya lezat.
Dialogue: 0,0:19:55.17,0:19:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:19:57.80,0:20:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bagaimana," katamu?
Dialogue: 0,0:20:00.30,0:20:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu
Dialogue: 0,0:20:01.84,0:20:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengucapkan itu padaku?
Dialogue: 0,0:20:04.73,0:20:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, lagi-lagi keceplosan!\NMaafkan aku!
Dialogue: 0,0:20:07.39,0:20:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, etiketmu lulus.
Dialogue: 0,0:20:10.19,0:20:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih banyak.
Dialogue: 0,0:20:17.36,0:20:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Ratu,
Dialogue: 0,0:20:19.11,0:20:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahaya!
Dialogue: 0,0:20:28.75,0:20:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Ratu!
Dialogue: 0,0:20:31.33,0:20:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ditembak dari jendela istana.
Dialogue: 0,0:20:33.50,0:20:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:20:35.26,0:20:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Maria, apa Anda terluka?
Dialogue: 0,0:20:37.63,0:20:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku baik-baik saja.
Dialogue: 0,0:20:40.44,0:20:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, segera tangkap pelakunya,\Ndan amankan Baginda Ratu.
Dialogue: 0,0:20:43.94,0:20:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gemetaran...\NTentu saja.
Dialogue: 0,0:20:46.73,0:20:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun pasti ketakutan\Nsaat diserang tiba-tiba.
Dialogue: 0,0:20:49.56,0:20:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Ratu, semua sudah baik-baik saja.
Dialogue: 0,0:20:52.23,0:20:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kembali ke kamar.
Dialogue: 0,0:20:54.19,0:20:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bisa berdiri?
Dialogue: 0,0:20:55.98,0:20:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:20:56.65,0:20:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:57.32,0:20:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:20:59.03,0:21:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sanggup lagi!
Dialogue: 0,0:21:02.20,0:21:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi keren banget!\NAku suka!
Dialogue: 0,0:21:05.95,0:21:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:07.70,0:21:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aida benar, rupanya kamu\Nmemang sangat kuat!
Dialogue: 0,0:21:10.54,0:21:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lihat itu?\NGerakannya saat menendang meja tadi!
Dialogue: 0,0:21:13.91,0:21:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh ingin melihatmu bertarung\Nmelawan suruhan Baron Casciari!
Dialogue: 0,0:21:17.84,0:21:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa selalu Renato yang lihat? Curang!
Dialogue: 0,0:21:20.72,0:21:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baginda Ratu,
Dialogue: 0,0:21:22.14,0:21:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tolong berhenti memukul-mukul tanah!\N- Mimi memang yang paling keren!
Dialogue: 0,0:21:23.80,0:21:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tangan Anda nanti kotor!\N- Keren sekali!
Dialogue: 0,0:21:26.31,0:21:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa!
Dialogue: 0,0:21:27.22,0:21:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini bisa memuji kegagahanmu,\Ntangan jadi korban pun tak apa-apa!
Dialogue: 0,0:21:30.73,0:21:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku kurang paham ada apa ini,\N- Aku sangat sayang padamu, Mimi!
Dialogue: 0,0:21:32.65,0:21:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tapi sepertinya ada yang salah dengan beliau.\N- Aku sangat sayang padamu, Mimi!
Dialogue: 0,0:21:34.48,0:21:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tolong segera bawa dia ke dokter!\N- Aku suka Mimi, aku suka!
Dialogue: 0,0:21:36.48,0:21:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ba-Baik!\N- Aku suka Mimi, aku suka!
Dialogue: 0,0:21:38.53,0:21:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi, menginaplah malam ini!
Dialogue: 0,0:21:41.93,0:21:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi!
Dialogue: 0,0:21:42.78,0:21:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kenapa, ya?
Dialogue: 0,0:21:48.69,0:21:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia lebih menarik dari dugaanku.
Dialogue: 0,0:21:51.85,0:21:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimi.
Dialogue: 0,0:23:27.09,0:23:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginda Ratu memperlihatkan tiaranya.
Dialogue: 0,0:23:29.01,0:23:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak berlian yang menghias permukaannya,
Dialogue: 0,0:23:31.29,0:23:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku terkejut karena ternyata berat.
Dialogue: 0,0:23:33.68,0:23:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya Baginda Ratu tangguh juga, ya.
Dialogue: 0,0:23:35.60,0:23:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, beliau dan Raja...
Dialogue: 0,0:23:37.10,0:23:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku keceplosan lagi!
