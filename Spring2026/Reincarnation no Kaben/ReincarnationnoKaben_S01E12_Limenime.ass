Dialogue: 0,0:02:12.13,0:02:15.05,sign,,0000,0000,0000,,PETALS OF REINCARNATION
Dialogue: 0,0:13:39.06,0:13:40.02,sign,,0000,0000,0000,,"GOKUGAN"
Dialogue: 0,0:13:44.19,0:13:46.32,sign,,0000,0000,0000,,"MEMBACA GERAKAN, MENGANALISIS TEBASAN"
Dialogue: 0,0:13:46.41,0:13:48.95,sign,,0000,0000,0000,,"YAGYU SHINKAGE-RYU"
Dialogue: 0,0:14:37.21,0:14:38.50,sign,,0000,0000,0000,,MUHOU
Dialogue: 0,0:18:56.05,0:18:57.05,sign,,0000,0000,0000,,MAYAT ENAM WARNA
Dialogue: 0,0:22:28.84,0:22:30.01,sign,,0000,0000,0000,,EPISODE 12\NSAMPAI SUARANYA TERDENGAR
Dialogue: 0,0:23:35.04,0:23:36.66,sign,,0000,0000,0000,,EPISODE 13: AKHIR REINKARNASI
Dialogue: 0,0:00:01.04,0:00:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini,\NNightingale benar-benar tidak berdaya.
Dialogue: 0,0:00:04.17,0:00:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar kesempatan emas!
Dialogue: 0,0:00:05.96,0:00:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi lokasinya...
Dialogue: 0,0:00:07.59,0:00:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau bilang,\N"Aku tidak tahu lokasinya," kan?
Dialogue: 0,0:00:10.42,0:00:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya
Dialogue: 0,0:00:12.05,0:00:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kuberi tahu koordinat markas kami.
Dialogue: 0,0:00:17.89,0:00:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Nightingale dikalahkan,\Npara Pengembali akan kembali normal,
Dialogue: 0,0:00:21.48,0:00:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}begitu juga dengan Newton kesayanganmu.
Dialogue: 0,0:00:26.90,0:00:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuanmu memberi tahu kami semua ini?
Dialogue: 0,0:00:31.44,0:00:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku punya satu syarat...
Dialogue: 0,0:00:34.70,0:00:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu...
Dialogue: 0,0:00:36.82,0:00:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tinggalkan setidaknya satu goresan padaku."
Dialogue: 0,0:00:45.75,0:00:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, mari kita mulai.
Dialogue: 0,0:00:49.00,0:00:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, aku akan pemanasan dengan mereka...
Dialogue: 0,0:00:51.80,0:00:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu berakhir,
Dialogue: 0,0:00:53.42,0:00:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan bermain denganmu.
Dialogue: 0,0:02:29.94,0:02:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:02:31.56,0:02:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunlah sekarang juga.
Dialogue: 0,0:02:33.36,0:02:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan Einstein dahulu!
Dialogue: 0,0:02:35.57,0:02:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak.
Dialogue: 0,0:02:37.99,0:02:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membaca koordinat\Ndi dalam medan gravitasi Newton yang kuat.
Dialogue: 0,0:02:42.28,0:02:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, jangan melawan orang ini!
Dialogue: 0,0:02:44.91,0:02:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mencari cara untuk kabur...
Dialogue: 0,0:02:47.08,0:02:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kau tidak mendengarku?
Dialogue: 0,0:02:48.79,0:02:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan diam saja. Katakan sesuatu...
Dialogue: 0,0:02:50.46,0:02:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan teriakan itu.
Dialogue: 0,0:02:52.08,0:02:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah bergerak.
Dialogue: 0,0:02:54.50,0:02:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika terus begini, ini bahkan\Ntidak bisa dianggap sebagai pemanasan.
Dialogue: 0,0:02:56.55,0:02:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:03:04.93,0:03:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menangkap mereka!
Dialogue: 0,0:03:09.43,0:03:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya bercanda.
Dialogue: 0,0:03:12.23,0:03:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf atas serangan mendadak ini.
Dialogue: 0,0:03:19.03,0:03:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:03:21.66,0:03:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan serangan itu bisa dihindari?
Dialogue: 0,0:03:23.41,0:03:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergerak bebas di udara seperti daun...
Dialogue: 0,0:03:26.33,0:03:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu bakat mereka?
Dialogue: 0,0:03:28.50,0:03:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu efek "Buah Gravitasi" Newton.
Dialogue: 0,0:03:31.79,0:03:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bakat orang yang mengaku Einstein itu
Dialogue: 0,0:03:35.34,0:03:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak terbatas...
Dialogue: 0,0:03:37.13,0:03:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekeras apa pun aku berusaha,\Naku tidak bisa memahaminya.
Dialogue: 0,0:03:39.26,0:03:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotaro! Carothers!
Dialogue: 0,0:03:40.59,0:03:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan jurus itu!
Dialogue: 0,0:03:41.63,0:03:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik.
Dialogue: 0,0:03:46.18,0:03:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dinding.
Dialogue: 0,0:03:47.22,0:03:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka akan melakukan pertahanan total?
Dialogue: 0,0:03:52.14,0:03:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badai Besi!
Dialogue: 0,0:03:58.32,0:03:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan ini?
Dialogue: 0,0:03:59.23,0:04:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan serangan besi ini!
Dialogue: 0,0:04:00.86,0:04:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada jalan keluar untukmu sekarang!
Dialogue: 0,0:04:02.91,0:04:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu?
Dialogue: 0,0:04:03.99,0:04:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan kombinasimu\Ntidak melampaui harapanku.
Dialogue: 0,0:04:06.66,0:04:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sama sekali tidak punya selera.
Dialogue: 0,0:04:08.79,0:04:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan bilang kau kehabisan trik.
Dialogue: 0,0:04:12.04,0:04:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kau tidak tahu cara mengalahkanku?
Dialogue: 0,0:04:15.67,0:04:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, cepatlah mundur.
Dialogue: 0,0:04:18.92,0:04:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotaro, pasang pelindung!
Dialogue: 0,0:04:20.30,0:04:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan tepat waktu.
Dialogue: 0,0:04:24.18,0:04:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei...
Dialogue: 0,0:04:26.43,0:04:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bersenang-senang tanpa aku, Norton.
Dialogue: 0,0:04:29.43,0:04:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai cemburu.
Dialogue: 0,0:04:30.89,0:04:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penukaran target dan pengalihan, ya?
Dialogue: 0,0:04:33.56,0:04:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa itu ide bagus?
Dialogue: 0,0:04:35.77,0:04:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memfokuskan semua serangan pada dirimu
Dialogue: 0,0:04:38.32,0:04:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya akan mempercepat kematianmu.
Dialogue: 0,0:04:40.86,0:04:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini.
Dialogue: 0,0:04:42.07,0:04:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya.
Dialogue: 0,0:04:47.16,0:04:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu menyentuh garis-garis itu,
Dialogue: 0,0:04:48.87,0:04:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua listrik yang\Nmenggerakkannya menghilang.
Dialogue: 0,0:04:51.75,0:04:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Norton mengalihkan,
Dialogue: 0,0:04:53.50,0:04:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Möbius membatalkan.
Dialogue: 0,0:04:55.33,0:04:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ide yang menarik...
Dialogue: 0,0:05:00.05,0:05:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang tidak ada gunanya.
Dialogue: 0,0:05:02.17,0:05:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun serangannya...
Dialogue: 0,0:05:10.35,0:05:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan garis-garis itu\Ntak berguna melawan bom klaster.
Dialogue: 0,0:05:15.52,0:05:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bertahanlah, Möbius!
Dialogue: 0,0:05:21.11,0:05:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:05:23.03,0:05:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat Norton sepertinya tidak bertahan lama.
Dialogue: 0,0:05:28.53,0:05:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjatuhkan satu dahulu.
Dialogue: 0,0:05:35.08,0:05:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, lalu...
Dialogue: 0,0:05:39.54,0:05:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan kalah\Ndengan goresan seperti ini...
Dialogue: 0,0:05:42.42,0:05:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, matilah saja.
Dialogue: 0,0:05:51.01,0:05:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukanya menghilang...
Dialogue: 0,0:05:52.81,0:05:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:05:56.14,0:05:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekuat apa pun kau,
Dialogue: 0,0:05:58.65,0:06:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak bisa mengalahkan kami.
Dialogue: 0,0:06:01.27,0:06:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sia-siakan energimu. Menyerah saja.
Dialogue: 0,0:06:05.94,0:06:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Henri!
Dialogue: 0,0:06:07.11,0:06:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur!
Dialogue: 0,0:06:10.07,0:06:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa menahannya.
Dialogue: 0,0:06:12.03,0:06:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku terlalu jauh, efeknya...
Dialogue: 0,0:06:15.04,0:06:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:06:16.54,0:06:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pemain kunci di sini.
Dialogue: 0,0:06:18.92,0:06:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Henri.
Dialogue: 0,0:06:20.04,0:06:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira bakatmu adalah kemampuan\Nmenyembuhkan seperti Gale,
Dialogue: 0,0:06:23.38,0:06:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sebenarnya itu\Nberbagi rasa sakit orang lain.
Dialogue: 0,0:06:27.05,0:06:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:28.26,0:06:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Henri bahkan tidak bertarung,\Ntapi dia berlumuran darah.
Dialogue: 0,0:06:32.05,0:06:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka menembak bahu Mesmer\Ndengan jurus pertama
Dialogue: 0,0:06:35.43,0:06:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya untuk mengetahui bakat Henri?
Dialogue: 0,0:06:38.23,0:06:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengalami luka fatal yang seharusnya\Nmembunuhnya, tapi kau masih hidup.
Dialogue: 0,0:06:43.15,0:06:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, kau tidak akan\Nmati karena luka yang kau derita.
Dialogue: 0,0:06:47.19,0:06:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyerang orang untuk melihat\Nbesarnya rasa sakit yang bisa kau terima,
Dialogue: 0,0:06:52.57,0:06:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jika aku menyerangmu secara langsung,
Dialogue: 0,0:06:55.29,0:06:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang terjadi?
Dialogue: 0,0:06:57.83,0:06:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lindungi Henri!
Dialogue: 0,0:07:03.09,0:07:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang lucu?
Dialogue: 0,0:07:05.80,0:07:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya sudah memahami kalian, itu saja.
Dialogue: 0,0:07:09.88,0:07:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:11.26,0:07:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa persaingan yang dangkal.
Dialogue: 0,0:07:13.80,0:07:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taktik menyerang yang naif.
Dialogue: 0,0:07:16.01,0:07:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan strategi yang berpusat pada pertahanan.
Dialogue: 0,0:07:18.52,0:07:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian jauh dari kekuatan tempur elite.
Dialogue: 0,0:07:21.65,0:07:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ada,
Dialogue: 0,0:07:23.19,0:07:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian hanya sekelompok pembelot menyedihkan.
Dialogue: 0,0:07:27.40,0:07:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghabisi kalian dalam sekejap.
Dialogue: 0,0:07:30.03,0:07:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebagai latihan pemanasan,\Nini cukup menyenangkan.
Dialogue: 0,0:07:34.07,0:07:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:07:52.18,0:07:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu.
Dialogue: 0,0:07:55.39,0:07:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai.
Dialogue: 0,0:07:56.93,0:07:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyangkal keberadaanmu
Dialogue: 0,0:07:59.27,0:08:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar aku bisa memastikan\Nkeberadaanku sendiri.
Dialogue: 0,0:08:03.73,0:08:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Lihat perbedaan kekuatan kita?
Dialogue: 0,0:08:06.02,0:08:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau siap mengakuinya, kan?
Dialogue: 0,0:08:08.40,0:08:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akui bahwa aku Einstein!
Dialogue: 0,0:08:12.91,0:08:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kitazuka.
Dialogue: 0,0:08:14.53,0:08:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:15.45,0:08:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan hanya berdiri di sana.\NBerikan perintah untuk mundur!
Dialogue: 0,0:08:18.08,0:08:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan mundur.
Dialogue: 0,0:08:20.41,0:08:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menegosiasikan gencatan senjata.
Dialogue: 0,0:08:22.87,0:08:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:23.79,0:08:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gencatan senjata?
Dialogue: 0,0:08:24.75,0:08:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti setelah\Nmelihat Albert bertarung.
Dialogue: 0,0:08:30.01,0:08:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat baik-baik.
Dialogue: 0,0:08:33.67,0:08:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tak berubah menjadi Cabang.
Dialogue: 0,0:08:35.51,0:08:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Einstein masih hidup...
Dialogue: 0,0:08:37.89,0:08:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, dia sengaja dibiarkan hidup.
Dialogue: 0,0:08:40.52,0:08:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan orang itu bukan membunuh.
Dialogue: 0,0:08:43.14,0:08:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita meminta gencatan senjata,\Nmereka akan menerimanya.
Dialogue: 0,0:08:50.03,0:08:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau tertidur lagi?
Dialogue: 0,0:08:53.45,0:08:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Newton, pegang kakinya.
Dialogue: 0,0:09:05.37,0:09:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana tidurmu?
Dialogue: 0,0:09:07.67,0:09:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya kehilangan\Nkaki yang sama dua kali?
Dialogue: 0,0:09:11.59,0:09:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku, pemenang, adalah Ein yang asli...\N- Aku baik-baik saja...
Dialogue: 0,0:09:15.18,0:09:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja,
Dialogue: 0,0:09:16.55,0:09:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Newton.
Dialogue: 0,0:09:18.39,0:09:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak perlu merasa bersalah.
Dialogue: 0,0:09:21.97,0:09:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja...
Dialogue: 0,0:09:24.27,0:09:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja...
Dialogue: 0,0:09:26.90,0:09:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani sekali kau mengabaikanku.
Dialogue: 0,0:09:29.61,0:09:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Newton, berikutnya lengannya.
Dialogue: 0,0:09:36.24,0:09:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Hei, apa yang kau lakukan...
Dialogue: 0,0:09:40.83,0:09:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini? Berasap sekali...
Dialogue: 0,0:09:48.46,0:09:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit! Tunggu!
Dialogue: 0,0:09:49.75,0:09:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melihat apa pun...
Dialogue: 0,0:09:51.04,0:09:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Newton, singkirkan asapnya!
Dialogue: 0,0:09:56.97,0:09:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!
Dialogue: 0,0:10:01.35,0:10:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial. Newton, hancurkan mereka!
Dialogue: 0,0:10:03.93,0:10:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu...
Dialogue: 0,0:10:04.89,0:10:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:10:05.89,0:10:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sasaran!
Dialogue: 0,0:10:07.77,0:10:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun kita mengenainya...
Dialogue: 0,0:10:09.23,0:10:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Menggunakan trik murahan seperti itu?
Dialogue: 0,0:10:11.06,0:10:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku sendiri yang akan...
Dialogue: 0,0:10:14.28,0:10:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:10:15.32,0:10:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asap lagi?
Dialogue: 0,0:10:18.24,0:10:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Einstein, dipastikan selamat.
Dialogue: 0,0:10:20.28,0:10:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:10:21.28,0:10:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur!
Dialogue: 0,0:10:23.12,0:10:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa menghabisi mereka?
Dialogue: 0,0:10:25.54,0:10:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengembali kelas hebat memang\Nsesuai dengan reputasinya.
Dialogue: 0,0:10:28.54,0:10:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau bisa begitu tenang?
Dialogue: 0,0:10:30.13,0:10:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat berbeda dari perkataanmu!
Dialogue: 0,0:10:32.34,0:10:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau bilang kita\Nakan gencatan senjata?
Dialogue: 0,0:10:35.17,0:10:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa kau tiba-tiba menyerang mereka?
Dialogue: 0,0:10:37.93,0:10:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bodoh?
Dialogue: 0,0:10:39.22,0:10:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya pilihan.
Dialogue: 0,0:10:40.55,0:10:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan mendadak itu penting...
Dialogue: 0,0:10:41.93,0:10:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu seharusnya gencatan senjata,\Nbukan serangan mendadak!
Dialogue: 0,0:10:43.72,0:10:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita benar-benar\Nmembutuhkan gencatan senjata!
Dialogue: 0,0:10:47.06,0:10:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang aku sudah mengerti...
Dialogue: 0,0:10:50.31,0:10:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:10:51.90,0:10:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bisa\Nmengabaikan hama berisik itu...
Dialogue: 0,0:10:55.69,0:10:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia biasa...
Dialogue: 0,0:10:57.95,0:10:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau menyusahkanku!
Dialogue: 0,0:10:59.86,0:11:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya suasana hati mereka sedang buruk.
Dialogue: 0,0:11:02.78,0:11:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harapan untuk gencatan\Nsenjata bahkan lebih tipis.
Dialogue: 0,0:11:04.54,0:11:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten Kitazuka.
Dialogue: 0,0:11:06.25,0:11:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lawan mereka sampai mereka tenang.
Dialogue: 0,0:11:09.87,0:11:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi yang akan terjadi, kita harus\Nmembuat Yodomi bertarung sungguhan.
Dialogue: 0,0:11:13.13,0:11:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu memaksakan diri.
Dialogue: 0,0:11:14.63,0:11:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan jangan terlalu gigih.
Dialogue: 0,0:11:16.55,0:11:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mengerti.
Dialogue: 0,0:11:18.47,0:11:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:11:20.09,0:11:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bermain denganmu sebentar.
Dialogue: 0,0:11:25.89,0:11:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku mengandalkanmu.
Dialogue: 0,0:11:32.56,0:11:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam ini sangat dingin.
Dialogue: 0,0:11:34.44,0:11:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuacanya tiba-tiba menjadi lebih\Ndingin selama tiga hari terakhir.
Dialogue: 0,0:11:38.36,0:11:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:39.78,0:11:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini membantuku tetap fokus.
Dialogue: 0,0:11:41.78,0:11:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu tegang.
Dialogue: 0,0:11:43.78,0:11:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengajarimu semua yang kutahu,
Dialogue: 0,0:11:45.41,0:11:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini baru tiga hari latihan.
Dialogue: 0,0:11:47.66,0:11:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bisa menangani setiap situasi.
Dialogue: 0,0:11:50.00,0:11:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang paling penting adalah...
Dialogue: 0,0:11:51.58,0:11:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahanan dan menggertak, kan?
Dialogue: 0,0:11:54.54,0:11:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai ini.
Dialogue: 0,0:11:56.38,0:11:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:11:57.34,0:11:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haori.
Dialogue: 0,0:11:58.84,0:12:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menambalnya dengan kain\Nyang ditemukan di reruntuhan.
Dialogue: 0,0:12:02.43,0:12:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini juga bagian dari "menggertak"?
Dialogue: 0,0:12:05.35,0:12:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuatmu terlihat kuat, kan?
Dialogue: 0,0:12:07.81,0:12:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini tidak cocok untukku.
Dialogue: 0,0:12:10.85,0:12:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada surat di saku dalam.
Dialogue: 0,0:12:13.27,0:12:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bacalah setelah pertarungan berakhir.
Dialogue: 0,0:12:16.02,0:12:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu\N"buka saat kau dalam keadaan darurat"?
Dialogue: 0,0:12:19.11,0:12:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti gulungan teknik rahasia?
Dialogue: 0,0:12:20.65,0:12:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah hal semudah itu ada.
Dialogue: 0,0:12:23.11,0:12:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memberimu semua saranku.
Dialogue: 0,0:12:26.20,0:12:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika keadaan melampaui ekspektasi kita,
Dialogue: 0,0:12:28.66,0:12:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka kita sudah kalah dalam pertempuran ini.
Dialogue: 0,0:12:32.50,0:12:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:37.25,0:12:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Yagyu?
Dialogue: 0,0:12:39.21,0:12:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:40.21,0:12:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya.
Dialogue: 0,0:12:41.76,0:12:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mewarisi "Mata" sudah cukup?
Dialogue: 0,0:12:45.18,0:12:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih berpikir itu bukan ide bagus.
Dialogue: 0,0:12:47.76,0:12:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memutuskan.
Dialogue: 0,0:12:49.97,0:12:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau ingin menghadapi ini dengan\Nkekuatanmu sendiri, apa pun yang terjadi?
Dialogue: 0,0:12:53.73,0:12:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan mencoba sok keren.
Dialogue: 0,0:12:56.98,0:12:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan sok keren.
Dialogue: 0,0:12:59.23,0:13:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang tampak keren.
Dialogue: 0,0:13:01.44,0:13:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak
Dialogue: 0,0:13:03.53,0:13:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas bimbinganmu.
Dialogue: 0,0:13:07.82,0:13:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya,
Dialogue: 0,0:13:09.33,0:13:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia benar-benar tidak terduga.
Dialogue: 0,0:13:12.58,0:13:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau menolak?
Dialogue: 0,0:13:14.58,0:13:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dengan senang hati\Nmenerima dan menggunakan "Mata".
Dialogue: 0,0:13:16.92,0:13:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untuk keahlian pedang...
Dialogue: 0,0:13:18.13,0:13:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak puas dengan teknikku?
Dialogue: 0,0:13:20.59,0:13:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tenanglah.
Dialogue: 0,0:13:22.34,0:13:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Yagyu Shinkage-ryu Seiho."
Dialogue: 0,0:13:24.55,0:13:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengembangkannya sendiri\Nsetelah menjadi Pengembali, kan?
Dialogue: 0,0:13:28.22,0:13:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau berpikir begitu?
Dialogue: 0,0:13:30.01,0:13:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya pendapat amatir,
Dialogue: 0,0:13:32.56,0:13:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi keahlian pedangmu, Nona Yagyu...\NBagaimana mengatakannya, ya?
Dialogue: 0,0:13:35.06,0:13:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada sedikit celah di antara gerakanmu.
Dialogue: 0,0:13:39.06,0:13:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlian pedang itu,
Dialogue: 0,0:13:40.11,0:13:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa gerakan yang tidak perlu,
Dialogue: 0,0:13:42.07,0:13:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin itu dikembangkan
Dialogue: 0,0:13:44.19,0:13:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan premis memiliki "Mata".
Dialogue: 0,0:13:46.41,0:13:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabang hanya memberiku "Mata".
Dialogue: 0,0:13:49.70,0:13:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Shinkage-ryu" adalah gaya\Nyang kukembangkan setelah dapat "Mata".
Dialogue: 0,0:13:54.41,0:13:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini puncak teknik yang dioptimalkan\Nuntuk menyerang dan bertahan.
Dialogue: 0,0:13:58.42,0:14:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan orang paling berbakat
Dialogue: 0,0:14:00.09,0:14:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kesulitan menguasainya\Ndalam satu kehidupan.
Dialogue: 0,0:14:02.84,0:14:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kau bisa memilikinya\Nhanya dengan mengulurkan tangan.
Dialogue: 0,0:14:06.18,0:14:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tak bisa mencurinya.
Dialogue: 0,0:14:08.97,0:14:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu satu-satunya puncak\Nkeahlian pedang yang kau ciptakan,
Dialogue: 0,0:14:13.27,0:14:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan dengan mengorbankan\Nmenjadi Pengembali.
Dialogue: 0,0:14:16.35,0:14:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan sesuatu yang seharusnya kumiliki.
Dialogue: 0,0:14:19.10,0:14:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan membenci Pendekar Pedang Kelabu,
Dialogue: 0,0:14:22.02,0:14:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bencilah kurangnya keahlianmu sendiri."
Dialogue: 0,0:14:25.24,0:14:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja harus tetap berada di tanganmu.
Dialogue: 0,0:14:28.95,0:14:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlian pedang itu seindah tarian.
Dialogue: 0,0:14:32.87,0:14:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang aku cari
Dialogue: 0,0:14:35.79,0:14:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Muhou no Ken.
Dialogue: 0,0:14:38.79,0:14:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon itu bahkan bisa\Nmemblokir bakat Kouu.
Dialogue: 0,0:14:41.88,0:14:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berbeda dari dirinya dahulu yang\Nhalalkan segala cara untuk mencapai tujuan.
Dialogue: 0,0:14:46.34,0:14:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah semua pertemuan dan perpisahan...
Dialogue: 0,0:14:48.59,0:14:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia berubah,\Natau dia selalu seperti ini?
Dialogue: 0,0:14:50.93,0:14:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun tidak ada cara untuk mengetahuinya.
Dialogue: 0,0:14:53.56,0:14:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku yakin kau tidak tahu
Dialogue: 0,0:14:56.39,0:14:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}betapa kata-kata itu menyelamatkanku.
Dialogue: 0,0:15:00.60,0:15:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifatmu itu,\Nseolah-olah kau selalu ada untuk orang lain,
Dialogue: 0,0:15:03.57,0:15:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih penting daripada keahlian pedang.
Dialogue: 0,0:15:07.03,0:15:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa menyelamatkannya,
Dialogue: 0,0:15:09.07,0:15:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedalam apa pun keputusasaan Haito.
Dialogue: 0,0:15:14.74,0:15:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini medan perang hidup dan mati.\NOrang tak bersenjata tak punya tempat...
Dialogue: 0,0:15:17.91,0:15:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangnya ada di sini.
Dialogue: 0,0:15:20.00,0:15:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk menantangmu.
Dialogue: 0,0:15:22.42,0:15:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Yagyu?
Dialogue: 0,0:15:24.55,0:15:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka siapa pun yang memegangnya\Nadalah musuhku.
Dialogue: 0,0:15:27.46,0:15:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jika kau mau pergi, lakukan sekarang...\N- Jangan repot-repot.
Dialogue: 0,0:15:29.88,0:15:31.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius.
Dialogue: 0,0:15:31.51,0:15:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito, aku akan mengalahkanmu.
Dialogue: 0,0:15:35.14,0:15:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali tidak lucu.
Dialogue: 0,0:15:36.39,0:15:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku menang, tolong dengarkan aku.
Dialogue: 0,0:15:38.73,0:15:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaralah baik-baik denganku.
Dialogue: 0,0:15:40.10,0:15:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan hanya ditentukan\Noleh hidup dan mati.
Dialogue: 0,0:15:42.81,0:15:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah aku mendengarkanmu atau tidak,\Nitu tidak relevan.
Dialogue: 0,0:15:45.69,0:15:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang kalah, hanya ada kematian.
Dialogue: 0,0:15:56.58,0:15:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gaya, tidak ada perguruan.
Dialogue: 0,0:15:58.08,0:15:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senji Touya.
Dialogue: 0,0:15:59.75,0:16:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:16:01.46,0:16:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyamoto Musashi Harunobu.
Dialogue: 0,0:16:04.04,0:16:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dimulai.
Dialogue: 0,0:16:05.63,0:16:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertempuran panjang ini...
Dialogue: 0,0:16:17.97,0:16:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?
Dialogue: 0,0:16:20.23,0:16:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menyarungkan pedangmu?
Dialogue: 0,0:16:22.73,0:16:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan tidak pantas ditebas.
Dialogue: 0,0:16:24.48,0:16:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:16:26.15,0:16:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak seperti Miyamoto Musashi yang asli.
Dialogue: 0,0:16:30.24,0:16:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan tidak punya jejaknya!
Dialogue: 0,0:16:32.61,0:16:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka atau tidak, akan kubuat\Nkau menarik kembali kata-kata itu!
Dialogue: 0,0:16:37.91,0:16:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar. Begitu pertarungan dimulai,\Nhal pertama yang harus kau lakukan...
Dialogue: 0,0:16:41.00,0:16:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyarungkan pedangku?
Dialogue: 0,0:16:42.66,0:16:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku melakukan itu...
Dialogue: 0,0:16:44.29,0:16:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan ini akan menjadi perang atrisi.
Dialogue: 0,0:16:47.46,0:16:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,\Nkau tidak menang dengan menjatuhkan lawanmu.
Dialogue: 0,0:16:50.67,0:16:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menang dengan bertahan.
Dialogue: 0,0:16:53.63,0:16:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Lipan Hitam menginginkan kekuatan,
Dialogue: 0,0:16:56.60,0:17:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito akan menyerang lebih dahulu untuk\Nmelihat apa kau layak berduel sampai mati.
Dialogue: 0,0:17:00.93,0:17:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tidak selamat dari gelombang ini,\Nhal lain tidak penting.
Dialogue: 0,0:17:03.27,0:17:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa hubungannya dengan\Nmenyarungkan pedangku?
Dialogue: 0,0:17:07.27,0:17:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang lebih mudah, memegang pedangmu,\Natau menyarungkannya di pinggangmu?
Dialogue: 0,0:17:12.03,0:17:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuda-kuda menghunus pedang
Dialogue: 0,0:17:13.49,0:17:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyiratkan akan ada\Npertarungan hidup dan mati,
Dialogue: 0,0:17:16.36,0:17:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, staminamu cepat terkuras.
Dialogue: 0,0:17:18.78,0:17:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:17:19.91,0:17:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku tak mencoba\Nmenang dengan membunuh...
Dialogue: 0,0:17:22.29,0:17:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuncinya adalah tetap di luar jangkauan,\Nmenjaga jarak, dan menghindar.
Dialogue: 0,0:17:27.32,0:17:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tetap menyarungkan\Npedangmu lebih menguntungkan.
Dialogue: 0,0:17:29.96,0:17:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa memprovokasinya.
Dialogue: 0,0:17:32.34,0:17:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memprovokasinya?
Dialogue: 0,0:17:33.80,0:17:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar dia tidak mengira kau\Nmenghindar dengan melarikan diri.
Dialogue: 0,0:17:37.14,0:17:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya menghindar saat\Nserangan mematikannya datang.
Dialogue: 0,0:17:41.35,0:17:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:17:43.48,0:17:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata ini ada untuk tujuan itu.
Dialogue: 0,0:17:53.40,0:17:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu kemampuanmu?
Dialogue: 0,0:17:54.90,0:17:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuatku tertawa!
Dialogue: 0,0:18:02.33,0:18:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melihatnya.
Dialogue: 0,0:18:05.25,0:18:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu saja.
Dialogue: 0,0:18:07.00,0:18:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kata Nona Yagyu.
Dialogue: 0,0:18:09.38,0:18:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilah putih adalah tipuan.
Dialogue: 0,0:18:11.21,0:18:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilah hitam adalah serangan sesungguhnya.
Dialogue: 0,0:18:15.30,0:18:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan Haito dibangun di sekitar\Nkarakteristik pedang gandanya.
Dialogue: 0,0:18:19.72,0:18:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertipu oleh bilah putih.
Dialogue: 0,0:18:21.51,0:18:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap waspada dengan bilah hitam.
Dialogue: 0,0:18:24.06,0:18:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk melakukan itu...
Dialogue: 0,0:18:25.48,0:18:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus bergerak dan jaga jarak.
Dialogue: 0,0:18:27.90,0:18:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan dia menguncimu.
Dialogue: 0,0:18:29.90,0:18:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:18:35.53,0:18:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan diawasi ini...
Dialogue: 0,0:18:37.61,0:18:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:38.91,0:18:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti mata Yagyu.
Dialogue: 0,0:18:41.58,0:18:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau menerima banyak bimbingan.
Dialogue: 0,0:18:45.20,0:18:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:18:46.37,0:18:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengujimu.
Dialogue: 0,0:18:49.29,0:18:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuda-kuda itu...
Dialogue: 0,0:18:50.58,0:18:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou!
Dialogue: 0,0:18:52.54,0:18:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:18:53.80,0:18:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Enam Warna!
Dialogue: 0,0:19:05.10,0:19:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar menangkisnya.
Dialogue: 0,0:19:06.56,0:19:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Delapan Warna!
Dialogue: 0,0:19:10.31,0:19:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu bukan kebetulan?
Dialogue: 0,0:19:12.52,0:19:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan menggunakan ini...
Dialogue: 0,0:19:14.23,0:19:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:19:16.36,0:19:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nirwana: Pedang Tunggal Baja Murni!
Dialogue: 0,0:19:28.96,0:19:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou, Apratisthita: Ainuki.
Dialogue: 0,0:19:31.46,0:19:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, gerakanmu akan...
Dialogue: 0,0:19:33.13,0:19:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:36.38,0:19:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak berhasil?
Dialogue: 0,0:19:38.84,0:19:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura hitam mendalam apa itu?
Dialogue: 0,0:19:45.43,0:19:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peka terhadap kematian?
Dialogue: 0,0:19:47.72,0:19:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Tunggal Baja Murni Haito
Dialogue: 0,0:19:50.31,0:19:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Ainuki.
Dialogue: 0,0:19:52.02,0:19:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua serangan mental.
Dialogue: 0,0:19:54.23,0:19:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dilawan hanya dengan keahlian.
Dialogue: 0,0:19:57.03,0:19:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, selama tiga hari ke depan,
Dialogue: 0,0:19:59.11,0:20:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan kubunuh berulang kali
Dialogue: 0,0:20:01.45,0:20:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengatasi rasa takutmu akan kematian.
Dialogue: 0,0:20:04.07,0:20:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal semacam itu...
Dialogue: 0,0:20:05.41,0:20:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa.
Dialogue: 0,0:20:06.62,0:20:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada bedanya dengan membentuk kebiasaan.
Dialogue: 0,0:20:09.71,0:20:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak puas?
Dialogue: 0,0:20:10.79,0:20:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan begitu.
Dialogue: 0,0:20:12.92,0:20:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin tahu apa\Nperlu bertindak sejauh itu...
Dialogue: 0,0:20:16.38,0:20:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan Reinkarnasi Kembali.
Dialogue: 0,0:20:17.96,0:20:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan segera mengerti.
Dialogue: 0,0:20:21.72,0:20:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tekanannya terlalu berat untukmu.
Dialogue: 0,0:20:22.97,0:20:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reinkarnasi Kembalimu memudar.
Dialogue: 0,0:20:24.97,0:20:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mungkin berpikir\Nbisa lolos dengan luka fatal,
Dialogue: 0,0:20:28.43,0:20:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi keabadianmu\Nyang belum sempurna ada batasnya.
Dialogue: 0,0:20:31.77,0:20:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau terus menggunakan keabadian itu,
Dialogue: 0,0:20:33.60,0:20:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reinkarnasi Kembali akhirnya akan memudar.
Dialogue: 0,0:20:36.23,0:20:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu terjadi, artinya kematian.
Dialogue: 0,0:20:40.28,0:20:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengerti sekarang?
Dialogue: 0,0:20:41.86,0:20:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bisa bertarung\Nhanya dengan keabadianmu.
Dialogue: 0,0:20:44.91,0:20:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini akan berlanjut selama tiga hari.
Dialogue: 0,0:20:48.04,0:20:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan mengalami kematian berkali-kali.
Dialogue: 0,0:20:51.46,0:20:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sederhananya, itu akan seperti neraka.
Dialogue: 0,0:20:54.12,0:20:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kau mau melakukannya?
Dialogue: 0,0:20:55.75,0:20:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:20:57.17,0:20:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau masih ingin menyelamatkan Haito?
Dialogue: 0,0:21:02.72,0:21:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:21:05.64,0:21:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peka terhadap kematian bukan\Nhanya bertahan melawan teknik Haito.
Dialogue: 0,0:21:08.93,0:21:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga membantu\Nmengurangi tekanan di pihak kita.
Dialogue: 0,0:21:14.65,0:21:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:21:16.02,0:21:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyarungkan\Npedangku sampai bisa bicara denganmu.
Dialogue: 0,0:21:20.90,0:21:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang akan menang!
Dialogue: 0,0:21:23.65,0:21:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:21:25.61,0:21:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Sepuluh Warna.
Dialogue: 0,0:21:29.41,0:21:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melakukannya dengan baik,
Dialogue: 0,0:21:31.08,0:21:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi meski begitu, kau masih tidak\Nbisa menangani semua gerakan Haito?
Dialogue: 0,0:21:36.63,0:21:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:21:39.00,0:21:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Dua Belas Warna!
Dialogue: 0,0:21:46.84,0:21:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena kau!
Dialogue: 0,0:21:51.60,0:21:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, apa yang sebenarnya kau miliki?
Dialogue: 0,0:21:54.85,0:21:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan pedangnya menghantam...
Dialogue: 0,0:21:56.90,0:22:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau berhalusinasi\Nkarena sangat ingin menang?
Dialogue: 0,0:22:00.19,0:22:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kau lihat, aku tidak terluka.
Dialogue: 0,0:22:02.90,0:22:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menghindarinya sepenuhnya.
Dialogue: 0,0:22:04.44,0:22:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terpaksa menggunakan keabadianku.
Dialogue: 0,0:22:06.95,0:22:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membiarkannya tahu.
Dialogue: 0,0:22:08.74,0:22:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertarungan ketahanan
Dialogue: 0,0:22:10.74,0:22:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan perang psikologis.
Dialogue: 0,0:22:13.75,0:22:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika menurutmu aku berbohong,
Dialogue: 0,0:22:15.71,0:22:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa tidak mencoba beberapa kali lagi?
Dialogue: 0,0:22:18.17,0:22:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski menurutku itu sia-sia.
Dialogue: 0,0:22:22.92,0:22:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bertahan, apa pun yang terjadi.
Dialogue: 0,0:22:25.72,0:22:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai suaraku
Dialogue: 0,0:22:27.30,0:22:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencapai Haito!
Dialogue: 0,0:23:36.75,0:23:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir reinkarnasi.
