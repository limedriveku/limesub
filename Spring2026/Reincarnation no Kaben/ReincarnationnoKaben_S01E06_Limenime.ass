Dialogue: 0,0:01:14.99,0:01:17.99,tanda,,0000,0000,0000,,PETALS OF REINCARNATION
Dialogue: 0,0:02:40.11,0:02:42.03,tanda,,0000,0000,0000,,"MENCURI"
Dialogue: 0,0:02:42.12,0:02:42.95,tanda,,0000,0000,0000,,"SEMBUNYI DI DALAM"
Dialogue: 0,0:02:44.45,0:02:45.66,tanda,,0000,0000,0000,,"SERANG"
Dialogue: 0,0:09:53.67,0:09:54.51,tanda,,0000,0000,0000,,PERDAMAIAN DUNIA
Dialogue: 0,0:10:26.54,0:10:27.87,tanda,,0000,0000,0000,,"PENAKLUKAN SELESAI"
Dialogue: 0,0:11:22.97,0:11:26.01,tanda,,0000,0000,0000,,"EPISODE 6: SEIYA"
Dialogue: 0,0:21:06.05,0:21:07.93,tanda,,0000,0000,0000,,"HIROSHI FUNASAKA"
Dialogue: 0,0:23:38.33,0:23:40.00,tanda,,0000,0000,0000,,EPISODE 7\NPUTARAN REINKARNASI YANG TIDAK BERUJUNG
Dialogue: 0,0:01:31.46,0:01:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut kau bisa\Nsampai sejauh ini, Touya.
Dialogue: 0,0:01:35.13,0:01:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau orang dengan kemampuan terkuat\Ndalam sejarah,
Dialogue: 0,0:01:38.55,0:01:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu?
Dialogue: 0,0:01:39.93,0:01:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ya, kenapa?
Dialogue: 0,0:01:41.05,0:01:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuanku adalah
Dialogue: 0,0:01:43.85,0:01:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengumpulkan bakat.
Dialogue: 0,0:01:46.10,0:01:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan bakatmu!
Dialogue: 0,0:01:49.48,0:01:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:01:52.44,0:01:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bermain denganmu sebentar.
Dialogue: 0,0:01:58.70,0:01:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana dia?
Dialogue: 0,0:02:03.79,0:02:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi yang bagus.
Dialogue: 0,0:02:09.33,0:02:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi...
Dialogue: 0,0:02:20.47,0:02:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak apa-apa membunuhnya?
Dialogue: 0,0:02:26.98,0:02:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menguasainya.
Dialogue: 0,0:02:30.19,0:02:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena kau.
Dialogue: 0,0:02:31.81,0:02:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dia...
Dialogue: 0,0:02:32.98,0:02:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Lengan Kanan Pencuri.
Dialogue: 0,0:02:36.15,0:02:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara harfiah, artinya "mencuri".
Dialogue: 0,0:02:40.11,0:02:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mencuri ruang di dalam batu besar
Dialogue: 0,0:02:42.12,0:02:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bersembunyi di dalamnya.
Dialogue: 0,0:02:43.03,0:02:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia menyiapkan senjata dari dalam
Dialogue: 0,0:02:44.45,0:02:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk meluncurkan serangan.
Dialogue: 0,0:02:46.16,0:02:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu strategi yang bagus.
Dialogue: 0,0:02:47.87,0:02:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pandai berimprovisasi.
Dialogue: 0,0:02:50.12,0:02:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:02:53.09,0:02:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maha Mengendalikan.
Dialogue: 0,0:02:54.59,0:02:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bakatku.
Dialogue: 0,0:02:56.55,0:02:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengendalikan semua hal\Ndengan aura pertarunganku
Dialogue: 0,0:02:58.92,0:02:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengubahnya menjadi senjata.
Dialogue: 0,0:03:00.22,0:03:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:03:02.39,0:03:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua hal harus tunduk kepadaku!
Dialogue: 0,0:03:13.40,0:03:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu seharusnya cukup.
Dialogue: 0,0:03:15.86,0:03:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan hanya berdiri di sana.
Dialogue: 0,0:03:18.11,0:03:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat gunakan bakatmu untuk menyembuhkan.
Dialogue: 0,0:03:20.90,0:03:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti sakit, kan?
Dialogue: 0,0:03:25.45,0:03:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:03:27.41,0:03:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak merasakan kebencian\Ndari pria ini.
Dialogue: 0,0:03:30.58,0:03:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk ukuran Prajurit Abadi,\Nkau terlalu lama.
Dialogue: 0,0:03:33.83,0:03:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan jika kau mencuri bakat,
Dialogue: 0,0:03:35.75,0:03:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kinerjanya lebih rendah dari aslinya.
Dialogue: 0,0:03:39.09,0:03:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dalam hal rela menderita\Nuntuk mendapatkan bakat,
Dialogue: 0,0:03:42.63,0:03:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau dan kakakmu sangat mirip.
Dialogue: 0,0:03:44.85,0:03:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:03:46.51,0:03:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin melampaui Seiya, kan?
Dialogue: 0,0:03:49.06,0:03:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kenal kakakku?
Dialogue: 0,0:03:50.27,0:03:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:03:51.48,0:03:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, dia sama sepertiku,
Dialogue: 0,0:03:53.23,0:03:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}salah satu pendiri Hutan Para Legenda.
Dialogue: 0,0:03:57.11,0:04:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya adalah satu-satunya Pengembali\Nyang setara denganku,
Dialogue: 0,0:04:00.11,0:04:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tak tertandingi di bawah surga.
Dialogue: 0,0:04:03.16,0:04:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku seorang Pengembali?
Dialogue: 0,0:04:05.16,0:04:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:06.07,0:04:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau tak tahu Seiya yang sebenarnya.
Dialogue: 0,0:04:09.08,0:04:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya yang kau tahu
Dialogue: 0,0:04:11.08,0:04:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak lebih dari beberapa kenangan\Nmasa kecilmu bersamanya
Dialogue: 0,0:04:14.50,0:04:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan citra palsu dirinya sebagai orang\Nyang berkontribusi bagi dunia.
Dialogue: 0,0:04:19.63,0:04:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin tahu siapa kakakmu sebenarnya?
Dialogue: 0,0:04:22.34,0:04:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:04:25.59,0:04:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan.
Dialogue: 0,0:04:27.01,0:04:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa lalu kakakmu\Nyang tidak pernah kau ketahui.
Dialogue: 0,0:04:31.10,0:04:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan saat-saat terakhirnya.
Dialogue: 0,0:04:37.48,0:04:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa kali harus kukatakan?
Dialogue: 0,0:04:39.69,0:04:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu keras kepadanya!
Dialogue: 0,0:04:41.78,0:04:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu bodoh!
Dialogue: 0,0:04:42.95,0:04:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menghajarnya habis-habisan!
Dialogue: 0,0:04:44.95,0:04:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh, diamlah.
Dialogue: 0,0:04:46.53,0:04:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:04:48.08,0:04:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku baik-baik saja.\N- Katakan lagi!
Dialogue: 0,0:04:49.62,0:04:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku minta dia berlatih tanding denganku.\N- Kouu bodoh!
Dialogue: 0,0:04:52.41,0:04:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya,\Naku harus berterima kasih kepadanya.
Dialogue: 0,0:04:54.00,0:04:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah bicara.
Dialogue: 0,0:04:55.71,0:04:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian ada di persembunyianku?
Dialogue: 0,0:04:59.50,0:05:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann,\Njangan tinggalkan barangmu di sini!
Dialogue: 0,0:05:01.88,0:05:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga, Picasso!
Dialogue: 0,0:05:03.47,0:05:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu kaku,
Dialogue: 0,0:05:05.13,0:05:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang Terkuat di Dunia.
Dialogue: 0,0:05:06.47,0:05:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini...
Dialogue: 0,0:05:07.64,0:05:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya adalah murid kita.
Dialogue: 0,0:05:10.14,0:05:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja kita datang menemuinya.
Dialogue: 0,0:05:12.81,0:05:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sayang sekali.
Dialogue: 0,0:05:14.77,0:05:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai aku datang lebih awal,
Dialogue: 0,0:05:16.35,0:05:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa melukis latihan intens mereka.
Dialogue: 0,0:05:19.69,0:05:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa mengumpulkan data.
Dialogue: 0,0:05:21.73,0:05:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma.
Dialogue: 0,0:05:23.32,0:05:26.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang berpikiran teoretis\Ntak bisa memahami puncak seni bela diri.
Dialogue: 0,0:05:26.82,0:05:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kalau begitu...
Dialogue: 0,0:05:28.45,0:05:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan ABCDEF menjadi heksagon cembung\Nseperti AB//DE, BC//EF, dan CD//FA
Dialogue: 0,0:05:30.28,0:05:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh...
Dialogue: 0,0:05:31.62,0:05:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:05:32.74,0:05:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak mengerti pertanyaannya?
Dialogue: 0,0:05:36.17,0:05:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika itu Da Vinci,\Ndia bisa menjawabnya secara alami, bukan?
Dialogue: 0,0:05:40.09,0:05:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat yang bisa membangkitkan\Nbakat apa pun, Pusaka Semesta.
Dialogue: 0,0:05:43.55,0:05:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat Da Vinci, si polimatik.
Dialogue: 0,0:05:46.30,0:05:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat kuat.
Dialogue: 0,0:05:48.43,0:05:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat atau lambat,\Nbakatnya akan melampaui kita semua
Dialogue: 0,0:05:52.18,0:05:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjadi makhluk terhebat di dunia.
Dialogue: 0,0:05:55.52,0:05:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu terjadi, manusia mungkin\Nmenyaksikan keberadaan Dewa.
Dialogue: 0,0:06:01.11,0:06:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski memiliki bakat\Nyang bisa mengguncang dunia,
Dialogue: 0,0:06:03.94,0:06:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tidak punya ambisi atau tujuan besar,\Nhanya hidup tanpa tujuan.
Dialogue: 0,0:06:08.41,0:06:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:06:09.45,0:06:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia satu-satunya pengecualian.
Dialogue: 0,0:06:11.99,0:06:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu.
Dialogue: 0,0:06:12.99,0:06:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:06:13.91,0:06:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin meminta bantuanmu.
Dialogue: 0,0:06:17.21,0:06:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan layanan taksi, tahu.
Dialogue: 0,0:06:19.63,0:06:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:06:21.13,0:06:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu memintamu melukaiku seperti ini.
Dialogue: 0,0:06:24.00,0:06:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menggunakan bakatku\Nkecuali aku melukai seseorang.
Dialogue: 0,0:06:28.18,0:06:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tidak keberatan, aku juga tidak.
Dialogue: 0,0:06:30.59,0:06:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:06:31.60,0:06:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ikut dan melihatnya?
Dialogue: 0,0:06:34.68,0:06:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tertarik dengan urusan duniawi.
Dialogue: 0,0:06:37.64,0:06:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, akan buruk jika seseorang\Nmelihat kelopak bunga, bukan?
Dialogue: 0,0:06:41.06,0:06:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada yang menyadarinya.
Dialogue: 0,0:06:43.65,0:06:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat untuk menyembunyikan kelopak bunga.
Dialogue: 0,0:06:46.07,0:06:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mempelajarinya\Ndari penyihir modern yang hebat,
Dialogue: 0,0:06:47.95,0:06:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang Pengembali, Houdini.
Dialogue: 0,0:06:51.66,0:06:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begitu caramu berbaur\Ntanpa menarik perhatian?
Dialogue: 0,0:06:56.41,0:06:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau sudah di sini?
Dialogue: 0,0:06:58.58,0:07:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku baru saja sampai\Ndi bagian yang bagus.
Dialogue: 0,0:07:00.92,0:07:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitazuka.
Dialogue: 0,0:07:02.38,0:07:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:07:04.13,0:07:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini temanku, Kouu.
Dialogue: 0,0:07:06.92,0:07:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:07:10.18,0:07:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah, mari kita mulai saja.
Dialogue: 0,0:07:12.26,0:07:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya lagi hari ini.
Dialogue: 0,0:07:22.48,0:07:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan, Nak?
Dialogue: 0,0:07:24.31,0:07:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri?\NApa yang kau inginkan dengan kakakku?
Dialogue: 0,0:07:26.61,0:07:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau penyusup!
Dialogue: 0,0:07:27.94,0:07:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku teman Seiya.
Dialogue: 0,0:07:30.15,0:07:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adiknya Seiya?
Dialogue: 0,0:07:37.79,0:07:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau mengaguminya?
Dialogue: 0,0:07:38.95,0:07:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tujuanku!
Dialogue: 0,0:07:40.29,0:07:41.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerahlah.
Dialogue: 0,0:07:41.50,0:07:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan jadikan itu tujuanmu.
Dialogue: 0,0:07:45.04,0:07:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga?
Dialogue: 0,0:07:47.34,0:07:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga berpikir\Naku tidak kompeten, bukan?
Dialogue: 0,0:07:50.34,0:07:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, hanya saja...
Dialogue: 0,0:07:52.34,0:07:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:07:55.05,0:07:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Seiya bukan manusia lagi."
Dialogue: 0,0:07:57.56,0:08:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin aku bisa\Nmengatakan itu kepadanya.
Dialogue: 0,0:08:04.44,0:08:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi...
Dialogue: 0,0:08:09.19,0:08:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum selesai.
Dialogue: 0,0:08:11.40,0:08:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup untuk hari ini.
Dialogue: 0,0:08:14.87,0:08:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau memaksakan diri?
Dialogue: 0,0:08:19.20,0:08:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupa makan dan tidur, hanya fokus berlatih.
Dialogue: 0,0:08:22.25,0:08:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti punya tujuan.
Dialogue: 0,0:08:24.54,0:08:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau hanya ingin memenuhi\Nkeinginan kecil atau memuaskan gengsi,
Dialogue: 0,0:08:27.46,0:08:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan butuh bakat sebesar itu.
Dialogue: 0,0:08:30.38,0:08:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin menguasai dunia?
Dialogue: 0,0:08:33.01,0:08:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut.\NItulah gunanya Maha Mengendalikan.
Dialogue: 0,0:08:39.52,0:08:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa yang kau tertawakan?\N- Aduh!
Dialogue: 0,0:08:41.30,0:08:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa, hanya saja\Nkau tiba-tiba menyebutkan dunia.
Dialogue: 0,0:08:44.85,0:08:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu untuk apa?
Dialogue: 0,0:08:47.31,0:08:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi kakak yang baik.
Dialogue: 0,0:08:50.07,0:08:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya adik yang jauh lebih muda dariku.
Dialogue: 0,0:08:52.90,0:08:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak nakal itu.
Dialogue: 0,0:08:55.32,0:08:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pekerja keras, jujur, dan kompetitif.
Dialogue: 0,0:08:59.54,0:09:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu mengikuti jejakku.
Dialogue: 0,0:09:02.75,0:09:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang soal itu.
Dialogue: 0,0:09:05.33,0:09:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku juga merasa bersalah.
Dialogue: 0,0:09:07.33,0:09:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bakatku berasal dari kelopak bunga.
Dialogue: 0,0:09:11.34,0:09:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sesuatu yang kudapatkan dengan curang.
Dialogue: 0,0:09:14.13,0:09:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku tidak pernah bisa\Nmenghadapinya dengan jujur.
Dialogue: 0,0:09:17.05,0:09:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bersamanya,\Naku merasa dia akan langsung tahu.
Dialogue: 0,0:09:20.22,0:09:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau dia akan meremehkanku.
Dialogue: 0,0:09:23.06,0:09:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa pun, aku mau lakukan hal baik\Nagar bisa menghadapinya dengan benar.
Dialogue: 0,0:09:28.52,0:09:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku mengumpulkan bakat.
Dialogue: 0,0:09:32.44,0:09:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin menjadi Legenda.
Dialogue: 0,0:09:35.03,0:09:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi kakak\Nyang bisa dibanggakan adikku.
Dialogue: 0,0:09:38.16,0:09:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melakukan apa pun\Nuntuk mencapainya.
Dialogue: 0,0:09:40.83,0:09:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:09:43.83,0:09:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu?
Dialogue: 0,0:09:44.87,0:09:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya sedikit tercengang.
Dialogue: 0,0:09:47.21,0:09:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu menurutmu apa kebaikan terbesar?
Dialogue: 0,0:09:50.29,0:09:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:09:52.17,0:09:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perdamaian dunia.
Dialogue: 0,0:09:58.22,0:10:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu tertawa sekeras itu...
Dialogue: 0,0:10:00.39,0:10:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini menarik?
Dialogue: 0,0:10:02.26,0:10:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita wujudkan.
Dialogue: 0,0:10:04.64,0:10:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian!
Dialogue: 0,0:10:07.69,0:10:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti, tapi aku ikut!
Dialogue: 0,0:10:09.94,0:10:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika untuk Da Vinci, aku senang membantu!
Dialogue: 0,0:10:12.65,0:10:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:10:13.98,0:10:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menatap...
Dialogue: 0,0:10:15.61,0:10:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menolak.
Dialogue: 0,0:10:17.11,0:10:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci membuang energi\Nuntuk hal-hal yang tak memiliki jawaban.
Dialogue: 0,0:10:21.66,0:10:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:10:23.33,0:10:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menaklukkan dunia akan lebih mudah.
Dialogue: 0,0:10:25.62,0:10:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya perlu membunuh
Dialogue: 0,0:10:26.54,0:10:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua orang yang menentangmu.
Dialogue: 0,0:10:27.96,0:10:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi perdamaian dunia hanyalah fantasi.
Dialogue: 0,0:10:30.33,0:10:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelaparan, diskriminasi, agama, perang.
Dialogue: 0,0:10:33.96,0:10:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini penuh dengan masalah.
Dialogue: 0,0:10:36.09,0:10:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dengan otak iblisku ini,\Naku tidak tahu harus mulai dari mana.
Dialogue: 0,0:10:40.01,0:10:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau hanya tidak percaya diri.
Dialogue: 0,0:10:42.22,0:10:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tidak bisa, katakan saja.\NAku tidak akan memaksamu.
Dialogue: 0,0:10:45.89,0:10:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalilah tidur.
Dialogue: 0,0:10:48.19,0:10:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami akan...
Dialogue: 0,0:10:49.69,0:10:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:10:51.52,0:10:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melindasku!
Dialogue: 0,0:10:52.81,0:10:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann, aku akan membunuhmu!
Dialogue: 0,0:10:54.73,0:10:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuhku?
Dialogue: 0,0:10:56.19,0:10:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tujuan kita perdamaian dunia?
Dialogue: 0,0:11:00.36,0:11:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann...
Dialogue: 0,0:11:01.78,0:11:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainan markas rahasia sudah berakhir.
Dialogue: 0,0:11:04.79,0:11:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang memutuskan\Napa yang akan kita mulai, Seiya.
Dialogue: 0,0:11:08.12,0:11:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu...
Dialogue: 0,0:11:09.71,0:11:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tokoh berbakat dari sejarah\Nyang disatukan oleh Cabang Reinkarnasi.
Dialogue: 0,0:11:14.34,0:11:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lakukan sesuatu yang besar.
Dialogue: 0,0:11:16.46,0:11:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan Para Legenda dengan ini didirikan!
Dialogue: 0,0:11:20.43,0:11:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggu
Dialogue: 0,0:11:22.97,0:11:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seseorang seperti Seiya muncul.
Dialogue: 0,0:11:27.27,0:11:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan Para Legenda?
Dialogue: 0,0:11:28.85,0:11:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:29.89,0:11:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipimpin oleh polimatik hebat, Da Vinci,
Dialogue: 0,0:11:32.56,0:11:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencapai perdamaian dunia.
Dialogue: 0,0:11:34.82,0:11:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang organisasi\Ndengan tujuan yang sangat mulia.
Dialogue: 0,0:11:39.53,0:11:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau terdengar sangat santai?
Dialogue: 0,0:11:41.86,0:11:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu tak ada hubungannya denganku.
Dialogue: 0,0:11:43.91,0:11:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:11:45.49,0:11:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau di sini untuk menyingkirkan kami\Nyang bukan Legenda?
Dialogue: 0,0:11:50.04,0:11:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa tahu dengan menggunakan Enigma.
Dialogue: 0,0:11:52.71,0:11:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar, kan?
Dialogue: 0,0:11:54.46,0:11:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah ancaman bagi kedamaian.\NLagi pula, kami, para Pendosa,
Dialogue: 0,0:11:59.34,0:12:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara omong kosong.
Dialogue: 0,0:12:00.88,0:12:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu hanya berusaha memastikan\Nkita tak membuat masalah, jadi...
Dialogue: 0,0:12:03.59,0:12:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}D'Armont.
Dialogue: 0,0:12:04.85,0:12:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga harus mundur.
Dialogue: 0,0:12:06.89,0:12:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tidak,
Dialogue: 0,0:12:08.35,0:12:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan menjadi yang pertama mati.
Dialogue: 0,0:12:11.98,0:12:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan dahulu apa yang ingin kukatakan.
Dialogue: 0,0:12:14.65,0:12:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kalian bergabung\Ndengan Hutan Para Legenda.
Dialogue: 0,0:12:17.77,0:12:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau mendengarkanku?
Dialogue: 0,0:12:20.24,0:12:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bukan Legenda.
Dialogue: 0,0:12:22.91,0:12:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar.
Dialogue: 0,0:12:24.36,0:12:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan logika itu,\Naku juga tidak bisa bergabung.
Dialogue: 0,0:12:28.24,0:12:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Hutan Para Legenda\Nbukan karena itu perkumpulan Legenda.
Dialogue: 0,0:12:32.12,0:12:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena mereka yang berkumpul\Nakan mencapai perbuatan baik.
Dialogue: 0,0:12:36.46,0:12:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang membuat batasan itu,\Nmembedakan Legenda dan Pendosa...
Dialogue: 0,0:12:40.30,0:12:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:12:42.42,0:12:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak semudah itu.
Dialogue: 0,0:12:44.93,0:12:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak semua orang memiliki\Nsudut pandang yang sama denganmu.
Dialogue: 0,0:12:48.68,0:12:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana caranya?
Dialogue: 0,0:12:50.10,0:12:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengembali memiliki dorongan\Nyang didorong oleh bakat mereka, kan?
Dialogue: 0,0:12:53.56,0:12:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang Pendosa pada akhirnya\Nakan melakukan kejahatan.
Dialogue: 0,0:12:56.56,0:12:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:12:58.69,0:13:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mereka benar-benar dikuasai\Noleh bakat mereka,
Dialogue: 0,0:13:01.82,0:13:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akulah yang akan menghabisi mereka sendiri.
Dialogue: 0,0:13:05.95,0:13:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua mengorbankan diri\Ndemi keselamatan,
Dialogue: 0,0:13:09.20,0:13:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bakat yang kita bangkitkan\Nmalah memisahkan kita.
Dialogue: 0,0:13:12.16,0:13:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alhasil,\Nkita kehilangan tempat di dunia ini.
Dialogue: 0,0:13:15.00,0:13:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan diam saja.
Dialogue: 0,0:13:17.88,0:13:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:13:19.17,0:13:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berbahaya!
Dialogue: 0,0:13:21.09,0:13:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu, bantu aku membawa ini.
Dialogue: 0,0:13:23.84,0:13:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:13:25.30,0:13:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih punya waktu untuk membantu?
Dialogue: 0,0:13:28.18,0:13:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah memutuskan harus mulai dari mana\Ndengan Hutan Para Legenda?
Dialogue: 0,0:13:33.10,0:13:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar tidak tegas.
Dialogue: 0,0:13:36.31,0:13:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini masalah penting.
Dialogue: 0,0:13:39.77,0:13:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa mereka?
Dialogue: 0,0:13:40.82,0:13:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka rekan\Nyang dibawa Neumann.
Dialogue: 0,0:13:43.86,0:13:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan.
Dialogue: 0,0:13:45.49,0:13:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya orang\Nyang ingin kurekomendasikan.
Dialogue: 0,0:13:48.41,0:13:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya akan ada seratus.
Dialogue: 0,0:13:51.37,0:13:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka kita akan berkumpul di sini\Ndengan para Legenda sejarah.
Dialogue: 0,0:13:54.83,0:13:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menantikannya.
Dialogue: 0,0:13:58.13,0:13:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu?
Dialogue: 0,0:13:59.50,0:14:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merusak kesenanganmu,
Dialogue: 0,0:14:01.80,0:14:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kebanyakan orang yang kubawa\Ntak punya bakat Legenda.
Dialogue: 0,0:14:07.09,0:14:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, bisakah kau menerima mereka?
Dialogue: 0,0:14:09.43,0:14:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:14:11.14,0:14:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama mereka temanmu.
Dialogue: 0,0:14:12.93,0:14:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua.
Dialogue: 0,0:14:14.47,0:14:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti bermalas-malasan dan bantu aku!
Dialogue: 0,0:14:17.35,0:14:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:14:19.02,0:14:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Seiya.
Dialogue: 0,0:14:20.23,0:14:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:22.15,0:14:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan yang putus asa dan memilih menyerah\Npada nasib berkumpul bersama,
Dialogue: 0,0:14:26.36,0:14:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menuju cita-cita yang tampak bodoh,\Nmendapatkan kembali harapan, dan bersatu.
Dialogue: 0,0:14:31.49,0:14:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada inti dari semua ini,
Dialogue: 0,0:14:33.04,0:14:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami membutuhkan seseorang seperti Seiya.
Dialogue: 0,0:14:35.79,0:14:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sepertiku, yang hanya bisa\Nmenyakiti orang lain, tidak akan berhasil.
Dialogue: 0,0:14:39.96,0:14:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin hanya Seiya,\Ndengan kebaikannya yang tidak terbatas,
Dialogue: 0,0:14:42.59,0:14:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bisa memimpin kami.
Dialogue: 0,0:14:47.26,0:14:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ada apa?
Dialogue: 0,0:14:49.93,0:14:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan hanya memanggil anggota pendiri?
Dialogue: 0,0:14:52.76,0:14:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memutuskan\Napa yang akan kita mulai.
Dialogue: 0,0:14:55.27,0:14:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akhirnya memutuskan?
Dialogue: 0,0:14:57.43,0:14:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jelas membuat kami tegang.
Dialogue: 0,0:14:59.39,0:15:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi? Kita mulai dari mana...
Dialogue: 0,0:15:03.11,0:15:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya?
Dialogue: 0,0:15:05.19,0:15:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ada apa? Kenapa wajahmu seperti itu?
Dialogue: 0,0:15:07.49,0:15:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau habis menangis?\N- Aku baik-baik saja.
Dialogue: 0,0:15:09.78,0:15:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih penting,\Ntujuan Hutan Para Legenda kita,
Dialogue: 0,0:15:13.16,0:15:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langkah pertama menuju perdamaian dunia,
Dialogue: 0,0:15:16.16,0:15:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah memusnahkan\NPengembali kelas Pendosa.
Dialogue: 0,0:15:21.29,0:15:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika perdamaian dunia\Nhanya bisa dicapai melalui Pengembali,
Dialogue: 0,0:15:24.46,0:15:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka yang menggulingkan perdamaian itu\Njuga akan menjadi Pengembali.
Dialogue: 0,0:15:27.55,0:15:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langkah pertama kita adalah\Nmelenyapkan elemen berbahaya ini.
Dialogue: 0,0:15:30.63,0:15:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:15:32.14,0:15:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan yang kita sepakati.
Dialogue: 0,0:15:34.30,0:15:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau yang bilang\NDa Vinci harus menentukan arah kita?
Dialogue: 0,0:15:38.64,0:15:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan memintamu\Nmenjelaskan alasanmu mengatakan ini.
Dialogue: 0,0:15:41.69,0:15:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik kembali ucapanmu sekarang juga!
Dialogue: 0,0:15:44.27,0:15:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meminta Neumann menyelidiki
Dialogue: 0,0:15:46.98,0:15:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah Pengembali terlibat dalam kejahatan.
Dialogue: 0,0:15:51.24,0:15:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah orang yang dikuasai\Noleh bakat mereka
Dialogue: 0,0:15:53.91,0:15:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tampaknya meningkat pesat.
Dialogue: 0,0:15:56.58,0:15:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masyarakat belum tahu soal Pengembali.
Dialogue: 0,0:15:59.41,0:16:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak bisa menangani bakat kuat itu.
Dialogue: 0,0:16:02.50,0:16:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kita yang bisa menghentikan mereka.
Dialogue: 0,0:16:05.50,0:16:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:16:06.88,0:16:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikku
Dialogue: 0,0:16:08.76,0:16:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diserang.
Dialogue: 0,0:16:11.93,0:16:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat usaha semua orang,\Nkita berhasil mengusir Pengembali.
Dialogue: 0,0:16:15.93,0:16:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik Seiya hampir tidak selamat.
Dialogue: 0,0:16:19.27,0:16:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mengumpulkan informasi\Ntentang lukanya dan orang yang dia hadapi,
Dialogue: 0,0:16:23.52,0:16:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami mengetahui bahwa pelakunya adalah...
Dialogue: 0,0:16:24.65,0:16:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu yang terjadi...
Dialogue: 0,0:16:26.44,0:16:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa diam saja...
Dialogue: 0,0:16:30.07,0:16:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaulah pegangan hidup Seiya.
Dialogue: 0,0:16:33.28,0:16:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi kau,\Ndia bisa menyelamatkan seluruh dunia.
Dialogue: 0,0:16:36.78,0:16:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika seseorang mencoba menyakitimu...
Dialogue: 0,0:16:40.08,0:16:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku sudah memutuskan.
Dialogue: 0,0:16:42.16,0:16:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melenyapkan\Nsemua Pengembali kelas Pendosa.
Dialogue: 0,0:16:45.08,0:16:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:16:46.34,0:16:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan di antara para Pendosa,
Dialogue: 0,0:16:47.63,0:16:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada banyak yang tidak berbahaya.\NSetidaknya kau harus...
Dialogue: 0,0:16:49.96,0:16:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi kita sibuk bersikap selektif,
Dialogue: 0,0:16:51.51,0:16:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}korban kedua atau ketiga bisa muncul!
Dialogue: 0,0:16:54.64,0:16:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti konsekuensinya tidak bisa diubah.
Dialogue: 0,0:16:57.55,0:17:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendosa pada dasarnya\Nadalah ancaman bagi kedamaian!
Dialogue: 0,0:17:03.64,0:17:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mulailah dari aku.
Dialogue: 0,0:17:06.02,0:17:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar para Pendosa\Nmenimbulkan bahaya.
Dialogue: 0,0:17:10.73,0:17:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah berbuat\Nsalah besar terhadap mereka.
Dialogue: 0,0:17:14.31,0:17:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memberi mereka harapan.
Dialogue: 0,0:17:17.24,0:17:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus mencapai kedamaian dunia itu.
Dialogue: 0,0:17:22.54,0:17:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:24.04,0:17:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu artinya aku tidak perlu mati?
Dialogue: 0,0:17:26.79,0:17:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita rekan?
Dialogue: 0,0:17:30.71,0:17:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:17:32.80,0:17:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakatku adalah raja tiran\Nyang membantai 200.000 orang!
Dialogue: 0,0:17:36.64,0:17:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau ingin aku hidup?
Dialogue: 0,0:17:38.43,0:17:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kenapa jika kita rekan?
Dialogue: 0,0:17:40.10,0:17:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, para Pendosa itu juga rekanku!
Dialogue: 0,0:17:42.98,0:17:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyuruhku diam saja?
Dialogue: 0,0:17:44.48,0:17:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat rekan-rekanku\Ndibunuh olehmu satu per satu?
Dialogue: 0,0:17:47.15,0:17:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau apa?
Dialogue: 0,0:17:48.40,0:17:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin aku membantumu membunuh mereka?
Dialogue: 0,0:17:49.90,0:17:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan!
Dialogue: 0,0:17:51.32,0:17:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kapan kau akan mempermalukanku,
Dialogue: 0,0:17:54.15,0:17:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya?
Dialogue: 0,0:17:55.65,0:17:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku bukan begitu...
Dialogue: 0,0:17:57.45,0:18:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bukan mainan bagi orang sepertimu,
Dialogue: 0,0:18:00.53,0:18:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tidak punya tekad\Ndan hanya memikirkan diri sendiri.
Dialogue: 0,0:18:03.95,0:18:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pernyataan perang.
Dialogue: 0,0:18:06.58,0:18:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, Kouu!
Dialogue: 0,0:18:15.05,0:18:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:18:19.85,0:18:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mendaratkan pukulan telak.
Dialogue: 0,0:18:31.65,0:18:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan, Seiya?
Dialogue: 0,0:18:34.61,0:18:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan melepaskanku?
Dialogue: 0,0:18:37.20,0:18:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin membunuh semua Pendosa\Natau menyelamatkan mereka...?
Dialogue: 0,0:18:44.24,0:18:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, bukan?
Dialogue: 0,0:18:46.91,0:18:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:18:49.29,0:18:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:18:50.50,0:18:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau memang tidak pernah tegas?
Dialogue: 0,0:18:53.13,0:18:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:54.67,0:18:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bukan tipe orang\Nyang menyakiti orang lain sendirian.
Dialogue: 0,0:18:58.93,0:19:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarahanmu karena adikmu terluka\Nmendorongmu ke keputusan ekstrem ini.
Dialogue: 0,0:19:04.47,0:19:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada harapan.
Dialogue: 0,0:19:05.72,0:19:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami masih bisa memperbaiki hubungan ini.
Dialogue: 0,0:19:13.27,0:19:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri tahu adikku...
Dialogue: 0,0:19:16.65,0:19:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Maafkan aku karena tidak pernah\Nmenjadi kakak yang seharusnya."
Dialogue: 0,0:19:23.49,0:19:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan orang yang lembut sepertimu.
Dialogue: 0,0:19:27.00,0:19:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada yang ingin kau katakan,\Nkatakan sendiri.
Dialogue: 0,0:19:30.04,0:19:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:32.58,0:19:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menghadapinya dengan benar.
Dialogue: 0,0:19:34.67,0:19:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:19:36.21,0:19:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia akan memaafkanmu.
Dialogue: 0,0:19:38.22,0:19:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adik yang kau banggakan, bukan?
Dialogue: 0,0:19:40.51,0:19:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbaikilah hubunganmu dengannya\Nmulai sekarang.
Dialogue: 0,0:19:44.18,0:19:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, bukan?
Dialogue: 0,0:19:45.64,0:19:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya...
Dialogue: 0,0:19:47.02,0:19:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:19:48.43,0:19:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:19:51.14,0:19:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku tidak membebaninya\Ndengan harapan besar perdamaian dunia.
Dialogue: 0,0:19:54.77,0:19:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup demi adiknya saja
Dialogue: 0,0:19:57.15,0:19:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah menjadi kebahagiaan terbesarnya.
Dialogue: 0,0:20:00.65,0:20:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang membunuhnya.
Dialogue: 0,0:20:02.49,0:20:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan minta maaf.
Dialogue: 0,0:20:07.66,0:20:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:20:10.62,0:20:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku bukan genius.\NDia seorang Pengembali.
Dialogue: 0,0:20:14.50,0:20:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu menderita karena itu.
Dialogue: 0,0:20:17.25,0:20:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang lebih penting,\Ndia selalu memikirkanku.
Dialogue: 0,0:20:21.72,0:20:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merasa dia ada di sisiku,
Dialogue: 0,0:20:23.72,0:20:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa terselamatkan.
Dialogue: 0,0:20:26.01,0:20:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja?
Dialogue: 0,0:20:27.64,0:20:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa mengatakan lebih dari itu.
Dialogue: 0,0:20:31.19,0:20:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau tidak menunjukkan masa lalu\Nhanya untuk mengatakan yang sebenarnya.
Dialogue: 0,0:20:35.98,0:20:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin aku melakukan sesuatu.
Dialogue: 0,0:20:38.15,0:20:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:20:41.70,0:20:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan Neumann.
Dialogue: 0,0:20:43.66,0:20:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:20:47.49,0:20:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:20:49.04,0:20:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Hutan Para Legenda berhenti\Nmenyingkirkan Pendosa, kedua pihak bisa...
Dialogue: 0,0:20:52.75,0:20:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah itu sudah selesai.
Dialogue: 0,0:20:56.96,0:20:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau datang ke sini,\Nkau pasti sudah melihatnya.
Dialogue: 0,0:21:01.13,0:21:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kami adalah pemusnahan total.
Dialogue: 0,0:21:03.63,0:21:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kami memasang batu nisan.
Dialogue: 0,0:21:06.05,0:21:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada makam untuk Legenda juga.
Dialogue: 0,0:21:08.43,0:21:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami diperintahkan untuk berduka\Nmeski mereka musuh.
Dialogue: 0,0:21:12.39,0:21:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami mengukir nama\Nyang muncul dalam ramalan.
Dialogue: 0,0:21:16.10,0:21:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:21:17.86,0:21:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika masalah Kelas Pendosa terpecahkan,
Dialogue: 0,0:21:20.23,0:21:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka Neumann dan yang lain\Ndi Hutan Para Legenda
Dialogue: 0,0:21:22.03,0:21:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga akan berhenti, kan?
Dialogue: 0,0:21:23.61,0:21:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil.
Dialogue: 0,0:21:25.53,0:21:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann pasti merencanakan sesuatu.
Dialogue: 0,0:21:29.45,0:21:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin melakukannya
Dialogue: 0,0:21:30.62,0:21:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan dalih idealisme Seiya yang mulia\Nuntuk perdamaian dunia.
Dialogue: 0,0:21:34.33,0:21:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika begitu,\Napa yang akan dia lakukan selanjutnya?
Dialogue: 0,0:21:37.21,0:21:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah membunuh semua\NPengembali kelas Pendosa saat ini,
Dialogue: 0,0:21:39.75,0:21:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siapa yang akan dia bunuh selanjutnya?
Dialogue: 0,0:21:41.84,0:21:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah...
Dialogue: 0,0:21:45.43,0:21:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur, Touya.
Dialogue: 0,0:21:46.80,0:21:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga, berlindung di belakangku.
Dialogue: 0,0:21:51.60,0:21:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu, aku kembali!
Dialogue: 0,0:21:54.27,0:21:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh pria dengan waktu yang tidak tepat.
Dialogue: 0,0:21:56.60,0:21:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Caesar?
Dialogue: 0,0:21:58.02,0:21:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini bisa terjadi?
Dialogue: 0,0:21:59.40,0:22:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia salah satu dari Lima Jenderal Harimau.
Dialogue: 0,0:22:01.61,0:22:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata-mata yang kutanam di sana.
Dialogue: 0,0:22:05.11,0:22:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yagyu!
Dialogue: 0,0:22:07.07,0:22:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan biarkan dia mati.
Dialogue: 0,0:22:13.20,0:22:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musashi datang.
Dialogue: 0,0:22:18.21,0:22:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:22:20.17,0:22:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito...
Dialogue: 0,0:23:36.33,0:23:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putaran reinkarnasi yang tidak berujung.
