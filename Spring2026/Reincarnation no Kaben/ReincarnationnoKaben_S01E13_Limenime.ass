Dialogue: 0,0:00:39.91,0:00:41.16,sign,,0000,0000,0000,,MAYAT EMPAT BELAS WARNA
Dialogue: 0,0:20:48.79,0:20:49.62,sign,,0000,0000,0000,,SEMINGGU KEMUDIAN\NJANJI: NAMA INI AKAN BERTINDAK BERSAMA
Dialogue: 0,0:20:49.70,0:20:50.79,sign,,0000,0000,0000,,FRANZ A. MESMER, TOUYA SENJI, J. HENRI,\NHAITO LUO BUFFETT, KITAZUKA, A. EINSTEIN
Dialogue: 0,0:21:19.53,0:21:20.98,sign,,0000,0000,0000,,EPISODE 13\NAKHIR REINKARNASI
Dialogue: 0,0:00:08.21,0:00:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sekali...
Dialogue: 0,0:00:10.30,0:00:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertempuran ini sudah berlangsung\Nterlalu lama.
Dialogue: 0,0:00:14.13,0:00:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah membayangkan\Nobsesi Haito, kegigihannya,
Dialogue: 0,0:00:17.64,0:00:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa sekuat ini...
Dialogue: 0,0:00:22.23,0:00:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlepas dari batas fisik Touya,
Dialogue: 0,0:00:24.69,0:00:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia sudah menggunakan\Nsemua sisa daya keabadiannya.
Dialogue: 0,0:00:27.94,0:00:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya bertahan dengan tekad belaka.
Dialogue: 0,0:00:30.78,0:00:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika terus begini...
Dialogue: 0,0:00:33.90,0:00:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:00:35.99,0:00:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Empat Belas Warna!
Dialogue: 0,0:00:45.00,0:00:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito,
Dialogue: 0,0:00:46.33,0:00:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kau tidak mengerti?
Dialogue: 0,0:00:48.42,0:00:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekosongan yang kau rasakan\Nsaat melakukan teknikmu.
Dialogue: 0,0:00:50.75,0:00:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlian pedangmu hanya tambal sulam\Ndari gaya yang berbeda.
Dialogue: 0,0:00:54.93,0:00:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Berwarna.
Dialogue: 0,0:00:56.39,0:00:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rangkaian tebasan itu
Dialogue: 0,0:00:57.89,0:01:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berasal dari legenda memotong ranting dedalu\Nmenjadi 13 bagian
Dialogue: 0,0:01:01.06,0:01:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum menyentuh air.
Dialogue: 0,0:01:02.47,0:01:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Yanagi Jusan-dan" oleh\NMinamoto no Yoshitsune dari Kyohachi-ryu.
Dialogue: 0,0:01:07.15,0:01:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ainuki melampaui kehancuran bersama.
Dialogue: 0,0:01:09.82,0:01:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kondisi terbaik dari Mujushin-kenjutsu,
Dialogue: 0,0:01:11.98,0:01:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ainuke" oleh Harigaya Sekiun.
Dialogue: 0,0:01:15.74,0:01:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Tunggal Baja Murni
Dialogue: 0,0:01:17.36,0:01:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah "Hassun no Nobegane"\NOgasawara Nagaharu
Dialogue: 0,0:01:20.24,0:01:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari Shin Shinkage-ryu yang tak terkalahkan.
Dialogue: 0,0:01:25.12,0:01:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir tidak ada Niten Ichi-ryu di sana.
Dialogue: 0,0:01:28.63,0:01:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti karena aku juga ahli pedang.
Dialogue: 0,0:01:31.13,0:01:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:01:32.63,0:01:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya,
Dialogue: 0,0:01:34.46,0:01:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak benar-benar ingin\Nmenjadi Miyamoto Musashi.
Dialogue: 0,0:01:38.14,0:01:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya ingin menjadi lebih kuat,
Dialogue: 0,0:01:41.22,0:01:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar orang selain dirimu...\Nagar orang itu mengakuimu.
Dialogue: 0,0:01:47.44,0:01:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau menyimpan kontradiksi itu,
Dialogue: 0,0:01:50.36,0:01:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak bisa menjadi Pengembali Lengkap.
Dialogue: 0,0:01:53.98,0:01:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi meski begitu,\Nuntuk menguasai berbagai teknik,
Dialogue: 0,0:01:57.86,0:02:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku hanya bisa membayangkan usaha keras\Nyang sudah kau lakukan.
Dialogue: 0,0:02:02.83,0:02:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, Haito,
Dialogue: 0,0:02:05.08,0:02:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus merebut kembali dirimu\Nyang pernah kau tinggalkan.
Dialogue: 0,0:02:09.03,0:02:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau melakukannya sekarang,
Dialogue: 0,0:02:11.88,0:02:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau masih bisa kembali!
Dialogue: 0,0:02:23.68,0:02:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:02:26.31,0:02:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Tunggal Baja Murni!
Dialogue: 0,0:02:37.44,0:02:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:38.61,0:02:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tipuan?
Dialogue: 0,0:02:40.78,0:02:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematian sesaatnya memperlambat reaksi lawan,\Ndan dia memanfaatkannya.
Dialogue: 0,0:02:48.25,0:02:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berakhir.
Dialogue: 0,0:02:49.79,0:02:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah.
Dialogue: 0,0:02:51.38,0:02:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlibat denganku lagi.
Dialogue: 0,0:03:00.43,0:03:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya...
Dialogue: 0,0:03:01.51,0:03:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini belum berakhir...
Dialogue: 0,0:03:04.14,0:03:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih bisa bertarung!
Dialogue: 0,0:03:16.32,0:03:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:18.74,0:03:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau!
Dialogue: 0,0:03:23.74,0:03:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini belum berakhir!
Dialogue: 0,0:03:37.17,0:03:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan...
Dialogue: 0,0:03:38.76,0:03:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu aku!
Dialogue: 0,0:03:53.52,0:03:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini akhirnya?
Dialogue: 0,0:03:55.27,0:03:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan luka seperti itu, seharusnya dia\Ntak bisa pakai Reinkarnasi Kembali lagi...
Dialogue: 0,0:04:01.03,0:04:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakanku berikutnya akan menjadi\Nyang terakhir bagimu.
Dialogue: 0,0:04:04.62,0:04:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh akan melakukan ini?
Dialogue: 0,0:04:16.20,0:04:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:04:18.08,0:04:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau sangat peduli kepadaku?
Dialogue: 0,0:04:22.01,0:04:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sampai memaksakan diri sejauh ini?
Dialogue: 0,0:04:24.34,0:04:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang...
Dialogue: 0,0:04:27.55,0:04:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bicara denganmu.
Dialogue: 0,0:04:31.93,0:04:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai saat itu, selama apa pun,
Dialogue: 0,0:04:34.14,0:04:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau berapa kali pun kita bertarung,\Naku dengan senang hati akan melawanmu.
Dialogue: 0,0:04:40.11,0:04:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara...
Dialogue: 0,0:04:47.57,0:04:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa akhirnya dia siap bicara?
Dialogue: 0,0:04:51.66,0:04:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah saat yang menentukan...
Dialogue: 0,0:04:56.29,0:04:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia memakai logika dingin\Nseperti sebelumnya,
Dialogue: 0,0:04:58.54,0:05:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tidak akan bisa menembus pertahanannya.
Dialogue: 0,0:05:01.67,0:05:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia mendorongnya terlalu keras,\NLipan Hitam itu mungkin akan muncul kembali.
Dialogue: 0,0:05:05.68,0:05:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu terjadi,
Dialogue: 0,0:05:07.01,0:05:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita tidak punya pilihan selain...
Dialogue: 0,0:05:08.39,0:05:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gunanya bicara sekarang?
Dialogue: 0,0:05:11.01,0:05:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya, kau ingin melenyapkan semua Pengembali,\Ntermasuk dirimu sendiri, kan?
Dialogue: 0,0:05:15.69,0:05:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau melakukan itu, aku juga akan mati.
Dialogue: 0,0:05:17.48,0:05:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa kau tidak bisa\Nmembiarkanku saja?
Dialogue: 0,0:05:19.77,0:05:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berusaha maksimal,\Ntapi ini belum berakhir.
Dialogue: 0,0:05:23.44,0:05:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak melakukan kesalahan.\NKau hanya kurang berusaha.
Dialogue: 0,0:05:26.66,0:05:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak memikirkannya baik-baik\Natau memilih kata yang tepat.
Dialogue: 0,0:05:29.91,0:05:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:05:31.03,0:05:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kukatakan?
Dialogue: 0,0:05:33.08,0:05:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerahkan seluruh kemampuanmu,\Nbaik itu metode atau kata-katamu.
Dialogue: 0,0:05:36.50,0:05:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin aku bisa membiarkanmu.
Dialogue: 0,0:05:39.84,0:05:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito, kau satu-satunya teman\Nyang memberiku alasan untuk melangkah maju...
Dialogue: 0,0:05:45.47,0:05:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga penolongku.
Dialogue: 0,0:05:48.22,0:05:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kita berpisah dengan buruk,\Naku masih ingin bicara baik-baik denganmu.
Dialogue: 0,0:05:52.68,0:05:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:05:54.35,0:05:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"ingin bicara" mungkin\Nhanya angan-anganku sendiri.
Dialogue: 0,0:05:57.44,0:05:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memaksakannya kepadamu itu salah.
Dialogue: 0,0:06:00.81,0:06:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:06:02.40,0:06:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah datang jauh-jauh kemari...
Dialogue: 0,0:06:03.78,0:06:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:06:05.32,0:06:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan mengatakan yang ingin kukatakan.
Dialogue: 0,0:06:07.82,0:06:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujudmu setelah Reinkarnasi Kembali
Dialogue: 0,0:06:10.37,0:06:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menakjubkan.
Dialogue: 0,0:06:12.66,0:06:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut hitam dan mata indahmu...
Dialogue: 0,0:06:15.37,0:06:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin "bermartabat" adalah kata yang tepat.
Dialogue: 0,0:06:17.04,0:06:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memiliki keanggunan Jepang yang khas.
Dialogue: 0,0:06:19.88,0:06:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku
Dialogue: 0,0:06:22.38,0:06:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih lebih suka rambut\Ndan mata abu-abu aslimu.
Dialogue: 0,0:06:26.67,0:06:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah yang ingin kau katakan kepadaku
Dialogue: 0,0:06:30.72,0:06:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah bertarung selama ini?
Dialogue: 0,0:06:33.97,0:06:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:39.77,0:06:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:06:42.69,0:06:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar cantik...
Dialogue: 0,0:06:48.82,0:06:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Haito.
Dialogue: 0,0:06:53.20,0:06:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menepati janjiku hari itu.
Dialogue: 0,0:06:57.20,0:07:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengasah\Nkeahlian pedang ini lebih jauh.
Dialogue: 0,0:07:00.58,0:07:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengasah diriku\Nsampai kau ingin mencurinya.
Dialogue: 0,0:07:05.38,0:07:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:07:07.09,0:07:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengumpulkan bakat\Nyang sama bagusnya dengan bakatmu.
Dialogue: 0,0:07:11.26,0:07:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:07:14.05,0:07:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua gagal, bukan?
Dialogue: 0,0:07:17.72,0:07:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kita gagal total.
Dialogue: 0,0:07:22.02,0:07:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa mengejar apa pun.
Dialogue: 0,0:07:25.32,0:07:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa memahami apa pun.
Dialogue: 0,0:07:28.69,0:07:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mungkin lebih baik seperti ini.
Dialogue: 0,0:07:31.86,0:07:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:33.12,0:07:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih seperti biasanya.
Dialogue: 0,0:07:36.29,0:07:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:07:37.37,0:07:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku masih tidak bisa berhenti berjuang.
Dialogue: 0,0:07:42.00,0:07:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian karena kekacauan
Dialogue: 0,0:07:44.13,0:07:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akibat para Pengembali ini\Nberkaitan dengan kakakku...
Dialogue: 0,0:07:47.63,0:07:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi terutama,\Nkarena aku ingin mengakhirinya sendiri.
Dialogue: 0,0:07:51.80,0:07:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu "melenyapkan semua Pengembali"?
Dialogue: 0,0:07:55.97,0:07:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:57.14,0:08:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu jawaban yang kau dapatkan\Nsetelah pertimbangan matang,
Dialogue: 0,0:08:00.89,0:08:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka itu pasti tindakan yang tepat.
Dialogue: 0,0:08:04.31,0:08:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:08:06.06,0:08:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita tidak menjadi Pengembali,
Dialogue: 0,0:08:09.23,0:08:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurutmu hidup seperti\Napa yang akan kita jalani?
Dialogue: 0,0:08:11.74,0:08:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita tidak menjadi Pengembali...
Dialogue: 0,0:08:15.28,0:08:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak bisa membayangkannya.
Dialogue: 0,0:08:17.62,0:08:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:19.04,0:08:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita masih ingat saat kita\Nmemilih menjadi Pengembali.
Dialogue: 0,0:08:25.54,0:08:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih ingat.
Dialogue: 0,0:08:28.59,0:08:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah itu menggorok leherku sendiri\Ndengan "Cabang" di tangan,
Dialogue: 0,0:08:31.63,0:08:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menggunakan keadaan\Ndan usahaku sebagai alasan
Dialogue: 0,0:08:34.51,0:08:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membenarkan menjadi Pengembali...
Dialogue: 0,0:08:38.47,0:08:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau rasa bersalah yang kurasakan
Dialogue: 0,0:08:40.89,0:08:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setiap kali melakukan Reinkarnasi Kembali.
Dialogue: 0,0:08:43.85,0:08:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sederhananya, aku menyerah.
Dialogue: 0,0:08:47.15,0:08:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menetapkan batasanku\Nsendiri dan menyerah.
Dialogue: 0,0:08:50.65,0:08:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpikir, "Tak bisa berusaha lebih keras,"\Ndan "Itu tidak akan mengarah ke apa pun."
Dialogue: 0,0:08:54.03,0:08:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tidak akan ada yang mengakuiku."
Dialogue: 0,0:08:58.20,0:09:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku menerima Cabang,
Dialogue: 0,0:09:00.12,0:09:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin ada versi diriku yang berpikir,
Dialogue: 0,0:09:01.37,0:09:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bahkan tanpa ini, aku akan membuat\Nsemua orang duduk dan memperhatikan,"
Dialogue: 0,0:09:03.50,0:09:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu membuangnya dan kembali ke mejaku.
Dialogue: 0,0:09:07.88,0:09:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika versi diriku yang itu ada,
Dialogue: 0,0:09:09.25,0:09:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin melihat masa depannya.
Dialogue: 0,0:09:11.67,0:09:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku yakin dia akan\Nmenjalani hidupnya dengan maksimal.
Dialogue: 0,0:09:14.55,0:09:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang sama berlaku untukmu, Haito.
Dialogue: 0,0:09:17.01,0:09:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan tanpa menjadi Pengembali,
Dialogue: 0,0:09:18.85,0:09:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bisa diingat\Nsebagai pendekar pedang legendaris.
Dialogue: 0,0:09:22.47,0:09:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin kau akan memperluas wawasanmu
Dialogue: 0,0:09:24.35,0:09:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menggunakan hasrat alamimu\Nuntuk bersinar melampaui dunia kendo.
Dialogue: 0,0:09:29.48,0:09:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin sesempurna itu.
Dialogue: 0,0:09:31.98,0:09:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin tidak bersinar sama sekali.
Dialogue: 0,0:09:34.61,0:09:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kerja keras tidak selalu\Nmembuahkan hasil.
Dialogue: 0,0:09:36.99,0:09:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyangkalnya.
Dialogue: 0,0:09:38.37,0:09:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kau harus menyangkalnya!
Dialogue: 0,0:09:42.54,0:09:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, kisah kita adalah masa lalu.
Dialogue: 0,0:09:45.54,0:09:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:09:47.00,0:09:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dunia ini penuh dengan orang
Dialogue: 0,0:09:50.17,0:09:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sama seperti kita dahulu.
Dialogue: 0,0:09:55.55,0:09:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesuksesan, kegagalan, dan ketenaran
Dialogue: 0,0:09:59.14,0:10:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang pantas mereka dapatkan...
Dialogue: 0,0:10:00.47,0:10:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat mereka di dunia\Ndan masa depan mereka...
Dialogue: 0,0:10:03.18,0:10:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika para Pengembali akan merebutnya\Ndengan kejam,
Dialogue: 0,0:10:08.31,0:10:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka aku akan melawan.
Dialogue: 0,0:10:10.44,0:10:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan mengakhiri ini.
Dialogue: 0,0:10:12.82,0:10:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku sudah siap untuk itu.
Dialogue: 0,0:10:16.03,0:10:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku sudah memutuskan.
Dialogue: 0,0:10:19.57,0:10:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika memegang Benih itu sekarang,
Dialogue: 0,0:10:22.87,0:10:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin aku akan ragu.
Dialogue: 0,0:10:26.58,0:10:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali memikirkan semua orang\Nyang kutemui di sepanjang jalan...
Dialogue: 0,0:10:30.42,0:10:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya
Dialogue: 0,0:10:31.79,0:10:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin kau tetap di sisiku.
Dialogue: 0,0:10:34.00,0:10:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kau menjagaku.
Dialogue: 0,0:10:37.26,0:10:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar aku tidak akan lari lagi.
Dialogue: 0,0:10:40.09,0:10:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar aku bisa menyelesaikan ini.
Dialogue: 0,0:10:42.39,0:10:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku tidak bisa menerimanya.
Dialogue: 0,0:10:45.27,0:10:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau hanya melihat.
Dialogue: 0,0:10:47.94,0:10:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, aku akan menjadi pedangmu.
Dialogue: 0,0:10:50.94,0:10:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika percikan terbang ke arahmu,\Naku akan menjatuhkannya.
Dialogue: 0,0:10:53.52,0:10:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dibutuhkan tekad,\Naku akan berdiri di depanmu.
Dialogue: 0,0:10:56.49,0:10:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, biarkan aku tetap bersamamu
Dialogue: 0,0:10:58.86,0:11:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai akhir.
Dialogue: 0,0:11:01.99,0:11:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya bercanda.
Dialogue: 0,0:11:06.62,0:11:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:11:08.21,0:11:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah mengakuiku.
Dialogue: 0,0:11:10.96,0:11:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena membutuhkanku.
Dialogue: 0,0:11:12.67,0:11:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu terima kasih.
Dialogue: 0,0:11:14.84,0:11:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali.
Dialogue: 0,0:11:17.63,0:11:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:11:19.22,0:11:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini akan menjadi\Npertarungan panjang,
Dialogue: 0,0:11:21.68,0:11:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kurasa ini patut dirayakan.
Dialogue: 0,0:11:24.26,0:11:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali,
Dialogue: 0,0:11:25.43,0:11:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:11:26.39,0:11:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubei,
Dialogue: 0,0:11:27.64,0:11:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maaf sudah merepotkanmu...
Dialogue: 0,0:11:28.81,0:11:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:11:29.73,0:11:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak boleh membicarakan masa lalu,
Dialogue: 0,0:11:32.44,0:11:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tentang masa depan.
Dialogue: 0,0:11:34.06,0:11:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengerti?
Dialogue: 0,0:11:36.78,0:11:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, tapi...
Dialogue: 0,0:11:38.53,0:11:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua harus banyak\Nberistirahat sekarang.
Dialogue: 0,0:11:42.57,0:11:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:11:44.83,0:11:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa bantuan Nona Yagyu,\Nkita tidak akan sampai sejauh ini.
Dialogue: 0,0:11:48.70,0:11:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membalas kebaikan ini\Nsedikit demi sedikit mulai sekarang.
Dialogue: 0,0:11:52.04,0:11:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:11:53.50,0:11:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya melakukan yang kuinginkan.
Dialogue: 0,0:11:57.30,0:11:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengakhiri siklus dosa ini.
Dialogue: 0,0:12:00.26,0:12:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kebetulan yang aneh,\Ntapi aku sudah memenuhi permintaan pria itu.
Dialogue: 0,0:12:04.97,0:12:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk hadiahnya,\Naku akan memintanya saat tiba di sisi lain.
Dialogue: 0,0:12:10.23,0:12:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan berduri ini hanya akan makin sulit.
Dialogue: 0,0:12:13.10,0:12:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski menghindari pertempuran langsung\Ndan mengincar Benih,
Dialogue: 0,0:12:15.98,0:12:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak akan bisa menghindari\Nbentrokan dengan Hutan Para Legenda.
Dialogue: 0,0:12:20.69,0:12:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di levelmu saat ini, kau tidak punya\Nkekuatan untuk mengalahkan Legenda.
Dialogue: 0,0:12:25.53,0:12:26.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:12:26.83,0:12:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah jelas kau berhak menantang mereka.
Dialogue: 0,0:12:30.70,0:12:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya,
Dialogue: 0,0:12:31.79,0:12:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hadapilah kenyataan.
Dialogue: 0,0:12:33.46,0:12:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan semua yang kau miliki.
Dialogue: 0,0:12:35.54,0:12:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putuskan siklus rumit yang diciptakan\Noleh Cabang Reinkarnasi.
Dialogue: 0,0:12:39.21,0:12:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito,
Dialogue: 0,0:12:40.30,0:12:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kejarlah impianmu.
Dialogue: 0,0:12:41.92,0:12:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu menjadi orang yang istimewa.
Dialogue: 0,0:12:43.88,0:12:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan keinginanmu akan kekuatan\Nuntuk melindungi Touya.
Dialogue: 0,0:12:48.22,0:12:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mungkin bukan urusanku,
Dialogue: 0,0:12:50.68,0:12:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jika pesan itu tersampaikan,
Dialogue: 0,0:12:53.77,0:12:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia seharusnya bisa menggantikanku\Nuntuk membimbingmu.
Dialogue: 0,0:13:02.99,0:13:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubei...
Dialogue: 0,0:13:05.53,0:13:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matahari sudah terbit.
Dialogue: 0,0:13:18.46,0:13:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ke mana?
Dialogue: 0,0:13:21.00,0:13:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan mencari puncak pedang "ketiadaan"?
Dialogue: 0,0:13:24.47,0:13:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kau akan hanyut ke tempat lain?
Dialogue: 0,0:13:31.31,0:13:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh...
Dialogue: 0,0:13:33.27,0:13:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantikannya.
Dialogue: 0,0:13:53.91,0:13:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang Pengembali bernama Albert ini...
Dialogue: 0,0:13:57.25,0:13:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan membahasnya nanti.
Dialogue: 0,0:13:59.67,0:14:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:14:01.09,0:14:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau butuh rekaman dengan resolusi\Ndan tingkat bingkai lebih tinggi?
Dialogue: 0,0:14:05.05,0:14:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa menyusun\Nstrategi seperti ini...
Dialogue: 0,0:14:12.76,0:14:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian Pengembali, kan?
Dialogue: 0,0:14:14.85,0:14:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau? Apa kalian rekan baru?
Dialogue: 0,0:14:16.94,0:14:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:14:17.85,0:14:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Haito.
Dialogue: 0,0:14:19.15,0:14:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Touya.
Dialogue: 0,0:14:20.65,0:14:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:14:21.57,0:14:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka staf pendukung.
Dialogue: 0,0:14:23.40,0:14:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kalian berdua. Silakan lewat sini.
Dialogue: 0,0:14:27.70,0:14:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan mereka berdua?
Dialogue: 0,0:14:29.87,0:14:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka penuh luka, tapi terlihat sangat puas.
Dialogue: 0,0:14:34.66,0:14:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kita harus cari cara selamatkan mereka!\N- Kapten Kitazuka sedang rapat di dalam.
Dialogue: 0,0:14:38.33,0:14:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu tidak sabar.
Dialogue: 0,0:14:41.96,0:14:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua sudah kembali.
Dialogue: 0,0:14:45.76,0:14:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf aku terlambat.
Dialogue: 0,0:14:48.22,0:14:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:14:49.34,0:14:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat mencemaskanmu.
Dialogue: 0,0:14:51.68,0:14:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Kitazuka?
Dialogue: 0,0:14:53.06,0:14:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau kembali?
Dialogue: 0,0:14:54.85,0:14:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:55.89,0:14:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun kau kabur,
Dialogue: 0,0:14:57.94,0:14:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak akan repot-repot mengejarmu.
Dialogue: 0,0:14:59.77,0:15:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kitazuka.
Dialogue: 0,0:15:01.36,0:15:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kau meninggalkan markas,\Naku tak pernah memikirkanmu.
Dialogue: 0,0:15:06.11,0:15:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang begitu,\Ntapi dia yang paling mencemaskanmu.
Dialogue: 0,0:15:09.45,0:15:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:15:10.41,0:15:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kembali meneliti.
Dialogue: 0,0:15:13.66,0:15:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten Kitazuka.
Dialogue: 0,0:15:16.29,0:15:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya, aku...
Dialogue: 0,0:15:19.00,0:15:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Cabang yang ditinggalkan Nona Yagyu.
Dialogue: 0,0:15:22.21,0:15:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali hanya untuk satu alasan.
Dialogue: 0,0:15:24.38,0:15:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menemukan Benih Reinkarnasi\Ndan menghancurkannya.
Dialogue: 0,0:15:27.84,0:15:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:15:29.26,0:15:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertempuran ini...\NAku memutuskan bahwa aku akan...
Dialogue: 0,0:15:32.18,0:15:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:15:34.14,0:15:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita yang akan mengakhiri ini.
Dialogue: 0,0:15:39.94,0:15:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Periksakan dirimu dan obati.
Dialogue: 0,0:15:43.48,0:15:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:15:44.82,0:15:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bisa berterus terang, ya?
Dialogue: 0,0:15:47.99,0:15:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kalian selamat.
Dialogue: 0,0:15:50.86,0:15:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku menyambutmu kembali\Nuntuk saat ini.
Dialogue: 0,0:15:53.66,0:15:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali, Neumann.
Dialogue: 0,0:15:55.45,0:15:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, Neumann II.
Dialogue: 0,0:15:57.83,0:15:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:15:58.91,0:16:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sudah menemukan kejelasan.
Dialogue: 0,0:16:01.83,0:16:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua berkat Touya.
Dialogue: 0,0:16:04.33,0:16:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:05.67,0:16:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau sudah berusaha maksimal, bukan?
Dialogue: 0,0:16:10.09,0:16:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau juga memprediksi keadaan\Nakan menjadi seperti ini?
Dialogue: 0,0:16:13.18,0:16:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kau tahu,
Dialogue: 0,0:16:14.43,0:16:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa memprediksi masa depan.
Dialogue: 0,0:16:17.35,0:16:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil ini hanya ada karena kau\Nmembuat pilihan dan melakukannya.
Dialogue: 0,0:16:21.94,0:16:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:22.98,0:16:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:16:24.35,0:16:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu?
Dialogue: 0,0:16:26.06,0:16:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua sudah menghabiskan\Nbanyak waktu bersama.
Dialogue: 0,0:16:29.28,0:16:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah waktunya kalian mulai\Nberkencan, lebih dari sekadar teman?
Dialogue: 0,0:16:33.24,0:16:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ini lagi.
Dialogue: 0,0:16:34.28,0:16:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya sempurna.
Dialogue: 0,0:16:35.78,0:16:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika kalian berciuman di sini...
Dialogue: 0,0:16:36.95,0:16:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terima kasih.
Dialogue: 0,0:16:38.41,0:16:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:40.83,0:16:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat laporan misi ini,
Dialogue: 0,0:16:42.71,0:16:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada sesuatu yang menggangguku.
Dialogue: 0,0:16:44.88,0:16:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama pertempuran di gurun,
Dialogue: 0,0:16:46.42,0:16:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitazuka dan yang lainnya\Nsangat dirugikan, kan?
Dialogue: 0,0:16:50.30,0:16:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:51.26,0:16:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut si Kacamata Bundar,\Nmereka hampir dihabisi.
Dialogue: 0,0:16:55.59,0:16:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya baik orang-orang di sini
Dialogue: 0,0:16:58.97,0:17:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maupun para Pengembali
Dialogue: 0,0:17:01.18,0:17:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama-sama diberi pelajaran keras.
Dialogue: 0,0:17:05.23,0:17:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku tak mengerti.
Dialogue: 0,0:17:07.98,0:17:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Albert memiliki keuntungan mutlak,
Dialogue: 0,0:17:11.06,0:17:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa mereka menyetujui gencatan senjata?
Dialogue: 0,0:17:14.15,0:17:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada satu kesimpulan logis...
Dialogue: 0,0:17:17.78,0:17:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nightingale pasti memanggil Albert kembali.
Dialogue: 0,0:17:21.82,0:17:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bertindak cukup bebas sendirian,
Dialogue: 0,0:17:25.29,0:17:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Albert.
Dialogue: 0,0:17:26.92,0:17:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin sudah menyuruhmu\Nmenghindari kontak.
Dialogue: 0,0:17:31.71,0:17:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kesempatan langka.
Dialogue: 0,0:17:33.97,0:17:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selangkah lagi untuk\Nmendapatkan Einstein...
Dialogue: 0,0:17:36.01,0:17:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Albert!
Dialogue: 0,0:17:37.89,0:17:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena
Dialogue: 0,0:17:39.10,0:17:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak pernah memberitahuku\Nhal-hal penting, Gale.
Dialogue: 0,0:17:42.72,0:17:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti di sanatorium...
Dialogue: 0,0:17:45.48,0:17:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku melakukan\Npenyelidikan sendiri,
Dialogue: 0,0:17:47.98,0:17:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti waktu itu.
Dialogue: 0,0:17:49.19,0:17:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,
Dialogue: 0,0:17:51.02,0:17:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau memakai alasan itu untuk\Nmemenuhi keinginanmu sendiri, kan?
Dialogue: 0,0:17:55.45,0:17:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann benar-benar hancur karena itu,
Dialogue: 0,0:17:57.74,0:17:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyebabkan sistem gagal sementara.
Dialogue: 0,0:18:00.08,0:18:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan menarik tamu tak diundang.
Dialogue: 0,0:18:03.04,0:18:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah.
Dialogue: 0,0:18:04.33,0:18:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membiarkannya kali ini,\Ntapi jangan sampai terjadi lagi.
Dialogue: 0,0:18:08.96,0:18:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:18:10.29,0:18:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan ada kali kedua.
Dialogue: 0,0:18:12.80,0:18:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, Benih masih\Nmenjadi satu-satunya kekhawatiran kita.
Dialogue: 0,0:18:16.01,0:18:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah lebih baik bertindak?
Dialogue: 0,0:18:18.26,0:18:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tidak, kita bisa memakai Sistem Dunia...
Dialogue: 0,0:18:20.39,0:18:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, Tesla. Tolong fokuskan semua\Nusahamu untuk memperbaiki sistem.
Dialogue: 0,0:18:24.77,0:18:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak akan menemukan Benih.
Dialogue: 0,0:18:28.60,0:18:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu di mana tempatnya?
Dialogue: 0,0:18:30.40,0:18:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada beberapa tempat di Bumi
Dialogue: 0,0:18:33.48,0:18:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang di luar jangkauan kita.
Dialogue: 0,0:18:36.11,0:18:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku bisa menebaknya.
Dialogue: 0,0:18:38.28,0:18:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau terlalu meremehkan Benih?
Dialogue: 0,0:18:41.07,0:18:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita tahu lokasinya,\Nbukankah lebih baik merebutnya...
Dialogue: 0,0:18:44.87,0:18:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang...
Dialogue: 0,0:18:46.37,0:18:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah kirim beberapa Legenda ke sana,
Dialogue: 0,0:18:49.75,0:18:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak ada yang kembali.
Dialogue: 0,0:18:51.96,0:18:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Asosiasi Seni" adalah tempat seperti itu.
Dialogue: 0,0:18:54.84,0:18:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar,
Dialogue: 0,0:18:56.13,0:18:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Picasso?
Dialogue: 0,0:18:58.51,0:19:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nightingale dan Albert...
Dialogue: 0,0:19:01.14,0:19:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera menemukan Benih.
Dialogue: 0,0:19:05.10,0:19:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya?
Dialogue: 0,0:19:06.23,0:19:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mempertimbangkan situasi saat ini,
Dialogue: 0,0:19:08.10,0:19:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memikirkan solusinya\Ndengan caraku sendiri.
Dialogue: 0,0:19:10.90,0:19:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:19:11.94,0:19:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\Ndiam saja tidak akan menyelesaikan masalah.
Dialogue: 0,0:19:16.28,0:19:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:19:18.36,0:19:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kau membantuku?
Dialogue: 0,0:19:20.78,0:19:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:19:27.25,0:19:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka Touya akan bergantung\Npada orang lain.
Dialogue: 0,0:19:31.63,0:19:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja, Seiya.
Dialogue: 0,0:19:36.42,0:19:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku harus menjadi orang hebat."
Dialogue: 0,0:19:39.59,0:19:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama terikat oleh suara itu.
Dialogue: 0,0:19:43.60,0:19:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus membandingkan diriku dengan orang lain,\Nmemojokkan diriku,
Dialogue: 0,0:19:46.56,0:19:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat bergantung pada sesuatu\Nuntuk mengisi ketidakmampuanku...
Dialogue: 0,0:19:50.10,0:19:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang disebut bakat.
Dialogue: 0,0:19:52.06,0:19:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia hanya menyinari mereka\Nyang memiliki bakat tertentu.
Dialogue: 0,0:19:56.36,0:19:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang tidak berbakat ditakdirkan\Nuntuk dikubur dan dilupakan.
Dialogue: 0,0:19:59.24,0:20:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan membuang martabatku\Nuntuk mendapatkan bakat.
Dialogue: 0,0:20:03.03,0:20:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira jika memilikinya,\Naku akan diselamatkan.
Dialogue: 0,0:20:05.28,0:20:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahwa semuanya akhirnya akan terbayar.
Dialogue: 0,0:20:07.95,0:20:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ternyata tidak.
Dialogue: 0,0:20:10.00,0:20:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti pria yang dahulu\Nmahakuasa itu sebenarnya tidak sempurna
Dialogue: 0,0:20:12.54,0:20:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak ada bedanya denganku,
Dialogue: 0,0:20:15.38,0:20:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua Pengembali yang kutemui sejauh ini
Dialogue: 0,0:20:18.26,0:20:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hidup dengan perjuangan masing-masing.
Dialogue: 0,0:20:20.59,0:20:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mungkin itu bagus.
Dialogue: 0,0:20:23.18,0:20:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan soal berbakat atau tidak.
Dialogue: 0,0:20:25.68,0:20:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara seseorang membuktikan keberadaan
Dialogue: 0,0:20:29.18,0:20:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah inti dari pencarian jati diri manusia.
Dialogue: 0,0:20:33.90,0:20:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku tidak perlu
Dialogue: 0,0:20:35.77,0:20:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi orang yang istimewa lagi.
Dialogue: 0,0:20:39.53,0:20:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:20:44.78,0:20:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menjadi diriku sendiri.
Dialogue: 0,0:20:51.83,0:20:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya,
Dialogue: 0,0:20:52.96,0:20:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengandalkan kalian.
Dialogue: 0,0:20:54.50,0:20:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap kapan pun kau siap.
Dialogue: 0,0:20:57.29,0:20:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Newton.
Dialogue: 0,0:20:59.92,0:21:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti...
Dialogue: 0,0:21:02.26,0:21:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunggu tanpa berharap.
Dialogue: 0,0:21:06.14,0:21:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya,
Dialogue: 0,0:21:07.97,0:21:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mohon bimbingannya.
Dialogue: 0,0:21:10.93,0:21:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku yang bilang begitu,
Dialogue: 0,0:21:12.27,0:21:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:21:16.69,0:21:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo,
Dialogue: 0,0:21:18.61,0:21:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:22:48.16,0:22:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya!
Dialogue: 0,0:22:50.20,0:22:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:22:51.45,0:22:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik ke sini!
Dialogue: 0,0:22:53.08,0:22:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang!
Dialogue: 0,0:22:55.50,0:22:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu.
Dialogue: 0,0:22:57.54,0:22:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau menemukan sesuatu...
Dialogue: 0,0:22:59.37,0:23:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:23:00.79,0:23:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat! Pemandangannya menakjubkan.
Dialogue: 0,0:23:04.05,0:23:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:23:06.47,0:23:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, bukan?
Dialogue: 0,0:23:08.22,0:23:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:23:10.80,0:23:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumba-lumba!
Dialogue: 0,0:23:12.18,0:23:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lumba-lumba di sana, Haito!
Dialogue: 0,0:23:14.26,0:23:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, di mana?
Dialogue: 0,0:23:15.31,0:23:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sejujurnya...\N- Itu dia!
Dialogue: 0,0:23:16.73,0:23:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah kusebut mereka bodoh?\NAku terkejut mereka tak pernah bosan.
Dialogue: 0,0:23:20.02,0:23:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersemangat itu bagus.
Dialogue: 0,0:23:22.61,0:23:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:23:23.86,0:23:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini akan menjadi perjalanan panjang.
