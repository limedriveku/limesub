Dialogue: 0,0:02:32.06,0:02:35.03,tanda,,0000,0000,0000,,PETALS OF REINCARNATION
Dialogue: 0,0:08:27.42,0:08:28.25,tanda,,0000,0000,0000,,BAKAT: ENIGMA - BAKAT: NERAKA HIJAU\NBAKAT: BUAH KORUPSI
Dialogue: 0,0:08:28.34,0:08:29.17,tanda,,0000,0000,0000,,"BAKAT: FENIKS"
Dialogue: 0,0:10:13.07,0:10:14.82,tanda,,0000,0000,0000,,GAIUS J. CAESAR\NBAKAT: WASIAT PAHLAWAN
Dialogue: 0,0:21:52.52,0:21:54.06,tanda,,0000,0000,0000,,EPISODE 5\NSELAMAT TINGGAL, ORANG YANG MENDENGARKU
Dialogue: 0,0:22:40.06,0:22:41.48,tanda,,0000,0000,0000,,"HIROSHI FUNASAKA"
Dialogue: 0,0:23:37.62,0:23:39.96,tanda,,0000,0000,0000,,EPISODE 6\NSEIYA
Dialogue: 0,0:00:03.37,0:00:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa kusadari,\Nkelopak bunga bertebaran di leherku.
Dialogue: 0,0:00:07.04,0:00:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anehnya aku langsung mengerti bahwa aku\Ntelah mendapatkan bakat tertentu.
Dialogue: 0,0:00:10.13,0:00:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, ingatanku mulai memudar.
Dialogue: 0,0:00:12.67,0:00:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kurasa tidak perlu\Nmengkhawatirkannya.
Dialogue: 0,0:00:15.47,0:00:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, itu semua masalah sepele.
Dialogue: 0,0:00:17.72,0:00:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung menerima undangannya.
Dialogue: 0,0:00:19.93,0:00:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang menyebut diri mereka Legenda
Dialogue: 0,0:00:21.85,0:00:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terjun ke pertempuran atas nama\N"berkontribusi pada kemanusiaan".
Dialogue: 0,0:00:25.23,0:00:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga menyatakan keinginanku\Nuntuk berpartisipasi,
Dialogue: 0,0:00:27.19,0:00:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}merasa sangat terharu telah bergabung\Ndengan jajaran Legenda.
Dialogue: 0,0:00:30.73,0:00:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa yang harus kulakukan?
Dialogue: 0,0:00:33.86,0:00:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini penuh dengan konflik.
Dialogue: 0,0:00:36.82,0:00:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:00:38.58,0:00:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann membantuku,
Dialogue: 0,0:00:39.64,0:00:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memungkinkanku bergegas\Nke medan perang di seluruh dunia.
Dialogue: 0,0:00:43.29,0:00:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama halnya dengan Funasaka\Nyang merupakan tentara di kehidupan lampau,
Dialogue: 0,0:00:46.29,0:00:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga hanya bisa dianggap\Nsebagai Legenda di medan perang.
Dialogue: 0,0:00:49.04,0:00:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak meragukan itu.
Dialogue: 0,0:00:55.18,0:00:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika melakukan ini membuatku berkontribusi\Npada umat manusia,
Dialogue: 0,0:00:58.05,0:01:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka menjadi Legenda tidaklah sia-sia.
Dialogue: 0,0:01:01.10,0:01:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah menyerang.
Dialogue: 0,0:01:03.02,0:01:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti seorang Legenda...
Dialogue: 0,0:01:06.02,0:01:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa kusadari,
Dialogue: 0,0:01:09.48,0:01:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bahkan tidak ingat ingatanku sendiri.
Dialogue: 0,0:01:12.11,0:01:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa lalu terasa nostalgia.
Dialogue: 0,0:01:13.99,0:01:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, membosankan sekali...
Dialogue: 0,0:02:50.92,0:02:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka!
Dialogue: 0,0:02:56.51,0:02:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang bernama Touya,
Dialogue: 0,0:02:57.59,0:02:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mundurlah.
Dialogue: 0,0:02:58.88,0:03:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati seperti ini tanpa menyadarinya\Nadalah semacam kebahagiaan.
Dialogue: 0,0:03:02.68,0:03:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak menyerang?
Dialogue: 0,0:03:06.47,0:03:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan sekadar pertarungan\Nantara dua makhluk abadi yang terobsesi.
Dialogue: 0,0:03:09.43,0:03:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada alasan lain.
Dialogue: 0,0:03:11.10,0:03:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:03:12.19,0:03:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin kita bisa memanfaatkannya.
Dialogue: 0,0:03:14.61,0:03:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka, kita masih punya kesempatan\Nuntuk menang.
Dialogue: 0,0:03:17.99,0:03:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan untuk menang.
Dialogue: 0,0:03:19.90,0:03:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya tidak perlu bertarung\Nseolah-olah kau bergegas menuju kematian!
Dialogue: 0,0:03:24.24,0:03:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematian...
Dialogue: 0,0:03:25.37,0:03:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka, kau juga pasti punya.
Dialogue: 0,0:03:27.70,0:03:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang hanya bisa kau capai\Ndengan tetap hidup.
Dialogue: 0,0:03:30.04,0:03:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang ingin kucapai?
Dialogue: 0,0:03:32.88,0:03:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:03:37.00,0:03:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka?
Dialogue: 0,0:03:38.42,0:03:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Touya.
Dialogue: 0,0:03:40.17,0:03:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tolong jangan khawatir.
Dialogue: 0,0:03:43.51,0:03:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan ikut campur\Ndalam pertarungan ini.
Dialogue: 0,0:03:46.72,0:03:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja dengan tenang.
Dialogue: 0,0:03:50.85,0:03:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudel, terima kasih.
Dialogue: 0,0:03:53.15,0:03:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku mengerti ketidaknyamanan\Nyang terus muncul di hatiku.
Dialogue: 0,0:04:00.11,0:04:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan Legenda.
Dialogue: 0,0:04:02.28,0:04:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak pernah berniat berkontribusi\Nuntuk umat manusia.
Dialogue: 0,0:04:05.12,0:04:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin bertarung.
Dialogue: 0,0:04:07.83,0:04:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari pertempuran seperti ini yang\Nmenguras tenaga kedua pihak sampai batasnya.
Dialogue: 0,0:04:11.54,0:04:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu pesimis.
Dialogue: 0,0:04:12.96,0:04:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:04:14.96,0:04:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku memilih jalan\Nmelawan Hutan Para Legenda.
Dialogue: 0,0:04:19.13,0:04:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena menurutku melawan Para Legenda\Nadalah jalan terbaik.
Dialogue: 0,0:04:23.38,0:04:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu naluri\Nuntuk mencari sensasi pertempuran.
Dialogue: 0,0:04:26.93,0:04:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambisi besar dan patriotisme\Nyang diharapkan dari Legenda,
Dialogue: 0,0:04:30.47,0:04:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak punya hal seperti itu.
Dialogue: 0,0:04:31.93,0:04:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja.\NYang diberikan kelopak bunga adalah
Dialogue: 0,0:04:35.31,0:04:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"bakat".
Dialogue: 0,0:04:36.90,0:04:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat saja tidak membuat seseorang\Njadi Legenda.
Dialogue: 0,0:04:40.23,0:04:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak Pengembali hanya ditelan
Dialogue: 0,0:04:42.03,0:04:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh bakat dan nama mereka\Nyang diabadikan dalam sejarah,
Dialogue: 0,0:04:44.61,0:04:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertindak dalam ilusi belaka.
Dialogue: 0,0:04:47.99,0:04:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita ini apa?
Dialogue: 0,0:04:52.08,0:04:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bahkan tidak bisa disebut manusia.
Dialogue: 0,0:04:54.62,0:04:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kita sudah kehilangan
Dialogue: 0,0:04:56.54,0:04:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diri kita yang bunuh diri demi bakat.
Dialogue: 0,0:04:59.84,0:05:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya ingatan kita,\Ntapi juga nama kita.
Dialogue: 0,0:05:02.63,0:05:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dahulu kita inginkan
Dialogue: 0,0:05:04.34,0:05:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau pengakuan siapa yang kita cari
Dialogue: 0,0:05:06.26,0:05:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kini mustahil diketahui.
Dialogue: 0,0:05:08.97,0:05:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pikir kita mendapatkan sesuatu,\Ntapi kita kehilangan segalanya.
Dialogue: 0,0:05:13.56,0:05:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mereka berbeda.
Dialogue: 0,0:05:16.56,0:05:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengembali Tidak Lengkap.
Dialogue: 0,0:05:19.52,0:05:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah alasanmu tidak menyerang Touya?
Dialogue: 0,0:05:22.69,0:05:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Biarkan mereka yang masih menyandang\Nnama mereka di kehidupan ini berlalu."
Dialogue: 0,0:05:25.78,0:05:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu permintaan Kouu.
Dialogue: 0,0:05:27.82,0:05:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan pria bernama Touya itu dikecualikan.
Dialogue: 0,0:05:30.24,0:05:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:05:31.95,0:05:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:05:33.12,0:05:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi masih ada beberapa hal yang kupahami.
Dialogue: 0,0:05:35.46,0:05:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih manusia
Dialogue: 0,0:05:37.25,0:05:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan punya "masa depan"\Nsetelah mendapat bakat.
Dialogue: 0,0:05:40.96,0:05:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iri sekali.
Dialogue: 0,0:05:43.21,0:05:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:44.34,0:05:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar sekali.
Dialogue: 0,0:05:46.38,0:05:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran apa nama kita dahulu.
Dialogue: 0,0:05:49.64,0:05:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin itu cukup biasa.
Dialogue: 0,0:05:53.06,0:05:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:05:55.10,0:05:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Funasaka.
Dialogue: 0,0:05:56.98,0:05:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti lelah menjadi abadi.
Dialogue: 0,0:05:59.06,0:06:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan hal yang sama.
Dialogue: 0,0:06:01.11,0:06:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:06:02.57,0:06:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya menyelesaikan ini!
Dialogue: 0,0:06:04.44,0:06:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan demi orang lain,
Dialogue: 0,0:06:05.82,0:06:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi demi diri kita sendiri!
Dialogue: 0,0:06:07.03,0:06:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau dan aku bisa mati di sini,\Nkeinginan kita akan terpenuhi.
Dialogue: 0,0:06:09.16,0:06:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:06:16.46,0:06:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Hathcock sudah mati?
Dialogue: 0,0:06:18.96,0:06:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:19.88,0:06:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membawa Häyhä bersamanya.
Dialogue: 0,0:06:21.67,0:06:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengesankan.
Dialogue: 0,0:06:23.05,0:06:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nightingale, bisakah dia diselamatkan?
Dialogue: 0,0:06:25.67,0:06:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, dia sudah...
Dialogue: 0,0:06:28.43,0:06:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedih?
Dialogue: 0,0:06:30.05,0:06:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin aku membunuh orang\Nyang membuatmu sedih?
Dialogue: 0,0:06:33.31,0:06:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku bahagia.
Dialogue: 0,0:06:35.10,0:06:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melawan saingan sepadan\Nyang dia hormati dan akhirnya mati.
Dialogue: 0,0:06:38.94,0:06:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada akhir\Nyang lebih baik daripada itu.
Dialogue: 0,0:06:41.90,0:06:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:06:44.44,0:06:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:45.57,0:06:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang di sini.
Dialogue: 0,0:06:46.94,0:06:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak merasakan siapa pun.
Dialogue: 0,0:06:49.15,0:06:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita terlalu lambat\Ndan mereka sudah kembali?
Dialogue: 0,0:06:51.45,0:06:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin? Aku akan memeriksanya!
Dialogue: 0,0:06:54.28,0:06:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengkhawatirkan Musashi sendirian.
Dialogue: 0,0:06:56.70,0:06:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Caesar, akan menemanimu...
Dialogue: 0,0:06:58.41,0:06:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:06:59.46,0:07:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musashi kuat.
Dialogue: 0,0:07:00.71,0:07:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak butuh perhatianmu.
Dialogue: 0,0:07:02.00,0:07:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh...
Dialogue: 0,0:07:03.54,0:07:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tidak terduga.
Dialogue: 0,0:07:04.50,0:07:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menduga Jubei\Nbegitu menghormatinya.
Dialogue: 0,0:07:06.26,0:07:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak membiarkan perasaan pribadi\Nmengaburkan penilaian kekuatanku.
Dialogue: 0,0:07:09.80,0:07:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu antara Jubei dan Musashi,\Nsiapa yang lebih kuat?
Dialogue: 0,0:07:12.43,0:07:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku.
Dialogue: 0,0:07:14.10,0:07:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlian pedang Musashi terlalu kasar.
Dialogue: 0,0:07:15.97,0:07:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan semangat kompetitifmu memesona!
Dialogue: 0,0:07:18.64,0:07:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubei, kau dan aku, Caesar...
Dialogue: 0,0:07:20.19,0:07:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak tahu untuk masa depan.
Dialogue: 0,0:07:22.40,0:07:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musashi masih Pengembali Tidak Lengkap.
Dialogue: 0,0:07:24.98,0:07:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,\Ndia punya banyak ruang untuk tumbuh.
Dialogue: 0,0:07:26.90,0:07:28.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai namanya...
Dialogue: 0,0:07:28.19,0:07:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dia belum melupakannya.
Dialogue: 0,0:07:29.99,0:07:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin namanya Haito.
Dialogue: 0,0:07:31.57,0:07:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama yang bagus.
Dialogue: 0,0:07:33.57,0:07:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:07:34.83,0:07:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa nama adalah sesuatu\Nyang harus segera dibuang.
Dialogue: 0,0:07:39.16,0:07:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, ini sangat aneh.
Dialogue: 0,0:07:40.96,0:07:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah tidak pernah ada orang di sini.
Dialogue: 0,0:07:43.54,0:07:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini terlalu terbuka\Nuntuk sebuah benteng.
Dialogue: 0,0:07:46.13,0:07:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah karena modelnya\Nseperti koloseum?
Dialogue: 0,0:07:49.46,0:07:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara soal "Koloseum Romawi",
Dialogue: 0,0:07:51.18,0:07:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin kau pernah mendengarnya.
Dialogue: 0,0:07:52.84,0:07:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya namanya.
Dialogue: 0,0:07:54.76,0:07:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak mengerti\Nkenapa mereka meniru arena Barat.
Dialogue: 0,0:07:58.47,0:08:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada hal seperti itu di sini...?
Dialogue: 0,0:08:07.69,0:08:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas
Dialogue: 0,0:08:09.69,0:08:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membuat kita saling membunuh.
Dialogue: 0,0:08:13.11,0:08:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertanya padamu.
Dialogue: 0,0:08:16.87,0:08:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya dicurigai sebagai mata-mata.
Dialogue: 0,0:08:21.29,0:08:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut informasi,
Dialogue: 0,0:08:22.62,0:08:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para Pendosa punya lima tuan yang dikenal\Nsebagai Lima Jenderal Harimau, kan?
Dialogue: 0,0:08:28.34,0:08:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:29.59,0:08:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terakhir sedang bersembunyi\Ndi dalam Hutan Para Legenda.
Dialogue: 0,0:08:34.92,0:08:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bukan Touya, lalu siapa mata-matanya?
Dialogue: 0,0:08:38.35,0:08:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria dengan ilmu dan senjata,\Nyang namanya terukir dalam sejarah.
Dialogue: 0,0:08:41.10,0:08:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan tertinggi Roma.
Dialogue: 0,0:08:43.23,0:08:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengembali terkuat\Ndi antara Lima Jenderal Harimau.
Dialogue: 0,0:08:49.82,0:08:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubei?
Dialogue: 0,0:08:52.07,0:08:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caesar?
Dialogue: 0,0:08:53.24,0:08:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadu telah dilemparkan.
Dialogue: 0,0:08:56.87,0:08:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:58.33,0:09:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira menjadi pengkhianat\Nakan terasa cukup menyenangkan.
Dialogue: 0,0:09:02.62,0:09:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tidak begitu.
Dialogue: 0,0:09:06.50,0:09:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caesar, kau!
Dialogue: 0,0:09:13.80,0:09:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?\NAku terlempar ke belakang.
Dialogue: 0,0:09:15.97,0:09:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangkas jarak dengan pengguna senjata\Npanjang adalah pilihan taktis yang buruk.
Dialogue: 0,0:09:20.56,0:09:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang panjang yang digunakan dari\NPerang Salib hingga Perang Seratus Tahun
Dialogue: 0,0:09:25.14,0:09:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi tersohor karena fleksibilitasnya.
Dialogue: 0,0:09:29.15,0:09:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini teknik yang disebut "setengah pedang".
Dialogue: 0,0:09:31.48,0:09:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencengkeram pedang\Nmemungkinkan kuda-kuda yang rapat.
Dialogue: 0,0:09:35.45,0:09:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang bisa digunakan sebagai gada
Dialogue: 0,0:09:37.70,0:09:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau untuk menusuk.
Dialogue: 0,0:09:39.28,0:09:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menggertak!
Dialogue: 0,0:09:45.96,0:09:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Refleksmu cepat,\Ntapi beberapa tulang rusukmu pasti patah.
Dialogue: 0,0:09:50.00,0:09:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pukulan mematikan yang dikenal\Nsebagai "Mordschlag"
Dialogue: 0,0:09:52.92,0:09:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menggunakan pedang\Nsebagai senjata tumpul yang mematikan.
Dialogue: 0,0:09:56.80,0:09:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Jepang tidak punya\Ngaya bertarung seperti itu, bukan?
Dialogue: 0,0:10:00.35,0:10:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan hanya dengan pedang panjang,\Nada banyak variasi.
Dialogue: 0,0:10:04.43,0:10:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi persenjataan Barat\Ntidak berhenti di sana.
Dialogue: 0,0:10:15.32,0:10:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehancuran Dahsyat, Zweihänder.
Dialogue: 0,0:10:19.62,0:10:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebasan Tusukan Tercepat, Sabetan Pedang.
Dialogue: 0,0:10:23.70,0:10:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta
Dialogue: 0,0:10:24.62,0:10:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghancur Pertahanan, Shotel!
Dialogue: 0,0:10:26.58,0:10:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial...
Dialogue: 0,0:10:28.92,0:10:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghancur Senjata, Penghancur Pedang!
Dialogue: 0,0:10:35.26,0:10:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenggal, Algojo!
Dialogue: 0,0:10:44.93,0:10:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bakatku, "Wasiat Pahlawan".
Dialogue: 0,0:10:48.89,0:10:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mendorong\Nsenjata apa pun hingga batasnya.
Dialogue: 0,0:10:52.23,0:10:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, keahlian sejatiku\Nadalah "bakat strategis"
Dialogue: 0,0:10:54.44,0:10:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memimpin pasukan\Ndan membawa mereka menuju kemenangan.
Dialogue: 0,0:10:56.78,0:10:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlian bela diri hanyalah pelengkap.
Dialogue: 0,0:10:59.03,0:11:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat seperti itu hanya pelengkap?
Dialogue: 0,0:11:01.53,0:11:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan bakat luar biasa itu,\Nkenapa kau mengkhianati kami?
Dialogue: 0,0:11:04.87,0:11:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah menjadi sekutumu sejak awal.
Dialogue: 0,0:11:07.75,0:11:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar bahkan\Nsebelum Hutan Para Legenda terbentuk.
Dialogue: 0,0:11:10.50,0:11:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musashi, kau selalu ingin\Nmelawan seorang master, bukan?
Dialogue: 0,0:11:15.34,0:11:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kenapa tidak menikmatinya?
Dialogue: 0,0:11:17.51,0:11:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa melawanku, sang pahlawan Caesar.
Dialogue: 0,0:11:20.93,0:11:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau melewatkan kesempatan ini,\Nkau takkan pernah mendapatkan...
Dialogue: 0,0:11:22.64,0:11:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:11:25.35,0:11:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan dia...
Dialogue: 0,0:11:28.10,0:11:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia mulai berubah?
Dialogue: 0,0:11:30.48,0:11:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pemicunya?
Dialogue: 0,0:11:32.27,0:11:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keputusasaan? Atau ledakan emosi?
Dialogue: 0,0:11:34.98,0:11:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin keduanya?
Dialogue: 0,0:11:37.03,0:11:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kouu, tapi biarkan aku menguji ini.
Dialogue: 0,0:11:39.82,0:11:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pengembali Tidak Lengkap."
Dialogue: 0,0:11:42.28,0:11:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sini! Bodoh! Tolol!
Dialogue: 0,0:11:45.91,0:11:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!
Dialogue: 0,0:11:58.01,0:11:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perpindahan Ruang...
Dialogue: 0,0:11:59.46,0:12:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mereka bertekad untuk melarikan diri,\Napakah mustahil untuk menangkap mereka?
Dialogue: 0,0:12:02.47,0:12:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berhenti tepat di tepi area korupsi.
Dialogue: 0,0:12:06.51,0:12:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:07.81,0:12:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangkauan efektif "Buah Korupsi"
Dialogue: 0,0:12:09.81,0:12:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya radius enam meter.
Dialogue: 0,0:12:11.52,0:12:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya ada jeda satu detik\Nsebelum bisa digunakan lagi.
Dialogue: 0,0:12:14.73,0:12:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya, "Buah Gravitasi"-ku\Nmemiliki radius empat meter.
Dialogue: 0,0:12:18.11,0:12:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangkauan mematikannya hanya dua meter.
Dialogue: 0,0:12:20.99,0:12:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisinya tidak menguntungkanku,
Dialogue: 0,0:12:22.82,0:12:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ada kesempatan!
Dialogue: 0,0:12:23.95,0:12:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini!
Dialogue: 0,0:12:25.28,0:12:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau meleset!
Dialogue: 0,0:12:26.74,0:12:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kau diktator legendaris,\Ntapi kau tak istimewa.
Dialogue: 0,0:12:30.08,0:12:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:12:31.21,0:12:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!
Dialogue: 0,0:12:33.12,0:12:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari bekerja sama dan mengganggunya.
Dialogue: 0,0:12:34.42,0:12:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan mati di sini. Apa maksudmu?
Dialogue: 0,0:12:36.71,0:12:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hitler pintar.
Dialogue: 0,0:12:38.50,0:12:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan mudah mengalahkannya.
Dialogue: 0,0:12:40.13,0:12:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kurasa Pol bertindak\Nberdasarkan insting.
Dialogue: 0,0:12:42.51,0:12:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencanaku adalah memprovokasinya\Nsebisa mungkin.
Dialogue: 0,0:12:45.72,0:12:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bisa merusak koordinasi mereka,\Nkita akan punya kesempatan menang.
Dialogue: 0,0:12:48.97,0:12:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa trik murahan itu akan berhasil?
Dialogue: 0,0:12:51.31,0:12:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari gunakan semua trik\Nyang bisa kita pikirkan.
Dialogue: 0,0:12:53.81,0:12:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah selagi kita berlari.\NKita hanya perlu satu untuk mendarat.
Dialogue: 0,0:12:59.32,0:13:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pol, jangan asal menyerang.
Dialogue: 0,0:13:01.99,0:13:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengira akan selancar ini.
Dialogue: 0,0:13:04.32,0:13:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau meleset! Ayo!\N- Dia berhenti mendengarkan Hitler.
Dialogue: 0,0:13:06.78,0:13:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pol!
Dialogue: 0,0:13:09.74,0:13:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup jauh.
Dialogue: 0,0:13:10.66,0:13:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan kita!
Dialogue: 0,0:13:11.70,0:13:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghindari efek korupsi dan\Nmenjatuhkannya sebelum langkah berikutnya.
Dialogue: 0,0:13:16.92,0:13:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tertipu!
Dialogue: 0,0:13:29.56,0:13:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Newton!\N- Jangan mendekat!
Dialogue: 0,0:13:33.98,0:13:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pakai gravitasi untuk melengkungkan\Nruang dan nyaris mati dalam sekejap?
Dialogue: 0,0:13:37.94,0:13:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipermainkan.
Dialogue: 0,0:13:39.61,0:13:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah dia bertindak berdasarkan insting
Dialogue: 0,0:13:41.78,0:13:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau jangkauan korupsi enam meter itu,
Dialogue: 0,0:13:44.74,0:13:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu semua jebakan untuk memancing kami.
Dialogue: 0,0:13:47.74,0:13:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:13:48.66,0:13:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kekuatan penuh,\Nradius korupsinya maksimal 50 meter.
Dialogue: 0,0:13:51.62,0:13:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak bisa kalahkan kami\Ndi langkah pertama,
Dialogue: 0,0:13:53.79,0:13:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak punya kesempatan.
Dialogue: 0,0:13:55.54,0:13:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami dipermainkan sejak awal?
Dialogue: 0,0:13:58.50,0:13:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Newton!
Dialogue: 0,0:13:59.71,0:14:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Aku salah menilai situasinya.
Dialogue: 0,0:14:02.59,0:14:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan Neumann\Ndan yang lainnya kepadamu.
Dialogue: 0,0:14:08.14,0:14:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:14:09.22,0:14:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini keputusan bijak dari Legenda?
Dialogue: 0,0:14:11.43,0:14:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan urusanmu.
Dialogue: 0,0:14:13.27,0:14:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ein, apa yang kau lakukan?
Dialogue: 0,0:14:15.43,0:14:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:14:16.39,0:14:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak ada gunanya.
Dialogue: 0,0:14:17.48,0:14:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:14:20.11,0:14:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mati di sini,\Nkau tidak akan bisa membalas dendam.
Dialogue: 0,0:14:23.40,0:14:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dia penting bagimu?
Dialogue: 0,0:14:25.49,0:14:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin aku
Dialogue: 0,0:14:27.49,0:14:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak tahu?
Dialogue: 0,0:14:37.71,0:14:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita "seimbang".
Dialogue: 0,0:14:40.00,0:14:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:41.00,0:14:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang, hasilnya seimbang.
Dialogue: 0,0:14:43.34,0:14:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya Pol memutuskan\Nuntuk membiarkan kalian hidup.
Dialogue: 0,0:14:47.34,0:14:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ingin membunuhmu,\Naku tak bisa menyerang.
Dialogue: 0,0:14:51.14,0:14:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kalian berdua\Ntidak dalam kondisi untuk bertarung.
Dialogue: 0,0:14:53.89,0:14:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita impas sekarang.
Dialogue: 0,0:14:56.52,0:14:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu? Apa ini simpati...
Dialogue: 0,0:14:59.27,0:15:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:15:00.81,0:15:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau melepaskan kami, kami akan\Nterus mengejarmu untuk menghentikanmu...
Dialogue: 0,0:15:04.82,0:15:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak perlu.
Dialogue: 0,0:15:06.86,0:15:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam pertempuran ini,\N"kita semua akan mati."
Dialogue: 0,0:15:10.07,0:15:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah diputuskan\Nsebelum perang dimulai.
Dialogue: 0,0:15:12.62,0:15:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:13.53,0:15:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak suka\Nsemua berjalan sesuai naskahmu.
Dialogue: 0,0:15:17.20,0:15:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku berniat menyeret kalian\Nke alam baka sebanyak mungkin.
Dialogue: 0,0:15:20.83,0:15:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalian tidak begitu saja\Nmemercayai bakat kalian.
Dialogue: 0,0:15:24.13,0:15:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian membuat strategi\Ndan bermanuver untuk melarikan diri.
Dialogue: 0,0:15:26.30,0:15:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa tahu\Ndari cara bicara dan perilakumu
Dialogue: 0,0:15:28.09,0:15:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa kau tidak memasuki\Nmedan perang ini hanya untuk bertarung.
Dialogue: 0,0:15:31.30,0:15:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihat kehangatan kemanusiaan\Ndalam cara kalian saling melindungi.
Dialogue: 0,0:15:33.84,0:15:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya membunuh\N"yang menyamar sebagai Legenda"
Dialogue: 0,0:15:37.52,0:15:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan "yang ditelan oleh Kelopak Bunga."
Dialogue: 0,0:15:39.52,0:15:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak membunuh "manusia".
Dialogue: 0,0:15:41.52,0:15:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kalian\Nterus menghargai perasaan ini.
Dialogue: 0,0:15:45.02,0:15:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuat kami\Nmenyesali keputusan ini.
Dialogue: 0,0:15:48.24,0:15:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:49.82,0:15:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku harus memberikan\Nsatu pesan terakhir,
Dialogue: 0,0:15:51.45,0:15:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu adalah\N"Jangan percaya Neumann begitu saja."
Dialogue: 0,0:15:54.95,0:15:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga beruntung dalam pertempuran.
Dialogue: 0,0:16:02.96,0:16:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mengatakannya, ya?
Dialogue: 0,0:16:04.59,0:16:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya seri, tapi aku merasa kalah.
Dialogue: 0,0:16:07.50,0:16:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:11.13,0:16:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann.
Dialogue: 0,0:16:13.09,0:16:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua aman.
Dialogue: 0,0:16:14.80,0:16:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat mencemaskanmu.
Dialogue: 0,0:16:16.60,0:16:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nightingale, obati mereka.
Dialogue: 0,0:16:18.60,0:16:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:16:20.35,0:16:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana situasinya?
Dialogue: 0,0:16:22.06,0:16:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wright Bersaudari dan Häyhä tewas.
Dialogue: 0,0:16:24.86,0:16:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kita kehilangan\Njejak pergerakan semua orang.
Dialogue: 0,0:16:28.19,0:16:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kalian berdua selamat.
Dialogue: 0,0:16:30.78,0:16:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Penyerang Hutan dihabisi, kecuali kami.
Dialogue: 0,0:16:34.16,0:16:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kami bertemu Hitler dan Pol,\Ndua dari Lima Jenderal Harimau.
Dialogue: 0,0:16:38.16,0:16:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:39.41,0:16:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:16:43.58,0:16:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann,
Dialogue: 0,0:16:45.08,0:16:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah kau kenal baik dengan Hitler?
Dialogue: 0,0:16:48.55,0:16:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau bertanya?
Dialogue: 0,0:16:50.21,0:16:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia sangat mengenalmu.
Dialogue: 0,0:16:52.47,0:16:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia tidak mendengar\Ntentangmu dari orang lain.
Dialogue: 0,0:16:55.14,0:16:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka rasional dan mudah diajak bicara.
Dialogue: 0,0:16:58.68,0:17:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksud kalian?
Dialogue: 0,0:17:00.22,0:17:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya sedikit bingung.
Dialogue: 0,0:17:02.02,0:17:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Tentara Pendosa Kouu\Nbenar-benar hanya sekelompok penjahat?
Dialogue: 0,0:17:06.77,0:17:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kalian terpengaruh\Noleh kata-kata musuh?
Dialogue: 0,0:17:08.85,0:17:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:17:10.35,0:17:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu memberi kami kesempatan\Nuntuk berpikir.
Dialogue: 0,0:17:13.10,0:17:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, jika mereka ingin\Nmelakukan sesuatu dalam skala global,
Dialogue: 0,0:17:16.70,0:17:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jumlah mereka lebih banyak daripada kita.
Dialogue: 0,0:17:18.95,0:17:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa menyebar ke seluruh dunia\Ndan menyebabkan kekacauan secara bersamaan.
Dialogue: 0,0:17:22.79,0:17:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka sengaja berkumpul\Ndi area terpencil ini
Dialogue: 0,0:17:25.71,0:17:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menunggu kita tanpa strategi.\NItu terlalu aneh.
Dialogue: 0,0:17:29.13,0:17:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu karena Kouu...\N- Pria itu bahkan tidak muncul.
Dialogue: 0,0:17:32.05,0:17:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia menggunakan bakatnya,\Nkita pasti langsung tahu.
Dialogue: 0,0:17:35.01,0:17:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia datang ke sini\Nuntuk memulai perang,
Dialogue: 0,0:17:37.30,0:17:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aneh bahwa dia tidak berdiri\Ndi garis depan sendiri.
Dialogue: 0,0:17:41.47,0:17:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pendapat kami.
Dialogue: 0,0:17:43.89,0:17:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentara Pendosa\Nbukan hanya kelompok yang kejam.
Dialogue: 0,0:17:47.02,0:17:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti punya alasan khusus\Nuntuk memulai perang ini.
Dialogue: 0,0:17:50.52,0:17:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin mereka dipaksa\Nke dalam pertarungan ini oleh "seseorang".
Dialogue: 0,0:17:54.65,0:17:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika aku mendengar Kouu masih hidup,\Naku benar-benar kehilangan ketenanganku.
Dialogue: 0,0:17:58.91,0:17:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:17:59.83,0:18:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini dia!\N- Kalau dipikir-pikir, ada banyak keraguan.
Dialogue: 0,0:18:02.83,0:18:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujurlah kepada kami.
Dialogue: 0,0:18:04.20,0:18:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:18:05.71,0:18:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rencanakan?
Dialogue: 0,0:18:08.21,0:18:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tidak mau bicara,\Nkami harus memaksamu.
Dialogue: 0,0:18:10.42,0:18:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:11.96,0:18:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu ancaman.
Dialogue: 0,0:18:13.55,0:18:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah berada\Ndalam medan gravitasi Newton.
Dialogue: 0,0:18:16.22,0:18:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab kami dengan jujur.
Dialogue: 0,0:18:20.68,0:18:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggunakan kekerasan untuk memaksakan\Npenjelasan cukup sulit diterima.
Dialogue: 0,0:18:24.06,0:18:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, Newton?
Dialogue: 0,0:18:28.31,0:18:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:32.36,0:18:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:33.28,0:18:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kita rekan.
Dialogue: 0,0:18:34.99,0:18:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak baik saling mencurigai.
Dialogue: 0,0:18:37.57,0:18:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:18:38.86,0:18:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau ingin bicara,\Nkita bisa melakukannya setelah perang.
Dialogue: 0,0:18:43.04,0:18:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganmu, Newton?
Dialogue: 0,0:18:44.58,0:18:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ini yang kita sepakati.
Dialogue: 0,0:18:46.37,0:18:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ein, lukamu pasti menyakitkan.
Dialogue: 0,0:18:48.17,0:18:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan Nightingale segera merawatmu.
Dialogue: 0,0:18:54.17,0:18:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan kepada Newton?
Dialogue: 0,0:18:55.80,0:18:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nightingale! Neumann!
Dialogue: 0,0:18:58.30,0:19:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah. Jangan malu-malu.
Dialogue: 0,0:19:03.68,0:19:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Newton, sadarlah!
Dialogue: 0,0:19:05.97,0:19:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merepotkan sekali.
Dialogue: 0,0:19:08.69,0:19:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seperti anak kecil yang takut disuntik.
Dialogue: 0,0:19:17.03,0:19:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau melawan, aku bisa\Nmematahkan lengan dan kakimu, 'kan?
Dialogue: 0,0:19:20.78,0:19:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\Nkau akan segera sembuh setelah diobati.
Dialogue: 0,0:19:24.87,0:19:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Newton...
Dialogue: 0,0:19:34.21,0:19:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pertarungan yang memuaskan.
Dialogue: 0,0:19:36.21,0:19:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh luar biasa!
Dialogue: 0,0:19:40.63,0:19:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang di sana, Touya.
Dialogue: 0,0:19:43.10,0:19:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sisi lain benteng
Dialogue: 0,0:19:44.47,0:19:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada labirin tumbuhan beracun.\NTeruslah berjalan melewatinya.
Dialogue: 0,0:19:49.39,0:19:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu menunggumu di Kastel Pupil Ganda.
Dialogue: 0,0:20:02.03,0:20:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka!
Dialogue: 0,0:20:04.45,0:20:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:20:05.99,0:20:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:20:07.91,0:20:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti mimpi.
Dialogue: 0,0:20:10.54,0:20:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertarung murni untuk diriku sendiri.
Dialogue: 0,0:20:13.54,0:20:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa ideologi, tanpa prinsip,\Ndan tidak peduli menang atau kalah.
Dialogue: 0,0:20:16.09,0:20:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya bertarung sesuai naluri.
Dialogue: 0,0:20:18.51,0:20:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sungguh seperti mimpi.
Dialogue: 0,0:20:20.92,0:20:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka.
Dialogue: 0,0:20:22.34,0:20:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat kembali ke markas.
Dialogue: 0,0:20:24.60,0:20:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita tidak segera merawatmu...
Dialogue: 0,0:20:27.93,0:20:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa sejauh ini.
Dialogue: 0,0:20:31.31,0:20:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus terus melangkah maju.
Dialogue: 0,0:20:34.02,0:20:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, bawa bakat ini bersamamu.
Dialogue: 0,0:20:36.11,0:20:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Keabadian" pasti akan berguna.
Dialogue: 0,0:20:40.19,0:20:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau bicarakan...?
Dialogue: 0,0:20:41.99,0:20:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu menginginkan keabadianku, 'kan?
Dialogue: 0,0:20:44.95,0:20:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena
Dialogue: 0,0:20:47.45,0:20:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktu itu kita orang asing.
Dialogue: 0,0:20:49.87,0:20:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak yang harus kita bicarakan...
Dialogue: 0,0:20:54.67,0:20:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau sangat naif,\Naku ingin memercayakan ini kepadamu.
Dialogue: 0,0:20:59.51,0:21:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu lagi.
Dialogue: 0,0:21:02.01,0:21:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan penyembuhan,\Nbakatku sudah mulai rusak.
Dialogue: 0,0:21:05.89,0:21:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini permintaan pertama dan terakhirku\Nsebagai temanmu.
Dialogue: 0,0:21:09.64,0:21:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kau menerimanya?
Dialogue: 0,0:21:14.06,0:21:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:21:15.48,0:21:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa mengumpulkan bakat banyak Pengembali,
Dialogue: 0,0:21:18.02,0:21:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak bisa melampauinya.
Dialogue: 0,0:21:19.44,0:21:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakaknya Touya sama seperti...
Dialogue: 0,0:21:22.11,0:21:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:21:23.24,0:21:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kau sudah mengerti.
Dialogue: 0,0:21:29.79,0:21:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mendoakanmu. Semoga kau sukses.
Dialogue: 0,0:21:34.62,0:21:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:21:37.13,0:21:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:39.09,0:21:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal.
Dialogue: 0,0:21:43.72,0:21:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal,
Dialogue: 0,0:21:48.85,0:21:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang mendengarku.
Dialogue: 0,0:22:09.28,0:22:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari terus melangkah maju.
Dialogue: 0,0:22:25.38,0:22:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makam?
Dialogue: 0,0:22:26.72,0:22:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian luar kastel tertutup makam.
Dialogue: 0,0:22:28.89,0:22:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak sekali.
Dialogue: 0,0:22:30.83,0:22:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada banyak sekali?
Dialogue: 0,0:22:33.85,0:22:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama-nama Legenda juga ada.
Dialogue: 0,0:22:35.60,0:22:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa? Kenapa?
Dialogue: 0,0:22:40.06,0:22:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:22:41.57,0:22:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak,
Dialogue: 0,0:22:42.48,0:22:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan dipikirkan!
Dialogue: 0,0:22:44.65,0:22:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku hanya bisa fokus\Nuntuk melangkah maju.
Dialogue: 0,0:22:47.32,0:22:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirkan hari-hari memalukan itu.
Dialogue: 0,0:22:54.54,0:22:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}D'Armont manis bahkan saat menguap.
Dialogue: 0,0:22:57.92,0:22:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena dia bosan.
Dialogue: 0,0:22:59.83,0:23:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, sejak Hitler tewas,\N"Indra Bersama" terputus.
Dialogue: 0,0:23:03.96,0:23:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa melihat apa pun lagi.
Dialogue: 0,0:23:06.67,0:23:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, Kouu,
Dialogue: 0,0:23:08.30,0:23:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siapa yang tahu\Nkapan orang yang kau tunggu akan tiba?
Dialogue: 0,0:23:10.59,0:23:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:23:12.10,0:23:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut ramalanku...
Dialogue: 0,0:23:13.39,0:23:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan ramalannya.
Dialogue: 0,0:23:15.60,0:23:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru juga dibicarakan.
Dialogue: 0,0:23:29.28,0:23:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang,
Dialogue: 0,0:23:31.20,0:23:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senji Touya.
Dialogue: 0,0:23:36.70,0:23:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya.
