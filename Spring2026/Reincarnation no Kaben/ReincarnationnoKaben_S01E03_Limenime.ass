Dialogue: 0,0:00:43.16,0:00:44.41,tanda,,0000,0000,0000,,"AKAN DILEPAS TANPA LUKA"
Dialogue: 0,0:00:44.50,0:00:45.62,tanda,,0000,0000,0000,,"RAJA KAMI AKAN BAWA MALAPETAKA LAMPAU"
Dialogue: 0,0:00:45.71,0:00:46.88,tanda,,0000,0000,0000,,"KEPADA KITA SEKALI LAGI"
Dialogue: 0,0:03:12.60,0:03:16.07,tanda,,0000,0000,0000,,PETALS OF REINCARNATION
Dialogue: 0,0:03:58.86,0:04:00.86,tanda,,0000,0000,0000,,P. PICASSO
Dialogue: 0,0:09:34.86,0:09:36.36,tanda,,0000,0000,0000,,YAGYU JUBEI MITSUYOSHI
Dialogue: 0,0:10:36.38,0:10:37.55,tanda,,0000,0000,0000,,CHARLES R. DARWIN
Dialogue: 0,0:10:42.05,0:10:43.18,tanda,,0000,0000,0000,,B. FISCHER
Dialogue: 0,0:10:47.43,0:10:48.69,tanda,,0000,0000,0000,,WRIGHT BERSAUDARI
Dialogue: 0,0:10:57.32,0:10:58.57,tanda,,0000,0000,0000,,E. SCHRODINGER
Dialogue: 0,0:11:13.88,0:11:16.76,tanda,,0000,0000,0000,,"JALUR LANGIT - JALUR BUMI"
Dialogue: 0,0:12:39.46,0:12:42.97,tanda,,0000,0000,0000,,EPISODE 3: PERTEMPURAN DIMULAI
Dialogue: 0,0:12:57.94,0:12:59.44,tanda,,0000,0000,0000,,BAKAT\NORANG-ORANG LANGIT
Dialogue: 0,0:15:46.69,0:15:47.94,tanda,,0000,0000,0000,,BAKAT\NKUCING PENYELEKSI
Dialogue: 0,0:16:01.71,0:16:02.96,tanda,,0000,0000,0000,,BAKAT\NTEORI EVOLUSI
Dialogue: 0,0:16:25.69,0:16:26.52,tanda,,0000,0000,0000,,IBITSU NITEN REIHOU
Dialogue: 0,0:16:26.61,0:16:27.44,tanda,,0000,0000,0000,,MAYAT DELAPAN WARNA
Dialogue: 0,0:18:09.96,0:18:11.09,tanda,,0000,0000,0000,,"JEAN-H. FABRE"
Dialogue: 0,0:18:11.17,0:18:12.67,tanda,,0000,0000,0000,,"BAKAT: PENGAMAT"
Dialogue: 0,0:23:38.21,0:23:39.96,tanda,,0000,0000,0000,,EPISODE 4\NMAHATAHU DAN KORUPSI
Dialogue: 0,0:00:00.95,0:00:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanku membiarkan diri menjadi tawananmu
Dialogue: 0,0:00:03.46,0:00:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah karena ramalanku.
Dialogue: 0,0:00:05.96,0:00:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari-hari sejak kau ditangkap
Dialogue: 0,0:00:08.50,0:00:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat membuat frustrasi,\Ntapi semua terjadi tepat sesuai prediksimu.
Dialogue: 0,0:00:12.38,0:00:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga bahwa Pengembali memakai\Nbenda mirip pisau untuk menarik kekuatan.
Dialogue: 0,0:00:17.85,0:00:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang janggal dengan ini.
Dialogue: 0,0:00:19.81,0:00:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim analisis kami pun kebingungan.\NMereka tak tahu materialnya.
Dialogue: 0,0:00:24.73,0:00:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:00:26.36,0:00:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katakan semua yang kau tahu.
Dialogue: 0,0:00:29.90,0:00:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah jika kau\Nmenolak untuk bekerja sama.
Dialogue: 0,0:00:32.65,0:00:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti akan segera buka mulut.
Dialogue: 0,0:00:34.78,0:00:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Unit Sudut Hitam.
Dialogue: 0,0:00:36.70,0:00:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Unit berisi orang-orang tercerdas\Ndi negara ini
Dialogue: 0,0:00:39.49,0:00:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menangani ancaman nasional.
Dialogue: 0,0:00:43.16,0:00:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara mereka, Nak,
Dialogue: 0,0:00:44.50,0:00:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau menunjukkan bakat bela diri
Dialogue: 0,0:00:45.71,0:00:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setara para legenda bersejarah.
Dialogue: 0,0:00:46.96,0:00:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pada akhirnya,\Nkau hanya manusia biasa.
Dialogue: 0,0:00:50.17,0:00:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keberadaan yang tak berarti.
Dialogue: 0,0:00:52.38,0:00:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mewujudkan dua ramalan.
Dialogue: 0,0:00:55.13,0:00:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu: Aku akan segera dibebaskan\Ntanpa luka.
Dialogue: 0,0:00:59.39,0:01:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua:
Dialogue: 0,0:01:00.39,0:01:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja kami akan membawa malapetaka\Ndari masa lampau sekali lagi.
Dialogue: 0,0:01:05.51,0:01:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan dia kabur!
Dialogue: 0,0:01:12.07,0:01:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa luka?
Dialogue: 0,0:01:16.28,0:01:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jelas terluka sekarang.
Dialogue: 0,0:01:17.78,0:01:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tak terluka.
Dialogue: 0,0:01:19.58,0:01:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:01:22.04,0:01:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, permisi.
Dialogue: 0,0:01:24.33,0:01:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan dia.
Dialogue: 0,0:01:27.37,0:01:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak pintar.
Dialogue: 0,0:01:29.33,0:01:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai kau Pengembali,\Naku pasti sudah merekrutmu.
Dialogue: 0,0:01:33.05,0:01:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab satu pertanyaanku.
Dialogue: 0,0:01:34.80,0:01:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyebut soal "Raja".
Dialogue: 0,0:01:36.55,0:01:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa para Pengembali memang bersatu?
Dialogue: 0,0:01:38.97,0:01:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersatu, ya?
Dialogue: 0,0:01:40.68,0:01:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang ada yang begitu.
Dialogue: 0,0:01:42.97,0:01:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:01:44.10,0:01:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami berbeda.
Dialogue: 0,0:01:46.73,0:01:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:01:48.77,0:01:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelopak...
Dialogue: 0,0:01:50.44,0:01:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu layak disebut Pengembali?
Dialogue: 0,0:01:53.32,0:01:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengabdi sepenuhnya
Dialogue: 0,0:01:55.90,0:01:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepada Raja Pengembali.
Dialogue: 0,0:03:29.08,0:03:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu gawat.
Dialogue: 0,0:03:32.42,0:03:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat misi eliminasi kemarin,
Dialogue: 0,0:03:34.42,0:03:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami diserang Pengembali lain.
Dialogue: 0,0:03:37.00,0:03:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:03:38.01,0:03:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak hancur jadi jus apel saja?
Dialogue: 0,0:03:41.38,0:03:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ciri fisik atau bakat tertentu?
Dialogue: 0,0:03:43.59,0:03:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:03:44.76,0:03:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit menjelaskannya.
Dialogue: 0,0:03:47.26,0:03:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujudnya seperti kabut hitam.
Dialogue: 0,0:03:49.68,0:03:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabut hitam...
Dialogue: 0,0:03:52.90,0:03:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya, yang waktu itu...
Dialogue: 0,0:03:54.73,0:03:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:57.36,0:03:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Picasso?
Dialogue: 0,0:04:01.24,0:04:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menggambarnya. Lihat.
Dialogue: 0,0:04:07.37,0:04:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:04:08.41,0:04:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persis seperti itu!
Dialogue: 0,0:04:11.71,0:04:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, ada apa ini?
Dialogue: 0,0:04:13.25,0:04:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann, Ein, kenapa murung begitu?
Dialogue: 0,0:04:15.96,0:04:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan apa-apa.
Dialogue: 0,0:04:17.92,0:04:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali sikap kalian.
Dialogue: 0,0:04:23.30,0:04:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:04:24.76,0:04:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kabar kalian?
Dialogue: 0,0:04:26.60,0:04:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bawahanku merepotkan kalian\Nbelakangan ini.
Dialogue: 0,0:04:29.93,0:04:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ein, kau masih sembunyi\Ndi belakang orang lain seperti biasa?
Dialogue: 0,0:04:33.89,0:04:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Picasso, masih sibuk menggambar?
Dialogue: 0,0:04:36.56,0:04:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann.
Dialogue: 0,0:04:37.65,0:04:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya kebiasaan mengurung dirimu\Nbelum hilang juga.
Dialogue: 0,0:04:40.90,0:04:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sudah mengumpulkan\Nbeberapa sekutu.
Dialogue: 0,0:04:43.70,0:04:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyedihkan sekali.
Dialogue: 0,0:04:45.49,0:04:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini berkatmu.
Dialogue: 0,0:04:47.70,0:04:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, sangat kusayangkan.
Dialogue: 0,0:04:50.16,0:04:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menghancurkan Hutan.
Dialogue: 0,0:04:53.54,0:04:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mereka yang berbakat\Nharus mengabdi pada umat manusia"?
Dialogue: 0,0:04:56.96,0:04:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dan menyingkirkan bakat jahat"?
Dialogue: 0,0:04:59.42,0:05:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelucon macam apa itu?
Dialogue: 0,0:05:00.96,0:05:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat itu adalah sesuatu\Nyang jauh lebih bebas.
Dialogue: 0,0:05:04.42,0:05:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ein...
Dialogue: 0,0:05:06.05,0:05:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi,
Dialogue: 0,0:05:08.05,0:05:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kukirim kalian kembali\Nke Pusaran Reinkarnasi.
Dialogue: 0,0:05:14.23,0:05:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria tadi itu...
Dialogue: 0,0:05:15.89,0:05:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi.
Dialogue: 0,0:05:18.19,0:05:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang mengatur pergerakan para Pendosa.
Dialogue: 0,0:05:21.40,0:05:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:05:22.61,0:05:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia...
Dialogue: 0,0:05:23.74,0:05:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah...
Dialogue: 0,0:05:25.15,0:05:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pearmain Musim Panas Amerika!
Dialogue: 0,0:05:26.57,0:05:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah, Ein.
Dialogue: 0,0:05:28.03,0:05:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:05:28.95,0:05:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini dia terlihat sangat murka.
Dialogue: 0,0:05:31.29,0:05:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai hilang kendali begini...
Dialogue: 0,0:05:34.37,0:05:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pupil ganda adalah\Nbukti mutlak seorang raja.
Dialogue: 0,0:05:36.83,0:05:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Raja Tiran, Kouu.
Dialogue: 0,0:05:38.88,0:05:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria dengan bakat seni bela diri tertinggi,
Dialogue: 0,0:05:42.42,0:05:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekaligus pendiri Hutan Para Legenda.
Dialogue: 0,0:05:46.63,0:05:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, Hutan Para Legenda\Ntidaklah sebesar ini.
Dialogue: 0,0:05:50.30,0:05:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada kami berlima.
Dialogue: 0,0:05:52.18,0:05:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann!
Dialogue: 0,0:05:53.89,0:05:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dipimpin oleh seseorang.
Dialogue: 0,0:05:56.89,0:05:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang bodoh yang tak pernah\Nmemedulikan dirinya sendiri,
Dialogue: 0,0:05:59.86,0:06:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi selalu tulus memperlakukan orang lain.
Dialogue: 0,0:06:06.20,0:06:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang mengusulkan
Dialogue: 0,0:06:08.32,0:06:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar kami berkontribusi bagi umat manusia.
Dialogue: 0,0:06:10.32,0:06:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia percaya bakat dari reinkarnasi\Nadalah berkah ilahi
Dialogue: 0,0:06:14.12,0:06:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang harus digunakan demi menolong sesama.
Dialogue: 0,0:06:16.66,0:06:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:06:17.71,0:06:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu yang jadi prinsip dasar\NHutan Para Legenda?
Dialogue: 0,0:06:22.21,0:06:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, apa yang terjadi kepadanya?
Dialogue: 0,0:06:23.71,0:06:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dibunuh.
Dialogue: 0,0:06:25.13,0:06:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibunuh oleh Kouu.
Dialogue: 0,0:06:27.22,0:06:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu hanya peduli pada pertarungan.
Dialogue: 0,0:06:29.59,0:06:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkontribusi bagi umat manusia\Npasti sangat membosankan baginya.
Dialogue: 0,0:06:33.64,0:06:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari insiden itu, kami sadar
Dialogue: 0,0:06:36.31,0:06:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami takkan pernah sejalan\Ndengan pemilik bakat jahat.
Dialogue: 0,0:06:39.44,0:06:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyingkirkan mereka sepenuhnya
Dialogue: 0,0:06:41.90,0:06:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah prioritas utama kami\Ndalam berkontribusi bagi umat manusia.
Dialogue: 0,0:06:45.82,0:06:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:06:47.36,0:06:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya Hutan Para Legenda
Dialogue: 0,0:06:49.07,0:06:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dibentuk untuk membasmi\Npara Pengembali jahat.
Dialogue: 0,0:06:50.95,0:06:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengumpulkan orang-orang berbakat jahat.
Dialogue: 0,0:06:53.74,0:06:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuannya kemungkinan besar
Dialogue: 0,0:06:55.79,0:06:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengulang kembali\Npembantaian dan kekejaman.
Dialogue: 0,0:06:58.71,0:07:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelaparan, perang, dan tirani.
Dialogue: 0,0:07:02.58,0:07:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:07:03.84,0:07:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengulang kembali\Ntragedi terburuk dalam sejarah.
Dialogue: 0,0:07:07.80,0:07:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita sudah membunuhnya?
Dialogue: 0,0:07:10.18,0:07:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, aku pasti akan membunuhnya!
Dialogue: 0,0:07:12.64,0:07:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, ya?
Dialogue: 0,0:07:15.10,0:07:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar tebakanmu, Touya.
Dialogue: 0,0:07:17.64,0:07:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami melancarkan serangan mendadak
Dialogue: 0,0:07:19.64,0:07:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat Kouu pergi\Nmeninggalkan Hutan Para Legenda.
Dialogue: 0,0:07:21.98,0:07:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka dia masih hidup.
Dialogue: 0,0:07:24.02,0:07:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera menyingkirkannya.
Dialogue: 0,0:07:27.53,0:07:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh dia meski harus maju sendiri!
Dialogue: 0,0:07:29.19,0:07:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku tak bisa membiarkanmu.
Dialogue: 0,0:07:32.24,0:07:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa gegabah menyerang\Ntanpa tahu kekuatan musuh.
Dialogue: 0,0:07:35.24,0:07:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertindak sendiri hanya akan\Nmembahayakan rekan-rekanmu...
Dialogue: 0,0:07:39.75,0:07:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teramonts!
Dialogue: 0,0:07:41.29,0:07:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ein.
Dialogue: 0,0:07:42.25,0:07:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:07:43.88,0:07:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah tahu itu!
Dialogue: 0,0:07:45.96,0:07:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:07:47.75,0:07:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh. Seperti biasa,\Ntanganmu cepat sekali bergerak.
Dialogue: 0,0:07:51.30,0:07:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang melarangmu pergi.
Dialogue: 0,0:07:53.93,0:07:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bertarung bersama.
Dialogue: 0,0:07:56.47,0:07:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu seberapa dalam\Nkebencianmu pada Kouu,
Dialogue: 0,0:07:59.35,0:08:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau seberapa banyak orang terkasihmu\Nyang direnggut olehnya.
Dialogue: 0,0:08:03.77,0:08:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak berniat ikut campur.
Dialogue: 0,0:08:06.52,0:08:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di sini,
Dialogue: 0,0:08:08.11,0:08:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak sendirian, 'kan?
Dialogue: 0,0:08:11.86,0:08:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar begitu, Neumann?
Dialogue: 0,0:08:13.28,0:08:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:14.62,0:08:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama, kita pasti bisa menang.
Dialogue: 0,0:08:18.16,0:08:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita punya kesempatan menyingkirkan\Npara bakat jahat itu selamanya.
Dialogue: 0,0:08:21.71,0:08:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertarunglah!
Dialogue: 0,0:08:23.00,0:08:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari pertaruhkan harga diri\NHutan Para Legenda,
Dialogue: 0,0:08:25.13,0:08:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kalahkan Kouu beserta pasukannya!
Dialogue: 0,0:08:29.96,0:08:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan sesuka kalian.
Dialogue: 0,0:08:32.34,0:08:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka.
Dialogue: 0,0:08:36.76,0:08:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka.
Dialogue: 0,0:08:38.67,0:08:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengandalkanmu.
Dialogue: 0,0:08:40.97,0:08:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Kastel Pupil Ganda.
Dialogue: 0,0:08:43.05,0:08:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benteng Kouu dan para Pendosa.
Dialogue: 0,0:08:46.27,0:08:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menemukan lokasi mereka\Nhanya dalam sepekan...
Dialogue: 0,0:08:48.90,0:08:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali kau, Neumann.
Dialogue: 0,0:08:50.48,0:08:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku ini terhitung lambat.
Dialogue: 0,0:08:52.36,0:08:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah gatal ingin bertarung.
Dialogue: 0,0:08:54.95,0:08:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, lama tidak berjumpa!
Dialogue: 0,0:08:58.28,0:09:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musashi!
Dialogue: 0,0:09:00.87,0:09:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malu-malu begitu.
Dialogue: 0,0:09:03.00,0:09:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, peluk aku!
Dialogue: 0,0:09:05.75,0:09:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bersemangat seperti biasa, ya.
Dialogue: 0,0:09:07.29,0:09:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga masih secantik dulu.
Dialogue: 0,0:09:09.55,0:09:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana?
Dialogue: 0,0:09:10.67,0:09:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bermalam denganku...
Dialogue: 0,0:09:19.64,0:09:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau datang membawa pria.
Dialogue: 0,0:09:22.06,0:09:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau sudah jadi lembek,
Dialogue: 0,0:09:24.06,0:09:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musashi.
Dialogue: 0,0:09:25.27,0:09:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubei...
Dialogue: 0,0:09:26.60,0:09:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tampak sehat.
Dialogue: 0,0:09:30.61,0:09:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah menyeretmu ke sini.
Dialogue: 0,0:09:33.07,0:09:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Yagyu Jubei.
Dialogue: 0,0:09:36.53,0:09:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Ishikawa Goemon, 'kan?
Dialogue: 0,0:09:39.83,0:09:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Caesar, pria yang bahkan\Nmampu menaklukkan takdir.
Dialogue: 0,0:09:42.58,0:09:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Brutus,
Dialogue: 0,0:09:43.50,0:09:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan kehadiranku,
Dialogue: 0,0:09:45.08,0:09:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemenangan sudah pasti di tangan.
Dialogue: 0,0:09:46.83,0:09:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan Brutus...
Dialogue: 0,0:09:48.33,0:09:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu melihat sosok hebatku ini,\Nkau pasti akan berseru,
Dialogue: 0,0:09:51.13,0:09:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku datang, aku melihat,\Naku menaklukkan."
Dialogue: 0,0:09:53.92,0:09:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau cerewet sekali!
Dialogue: 0,0:09:55.34,0:09:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar raja botak mata keranjang\Nyang terlilit utang!
Dialogue: 0,0:09:58.84,0:10:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebutku Caesar botak?\NSama sekali tak lucu.
Dialogue: 0,0:10:01.81,0:10:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, lepas mahkota daun itu.
Dialogue: 0,0:10:05.06,0:10:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa. Ini simbol kehormatanku.
Dialogue: 0,0:10:07.10,0:10:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas saja!
Dialogue: 0,0:10:09.56,0:10:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya, kau tiba-tiba\Nterlibat dengan mereka?
Dialogue: 0,0:10:12.44,0:10:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa mereka?
Dialogue: 0,0:10:14.74,0:10:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup Ekspedisi Hutan Para Legenda\Ndari seluruh dunia.
Dialogue: 0,0:10:18.36,0:10:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berkumpul di sini hari ini\Natas panggilan Neumann.
Dialogue: 0,0:10:21.62,0:10:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh pemandangan yang spektakuler.
Dialogue: 0,0:10:23.62,0:10:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat begitu banyak bakat bersejarah\Nberkumpul di satu tempat...
Dialogue: 0,0:10:27.37,0:10:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak butuh pasukan sebanyak ini.
Dialogue: 0,0:10:30.17,0:10:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka cuma pecundang sejarah.
Dialogue: 0,0:10:32.75,0:10:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa taktik pun,\Nkehancuran mereka takkan terhindarkan.
Dialogue: 0,0:10:37.63,0:10:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga enggan bekerja sama.
Dialogue: 0,0:10:39.26,0:10:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, akulah\Nahli strategi militer terbaik di sini.
Dialogue: 0,0:10:43.51,0:10:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Kak?
Dialogue: 0,0:10:45.35,0:10:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kau senang, aku ikut saja.
Dialogue: 0,0:10:49.10,0:10:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\Nsemua cuma masalah probabilitas.
Dialogue: 0,0:10:51.81,0:10:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada menyusun aliansi yang ceroboh,
Dialogue: 0,0:10:53.82,0:10:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik kita bergerak sendiri-sendiri\Nmengincar kepala Kouu.
Dialogue: 0,0:10:58.90,0:11:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup Ekspedisi menolak bekerja sama.
Dialogue: 0,0:11:02.32,0:11:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:11:03.99,0:11:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuanku di sini bukan untuk menang.
Dialogue: 0,0:11:06.54,0:11:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin memanfaatkan\Nkekacauan pertempuran ini
Dialogue: 0,0:11:08.16,0:11:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi mencuri bakat sebanyak mungkin.
Dialogue: 0,0:11:10.58,0:11:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.\NLakukan sesukamu.
Dialogue: 0,0:11:12.96,0:11:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku ingin kalian
Dialogue: 0,0:11:13.88,0:11:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyerang dari tiga rute ini.
Dialogue: 0,0:11:16.84,0:11:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kekuatan kita menumpuk di satu titik,
Dialogue: 0,0:11:18.30,0:11:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang akan menyeimbangkannya.
Dialogue: 0,0:11:20.01,0:11:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan...
Dialogue: 0,0:11:23.47,0:11:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann.
Dialogue: 0,0:11:25.06,0:11:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mendobrak benteng di Jalur Bumi,
Dialogue: 0,0:11:27.06,0:11:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu merangsek ke kastel utama.
Dialogue: 0,0:11:28.56,0:11:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fabre dan Ishikawa Goemon...
Dialogue: 0,0:11:31.77,0:11:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, Touya akan ikut bersamaku.
Dialogue: 0,0:11:34.77,0:11:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau memilihku?
Dialogue: 0,0:11:36.07,0:11:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:11:37.57,0:11:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sangat tertarik kepadamu, Touya.
Dialogue: 0,0:11:42.32,0:11:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:11:43.57,0:11:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cari alasan\Nsupaya bisa bergerak sendiri.
Dialogue: 0,0:11:46.91,0:11:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa, ya?
Dialogue: 0,0:11:49.87,0:11:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Semuanya, ambil posisi.
Dialogue: 0,0:11:52.46,0:11:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai misi pemusnahan\NPasukan Pendosa sekarang.
Dialogue: 0,0:11:55.96,0:11:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan musuh tidak diketahui.
Dialogue: 0,0:11:58.01,0:12:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah melawan beberapa Pendosa\Ndengan kekuatan sekaliber sejarah.
Dialogue: 0,0:12:01.72,0:12:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan gentar. Habisi mereka.
Dialogue: 0,0:12:04.93,0:12:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di pertempuran ini,
Dialogue: 0,0:12:07.51,0:12:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan memusnahkan seluruh bakat jahat\Nyang lahir dari reinkarnasi.
Dialogue: 0,0:12:10.10,0:12:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musashi, Jubei.
Dialogue: 0,0:12:15.44,0:12:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita bertemu di kastel utama.
Dialogue: 0,0:12:18.40,0:12:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa saat kita bertemu lagi,
Dialogue: 0,0:12:20.40,0:12:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah menjadi jauh lebih kuat.
Dialogue: 0,0:12:23.36,0:12:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat waktunya tiba,
Dialogue: 0,0:12:27.78,0:12:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memiliki bakat hebat\Nyang takkan bisa kau tolak untuk dicuri.
Dialogue: 0,0:12:33.50,0:12:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito...
Dialogue: 0,0:12:46.93,0:12:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dimulai.
Dialogue: 0,0:12:48.64,0:12:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:49.56,0:12:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wright Bersaudari.
Dialogue: 0,0:12:51.23,0:12:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliran kalian.
Dialogue: 0,0:13:09.45,0:13:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengkhawatirkannya?
Dialogue: 0,0:13:11.91,0:13:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang Nona Musashi.
Dialogue: 0,0:13:13.00,0:13:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:13.91,0:13:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak usah ditutup-tutupi.
Dialogue: 0,0:13:14.96,0:13:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pacaran, 'kan?
Dialogue: 0,0:13:16.79,0:13:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kami terlihat seperti itu?
Dialogue: 0,0:13:18.84,0:13:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:19.96,0:13:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatapan kalian berdua terkadang\Nterlihat sangat intens.
Dialogue: 0,0:13:23.05,0:13:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:24.17,0:13:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:13:25.43,0:13:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau
Dialogue: 0,0:13:26.64,0:13:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tipe penyendiri yang tidak peduli\Npada keadaan sekitar.
Dialogue: 0,0:13:31.22,0:13:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tidak pandai\Nmengekspresikan perasaanku.
Dialogue: 0,0:13:34.81,0:13:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa di antara aku dan Haito.
Dialogue: 0,0:13:37.27,0:13:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri tidak apa-apa, Funasaka?
Dialogue: 0,0:13:39.44,0:13:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu bersama Nona Nightingale,\Njadi berpisah darinya pasti...
Dialogue: 0,0:13:44.49,0:13:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tiba-tiba bilang begitu?
Dialogue: 0,0:13:45.90,0:13:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:13:47.45,0:13:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin kau mengenal seseorang,\Nmakin dalam pula perasaanmu padanya.
Dialogue: 0,0:13:49.99,0:13:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan itu akan memicu keraguan.
Dialogue: 0,0:13:51.95,0:13:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keraguan saat mencuri bakat.
Dialogue: 0,0:13:53.62,0:13:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau keraguan saat harus menyerang.
Dialogue: 0,0:13:55.29,0:13:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau mengobrol,\Nbahaslah sesuatu yang lebih berguna.
Dialogue: 0,0:14:01.04,0:14:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada serangan musuh.
Dialogue: 0,0:14:02.67,0:14:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya lebih dari satu.
Dialogue: 0,0:14:05.22,0:14:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar mendengar jeritan
Dialogue: 0,0:14:06.97,0:14:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuh manusia yang dihancurkan!
Dialogue: 0,0:14:09.93,0:14:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Pencekik, DeSalvo.
Dialogue: 0,0:14:12.64,0:14:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Orang Mati, Hickok.
Dialogue: 0,0:14:15.48,0:14:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pencabik Merah, Chikatilo.
Dialogue: 0,0:14:18.19,0:14:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Pembunuh, Okada Izo.
Dialogue: 0,0:14:20.81,0:14:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaki Gajah, Jahangir.
Dialogue: 0,0:14:23.36,0:14:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua Pendosa ternama.
Dialogue: 0,0:14:25.44,0:14:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kita lakukan?
Dialogue: 0,0:14:27.53,0:14:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu lapor yang lain?
Dialogue: 0,0:14:29.11,0:14:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah.
Dialogue: 0,0:14:40.46,0:14:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran bakat hebat apa\Nyang akan kulawan.
Dialogue: 0,0:14:43.55,0:14:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata cuma penembak?
Dialogue: 0,0:14:51.22,0:14:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap musuh berikutnya\Njauh lebih tangguh...
Dialogue: 0,0:14:58.31,0:14:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak apa-apa?
Dialogue: 0,0:14:59.35,0:15:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal peluruku menembus kepalamu...
Dialogue: 0,0:15:00.65,0:15:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:01.69,0:15:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baru saja menembakku sampai mati.
Dialogue: 0,0:15:04.53,0:15:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:15:05.48,0:15:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dunia paralel,
Dialogue: 0,0:15:07.03,0:15:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada versi diriku yang berhasil\Nmenghindar dan tetap hidup.
Dialogue: 0,0:15:10.11,0:15:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kupilih versi diriku yang itu.
Dialogue: 0,0:15:11.87,0:15:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu apa?\NAku sama sekali tak paham.
Dialogue: 0,0:15:20.92,0:15:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan menembakku tak seberapa.
Dialogue: 0,0:15:24.17,0:15:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu bukan masalah.
Dialogue: 0,0:15:27.01,0:15:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu kenapa?
Dialogue: 0,0:15:30.05,0:15:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabannya sangat sederhana.
Dialogue: 0,0:15:32.05,0:15:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekecil apa pun kemungkinannya,
Dialogue: 0,0:15:34.05,0:15:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa memilih versi dirimu\Nyang terluka parah di dunia lain.
Dialogue: 0,0:15:40.89,0:15:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Pendosa, semua malapetaka\Nyang kalian tebar di dunia ini
Dialogue: 0,0:15:44.69,0:15:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kutolak mentah-mentah.
Dialogue: 0,0:15:49.57,0:15:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan!
Dialogue: 0,0:15:52.28,0:15:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa...
Dialogue: 0,0:15:57.49,0:16:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat yang terus berevolusi\Nsesuai kondisi dan kebutuhan.
Dialogue: 0,0:16:00.58,0:16:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teori Evolusi.
Dialogue: 0,0:16:03.21,0:16:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya mereka yang mampu beradaptasi\Nyang akan bertahan hidup.
Dialogue: 0,0:16:06.59,0:16:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tereliminasilah oleh sejarah sekali lagi,
Dialogue: 0,0:16:09.84,0:16:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wahai spesies inferior.
Dialogue: 0,0:16:15.76,0:16:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus,
Dialogue: 0,0:16:16.97,0:16:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benteng dan Ratu.
Dialogue: 0,0:16:18.93,0:16:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendosa kelas teri...
Dialogue: 0,0:16:20.73,0:16:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata lemah sekali.
Dialogue: 0,0:16:22.23,0:16:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:16:24.10,0:16:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Delapan Warna.
Dialogue: 0,0:16:29.40,0:16:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan barusan kurang menantang.
Dialogue: 0,0:16:32.53,0:16:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau malah ambil jatah musuh kuat?
Dialogue: 0,0:16:35.16,0:16:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik kau lari-lari saja sana\Nseperti Caesar.
Dialogue: 0,0:16:37.83,0:16:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kemari untuk membantumu\Nkarena kau takkan sanggup sendirian.
Dialogue: 0,0:16:41.50,0:16:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma mengandalkan Musashi,\Nkita pasti sudah mati.
Dialogue: 0,0:16:43.71,0:16:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:16:44.92,0:16:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:16:46.08,0:16:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bertengkar terus.
Dialogue: 0,0:16:48.25,0:16:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang wajah manis kalian kalau...
Dialogue: 0,0:16:50.05,0:16:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, ayo kita jalan!
Dialogue: 0,0:16:56.18,0:16:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obsesi yang gila pada pencekikan.
Dialogue: 0,0:16:59.39,0:17:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibiarkan begini...
Dialogue: 0,0:17:01.27,0:17:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu menggunakan bakat kita.
Dialogue: 0,0:17:03.89,0:17:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti menang asalkan terus\Nmengulur waktu sambil bermanuver.
Dialogue: 0,0:17:16.95,0:17:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhenti, kita akan dikepung.
Dialogue: 0,0:17:18.86,0:17:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari tahan mereka sambil mundur.
Dialogue: 0,0:17:21.50,0:17:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksud semua ini...
Dialogue: 0,0:17:23.07,0:17:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Touya.
Dialogue: 0,0:17:28.75,0:17:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:17:43.89,0:17:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Fabre.
Dialogue: 0,0:17:48.27,0:17:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang barusan terjadi?
Dialogue: 0,0:17:50.15,0:17:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tak melihat\Nkeberadaan Fabre...
Dialogue: 0,0:17:52.32,0:17:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja.
Dialogue: 0,0:17:54.28,0:17:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat Fabre itu bersembunyi.
Dialogue: 0,0:17:56.91,0:17:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa menghapus wujud,\Naroma, hingga suaranya.
Dialogue: 0,0:17:59.37,0:18:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan hawa keberadaannya pun lenyap.
Dialogue: 0,0:18:03.12,0:18:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia terus mengikuti kita sejak awal.
Dialogue: 0,0:18:07.33,0:18:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjatanya adalah jarum suntik\Nberisi racun serangga.
Dialogue: 0,0:18:09.96,0:18:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada satu makhluk pun yang bisa lolos
Dialogue: 0,0:18:11.17,0:18:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari suntikan mautnya.
Dialogue: 0,0:18:13.38,0:18:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tak bisa mati, akulah umpannya.
Dialogue: 0,0:18:16.30,0:18:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Fabre yang tak terdeteksi\Nakan melancarkan serangan diam-diam.
Dialogue: 0,0:18:19.64,0:18:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua ini duet maut yang sempurna.
Dialogue: 0,0:18:26.27,0:18:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini luar biasa?
Dialogue: 0,0:18:28.48,0:18:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku punya bakat tak kasatmata itu...
Dialogue: 0,0:18:30.11,0:18:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu digabungkan dengan tangan kananku,\Naku bisa mencuri bakat dengan bebas!
Dialogue: 0,0:18:34.44,0:18:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau wujud Fabre tak terlihat...
Dialogue: 0,0:18:39.95,0:18:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka.
Dialogue: 0,0:18:41.33,0:18:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:18:43.33,0:18:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:44.62,0:18:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia tidak sadar\Nkalau kita sedang mengawasinya.
Dialogue: 0,0:18:47.00,0:18:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa dugaanmu itu benar?
Dialogue: 0,0:18:49.63,0:18:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus awasi Senji Touya.
Dialogue: 0,0:18:52.04,0:18:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kemungkinan dia itu mata-mata.
Dialogue: 0,0:18:54.30,0:18:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita belum bisa memastikannya.
Dialogue: 0,0:18:56.38,0:18:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi belakangan, dia sering\Nmematikan ponselnya.
Dialogue: 0,0:18:59.68,0:19:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerak-geriknya yang sibuk menyelidiki\Nbakat anggota lain juga mencurigakan.
Dialogue: 0,0:19:03.93,0:19:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tadi dia baru saja melindungiku.
Dialogue: 0,0:19:07.18,0:19:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku ini abadi.
Dialogue: 0,0:19:08.52,0:19:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah biasa jadi tameng semua orang.
Dialogue: 0,0:19:09.98,0:19:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi baru kali ini\Nada seseorang yang repot-repot melindungiku.
Dialogue: 0,0:19:11.36,0:19:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal itu tak pernah terjadi sebelumnya.
Dialogue: 0,0:19:13.32,0:19:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja\Nitu triknya agar terlihat sebagai sekutu.
Dialogue: 0,0:19:16.19,0:19:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, jangan sampai lengah.
Dialogue: 0,0:19:18.78,0:19:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:22.12,0:19:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mengabulkan harapan sang Raja
Dialogue: 0,0:19:24.12,0:19:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membalaskan dendam rekan yang gugur,
Dialogue: 0,0:19:26.37,0:19:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menembak mati dia.
Dialogue: 0,0:19:33.67,0:19:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meleset?
Dialogue: 0,0:19:34.88,0:19:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tembakanku tadi\Nsudah kuselaraskan dengan bunyi lonceng.
Dialogue: 0,0:19:38.97,0:19:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil meleset...
Dialogue: 0,0:19:42.93,0:19:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini Wright Bersaudari.
Dialogue: 0,0:19:44.89,0:19:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kami diserang.
Dialogue: 0,0:19:47.43,0:19:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panik.
Dialogue: 0,0:19:48.60,0:19:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbanglah terus di udara.
Dialogue: 0,0:19:51.44,0:19:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Kematian Putih.
Dialogue: 0,0:19:53.27,0:19:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hayha akan mengurusnya untuk kalian.
Dialogue: 0,0:19:55.73,0:19:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...\Ndia penembak jitu legendaris itu?
Dialogue: 0,0:20:00.82,0:20:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana asal tembakannya?
Dialogue: 0,0:20:03.16,0:20:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas kastel utama.
Dialogue: 0,0:20:05.03,0:20:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat menara jam.
Dialogue: 0,0:20:06.41,0:20:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuhitung kalkulasi balistiknya\Nsekarang juga.
Dialogue: 0,0:20:09.16,0:20:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:20:12.25,0:20:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia melihat\Nkilatan cahaya tembakan senjataku dan...
Dialogue: 0,0:20:14.71,0:20:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penglihatan dinamis\Ndan fokusnya luar biasa.
Dialogue: 0,0:20:17.67,0:20:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau cuma itu bakatnya,
Dialogue: 0,0:20:20.13,0:20:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakat "Menembak Setepat Jarum Jam" milikku\Ntakkan pernah kalah...
Dialogue: 0,0:20:29.64,0:20:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salju?
Dialogue: 0,0:20:30.89,0:20:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:20:32.69,0:20:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah wujud bakat Hayha?
Dialogue: 0,0:20:39.23,0:20:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sengaja meleset...
Dialogue: 0,0:20:41.20,0:20:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakan peringatan untuk mengajak duel.
Dialogue: 0,0:20:44.07,0:20:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan cuma sok hebat, dia percaya diri.
Dialogue: 0,0:20:47.24,0:20:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:20:49.04,0:20:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jam tembakan menyebar.
Dialogue: 0,0:20:51.87,0:20:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita selesaikan.
Dialogue: 0,0:20:55.96,0:20:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Hayha?
Dialogue: 0,0:20:57.92,0:20:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berakhir.
Dialogue: 0,0:21:00.63,0:21:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi selesai.
Dialogue: 0,0:21:08.60,0:21:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rajaku...
Dialogue: 0,0:21:11.06,0:21:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku karena gagal membalaskan\Ndendam rekan-rekan kita.
Dialogue: 0,0:21:15.81,0:21:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak penting.
Dialogue: 0,0:21:18.27,0:21:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah puas bertarung?
Dialogue: 0,0:21:20.53,0:21:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sungguh menyenangkan.
Dialogue: 0,0:21:23.40,0:21:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:28.33,0:21:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Schrodinger,
Dialogue: 0,0:21:29.74,0:21:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau pertempurannya sudah mereda,\Nmundur dan berkumpullah.
Dialogue: 0,0:21:32.62,0:21:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus berkumpul kembali.
Dialogue: 0,0:21:34.50,0:21:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubereskan dulu hama di dekat sini,\Nsetelah itu aku akan menyusul.
Dialogue: 0,0:21:39.04,0:21:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kucing sangat suka kebersihan.
Dialogue: 0,0:21:44.01,0:21:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, membosankan sekali.
Dialogue: 0,0:21:46.68,0:21:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tak banyak musuh yang tersisa.
Dialogue: 0,0:21:49.10,0:21:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, mereka itu terlalu percaya diri.
Dialogue: 0,0:21:51.64,0:21:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Pendosa itu bukan pemilik bakat,\Ncuma orang tak waras biasa.
Dialogue: 0,0:21:54.77,0:21:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani-beraninya mereka\Nmencari masalah dengan kita.
Dialogue: 0,0:21:56.65,0:21:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau boleh saja mengeluh,\Ntapi jangan sampai lengah.
Dialogue: 0,0:21:59.02,0:21:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:21:59.98,0:22:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diomeli.
Dialogue: 0,0:22:02.48,0:22:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:22:03.69,0:22:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:22:06.61,0:22:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kenapa, Wright Bersaudari?
Dialogue: 0,0:22:13.20,0:22:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena! Tepat sasaran!
Dialogue: 0,0:22:15.75,0:22:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu Putih memang hebat.
Dialogue: 0,0:22:17.88,0:22:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membayangkan\Nbetapa kagetnya wajah Neumann nanti.
Dialogue: 0,0:22:23.13,0:22:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya telah tiba.
Dialogue: 0,0:22:25.26,0:22:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertunjukan yang sesungguhnya\Nakan segera dimulai.
Dialogue: 0,0:22:27.34,0:22:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah dan bersenang-senanglah.
Dialogue: 0,0:22:30.14,0:22:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima Jenderal Harimau.
Dialogue: 0,0:22:32.14,0:22:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sepertinya\Nada satu dari kita yang menghilang.
Dialogue: 0,0:22:38.31,0:22:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:22:39.48,0:22:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan apa-apa.
Dialogue: 0,0:22:41.61,0:22:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komunikasi dengan Neumann terputus.
Dialogue: 0,0:22:43.90,0:22:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu di markas?
Dialogue: 0,0:22:45.49,0:22:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhubung tak ada yang memberi arahan,
Dialogue: 0,0:22:47.15,0:22:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus mengambil keputusan sendiri.
Dialogue: 0,0:22:50.16,0:22:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka, awas!
Dialogue: 0,0:23:01.79,0:23:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat itu...
Dialogue: 0,0:23:03.50,0:23:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bakat Tentara Pendosa\Nyang dibilang Neumann.
Dialogue: 0,0:23:07.17,0:23:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau memakai bakat para Pendosa?
Dialogue: 0,0:23:11.30,0:23:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau ini mata-mata musuh?
Dialogue: 0,0:23:14.60,0:23:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata-mata?
Dialogue: 0,0:23:17.14,0:23:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat jawab pertanyaanku!
Dialogue: 0,0:23:18.77,0:23:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak...
Dialogue: 0,0:23:20.19,0:23:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, bukan begitu!
Dialogue: 0,0:23:21.40,0:23:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon percayalah kepadaku!
Dialogue: 0,0:23:36.62,0:23:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahatahu dan Korupsi.
