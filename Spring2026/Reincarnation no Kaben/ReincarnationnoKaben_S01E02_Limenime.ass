Dialogue: 0,0:01:48.94,0:01:52.02,tanda,,0000,0000,0000,,PETALS OF REINCARNATION
Dialogue: 0,0:03:36.00,0:03:37.50,tanda,,0000,0000,0000,,"JOHN W. GACY"
Dialogue: 0,0:04:36.10,0:04:37.81,tanda,,0000,0000,0000,,EDWARD T. GEIN
Dialogue: 0,0:05:07.55,0:05:08.39,tanda,,0000,0000,0000,,I. NEWTON
Dialogue: 0,0:05:08.47,0:05:09.51,tanda,,0000,0000,0000,,BAKAT: BUAH GRAVITASI\NI. NEWTON
Dialogue: 0,0:05:24.53,0:05:25.36,tanda,,0000,0000,0000,,A. EINSTEIN
Dialogue: 0,0:05:25.45,0:05:26.53,tanda,,0000,0000,0000,,BAKAT: PERPINDAHAN RUANG\NA. EINSTEIN
Dialogue: 0,0:06:08.41,0:06:09.24,tanda,,0000,0000,0000,,"FUNASAKA HIROSHI"
Dialogue: 0,0:06:09.32,0:06:10.32,tanda,,0000,0000,0000,,BAKAT: PRAJURIT ABADI
Dialogue: 0,0:06:25.63,0:06:26.47,tanda,,0000,0000,0000,,H. DRIESCH
Dialogue: 0,0:06:26.55,0:06:27.59,tanda,,0000,0000,0000,,BAKAT: REPLIKATOR\NH. DRIESCH
Dialogue: 0,0:07:06.51,0:07:07.42,tanda,,0000,0000,0000,,F. NIGHTINGALE
Dialogue: 0,0:07:07.51,0:07:09.01,tanda,,0000,0000,0000,,BAKAT: MALAIKAT PENYEMBUH\NF. NIGHTINGALE
Dialogue: 0,0:09:36.15,0:09:37.57,tanda,,0000,0000,0000,,"KITAZUKA ITSUKI"
Dialogue: 0,0:11:43.66,0:11:45.20,tanda,,0000,0000,0000,,"KAU TIDAK BERBAKAT"
Dialogue: 0,0:12:06.89,0:12:08.02,tanda,,0000,0000,0000,,EPISODE 2\NMAKNA MENJADI PEMILIK
Dialogue: 0,0:14:19.65,0:14:21.69,tanda,,0000,0000,0000,,"MINAMI YOSHIKI"
Dialogue: 0,0:23:38.08,0:23:40.08,tanda,,0000,0000,0000,,EPISODE 3\NPERTARUNGAN DIMULAI
Dialogue: 0,0:00:08.50,0:00:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben kau sudah bangun\Nsebelum alarm berbunyi?
Dialogue: 0,0:00:10.76,0:00:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku baru mau menelepon\Nuntuk membangunkanmu.
Dialogue: 0,0:00:12.51,0:00:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau bergadang\Nuntuk belajar semalaman.
Dialogue: 0,0:00:17.18,0:00:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau sudah memiliki Bakat.
Dialogue: 0,0:00:22.02,0:00:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu?
Dialogue: 0,0:00:23.64,0:00:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tugasku hari ini?
Dialogue: 0,0:00:26.10,0:00:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membasmi Pengembali jahat.
Dialogue: 0,0:00:28.98,0:00:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:00:30.15,0:00:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum itu,\Naku ingin kau mampir ke suatu tempat.
Dialogue: 0,0:02:09.28,0:02:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sampai.
Dialogue: 0,0:02:14.63,0:02:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bangunlah.
Dialogue: 0,0:02:16.47,0:02:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun.
Dialogue: 0,0:02:17.51,0:02:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito Luo Buffett!
Dialogue: 0,0:02:22.35,0:02:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:26.89,0:02:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menjemputku.
Dialogue: 0,0:02:28.98,0:02:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh memalukan.
Dialogue: 0,0:02:30.69,0:02:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa seorang Musashi menangis.
Dialogue: 0,0:02:32.81,0:02:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal tahu saja, aku berlatih sampai subuh.
Dialogue: 0,0:02:37.28,0:02:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau ketularan Touya, ya?
Dialogue: 0,0:02:40.03,0:02:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuang waktu untuk hal tak berguna.
Dialogue: 0,0:02:41.57,0:02:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal bakatmu itu jauh melampaui usahamu.
Dialogue: 0,0:02:43.87,0:02:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seribu hari untuk menempa,\Nsepuluh ribu hari untuk menyempurnakan.
Dialogue: 0,0:02:48.91,0:02:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bercanda.
Dialogue: 0,0:02:50.21,0:02:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simpan saja leluconmu.
Dialogue: 0,0:02:51.92,0:02:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita punya misi. Bersiaplah.
Dialogue: 0,0:02:53.92,0:02:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:02:57.59,0:02:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Target kita adalah pemilik bakat Gacy.
Dialogue: 0,0:03:00.13,0:03:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mendekati anak-anak\Ndengan kostum badut kesukaan mereka,
Dialogue: 0,0:03:02.85,0:03:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu membunuhnya.
Dialogue: 0,0:03:04.97,0:03:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pembunuh familiar\Nyang dijuluki "Badut Pembunuh".
Dialogue: 0,0:03:10.02,0:03:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap waspada.
Dialogue: 0,0:03:11.27,0:03:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah memasuki persembunyian target.
Dialogue: 0,0:03:15.19,0:03:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melompatlah ke kiri dan\Nkanan sesuai aba-abaku.
Dialogue: 0,0:03:17.40,0:03:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga.
Dialogue: 0,0:03:18.49,0:03:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua.
Dialogue: 0,0:03:19.40,0:03:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu.
Dialogue: 0,0:03:22.91,0:03:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian memasuki perangkapku.
Dialogue: 0,0:03:25.37,0:03:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Sirkus Pembunuhanku.
Dialogue: 0,0:03:29.00,0:03:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Samurai dan pencuri.
Dialogue: 0,0:03:31.62,0:03:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persis seperti prediksinya,\Nkalian masuk begitu saja layaknya orang bodoh.
Dialogue: 0,0:03:36.00,0:03:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:03:38.09,0:03:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Prediksinya"?
Dialogue: 0,0:03:41.47,0:03:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua adalah petarung jarak dekat.
Dialogue: 0,0:03:44.09,0:03:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekuat apa pun kalian,
Dialogue: 0,0:03:45.93,0:03:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama aku tidak membiarkan\Nkalian mendekat, itu bukan masalah.
Dialogue: 0,0:03:48.77,0:03:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupermainkan kalian\Nsampai mati di area perburuanku ini.
Dialogue: 0,0:03:52.10,0:03:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari kita mulai!
Dialogue: 0,0:04:04.49,0:04:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah.
Dialogue: 0,0:04:05.53,0:04:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang "hah"!
Dialogue: 0,0:04:06.95,0:04:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah kau habisi dalam satu pukulan?
Dialogue: 0,0:04:08.95,0:04:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini kesempatan Touya\Nuntuk mencari pengalaman.
Dialogue: 0,0:04:11.46,0:04:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Perasaanku mengatakan\Nini akan berhasil.
Dialogue: 0,0:04:14.46,0:04:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:04:16.38,0:04:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:04:17.54,0:04:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rebut kembali Cabangnya.
Dialogue: 0,0:04:19.63,0:04:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana berubah.
Dialogue: 0,0:04:21.08,0:04:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Target beralih dari Gacy\Nke dua pendatang baru.
Dialogue: 0,0:04:25.01,0:04:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai pengejaran.
Dialogue: 0,0:04:26.43,0:04:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini demi mengungkap\Ndalang penyebar kelopak bunga itu.
Dialogue: 0,0:04:34.69,0:04:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:04:39.82,0:04:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menghindar?
Dialogue: 0,0:04:41.99,0:04:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:04:46.87,0:04:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apel?
Dialogue: 0,0:04:55.12,0:04:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana sudi aku mati di sini!
Dialogue: 0,0:05:00.63,0:05:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:05:05.26,0:05:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melarikan diri.
Dialogue: 0,0:05:09.76,0:05:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau malah kagum?
Dialogue: 0,0:05:11.77,0:05:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja. Anggap ini\Nkesempatanmu untuk pamer, Ein.
Dialogue: 0,0:05:17.35,0:05:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada dasarnya, aku ini non-kombatan.
Dialogue: 0,0:05:20.52,0:05:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat egois dan tak bertanggung jawab.
Dialogue: 0,0:05:22.40,0:05:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah alasanku membenci laki-laki.
Dialogue: 0,0:05:26.74,0:05:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan muncul dari\Nmana lagi setelah ini?
Dialogue: 0,0:05:33.25,0:05:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan kananku!
Dialogue: 0,0:05:34.79,0:05:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali.
Dialogue: 0,0:05:36.29,0:05:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak kau pindahkan kepalanya saja?
Dialogue: 0,0:05:38.92,0:05:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berniat menyiksanya?
Dialogue: 0,0:05:39.96,0:05:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyamakanku\Ndengan pria vulgar sepertinya.
Dialogue: 0,0:05:42.88,0:05:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan serangan penutup\Nadalah tugas seorang prajurit.
Dialogue: 0,0:05:48.01,0:05:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerahlah.
Dialogue: 0,0:05:52.68,0:05:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lihat itu?
Dialogue: 0,0:05:53.68,0:05:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucungkil matamu dan kukuliti kau!
Dialogue: 0,0:05:56.23,0:05:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembedahan selesai.
Dialogue: 0,0:05:57.90,0:05:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:06:00.56,0:06:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia masih hidup?
Dialogue: 0,0:06:02.32,0:06:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah merasakan bakatmu\Nsecara langsung.
Dialogue: 0,0:06:06.49,0:06:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliranku
Dialogue: 0,0:06:08.41,0:06:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menunjukkan bakatku.
Dialogue: 0,0:06:11.95,0:06:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:06:12.87,0:06:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa melarikan diri.
Dialogue: 0,0:06:15.33,0:06:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena seluruh area ini sudah kami kepung.
Dialogue: 0,0:06:22.54,0:06:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau masih ingin melawan,
Dialogue: 0,0:06:24.71,0:06:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan saja.
Dialogue: 0,0:06:27.88,0:06:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau hanya bisa mengalahkan\Nbeberapa dari kami.
Dialogue: 0,0:06:35.14,0:06:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang memburu para Pengembali jahat.
Dialogue: 0,0:06:40.10,0:06:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan Para Legenda.
Dialogue: 0,0:06:45.65,0:06:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat waktu, persis seperti prediksiku.
Dialogue: 0,0:06:48.45,0:06:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya,
Dialogue: 0,0:06:50.03,0:06:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kerja bagus.
Dialogue: 0,0:06:51.28,0:06:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku hampir merasa kasihan padanya.
Dialogue: 0,0:06:54.58,0:06:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar hancur lebur.
Dialogue: 0,0:06:59.37,0:07:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabangnya sudah diamankan.
Dialogue: 0,0:07:01.46,0:07:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang terluka di sini?
Dialogue: 0,0:07:04.67,0:07:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan kepadamu... Astaga!
Dialogue: 0,0:07:09.51,0:07:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf selalu merepotkanmu.
Dialogue: 0,0:07:11.22,0:07:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funasaka,
Dialogue: 0,0:07:12.59,0:07:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meskipun tubuhmu abadi,
Dialogue: 0,0:07:14.22,0:07:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong jangan memaksakan diri.
Dialogue: 0,0:07:16.31,0:07:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuusahakan.
Dialogue: 0,0:07:18.43,0:07:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisikan di telinga itu\Npasti nikmat sekali...
Dialogue: 0,0:07:20.81,0:07:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja aku terluka juga.
Dialogue: 0,0:07:22.90,0:07:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Ein,
Dialogue: 0,0:07:24.44,0:07:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo urus para saksinya.
Dialogue: 0,0:07:28.07,0:07:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau bisa\N- Orin!
Dialogue: 0,0:07:29.40,0:07:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- mengurusnya\N- Tsugaru!
Dialogue: 0,0:07:30.95,0:07:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sendiri, 'kan?
Dialogue: 0,0:07:32.07,0:07:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Summer...
Dialogue: 0,0:07:33.78,0:07:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau boleh ikut dengan kami.
Dialogue: 0,0:07:36.29,0:07:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:07:37.66,0:07:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kau?
Dialogue: 0,0:07:39.16,0:07:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasang monitor dan kabel.
Dialogue: 0,0:07:41.46,0:07:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau mendapatkan bakat\Nyang selalu kau impikan,
Dialogue: 0,0:07:44.17,0:07:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau malah menjadi pesuruh Neumann?
Dialogue: 0,0:07:45.88,0:07:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku cukup menikmati\Npekerjaan sepele begini.
Dialogue: 0,0:07:48.92,0:07:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tak ada orang\Ndi grup ini yang serajin Touya.
Dialogue: 0,0:07:53.39,0:07:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat membantu.
Dialogue: 0,0:07:55.01,0:07:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann sudah banyak bercerita tentangmu.
Dialogue: 0,0:07:57.64,0:08:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang rasanya ada kawan baru\Nyang bergabung bersama kami.
Dialogue: 0,0:08:00.64,0:08:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya, ya.
Dialogue: 0,0:08:05.69,0:08:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun belum terkumpul semua, sih.
Dialogue: 0,0:08:08.65,0:08:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang di sini sama sepertimu.
Dialogue: 0,0:08:11.70,0:08:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka punya kekhawatiran masing-masing\Nsampai akhirnya mendapatkan bakat.
Dialogue: 0,0:08:15.70,0:08:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua ingin berubah.
Dialogue: 0,0:08:18.16,0:08:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu mereka ingin menjadi istimewa?
Dialogue: 0,0:08:20.91,0:08:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau butuh bantuan, bilang saja.
Dialogue: 0,0:08:23.00,0:08:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:08:23.92,0:08:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keberatan.
Dialogue: 0,0:08:26.00,0:08:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ein.
Dialogue: 0,0:08:27.59,0:08:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bakat orang ini bukan Kelas Legenda.
Dialogue: 0,0:08:31.38,0:08:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya itu,\Npada dasarnya dia itu penjahat.
Dialogue: 0,0:08:33.13,0:08:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat yang dia miliki itu\Nbakat seorang penjahat, bukan?
Dialogue: 0,0:08:35.01,0:08:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan pernah sudi menerima\Norang sepertinya sebagai sekutu.
Dialogue: 0,0:08:38.39,0:08:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun dia membangkitkan bakatnya,
Dialogue: 0,0:08:40.67,0:08:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan berarti dia menjadi orang\Ndari kehidupan sebelumnya.
Dialogue: 0,0:08:43.77,0:08:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, masyarakat mengenalnya\Nsebagai pencuri dermawan.
Dialogue: 0,0:08:47.02,0:08:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:08:48.40,0:08:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatannya tipe orang\Nyang bakal kabur membawa Cabang.
Dialogue: 0,0:08:50.69,0:08:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya itu malah\Nmembuatnya bisa diandalkan?
Dialogue: 0,0:08:52.32,0:08:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memilih cara paling efektif\Nuntuk mencapai tujuannya.
Dialogue: 0,0:08:54.99,0:08:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi...\N- Ayolah, jangan berbicara begitu.
Dialogue: 0,0:08:57.66,0:09:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang merekomendasikannya.\NKita lihat saja perkembangannya dulu.
Dialogue: 0,0:09:01.41,0:09:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:09:03.37,0:09:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya...
Dialogue: 0,0:09:04.62,0:09:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Musashi sudah berkata\Nbegitu, ya sudahlah.
Dialogue: 0,0:09:06.38,0:09:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Ein!
Dialogue: 0,0:09:11.51,0:09:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak kesal?
Dialogue: 0,0:09:14.13,0:09:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku sih, pasti tidak tahan.
Dialogue: 0,0:09:16.47,0:09:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bersusah payah mendapatkan bakat,
Dialogue: 0,0:09:19.51,0:09:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah dikritik semacam itu.
Dialogue: 0,0:09:23.18,0:09:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita ini sangat mirip.
Dialogue: 0,0:09:29.27,0:09:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lampunya menyala.
Dialogue: 0,0:09:30.82,0:09:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:09:34.86,0:09:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:36.15,0:09:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:09:38.03,0:09:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa!
Dialogue: 0,0:09:40.08,0:09:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tambah tinggi, ya? Hei.
Dialogue: 0,0:09:43.41,0:09:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membawakan oleh-oleh.
Dialogue: 0,0:09:45.25,0:09:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, di ruangan ini tak ada\Nmanga atau majalah dewasa sama sekali.
Dialogue: 0,0:09:49.04,0:09:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuang semuanya.
Dialogue: 0,0:09:51.42,0:09:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap buruk dan mata pandamu itu\Nsama sekali tak berubah, Touya.
Dialogue: 0,0:09:55.42,0:09:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia temanmu?
Dialogue: 0,0:09:57.68,0:09:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Haito Luo Buffett.
Dialogue: 0,0:09:59.55,0:10:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kitazuka Itsuki.
Dialogue: 0,0:10:01.89,0:10:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:10:03.43,0:10:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilannya mungkin memang begini,
Dialogue: 0,0:10:05.02,0:10:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dulunya dia anak emas seni bela diri,\Ndisanjung sebagai genius bersama kakakku.
Dialogue: 0,0:10:09.48,0:10:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dia memimpin unit pasukan khusus\Ndi Pasukan Bela Diri Jepang.
Dialogue: 0,0:10:12.57,0:10:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memujiku secara berlebihan begitu.
Dialogue: 0,0:10:15.07,0:10:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku hanya salah satu dari sedikit\Norang yang terlahir sebagai pemenang.
Dialogue: 0,0:10:17.61,0:10:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, faktor\Nkeberuntungan juga berperan.
Dialogue: 0,0:10:19.66,0:10:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga, sih...
Dialogue: 0,0:10:20.95,0:10:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu?
Dialogue: 0,0:10:24.29,0:10:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar akhir-akhir ini\Nkau membolos sekolah.
Dialogue: 0,0:10:30.54,0:10:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir, makanya aku mampir kemari,
Dialogue: 0,0:10:33.09,0:10:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sepertinya\Nkekhawatiranku tak beralasan.
Dialogue: 0,0:10:35.17,0:10:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau baru punya pacar\Nsampai lupa belajar.
Dialogue: 0,0:10:38.68,0:10:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?\N- Bukan!
Dialogue: 0,0:10:40.51,0:10:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi dia gadis blasteran. Boleh juga.
Dialogue: 0,0:10:43.76,0:10:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}'Kan sudah kubilang, Kak Kitazuka.
Dialogue: 0,0:10:45.39,0:10:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kaku begitu.
Dialogue: 0,0:10:47.94,0:10:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil aku Itsuki saja.
Dialogue: 0,0:10:49.27,0:10:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita 'kan sudah saling kenal\Ndari kau masih kecil?
Dialogue: 0,0:10:52.31,0:10:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dia kecil?
Dialogue: 0,0:10:53.98,0:10:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, deh.
Dialogue: 0,0:10:56.32,0:10:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang membelakangi kamera ini Seiya,\Nkakaknya Touya.
Dialogue: 0,0:10:59.28,0:11:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di tengah itu aku.
Dialogue: 0,0:11:01.37,0:11:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus bocah cilik ini adalah...
Dialogue: 0,0:11:04.12,0:11:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Seiya bersahabat baik.
Dialogue: 0,0:11:06.87,0:11:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku sudah menganggap\NTouya seperti adikku.
Dialogue: 0,0:11:10.29,0:11:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kakak beradik yang sangat akrab.
Dialogue: 0,0:11:13.42,0:11:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya selalu mengejar bayang-bayang Seiya.
Dialogue: 0,0:11:17.05,0:11:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun Seiya tak pernah\Nmenoleh ke belakang,
Dialogue: 0,0:11:19.72,0:11:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia takkan pernah meninggalkan adiknya.
Dialogue: 0,0:11:22.93,0:11:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, akhirnya Touya punya pacar juga.
Dialogue: 0,0:11:26.43,0:11:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi penasaran bagaimana reaksi Seiya\Nkalau dia tahu.
Dialogue: 0,0:11:29.85,0:11:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin reaksinya biasa saja.
Dialogue: 0,0:11:32.15,0:11:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal-hal sepele takkan mengganggunya.
Dialogue: 0,0:11:34.90,0:11:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malahan, dia mungkin\Ntak sempat untuk terkejut.
Dialogue: 0,0:11:37.73,0:11:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengantre untuk merekrutnya.\NToh orang-orang dari berbagai bidang
Dialogue: 0,0:11:40.65,0:11:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itulah takdir
Dialogue: 0,0:11:43.66,0:11:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka yang terlahir dengan bakat.
Dialogue: 0,0:11:45.74,0:11:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku ikut senang.
Dialogue: 0,0:11:48.37,0:11:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah, saatnya aku pergi.
Dialogue: 0,0:11:50.83,0:11:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kalian berdua langgeng, ya.
Dialogue: 0,0:11:53.58,0:11:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku juga punya bakat.
Dialogue: 0,0:11:57.50,0:11:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya.
Dialogue: 0,0:12:03.64,0:12:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:12:05.51,0:12:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dengan tubuhmu itu?
Dialogue: 0,0:12:10.85,0:12:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bakat yang baru saja kudapatkan.
Dialogue: 0,0:12:13.23,0:12:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau cuma bakat pencuri yang cocok\Nuntuk orang gila sepertiku.
Dialogue: 0,0:12:17.82,0:12:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:12:21.61,0:12:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begitu.
Dialogue: 0,0:12:23.45,0:12:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumor yang beredar belakangan ini\Nsoal membangkitkan bakat kehidupan lampau...
Dialogue: 0,0:12:28.41,0:12:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu sekali.
Dialogue: 0,0:12:30.79,0:12:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi begitu.
Dialogue: 0,0:12:32.58,0:12:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau tak berguna\Ndi kehidupan sekarang,
Dialogue: 0,0:12:35.58,0:12:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}alih-alih berharap di kehidupan selanjutnya,\Nkau malah mengandalkan masa lalumu?
Dialogue: 0,0:12:38.75,0:12:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logika macam apa itu?
Dialogue: 0,0:12:40.55,0:12:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau mengandalkan\Nhal konyol semacam itu,
Dialogue: 0,0:12:43.18,0:12:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah kau sudah resmi menjadi pecundang?
Dialogue: 0,0:12:45.43,0:12:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik ucapanmu!
Dialogue: 0,0:12:48.85,0:12:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:12:50.27,0:12:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kau juga pecundang?
Dialogue: 0,0:12:53.10,0:12:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik ucapanmu sekarang juga!
Dialogue: 0,0:12:55.19,0:12:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tahu perasaan kami\Nsaat mendapatkan bakat ini.
Dialogue: 0,0:12:59.57,0:13:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tahu sebesar apa tekad\Nyang kami butuhkan untuk jadi seperti ini!
Dialogue: 0,0:13:03.95,0:13:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berani menceramahi kami\Ndengan kesombonganmu itu,
Dialogue: 0,0:13:06.28,0:13:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dasar genius alami!
Dialogue: 0,0:13:07.41,0:13:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kan sudah kubilang.
Dialogue: 0,0:13:09.28,0:13:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun ucapanmu, di telingaku\Nitu cuma terdengar sebagai alasan.
Dialogue: 0,0:13:13.16,0:13:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalih orang-orang lemah.
Dialogue: 0,0:13:25.93,0:13:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau bukan pacarnya Touya,
Dialogue: 0,0:13:28.26,0:13:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah kupatahkan kaki\Ndan tanganmu dari tadi.
Dialogue: 0,0:13:30.85,0:13:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cabut. Merusak suasana saja.
Dialogue: 0,0:13:34.48,0:13:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Seiya melihatmu yang sekarang,
Dialogue: 0,0:13:37.10,0:13:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pasti bakal kecewa berat.
Dialogue: 0,0:13:39.11,0:13:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa juga begitu.
Dialogue: 0,0:13:40.94,0:13:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:13:42.99,0:13:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak menyesal.
Dialogue: 0,0:13:44.86,0:13:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kugunakan bakat ini\Nuntuk melampaui kakakku. Lihat saja nanti.
Dialogue: 0,0:13:49.62,0:13:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tak lucu.
Dialogue: 0,0:14:00.00,0:14:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Kapten.
Dialogue: 0,0:14:02.25,0:14:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa operasinya kita lanjutkan?
Dialogue: 0,0:14:05.34,0:14:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batalkan.
Dialogue: 0,0:14:06.38,0:14:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi targetnya masih sama.
Dialogue: 0,0:14:08.26,0:14:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan mereka bergerak bebas\Nuntuk sekarang.
Dialogue: 0,0:14:10.14,0:14:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh unit pengacak sinyal\Nuntuk mundur juga.
Dialogue: 0,0:14:12.51,0:14:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Laksanakan.\N- Baik!
Dialogue: 0,0:14:16.69,0:14:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Tidak kau tangkap?
Dialogue: 0,0:14:19.65,0:14:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal itu sampel yang berharga, lo.
Dialogue: 0,0:14:21.77,0:14:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yoshiki,
Dialogue: 0,0:14:22.94,0:14:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau berisik.
Dialogue: 0,0:14:24.15,0:14:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah,
Dialogue: 0,0:14:25.07,0:14:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada yang sedang uring-uringan, nih.
Dialogue: 0,0:14:27.70,0:14:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam dan menyetir saja.
Dialogue: 0,0:14:29.70,0:14:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalau kau mau sampel,\Nkita sudah punya, 'kan?
Dialogue: 0,0:14:33.12,0:14:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai tak sempat bereaksi.
Dialogue: 0,0:14:35.25,0:14:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecepatan, daya serang,\Ndan tekanannya sungguh luar biasa.
Dialogue: 0,0:14:38.83,0:14:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan teknik langkah kaki biasa.
Dialogue: 0,0:14:41.46,0:14:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlahir dengan bakat sehebat itu...
Dialogue: 0,0:14:46.63,0:14:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:14:49.22,0:14:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita benar-benar mirip.
Dialogue: 0,0:14:51.60,0:14:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sangat mirip.
Dialogue: 0,0:14:54.35,0:14:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak terlahir dengan bakat.
Dialogue: 0,0:14:58.35,0:15:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum mendapatkan bakat ini,
Dialogue: 0,0:15:00.19,0:15:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku cuma gadis biasa yang ada di mana-mana.
Dialogue: 0,0:15:03.19,0:15:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, mungkin bukan itu\Ncara yang tepat untuk mengatakannya.
Dialogue: 0,0:15:07.07,0:15:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku ini anak telantar.
Dialogue: 0,0:15:10.74,0:15:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dibesarkan di panti asuhan.
Dialogue: 0,0:15:12.78,0:15:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak yang tumbuh di tempat semacam itu
Dialogue: 0,0:15:15.08,0:15:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biasanya memiliki trauma.
Dialogue: 0,0:15:18.41,0:15:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena warna rambut dan mataku berbeda,\Ndi lingkungan itu,
Dialogue: 0,0:15:22.21,0:15:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi sasaran empuk perundungan.
Dialogue: 0,0:15:24.88,0:15:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menangis setiap hari.
Dialogue: 0,0:15:26.92,0:15:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengurus panti pun cuma tutup mata.
Dialogue: 0,0:15:29.76,0:15:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membuktikan mereka itu salah.
Dialogue: 0,0:15:32.43,0:15:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku merasa sangat tak berdaya saat itu.
Dialogue: 0,0:15:36.18,0:15:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat itulah semuanya terjadi.
Dialogue: 0,0:15:38.18,0:15:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhentilah menangis.
Dialogue: 0,0:15:40.48,0:15:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatku pusing saja.
Dialogue: 0,0:15:44.52,0:15:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikutlah denganku.
Dialogue: 0,0:15:46.11,0:15:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulatih kau dengan benar.
Dialogue: 0,0:15:48.44,0:15:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu adalah guru di dojo dekat situ.
Dialogue: 0,0:15:51.78,0:15:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat yang sangat menjunjung\Ntradisi dan aturan kolot.
Dialogue: 0,0:15:54.95,0:15:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak orang yang menentang keputusannya
Dialogue: 0,0:15:57.70,0:15:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengadopsi anak sepertiku.
Dialogue: 0,0:16:00.21,0:16:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berisik!
Dialogue: 0,0:16:02.83,0:16:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kubilang aku menerimanya,\Nya aku menerimanya!
Dialogue: 0,0:16:05.25,0:16:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri yang akan mengajari bocah ini!
Dialogue: 0,0:16:07.67,0:16:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski semua orang menentang,\NGuru tetap menerimaku.
Dialogue: 0,0:16:10.76,0:16:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya itu...
Dialogue: 0,0:16:12.34,0:16:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangatmu boleh juga.
Dialogue: 0,0:16:15.30,0:16:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau sampai merusak\Npedang bambu begini.
Dialogue: 0,0:16:20.60,0:16:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau
Dialogue: 0,0:16:23.60,0:16:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakal segera melampauiku.
Dialogue: 0,0:16:27.94,0:16:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, selanjutnya,\Naku yang menjadi lawanmu.
Dialogue: 0,0:16:31.74,0:16:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:32.95,0:16:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengizinkanku memanggilnya Ayah,
Dialogue: 0,0:16:35.16,0:16:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia mewariskan ilmu pedangnya kepadaku.
Dialogue: 0,0:16:37.53,0:16:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan penuh semangat...
Dialogue: 0,0:16:42.71,0:16:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membulatkan tekad.
Dialogue: 0,0:16:44.50,0:16:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi pendekar pedang sejati
Dialogue: 0,0:16:46.46,0:16:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membalas budinya.
Dialogue: 0,0:16:48.71,0:16:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membuktikan kepada Ayah
Dialogue: 0,0:16:50.59,0:16:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau aku bisa menjadi orang\Nhebat berkat dididikannya.
Dialogue: 0,0:16:55.09,0:16:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:16:56.55,0:16:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak punya bakat berpedang.
Dialogue: 0,0:17:00.27,0:17:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginginkan bakat
Dialogue: 0,0:17:02.68,0:17:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melebihi apa pun.
Dialogue: 0,0:17:05.15,0:17:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku ingin memenuhi harapannya.
Dialogue: 0,0:17:08.02,0:17:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat itulah
Dialogue: 0,0:17:10.53,0:17:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal Cabang Reinkarnasi.\Naku mendengar rumor
Dialogue: 0,0:17:13.95,0:17:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencarinya ke mana-mana,
Dialogue: 0,0:17:15.95,0:17:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti orang putus asa.
Dialogue: 0,0:17:19.11,0:17:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kalau aku bisa mendapatkan bakat,
Dialogue: 0,0:17:21.20,0:17:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya bakal beres.
Dialogue: 0,0:17:24.32,0:17:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:17:26.21,0:17:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakat berpedang Musashi\Nmelampaui kemampuan ayahku dengan mudahnya.
Dialogue: 0,0:17:31.13,0:17:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau nyawanya selamat,
Dialogue: 0,0:17:33.22,0:17:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuhnya tak bisa lagi memegang pedang.
Dialogue: 0,0:17:37.26,0:17:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dojo pun ditutup.\N- Enyahlah kau!
Dialogue: 0,0:17:39.39,0:17:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diusir karena dianggap\Nmengkhianati guruku
Dialogue: 0,0:17:41.60,0:17:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dicap sebagai murid tak tahu diuntung.
Dialogue: 0,0:17:44.64,0:17:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa pulang\Ndengan tangan kosong begini.
Dialogue: 0,0:17:48.23,0:17:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus benar-benar menjadi\NMusashi, lalu pulang ke sana.
Dialogue: 0,0:17:50.40,0:17:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku akan membangkitkan dojo itu lagi.
Dialogue: 0,0:17:53.57,0:17:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku ingin secepatnya menjadi...
Dialogue: 0,0:17:56.61,0:17:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengembali Lengkap.
Dialogue: 0,0:17:59.37,0:18:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengembali Lengkap.
Dialogue: 0,0:18:04.00,0:18:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik sahabatku...
Dialogue: 0,0:18:06.21,0:18:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja,\Naku sedang malas bertemu dengannya.
Dialogue: 0,0:18:08.29,0:18:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben kau membiarkan
Dialogue: 0,0:18:09.84,0:18:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masalah pribadi mencampuri pekerjaan.
Dialogue: 0,0:18:11.42,0:18:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga manusia.
Dialogue: 0,0:18:14.05,0:18:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak suka,\Nserahkan saja komandonya pada AI.
Dialogue: 0,0:18:17.30,0:18:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:18:18.84,0:18:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagi Touya...
Dialogue: 0,0:18:22.10,0:18:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menyesal.
Dialogue: 0,0:18:24.56,0:18:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja, orang itu...
Dialogue: 0,0:18:26.19,0:18:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seenaknya melimpahkan semuanya kepadaku,\Nlalu mati begitu saja.
Dialogue: 0,0:18:30.02,0:18:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan banget.
Dialogue: 0,0:18:32.65,0:18:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi harus kuakui,
Dialogue: 0,0:18:34.40,0:18:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua yang terjadi beberapa hari ini
Dialogue: 0,0:18:37.36,0:18:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}persis seperti ucapannya.
Dialogue: 0,0:18:39.78,0:18:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk hal itu.
Dialogue: 0,0:18:41.83,0:18:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar bikin kesal.
Dialogue: 0,0:18:44.91,0:18:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kau tak tahu?
Dialogue: 0,0:18:47.08,0:18:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:48.42,0:18:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Hutan Para Legenda,\Nselain Touya dan Haito,
Dialogue: 0,0:18:51.59,0:18:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya itu Pengembali Lengkap.
Dialogue: 0,0:18:54.38,0:18:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu apa kesamaan mereka?
Dialogue: 0,0:18:57.47,0:18:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujud mereka semua aneh.
Dialogue: 0,0:18:59.18,0:19:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang kepalanya apel.
Dialogue: 0,0:19:00.97,0:19:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang badannya raksasa.
Dialogue: 0,0:19:02.76,0:19:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada yang bertanduk segala.
Dialogue: 0,0:19:05.64,0:19:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:19:07.06,0:19:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujud kami jelas bukan manusia lagi.
Dialogue: 0,0:19:10.06,0:19:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus,
Dialogue: 0,0:19:11.19,0:19:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kau tertarik\Ndengan penampilan aneh mereka?
Dialogue: 0,0:19:14.19,0:19:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan kenapa wujud Reinkarnasi kami\Ntak bisa kembali itu sederhana.
Dialogue: 0,0:19:18.65,0:19:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reinkarnasi Kembali kalian\Nitu ada batas waktunya.
Dialogue: 0,0:19:21.62,0:19:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah beberapa saat,
Dialogue: 0,0:19:24.16,0:19:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian bakal kembali ke wujud asli.
Dialogue: 0,0:19:26.70,0:19:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau Reinkarnasi Kembali\Ndiulang terus-menerus,
Dialogue: 0,0:19:29.46,0:19:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}batasan itu lama-lama akan lenyap.
Dialogue: 0,0:19:31.67,0:19:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menaruh hormat pada mereka\Nyang sudah menjadi Pengembali Lengkap
Dialogue: 0,0:19:35.55,0:19:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan memanggil nama masa lalunya.
Dialogue: 0,0:19:38.38,0:19:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Haito sudah dipanggil Musashi, ya.
Dialogue: 0,0:19:41.30,0:19:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak boleh cepat puas.
Dialogue: 0,0:19:42.76,0:19:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus segera menjadi\NPengembali Lengkap.
Dialogue: 0,0:19:46.06,0:19:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu aku tak perlu pakai ini lagi,
Dialogue: 0,0:19:48.10,0:19:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku bisa menghadap Ayah\Ndengan kepala tegak.
Dialogue: 0,0:19:53.56,0:19:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Listriknya mati, ya?
Dialogue: 0,0:19:54.61,0:19:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, padam.
Dialogue: 0,0:19:55.94,0:19:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:19:57.23,0:19:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Kiri Serbaguna.
Dialogue: 0,0:20:03.45,0:20:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:20:05.95,0:20:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lengan yang bisa memakai bakat curian.
Dialogue: 0,0:20:10.29,0:20:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama ingin\Nmemperlihatkan ini padamu, Haito.
Dialogue: 0,0:20:12.71,0:20:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi begitu.
Dialogue: 0,0:20:13.75,0:20:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini bagus, lo.
Dialogue: 0,0:20:15.25,0:20:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan bakat sehebat itu,\Nkau tak perlu menuntut apa-apa lagi.
Dialogue: 0,0:20:17.88,0:20:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin tak apa-apa?
Dialogue: 0,0:20:19.97,0:20:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatmu ikut senang begini...
Dialogue: 0,0:20:22.18,0:20:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal bakat,\Naku pasti bakal menggunakannya buat...
Dialogue: 0,0:20:24.85,0:20:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerang sekutumu sendiri?
Dialogue: 0,0:20:27.68,0:20:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya wajar saja, 'kan?
Dialogue: 0,0:20:30.64,0:20:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dikelilingi bakat-bakat yang kau incar.
Dialogue: 0,0:20:33.60,0:20:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku di posisimu,\Naku juga bakal melakukan hal yang sama.
Dialogue: 0,0:20:36.36,0:20:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curi saja sebanyak yang kau mau.
Dialogue: 0,0:20:38.78,0:20:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:20:40.40,0:20:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berusahalah semampumu.
Dialogue: 0,0:20:41.57,0:20:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:42.91,0:20:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah sendiri mereka lengah, 'kan.
Dialogue: 0,0:20:46.58,0:20:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah murung begitu?
Dialogue: 0,0:20:50.41,0:20:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memamerkan ini\Nbukan untuk minta dihentikan, 'kan?
Dialogue: 0,0:20:54.67,0:20:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sampai sengaja menghindari\Npengawasan Neumann segala.
Dialogue: 0,0:20:57.71,0:20:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja bukan.
Dialogue: 0,0:20:59.00,0:21:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, Haito itu...
Dialogue: 0,0:21:00.51,0:21:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:21:01.63,0:21:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena ini kau,\Naku ingin berterus terang.
Dialogue: 0,0:21:05.59,0:21:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:06.64,0:21:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang mendengarnya, Touya.
Dialogue: 0,0:21:09.77,0:21:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:21:12.18,0:21:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku kurang setuju dengan itu.
Dialogue: 0,0:21:14.27,0:21:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak langsung\Ncoba mencuri bakatku saja?
Dialogue: 0,0:21:17.94,0:21:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau memang mau,\Nkedekatan kita tak ada urusannya.
Dialogue: 0,0:21:22.57,0:21:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:21:23.82,0:21:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesal juga rasanya.
Dialogue: 0,0:21:25.11,0:21:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakatku masih jauh dari kata matang.
Dialogue: 0,0:21:28.16,0:21:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, berjanjilah kepadaku.
Dialogue: 0,0:21:30.16,0:21:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal terus mengasah ilmu pedangku ini.
Dialogue: 0,0:21:33.58,0:21:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menempa diriku\Nsampai kau merasa layak untuk mencurinya.
Dialogue: 0,0:21:38.38,0:21:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:21:40.09,0:21:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukumpulkan bakat-bakat\Nyang tak kalah hebat darimu.
Dialogue: 0,0:21:43.47,0:21:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari nanti,\Nkita buktikan hasil jerih payah kita.
Dialogue: 0,0:21:45.76,0:21:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji.
Dialogue: 0,0:23:18.98,0:23:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah pulang.
Dialogue: 0,0:23:20.73,0:23:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persis seperti dugaanku.
Dialogue: 0,0:23:22.65,0:23:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan reuni yang mengharukan, 'kan?
Dialogue: 0,0:23:25.90,0:23:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:23:27.61,0:23:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tahanan saja
Dialogue: 0,0:23:29.82,0:23:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak tingkah kau.
Dialogue: 0,0:23:36.66,0:23:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan Dimulai.
