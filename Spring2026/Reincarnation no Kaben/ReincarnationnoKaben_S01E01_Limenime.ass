Dialogue: 0,0:03:01.80,0:03:03.30,tanda,,0000,0000,0000,,BIMBINGAN BELAJAR MUTLAK
Dialogue: 0,0:03:03.39,0:03:05.14,tanda,,0000,0000,0000,,UJIAN LATIHAN - RAPOR PRIBADI
Dialogue: 0,0:05:28.87,0:05:30.53,tanda,,0000,0000,0000,,"JOHN VON NEUMANN"
Dialogue: 0,0:06:24.21,0:06:25.05,tanda,,0000,0000,0000,,HARASHOGI
Dialogue: 0,0:06:28.47,0:06:29.30,tanda,,0000,0000,0000,,KUBIKARI
