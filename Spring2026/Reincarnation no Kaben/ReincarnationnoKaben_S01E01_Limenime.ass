Dialogue: 0,0:20:47.99,0:20:51.00,tanda,,0000,0000,0000,,BAKAT: TUAN PENUSUK
Dialogue: 0,0:23:38.16,0:23:39.92,tanda,,0000,0000,0000,,EPISODE 2\NMAKNA MENJADI PEMILIK
Dialogue: 0,0:00:00.83,0:00:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bakat.
Dialogue: 0,0:00:08.05,0:00:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus jadi orang hebat.
Dialogue: 0,0:00:11.80,0:00:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun tak masalah...
Dialogue: 0,0:00:18.10,0:00:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu saja.
Dialogue: 0,0:00:22.85,0:00:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kudapatkan!
Dialogue: 0,0:00:48.38,0:00:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lihat Kelopaknya?
Dialogue: 0,0:00:50.46,0:00:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:51.92,0:00:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua hari lalu, di dekat minimarket.
Dialogue: 0,0:00:54.22,0:00:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:00:55.13,0:00:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga lihat orang begitu.
Dialogue: 0,0:00:56.80,0:00:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti mengada-ada.
Dialogue: 0,0:01:00.22,0:01:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong...
Dialogue: 0,0:01:01.43,0:01:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau bisa jadi orang hebat...\N- Bukannya belakangan ini
Dialogue: 0,0:01:03.39,0:01:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- kau ingin jadi tokoh masa lalu siapa?\N- banyak rumor Kelopak di medsos?
Dialogue: 0,0:01:04.48,0:01:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kurasa aku pilih Hideyoshi.\N- Benar juga.
Dialogue: 0,0:01:06.06,0:01:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia bisa menghangatkan apa pun.\N- Jangan-jangan...
Dialogue: 0,0:01:08.15,0:01:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia pasti yang terkuat.\N- pelakunya...
Dialogue: 0,0:01:09.36,0:01:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku pasti akan pilih\N- pembunuh berantai?
Dialogue: 0,0:01:10.77,0:01:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hoshiyama Ken.\N- Yang benar saja.
Dialogue: 0,0:01:12.19,0:01:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau begitu, aku bisa jadi suami Zekki.\N- Jaga bicaramu.
Dialogue: 0,0:01:14.44,0:01:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus.
Dialogue: 0,0:01:16.36,0:01:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semuanya, kembali ke tempat duduk.\N- Kalau begini terus...
Dialogue: 0,0:01:19.03,0:01:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatian...
Dialogue: 0,0:01:20.08,0:01:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum kelas dimulai,\Nada murid pindahan baru.
Dialogue: 0,0:01:24.58,0:01:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap tenang.
Dialogue: 0,0:01:25.83,0:01:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk.
Dialogue: 0,0:01:28.13,0:01:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah...
Dialogue: 0,0:01:30.46,0:01:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau.
Dialogue: 0,0:01:38.22,0:01:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito Luo Buffett.
Dialogue: 0,0:01:40.43,0:01:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:01:44.02,0:01:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:47.48,0:01:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah.
Dialogue: 0,0:01:48.65,0:01:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau boleh duduk di sebelahnya.
Dialogue: 0,0:01:50.94,0:01:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bapak akan mengabsen sekarang.
Dialogue: 0,0:02:00.82,0:02:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berhenti!
Dialogue: 0,0:02:04.24,0:02:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senji Touya.
Dialogue: 0,0:02:12.25,0:02:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu dari mana namaku?
Dialogue: 0,0:02:14.76,0:02:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:02:15.96,0:02:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak terlihat seperti\Ntipe yang rajin belajar.
Dialogue: 0,0:02:18.93,0:02:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kantong matamu parah.
Dialogue: 0,0:02:20.22,0:02:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alis terus berkerut.
Dialogue: 0,0:02:22.60,0:02:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat apa kau?
Dialogue: 0,0:02:25.93,0:02:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:02:27.31,0:02:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus buru-buru ke tempat les.
Dialogue: 0,0:02:32.73,0:02:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti katamu.
Dialogue: 0,0:02:34.90,0:02:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matanya bagus, Neumann.
Dialogue: 0,0:02:38.20,0:02:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:39.53,0:02:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sangat mirip.
Dialogue: 0,0:02:42.12,0:02:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ampuni aku.
Dialogue: 0,0:02:43.99,0:02:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon.
Dialogue: 0,0:02:45.70,0:02:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa. Jangan takut.
Dialogue: 0,0:02:49.12,0:02:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera buatkan\Nmakanan lezat untukmu.
Dialogue: 0,0:02:53.79,0:02:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, jangan!
Dialogue: 0,0:02:55.75,0:02:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong! Tidak!
Dialogue: 0,0:03:06.81,0:03:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini saja tidak cukup.
Dialogue: 0,0:03:09.85,0:03:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya harus ada satu.
Dialogue: 0,0:03:12.98,0:03:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat yang cuma milikku.
Dialogue: 0,0:03:15.94,0:03:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak...
Dialogue: 0,0:03:19.86,0:03:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bakat...
Dialogue: 0,0:03:21.95,0:03:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun tak masalah.
Dialogue: 0,0:03:23.70,0:03:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu saja.
Dialogue: 0,0:03:26.70,0:03:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal bisa kudapatkan,
Dialogue: 0,0:03:29.96,0:03:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kulakukan apa pun.
Dialogue: 0,0:03:33.42,0:03:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ketemu?
Dialogue: 0,0:03:34.33,0:03:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum, batang hidungnya pun tak terlihat.
Dialogue: 0,0:03:36.80,0:03:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan laporannya palsu?
Dialogue: 0,0:03:38.84,0:03:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ada yang lapor\Ndengar teriakan di sekitar sini.
Dialogue: 0,0:03:42.76,0:03:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:45.68,0:03:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin cuma orang mabuk?
Dialogue: 0,0:03:47.85,0:03:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:03:49.98,0:03:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:03:52.48,0:03:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pedulikan aku.
Dialogue: 0,0:03:53.73,0:03:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa begitu.
Dialogue: 0,0:03:55.52,0:03:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia
Dialogue: 0,0:03:57.32,0:04:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyebutku tidak becus dan mengejekku,
Dialogue: 0,0:04:00.90,0:04:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padahal aku sangat berbakat!
Dialogue: 0,0:04:04.07,0:04:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini...
Dialogue: 0,0:04:07.83,0:04:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau aneh apa ini?
Dialogue: 0,0:04:19.95,0:04:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali sampai tak bisa berhenti.
Dialogue: 0,0:04:22.55,0:04:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa sangat diberkati.
Dialogue: 0,0:04:26.85,0:04:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:04:28.18,0:04:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana...
Dialogue: 0,0:04:29.72,0:04:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau iri?
Dialogue: 0,0:04:32.48,0:04:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat seseorang temukan bakat,\Nada tiga emosi yang dirasakan.
Dialogue: 0,0:04:36.81,0:04:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekaguman.
Dialogue: 0,0:04:38.07,0:04:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketakutan.
Dialogue: 0,0:04:39.36,0:04:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kecemburuan.
Dialogue: 0,0:04:41.44,0:04:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang bisa memahami bakat
Dialogue: 0,0:04:43.78,0:04:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cenderung jatuh lebih dalam\Npada emosi yang ketiga.
Dialogue: 0,0:04:46.45,0:04:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:04:48.91,0:04:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, ini benar-benar...
Dialogue: 0,0:04:52.00,0:04:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau bersenang-senang,
Dialogue: 0,0:04:54.62,0:04:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fish.
Dialogue: 0,0:04:56.17,0:04:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua berkat dirimu.
Dialogue: 0,0:04:58.29,0:05:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membimbingku\Nmendapat bakat luar biasa ini.
Dialogue: 0,0:05:04.13,0:05:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai tanda terima kasih,
Dialogue: 0,0:05:06.34,0:05:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memasakmu.
Dialogue: 0,0:05:16.31,0:05:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:17.86,0:05:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana perginya mereka?
Dialogue: 0,0:05:20.61,0:05:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhitungan Prediksi.
Dialogue: 0,0:05:22.28,0:05:23.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat seperti biasa, Neumann.
Dialogue: 0,0:05:25.95,0:05:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:05:28.87,0:05:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann?
Dialogue: 0,0:05:30.62,0:05:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:05:31.54,0:05:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:05:36.00,0:05:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepayah apa pun dirimu di kehidupan ini,
Dialogue: 0,0:05:38.50,0:05:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bila kau punya bakat di masa lampau,
Dialogue: 0,0:05:40.25,0:05:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu bisa jadi milikmu.
Dialogue: 0,0:05:42.80,0:05:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika hal semacam itu ada,
Dialogue: 0,0:05:44.88,0:05:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya,
Dialogue: 0,0:05:46.34,0:05:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang akan kau lakukan?
Dialogue: 0,0:05:52.64,0:05:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Cabang Reinkarnasi.
Dialogue: 0,0:05:55.89,0:05:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka mata dan saksikanlah.
Dialogue: 0,0:05:58.81,0:06:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:06:04.78,0:06:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka di sana?
Dialogue: 0,0:06:19.50,0:06:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harashogi.
Dialogue: 0,0:06:21.13,0:06:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubikari.
Dialogue: 0,0:06:25.13,0:06:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah!
Dialogue: 0,0:06:36.64,0:06:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelopak?
Dialogue: 0,0:06:51.28,0:06:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyamoto Musashi Harunobu.
Dialogue: 0,0:06:55.87,0:06:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah.
Dialogue: 0,0:07:00.96,0:07:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma bercanda.
Dialogue: 0,0:07:03.34,0:07:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reinkarnasi Kembali.
Dialogue: 0,0:07:05.42,0:07:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melalui Cabang Reinkarnasi,\Nkami telusuri masa lalu
Dialogue: 0,0:07:07.84,0:07:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu membangkitkan bakat kami.
Dialogue: 0,0:07:09.34,0:07:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:07:14.81,0:07:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang berhasil\Njalani Reinkarnasi Kembali
Dialogue: 0,0:07:17.22,0:07:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}disebut "Pengembali".
Dialogue: 0,0:07:31.86,0:07:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelopak itu...
Dialogue: 0,0:07:33.53,0:07:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelopak
Dialogue: 0,0:07:35.08,0:07:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah bukti kebangkitan bakat\Ndari kehidupan lampau.
Dialogue: 0,0:07:38.79,0:07:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah itu pahlawan di masanya\Natau genius tiada tara,
Dialogue: 0,0:07:42.37,0:07:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kematian tak bisa dihindari umat manusia.
Dialogue: 0,0:07:45.17,0:07:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ironisnya,
Dialogue: 0,0:07:47.25,0:07:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}reinkarnasi hanya terjadi melalui kematian.
Dialogue: 0,0:07:49.80,0:07:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bakat para Legenda bangkit\Ndi dunia orang hidup.
Dialogue: 0,0:07:53.34,0:07:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sepertinya.
Dialogue: 0,0:08:00.18,0:08:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabang Reinkarnasi bisa bangkitkan\Nbakat dari kehidupan lampau.
Dialogue: 0,0:08:07.48,0:08:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kita tak bisa memilih\Nbakat yang diterima.
Dialogue: 0,0:08:10.36,0:08:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Legenda atau pahlawan.
Dialogue: 0,0:08:11.95,0:08:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti halnya Legenda yang memiliki bakat\Nuntuk memimpin umat manusia...
Dialogue: 0,0:08:19.12,0:08:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:21.75,0:08:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fish.
Dialogue: 0,0:08:23.12,0:08:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sepertinya, penjahat kejam, pembunuh,
Dialogue: 0,0:08:26.13,0:08:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diktator.
Dialogue: 0,0:08:27.59,0:08:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya bakat yang bisa\Nmembahayakan umat manusia.
Dialogue: 0,0:08:30.26,0:08:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat para Pendosa seperti itu\Njuga bisa bangkit.
Dialogue: 0,0:08:33.92,0:08:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja,
Dialogue: 0,0:08:35.04,0:08:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa jadi kau tak bangkitkan bakat apa pun,
Dialogue: 0,0:08:37.04,0:08:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mati begitu saja.
Dialogue: 0,0:08:40.39,0:08:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarpun begitu, kau tetap mau?
Dialogue: 0,0:08:43.02,0:08:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ragu, kan?
Dialogue: 0,0:08:44.31,0:08:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu malu.
Dialogue: 0,0:08:46.73,0:08:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehebat itulah...
Dialogue: 0,0:08:49.94,0:08:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya?
Dialogue: 0,0:08:52.28,0:08:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa, bukan?
Dialogue: 0,0:08:54.91,0:08:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat berekspektasi tinggi saat dengar\Nsoal bakat ahli pedang itu.
Dialogue: 0,0:08:58.95,0:09:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku kecewa.
Dialogue: 0,0:09:01.70,0:09:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar juga nyalimu.
Dialogue: 0,0:09:04.37,0:09:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:09:06.92,0:09:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Delapan Warna!
Dialogue: 0,0:09:13.51,0:09:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangmu tumpul!
Dialogue: 0,0:09:16.18,0:09:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cuma bisa lihat satu pedang?
Dialogue: 0,0:09:18.35,0:09:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:09:33.90,0:09:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berakhir, Neumann.
Dialogue: 0,0:09:37.87,0:09:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Touya?
Dialogue: 0,0:09:39.58,0:09:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah pergi.
Dialogue: 0,0:09:44.87,0:09:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:09:51.17,0:09:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Touya, aku yakin dia pasti bisa.
Dialogue: 0,0:09:54.01,0:09:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelopak akan bermunculan.
Dialogue: 0,0:10:05.18,0:10:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini, Touya.
Dialogue: 0,0:10:07.19,0:10:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu...
Dialogue: 0,0:10:08.31,0:10:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku!
Dialogue: 0,0:10:09.73,0:10:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:10:10.86,0:10:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah.
Dialogue: 0,0:10:12.32,0:10:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya.
Dialogue: 0,0:10:13.48,0:10:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:10:15.99,0:10:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya.
Dialogue: 0,0:10:17.45,0:10:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya.
Dialogue: 0,0:10:19.91,0:10:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:10:23.12,0:10:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:26.25,0:10:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Reinkarnasi Kembali milikmu\Nsudah berhasil.
Dialogue: 0,0:10:29.04,0:10:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau mengerang terus.
Dialogue: 0,0:10:35.55,0:10:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku punya kakak.
Dialogue: 0,0:10:38.47,0:10:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademik, bela diri, kesenian.
Dialogue: 0,0:10:41.22,0:10:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pandai segalanya.
Dialogue: 0,0:10:43.47,0:10:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan dijuluki genius.
Dialogue: 0,0:10:45.47,0:10:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bandingkan dengannya\Nyang sukses di usia muda
Dialogue: 0,0:10:47.52,0:10:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjadi tumpuan harapan...
Dialogue: 0,0:10:50.60,0:10:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma juara empat.
Dialogue: 0,0:10:52.69,0:10:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya selalu juara satu.
Dialogue: 0,0:10:55.94,0:10:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya selalu menang.
Dialogue: 0,0:10:57.82,0:11:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cuma juara harapan.\NKau hanya hadiah hiburan.
Dialogue: 0,0:11:01.53,0:11:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:11:04.62,0:11:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu bekerja keras mengejarnya.
Dialogue: 0,0:11:08.37,0:11:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kurasa itu yang namanya\N"surga iri pada bakat".
Dialogue: 0,0:11:11.75,0:11:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku jatuh sakit dan...
Dialogue: 0,0:11:14.38,0:11:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:11:16.09,0:11:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematiannya ditimpakan padaku.
Dialogue: 0,0:11:18.92,0:11:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipikir-pikir lagi,
Dialogue: 0,0:11:20.18,0:11:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu demi melindungi reputasi keluarga\Nyang susah payah dibangun.
Dialogue: 0,0:11:25.10,0:11:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun alasannya,
Dialogue: 0,0:11:26.93,0:11:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku diusir dari keluarga.
Dialogue: 0,0:11:30.81,0:11:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan aku
Dialogue: 0,0:11:32.40,0:11:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin dapatkan bakat dan membalas mereka.
Dialogue: 0,0:11:35.61,0:11:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau balas dendam.
Dialogue: 0,0:11:37.94,0:11:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terhadap mereka yang meremehkanku.
Dialogue: 0,0:11:41.86,0:11:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terpenting...
Dialogue: 0,0:11:43.20,0:11:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terhadap diriku sendiri,
Dialogue: 0,0:11:45.78,0:11:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tak pernah mencapai apa pun.
Dialogue: 0,0:11:48.08,0:11:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:11:49.66,0:11:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kau terus mencari.
Dialogue: 0,0:11:52.29,0:11:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biola,
Dialogue: 0,0:11:54.25,0:11:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}piano, seruling, melukis, menari,
Dialogue: 0,0:11:56.34,0:11:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}renang, lari, basket, sepak bola,
Dialogue: 0,0:11:58.80,0:12:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}senam, go, catur,\Nditambah aikido, karate, dan kendo.
Dialogue: 0,0:12:03.05,0:12:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belajar semuanya.
Dialogue: 0,0:12:05.47,0:12:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:12:06.51,0:12:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi satu pun tak ada yang menjadi bakatku.
Dialogue: 0,0:12:10.02,0:12:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita...
Dialogue: 0,0:12:12.56,0:12:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat mirip.
Dialogue: 0,0:12:14.31,0:12:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:12:22.78,0:12:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senji Touya, kau di sini.
Dialogue: 0,0:12:25.70,0:12:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggumu.
Dialogue: 0,0:12:30.54,0:12:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau...
Dialogue: 0,0:12:32.33,0:12:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann?
Dialogue: 0,0:12:35.04,0:12:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana yang lain?
Dialogue: 0,0:12:36.29,0:12:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pergi
Dialogue: 0,0:12:37.88,0:12:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memberantas Pengembali jahat.
Dialogue: 0,0:12:40.88,0:12:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah prinsip organisasi kami,\NHutan Para Legenda.
Dialogue: 0,0:12:45.14,0:12:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan Para Legenda?
Dialogue: 0,0:12:46.76,0:12:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabang Reinkarnasi tak bisa pilih\Nbakat mana yang dibangkitkan.
Dialogue: 0,0:12:49.56,0:12:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bakat Legenda itu berguna\Nbagi umat manusia, itu wajar.
Dialogue: 0,0:12:53.31,0:12:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika yang bangkit
Dialogue: 0,0:12:54.94,0:12:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakat masa lalu yang membahayakan\Nseperti milik Fish,
Dialogue: 0,0:12:58.82,0:13:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka harus segera disingkirkan.
Dialogue: 0,0:13:01.69,0:13:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah misi kami yang membangkitkan\NBakat Kelas Legenda.
Dialogue: 0,0:13:06.95,0:13:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah ini.
Dialogue: 0,0:13:08.24,0:13:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat dari Reinkarnasi Kembali\Nadalah sebuah anugerah.
Dialogue: 0,0:13:11.54,0:13:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan jemawa dengan bakatmu.
Dialogue: 0,0:13:13.46,0:13:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan itu untuk berkontribusi\Nbagi umat manusia.
Dialogue: 0,0:13:16.58,0:13:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sekian.
Dialogue: 0,0:13:18.50,0:13:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu,
Dialogue: 0,0:13:20.09,0:13:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin kau segera jalankan\Nmisi bersama Haito.
Dialogue: 0,0:13:25.47,0:13:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Targetnya adalah Pendosa bernama...
Dialogue: 0,0:13:28.68,0:13:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vlad III.
Dialogue: 0,0:13:31.06,0:13:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dibunuh,\Ntapi buatlah dia tak berdaya.
Dialogue: 0,0:13:33.73,0:13:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak berdaya, tapi jangan dibunuh?
Dialogue: 0,0:13:35.56,0:13:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita harus membunuhnya?
Dialogue: 0,0:13:36.98,0:13:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mengganjal pikiranku.
Dialogue: 0,0:13:39.86,0:13:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito, alihkan perhatian musuh.
Dialogue: 0,0:13:41.90,0:13:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulur waktu pertarungan selama mungkin.
Dialogue: 0,0:13:44.99,0:13:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu habisi setelah sepuluh menit.
Dialogue: 0,0:13:47.32,0:13:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika terlalu lama,\Nmereka akan tahu bakat kita.
Dialogue: 0,0:13:49.95,0:13:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:13:51.49,0:13:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya, laporkan status target\Ndan kondisi sekitarnya.
Dialogue: 0,0:13:55.83,0:13:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai operasi dua hari lagi.
Dialogue: 0,0:13:57.83,0:13:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua hari lagi?
Dialogue: 0,0:13:59.04,0:14:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mau kulakukan lebih dulu.
Dialogue: 0,0:14:02.42,0:14:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan Para Legenda, ya?
Dialogue: 0,0:14:04.51,0:14:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jambret!
Dialogue: 0,0:14:07.80,0:14:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau, hentikan dia!
Dialogue: 0,0:14:11.85,0:14:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahayanya redup, jadi sulit terlihat.
Dialogue: 0,0:14:14.52,0:14:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada angin,\Njadi kelopak lebih mudah beterbangan.
Dialogue: 0,0:14:17.81,0:14:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau bertindak?
Dialogue: 0,0:14:19.44,0:14:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:20.36,0:14:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri,
Dialogue: 0,0:14:21.98,0:14:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau baru saja jalani Reinkarnasi Kembali.
Dialogue: 0,0:14:30.41,0:14:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat.
Dialogue: 0,0:14:34.04,0:14:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengan Kanan Pencuri.
Dialogue: 0,0:14:37.58,0:14:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir, Berandal!\NAkan kuhajar kau!
Dialogue: 0,0:14:47.72,0:14:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:49.72,0:14:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa tidak ditangkap?
Dialogue: 0,0:14:53.06,0:14:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah. Jangan khawatir.
Dialogue: 0,0:14:56.14,0:14:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuambil kembali.
Dialogue: 0,0:14:58.02,0:14:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini isinya...
Dialogue: 0,0:14:59.44,0:15:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih...
Dialogue: 0,0:15:00.60,0:15:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, Bodoh!
Dialogue: 0,0:15:02.06,0:15:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tasnya lebih berharga daripada isinya!
Dialogue: 0,0:15:04.07,0:15:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tas bermerek!
Dialogue: 0,0:15:05.53,0:15:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:15:09.36,0:15:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangkauannya 70 cm.
Dialogue: 0,0:15:11.49,0:15:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada daya serang
Dialogue: 0,0:15:13.70,0:15:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sangat tak praktis.
Dialogue: 0,0:15:16.45,0:15:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, selama target ada di jangkauan,
Dialogue: 0,0:15:19.29,0:15:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bisa abaikan materi penghalang\Ndan mencuri apa pun isinya.
Dialogue: 0,0:15:24.29,0:15:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa yang terjadi?
Dialogue: 0,0:15:27.13,0:15:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mencuri darahnya,\Nkau buat dia anemia paksa.
Dialogue: 0,0:15:30.09,0:15:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:15:31.55,0:15:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghentikan kejahatan.\NItulah guna bakatmu.
Dialogue: 0,0:15:35.43,0:15:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terpenting bukan bakatnya,
Dialogue: 0,0:15:38.23,0:15:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi caramu menggunakannya.
Dialogue: 0,0:15:40.85,0:15:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:43.31,0:15:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana situasinya?
Dialogue: 0,0:15:44.98,0:15:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami belum temukan jejak musuh...
Dialogue: 0,0:15:49.78,0:15:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan Para Legenda?
Dialogue: 0,0:15:52.53,0:15:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adipati Vlad.
Dialogue: 0,0:15:54.20,0:15:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sekali.
Dialogue: 0,0:15:56.62,0:15:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi cuma satu orang\Nyang dikirim melawanku?
Dialogue: 0,0:16:02.21,0:16:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka benar-benar
Dialogue: 0,0:16:04.63,0:16:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meremehkanku.
Dialogue: 0,0:16:14.85,0:16:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:16:20.14,0:16:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Empat Warna!
Dialogue: 0,0:16:22.27,0:16:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja.
Dialogue: 0,0:16:30.82,0:16:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kulihat,\Nseberapa lama kau bisa bertahan.
Dialogue: 0,0:16:38.91,0:16:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:16:40.16,0:16:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangankan membuatnya tak berdaya\Natau membunuhnya,
Dialogue: 0,0:16:42.16,0:16:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bahkan tak bisa mendekat.
Dialogue: 0,0:16:44.37,0:16:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gegabah.
Dialogue: 0,0:16:45.96,0:16:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang menganalisisnya.
Dialogue: 0,0:16:48.17,0:16:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa, asal tujuan kita tercapai.
Dialogue: 0,0:16:51.84,0:16:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menunggumu di sana.
Dialogue: 0,0:16:55.01,0:16:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bertindak sekarang,\Nkita bisa memancing bahaya.
Dialogue: 0,0:16:58.93,0:17:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik tunggu saat yang tepat.
Dialogue: 0,0:17:01.56,0:17:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaranya gampang.
Dialogue: 0,0:17:04.34,0:17:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus menghindar dari jarum di segala arah
Dialogue: 0,0:17:07.81,0:17:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangatlah
Dialogue: 0,0:17:09.60,0:17:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melelahkan.
Dialogue: 0,0:17:12.10,0:17:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:17:13.53,0:17:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sama sekali tak menyerang.
Dialogue: 0,0:17:18.66,0:17:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah, Touya.
Dialogue: 0,0:17:20.54,0:17:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti insting ahli pedang.
Dialogue: 0,0:17:22.96,0:17:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito cenderung menikmati pertarungan.
Dialogue: 0,0:17:25.96,0:17:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, Haito akan...
Dialogue: 0,0:17:31.09,0:17:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:17:33.72,0:17:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Delapan Warna!
Dialogue: 0,0:17:41.10,0:17:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan begini membuatku hilang sabar.
Dialogue: 0,0:17:44.43,0:17:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ini adalah adu ketenangan.
Dialogue: 0,0:17:50.07,0:17:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma bertahan dan tak menyerang\Nitu bukan gayaku.
Dialogue: 0,0:17:52.53,0:17:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:17:53.86,0:17:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:17:58.95,0:18:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang kutunggu-tunggu!
Dialogue: 0,0:18:07.42,0:18:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasi gagal.
Dialogue: 0,0:18:10.50,0:18:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:18:12.00,0:18:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat mundur!
Dialogue: 0,0:18:17.38,0:18:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenggelam dalam bakatmu sendiri?
Dialogue: 0,0:18:20.85,0:18:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh sekali.
Dialogue: 0,0:18:25.43,0:18:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menang.
Dialogue: 0,0:18:31.40,0:18:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:18:32.65,0:18:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada dinding di belakangku...
Dialogue: 0,0:18:34.82,0:18:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan itu...
Dialogue: 0,0:18:39.66,0:18:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh menit berlalu,\Njadi kulancarkan serangan.
Dialogue: 0,0:18:45.91,0:18:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena, tidak?
Dialogue: 0,0:18:50.58,0:18:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nak,
Dialogue: 0,0:18:51.79,0:18:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau belum lama
Dialogue: 0,0:18:53.92,0:18:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi Pengembali, kan?
Dialogue: 0,0:18:56.76,0:18:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum terbiasa pakai bakatmu.
Dialogue: 0,0:18:59.72,0:19:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melewatkan celah besar untuk mengalahkanku
Dialogue: 0,0:19:02.76,0:19:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kebodohan mutlak.
Dialogue: 0,0:19:04.97,0:19:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhukum kau dengan tusukan!
Dialogue: 0,0:19:08.19,0:19:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundurlah.
Dialogue: 0,0:19:15.53,0:19:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak.
Dialogue: 0,0:19:17.36,0:19:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau patuh, nyawamu kuampuni.
Dialogue: 0,0:19:20.41,0:19:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara itu...
Dialogue: 0,0:19:22.66,0:19:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur, Vlad.
Dialogue: 0,0:19:23.87,0:19:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:19:25.62,0:19:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit lagi kutangkap mereka...
Dialogue: 0,0:19:27.33,0:19:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak dengar ucapanku?
Dialogue: 0,0:19:30.71,0:19:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:19:32.88,0:19:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:34.50,0:19:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mirip.
Dialogue: 0,0:19:39.76,0:19:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kita sudah tercapai.
Dialogue: 0,0:19:42.09,0:19:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur.
Dialogue: 0,0:19:54.40,0:19:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pencuri!
Dialogue: 0,0:19:56.36,0:19:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu kau!
Dialogue: 0,0:19:58.61,0:19:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan...
Dialogue: 0,0:19:59.99,0:20:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan itu padaku!
Dialogue: 0,0:20:01.70,0:20:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adipati Vlad.
Dialogue: 0,0:20:03.49,0:20:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:05.33,0:20:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pura-pura bodoh!
Dialogue: 0,0:20:06.70,0:20:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pencuri tak tahu malu!
Dialogue: 0,0:20:08.83,0:20:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau curi itu saat lengah, kan?
Dialogue: 0,0:20:10.91,0:20:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakatku!
Dialogue: 0,0:20:14.21,0:20:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau beri tahu orang lain soal ini?
Dialogue: 0,0:20:17.59,0:20:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak!
Dialogue: 0,0:20:18.63,0:20:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana sudi aku sebarkan aib semacam itu!
Dialogue: 0,0:20:21.59,0:20:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:20:23.89,0:20:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:20:25.05,0:20:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kubuat kau...
Dialogue: 0,0:20:38.32,0:20:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lenyap.
Dialogue: 0,0:20:42.36,0:20:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Kiri Berguna.
Dialogue: 0,0:20:51.54,0:20:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Vlad,
Dialogue: 0,0:20:52.87,0:20:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berterima kasih padamu.
Dialogue: 0,0:20:56.00,0:20:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:20:58.25,0:20:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat ini akan kugunakan,
Dialogue: 0,0:20:59.67,0:21:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauh lebih baik darimu.
Dialogue: 0,0:21:03.34,0:21:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengabdi pada umat manusia...
Dialogue: 0,0:21:05.47,0:21:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tertarik.
Dialogue: 0,0:21:08.22,0:21:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak ada urusannya denganku.
Dialogue: 0,0:21:10.60,0:21:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila ada bakat yang kuinginkan,\Npasti kucuri.
Dialogue: 0,0:21:13.06,0:21:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bakat.
Dialogue: 0,0:21:15.44,0:21:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah itu Legenda atau Pendosa,
Dialogue: 0,0:21:17.73,0:21:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan terus kucuri,
Dialogue: 0,0:21:21.36,0:21:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kucuri semuanya!
Dialogue: 0,0:21:23.07,0:21:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat semua bakat sudah kucuri,
Dialogue: 0,0:21:25.86,0:21:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan jadi orang\Npaling berbakat dalam sejarah.
Dialogue: 0,0:21:31.33,0:21:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah bukti aku telah menyusul kakakku...
Dialogue: 0,0:21:34.16,0:21:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukti aku telah melampauinya.
Dialogue: 0,0:21:41.84,0:21:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar.
Dialogue: 0,0:21:43.92,0:21:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tak sabar.
Dialogue: 0,0:21:46.68,0:21:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang tertawa di akhir
Dialogue: 0,0:21:48.89,0:21:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah "Legenda" atau "Pendosa".
Dialogue: 0,0:21:52.93,0:21:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melainkan aku!
Dialogue: 0,0:23:27.36,0:23:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai prediksiku.
Dialogue: 0,0:23:30.16,0:23:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lihat itu,
Dialogue: 0,0:23:33.03,0:23:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiya?
Dialogue: 0,0:23:36.08,0:23:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makna menjadi pemilik.
