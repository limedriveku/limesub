Dialogue: 0,0:01:15.11,0:01:17.99,tanda,,0000,0000,0000,,PETALS OF REINCARNATION
Dialogue: 0,0:02:47.20,0:02:48.37,tanda,,0000,0000,0000,,IBITSU NITEN REIHOU: MAYAT SERIBU WARNA
Dialogue: 0,0:03:15.57,0:03:16.40,tanda,,0000,0000,0000,,TEBASAN HORIZONTAL CAESAR\NBERHASIL DIHINDARI
Dialogue: 0,0:03:16.48,0:03:17.57,tanda,,0000,0000,0000,,DISERANG BALIK,\NDIA DITUSUK DI KEPALA DAN DIBUNUH
Dialogue: 0,0:03:34.17,0:03:35.50,tanda,,0000,0000,0000,,DENGAN BELAS KASIHAN KENYATAAN,\NHIDUP TERDISTORSI KEBOHONGAN BERAKHIR
Dialogue: 0,0:09:52.75,0:09:54.09,tanda,,0000,0000,0000,,TIDAK ADA SINYAL
Dialogue: 0,0:10:44.22,0:10:46.10,tanda,,0000,0000,0000,,TIDAK ADA SINYAL
Dialogue: 0,0:18:37.65,0:18:39.16,tanda,,0000,0000,0000,,M. D'ARMONT\NBAKAT: MALAIKAT PEMBUNUH
Dialogue: 0,0:23:32.87,0:23:34.83,tanda,,0000,0000,0000,,EPISODE 7\NPUTARAN REINKARNASI YANG TIDAK BERUJUNG
Dialogue: 0,0:23:34.91,0:23:36.50,tanda,,0000,0000,0000,,EPISODE 8\NSANG PENYELAMAT
Dialogue: 0,0:01:33.26,0:01:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu Haito?
Dialogue: 0,0:01:38.97,0:01:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah takdir mereka yang ingin\Nmenjadi lebih kuat dengan cara apa pun.
Dialogue: 0,0:01:43.93,0:01:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu...
Dialogue: 0,0:01:45.10,0:01:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:01:46.89,0:01:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, selagi dia masih bisa diselamatkan,\Nkita akan pulihkan, walau dengan paksa.
Dialogue: 0,0:01:51.40,0:01:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menggunakan semua\Nyang kita miliki untuk menahan gerakannya.
Dialogue: 0,0:01:53.15,0:01:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:01:54.40,0:01:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika dia menghadapi\NTuan Kouu secara langsung,
Dialogue: 0,0:01:57.03,0:01:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku khawatir dia akan\Nterkuras tenaganya hingga mati.
Dialogue: 0,0:01:59.36,0:02:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:02:01.12,0:02:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus menggunakan langkah itu.
Dialogue: 0,0:02:02.62,0:02:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caesar, ulur waktu untuk kami.
Dialogue: 0,0:02:04.37,0:02:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:02:05.50,0:02:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}D'Armont,
Dialogue: 0,0:02:06.66,0:02:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bawa Touya dan mundur.
Dialogue: 0,0:02:08.66,0:02:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu.
Dialogue: 0,0:02:09.75,0:02:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:02:11.00,0:02:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gunakan bakatmu.
Dialogue: 0,0:02:13.63,0:02:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarilah.
Dialogue: 0,0:02:16.72,0:02:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:02:20.22,0:02:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Penyapu dan Belati Penangkis.
Dialogue: 0,0:02:23.68,0:02:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:02:26.02,0:02:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Sepuluh Warna.
Dialogue: 0,0:02:29.35,0:02:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:02:32.48,0:02:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengannya bertambah!
Dialogue: 0,0:02:34.07,0:02:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Seratus Warna.
Dialogue: 0,0:02:38.45,0:02:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katana tidak bisa\Nmenembus perisai menara ini...
Dialogue: 0,0:02:42.66,0:02:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:02:44.87,0:02:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Seribu Warna.
Dialogue: 0,0:02:58.34,0:02:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:02:59.59,0:03:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangannya menjadi tidak wajar.
Dialogue: 0,0:03:01.55,0:03:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kemampuan Nos.
Dialogue: 0,0:03:03.35,0:03:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat ramalannya tak hanya\Nmengungkapkan masa depan.
Dialogue: 0,0:03:06.93,0:03:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan menghapus\Natau menambahkan bagian tertentu,
Dialogue: 0,0:03:09.52,0:03:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bahkan bisa mengubah masa depan.
Dialogue: 0,0:03:11.90,0:03:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dia tak bisa mengubah segalanya.
Dialogue: 0,0:03:22.66,0:03:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:03:25.62,0:03:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa mengalahkannya\Nbahkan dengan ramalan Nos.
Dialogue: 0,0:03:28.54,0:03:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster.
Dialogue: 0,0:03:31.50,0:03:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir terkena tenosinovitis.
Dialogue: 0,0:03:35.75,0:03:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:03:39.30,0:03:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nirwana: Pedang Tunggal Baja Murni.
Dialogue: 0,0:03:44.60,0:03:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nos!
Dialogue: 0,0:03:48.10,0:03:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:03:50.31,0:03:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibitsu Niten Reihou.
Dialogue: 0,0:03:52.64,0:03:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apratisthita: Ainuki.
Dialogue: 0,0:03:55.31,0:03:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekanan apa ini?
Dialogue: 0,0:03:57.48,0:04:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau menggunakan aura pedang\Nuntuk menyegel gerakan kami?
Dialogue: 0,0:04:00.61,0:04:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hal yang sama berlaku untukmu.
Dialogue: 0,0:04:02.99,0:04:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang ini pertarungan tekad.
Dialogue: 0,0:04:05.99,0:04:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar datang?
Dialogue: 0,0:04:15.54,0:04:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan yang bagus.
Dialogue: 0,0:04:18.92,0:04:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caesar, Nos.
Dialogue: 0,0:04:20.95,0:04:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, kalian berdua.
Dialogue: 0,0:04:27.39,0:04:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:04:28.60,0:04:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membunuhmu.
Dialogue: 0,0:04:31.02,0:04:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau mungkin\Nakan mengharapkan kematian.
Dialogue: 0,0:04:40.78,0:04:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Haito dan yang lainnya?
Dialogue: 0,0:04:42.65,0:04:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghalang Maha Mengendalikan...
Dialogue: 0,0:04:44.61,0:04:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maut Harmoni Hitam.
Dialogue: 0,0:04:46.57,0:04:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inti dari Maha Mengendalikan\Nadalah dominasi.
Dialogue: 0,0:04:48.95,0:04:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ruang tertutup itu, Kouu bisa\Nkendalikan semuanya di tingkat molekuler.
Dialogue: 0,0:04:53.50,0:04:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu bilang itu seperti\NBig Bang yang disederhanakan.
Dialogue: 0,0:04:57.54,0:04:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia dilempar\Nke dalam benda seperti itu,
Dialogue: 0,0:05:00.25,0:05:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuh Haito tidak akan bisa menahannya.
Dialogue: 0,0:05:03.72,0:05:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak apa-apa, Kouu...\N- Aku harus bergegas.
Dialogue: 0,0:05:06.34,0:05:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ada di dalam, di mana pun itu,
Dialogue: 0,0:05:09.60,0:05:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa mencurinya.
Dialogue: 0,0:05:23.82,0:05:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:05:25.36,0:05:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah merasakan langsung bakat Musashi,\Nbagaimana perasaanmu?
Dialogue: 0,0:05:29.32,0:05:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:05:32.16,0:05:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau masih menginginkan kekuatan?
Dialogue: 0,0:05:37.50,0:05:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari, kita akan saling menunjukkan.
Dialogue: 0,0:05:39.67,0:05:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji.
Dialogue: 0,0:05:45.26,0:05:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito.
Dialogue: 0,0:05:48.43,0:05:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito!
Dialogue: 0,0:05:49.97,0:05:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haito!
Dialogue: 0,0:05:52.56,0:05:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya!
Dialogue: 0,0:06:01.44,0:06:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah berakhir?
Dialogue: 0,0:06:03.03,0:06:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:06:08.07,0:06:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru saja dimulai.
Dialogue: 0,0:06:10.95,0:06:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perkembangannya?
Dialogue: 0,0:06:12.70,0:06:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:06:13.87,0:06:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya tidak bagus.
Dialogue: 0,0:06:15.45,0:06:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mencoba mendekatinya\Ndari berbagai sudut,
Dialogue: 0,0:06:18.17,0:06:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Cabang Reinkarnasi ini...
Dialogue: 0,0:06:19.25,0:06:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudku.
Dialogue: 0,0:06:21.21,0:06:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:06:22.46,0:06:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak bisa\Nmengunci sumber sinyalnya.
Dialogue: 0,0:06:24.88,0:06:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambar satelit dengan konten\Nyang sebagian terganti,
Dialogue: 0,0:06:27.34,0:06:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}informasi, dan laporan peringatan anomali
Dialogue: 0,0:06:29.84,0:06:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah diubah secara sistematis.
Dialogue: 0,0:06:31.43,0:06:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ulah para Pengembali.
Dialogue: 0,0:06:33.64,0:06:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dimulai pada hari Touya menghilang.
Dialogue: 0,0:06:36.02,0:06:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah jelas sekarang?
Dialogue: 0,0:06:43.36,0:06:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya.
Dialogue: 0,0:06:44.69,0:06:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitazuka!
Dialogue: 0,0:06:46.15,0:06:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong selamatkan dia!
Dialogue: 0,0:06:49.91,0:06:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil tim medis.
Dialogue: 0,0:06:51.49,0:06:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:06:52.87,0:06:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kenalanku.
Dialogue: 0,0:06:54.49,0:06:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... Aku mengerti.
Dialogue: 0,0:06:57.79,0:06:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga.
Dialogue: 0,0:06:59.83,0:07:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:07:01.42,0:07:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan. Aku tidak berniat bertarung.
Dialogue: 0,0:07:04.09,0:07:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berhasil mengeliminasi\Ndan menangkap para Pengembali
Dialogue: 0,0:07:07.67,0:07:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuat kemajuan dalam penelitian\Ntentang Cabang dan Kelopak.
Dialogue: 0,0:07:10.22,0:07:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat mengesankan.
Dialogue: 0,0:07:11.80,0:07:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktivitas kami seharusnya sangat rahasia.
Dialogue: 0,0:07:15.14,0:07:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nos juga sangat menghormatimu.
Dialogue: 0,0:07:17.35,0:07:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:07:18.85,0:07:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia sengaja\Nmembiarkan dirinya tertangkap?
Dialogue: 0,0:07:21.35,0:07:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lengah.
Dialogue: 0,0:07:22.65,0:07:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kau punya banyak pertanyaan,
Dialogue: 0,0:07:25.36,0:07:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak ada waktu untuk basa-basi.
Dialogue: 0,0:07:27.86,0:07:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh sudah mulai bergerak.
Dialogue: 0,0:07:29.95,0:07:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh?
Dialogue: 0,0:07:31.24,0:07:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Musuh.
Dialogue: 0,0:07:34.28,0:07:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:07:35.78,0:07:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembok api telah ditembus.
Dialogue: 0,0:07:37.66,0:07:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini serangan peretasan.
Dialogue: 0,0:07:38.83,0:07:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini bisa terjadi?
Dialogue: 0,0:07:40.29,0:07:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:07:41.67,0:07:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Apa ini pemadaman listrik?
Dialogue: 0,0:07:44.13,0:07:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa ini?
Dialogue: 0,0:07:45.34,0:07:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membeku.
Dialogue: 0,0:07:47.09,0:07:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa yang terjadi?
Dialogue: 0,0:07:49.01,0:07:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, lihat itu!
Dialogue: 0,0:07:50.38,0:07:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu semacam logo?
Dialogue: 0,0:07:52.05,0:07:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepada seluruh umat manusia,
Dialogue: 0,0:07:53.89,0:07:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}salam.
Dialogue: 0,0:07:55.80,0:07:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah Hutan Para Legenda.
Dialogue: 0,0:07:58.93,0:08:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neumann.
Dialogue: 0,0:08:01.77,0:08:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memanfaatkan bakat\Nyang baru bangkit dari sejarah,
Dialogue: 0,0:08:05.40,0:08:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beroperasi dengan tujuan utama\Nmenjaga perdamaian dunia.
Dialogue: 0,0:08:08.57,0:08:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kami adalah melenyapkan kelompok\Nyang bahayakan dunia dengan bakat jahat.
Dialogue: 0,0:08:11.74,0:08:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yoshiki!
Dialogue: 0,0:08:12.65,0:08:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku sedang mengonfirmasi.\N- Menyingkirkan Pengembali kelas Pendosa.
Dialogue: 0,0:08:14.07,0:08:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Perdamaian dunia?\N- Tapi sampai sekarang,
Dialogue: 0,0:08:15.16,0:08:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kepribadian kelas Pendosa?\N- itu masih belum terselesaikan...
Dialogue: 0,0:08:16.66,0:08:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat jahat?
Dialogue: 0,0:08:17.58,0:08:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sebanyak apa pun penjahat\Nyang dibunuh,
Dialogue: 0,0:08:18.95,0:08:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Menyingkirkan?\N- mereka akan
Dialogue: 0,0:08:20.00,0:08:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Reinkarnasi?\N- terlahir kembali
Dialogue: 0,0:08:20.91,0:08:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa yang dia bicarakan?\N- melalui reinkarnasi.
Dialogue: 0,0:08:22.50,0:08:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hadapan tragedi seperti itu,\Nharuskah orang-orang menonton tanpa daya?
Dialogue: 0,0:08:26.88,0:08:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:08:28.05,0:08:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan menyingkirkan mereka\Nsebanyak yang dibutuhkan.
Dialogue: 0,0:08:31.01,0:08:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untuk tujuan itu,\Nkami harus meminta kalian mati.
Dialogue: 0,0:08:34.92,0:08:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena setiap manusia yang hidup di Bumi
Dialogue: 0,0:08:37.47,0:08:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berpotensi membangkitkan bakat jahat.
Dialogue: 0,0:08:40.60,0:08:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka mereka akan\Nmemutarbalikkan perdamaian dunia
Dialogue: 0,0:08:43.35,0:08:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diinginkan kakakku\Ndengan cara seperti itu.
Dialogue: 0,0:08:46.31,0:08:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak akan membunuh semua orang.
Dialogue: 0,0:08:48.73,0:08:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya,\Nkami akan meninggalkan sejumlah orang,
Dialogue: 0,0:08:51.36,0:08:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menahan manusia yang tersisa,
Dialogue: 0,0:08:53.74,0:08:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menusuk beberapa dari mereka\Ndengan Cabang.
Dialogue: 0,0:08:56.78,0:08:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menahan?
Dialogue: 0,0:08:58.12,0:09:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang tidak berbakat akan mati.
Dialogue: 0,0:09:00.49,0:09:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika mereka bangkitkan bakat Legenda,\Nmereka akan menjadi rekan kami.
Dialogue: 0,0:09:04.92,0:09:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, kelas Pendosa\Nakan disingkirkan di tempat.
Dialogue: 0,0:09:07.84,0:09:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, dunia baru\Nyang penuh dengan bakat Legenda
Dialogue: 0,0:09:12.05,0:09:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menjadi puncak sejarah manusia.
Dialogue: 0,0:09:16.34,0:09:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menamai ini Rencana Kemanusiaan Besar,
Dialogue: 0,0:09:19.89,0:09:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kini resmi diberlakukan.
Dialogue: 0,0:09:21.47,0:09:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau benar-benar\Nmenolak kemanusiaan modern?
Dialogue: 0,0:09:24.06,0:09:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong.
Dialogue: 0,0:09:25.69,0:09:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai apakah kami punya kekuatan\Nuntuk menjalankan rencana ini,
Dialogue: 0,0:09:29.23,0:09:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan nilai sendiri\Nsetelah demonstrasi berikut.
Dialogue: 0,0:09:33.15,0:09:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat menikmati.
Dialogue: 0,0:09:38.41,0:09:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nobel.
Dialogue: 0,0:09:39.41,0:09:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izin pengeboman dikonfirmasi.
Dialogue: 0,0:09:41.74,0:09:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bom Pemusnah Level 1.
Dialogue: 0,0:09:43.95,0:09:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memulai pelepasan.
Dialogue: 0,0:09:54.34,0:09:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area luas di Australia
Dialogue: 0,0:09:57.09,0:09:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hilang.
Dialogue: 0,0:10:00.05,0:10:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tesla.
Dialogue: 0,0:10:01.31,0:10:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kumulai sekarang?
Dialogue: 0,0:10:02.85,0:10:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:10:04.93,0:10:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci pengaman, dilepaskan.
Dialogue: 0,0:10:06.73,0:10:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tautan sistem.
Dialogue: 0,0:10:09.23,0:10:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:10:11.27,0:10:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:10:15.28,0:10:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya terbakar.
Dialogue: 0,0:10:16.61,0:10:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali!
Dialogue: 0,0:10:19.32,0:10:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitazuka.
Dialogue: 0,0:10:21.45,0:10:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:10:23.45,0:10:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagarin.
Dialogue: 0,0:10:25.12,0:10:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Neumann.
Dialogue: 0,0:10:26.96,0:10:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini menyedihkan,\Ntapi aku harus melakukannya.
Dialogue: 0,0:10:29.25,0:10:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua demi senyuman umat manusia.
Dialogue: 0,0:10:31.63,0:10:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhitungan pengeboman dikonfirmasi.
Dialogue: 0,0:10:33.46,0:10:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi dampak dikonfirmasi.
Dialogue: 0,0:10:36.97,0:10:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bumi sangat biru.
Dialogue: 0,0:10:39.13,0:10:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak melihat Tuhan di sini.
Dialogue: 0,0:10:50.40,0:10:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya sebagian kecil
Dialogue: 0,0:10:52.06,0:10:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari kekuatan yang kami,\NHutan Para Legenda, miliki.
Dialogue: 0,0:10:54.53,0:10:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu takut.
Dialogue: 0,0:10:56.24,0:10:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana akan dilaksanakan\Npada tanggal 1 Januari.
Dialogue: 0,0:10:59.03,0:11:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa tenggang tiga bulan ini\Nadalah hadiah terakhir kami untukmu.
Dialogue: 0,0:11:03.78,0:11:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, semoga kalian semua bahagia.
Dialogue: 0,0:11:14.46,0:11:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau diawasi.
Dialogue: 0,0:11:16.71,0:11:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diawasi?
Dialogue: 0,0:11:18.30,0:11:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat Neumann, "Ahli Komputer".
Dialogue: 0,0:11:21.34,0:11:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia maya adalah halaman belakangnya.
Dialogue: 0,0:11:24.14,0:11:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah bakat Neumann\Nadalah Perhitungan Prediksi?
Dialogue: 0,0:11:27.27,0:11:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa bilang Pengembali\Nhanya bisa punya satu bakat?
Dialogue: 0,0:11:31.73,0:11:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, sebaiknya kau berhati-hati.
Dialogue: 0,0:11:34.61,0:11:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau mengatakannya\Nseolah-olah itu bukan urusanmu?
Dialogue: 0,0:11:37.36,0:11:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga bertarung, mengerti?
Dialogue: 0,0:11:39.24,0:11:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau,
Dialogue: 0,0:11:43.03,0:11:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku yakin musuh juga tahu ini.
Dialogue: 0,0:11:46.66,0:11:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batas aktivitas yang berasal\Ndari Perhitungan Prediksi
Dialogue: 0,0:11:49.16,0:11:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hampir mutlak.
Dialogue: 0,0:11:50.71,0:11:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mengalahkan Kouu dalam waktu singkat.
Dialogue: 0,0:11:52.58,0:11:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu pertaruhan yang berbahaya.
Dialogue: 0,0:11:54.75,0:11:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, jika dia menyerang kita\Ndalam perjuangan putus asa
Dialogue: 0,0:11:57.42,0:11:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat dia sekarat...
Dialogue: 0,0:11:58.51,0:11:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir.
Dialogue: 0,0:12:02.68,0:12:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sudah mengumpulkan\Ncukup pasukan untuk melawannya.
Dialogue: 0,0:12:06.26,0:12:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai ekspektasi.
Dialogue: 0,0:12:08.64,0:12:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Nobel dan Tesla ada\Ndi perbatasan tadi?
Dialogue: 0,0:12:12.73,0:12:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meminta mereka diteleportasi.
Dialogue: 0,0:12:13.98,0:12:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:12:15.23,0:12:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ini sederhana.
Dialogue: 0,0:12:18.03,0:12:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teleportasi, ya?
Dialogue: 0,0:12:21.70,0:12:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teleportasi?
Dialogue: 0,0:12:24.28,0:12:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit...
Dialogue: 0,0:12:25.53,0:12:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nightingale, periksalah keadaannya.
Dialogue: 0,0:12:27.87,0:12:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:12:28.79,0:12:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:12:31.00,0:12:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih penting, di mana Ein?
Dialogue: 0,0:12:35.83,0:12:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak ingat?
Dialogue: 0,0:12:37.46,0:12:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengkhianat itu.
Dialogue: 0,0:12:39.38,0:12:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau membunuhnya\Ndengan tanganmu sendiri?
Dialogue: 0,0:12:42.76,0:12:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya satu kakinya yang tersisa, kan?
Dialogue: 0,0:12:45.97,0:12:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membunuh Ein?
Dialogue: 0,0:12:48.85,0:12:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, efeknya hampir hilang.
Dialogue: 0,0:12:51.48,0:12:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nightingale.
Dialogue: 0,0:12:52.77,0:12:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:57.44,0:12:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku...
Dialogue: 0,0:12:59.53,0:13:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan kepadaku?
Dialogue: 0,0:13:01.24,0:13:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bayangan Merah Crimea."
Dialogue: 0,0:13:03.70,0:13:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuat siapa pun yang lukanya\Ndia sembuhkan tunduk kepadanya.
Dialogue: 0,0:13:06.24,0:13:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bakat kedua Nightingale.
Dialogue: 0,0:13:09.45,0:13:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon itu bakat yang lahir\Ndari anekdot prajurit terluka
Dialogue: 0,0:13:12.87,0:13:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mencium bayangannya saat ia lewat,\Nseusai menerima perawatannya yang setia.
Dialogue: 0,0:13:17.17,0:13:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:13:18.38,0:13:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu sebabnya aku...
Dialogue: 0,0:13:19.92,0:13:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh sekali.
Dialogue: 0,0:13:21.55,0:13:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai kau tak melawan\Ndan menerima penaklukan,
Dialogue: 0,0:13:24.01,0:13:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ein tak perlu mati...
Dialogue: 0,0:13:26.09,0:13:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang Da Vinci juga begitu?
Dialogue: 0,0:13:29.14,0:13:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sekali.
Dialogue: 0,0:13:30.18,0:13:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian dengar itu?
Dialogue: 0,0:13:32.10,0:13:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergabunglah denganku\Nuntuk menghentikan dalang ini...
Dialogue: 0,0:13:36.14,0:13:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya.
Dialogue: 0,0:13:37.69,0:13:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang di sini berada\Ndi bawah kendali Nightingale.
Dialogue: 0,0:13:41.32,0:13:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa...
Dialogue: 0,0:13:42.99,0:13:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam Hutan Para Legenda,
Dialogue: 0,0:13:45.45,0:13:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku meminta Nightingale menyembuhkan\Nluka semua rekan kita.
Dialogue: 0,0:13:50.03,0:13:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah caraku menambah pionku,\Nsedikit demi sedikit.
Dialogue: 0,0:13:55.91,0:13:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berterima kasih kepada Kouu.
Dialogue: 0,0:13:58.50,0:14:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berjalan sesuai perhitunganku.
Dialogue: 0,0:14:00.92,0:14:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakatku sangat kuat\Nhingga aku pun merasa itu menakutkan.
Dialogue: 0,0:14:03.80,0:14:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau serius?
Dialogue: 0,0:14:05.92,0:14:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengejek perdamaian dunia\Nyang dicari Da Vinci?
Dialogue: 0,0:14:09.64,0:14:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaan bodoh.
Dialogue: 0,0:14:10.76,0:14:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa otakmu juga terbakar?
Dialogue: 0,0:14:14.73,0:14:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:16.89,0:14:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lega, Neumann.
Dialogue: 0,0:14:20.02,0:14:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga dimanipulasi, kan?
Dialogue: 0,0:14:22.40,0:14:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong apa itu?
Dialogue: 0,0:14:24.07,0:14:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan saat dikendalikan,\Nkepribadian dan karakter tak berubah.
Dialogue: 0,0:14:27.99,0:14:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu karena perlawanan sengitmu.
Dialogue: 0,0:14:29.78,0:14:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikiran yang menyimpang membawa\Nrasa sakit yang menyiksa.
Dialogue: 0,0:14:32.95,0:14:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sampai menangis.
Dialogue: 0,0:14:35.00,0:14:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendekati orang lain dengan setia\Nhanya untuk mengendalikan mereka,
Dialogue: 0,0:14:37.75,0:14:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bahkan menginjak-injak harapan mereka.
Dialogue: 0,0:14:39.83,0:14:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau yang harus dikalahkan,
Dialogue: 0,0:14:42.17,0:14:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nightingale!
Dialogue: 0,0:14:46.63,0:14:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya Neumann.
Dialogue: 0,0:14:48.38,0:14:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir semua Pengembali\Ndi Hutan Para Legenda
Dialogue: 0,0:14:51.18,0:14:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dikendalikan oleh seseorang.
Dialogue: 0,0:14:53.76,0:14:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ini juga kabar baik.
Dialogue: 0,0:14:56.60,0:14:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuhnya bukan\NHutan Para Legenda itu sendiri,
Dialogue: 0,0:14:58.85,0:15:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dalang di baliknya.
Dialogue: 0,0:15:01.27,0:15:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan berurusan\Ndengan organisasi yang beragam...
Dialogue: 0,0:15:03.15,0:15:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua itu tidak penting.
Dialogue: 0,0:15:05.82,0:15:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, pekerjaan ini\Ndan penelitian Kelopak Bunga
Dialogue: 0,0:15:09.28,0:15:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dimulai dengan tujuan\Nmengungkap satu kebenaran.
Dialogue: 0,0:15:15.54,0:15:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mencari tahu\Nsiapa yang membunuh Seiya...
Dialogue: 0,0:15:17.08,0:15:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu aku.
Dialogue: 0,0:15:18.91,0:15:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang membunuh Seiya.
Dialogue: 0,0:15:22.50,0:15:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur, Orang Luar.
Dialogue: 0,0:15:24.96,0:15:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir.
Dialogue: 0,0:15:26.46,0:15:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah, Kitazuka.
Dialogue: 0,0:15:28.88,0:15:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku dan Kouu dijebak.
Dialogue: 0,0:15:32.01,0:15:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bisakah kita melakukannya?\NSambil melawan anggota Hutan
Dialogue: 0,0:15:35.85,0:15:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengungkap dalang di baliknya\Nuntuk menjatuhkan mereka...
Dialogue: 0,0:15:38.64,0:15:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:15:41.06,0:15:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu bakat terkuat\Ndan tak tertandingi, "Maha Mengendalikan".
Dialogue: 0,0:15:47.61,0:15:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menjadi Pengembali
Dialogue: 0,0:15:49.70,0:15:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melampaui Seiya, kan?
Dialogue: 0,0:15:52.03,0:15:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, semuanya akan berjalan\Nsesuai keinginanmu.
Dialogue: 0,0:15:55.45,0:15:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menolak.
Dialogue: 0,0:15:57.62,0:16:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak lagi berpikir\Nuntuk melampaui kakakku.
Dialogue: 0,0:16:01.46,0:16:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan berpikir seperti itu lagi.
Dialogue: 0,0:16:03.46,0:16:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, dengan bakat Maha Mengendalikan,\Naku bisa menyelesaikan semuanya sekaligus.
Dialogue: 0,0:16:08.71,0:16:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:16:10.55,0:16:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak melakukan itu.
Dialogue: 0,0:16:13.89,0:16:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah sampai sejauh ini\Ndengan melawan dirimu sendiri.
Dialogue: 0,0:16:17.26,0:16:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku juga akan...
Dialogue: 0,0:16:18.47,0:16:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:16:19.89,0:16:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau punya kesempatan menang?
Dialogue: 0,0:16:21.27,0:16:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:16:22.60,0:16:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:16:24.19,0:16:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti akan menemukannya sendiri.
Dialogue: 0,0:16:29.19,0:16:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:32.95,0:16:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:16:33.95,0:16:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya menepati janji kita.
Dialogue: 0,0:16:36.28,0:16:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu!
Dialogue: 0,0:16:37.83,0:16:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupercayakan semua informasi\Nyang kumiliki tentang Hutan Para Legenda
Dialogue: 0,0:16:40.95,0:16:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan penelitianku\Ntentang Kelopak Caesar kepadamu.
Dialogue: 0,0:16:47.21,0:16:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal, Touya.
Dialogue: 0,0:16:50.80,0:16:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sampaikan salamku kepada kakakku.
Dialogue: 0,0:16:54.59,0:16:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan padanya bahwa adiknya...
Dialogue: 0,0:16:56.09,0:16:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahwa aku
Dialogue: 0,0:16:57.68,0:16:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik-baik saja sekarang.
Dialogue: 0,0:18:22.01,0:18:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya biarkan aku memilih tempat\Nyang bagus untuk mati.
Dialogue: 0,0:18:25.98,0:18:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau romantis.
Dialogue: 0,0:18:29.27,0:18:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku yang terkuat di dunia.
Dialogue: 0,0:18:31.40,0:18:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepantasnya, kan?
Dialogue: 0,0:18:34.61,0:18:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih...
Dialogue: 0,0:18:44.24,0:18:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Rekan.
Dialogue: 0,0:18:45.79,0:18:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sudah sadar.
Dialogue: 0,0:18:48.00,0:18:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaanmu?
Dialogue: 0,0:18:51.29,0:18:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu namamu?
Dialogue: 0,0:18:52.84,0:18:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu apa bakatmu?
Dialogue: 0,0:18:54.80,0:18:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengambil nyawa seseorang
Dialogue: 0,0:18:57.26,0:18:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan mengorbankan nyawaku.
Dialogue: 0,0:18:59.13,0:19:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cukup mengesankan.
Dialogue: 0,0:19:00.59,0:19:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, siapa yang ingin kau bunuh?
Dialogue: 0,0:19:02.60,0:19:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lebih banyak orang yang ingin kubunuh\Ndaripada yang bisa kuhitung.
Dialogue: 0,0:19:05.85,0:19:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membosankan sekali.
Dialogue: 0,0:19:07.18,0:19:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:08.14,0:19:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang, membosankan sekali.
Dialogue: 0,0:19:09.94,0:19:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa orang-orang itu sepadan dengan nyawamu?
Dialogue: 0,0:19:13.86,0:19:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kepada siapa aku\Nharus menggunakan bakat ini?
Dialogue: 0,0:19:18.78,0:19:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang harus kubunuh agar bisa selamat?
Dialogue: 0,0:19:20.53,0:19:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku menggorok leherku saat itu?
Dialogue: 0,0:19:24.54,0:19:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi cinta.
Dialogue: 0,0:19:26.29,0:19:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta?
Dialogue: 0,0:19:27.83,0:19:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang terlahir dan mati sendirian.
Dialogue: 0,0:19:30.54,0:19:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dengan bakatmu, kau bisa mengubah itu.
Dialogue: 0,0:19:34.59,0:19:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama seseorang di saat-saat terakhirmu\Npasti kebahagiaan sejati.
Dialogue: 0,0:19:38.67,0:19:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika orang itu orang yang kau cintai,\Nitu pasti lebih indah.
Dialogue: 0,0:19:42.55,0:19:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya orang seperti itu.
Dialogue: 0,0:19:44.68,0:19:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, cari dia.
Dialogue: 0,0:19:47.10,0:19:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiduplah demi momen terakhir\Nyang sempurna itu.
Dialogue: 0,0:19:50.60,0:19:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membantumu dengan itu.
Dialogue: 0,0:19:53.56,0:19:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau romantis, ya?
Dialogue: 0,0:19:56.28,0:19:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku yang terkuat di dunia.
Dialogue: 0,0:19:58.53,0:19:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepantasnya, kan?
Dialogue: 0,0:20:00.82,0:20:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku D'Armont.
Dialogue: 0,0:20:01.99,0:20:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu.
Dialogue: 0,0:20:03.37,0:20:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:20:04.74,0:20:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa itu, Kouu?
Dialogue: 0,0:20:06.62,0:20:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau kuat,\Njangan mengganggu yang lemah!
Dialogue: 0,0:20:09.58,0:20:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya tidak tahan\Ndengan sikapnya yang plinplan.
Dialogue: 0,0:20:14.88,0:20:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:20:18.42,0:20:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kau mengerti.
Dialogue: 0,0:20:19.80,0:20:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, berjabat tangan dan berbaikanlah.
Dialogue: 0,0:20:21.93,0:20:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita jarang bertemu\Nmelalui kelopak bunga ini.
Dialogue: 0,0:20:24.55,0:20:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berusaha akur.
Dialogue: 0,0:20:26.51,0:20:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kau akan menemukan seseorang\Nyang ingin kau temani di saat terakhirmu.
Dialogue: 0,0:20:37.82,0:20:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bercanda?
Dialogue: 0,0:20:39.53,0:20:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para bedebah dari Hutan Para Legenda itu...
Dialogue: 0,0:20:41.11,0:20:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Pol!
Dialogue: 0,0:20:42.49,0:20:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini bisa terjadi?
Dialogue: 0,0:20:45.53,0:20:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membunuh mereka!
Dialogue: 0,0:20:47.78,0:20:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:20:49.33,0:20:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian jangan gegabah.
Dialogue: 0,0:20:51.54,0:20:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu kita harus membiarkan\Nmereka membantai kita?
Dialogue: 0,0:20:53.67,0:20:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak!
Dialogue: 0,0:20:56.71,0:20:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuh karena marah itu mudah.
Dialogue: 0,0:20:59.67,0:21:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa yang tersisa?
Dialogue: 0,0:21:02.26,0:21:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kerugian.
Dialogue: 0,0:21:04.34,0:21:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi kita bubar sekarang.
Dialogue: 0,0:21:07.51,0:21:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencari tahu kebenarannya sendiri.
Dialogue: 0,0:21:10.10,0:21:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jadi...\N- Kouu.
Dialogue: 0,0:21:12.48,0:21:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukai aku.
Dialogue: 0,0:21:15.23,0:21:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}D'Armont...
Dialogue: 0,0:21:16.36,0:21:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong apa yang kau katakan?
Dialogue: 0,0:21:18.27,0:21:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa melakukan apa pun\Nselama kau menyakiti seseorang, kan?
Dialogue: 0,0:21:22.11,0:21:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, setidaknya sakiti aku.
Dialogue: 0,0:21:24.70,0:21:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bahkan hanya luka kecil...\N- Jangan konyol!
Dialogue: 0,0:21:26.66,0:21:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kata-kataku.
Dialogue: 0,0:21:29.33,0:21:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak mengikuti sembarang orang.
Dialogue: 0,0:21:31.83,0:21:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengikutimu.
Dialogue: 0,0:21:33.75,0:21:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan lepaskan kami.
Dialogue: 0,0:21:35.87,0:21:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}D'Armont...
Dialogue: 0,0:21:37.08,0:21:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan hal yang sama.
Dialogue: 0,0:21:39.25,0:21:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak mencari cara hidup yang benar.
Dialogue: 0,0:21:42.97,0:21:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga tak bersikap rasional.
Dialogue: 0,0:21:45.26,0:21:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, melihatmu sekarang,
Dialogue: 0,0:21:47.39,0:21:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada yang bisa diam saja.
Dialogue: 0,0:21:51.47,0:21:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouu...
Dialogue: 0,0:21:54.27,0:21:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sekelompok orang bodoh.
Dialogue: 0,0:21:56.81,0:21:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi, semuanya.
Dialogue: 0,0:22:04.32,0:22:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini menjadi cukup kosong, bukan?
Dialogue: 0,0:22:07.11,0:22:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin tentang ini?
Dialogue: 0,0:22:08.91,0:22:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:22:10.37,0:22:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang menemukan alasan\Nuntuk hidup dan tempat untuk mati.
Dialogue: 0,0:22:13.33,0:22:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti puas.
Dialogue: 0,0:22:15.25,0:22:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu semua berkat Raja.
Dialogue: 0,0:22:17.83,0:22:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bagaimana denganmu?
Dialogue: 0,0:22:19.92,0:22:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan membalaskan\Ndendam temanmu?
Dialogue: 0,0:22:22.05,0:22:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak meminta\Nbuku ramalan di tanganmu?
Dialogue: 0,0:22:27.18,0:22:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:22:28.89,0:22:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir itu salahmu\Naku tidak bisa membalas dendam?
Dialogue: 0,0:22:34.77,0:22:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pilihanku sendiri.
Dialogue: 0,0:22:36.77,0:22:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghabiskan setiap hari bersama kalian
Dialogue: 0,0:22:39.31,0:22:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berakhir seperti ini.
Dialogue: 0,0:22:41.57,0:22:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memercayakan masa depan setelah ini.
Dialogue: 0,0:22:44.03,0:22:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyesal.
