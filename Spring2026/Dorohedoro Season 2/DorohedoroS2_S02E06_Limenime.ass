Dialogue: 0,0:00:02.15,0:00:05.99,tanda,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:02:46.23,0:02:49.02,tanda,,0000,0000,0000,,AWAL
Dialogue: 0,0:12:04.37,0:12:07.37,tanda,,0000,0000,0000,,SELAMAT TINGGAL, CAIMAN
Dialogue: 0,0:13:12.94,0:13:15.23,tanda,,0000,0000,0000,,HATI YANG TERBAKAR
Dialogue: 0,0:19:01.87,0:19:04.33,tanda,,0000,0000,0000,,GELEMBUNG MEMORI
Dialogue: 0,0:24:15.68,0:24:16.98,tanda,,0000,0000,0000,,AKHIR
Dialogue: 0,0:00:08.32,0:00:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}2.302 ohba gioza.
Dialogue: 0,0:00:12.37,0:00:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}2.303 ohba gioza.
Dialogue: 0,0:00:16.37,0:00:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}2.304 ohba gioza.
Dialogue: 0,0:00:22.71,0:00:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa tidur sama sekali.\NTerlalu banyak yang kupikirkan.
Dialogue: 0,0:00:27.41,0:00:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghitung gioza membuatku lapar\Ndan tak membantu sama sekali.
Dialogue: 0,0:00:41.77,0:00:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada 100 nick!
Dialogue: 0,0:00:43.19,0:00:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:00:44.67,0:00:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa dapat uang receh\Ndari mesin otomatis ini tiap malam.
Dialogue: 0,0:00:48.60,0:00:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu pekerjaan lagi setelah sif.
Dialogue: 0,0:00:50.78,0:00:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya penyihir pun bisa bokek.
Dialogue: 0,0:00:55.12,0:00:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, mereka Mata Silang?
Dialogue: 0,0:00:59.04,0:01:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak salah lagi.
Dialogue: 0,0:01:04.12,0:01:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:01:07.46,0:01:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:01:12.05,0:01:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:01:15.04,0:01:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Risu.
Dialogue: 0,0:02:50.19,0:02:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En...
Dialogue: 0,0:02:53.69,0:02:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, kudengar En pingsan?
Dialogue: 0,0:02:56.49,0:02:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin, Noi!
Dialogue: 0,0:02:59.16,0:03:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian manusia dari Hole.
Dialogue: 0,0:03:02.66,0:03:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo!
Dialogue: 0,0:03:05.69,0:03:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kenalanku, abaikan saja.
Dialogue: 0,0:03:08.50,0:03:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:03:09.92,0:03:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Nikaido?
Dialogue: 0,0:03:11.55,0:03:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, sampai sekarang,\Nakulah yang menyamar jadi Nikaido.
Dialogue: 0,0:03:16.26,0:03:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tak sadar?
Dialogue: 0,0:03:17.30,0:03:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:18.80,0:03:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido yang asli kabur dengan pria kadal.
Dialogue: 0,0:03:23.43,0:03:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran di mana mereka sekarang.
Dialogue: 0,0:03:25.44,0:03:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begitu.\NKamu berhasil, Caiman!
Dialogue: 0,0:03:32.32,0:03:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En bangun!
Dialogue: 0,0:03:33.32,0:03:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, kamu baik-baik saja?
Dialogue: 0,0:03:35.07,0:03:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos!
Dialogue: 0,0:03:35.70,0:03:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En! Syukurlah!
Dialogue: 0,0:03:41.49,0:03:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chota!
Dialogue: 0,0:03:50.50,0:03:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu mau ke tempat Nikaido?
Dialogue: 0,0:03:54.16,0:03:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontrak dalam diriku akan membimbingku.
Dialogue: 0,0:03:57.62,0:04:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri yang akan\Nmenyingkirkan pria kadal itu!
Dialogue: 0,0:04:00.64,0:04:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susul aku nanti!
Dialogue: 0,0:04:15.94,0:04:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman?
Dialogue: 0,0:04:19.20,0:04:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:04:20.41,0:04:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu, kamu ada di sini?
Dialogue: 0,0:04:29.58,0:04:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebi—
Dialogue: 0,0:04:35.95,0:04:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu.
Dialogue: 0,0:04:37.51,0:04:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita.
Dialogue: 0,0:04:39.13,0:04:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu!
Dialogue: 0,0:04:41.93,0:04:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu!
Dialogue: 0,0:04:46.68,0:04:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu!
Dialogue: 0,0:05:10.40,0:05:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster!\NEbisu, bertahanlah!
Dialogue: 0,0:05:13.38,0:05:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan panggil Noi secepat mungkin!
Dialogue: 0,0:05:28.77,0:05:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, sihirku tak akan mempan.
Dialogue: 0,0:05:38.15,0:05:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Bubuk Hitam?
Dialogue: 0,0:05:40.03,0:05:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:05:49.73,0:05:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu teman Risu?
Dialogue: 0,0:05:52.40,0:05:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu Aikawa?
Dialogue: 0,0:05:54.92,0:05:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa?
Dialogue: 0,0:06:05.55,0:06:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:06:07.58,0:06:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, Tetsujo!
Dialogue: 0,0:06:09.31,0:06:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, En ada di sini.
Dialogue: 0,0:06:11.56,0:06:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia mengincar kita?
Dialogue: 0,0:06:13.59,0:06:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita belum dibayar!
Dialogue: 0,0:06:14.94,0:06:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya mencemaskan itu!
Dialogue: 0,0:06:18.05,0:06:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, kenapa malah diam, ayo pergi!
Dialogue: 0,0:06:20.44,0:06:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:21.19,0:06:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:22.53,0:06:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, pria itu hanya terlihat tak asing.
Dialogue: 0,0:06:31.95,0:06:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:06:34.00,0:06:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang, Nikaido!
Dialogue: 0,0:06:40.96,0:06:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:06:43.47,0:06:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:06:44.68,0:06:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido, ada apa?
Dialogue: 0,0:06:46.76,0:06:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadaku sakit.
Dialogue: 0,0:06:49.29,0:06:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En ada di dekat sini.
Dialogue: 0,0:06:51.97,0:06:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan menggendongmu.\NKita kabur dari sini!
Dialogue: 0,0:07:22.89,0:07:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa, Nikaido.
Dialogue: 0,0:07:25.63,0:07:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En.
Dialogue: 0,0:07:27.39,0:07:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kamu si pria kadal, ya?
Dialogue: 0,0:07:31.01,0:07:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini untuk mengambil\Npartnerku kembali.
Dialogue: 0,0:07:34.64,0:07:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan!
Dialogue: 0,0:07:36.06,0:07:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman!
Dialogue: 0,0:07:37.06,0:07:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sebenarnya bukan tipe\Norang yang suka kabur.
Dialogue: 0,0:07:40.27,0:07:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membunuhmu, Jamur Sialan!
Dialogue: 0,0:07:43.28,0:07:44.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu mati,
Dialogue: 0,0:07:44.99,0:07:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sihir kontrak Nikaido akan hilang.
Dialogue: 0,0:07:49.17,0:07:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadapi aku, kamu akan kucabik\Nsampai tak bisa hidup lagi.
Dialogue: 0,0:07:53.16,0:07:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sehebat apa pun dirimu sebagai penyihir,
Dialogue: 0,0:07:56.79,0:08:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sihir tak akan mempan padaku!
Dialogue: 0,0:08:18.44,0:08:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NSudah selesai?
Dialogue: 0,0:08:22.11,0:08:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir jamurku hanyalah sihir konyol.
Dialogue: 0,0:08:26.89,0:08:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu tak tahu\Nbetapa menakutkannya itu.
Dialogue: 0,0:08:30.61,0:08:32.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga balas dendam untuk Matsumura.
Dialogue: 0,0:08:33.30,0:08:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membunuhmu\Ndengan cara yang paling menyakitkan.
Dialogue: 0,0:08:36.37,0:08:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja!
Dialogue: 0,0:08:43.46,0:08:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar, sihirku tak mempan padamu.
Dialogue: 0,0:08:51.09,0:08:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak perlu merapalnya padamu.
Dialogue: 0,0:08:53.37,0:08:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melepaskan spora kecil\Nyang akan menghasilkan jamur.
Dialogue: 0,0:08:57.85,0:09:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengoceh apa kamu ini?
Dialogue: 0,0:09:00.10,0:09:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang aku sekarang!
Dialogue: 0,0:09:02.02,0:09:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah berakhir.
Dialogue: 0,0:09:04.02,0:09:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:05.47,0:09:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spora yang kutempelkan padamu,\Nsekarang menyerang tubuhmu,
Dialogue: 0,0:09:10.03,0:09:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan masuk ke dalam organmu.
Dialogue: 0,0:09:13.70,0:09:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman!
Dialogue: 0,0:09:14.66,0:09:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu mulai tumbuh.
Dialogue: 0,0:09:29.80,0:09:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas.
Dialogue: 0,0:09:31.87,0:09:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengalahkan monster itu dengan sihirku.
Dialogue: 0,0:09:35.47,0:09:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas.
Dialogue: 0,0:09:37.68,0:09:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memohon pada En
Dialogue: 0,0:09:40.06,0:09:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar kita diizinkan\Nmenggunakan sihir Kikurage.
Dialogue: 0,0:09:43.19,0:09:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen perihnya cuma sekarang saja.
Dialogue: 0,0:09:46.01,0:09:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kamu bangun,\Nkamu tak akan merasa sakit.
Dialogue: 0,0:10:00.98,0:10:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En malah membuat kacau lagi.
Dialogue: 0,0:10:04.00,0:10:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar merepotkan!
Dialogue: 0,0:10:20.46,0:10:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak boleh sembrono.
Dialogue: 0,0:10:22.52,0:10:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu merusak jamurnya,\Nitu sama saja seperti merusak kakimu.
Dialogue: 0,0:10:27.38,0:10:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kontrak kita belum sepenuhnya pulih,
Dialogue: 0,0:10:32.07,0:10:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku kagum kamu berhasil menyerangku.
Dialogue: 0,0:10:35.28,0:10:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pria itu sangat penting bagimu?
Dialogue: 0,0:10:37.70,0:10:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dia penting.\NDia satu-satunya temanku yang berharga!
Dialogue: 0,0:10:45.25,0:10:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada celah!
Dialogue: 0,0:10:52.17,0:10:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman?
Dialogue: 0,0:10:53.62,0:10:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, sakit sekali!
Dialogue: 0,0:10:56.55,0:11:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya dia menanam jamur di tubuhku!
Dialogue: 0,0:11:03.50,0:11:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:11:07.94,0:11:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati!
Dialogue: 0,0:11:11.94,0:11:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman!
Dialogue: 0,0:11:16.47,0:11:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu...
Dialogue: 0,0:11:26.94,0:11:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:11:31.57,0:11:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman...
Dialogue: 0,0:11:40.12,0:11:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau makan gioza.
Dialogue: 0,0:11:43.77,0:11:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan.
Dialogue: 0,0:11:51.09,0:11:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dibunuh orang lain, bukan olehku.
Dialogue: 0,0:12:09.36,0:12:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:12:11.07,0:12:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu wajah aslimu, ya?
Dialogue: 0,0:12:15.99,0:12:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akhirnya kembali normal.
Dialogue: 0,0:12:20.29,0:12:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingat janji kemarin?
Dialogue: 0,0:12:25.25,0:12:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kembali ke Hole bersama.
Dialogue: 0,0:12:30.05,0:12:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Caiman?
Dialogue: 0,0:12:35.01,0:12:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:12:37.05,0:12:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En menyuruh membawa mayat pria kadal itu,
Dialogue: 0,0:12:41.74,0:12:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bagaimana aku harus mencarinya?
Dialogue: 0,0:12:44.54,0:12:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman, jangan-jangan,\Nkamu benar-benar terbunuh?
Dialogue: 0,0:12:50.50,0:12:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Kasukabe!
Dialogue: 0,0:12:53.04,0:12:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini.
Dialogue: 0,0:12:55.80,0:12:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:12:57.01,0:12:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengejutkan!
Dialogue: 0,0:12:58.34,0:13:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu ada magma mengalir di sekitar sini.
Dialogue: 0,0:13:02.05,0:13:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:13:04.43,0:13:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Caiman?
Dialogue: 0,0:13:20.99,0:13:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En sepertinya tak mengikuti kita.
Dialogue: 0,0:13:23.16,0:13:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:13:24.31,0:13:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita mungkin harus\Ndi sini lebih lama.
Dialogue: 0,0:13:29.40,0:13:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Dokuga?
Dialogue: 0,0:13:32.48,0:13:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memikirkan Bos.
Dialogue: 0,0:13:37.74,0:13:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:13:39.34,0:13:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir-akhir ini, aku ingat banyak hal.\NAku belum cerita pada kalian.
Dialogue: 0,0:13:44.22,0:13:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos dan aku pernah pergi\Nke tempat ini, Bukit Kotoran,
Dialogue: 0,0:13:47.39,0:13:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat para penyihir elite berkumpul.
Dialogue: 0,0:13:50.77,0:13:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang menjalankan tempat itu\Nduduk di paling belakang.
Dialogue: 0,0:13:54.69,0:13:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bertatapan mata dengan Bos,\Ndia pingsan.
Dialogue: 0,0:13:58.98,0:14:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!\NKalau kalian curhat, aku juga punya.
Dialogue: 0,0:14:05.24,0:14:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu kali, bos kita yang rakus makanan\Nkasihan padaku dan memberiku hamburger!
Dialogue: 0,0:14:09.91,0:14:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena ekspresi mukamu\Nseolah belum makan berhari-hari.
Dialogue: 0,0:14:15.85,0:14:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga?
Dialogue: 0,0:14:17.24,0:14:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat hari pertama saat bertemu Bos.
Dialogue: 0,0:14:22.80,0:14:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih muda dan tak punya tujuan.\NHanya menjalani hidup hari demi hari.
Dialogue: 0,0:14:29.81,0:14:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merenung apa kita layak hidup\Nmeski tak bisa menggunakan sihir.
Dialogue: 0,0:14:34.65,0:14:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus mencuri makanan\Ndemi bertahan hidup.
Dialogue: 0,0:14:39.40,0:14:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar berandalan!
Dialogue: 0,0:14:41.40,0:14:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:14:44.78,0:14:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu meludah?
Dialogue: 0,0:14:45.99,0:14:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah sialan, akan kupotong mulutmu!
Dialogue: 0,0:14:49.28,0:14:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:14:51.33,0:14:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetsujo!
Dialogue: 0,0:14:52.50,0:14:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar para penyihir bodoh!\NApa yang kalian lakukan?
Dialogue: 0,0:14:55.50,0:15:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, sudah kuputuskan,\Naku mengeksekusi berandalan ini.
Dialogue: 0,0:15:00.45,0:15:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hole.\NAyo lempar mereka ke Hole.
Dialogue: 0,0:15:09.72,0:15:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga?
Dialogue: 0,0:15:10.60,0:15:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa sakit di tubuhku ini...
Dialogue: 0,0:15:13.60,0:15:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah penyihir dalam diriku\Nmenolak hujan Hole.
Dialogue: 0,0:15:19.19,0:15:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kita penyihir!
Dialogue: 0,0:15:21.61,0:15:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga.
Dialogue: 0,0:15:22.75,0:15:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, dia benar!
Dialogue: 0,0:15:27.07,0:15:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kenapa?
Dialogue: 0,0:15:34.86,0:15:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos membunuh penyihir itu\Ndan melewati pintu.
Dialogue: 0,0:15:40.07,0:15:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kita mengikutinya\Nseolah-olah ikut terisap.
Dialogue: 0,0:15:45.31,0:15:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,\Njumlah orang seperti kita bertambah
Dialogue: 0,0:15:49.54,0:15:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan organisasi tumbuh lebih besar.
Dialogue: 0,0:15:52.80,0:15:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Bos sekarang?
Dialogue: 0,0:15:55.67,0:15:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang, kamu di mana?
Dialogue: 0,0:15:58.06,0:16:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang, Nikaido!\NKalian di mana?
Dialogue: 0,0:16:21.42,0:16:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa di sana?
Dialogue: 0,0:16:33.89,0:16:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makhluk apaan?
Dialogue: 0,0:16:37.60,0:16:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu diriku?
Dialogue: 0,0:17:03.07,0:17:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa namamu?
Dialogue: 0,0:17:05.05,0:17:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki!
Dialogue: 0,0:17:07.33,0:17:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kemari ingin menemui Bos\Nbersama Caiman,
Dialogue: 0,0:17:10.88,0:17:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}abangku yang berwajah kadal.
Dialogue: 0,0:17:12.55,0:17:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman?\NTak pernah dengar tentang dia.
Dialogue: 0,0:17:14.89,0:17:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:17:16.84,0:17:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Abang tak tahu persembunyiannya\Ndan silang di matanya juga hilang.
Dialogue: 0,0:17:22.16,0:17:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin penipu.
Dialogue: 0,0:17:24.40,0:17:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dia Mata Silang palsu,\Naku masih cemas.
Dialogue: 0,0:17:30.40,0:17:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:17:31.57,0:17:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat itu!
Dialogue: 0,0:17:35.15,0:17:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Curse.
Dialogue: 0,0:17:37.37,0:17:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk paling jahat di dunia ini.
Dialogue: 0,0:17:40.94,0:17:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat aku.\NJangan sebut namaku.
Dialogue: 0,0:17:45.99,0:17:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Makhluk apaan kamu?
Dialogue: 0,0:17:48.82,0:17:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:17:50.05,0:17:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster!
Dialogue: 0,0:17:59.22,0:18:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetsujo!
Dialogue: 0,0:18:00.35,0:18:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ton, hentikan!
Dialogue: 0,0:18:06.15,0:18:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, jangan serang dia!
Dialogue: 0,0:18:08.32,0:18:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berpikir untuk membunuhnya.\NKita semua bisa mati!
Dialogue: 0,0:18:25.57,0:18:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Curse,\Nmakhluk yang merenggut segalanya.
Dialogue: 0,0:18:39.93,0:18:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali jadi penyihir\Ndan kekuatanku melemah.
Dialogue: 0,0:18:45.17,0:18:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana,\Naku hanya bisa membawanya bersamaku.
Dialogue: 0,0:18:49.40,0:18:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tak bernapas dan sangat dingin.
Dialogue: 0,0:19:16.37,0:19:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:19:17.47,0:19:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali.\NKamu pulang, ya.
Dialogue: 0,0:19:19.97,0:19:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sekarang baik-baik saja.
Dialogue: 0,0:19:22.64,0:19:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya aku tak perlu ingat\Nsiapa atau apa diriku.
Dialogue: 0,0:19:28.80,0:19:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:19:32.41,0:19:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, ayo minum.
Dialogue: 0,0:19:34.57,0:19:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan gioza juga!
Dialogue: 0,0:19:36.03,0:19:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku tahu.
Dialogue: 0,0:19:42.69,0:19:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido?
Dialogue: 0,0:19:47.15,0:19:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan bantu.
Dialogue: 0,0:19:51.95,0:19:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido?
Dialogue: 0,0:19:55.24,0:19:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.\NKenapa?
Dialogue: 0,0:19:59.51,0:20:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nika—
Dialogue: 0,0:20:02.50,0:20:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:21.41,0:21:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bermimpi buruk.
Dialogue: 0,0:21:24.91,0:21:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mimpi membunuh seseorang.
Dialogue: 0,0:21:27.64,0:21:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang yang berharga bagiku.
Dialogue: 0,0:21:32.31,0:21:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pernah terjadi.
Dialogue: 0,0:21:38.86,0:21:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang apa?
Dialogue: 0,0:21:41.28,0:21:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku?
Dialogue: 0,0:21:46.77,0:21:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:49.98,0:21:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin ini akan berguna.
Dialogue: 0,0:21:53.29,0:21:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, cepat!
Dialogue: 0,0:21:59.20,0:22:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NDia pergi?
Dialogue: 0,0:22:02.96,0:22:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia berubah\Nkarena tinggal di sini terlalu lama?
Dialogue: 0,0:22:09.39,0:22:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:22:10.31,0:22:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan sesuatu yang luar biasa!
Dialogue: 0,0:22:12.52,0:22:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Risu!\N- Aku belum bisa memastikannya.
Dialogue: 0,0:22:15.02,0:22:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:22:26.47,0:22:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memanipulasi waktu.
Dialogue: 0,0:22:34.90,0:22:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku mati seperti ini.
Dialogue: 0,0:24:16.98,0:24:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini di Episode 18.
Dialogue: 0,0:24:18.90,0:24:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman akhirnya bertemu\Nsisa anggota Mata Silang.
Dialogue: 0,0:24:21.65,0:24:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu gadis nakal.
Dialogue: 0,0:24:23.57,0:24:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos Mata Silang orangnya sangat hebat.
Dialogue: 0,0:24:25.61,0:24:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan kita ketahui di Episode 19,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:24:29.99,0:24:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
