Dialogue: 0,0:00:02.69,0:00:05.99,tanda,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:01:34.78,0:01:36.99,tanda,,0000,0000,0000,,AWAL
Dialogue: 0,0:01:36.99,0:01:39.66,tanda,,0000,0000,0000,,KUMBANG EMAS TAJIR MELINTIR
Dialogue: 0,0:07:11.99,0:07:13.41,tanda,,0000,0000,0000,,JAGAL IMUT
Dialogue: 0,0:10:27.40,0:10:28.73,tanda,,0000,0000,0000,,ZAGAN TIMUR\NTORSI
Dialogue: 0,0:11:12.32,0:11:15.32,tanda,,0000,0000,0000,,DAGING BARU SUDAH TIBA!
Dialogue: 0,0:12:07.25,0:12:09.75,tanda,,0000,0000,0000,,DIARI HATIKU
Dialogue: 0,0:12:37.66,0:12:39.28,tanda,,0000,0000,0000,,PINTU KE MASA LALU
Dialogue: 0,0:18:50.82,0:18:51.86,tanda,,0000,0000,0000,,KOTA KENYAMANAN\NBERITH
Dialogue: 0,0:19:36.74,0:19:39.74,tanda,,0000,0000,0000,,PERMANDIAN AIR PANAS BERITH
Dialogue: 0,0:19:51.88,0:19:53.88,tanda,,0000,0000,0000,,MANDI MAGMA
Dialogue: 0,0:23:29.64,0:23:30.97,tanda,,0000,0000,0000,,AKHIR
Dialogue: 0,0:01:44.53,0:01:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sampai.
Dialogue: 0,0:01:45.72,0:01:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempatnya.
Dialogue: 0,0:01:46.88,0:01:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gede!
Dialogue: 0,0:01:48.50,0:01:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jadi ini rumah Bu Kontrakan.
Dialogue: 0,0:01:52.51,0:01:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita akan membuat seolah-olah\NBu Kontrakan mati di dalam rumah.
Dialogue: 0,0:01:57.96,0:02:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bisa kacau kalau En tahu\Ndia mati di tempat kita.
Dialogue: 0,0:02:04.77,0:02:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saji, kamu sedang apa?
Dialogue: 0,0:02:06.77,0:02:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini tenggat setoran\Nsambilan menyulamku.
Dialogue: 0,0:02:13.92,0:02:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kamera pengawasnya!
Dialogue: 0,0:02:16.28,0:02:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar orang tajir!\NSialan!
Dialogue: 0,0:02:20.04,0:02:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, lihat itu!
Dialogue: 0,0:02:25.46,0:02:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu unit kendali utama sistem keamanan.
Dialogue: 0,0:02:27.42,0:02:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita bisa mengatasinya,\Nkameranya pasti mati.
Dialogue: 0,0:02:31.99,0:02:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ton.
Dialogue: 0,0:02:32.89,0:02:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:02:40.58,0:02:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarak ke target sekitar 35 meter, ya?
Dialogue: 0,0:02:47.11,0:02:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:03:03.23,0:03:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena!\NKamu memang hebat, dasar Babi!
Dialogue: 0,0:03:09.04,0:03:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat!
Dialogue: 0,0:03:11.55,0:03:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong masukkan asap.
Dialogue: 0,0:03:15.55,0:03:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia punya kunci asap.
Dialogue: 0,0:03:17.68,0:03:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintunya tak akan terbuka\Ntanpa asap sihir Bu Kontrakan.
Dialogue: 0,0:03:21.25,0:03:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini, Dokuga?\NKita tak bisa buang-buang waktu di sini.
Dialogue: 0,0:03:25.06,0:03:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:03:26.31,0:03:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini giliranku untuk bersinar!
Dialogue: 0,0:03:49.25,0:03:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kekuatan ototku?
Dialogue: 0,0:03:51.80,0:03:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:03:52.96,0:03:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak penting, ayo cepat masuk.
Dialogue: 0,0:03:56.30,0:03:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini gelap, aku tak bisa menyulam.
Dialogue: 0,0:03:59.01,0:04:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu untuk apa kamu ikut?
Dialogue: 0,0:04:01.47,0:04:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat!
Dialogue: 0,0:04:04.17,0:04:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beratnya pasti sekitar 400 kilogram!
Dialogue: 0,0:04:06.73,0:04:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luas, ya.\NIni pintu masuknya?
Dialogue: 0,0:04:09.40,0:04:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, ayo curi sesuatu sebelum pulang.
Dialogue: 0,0:04:12.73,0:04:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil tisu toilet.
Dialogue: 0,0:04:15.99,0:04:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat ini membuatku merasa bersalah.
Dialogue: 0,0:04:19.99,0:04:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus cepat memalsukan\Nkematian Bu Kontrakan.
Dialogue: 0,0:04:26.12,0:04:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyebab kematian paling umum\Ndi rumah itu di bak mandi.
Dialogue: 0,0:04:35.21,0:04:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suhu airnya bagus.
Dialogue: 0,0:04:37.26,0:04:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, sebentar lagi...\NSial!
Dialogue: 0,0:04:42.26,0:04:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:04:45.47,0:04:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat!
Dialogue: 0,0:04:53.74,0:04:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terlihat natural.
Dialogue: 0,0:04:59.61,0:05:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita ikat tali di lehernya\Ndan turunkan dari sini,
Dialogue: 0,0:05:02.31,0:05:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan terlihat seperti bunuh diri.
Dialogue: 0,0:05:05.79,0:05:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, kamu yang tulis?
Dialogue: 0,0:05:07.62,0:05:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:11.29,0:05:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan natural, kan?
Dialogue: 0,0:05:13.58,0:05:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, aku lempar, ya!
Dialogue: 0,0:05:16.09,0:05:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan.
Dialogue: 0,0:05:17.63,0:05:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu, wa...
Dialogue: 0,0:05:18.84,0:05:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, jadi siapa yang membunuh Risu?
Dialogue: 0,0:05:23.39,0:05:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia orang yang kita kenal?
Dialogue: 0,0:05:27.52,0:05:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat!
Dialogue: 0,0:05:29.18,0:05:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kamu juga gagal membunuh Risu.\NApa itu benar?
Dialogue: 0,0:05:34.92,0:05:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:05:36.57,0:05:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan konyol!\NSeharusnya kamu bisa, kan?
Dialogue: 0,0:05:46.66,0:05:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya...
Dialogue: 0,0:05:49.56,0:05:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya itu sihir Risu.
Dialogue: 0,0:05:53.50,0:05:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir Risu?
Dialogue: 0,0:05:58.75,0:06:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!
Dialogue: 0,0:06:05.01,0:06:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!
Dialogue: 0,0:06:15.56,0:06:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:06:22.36,0:06:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!
Dialogue: 0,0:06:28.77,0:06:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku tahu makhluk ini!\NIni serangga diet.
Dialogue: 0,0:06:32.83,0:06:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditaruh di perut, mereka akan\Nmenyerap apa pun yang kita makan.
Dialogue: 0,0:06:36.50,0:06:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangga itu keluar setelah\NBu Kontrakan mati, ya?
Dialogue: 0,0:06:39.15,0:06:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah...
Dialogue: 0,0:06:39.84,0:06:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang cukup terlihat natural.
Dialogue: 0,0:06:42.13,0:06:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di bagian mana?
Dialogue: 0,0:06:43.72,0:06:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!
Dialogue: 0,0:06:44.72,0:06:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ambil yang bisa diambil lalu lari.\N- Sadarlah!
Dialogue: 0,0:06:47.35,0:06:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya sulamanku selesai.
Dialogue: 0,0:06:50.54,0:06:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap saputangan ini\Nakan jadi milik wanita cantik.
Dialogue: 0,0:06:54.06,0:06:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat keluar!
Dialogue: 0,0:06:56.59,0:06:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, sulamannya indah!
Dialogue: 0,0:06:59.11,0:07:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para cewek pasti akan senang\Nkalau punya celana dalam imut seperti ini!
Dialogue: 0,0:07:06.56,0:07:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini toko tanpa nama dekat gerbang Neraka.
Dialogue: 0,0:07:19.86,0:07:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko macam apa ini?
Dialogue: 0,0:07:22.25,0:07:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini toko yang menjual daging.
Dialogue: 0,0:07:24.47,0:07:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak lihat pemilik tokonya.
Dialogue: 0,0:07:27.01,0:07:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu belum bisa melihatnya\Nkarena masih iblis level bawah.
Dialogue: 0,0:07:31.31,0:07:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, kamu bisa lihat bayangannya, kan?
Dialogue: 0,0:07:34.17,0:07:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan iblis ataupun penyihir
Dialogue: 0,0:07:36.89,0:07:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga tidak baik ataupun jahat.
Dialogue: 0,0:07:42.69,0:07:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong daging yang ini.
Dialogue: 0,0:07:48.41,0:07:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging apa ini?
Dialogue: 0,0:07:51.56,0:07:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging makhluk tertentu.
Dialogue: 0,0:07:53.45,0:07:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah memakannya,\Ntubuhmu akan mulai berubah menjadi Iblis.
Dialogue: 0,0:08:04.99,0:08:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tolong, ya.
Dialogue: 0,0:08:09.20,0:08:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu, kamu merahasiakan sesuatu\Ndari rekanmu sendiri, ya?
Dialogue: 0,0:08:15.06,0:08:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak bisa kumaafkan.
Dialogue: 0,0:08:18.37,0:08:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru menelepon Store untuk ke sini.\NKamu paham maksudnya, kan, Asu?
Dialogue: 0,0:08:41.57,0:08:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu gagal menjadi iblis, Asu.
Dialogue: 0,0:09:08.99,0:09:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, Store.\NLakukan.
Dialogue: 0,0:09:48.48,0:09:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, Store.\NAmbil.
Dialogue: 0,0:09:55.10,0:09:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu, kamu itu bodoh.
Dialogue: 0,0:09:59.44,0:10:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kamu bukan Asu lagi.\NKawajiri sang Penyihir, ya?
Dialogue: 0,0:10:06.38,0:10:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, Kawajiri.\NKamu bisa hidup sesukamu sebagai penyihir.
Dialogue: 0,0:10:16.08,0:10:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan iblisku memudar.
Dialogue: 0,0:10:20.60,0:10:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido...
Dialogue: 0,0:10:28.73,0:10:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat.
Dialogue: 0,0:10:30.15,0:10:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mau roti panggang isi keju\Ndan rebusan berkrim?
Dialogue: 0,0:10:35.74,0:10:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tiga!
Dialogue: 0,0:10:37.07,0:10:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:42.91,0:10:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu betulan makan pakai topengmu.
Dialogue: 0,0:10:45.96,0:10:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku yang bayar, Abang?
Dialogue: 0,0:10:54.01,0:10:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:10:54.95,0:10:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hebat!
Dialogue: 0,0:11:04.81,0:11:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mau rebusan krim?
Dialogue: 0,0:11:19.41,0:11:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam sebelumnya,\Naku mengubah Asu kembali jadi penyihir.
Dialogue: 0,0:11:26.29,0:11:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai topeng sendiri memang lebih nyaman.
Dialogue: 0,0:11:29.34,0:11:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, gawat!\NSudah malam.
Dialogue: 0,0:11:31.96,0:11:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus segera tidur.
Dialogue: 0,0:11:34.47,0:11:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku harus menyembunyikan topeng ini\Ndi tempat yang lebih sulit ditemukan.
Dialogue: 0,0:11:40.22,0:11:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di bawah laci\Nmudah ketahuan dan bahaya.
Dialogue: 0,0:11:44.27,0:11:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sembunyikan di dalam lemari saja?
Dialogue: 0,0:11:49.73,0:11:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Buku catatan?\NPunya Nikaido?
Dialogue: 0,0:11:54.47,0:11:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci asap, ya.
Dialogue: 0,0:11:57.74,0:11:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat isinya!
Dialogue: 0,0:11:59.49,0:12:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci seperti ini tak akan mempan\Ndengan sihirku!
Dialogue: 0,0:12:10.15,0:12:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Diari Hatiku".
Dialogue: 0,0:12:13.07,0:12:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si wanita sialan itu payah soal memberi nama!
Dialogue: 0,0:12:16.22,0:12:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat.
Dialogue: 0,0:12:17.72,0:12:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa kekuatan kontrak iblis\Nakan menghancurkanku.
Dialogue: 0,0:12:22.48,0:12:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, aku bisa lenyap.
Dialogue: 0,0:12:25.81,0:12:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, aku akan menulis\Ntentang sihirku di diari ini.
Dialogue: 0,0:12:31.84,0:12:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kontraknya mengendalikanku sepenuhnya,
Dialogue: 0,0:12:35.13,0:12:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak akan bisa menggunakan sihirku.
Dialogue: 0,0:12:42.06,0:12:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku besar di desa kecil jauh di pegunungan.
Dialogue: 0,0:12:45.33,0:12:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya orang tuaku meninggal\Nsaat aku masih bayi.
Dialogue: 0,0:12:49.12,0:12:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku senang.
Dialogue: 0,0:12:52.11,0:12:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya paman dan bibi yang baik.
Dialogue: 0,0:12:54.29,0:12:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga Kawajiri, yang peduli padaku\Nseperti abang kandungku sendiri.
Dialogue: 0,0:12:58.97,0:13:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap hari menyenangkan.
Dialogue: 0,0:13:01.66,0:13:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai Yakumo, sahabatku, menghilang.
Dialogue: 0,0:13:06.10,0:13:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kuat, aku ngantuk.
Dialogue: 0,0:13:08.31,0:13:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok lanjut baca.
Dialogue: 0,0:13:13.56,0:13:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin dengar pendapatmu soal produk baru
Dialogue: 0,0:13:16.32,0:13:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang akan dijual dengan merekku.
Dialogue: 0,0:13:18.40,0:13:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya: Boneka Jamur Model En.
Dialogue: 0,0:13:21.91,0:13:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jamur piaraan yang bisa dimakan\Nuntuk penggemarku.
Dialogue: 0,0:13:24.91,0:13:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hebat, En!
Dialogue: 0,0:13:27.41,0:13:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bereaksi terhadap kelembapan\Ndan aliran udara.
Dialogue: 0,0:13:30.54,0:13:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut!\NBeri aku satu!
Dialogue: 0,0:13:35.42,0:13:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebiasaan mereka menjadi parasit\Npada makhluk lain masih perlu diperbaiki.
Dialogue: 0,0:13:41.12,0:13:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Nikaido?\NAku ingin dengar pendapatmu.
Dialogue: 0,0:13:44.64,0:13:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NMenurutku ukurannya harus lebih besar.
Dialogue: 0,0:13:48.60,0:13:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukurannya sama denganmu.
Dialogue: 0,0:13:50.81,0:13:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendapat yang bagus, Nikaido!\NSetuju!
Dialogue: 0,0:13:53.56,0:13:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:13:54.73,0:13:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!\NLepaskan ini dariku!
Dialogue: 0,0:13:59.53,0:14:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Nikaido, kamu masih\Nbelum siap menggunakan sihir?
Dialogue: 0,0:14:04.20,0:14:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci bahas itu!
Dialogue: 0,0:14:05.95,0:14:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido, tunggu!\NAku tak berencana memaksamu.
Dialogue: 0,0:14:10.87,0:14:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido...
Dialogue: 0,0:14:14.79,0:14:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin kaget saja.
Dialogue: 0,0:14:16.59,0:14:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya pura-pura marah dan kabur\Ntak akan berhasil lagi.
Dialogue: 0,0:14:21.26,0:14:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai berkeringat.
Dialogue: 0,0:14:23.05,0:14:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mending mandi dan lanjut membaca diari itu.
Dialogue: 0,0:14:28.89,0:14:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat.
Dialogue: 0,0:14:31.39,0:14:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pertama menggunakan sihir\Nsaat berusia dua atau tiga tahun.
Dialogue: 0,0:14:39.40,0:14:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hebat, Nikaido.
Dialogue: 0,0:14:46.12,0:14:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:14:47.40,0:14:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permen?
Dialogue: 0,0:14:48.58,0:14:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mungkin tahu setelah kamu\Nbisa membuat lebih banyak asap.
Dialogue: 0,0:14:53.33,0:14:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melakukan yang terbaik!
Dialogue: 0,0:14:55.29,0:14:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:14:56.83,0:14:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawajiri, Nikaido!
Dialogue: 0,0:14:59.34,0:15:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakumo!
Dialogue: 0,0:15:01.09,0:15:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan sihir Yakumo itu\Nbisa terbang di langit.
Dialogue: 0,0:15:05.93,0:15:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masih bayi,
Dialogue: 0,0:15:07.72,0:15:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia berhasil diselamatkan\Nsaat terapung di sungai.
Dialogue: 0,0:15:11.10,0:15:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, dia sendiri bilang dia beruntung.
Dialogue: 0,0:15:16.80,0:15:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gadis yang tak kenal takut dan ceria.
Dialogue: 0,0:15:23.74,0:15:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu mayat anak-anak?
Dialogue: 0,0:15:25.73,0:15:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram!
Dialogue: 0,0:15:26.49,0:15:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada pemburu di dekat sini.\NAyo cepat pulang.
Dialogue: 0,0:15:31.24,0:15:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pemburu adalah kelompok\Nyang menculik anak-anak penyihir.
Dialogue: 0,0:15:36.48,0:15:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak anak-anak yang meninggal\Nkarena perkelahian antarpemburu.
Dialogue: 0,0:15:41.55,0:15:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Bang.
Dialogue: 0,0:15:43.38,0:15:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggalkan bocah itu di sini dan pergi.\NSalah satu bocah baru saja mati.
Dialogue: 0,0:15:47.34,0:15:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pemburu!
Dialogue: 0,0:15:48.39,0:15:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan! Rasakan ini!
Dialogue: 0,0:15:57.77,0:15:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Mereka menghilang!
Dialogue: 0,0:15:59.98,0:16:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang Kawajiri adalah penyihir yang bisa\Nberpindah ke mana pun dengan sihirnya.
Dialogue: 0,0:16:05.28,0:16:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga punya intuisi kuat\Ndan bisa pilih lokasi dengan bebas.
Dialogue: 0,0:16:09.91,0:16:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pulang, Bibi.
Dialogue: 0,0:16:12.41,0:16:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawajiri, jangan terlalu mengandalkan sihir\Nuntuk segala hal dan coba jalan kakilah.
Dialogue: 0,0:16:18.42,0:16:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.
Dialogue: 0,0:16:19.67,0:16:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baru kabur dari pemburu.
Dialogue: 0,0:16:21.71,0:16:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hari ini kita makan gioza!
Dialogue: 0,0:16:24.42,0:16:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gioza adalah masakan spesialis Bibi.
Dialogue: 0,0:16:28.17,0:16:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gioza itu apa?
Dialogue: 0,0:16:30.05,0:16:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak begitu tahu\Nsoal makanan rakyat jelata.
Dialogue: 0,0:16:35.25,0:16:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, saat aku berusia\Nsekitar empat tahun...
Dialogue: 0,0:16:41.25,0:16:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua sedang apa?
Dialogue: 0,0:16:42.69,0:16:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Kawajiri.\NAku baru melatih Nikaido.
Dialogue: 0,0:16:46.99,0:16:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sekarang bisa mematahkan papan
Dialogue: 0,0:16:49.66,0:16:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak berdarah?
Dialogue: 0,0:16:51.87,0:16:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berlebihan, Yakumo.
Dialogue: 0,0:16:53.58,0:16:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru dengan begitu,\Ntinjunya akan jadi lebih kuat.
Dialogue: 0,0:16:57.83,0:16:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:17:00.75,0:17:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:17:03.38,0:17:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari aku dapat ini\Ndari iblis yang memberiku kartu.
Dialogue: 0,0:17:07.05,0:17:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia membuatnya khusus untukku.
Dialogue: 0,0:17:09.08,0:17:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:17:11.54,0:17:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengundangku untuk menjadi Iblis.
Dialogue: 0,0:17:24.60,0:17:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan yang terbaik, Kawajiri.
Dialogue: 0,0:17:27.10,0:17:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zirahnya bagus sekali, ya.\NKamu baik-baik saja?
Dialogue: 0,0:17:30.36,0:17:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:31.47,0:17:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya hidup normal sambil memakai ini\Nadalah latihan pertamaku.
Dialogue: 0,0:17:36.41,0:17:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku pergi kerja dulu.
Dialogue: 0,0:17:39.58,0:17:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma kalau dia tidak jalan kaki.
Dialogue: 0,0:17:42.50,0:17:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu, aku menjaga rumah sendirian\Nuntuk kali pertama.
Dialogue: 0,0:17:46.71,0:17:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah selesai membantu melipat gioza,\Naku tiba-tiba senggang.
Dialogue: 0,0:17:54.13,0:17:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memutuskan menggunakan\Nsihir lagi setelah sekian lama
Dialogue: 0,0:17:58.31,0:18:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan mencoba menghasilkan asap.
Dialogue: 0,0:18:03.30,0:18:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kekuatan sihirku meningkat\Nseiring bertambahnya usia,
Dialogue: 0,0:18:06.65,0:18:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kubus itu\Nkira-kira setengah ukuranku.
Dialogue: 0,0:18:11.05,0:18:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kubus itu ada tombol dan tuas.
Dialogue: 0,0:18:14.03,0:18:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku coba menekan dan menariknya,\Ntak ada reaksi yang terjadi.
Dialogue: 0,0:18:19.56,0:18:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memutuskan untuk berlatih\Nagar bisa menguasai sihirku.
Dialogue: 0,0:18:28.53,0:18:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu itu awal\Ndari peristiwa yang menakutkan.
Dialogue: 0,0:18:33.43,0:18:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:18:34.48,0:18:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu En!
Dialogue: 0,0:18:35.43,0:18:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka pintunya, ini aku!
Dialogue: 0,0:18:37.43,0:18:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk minta maaf.\NAku juga bawa hadiah.
Dialogue: 0,0:18:40.68,0:18:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah mulai menarik.
Dialogue: 0,0:18:43.44,0:18:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keringkan rambutku dulu.
Dialogue: 0,0:18:45.94,0:18:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:49.69,0:18:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:51.86,0:18:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:52.69,0:18:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kamu memang tidak tahu\Npersembunyian Mata Silang?
Dialogue: 0,0:18:56.99,0:19:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, soalnya aku benar-benar\Ningin pergi dengan kalian.
Dialogue: 0,0:19:01.70,0:19:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau mencarinya pasti ketemu!
Dialogue: 0,0:19:04.96,0:19:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencarinya?
Dialogue: 0,0:19:07.17,0:19:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak punya informasi.
Dialogue: 0,0:19:09.50,0:19:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari mulai gelap.
Dialogue: 0,0:19:11.21,0:19:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita istirahat\Ndi suatu tempat malam ini.
Dialogue: 0,0:19:13.97,0:19:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari persembunyiannya besok saja.
Dialogue: 0,0:19:18.51,0:19:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak keberatan, Caiman?
Dialogue: 0,0:19:22.96,0:19:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:26.46,0:19:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:19:28.88,0:19:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa ada tempat sementara\Ndi daerah terpencil seperti ini?
Dialogue: 0,0:19:33.28,0:19:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NTempat itu cukup bagus, kan?
Dialogue: 0,0:19:39.74,0:19:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:19:42.24,0:19:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tiga pelanggan berkunjung!
Dialogue: 0,0:19:47.75,0:19:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasutri dan anaknya?
Dialogue: 0,0:19:53.88,0:19:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku boleh buka, Nikaido?\N- Duh, bagaimana ini?
Dialogue: 0,0:19:56.88,0:19:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nikaido!\N- Aku tiba-tiba kembali normal.
Dialogue: 0,0:20:01.89,0:20:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh! Hm?
Dialogue: 0,0:20:04.39,0:20:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Nikaido?\NKamu baik-baik saja?
Dialogue: 0,0:20:06.77,0:20:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... kontrak dari En yang ada\Ndi dalam tubuh Nikaido?
Dialogue: 0,0:20:15.03,0:20:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:20:17.81,0:20:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido, maaf soal yang tadi.
Dialogue: 0,0:20:20.70,0:20:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memaafkanmu.
Dialogue: 0,0:20:23.99,0:20:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chota, dasar burung sialan!\NApa maksudnya ini?
Dialogue: 0,0:20:27.54,0:20:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada alasannya!
Dialogue: 0,0:20:30.75,0:20:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:32.25,0:20:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido kabur dengan manusia kadal itu?
Dialogue: 0,0:20:35.38,0:20:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, Nikaido yang tadi di sini...
Dialogue: 0,0:20:37.67,0:20:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, itu aku.
Dialogue: 0,0:20:39.68,0:20:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubah jadi jamur sana!
Dialogue: 0,0:20:41.93,0:20:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:20:51.13,0:20:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ribut apa di wastu?
Dialogue: 0,0:20:53.44,0:20:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Ebisu pergi ke mana?
Dialogue: 0,0:20:57.82,0:21:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku baru gajian dari Bos Besar.
Dialogue: 0,0:21:00.99,0:21:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak banyak.
Dialogue: 0,0:21:04.49,0:21:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, dia bukan anggota resmi keluarga.
Dialogue: 0,0:21:08.96,0:21:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana,\Ndia akhirnya tinggal di sini.
Dialogue: 0,0:21:11.25,0:21:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang mungkin waktu yang tepat\Nuntuk mengusirnya.
Dialogue: 0,0:21:15.15,0:21:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu?
Dialogue: 0,0:21:18.47,0:21:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mau pergi ke mana?
Dialogue: 0,0:21:20.55,0:21:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa banyak barang begitu.
Dialogue: 0,0:21:23.51,0:21:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, mau keluar dari sini?
Dialogue: 0,0:21:29.10,0:21:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan dia pergi.\NDasar berhati dingin.
Dialogue: 0,0:21:33.98,0:21:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu!
Dialogue: 0,0:21:42.32,0:21:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau ke mana?
Dialogue: 0,0:21:44.91,0:21:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pulang.
Dialogue: 0,0:21:46.24,0:21:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang?\NIngatanmu sudah kembali?
Dialogue: 0,0:21:52.07,0:21:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah, Fujita.
Dialogue: 0,0:23:30.97,0:23:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini\Ndi Episode 4 Musim Kedua.
Dialogue: 0,0:23:33.14,0:23:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Store menjual daging makhluk tertentu.
Dialogue: 0,0:23:35.69,0:23:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki yang mentraktir.
Dialogue: 0,0:23:37.02,0:23:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En menemukan banyak hal.
Dialogue: 0,0:23:38.98,0:23:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan ketahui di Episode 4 Musim Kedua,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:23:42.86,0:23:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
