Dialogue: 0,0:00:02.69,0:00:05.99,sign,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:00:11.99,0:00:14.62,sign,,0000,0000,0000,,SI SIALAN MUJUR
Dialogue: 0,0:03:19.97,0:03:21.97,sign,,0000,0000,0000,,AWAL
Dialogue: 0,0:03:21.97,0:03:23.47,sign,,0000,0000,0000,,PEMBAYARAN
Dialogue: 0,0:04:33.50,0:04:35.55,sign,,0000,0000,0000,,LIMA HARI LALU
Dialogue: 0,0:10:43.46,0:10:45.96,sign,,0000,0000,0000,,SIHIR TINGKAT DASAR
Dialogue: 0,0:10:48.96,0:10:50.46,sign,,0000,0000,0000,,BANJIR PELANGGAN
Dialogue: 0,0:10:50.46,0:10:52.97,sign,,0000,0000,0000,,RESEPSIONIS
Dialogue: 0,0:13:08.18,0:13:11.19,sign,,0000,0000,0000,,APARTEMEN TACHIKAWA
Dialogue: 0,0:18:24.58,0:18:25.88,sign,,0000,0000,0000,,PERPUSTAKAAN, KANTIN
Dialogue: 0,0:22:20.28,0:22:21.53,sign,,0000,0000,0000,,SEDANG DIGUNAKAN
Dialogue: 0,0:24:19.73,0:24:20.98,sign,,0000,0000,0000,,AKHIR
Dialogue: 0,0:00:27.37,0:00:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:00:30.93,0:00:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut!
Dialogue: 0,0:00:32.61,0:00:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NKamu sendirian?
Dialogue: 0,0:00:47.18,0:00:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku...
Dialogue: 0,0:00:53.81,0:00:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini korannya!
Dialogue: 0,0:00:56.06,0:00:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat ini.
Dialogue: 0,0:00:57.90,0:01:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini hewan peliharaan En\Nyang konon bisa membangkitkan?
Dialogue: 0,0:01:02.38,0:01:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu... Chawantake?
Dialogue: 0,0:01:05.55,0:01:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Kikurage.
Dialogue: 0,0:01:06.88,0:01:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, kamu boleh pergi.
Dialogue: 0,0:01:09.01,0:01:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:01:11.05,0:01:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin banyak orang,\Nmakin cepat dapat informasi.
Dialogue: 0,0:01:13.89,0:01:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Organisasi kita makin tumbuh besar, ya.
Dialogue: 0,0:01:17.67,0:01:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sekarang pun,
Dialogue: 0,0:01:18.98,0:01:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para buruh kerja maksimal menato silang.
Dialogue: 0,0:01:23.31,0:01:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi kamu sedang apa, Natsuki?
Dialogue: 0,0:01:26.90,0:01:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir asap akan keluar.
Dialogue: 0,0:01:28.90,0:01:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ton, pergi ke hutan itu dan selidiki.
Dialogue: 0,0:01:32.78,0:01:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:01:34.55,0:01:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma Ton,\NKikurage akan takut dan kabur.
Dialogue: 0,0:01:39.27,0:01:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, kamu juga pergi.
Dialogue: 0,0:01:41.04,0:01:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku juga?
Dialogue: 0,0:01:42.54,0:01:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin bos ingin mendapatkan\Nsihir Kikurage juga.
Dialogue: 0,0:01:46.82,0:01:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cemas soal monster itu,\Ntapi aku percaya padamu.
Dialogue: 0,0:01:50.59,0:01:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:03:24.10,0:03:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan yang ini, ya?
Dialogue: 0,0:03:25.60,0:03:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di koran dia ada di dekat sungai.
Dialogue: 0,0:03:34.03,0:03:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, Natsuki?
Dialogue: 0,0:03:35.32,0:03:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begini...
Dialogue: 0,0:03:36.70,0:03:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal tes asap yang kamu lakukan\Nuntukku tempo hari.
Dialogue: 0,0:03:40.83,0:03:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:03:42.66,0:03:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak disangka,\Nhasil tesmu lumayan bagus, ya.
Dialogue: 0,0:03:45.75,0:03:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau penasaran, nanti akan kuperiksa\Ndetailnya setelah kita pulang.
Dialogue: 0,0:03:50.36,0:03:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:03:51.50,0:03:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lebih berguna bagi bos!
Dialogue: 0,0:03:55.05,0:03:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kuat sepertimu\Ndan yang lainnya juga!
Dialogue: 0,0:03:57.76,0:04:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sepertinya kamu tak bisa\Nbantu banyak, ya.
Dialogue: 0,0:04:00.93,0:04:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:07.56,0:04:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, dia terus melewati\Nsemua tempat sempit ini.
Dialogue: 0,0:04:12.27,0:04:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tadi ada orang lewat?
Dialogue: 0,0:04:15.22,0:04:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku melepuh.
Dialogue: 0,0:04:17.27,0:04:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengikuti Kikurage repot\Nkarena dia jalannya pelan.
Dialogue: 0,0:04:22.31,0:04:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah hari keempat.
Dialogue: 0,0:04:24.66,0:04:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumitku berdarah.
Dialogue: 0,0:04:27.48,0:04:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini demi membangkitkan Keluarga En!
Dialogue: 0,0:04:39.05,0:04:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NWastu En...
Dialogue: 0,0:04:41.72,0:04:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengambil alih wastu kita.
Dialogue: 0,0:04:45.54,0:04:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hanya mereka yang selamat?
Dialogue: 0,0:04:48.54,0:04:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar para pecundang.
Dialogue: 0,0:04:52.57,0:04:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:54.15,0:04:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bisa kabur dari wastu berkat sihirmu.
Dialogue: 0,0:04:58.32,0:05:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan karenamu,\Nkami semua pasti mati.
Dialogue: 0,0:05:03.95,0:05:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya, aku bisa\Nmenyelamatkan lebih banyak orang.
Dialogue: 0,0:05:07.41,0:05:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya...
Dialogue: 0,0:05:09.96,0:05:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantuanmu sudah lebih dari cukup.
Dialogue: 0,0:05:13.35,0:05:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turkey, siapa dia?
Dialogue: 0,0:05:15.71,0:05:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lupa padaku?
Dialogue: 0,0:05:19.09,0:05:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:05:20.51,0:05:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita, dasar tidak sopan.
Dialogue: 0,0:05:22.97,0:05:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah menjadi anggota\Nsejak Keluarga terbentuk.
Dialogue: 0,0:05:25.72,0:05:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya...
Dialogue: 0,0:05:28.25,0:05:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya... Siapa, ya?
Dialogue: 0,0:05:32.60,0:05:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup.
Dialogue: 0,0:05:37.01,0:05:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga menyelamatkan Shin dan Noi\Nsaat mereka akan dibunuh Mata Silang.
Dialogue: 0,0:05:42.74,0:05:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku mencuri sesuatu\Ndari musuh tanpa mereka sadari.
Dialogue: 0,0:05:47.75,0:05:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala En.
Dialogue: 0,0:05:50.59,0:05:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!\NKamu mendapatkannya kembali.
Dialogue: 0,0:05:53.50,0:05:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tumor iblis di kepalanya\Nsudah diangkat.
Dialogue: 0,0:05:59.93,0:06:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NBerarti, En sudah...
Dialogue: 0,0:06:03.38,0:06:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, masih ada harapan.
Dialogue: 0,0:06:06.37,0:06:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita terkena tumor iblis En\Ndari Mata Silang,
Dialogue: 0,0:06:09.64,0:06:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu minta Noi untuk memperbaiki tubuhnya
Dialogue: 0,0:06:12.35,0:06:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menggunakan sihir Kikurage...
Dialogue: 0,0:06:14.44,0:06:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu!
Dialogue: 0,0:06:16.51,0:06:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kikurage masih hilang.
Dialogue: 0,0:06:19.53,0:06:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:06:20.90,0:06:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti peranku dimulai lagi, ya?
Dialogue: 0,0:06:24.53,0:06:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:25.78,0:06:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita, untuk pencarian Kikurage,\Nbisa kuserahkan padamu?
Dialogue: 0,0:06:31.55,0:06:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan!
Dialogue: 0,0:06:33.58,0:06:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan\Nmenghidupkan kembali En!
Dialogue: 0,0:06:38.05,0:06:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:06:39.77,0:06:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini boneka Kikurage yang dibuat Turkey.
Dialogue: 0,0:06:43.67,0:06:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan dia terlalu lambat.
Dialogue: 0,0:06:46.26,0:06:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mual dan mau muntah.
Dialogue: 0,0:06:48.18,0:06:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu, kenapa kamu malah ikut?
Dialogue: 0,0:06:51.93,0:06:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini camilan untuk Kikurage.
Dialogue: 0,0:06:55.96,0:07:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, kamu lebih akrab\Ndengan Kikurage daripada aku, kan?
Dialogue: 0,0:07:00.65,0:07:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, begitu kita menemukan Kikurage,\Nkuserahkan dia padamu.
Dialogue: 0,0:07:06.78,0:07:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku lelah.\NSudah tidak kuat.
Dialogue: 0,0:07:14.94,0:07:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:07:16.46,0:07:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara Kikurage!\NAku yakin!
Dialogue: 0,0:07:19.21,0:07:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungi Sho dulu sekarang.
Dialogue: 0,0:07:21.71,0:07:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kikurage, semoga kamu baik-baik saja.\N- Bokongnya!
Dialogue: 0,0:07:27.33,0:07:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage.
Dialogue: 0,0:07:29.12,0:07:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu di sini lagi.
Dialogue: 0,0:07:33.71,0:07:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi, aku akan mati.
Dialogue: 0,0:07:37.98,0:07:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, En.
Dialogue: 0,0:07:40.36,0:07:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memercayakan Kikurage padaku,
Dialogue: 0,0:07:43.40,0:07:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tak bisa melindunginya\Nsampai akhir!
Dialogue: 0,0:07:48.57,0:07:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukannya!
Dialogue: 0,0:07:49.45,0:07:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Kikurage!
Dialogue: 0,0:07:50.53,0:07:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia di sana!
Dialogue: 0,0:07:52.12,0:07:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Mata Silang?\NLari, Kikurage! Lari!
Dialogue: 0,0:07:57.50,0:07:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur.
Dialogue: 0,0:08:01.25,0:08:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, berhasil ditangkap!
Dialogue: 0,0:08:03.50,0:08:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, lepaskan Kikurage!
Dialogue: 0,0:08:06.22,0:08:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kalian membunuh En-ku!\NAku akan membunuh kalian!
Dialogue: 0,0:08:09.72,0:08:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Chota, ya?
Dialogue: 0,0:08:12.29,0:08:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu ada di daftar petugas keluarga En.
Dialogue: 0,0:08:15.22,0:08:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian, aku akan penggal kepalamu juga.
Dialogue: 0,0:08:18.85,0:08:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:08:20.23,0:08:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas.
Dialogue: 0,0:08:21.48,0:08:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan kubunuh dengan sekali serang\Nagar tak menderita.
Dialogue: 0,0:08:24.53,0:08:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ton!
Dialogue: 0,0:08:25.61,0:08:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!\NKikurage-nya ada dua.
Dialogue: 0,0:08:28.61,0:08:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:32.99,0:08:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka\Nkita akan bertemu Mata Silang...
Dialogue: 0,0:08:36.37,0:08:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:08:37.37,0:08:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus begini,\Nmereka berdua akan terbunuh.
Dialogue: 0,0:08:40.00,0:08:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tak yakin\Nkami bisa mengalahkan mereka.
Dialogue: 0,0:08:50.80,0:08:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu?
Dialogue: 0,0:08:58.27,0:08:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:09:06.32,0:09:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mo-Monster?
Dialogue: 0,0:09:08.07,0:09:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki!
Dialogue: 0,0:09:16.54,0:09:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dari Keluarga En?
Dialogue: 0,0:09:22.37,0:09:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chota, kamu baik-baik saja?
Dialogue: 0,0:09:24.50,0:09:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita!
Dialogue: 0,0:09:26.32,0:09:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu...\NApa itu?
Dialogue: 0,0:09:28.63,0:09:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jepit rambut iblis yang ada\Ndi dalam kepala Ebisu
Dialogue: 0,0:09:32.72,0:09:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan emosinya tergerak\Nkarena Kikurage ketakutan.
Dialogue: 0,0:09:35.14,0:09:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti semacam efek pada sihirnya!
Dialogue: 0,0:09:50.07,0:09:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:10:02.79,0:10:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir Ebisu tak mempan?
Dialogue: 0,0:10:04.92,0:10:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... sihir tipe pertahanan.
Dialogue: 0,0:10:07.74,0:10:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata di Mata Silang\Nada yang bisa sihir semacam itu.
Dialogue: 0,0:10:12.68,0:10:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, dia tak akan sempat!
Dialogue: 0,0:10:14.51,0:10:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu!
Dialogue: 0,0:10:16.05,0:10:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita, kalian semua baik-baik saja?
Dialogue: 0,0:10:23.44,0:10:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Kikurage yang ini palsu.
Dialogue: 0,0:10:26.77,0:10:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Natsuki membuatku terkejut.
Dialogue: 0,0:10:30.36,0:10:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukanya jadi celah jalur asapnya.
Dialogue: 0,0:10:34.32,0:10:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kamu akan berguna\Nbagi bos dengan sihir ini.
Dialogue: 0,0:10:38.70,0:10:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki.
Dialogue: 0,0:10:54.99,0:10:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:11:36.38,0:11:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:11:40.68,0:11:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:11:43.17,0:11:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu, kan?
Dialogue: 0,0:11:48.44,0:11:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam, berisik!\NAku tak bisa berbuat apa-apa!
Dialogue: 0,0:11:53.57,0:11:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak berencana untuk melawan balik!
Dialogue: 0,0:12:11.21,0:12:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:12:15.34,0:12:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa.
Dialogue: 0,0:12:17.55,0:12:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa.
Dialogue: 0,0:12:21.37,0:12:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?\NKamu seperti tersiksa saat tidur.
Dialogue: 0,0:12:24.93,0:12:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:26.56,0:12:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga bisa mimpi buruk, ya?
Dialogue: 0,0:12:36.26,0:12:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Risu?\NTubuhmu sudah baikan?
Dialogue: 0,0:12:39.53,0:12:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sekarang mulai baikan.
Dialogue: 0,0:12:42.35,0:12:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkanmu dua hari penuh.
Dialogue: 0,0:12:46.29,0:12:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:12:47.58,0:12:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu.\NNanti aku ke sini lagi.
Dialogue: 0,0:12:50.61,0:12:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa.
Dialogue: 0,0:12:52.78,0:12:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu satu-satunya\Nyang sangat peduli padaku.
Dialogue: 0,0:12:57.42,0:12:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:59.41,0:13:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajar, kita kan partner!\NAku pergi dulu.
Dialogue: 0,0:13:03.74,0:13:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kamu banyak istirahat.
Dialogue: 0,0:13:13.27,0:13:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat yang ada dalam mimpiku tadi...
Dialogue: 0,0:13:16.28,0:13:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pria yang menyalakan rokok itu?
Dialogue: 0,0:13:22.31,0:13:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.\NAku tak mau memikirkan apa pun.
Dialogue: 0,0:13:27.35,0:13:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin menjalani\Nkehidupan normal sebagai penyihir.
Dialogue: 0,0:13:33.28,0:13:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu yang kuinginkan.
Dialogue: 0,0:13:36.53,0:13:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sebaiknya aku tak bertemu Risu lagi.
Dialogue: 0,0:13:42.12,0:13:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit kepala lagi.
Dialogue: 0,0:13:44.09,0:13:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial... Sial.
Dialogue: 0,0:13:47.04,0:13:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:13:57.30,0:13:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambah losionnya sedikit lagi, Hayes.
Dialogue: 0,0:13:59.57,0:14:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:14:01.51,0:14:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haru, memangnya ini ada efeknya?\NKamu kan iblis.
Dialogue: 0,0:14:05.62,0:14:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar nyaman saja.
Dialogue: 0,0:14:12.65,0:14:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:14:17.13,0:14:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hayes, dari tadi aku kepikiran,\Npenampilanmu itu bukan seleraku.
Dialogue: 0,0:14:22.88,0:14:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:23.76,0:14:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita malah terlihat seperti ibu dan anak.
Dialogue: 0,0:14:26.76,0:14:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan iblis!
Dialogue: 0,0:14:31.85,0:14:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:32.77,0:14:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membuat sosokku dewasa dalam sekejap!
Dialogue: 0,0:14:36.28,0:14:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sampai ada kacamatanya.
Dialogue: 0,0:14:39.11,0:14:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang kamu lakukan,\Nmenghancurkan pekerjaanku sebagai ilmuwan.
Dialogue: 0,0:14:46.32,0:14:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Hayes?
Dialogue: 0,0:14:49.70,0:14:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggallah bersamaku di Neraka.
Dialogue: 0,0:14:52.96,0:14:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lebih baik daripada ada\Ndi Hole sampah itu, kan?
Dialogue: 0,0:14:57.95,0:15:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihan antara Neraka dan Hole, ya?
Dialogue: 0,0:15:01.20,0:15:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keputusan sulit.
Dialogue: 0,0:15:03.84,0:15:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu milikku!\NPatuhi perintahku, Manusia!
Dialogue: 0,0:15:08.35,0:15:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan tiba-tiba mengubah penampilanmu!\N- Gawat, aku nyaris mati.
Dialogue: 0,0:15:13.60,0:15:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang sudah kubilang,\Naku sedang mencari Ai.
Dialogue: 0,0:15:18.86,0:15:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia penting bagimu?
Dialogue: 0,0:15:22.19,0:15:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja penting.
Dialogue: 0,0:15:24.07,0:15:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengubah manusia menjadi penyihir\Ndengan sains
Dialogue: 0,0:15:29.62,0:15:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu sangat penting bagi penelitianku.
Dialogue: 0,0:15:32.12,0:15:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan bantu mencarinya.
Dialogue: 0,0:15:35.58,0:15:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Haru!
Dialogue: 0,0:15:37.33,0:15:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, bisa ubah tubuhku kembali?
Dialogue: 0,0:15:40.71,0:15:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya malah tidak terbiasa.
Dialogue: 0,0:15:42.63,0:15:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:48.14,0:15:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paket untukmu.
Dialogue: 0,0:15:49.49,0:15:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:51.39,0:15:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah tiba dengan selamat.
Dialogue: 0,0:15:53.64,0:15:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang...
Dialogue: 0,0:16:05.61,0:16:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengejutkan.
Dialogue: 0,0:16:07.07,0:16:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zirah ini dua kali lebih berat\Ndari yang biasa dipakai di ujian iblis,
Dialogue: 0,0:16:11.17,0:16:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi masih berfungsi tanpa masalah.
Dialogue: 0,0:16:18.08,0:16:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, bilas!
Dialogue: 0,0:16:19.88,0:16:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:16:21.50,0:16:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan sekarang?
Dialogue: 0,0:16:27.78,0:16:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, silakan nikmati hidangan\Ndaging iblis spesialku hari ini!
Dialogue: 0,0:16:32.35,0:16:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini daging iblis lagi?
Dialogue: 0,0:16:34.77,0:16:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga bagian dari latihan.
Dialogue: 0,0:16:37.48,0:16:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging ini, jangan-jangan...
Dialogue: 0,0:16:40.48,0:16:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuknya jelek, tapi rasanya enak.
Dialogue: 0,0:16:45.05,0:16:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu, yang kulakukan ini\Npelatihan untuk ujian iblis?
Dialogue: 0,0:16:51.24,0:16:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak berniat menjadi iblis.
Dialogue: 0,0:16:54.49,0:16:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kecil dulu, kamu gagal pakai sihir,
Dialogue: 0,0:16:59.54,0:17:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi menurutku sebaiknya\Nkamu latihan membuat asap dulu.
Dialogue: 0,0:17:04.21,0:17:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelatihan untuk ujian iblis\Nkebetulan cocok untuk itu.
Dialogue: 0,0:17:08.58,0:17:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:17:10.82,0:17:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, coba hasilkan\Nasap sebanyak yang kamu bisa.
Dialogue: 0,0:17:15.09,0:17:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:24.60,0:17:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut.
Dialogue: 0,0:17:26.55,0:17:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kamu gagal saat kecil
Dialogue: 0,0:17:29.61,0:17:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena tak menghasilkan cukup asap.
Dialogue: 0,0:17:32.57,0:17:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu...
Dialogue: 0,0:17:37.81,0:17:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:51.47,0:17:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap fokus!
Dialogue: 0,0:17:53.14,0:17:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus hasilkan asap!
Dialogue: 0,0:18:02.67,0:18:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk kubusnya berubah!
Dialogue: 0,0:18:06.98,0:18:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido, buat lebih banyak asap!\NAku yakin kubusnya akan terus berubah!
Dialogue: 0,0:18:13.07,0:18:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tak sanggup...
Dialogue: 0,0:18:20.83,0:18:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:18:25.88,0:18:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti, Aikawa!
Dialogue: 0,0:18:29.42,0:18:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:18:32.89,0:18:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan bahan makan siang sekolah,\Ndasar sialan!
Dialogue: 0,0:18:36.01,0:18:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku terpojok.
Dialogue: 0,0:18:38.85,0:18:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mendekat,\Naku bisa jatuh dari sini dan mati!
Dialogue: 0,0:18:42.60,0:18:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu bagus!
Dialogue: 0,0:18:44.52,0:18:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati saja!
Dialogue: 0,0:18:45.85,0:18:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan otakmu ke tanah.
Dialogue: 0,0:18:48.11,0:18:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejam!
Dialogue: 0,0:18:50.11,0:18:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:18:50.98,0:18:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa?
Dialogue: 0,0:18:52.19,0:18:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda!
Dialogue: 0,0:18:54.45,0:18:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:18:56.87,0:18:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti!
Dialogue: 0,0:19:08.88,0:19:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia datang ke sekolah,\Nmakan, main, lalu tidur.
Dialogue: 0,0:19:13.55,0:19:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Aikawa yang sama.
Dialogue: 0,0:19:17.16,0:19:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir dia tak akan membocorkan\Nsihirku begitu saja,
Dialogue: 0,0:19:21.64,0:19:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlebih pada orang luar dari Mata Silang.
Dialogue: 0,0:19:25.98,0:19:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Risu!
Dialogue: 0,0:19:28.23,0:19:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Diam!\N- Lama tak jumpa!
Dialogue: 0,0:19:30.44,0:19:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu?
Dialogue: 0,0:19:35.01,0:19:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau datang ke sekolah, harusnya bilang.
Dialogue: 0,0:19:42.01,0:19:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu penuh misteri.
Dialogue: 0,0:19:47.05,0:19:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misteri?\NSeperti apa?
Dialogue: 0,0:19:49.55,0:19:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti tempat tinggalmu atau tempat kamu\Nmenghasilkan uang untuk makan.
Dialogue: 0,0:19:55.42,0:19:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:19:58.47,0:20:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bahkan belum memberitahuku\Njenis sihirmu!
Dialogue: 0,0:20:02.68,0:20:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tak menyembunyikan\Napa pun darimu.
Dialogue: 0,0:20:06.02,0:20:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu, sudah kubilang,\Naku hanya bisa menghasilkan sedikit asap.
Dialogue: 0,0:20:10.69,0:20:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pura-pura tak tahu!
Dialogue: 0,0:20:12.44,0:20:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu satu-satunya orang\Nyang kuceritakan soal sihirku.
Dialogue: 0,0:20:15.78,0:20:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memberi tahu seseorang\Ntentang sihirku dan aku mati karena itu!
Dialogue: 0,0:20:21.20,0:20:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, Risu.\NDengar, aku...
Dialogue: 0,0:20:23.95,0:20:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku percaya\Napa pun yang kamu katakan!
Dialogue: 0,0:20:28.16,0:20:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuat Mata Silang\Nmengatakan yang sebenarnya!
Dialogue: 0,0:20:32.21,0:20:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya kekuatan untuk itu sekarang!
Dialogue: 0,0:20:34.38,0:20:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu!\NOi, tunggu!
Dialogue: 0,0:20:37.95,0:20:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, dia pergi ke wastu En?
Dialogue: 0,0:20:47.48,0:20:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu memaksakan diri.
Dialogue: 0,0:20:49.73,0:20:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NTapi, aku kaget.
Dialogue: 0,0:20:52.23,0:20:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kubus itu akan berubah.
Dialogue: 0,0:20:55.13,0:21:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa yang harus kulakukan\Nuntuk menguasai sihirku?
Dialogue: 0,0:21:03.24,0:21:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah baca kasus\Nyang mirip dengan sihirmu di buku.
Dialogue: 0,0:21:08.88,0:21:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu sudah lama sekali.
Dialogue: 0,0:21:11.76,0:21:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja aku bisa baca buku itu lagi.
Dialogue: 0,0:21:16.42,0:21:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana buku itu sekarang?
Dialogue: 0,0:21:18.26,0:21:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu buku yang ditulis dalam bahasa iblis.
Dialogue: 0,0:21:20.72,0:21:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En harusnya satu-satunya penyihir\Nyang memilikinya.
Dialogue: 0,0:21:24.14,0:21:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wastu En, ya?
Dialogue: 0,0:21:26.29,0:21:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo pergi!
Dialogue: 0,0:21:29.29,0:21:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, Mata Silang menempati wastu.
Dialogue: 0,0:21:32.92,0:21:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan berbahaya.
Dialogue: 0,0:21:34.52,0:21:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, ada peluang besar\Nkamu dianggap rekannya En.
Dialogue: 0,0:21:40.72,0:21:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mencari buku kecil itu,\Nkita harus menyamar.
Dialogue: 0,0:21:46.16,0:21:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyamar?
Dialogue: 0,0:21:47.41,0:21:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, gunakan ini.
Dialogue: 0,0:21:51.40,0:21:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah lepas zirah itu,
Dialogue: 0,0:21:52.79,0:21:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atur botol di mesin di ruangan ini,\Ndan tarik tuasnya.
Dialogue: 0,0:21:56.96,0:21:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:21:58.99,0:22:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, bisa lepas zirah ini.
Dialogue: 0,0:22:04.28,0:22:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju ganti setelah berubah di dalam?
Dialogue: 0,0:22:07.56,0:22:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tak pakai baju layak.
Dialogue: 0,0:22:11.67,0:22:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat...
Dialogue: 0,0:22:14.27,0:22:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atur botolnya di sini dan di sini,
Dialogue: 0,0:22:17.77,0:22:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu tarik tuasnya.
Dialogue: 0,0:24:20.98,0:24:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini di Episode 22.
Dialogue: 0,0:24:23.36,0:24:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sho menyelamatkan Keluarga En.
Dialogue: 0,0:24:25.36,0:24:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir Natsuki mementalkan semuanya.
Dialogue: 0,0:24:27.57,0:24:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir Nikaido belum berkembang.
Dialogue: 0,0:24:29.49,0:24:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan kita ketahui di Episode 23,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:24:33.58,0:24:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
