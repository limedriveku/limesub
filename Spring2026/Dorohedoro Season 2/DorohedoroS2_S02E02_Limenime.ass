Dialogue: 0,0:00:02.15,0:00:05.99,tanda,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:00:07.61,0:00:11.12,tanda,,0000,0000,0000,,KEHARMONISAN PASUTRI
Dialogue: 0,0:02:21.04,0:02:23.00,tanda,,0000,0000,0000,,AWAL
Dialogue: 0,0:09:16.87,0:09:17.50,tanda,,0000,0000,0000,,NERAKA
Dialogue: 0,0:10:12.68,0:10:13.58,tanda,,0000,0000,0000,,STASIUN MASTEMA
Dialogue: 0,0:10:26.40,0:10:28.32,tanda,,0000,0000,0000,,PASAR BAWAH TANAH MASTEMA
Dialogue: 0,0:12:15.34,0:12:16.26,tanda,,0000,0000,0000,,PEGADAIAN
Dialogue: 0,0:17:49.30,0:17:53.51,tanda,,0000,0000,0000,,KISAH SEDIH MATA SILANG
Dialogue: 0,0:22:56.19,0:22:57.90,tanda,,0000,0000,0000,,BERITH TIMUR
Dialogue: 0,0:23:11.29,0:23:12.20,tanda,,0000,0000,0000,,SIHIR ZAGAN
Dialogue: 0,0:25:40.64,0:25:41.98,tanda,,0000,0000,0000,,AKHIR
Dialogue: 0,0:00:18.61,0:00:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga.
Dialogue: 0,0:00:19.87,0:00:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetsujo, Risu sedang apa?
Dialogue: 0,0:00:22.88,0:00:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang tidur.
Dialogue: 0,0:00:25.66,0:00:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:00:29.16,0:00:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, kamu tahu, kan?
Dialogue: 0,0:00:32.50,0:00:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang membunuh Risu?
Dialogue: 0,0:00:35.25,0:00:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:36.79,0:00:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihatnya mati\Ndengan kedua mataku sendiri.
Dialogue: 0,0:00:40.00,0:00:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa... yang melakukannya?
Dialogue: 0,0:00:49.15,0:00:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini surat origami pesawat dari Kento.
Dialogue: 0,0:02:25.75,0:02:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, kami buatkan minuman favoritmu.\NSilakan dicicipi.
Dialogue: 0,0:02:31.13,0:02:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat beberapa bagian\Nyang bagus hari ini.
Dialogue: 0,0:02:38.26,0:02:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubuk hitam sudah habis\Ndan organisasi kita melemah.
Dialogue: 0,0:02:43.27,0:02:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, kita bisa manfaatkan wanita ini.
Dialogue: 0,0:02:49.72,0:02:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya enak.
Dialogue: 0,0:02:52.93,0:02:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ravioli!
Dialogue: 0,0:02:55.57,0:02:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:02:56.53,0:02:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:03:04.08,0:03:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih!
Dialogue: 0,0:03:05.04,0:03:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris saja.
Dialogue: 0,0:03:07.92,0:03:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!\NDari mana kamu dapat topeng itu?
Dialogue: 0,0:03:11.84,0:03:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kamu lihat,\Nini topeng partnermu.
Dialogue: 0,0:03:14.92,0:03:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan menyanderamu,\Nmembunuhnya jadi sangat mudah.
Dialogue: 0,0:03:19.01,0:03:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin... Senior terbunuh?
Dialogue: 0,0:03:29.61,0:03:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membunuhmu!
Dialogue: 0,0:03:50.84,0:03:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos...
Dialogue: 0,0:03:51.88,0:03:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:03:52.88,0:03:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku...
Dialogue: 0,0:03:57.18,0:03:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau mati...
Dialogue: 0,0:04:03.26,0:04:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong...
Dialogue: 0,0:04:13.44,0:04:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noi tidak ada di sini.
Dialogue: 0,0:04:18.36,0:04:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin!
Dialogue: 0,0:04:20.36,0:04:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu sangat dingin.
Dialogue: 0,0:04:22.74,0:04:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menemukan Noi.
Dialogue: 0,0:04:25.62,0:04:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu sudah tidak sanggup!
Dialogue: 0,0:04:30.08,0:04:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin!
Dialogue: 0,0:04:35.09,0:04:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noi!\NKamu baik-baik saja?
Dialogue: 0,0:05:14.75,0:05:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergerakanmu terlalu lambat, makhluk aneh!
Dialogue: 0,0:05:17.67,0:05:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:05:21.43,0:05:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir raksasa?
Dialogue: 0,0:05:31.56,0:05:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noi!
Dialogue: 0,0:05:33.06,0:05:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, kamu masih hidup.
Dialogue: 0,0:05:36.09,0:05:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, kamu sedang apa diam di situ?
Dialogue: 0,0:05:43.87,0:05:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... patung lilin.
Dialogue: 0,0:05:52.16,0:05:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe! Kamu sedang apa?
Dialogue: 0,0:05:54.16,0:05:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:54.92,0:05:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah ini akan runtuh!\NKita harus kabur!
Dialogue: 0,0:06:12.06,0:06:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, kembalilah...
Dialogue: 0,0:06:20.36,0:06:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe.
Dialogue: 0,0:06:24.36,0:06:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe...
Dialogue: 0,0:06:28.73,0:06:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:06:35.04,0:06:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah patung ini...
Dialogue: 0,0:06:37.36,0:06:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip seperti wajah dia.
Dialogue: 0,0:06:41.03,0:06:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa?
Dialogue: 0,0:06:49.58,0:06:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hayes.
Dialogue: 0,0:06:51.64,0:06:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hayes.
Dialogue: 0,0:06:52.98,0:06:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun, Hayes.
Dialogue: 0,0:06:55.06,0:06:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?\NNama itu sudah lama hilang.
Dialogue: 0,0:06:59.88,0:07:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hayes.
Dialogue: 0,0:07:00.68,0:07:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haru?
Dialogue: 0,0:07:01.98,0:07:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hayes.
Dialogue: 0,0:07:03.93,0:07:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa, Hayes.
Dialogue: 0,0:07:06.07,0:07:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku tak mengenalimu\Nkarena tubuhmu seperti ini.
Dialogue: 0,0:07:09.74,0:07:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tak membangunkan suamiku.
Dialogue: 0,0:07:12.37,0:07:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:14.65,0:07:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat terbang, aku mencium aroma nostalgia.
Dialogue: 0,0:07:18.28,0:07:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu masih\Nmenulis buku atas namaku, ya?
Dialogue: 0,0:07:23.01,0:07:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Kasukabe.
Dialogue: 0,0:07:25.01,0:07:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haru, kamu...
Dialogue: 0,0:07:27.01,0:07:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku menjadi iblis.
Dialogue: 0,0:07:30.51,0:07:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melepaskan mimpi lamaku,\Njadi aku mengikuti ujian iblis.
Dialogue: 0,0:07:36.00,0:07:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa kembali ke Hole\Ndan sudah melakukan hal jahat padamu.
Dialogue: 0,0:07:42.69,0:07:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NAku senang kamu masih hidup.
Dialogue: 0,0:07:46.32,0:07:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini milikmu, kan?
Dialogue: 0,0:07:52.81,0:07:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Hayes.
Dialogue: 0,0:08:00.86,0:08:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah...\NWah, semuanya terbakar!
Dialogue: 0,0:08:04.17,0:08:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja panas.
Dialogue: 0,0:08:06.09,0:08:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oi, semuanya!\N- Hah?
Dialogue: 0,0:08:08.18,0:08:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baik-baik saja?
Dialogue: 0,0:08:09.76,0:08:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dok?
Dialogue: 0,0:08:12.12,0:08:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Itu Shin dan partnernya.
Dialogue: 0,0:08:14.68,0:08:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka datang untuk menyelamatkan kita?
Dialogue: 0,0:08:17.94,0:08:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas.\NMereka berdua masih hidup.
Dialogue: 0,0:08:21.11,0:08:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, kamu tak bertemu istrimu, ya.
Dialogue: 0,0:08:25.28,0:08:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku sudah menemuinya.
Dialogue: 0,0:08:38.33,0:08:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dari kapan\Nkamu tahu tentang Nikaido?
Dialogue: 0,0:08:50.09,0:08:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa memilih menyembunyikan penyihir\Nyang bisa memanipulasi waktu?
Dialogue: 0,0:08:55.10,0:08:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab aku, Asu.
Dialogue: 0,0:09:05.95,0:09:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang terlahir alami sepertimu\Ntak akan bisa paham, Chidaruma.
Dialogue: 0,0:09:12.53,0:09:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:09:26.36,0:09:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat macam apa ini?\NTak ada siapa pun.
Dialogue: 0,0:09:30.88,0:09:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyuruh kita ke tempat seperti ini,\Ndasar iblis muka babi sialan!
Dialogue: 0,0:09:34.76,0:09:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman, kurasa Asu sengaja\Nmemilih daerah sepi.
Dialogue: 0,0:09:39.27,0:09:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa gawat kalau En menemukan kita, kan?
Dialogue: 0,0:09:41.23,0:09:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir tak mempan padaku!
Dialogue: 0,0:09:43.90,0:09:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak takut pada En!
Dialogue: 0,0:09:46.34,0:09:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu bilang kalau bertemu En sekarang,\Naku akan jadi partnernya lagi.
Dialogue: 0,0:09:54.53,0:09:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau kamu jadi musuhku lagi.
Dialogue: 0,0:09:58.12,0:09:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau belum cukup,
Dialogue: 0,0:09:59.16,0:10:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bedebah berwajah hati itu juga menyebalkan.
Dialogue: 0,0:10:03.03,0:10:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu, apa kamu baik-baik saja?
Dialogue: 0,0:10:07.57,0:10:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:10:08.88,0:10:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... pintu masuk kereta bawah tanah?
Dialogue: 0,0:10:13.58,0:10:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mastema?
Dialogue: 0,0:10:16.13,0:10:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kota tempat En melawan\Nbos Mata Silang enam tahun lalu.
Dialogue: 0,0:10:26.40,0:10:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasar Bawah Tanah!
Dialogue: 0,0:10:31.40,0:10:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini mirip Hole, ya.
Dialogue: 0,0:10:34.91,0:10:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mungkin bisa beli baju dan pisau.
Dialogue: 0,0:10:37.41,0:10:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita tak punya uang,\Nmungkin harus merampok lagi.
Dialogue: 0,0:10:40.79,0:10:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mencopet.
Dialogue: 0,0:10:43.77,0:10:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:10:44.40,0:10:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:10:45.12,0:10:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap waspada.\NAda yang membuntuti kita.
Dialogue: 0,0:10:48.63,0:10:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:57.66,0:10:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh?
Dialogue: 0,0:10:59.43,0:11:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ke mana?
Dialogue: 0,0:11:03.39,0:11:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?\NKenapa mengikuti kami?
Dialogue: 0,0:11:06.90,0:11:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu, aku rekan kalian!
Dialogue: 0,0:11:09.90,0:11:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan?
Dialogue: 0,0:11:11.82,0:11:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:11:13.39,0:11:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan dia.
Dialogue: 0,0:11:15.93,0:11:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:11:17.53,0:11:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kasar, ya.\NAduh!
Dialogue: 0,0:11:20.08,0:11:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:11:21.79,0:11:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga punya lambang seperti ini, kan?
Dialogue: 0,0:11:24.29,0:11:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?
Dialogue: 0,0:11:26.00,0:11:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru dapat minggu lalu.
Dialogue: 0,0:11:32.03,0:11:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baru di kota ini, kan?\NAku belum pernah lihat kalian.
Dialogue: 0,0:11:36.18,0:11:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku anak buah Maki.\NNamaku Natsuki.
Dialogue: 0,0:11:40.18,0:11:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang aku pedagang pemula.
Dialogue: 0,0:11:43.68,0:11:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ke sini ingin ketemu Maki, kan?
Dialogue: 0,0:11:46.13,0:11:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:46.60,0:11:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dengarkan saja, Caiman.
Dialogue: 0,0:11:48.65,0:11:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ah, iya!\NBagaimana kabar Maki?
Dialogue: 0,0:11:52.44,0:11:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini bisnisnya sepi\Ndan dia kelihatan lelah.
Dialogue: 0,0:11:56.88,0:12:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, tunggu sebentar,\Naku harus kerja dulu.
Dialogue: 0,0:12:05.96,0:12:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu, dia menjual apa?
Dialogue: 0,0:12:08.58,0:12:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu!\NAkan kutelepon Maki sekarang.
Dialogue: 0,0:12:11.71,0:12:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, sebelum itu,\Nada yang ingin kutanyakan.
Dialogue: 0,0:12:16.66,0:12:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, Nenek!\NJual senjata dan baju untuk mereka.
Dialogue: 0,0:12:19.89,0:12:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:12:20.91,0:12:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, tempatnya bagus, ya!
Dialogue: 0,0:12:23.60,0:12:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumornya, beberapa barang di sini\Ndijual oleh bos Mata Silang dan ajudannya.
Dialogue: 0,0:12:29.13,0:12:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:12:30.94,0:12:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, pilih-pilih saja.\NAku kerja dulu.
Dialogue: 0,0:12:36.55,0:12:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, tak ada ukuran yang pas untukku.
Dialogue: 0,0:12:40.91,0:12:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman, aku sudah dapat yang pas!
Dialogue: 0,0:12:45.87,0:12:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih cari.\NDasar...
Dialogue: 0,0:12:51.82,0:12:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Nek, kotak anyaman ini isinya apa?
Dialogue: 0,0:12:55.38,0:12:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu!
Dialogue: 0,0:12:56.59,0:12:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang yang belum dibuka,\Nisinya sama seperti pas kubeli!
Dialogue: 0,0:13:00.59,0:13:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pemalas.
Dialogue: 0,0:13:06.14,0:13:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maki!
Dialogue: 0,0:13:07.64,0:13:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas sekali!\NBeberapa orang mencarimu—
Dialogue: 0,0:13:10.35,0:13:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki!
Dialogue: 0,0:13:11.85,0:13:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, malah malas-malasan lagi!
Dialogue: 0,0:13:15.61,0:13:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:13:17.80,0:13:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Natsuki, mulai sekarang kita akan sibuk.
Dialogue: 0,0:13:20.99,0:13:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang ini!
Dialogue: 0,0:13:22.49,0:13:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menjualnya di Mastema.
Dialogue: 0,0:13:26.99,0:13:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubuk hitam?\NDari mana bisa dapat sebanyak ini?
Dialogue: 0,0:13:30.98,0:13:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teksturnya kasar.\NMaki...
Dialogue: 0,0:13:33.38,0:13:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matamu tajam juga.\NBubuk ini palsu.
Dialogue: 0,0:13:37.67,0:13:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos sudah hilang beberapa tahun lalu.\NBarang asli sekarang sudah habis.
Dialogue: 0,0:13:42.18,0:13:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena orang-orang di sini bodoh,\Nmereka pasti akan bayar mahal.
Dialogue: 0,0:13:46.43,0:13:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa begitu?
Dialogue: 0,0:13:47.85,0:13:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Silang memakai bubuk hitam\Ndemi membantu mereka yang tak punya sihir.
Dialogue: 0,0:13:51.69,0:13:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebanyakan mereka gabung\Nke Mata Silang demi uang.
Dialogue: 0,0:13:55.67,0:13:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga begitu, kan?
Dialogue: 0,0:13:57.07,0:14:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tujuanku bukan itu!\NAku tidak peduli soal uang!
Dialogue: 0,0:14:00.57,0:14:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan bantu bisnis seperti ini!
Dialogue: 0,0:14:04.07,0:14:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah semua yang kulakukan,\Nkamu malah membantah?
Dialogue: 0,0:14:09.66,0:14:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada apa?
Dialogue: 0,0:14:11.96,0:14:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ribut antar rekan?
Dialogue: 0,0:14:14.46,0:14:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?\NAku belum pernah lihat wajahmu.
Dialogue: 0,0:14:18.21,0:14:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, siapa aku?\NAku sendiri pun tidak tahu.
Dialogue: 0,0:14:22.72,0:14:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kamu salah satu\Nanak buah Dokuga.
Dialogue: 0,0:14:26.35,0:14:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mencoba mengacaukan bisnisku?
Dialogue: 0,0:14:29.41,0:14:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:33.10,0:14:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki!
Dialogue: 0,0:14:35.63,0:14:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:14:38.02,0:14:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membunuhmu!
Dialogue: 0,0:14:42.99,0:14:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:15:00.74,0:15:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maki.
Dialogue: 0,0:15:02.09,0:15:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kasihan padamu.
Dialogue: 0,0:15:04.09,0:15:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar anggota Mata Silang asli\Nmahir memakai pisau.
Dialogue: 0,0:15:09.37,0:15:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kuat, pasti anggota asli, kan?
Dialogue: 0,0:15:11.60,0:15:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:15:13.23,0:15:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, pulang saja.\NKeluar dari Mata Silang.
Dialogue: 0,0:15:16.48,0:15:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NAku memutuskan akan mengikutimu!
Dialogue: 0,0:15:19.86,0:15:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku akan bertemu Bos!
Dialogue: 0,0:15:21.73,0:15:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah, kamu itu menyebalkan!
Dialogue: 0,0:15:24.24,0:15:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon!\NAku akan melakukan apa pun!
Dialogue: 0,0:15:27.99,0:15:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Nikaido, beri dia nasihat!
Dialogue: 0,0:15:33.20,0:15:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayar dulu, dasar sampah!
Dialogue: 0,0:15:46.84,0:15:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, di sana.
Dialogue: 0,0:15:53.96,0:15:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Kento.
Dialogue: 0,0:15:55.66,0:15:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menggunakan sihir dari toko asap\Nuntuk membesarkan tubuh.
Dialogue: 0,0:15:58.48,0:16:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!\NGawat, semuanya mati dibunuh!
Dialogue: 0,0:16:06.28,0:16:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mobil pembersih En.
Dialogue: 0,0:16:09.81,0:16:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menangkap Kento dan yang lainnya.
Dialogue: 0,0:16:12.16,0:16:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, kenapa jadi begini?
Dialogue: 0,0:16:14.62,0:16:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya malah jadi percuma!
Dialogue: 0,0:16:18.92,0:16:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ke sini karena\Nkamu bilang ada makanan,
Dialogue: 0,0:16:21.59,0:16:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi malah dihidangkan nasi!\NDasar penipu!
Dialogue: 0,0:16:23.71,0:16:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NNikaido kan memasak untukmu.
Dialogue: 0,0:16:27.67,0:16:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana kita bisa ke Berith?
Dialogue: 0,0:16:30.80,0:16:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita harus naik bus.
Dialogue: 0,0:16:32.93,0:16:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa naik bus ke Kota Zagan\Ndan pikirkan lagi di sana.
Dialogue: 0,0:16:36.98,0:16:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota Zagan?
Dialogue: 0,0:16:38.63,0:16:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jadi!
Dialogue: 0,0:16:40.19,0:16:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasi telur dadar polos.
Dialogue: 0,0:16:44.36,0:16:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betulan polos!
Dialogue: 0,0:16:46.69,0:16:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kenapa kamu tak punya uang?
Dialogue: 0,0:16:49.49,0:16:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan abangmu!
Dialogue: 0,0:16:51.68,0:16:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kupakai toiletnya?
Dialogue: 0,0:16:54.08,0:16:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, di sana.
Dialogue: 0,0:16:57.98,0:16:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Abang.
Dialogue: 0,0:16:59.21,0:17:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido partnermu?\NAtau pacarmu?
Dialogue: 0,0:17:03.92,0:17:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia partnerku.
Dialogue: 0,0:17:08.66,0:17:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia bukan anggota Mata Silang, ya?
Dialogue: 0,0:17:11.55,0:17:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka dari gereja hilang tanpa bekas.
Dialogue: 0,0:17:15.64,0:17:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Asu menyembuhkanku?
Dialogue: 0,0:17:18.64,0:17:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:17:20.89,0:17:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siapa yang menikamku?
Dialogue: 0,0:17:27.15,0:17:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya!
Dialogue: 0,0:17:28.65,0:17:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percayakan ini padamu.
Dialogue: 0,0:17:31.24,0:17:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:17:32.24,0:17:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubuk hitam, memangnya apa lagi?
Dialogue: 0,0:17:34.95,0:17:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja itu asli.\NItu kantong terakhir.
Dialogue: 0,0:17:38.16,0:17:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu mengambil ini,\Naku yang tak bisa menghasilkan asap pun,
Dialogue: 0,0:17:42.08,0:17:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa menjadi penyihir.
Dialogue: 0,0:17:45.17,0:17:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos yang menciptakan benda ini sangat hebat!
Dialogue: 0,0:17:49.30,0:17:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai! Wastu kita sudah jadi!
Dialogue: 0,0:17:53.51,0:17:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:17:54.55,0:17:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sapi, Babi! Jangan sentuh\Nbarang dagangan sambilan kita!
Dialogue: 0,0:17:58.39,0:18:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau tak laku?
Dialogue: 0,0:18:00.14,0:18:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu! Wastu ini dibangun\Ndari amplop hasil kerja keras kita!
Dialogue: 0,0:18:04.98,0:18:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus ada nuansa romannya.
Dialogue: 0,0:18:06.69,0:18:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dapurnya.\NKamar mandinya besar seperti spa.
Dialogue: 0,0:18:11.19,0:18:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita punya tiga wastafel dan tiga toilet,\Njadi tak perlu ribut lagi tiap pagi.
Dialogue: 0,0:18:16.12,0:18:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, akhirnya mulai lari dari kenyataan, ya?
Dialogue: 0,0:18:20.12,0:18:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Dokuga dan Tetsujo lama, ya.
Dialogue: 0,0:18:22.71,0:18:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu sebentar lagi akan datang.
Dialogue: 0,0:18:29.71,0:18:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:18:33.72,0:18:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Bu Kontrakan.\NHari ini pun kamu terlihat menawan.
Dialogue: 0,0:18:37.85,0:18:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dengar itu dari pria tampan\Nsepertimu membuatku senang.
Dialogue: 0,0:18:44.60,0:18:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan basa-basi.
Dialogue: 0,0:18:46.27,0:18:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kalian bayar semua\Nutang sewa enam bulan hari ini.
Dialogue: 0,0:18:51.36,0:18:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat suka kalian.\NTapi hari ini kalian harus melunasinya.
Dialogue: 0,0:18:56.74,0:19:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga sebentar lagi bawa uangnya.\NUshishimada akan menemanimu dulu.
Dialogue: 0,0:19:02.50,0:19:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kalau begitu, maaf merepotkan, ya.
Dialogue: 0,0:19:08.75,0:19:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu, Ushishimada.
Dialogue: 0,0:19:11.88,0:19:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga, Bu.
Dialogue: 0,0:19:14.30,0:19:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil aku Bu!
Dialogue: 0,0:19:16.51,0:19:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih lajang!
Dialogue: 0,0:19:19.08,0:19:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu?\NBaiklah!
Dialogue: 0,0:19:20.76,0:19:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku sudah bilang berkali-kali,
Dialogue: 0,0:19:23.56,0:19:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tak perlu bayar sewa\Nkalau menjadi suamiku.
Dialogue: 0,0:19:28.30,0:19:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-temanmu juga,\Naku akan merawat mereka.
Dialogue: 0,0:19:34.69,0:19:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga sebentar lagi pulang.
Dialogue: 0,0:19:37.53,0:19:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Dokuga dan Tetsujo!
Dialogue: 0,0:19:39.95,0:19:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NMereka pulang?
Dialogue: 0,0:19:42.45,0:19:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, kami sudah menunggu!\NMana uangnya?
Dialogue: 0,0:19:49.38,0:19:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembersih En mengalahkan\NKento dan yang lainnya.
Dialogue: 0,0:19:52.21,0:19:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubuk hitam terakhir dan asap mahal,\Nsemuanya jadi abu.
Dialogue: 0,0:19:56.22,0:19:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa apes begini?
Dialogue: 0,0:19:57.80,0:20:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi yang tersisa\Ncuma amplop sambilan kita?
Dialogue: 0,0:20:03.27,0:20:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kita harus pergi dari sini juga, ya?
Dialogue: 0,0:20:06.27,0:20:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Risu sedang apa?
Dialogue: 0,0:20:10.90,0:20:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, apa tidak ada sesuatu yang berharga?
Dialogue: 0,0:20:14.15,0:20:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petunjuk soal orang yang membunuhku.
Dialogue: 0,0:20:17.64,0:20:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mencoba mencuri sesuatu dari mejaku?
Dialogue: 0,0:20:20.85,0:20:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, tak ada yang berharga di sini.
Dialogue: 0,0:20:24.91,0:20:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini karena kalian\Nterus berpura-pura tak tahu!
Dialogue: 0,0:20:27.50,0:20:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang membunuhku?\NApa itu perintah Bos?
Dialogue: 0,0:20:31.29,0:20:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau... kamu yang melakukannya, Dokuga?
Dialogue: 0,0:20:38.30,0:20:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pencuri yang membobol rumah ini.
Dialogue: 0,0:20:43.60,0:20:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutunjukkan apa yang terjadi padanya.
Dialogue: 0,0:20:48.84,0:20:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kehabisan uang.
Dialogue: 0,0:20:51.48,0:20:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita terpaksa harus meninggalkan\Ntempat ini dan berpisah.
Dialogue: 0,0:20:55.73,0:21:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan! Bukankah kita berlima harusnya\Nmenunggu sampai Bos kembali?
Dialogue: 0,0:21:00.91,0:21:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemiskinan mengalahkan kita.
Dialogue: 0,0:21:03.98,0:21:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:21:05.56,0:21:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:21:06.70,0:21:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ke tempat Bu Kontrakan.
Dialogue: 0,0:21:09.98,0:21:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, kalian bisa bebas\Ntinggal di rumah ini!
Dialogue: 0,0:21:13.71,0:21:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!\NItu sama saja jual diri!
Dialogue: 0,0:21:16.42,0:21:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini pria!
Dialogue: 0,0:21:18.51,0:21:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tubuh ini bisa berguna untuk kalian,
Dialogue: 0,0:21:22.29,0:21:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan senang hati akan kukorbankan.
Dialogue: 0,0:21:25.37,0:21:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ushishimada.
Dialogue: 0,0:21:27.58,0:21:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu baik...
Dialogue: 0,0:21:29.31,0:21:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?\NUangnya sudah ada?
Dialogue: 0,0:21:33.88,0:21:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Kontrakan, maaf kami, uangnya tidak ada.
Dialogue: 0,0:21:37.26,0:21:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ikut denganmu.
Dialogue: 0,0:21:39.32,0:21:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:21:55.88,0:21:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan pada mataku?
Dialogue: 0,0:22:00.49,0:22:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air liurku beracun.
Dialogue: 0,0:22:02.26,0:22:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:22:15.90,0:22:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan membunuhmu.\NKarena kamu terlalu berbahaya.
Dialogue: 0,0:22:23.57,0:22:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akta rumah.
Dialogue: 0,0:22:26.32,0:22:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,\Ngedung ini milik kalian semua.
Dialogue: 0,0:22:29.58,0:22:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo pergi, Ushishimada.
Dialogue: 0,0:22:34.35,0:22:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ingin tinggal bersama kalian\Ndi rumah yang kita bangun dari amplop.
Dialogue: 0,0:22:39.34,0:22:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal.
Dialogue: 0,0:22:40.96,0:22:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ushishimada!
Dialogue: 0,0:23:03.76,0:23:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zagan.
Dialogue: 0,0:23:05.32,0:23:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah dengar nama itu.
Dialogue: 0,0:23:08.38,0:23:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana aku dengarnya, ya?
Dialogue: 0,0:23:16.40,0:23:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Kasukabe.
Dialogue: 0,0:23:18.28,0:23:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sekarang menjadi penyihir.
Dialogue: 0,0:23:21.92,0:23:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe.
Dialogue: 0,0:23:23.82,0:23:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:24.42,0:23:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah melamun?\NMasih ada yang sakit?
Dialogue: 0,0:23:28.93,0:23:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku baik-baik saja.
Dialogue: 0,0:23:31.85,0:23:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patung lilin itu...
Dialogue: 0,0:23:33.40,0:23:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patung lilin?
Dialogue: 0,0:23:34.43,0:23:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:23:35.52,0:23:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu seperti altar,\Ndan di tengahnya ada patung lilin.
Dialogue: 0,0:23:41.51,0:23:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sudah meleleh dilalap api.
Dialogue: 0,0:23:44.85,0:23:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, apa orang-orang\Nbermata silang itu semacam organisasi?
Dialogue: 0,0:23:49.87,0:23:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka musuh kami.\NTapi kami berhasil menghabisi beberapa.
Dialogue: 0,0:23:53.58,0:23:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman juga punya tanda silang.
Dialogue: 0,0:23:56.54,0:23:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya!
Dialogue: 0,0:23:59.78,0:24:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga penting, tapi wajah patung itu...
Dialogue: 0,0:24:04.49,0:24:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kenal dia.
Dialogue: 0,0:24:06.47,0:24:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:24:08.58,0:24:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kembali ke Hole.
Dialogue: 0,0:25:41.98,0:25:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini\Ndi Episode 2 Musim Kedua.
Dialogue: 0,0:25:44.31,0:25:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istri Kasukabe adalah iblis.
Dialogue: 0,0:25:46.07,0:25:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Mata Silang bokek.
Dialogue: 0,0:25:48.03,0:25:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zagan ada di ingatannya Caiman.
Dialogue: 0,0:25:49.99,0:25:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan ketahui di Episode 2 Musim Kedua,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:25:54.74,0:25:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
