Dialogue: 0,0:00:02.15,0:00:05.99,tanda,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:01:55.01,0:01:57.01,tanda,,0000,0000,0000,,AWAL
Dialogue: 0,0:02:38.43,0:02:41.81,tanda,,0000,0000,0000,,SEJENGKAL DARI AJAL
Dialogue: 0,0:03:03.60,0:03:06.17,tanda,,0000,0000,0000,,AKU SEDANG DIBAHAS? JADI PENASARAN
Dialogue: 0,0:03:12.96,0:03:14.97,tanda,,0000,0000,0000,,SUDAH WAKTUNYA MAKAN?\NBERI AKU MAKAN
Dialogue: 0,0:03:14.97,0:03:18.93,tanda,,0000,0000,0000,,SUDAH WAKTUNYA MAKAN?
Dialogue: 0,0:03:18.93,0:03:22.14,tanda,,0000,0000,0000,,BERI AKU MAKAN
Dialogue: 0,0:03:23.02,0:03:25.23,tanda,,0000,0000,0000,,SUDAH WAKTUNYA MAKAN?
Dialogue: 0,0:03:33.51,0:03:34.74,tanda,,0000,0000,0000,,BERI AKU MAKAN
Dialogue: 0,0:03:45.25,0:03:47.93,tanda,,0000,0000,0000,,WAKTUNYA PATROLI
Dialogue: 0,0:04:00.76,0:04:02.26,tanda,,0000,0000,0000,,MULAI DARI RUANGAN INI
Dialogue: 0,0:04:03.76,0:04:05.02,tanda,,0000,0000,0000,,SEMUA AMAN
Dialogue: 0,0:04:06.02,0:04:08.77,tanda,,0000,0000,0000,,RUANGAN SELANJUTNYA
Dialogue: 0,0:04:09.55,0:04:11.52,tanda,,0000,0000,0000,,OH, SIAPA YANG MEMANGGILKU?
Dialogue: 0,0:04:13.98,0:04:16.02,tanda,,0000,0000,0000,,OH, DIA KAN...
Dialogue: 0,0:04:18.02,0:04:20.02,tanda,,0000,0000,0000,,AKU MENCIUM BAU KEMATIAN!
Dialogue: 0,0:04:23.91,0:04:25.52,tanda,,0000,0000,0000,,TADI ITU SUNGGUH MENJENGKELKAN
Dialogue: 0,0:04:30.25,0:04:33.92,tanda,,0000,0000,0000,,KALIAN SEDANG APA?
Dialogue: 0,0:04:35.55,0:04:38.57,tanda,,0000,0000,0000,,DI SINI JUGA ADA SEDIKIT BAU KEMATIAN
Dialogue: 0,0:04:50.31,0:04:54.44,tanda,,0000,0000,0000,,TIBA-TIBA SELANGKANGANKU GATAL
Dialogue: 0,0:05:05.95,0:05:07.37,tanda,,0000,0000,0000,,BAU KEMATIANNYA MENYENGAT!
Dialogue: 0,0:05:59.09,0:06:00.31,tanda,,0000,0000,0000,,AH! KAMU LAGI?
Dialogue: 0,0:08:31.41,0:08:32.65,tanda,,0000,0000,0000,,PUKUL!
Dialogue: 0,0:08:33.40,0:08:35.40,tanda,,0000,0000,0000,,KAMU MATI LAGI?
Dialogue: 0,0:08:36.90,0:08:38.65,tanda,,0000,0000,0000,,AYO MAIN LAGI
Dialogue: 0,0:08:40.41,0:08:42.78,tanda,,0000,0000,0000,,PUKUL!
Dialogue: 0,0:08:43.78,0:08:45.67,tanda,,0000,0000,0000,,KAMU MATI LAGI?
Dialogue: 0,0:08:45.92,0:08:47.92,tanda,,0000,0000,0000,,INI AKAN MEMBUATMU BAIKAN
Dialogue: 0,0:08:50.30,0:08:52.01,tanda,,0000,0000,0000,,DIA LAGI!
Dialogue: 0,0:08:54.81,0:08:59.85,tanda,,0000,0000,0000,,SERAM
Dialogue: 0,0:09:12.03,0:09:13.78,tanda,,0000,0000,0000,,EBISU
Dialogue: 0,0:09:28.55,0:09:30.80,tanda,,0000,0000,0000,,MBAK, KAMU TIDUR?
Dialogue: 0,0:09:32.05,0:09:34.55,tanda,,0000,0000,0000,,KITA SUDAH SEPAKAT\NKAMU SELALU MEMBERIKU CAMILAN
Dialogue: 0,0:09:34.80,0:09:38.64,tanda,,0000,0000,0000,,BANGUN, MBAK!\NWAKTUNYA CAMILAN!
Dialogue: 0,0:09:45.15,0:09:46.90,tanda,,0000,0000,0000,,SEKARANG, BERIKAN AKU CAMILAN!
Dialogue: 0,0:11:29.25,0:11:30.71,tanda,,0000,0000,0000,,PEMBASMI RAYAP
Dialogue: 0,0:13:04.43,0:13:08.39,tanda,,0000,0000,0000,,EKSPEDISI MATA SILANG
Dialogue: 0,0:14:57.92,0:15:00.00,tanda,,0000,0000,0000,,MASKER PERBAN BESAR\NAMAN DAN NYAMAN
Dialogue: 0,0:22:50.89,0:22:52.81,tanda,,0000,0000,0000,,REUNI CACAT
Dialogue: 0,0:26:40.62,0:26:42.00,tanda,,0000,0000,0000,,AKHIR
Dialogue: 0,0:00:16.00,0:00:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berhenti!
Dialogue: 0,0:00:24.05,0:00:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku menemui En!
Dialogue: 0,0:02:01.50,0:02:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman...
Dialogue: 0,0:02:07.80,0:02:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:02:09.43,0:02:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisimu?
Dialogue: 0,0:02:11.68,0:02:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin baik-baik saja.
Dialogue: 0,0:02:15.16,0:02:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengar dari Noi.\NKamu hampir mati, kan?
Dialogue: 0,0:02:18.33,0:02:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini, selalu saja blakblakan.
Dialogue: 0,0:02:21.37,0:02:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku bisa selamat karena\Nmengisap asap Noi.
Dialogue: 0,0:02:29.42,0:02:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktu yang tepat\Nuntuk membahasnya...
Dialogue: 0,0:02:38.43,0:02:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, ini Fujita.
Dialogue: 0,0:02:41.03,0:02:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:42.46,0:02:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Fujita?
Dialogue: 0,0:02:45.84,0:02:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu...
Dialogue: 0,0:02:49.03,0:02:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu sudah mati.
Dialogue: 0,0:02:51.82,0:02:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, lalu?
Dialogue: 0,0:02:55.43,0:03:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...\NLalu...
Dialogue: 0,0:03:00.67,0:03:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh menggunakan sihir Kikurage
Dialogue: 0,0:03:03.60,0:03:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membangkitkannya?
Dialogue: 0,0:03:07.35,0:03:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita, Kikurage bukan piaraanku.
Dialogue: 0,0:03:11.03,0:03:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia anggota keluarga.
Dialogue: 0,0:03:14.97,0:03:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Kikurage paham apa yang kubilang.
Dialogue: 0,0:03:18.93,0:03:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun tak pernah memberinya perintah.
Dialogue: 0,0:03:23.02,0:03:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya memanfaatkannya sesekali.
Dialogue: 0,0:03:25.23,0:03:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku harus bagaimana?\NAku ingin menghidupkan kembali Ebisu!
Dialogue: 0,0:03:30.80,0:03:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tergantung pada suasana hati Kikurage.
Dialogue: 0,0:03:33.51,0:03:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:03:35.72,0:03:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memaksanya menggunakan sihir,\Nhal mengerikan akan terjadi.
Dialogue: 0,0:03:41.97,0:03:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal mengerikan?
Dialogue: 0,0:03:47.93,0:03:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya memang harus memanfaatkannya.
Dialogue: 0,0:03:51.63,0:03:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayatnya bisa dihidupkan\Nkalau dibawa dekat dia.
Dialogue: 0,0:03:56.26,0:04:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cukup dekat dengan Ebisu\Ndan sempat tidur dengannya.
Dialogue: 0,0:04:06.75,0:04:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage.
Dialogue: 0,0:04:09.55,0:04:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemari.
Dialogue: 0,0:04:12.02,0:04:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage.
Dialogue: 0,0:04:16.02,0:04:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage...
Dialogue: 0,0:04:20.02,0:04:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage, tunggu!
Dialogue: 0,0:04:25.52,0:04:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalanya sudah kuperiksa\Ndan jelas ada yang salah.
Dialogue: 0,0:04:30.25,0:04:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paku di kepalanya dipotong hati-hati, lalu...
Dialogue: 0,0:04:34.42,0:04:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:04:35.55,0:04:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada yang membedahnya.
Dialogue: 0,0:04:40.30,0:04:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu!
Dialogue: 0,0:04:41.80,0:04:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kepala dari saat itu.
Dialogue: 0,0:04:43.47,0:04:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu kepala yang kupotong, ya?
Dialogue: 0,0:04:46.39,0:04:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukanya terlihat seperti kepala\Nyang dipukul paluku.
Dialogue: 0,0:04:50.31,0:04:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa ada sana?
Dialogue: 0,0:04:54.98,0:04:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu, aku tidak tahu.\NTapi aku melihatnya.
Dialogue: 0,0:04:59.20,0:05:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman tak berwajah kadal lagi.
Dialogue: 0,0:05:02.20,0:05:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?\N- Apa?
Dialogue: 0,0:05:03.95,0:05:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu benar?
Dialogue: 0,0:05:05.95,0:05:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:05:07.37,0:05:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu!
Dialogue: 0,0:05:10.80,0:05:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau wajah pria kadal itu kembali normal,
Dialogue: 0,0:05:14.00,0:05:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu merapal sihir padanya.
Dialogue: 0,0:05:17.76,0:05:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membunuhnya?
Dialogue: 0,0:05:19.05,0:05:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aku! Aku hanya ingin Kikurage\Nmenghidupkannya kembali!
Dialogue: 0,0:05:22.93,0:05:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun ingin menghidupkannya,
Dialogue: 0,0:05:24.72,0:05:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa tumor iblis di kepalanya baik-baik saja?
Dialogue: 0,0:05:27.31,0:05:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita, minta dia memeriksanya.
Dialogue: 0,0:05:29.35,0:05:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu punya niat terselubung,\Ntapi keahliannya jempolan.
Dialogue: 0,0:05:34.77,0:05:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutnya Ebisu!
Dialogue: 0,0:05:35.86,0:05:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri yang menempelkannya, kan?
Dialogue: 0,0:05:38.55,0:05:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sepertinya masih baik-baik saja.
Dialogue: 0,0:05:41.20,0:05:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum menghidupkannya kembali,\Nminta Noi perbaiki kerusakan tubuhnya.
Dialogue: 0,0:05:46.33,0:05:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melakukannya.
Dialogue: 0,0:05:48.68,0:05:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu mati, tapi semuanya malah cuek.
Dialogue: 0,0:05:54.58,0:05:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa reaksi mereka akan sama kalau aku mati?
Dialogue: 0,0:05:59.09,0:06:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage!
Dialogue: 0,0:06:01.09,0:06:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur!\NEbisu itu temanmu, kan?
Dialogue: 0,0:06:05.30,0:06:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan, Bodoh?
Dialogue: 0,0:06:07.01,0:06:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamurku hampir patah!\NKamu mencoba membunuhku?
Dialogue: 0,0:06:09.81,0:06:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cho-Chota?
Dialogue: 0,0:06:13.09,0:06:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tak sadar itu kamu, Fujita.
Dialogue: 0,0:06:15.98,0:06:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku tak bisa melihat.
Dialogue: 0,0:06:18.23,0:06:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pasti sulit, ya?
Dialogue: 0,0:06:19.98,0:06:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sihirmu bisa membuatmu\Nkembali normal lagi dengan mudah, kan?
Dialogue: 0,0:06:24.59,0:06:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, tapi jamur ini...
Dialogue: 0,0:06:27.87,0:06:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya seperti En dan aku suka.
Dialogue: 0,0:06:31.37,0:06:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:06:34.16,0:06:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak mencium sesuatu yang aneh?
Dialogue: 0,0:06:36.63,0:06:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebenarnya...
Dialogue: 0,0:06:39.85,0:06:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, Ebisu...
Dialogue: 0,0:06:42.38,0:06:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Ebisu kurang beruntung.
Dialogue: 0,0:06:46.76,0:06:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga tak punya banyak rambut.
Dialogue: 0,0:06:48.63,0:06:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada!
Dialogue: 0,0:06:50.00,0:06:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dulu dapat ini dari iblis.
Dialogue: 0,0:06:52.14,0:06:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai jepit rambut ini,\Nkamu selalu bisa tersenyum dan bahagia.
Dialogue: 0,0:06:57.40,0:07:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupasangkan, ya.\NNah!
Dialogue: 0,0:07:01.18,0:07:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Ebisu.
Dialogue: 0,0:07:06.66,0:07:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana perginya Kikurage?
Dialogue: 0,0:07:11.16,0:07:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noi!
Dialogue: 0,0:07:14.91,0:07:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, serang aku dari semua arah!
Dialogue: 0,0:07:37.99,0:07:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita!\NKamu baik-baik saja?
Dialogue: 0,0:07:41.82,0:07:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, aku terlalu fokus latihan\Nsampai tak sadar itu kamu.
Dialogue: 0,0:07:47.18,0:07:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NDi mana Ebisu?
Dialogue: 0,0:07:52.27,0:07:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membunuhnya?
Dialogue: 0,0:07:53.66,0:07:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:07:55.54,0:07:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku hanya perlu memperbaikinya, kan?\N- Apa?
Dialogue: 0,0:08:02.19,0:08:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu sebentar!
Dialogue: 0,0:08:04.76,0:08:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru menyembuhkannya\Nsaat jepit rambutnya ada di kepalanya.
Dialogue: 0,0:08:08.26,0:08:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu?\NDatang lagi kalau ada yang aneh.
Dialogue: 0,0:08:11.93,0:08:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kusembuhkan.
Dialogue: 0,0:08:14.04,0:08:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia akan baik-baik saja?\NTapi bau busuknya sudah hilang.
Dialogue: 0,0:08:18.28,0:08:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sekarang cantik lagi, Ebisu.
Dialogue: 0,0:08:22.34,0:08:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat...
Dialogue: 0,0:08:24.15,0:08:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak kuat.
Dialogue: 0,0:08:28.10,0:08:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!\NItu Kikurage.
Dialogue: 0,0:08:50.30,0:08:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:08:52.37,0:08:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buang-buang sihir\Nuntuk hal seperti itu!
Dialogue: 0,0:08:54.81,0:08:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, ini mayat.
Dialogue: 0,0:08:56.81,0:08:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupkan kembali, cepat!
Dialogue: 0,0:09:07.64,0:09:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini hal yang menyeramkan?
Dialogue: 0,0:09:14.73,0:09:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, aku tak bisa\Nmenghidupkan kembali Ebisu hari ini.
Dialogue: 0,0:09:20.55,0:09:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba lagi besok.
Dialogue: 0,0:09:54.10,0:09:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa
Dialogue: 0,0:09:57.95,0:09:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya dirimu?
Dialogue: 0,0:10:06.32,0:10:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi itu lagi.\NSialan!
Dialogue: 0,0:10:09.42,0:10:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku takut?
Dialogue: 0,0:10:12.95,0:10:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bos Mata Silang masih hidup?
Dialogue: 0,0:10:16.33,0:10:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja aku bisa menggunakan\Nsihir Nikaido...
Dialogue: 0,0:10:21.00,0:10:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri air.
Dialogue: 0,0:10:23.81,0:10:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu.
Dialogue: 0,0:10:26.31,0:10:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kamu punya topeng baru.\NKamu cocok pakai itu.
Dialogue: 0,0:10:30.11,0:10:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya aku tak bisa lihat.
Dialogue: 0,0:10:34.20,0:10:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya jepit rambut yang kuberikan\Npadanya masih di kepalanya
Dialogue: 0,0:10:37.70,0:10:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan itu membuatnya aneh lagi.
Dialogue: 0,0:10:40.33,0:10:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu lucu!
Dialogue: 0,0:10:45.61,0:10:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak jadi jamur, aku mulai nyaman\Ndi hutan gelap seperti ini.
Dialogue: 0,0:10:50.97,0:10:54.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya horoskop\Nuntuk penyihir Gemini bulan ini.
Dialogue: 0,0:10:54.43,0:10:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu zodiakku!
Dialogue: 0,0:10:55.84,0:10:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja.
Dialogue: 0,0:10:57.43,0:11:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu mungkin terjadi\Nyang membuatmu makin jatuh cinta
Dialogue: 0,0:11:00.64,0:11:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada cinta sepihakmu.
Dialogue: 0,0:11:02.85,0:11:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi tidak sabar.
Dialogue: 0,0:11:04.60,0:11:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya
Dialogue: 0,0:11:05.81,0:11:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cuma biasa saja, ya?\N- Kaprikornus.
Dialogue: 0,0:11:07.73,0:11:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu En.
Dialogue: 0,0:11:09.36,0:11:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suram.
Dialogue: 0,0:11:10.65,0:11:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, masalah tak terpecahkan di masa lalu\Nkemungkinan besar akan diselesaikan.
Dialogue: 0,0:11:14.36,0:11:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramalannya suram.
Dialogue: 0,0:11:15.84,0:11:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kasihan En.\N- Selanjutnya, Pises.
Dialogue: 0,0:11:18.60,0:11:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi, aku agak cemas.\N- Bagus.
Dialogue: 0,0:11:21.66,0:11:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horoskop ini biasanya akurat.
Dialogue: 0,0:11:25.29,0:11:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.\NMau minum jus?
Dialogue: 0,0:11:27.92,0:11:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau!
Dialogue: 0,0:11:30.71,0:11:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelah.
Dialogue: 0,0:11:32.76,0:11:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Upah langsung dibayar tak seberapa,
Dialogue: 0,0:11:35.01,0:11:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi membasmi rayap\Ndengan racun cair sulit.
Dialogue: 0,0:11:40.14,0:11:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku butuh uang\Nuntuk pengobatan Tetsujo dan Ton.
Dialogue: 0,0:11:43.43,0:11:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang Dokuga!
Dialogue: 0,0:11:45.73,0:11:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu minum jus!\NAku juga mau!
Dialogue: 0,0:11:48.06,0:11:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, kamu bisa mati.
Dialogue: 0,0:11:49.77,0:11:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini dapat berapa?
Dialogue: 0,0:11:52.40,0:11:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}600 nick setelah mengurus tiga rumah.
Dialogue: 0,0:11:54.65,0:11:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat 800 nick sebagai pelayan.
Dialogue: 0,0:11:57.82,0:11:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:12:02.06,0:12:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga.
Dialogue: 0,0:12:03.29,0:12:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bicara dengan Ushishimada
Dialogue: 0,0:12:05.62,0:12:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus menggadaikan ini.\Ndan sepertinya kita terpaksa
Dialogue: 0,0:12:08.75,0:12:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua yang kita berdua\Ndapatkan hari ini!
Dialogue: 0,0:12:13.30,0:12:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pekerjaan yang layak untuk kita\Nyang tak bisa menggunakan sihir!
Dialogue: 0,0:12:18.18,0:12:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.
Dialogue: 0,0:12:19.72,0:12:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menyelamatkan Tetsujo dan Ton,
Dialogue: 0,0:12:21.80,0:12:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus dapat\Nasap kelas A sesegera mungkin.
Dialogue: 0,0:12:27.71,0:12:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa menggadaikan pisau ini.
Dialogue: 0,0:12:29.69,0:12:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, kenapa?
Dialogue: 0,0:12:31.73,0:12:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tak peduli\Nkalau Tetsujo dan Ton mati?
Dialogue: 0,0:12:35.19,0:12:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku yakin kamu\Nmenyembunyikan sesuatu dari kami—
Dialogue: 0,0:12:39.70,0:12:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oi!\N- Dengar!
Dialogue: 0,0:12:40.91,0:12:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini barang yang kudapat langsung dari Bos!
Dialogue: 0,0:12:44.54,0:12:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengembalikannya sendiri.
Dialogue: 0,0:12:47.25,0:12:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan mengembalikan\Nsemua yang kita gadaikan sampai sekarang!
Dialogue: 0,0:12:50.54,0:12:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk uang, biar aku yang urus.
Dialogue: 0,0:12:52.88,0:12:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau paham, sebaiknya diam!
Dialogue: 0,0:12:55.55,0:12:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku paham!
Dialogue: 0,0:12:57.55,0:12:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham!
Dialogue: 0,0:13:00.59,0:13:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Dokuga!
Dialogue: 0,0:13:09.46,0:13:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shaitan, organisasi beberapa\Npenyihir tipe penyembuh.
Dialogue: 0,0:13:15.97,0:13:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merekalah yang menaikkan\Nharga asap jenis penyembuhan.
Dialogue: 0,0:13:21.10,0:13:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keamanan dan pengawal ketat
Dialogue: 0,0:13:23.70,0:13:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatnya sulit untuk dibobol.
Dialogue: 0,0:13:25.66,0:13:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:13:28.41,0:13:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap hari, mereka mengundang wanita\Ndan mengadakan pesta.
Dialogue: 0,0:13:31.61,0:13:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, mari bersenang-senang.
Dialogue: 0,0:13:37.21,0:13:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sake ini enak.\NMinumlah!
Dialogue: 0,0:13:40.63,0:13:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di stoples itu masih banyak!
Dialogue: 0,0:13:44.97,0:13:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pesta lagi di bawah hari ini?
Dialogue: 0,0:13:48.27,0:13:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga sesekali ingin senang-senang.
Dialogue: 0,0:13:52.42,0:13:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba buah?
Dialogue: 0,0:14:14.04,0:14:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sekarang, Mata Silang\Nyang menonjol selalu disingkirkan En.
Dialogue: 0,0:14:19.88,0:14:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kami menunggu\Ndengan tenang sampai bos kembali.
Dialogue: 0,0:14:23.80,0:14:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sekarang...
Dialogue: 0,0:14:24.76,0:14:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati kamu!
Dialogue: 0,0:14:30.27,0:14:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuhan tanpa sihir.
Dialogue: 0,0:14:33.34,0:14:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En pasti akan dengar tentang ini.
Dialogue: 0,0:14:39.69,0:14:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, kamu sekarang di mana?
Dialogue: 0,0:14:47.14,0:14:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:14:50.64,0:14:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:14:54.51,0:14:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Aikawa.\NSalam kenal.
Dialogue: 0,0:15:00.00,0:15:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku beli\Nmasker perban ukuran besar.
Dialogue: 0,0:15:05.26,0:15:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku mulai.
Dialogue: 0,0:15:16.42,0:15:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.\NRasa pedihnya sedikit reda.
Dialogue: 0,0:15:19.48,0:15:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa namamu?\NKenapa kamu terlihat seperti itu?
Dialogue: 0,0:15:23.49,0:15:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Asu.\NBukan, aku Kawajiri.
Dialogue: 0,0:15:27.89,0:15:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak ingat?
Dialogue: 0,0:15:29.45,0:15:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang kamu temui\Ndi ruang bawah gereja di rumah En.
Dialogue: 0,0:15:33.93,0:15:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:15:35.37,0:15:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu pria bernama Caiman?
Dialogue: 0,0:15:39.17,0:15:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Nikaido yang ada di Hole.
Dialogue: 0,0:15:42.38,0:15:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido?\NAku tak kenal siapa dia.
Dialogue: 0,0:15:47.09,0:15:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku salah orang.
Dialogue: 0,0:15:50.50,0:15:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah merawatku.\NAku mau pergi.
Dialogue: 0,0:15:55.35,0:15:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi?\NHei, tunggu!
Dialogue: 0,0:16:03.17,0:16:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya bekerja, kalian berdua.
Dialogue: 0,0:16:06.01,0:16:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Silang bergerak lagi?
Dialogue: 0,0:16:08.72,0:16:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:09.95,0:16:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang di toko\Nbernama Shaitan di Devas dibantai.
Dialogue: 0,0:16:14.98,0:16:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jejak kaki tunjukkan hanya satu pelakunya\Ndan dia menggunakan pisau.
Dialogue: 0,0:16:20.08,0:16:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu ulah bos Mata Silang.\NPastikan kalian menghabisinya!
Dialogue: 0,0:16:28.55,0:16:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus berangkat kerja, Kasukabe.
Dialogue: 0,0:16:33.06,0:16:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga sikapmu, ya, Bocah.
Dialogue: 0,0:16:35.60,0:16:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin, aku ingin bertemu iblis.\NBagaimana caranya?
Dialogue: 0,0:16:40.06,0:16:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar ada kamar di wastu\Nuntuk memanggil iblis.
Dialogue: 0,0:16:44.61,0:16:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hati-hati.
Dialogue: 0,0:16:46.32,0:16:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku akan mencarinya.
Dialogue: 0,0:16:52.35,0:16:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang membuatku cemas?
Dialogue: 0,0:16:55.40,0:17:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengirim Shin dan Noi\Ntanpa yakin dia Mata Silang.
Dialogue: 0,0:17:01.75,0:17:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kegelisahan apa ini?
Dialogue: 0,0:17:05.33,0:17:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En, ayo minum teh!
Dialogue: 0,0:17:08.66,0:17:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chota.
Dialogue: 0,0:17:12.22,0:17:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En, akan kamu apakan Nikaido?
Dialogue: 0,0:17:15.47,0:17:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan mati kalau kamu\Nterus mengabaikannya.
Dialogue: 0,0:17:19.17,0:17:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk beberapa alasan,\NNikaido tak akan menggunakan sihirnya.
Dialogue: 0,0:17:24.28,0:17:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sekarang, aku menghormati\Nkeinginannya dan mengawasinya.
Dialogue: 0,0:17:28.72,0:17:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang kesabaranku habis.
Dialogue: 0,0:17:31.35,0:17:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membuatnya menggunakan sihir
Dialogue: 0,0:17:33.79,0:17:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski harus sedikit kasar.
Dialogue: 0,0:17:37.19,0:17:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bos Mata Silang benar-benar mati?\NAku harus memastikan itu.
Dialogue: 0,0:17:42.61,0:17:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam tahun lalu,\Naku meniupkan asap padanya, lalu...
Dialogue: 0,0:17:47.38,0:17:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota Mastema hancur.
Dialogue: 0,0:17:50.83,0:17:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bisa selamat\Ntanpa berubah menjadi jamur.
Dialogue: 0,0:17:54.89,0:17:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku melihatnya.
Dialogue: 0,0:17:57.99,0:18:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}merangkak keluar dari jamur.\NBayangan pria tanpa kepala
Dialogue: 0,0:18:08.55,0:18:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:18:09.48,0:18:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wastu milik En.
Dialogue: 0,0:18:10.90,0:18:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini sihirmu?
Dialogue: 0,0:18:14.64,0:18:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido ada di depan.\NAyo!
Dialogue: 0,0:18:19.06,0:18:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:18:21.71,0:18:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kamu penyihir hebat, ya?
Dialogue: 0,0:18:25.88,0:18:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa pergi ke mana pun.\NAku iri!
Dialogue: 0,0:18:29.57,0:18:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir macam apa yang kamu gunakan?
Dialogue: 0,0:18:32.85,0:18:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, aku tak bisa beri tahu\Npada orang yang baru kutemui.
Dialogue: 0,0:18:38.75,0:18:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido.
Dialogue: 0,0:18:41.89,0:18:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:18:42.81,0:18:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!\NIni aku, Asu!
Dialogue: 0,0:18:46.15,0:18:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu?
Dialogue: 0,0:18:47.27,0:18:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chidaruma mengubahku menjadi penyihir\Ndan sekarang aku terlihat seperti ini.
Dialogue: 0,0:18:52.43,0:18:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu yang terjadi padamu, Asu.
Dialogue: 0,0:18:55.56,0:18:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Chidaruma melakukan ini\Nkarena kamu membantuku?
Dialogue: 0,0:18:58.95,0:18:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:18:59.95,0:19:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah menyelamatkanku.
Dialogue: 0,0:19:03.21,0:19:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari pada itu, tubuhmu...
Dialogue: 0,0:19:06.19,0:19:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karena aku menolak kontrak dengan En.
Dialogue: 0,0:19:09.25,0:19:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih bisa tetap waras,
Dialogue: 0,0:19:12.24,0:19:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sepertinya aku sudah tidak sanggup.
Dialogue: 0,0:19:15.91,0:19:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kabur bersama.\NSihirku bisa mengatasinya.
Dialogue: 0,0:19:20.79,0:19:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:19:21.84,0:19:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:19:22.89,0:19:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu...
Dialogue: 0,0:19:24.11,0:19:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Aikawa.
Dialogue: 0,0:19:26.02,0:19:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak terlibat urusan dia,\Ntapi dia membawaku ke sini.
Dialogue: 0,0:19:29.72,0:19:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara itu...
Dialogue: 0,0:19:31.11,0:19:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bisa lepas topeng itu\Ndan tunjukkan wajahmu?
Dialogue: 0,0:19:34.82,0:19:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?\NKenapa?
Dialogue: 0,0:19:37.11,0:19:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tak bisa melepasnya?\NBukan masalah besar, kan?
Dialogue: 0,0:19:40.37,0:19:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido?
Dialogue: 0,0:19:41.79,0:19:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, aku akan pergi dari sini.
Dialogue: 0,0:19:45.15,0:19:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman!
Dialogue: 0,0:19:49.15,0:19:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu siapa itu.
Dialogue: 0,0:19:51.67,0:19:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tak melepas topengmu...
Dialogue: 0,0:20:00.51,0:20:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:20:06.31,0:20:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, kan?\NSudah, hentikan.
Dialogue: 0,0:20:09.44,0:20:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:20:12.57,0:20:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat!
Dialogue: 0,0:20:15.99,0:20:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:20:24.02,0:20:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman...
Dialogue: 0,0:20:30.86,0:20:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu senang sekarang?
Dialogue: 0,0:20:34.87,0:20:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, kamu ini gadis barbar.
Dialogue: 0,0:20:38.95,0:20:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman...
Dialogue: 0,0:20:45.96,0:20:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal.
Dialogue: 0,0:21:01.61,0:21:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido.
Dialogue: 0,0:21:03.60,0:21:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi pria itu Caiman?
Dialogue: 0,0:21:06.98,0:21:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:21:09.15,0:21:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita harus mengejarnya?
Dialogue: 0,0:21:11.35,0:21:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:17.63,0:21:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!\NNikai—
Dialogue: 0,0:21:21.55,0:21:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, infusnya!
Dialogue: 0,0:21:23.51,0:21:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:21:28.22,0:21:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sakit kepala lagi.
Dialogue: 0,0:21:36.79,0:21:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:21:41.93,0:21:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dihidupkan kembali,\Nkamu tertawa tanpa henti.
Dialogue: 0,0:21:46.22,0:21:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertawa saat kita di rumah En.
Dialogue: 0,0:21:49.85,0:21:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan minta izin\Nagar kamu bisa tinggal di wastu.
Dialogue: 0,0:21:55.05,0:21:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang tak ada yang bisa membantumu.\NKamu paham?
Dialogue: 0,0:22:09.42,0:22:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:22:14.50,0:22:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:22:19.36,0:22:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?\NPerasaan ini seperti...
Dialogue: 0,0:22:31.77,0:22:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku pasti akan membuat Nikaido\Nmemakai sihirnya.
Dialogue: 0,0:22:34.79,0:22:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan menahan diri lagi.
Dialogue: 0,0:22:37.82,0:22:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage.
Dialogue: 0,0:22:39.13,0:22:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke sini.
Dialogue: 0,0:22:41.26,0:22:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage?
Dialogue: 0,0:22:43.03,0:22:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perangkat keamanannya...\NLalu, dia ketakutan.
Dialogue: 0,0:22:48.39,0:22:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan apa ini?\NAku mual.
Dialogue: 0,0:23:05.20,0:23:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:23:12.54,0:23:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:23:14.54,0:23:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih hidup!
Dialogue: 0,0:23:20.42,0:23:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:21.42,0:23:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga Kikurage, Chota.
Dialogue: 0,0:23:23.80,0:23:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En!
Dialogue: 0,0:23:28.43,0:23:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En!
Dialogue: 0,0:23:40.09,0:23:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti enam tahun lalu.
Dialogue: 0,0:23:42.15,0:23:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai pusing.\NSeluruh tubuhku sakit dan berdenyut.
Dialogue: 0,0:23:45.95,0:23:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan akan berakhir dalam sekejap!
Dialogue: 0,0:24:01.97,0:24:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengakhiri ini\Ndengan tanganku sendiri!
Dialogue: 0,0:24:12.75,0:24:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarkan asapnya, En!
Dialogue: 0,0:24:33.84,0:24:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En!
Dialogue: 0,0:24:35.41,0:24:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa lama jamur ini akan terbang?
Dialogue: 0,0:24:39.42,0:24:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali normal?
Dialogue: 0,0:24:42.61,0:24:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:24:45.68,0:24:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak...\NTidak mungkin...
Dialogue: 0,0:24:49.43,0:24:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En!
Dialogue: 0,0:24:54.93,0:24:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria tanpa kepala.\NDia...
Dialogue: 0,0:26:42.00,0:26:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini di Episode 19.
Dialogue: 0,0:26:44.46,0:26:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta Fujita pada Ebisu nyata.
Dialogue: 0,0:26:46.21,0:26:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Chota selalu berubah.
Dialogue: 0,0:26:48.17,0:26:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan bos luar biasa.
Dialogue: 0,0:26:49.96,0:26:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En!
Dialogue: 0,0:26:51.13,0:26:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan kita ketahui di Episode 20,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:26:55.05,0:26:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
