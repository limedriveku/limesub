Dialogue: 0,0:00:21.46,0:00:23.80,Default,,0,0,0,,Kamu menghilang ke mana?
Dialogue: 0,0:00:24.88,0:00:28.39,Default,,0,0,0,,Tak ada yang bisa menggantikanmu.
Dialogue: 0,0:00:29.43,0:00:34.10,Default,,0,0,0,,Semua orang di sini\Nmencoba menjadi sepertimu.
Dialogue: 0,0:00:37.06,0:00:40.19,Default,,0,0,0,,Tapi tidak ada yang bisa menggantikanmu.
Dialogue: 0,0:01:03.04,0:01:05.88,Default,,0,0,0,,Tolong segera kembali.
Dialogue: 0,0:01:14.72,0:01:17.18,Default,,0,0,0,,Aku tak bisa menemukannya.
Dialogue: 0,0:01:17.81,0:01:24.73,Default,,0,0,0,,Tapi info soal persembunyian Mata Silang\Ndi Berith harusnya akurat.
Dialogue: 0,0:01:31.97,0:01:36.20,Default,,0,0,0,,Lagian, sudah berapa tahun sejak aku mati?
Dialogue: 0,0:01:38.87,0:01:40.12,Default,,0,0,0,,Selamat datang.
Dialogue: 0,0:01:43.67,0:01:45.17,Default,,0,0,0,,Aku mohon.
Dialogue: 0,0:01:45.17,0:01:50.34,Default,,0,0,0,,Sisanya kubayar dengan kupon belanja,\Nbelakangan ini uangku kurang.
Dialogue: 0,0:01:50.84,0:01:52.84,Default,,0,0,0,,Apa boleh buat.
Dialogue: 0,0:01:52.84,0:01:55.43,Default,,0,0,0,,Untuk hari ini saja, kamu dapat diskon.
Dialogue: 0,0:01:55.43,0:01:56.68,Default,,0,0,0,,Terima kasih.
Dialogue: 0,0:02:02.02,0:02:03.36,Default,,0,0,0,,Nanti aku mampir lagi.
Dialogue: 0,0:02:03.36,0:02:04.52,Default,,0,0,0,,Terima kasih.
Dialogue: 0,0:02:05.36,0:02:06.44,Default,,0,0,0,,Selamat datang.
Dialogue: 0,0:02:07.48,0:02:09.40,Default,,0,0,0,,Harganya 130 nick.
Dialogue: 0,0:02:10.65,0:02:11.99,Default,,0,0,0,,Terima kasih!
Dialogue: 0,0:02:14.20,0:02:14.83,Default,,0,0,0,,Yo?
Dialogue: 0,0:02:14.83,0:02:15.66,Default,,0,0,0,,Hm?
Dialogue: 0,0:02:18.16,0:02:19.74,Default,,0,0,0,,Apa perlu apa?
Dialogue: 0,0:02:19.74,0:02:22.46,Default,,0,0,0,,Kamu Risu, kan?
Dialogue: 0,0:02:24.37,0:02:26.56,Default,,0,0,0,,Kita belum pernah bertemu.
Dialogue: 0,0:04:07.56,0:04:09.77,Default,,0,0,0,,Ini persembunyian kami.
Dialogue: 0,0:04:16.36,0:04:20.53,Default,,0,0,0,,Ti-Tidak kusangka ini cuma rumah biasa.
Dialogue: 0,0:04:20.53,0:04:24.62,Default,,0,0,0,,Aku pikir tempatnya seperti markas rahasia.
Dialogue: 0,0:04:27.08,0:04:28.87,Default,,0,0,0,,Aku beli beras.
Dialogue: 0,0:04:31.04,0:04:32.38,Default,,0,0,0,,Semuanya.
Dialogue: 0,0:04:32.38,0:04:33.92,Default,,0,0,0,,Risu ke sini.
Dialogue: 0,0:04:46.79,0:04:49.56,Default,,0,0,0,,Ke-Kenapa ruangannya gelap?
Dialogue: 0,0:04:49.56,0:04:51.69,Default,,0,0,0,,Bagaimana kalau nyalakan lampu?
Dialogue: 0,0:04:52.69,0:04:55.65,Default,,0,0,0,,Aturan kami, lampu harus mati di siang hari.
Dialogue: 0,0:04:56.15,0:04:58.15,Default,,0,0,0,,Oi, buatkan teh untuknya.
Dialogue: 0,0:04:58.15,0:05:01.53,Default,,0,0,0,,Kita masih bisa pakai kantong teh kemarin.
Dialogue: 0,0:05:01.93,0:05:03.05,Default,,0,0,0,,Silakan diminum.
Dialogue: 0,0:05:05.06,0:05:07.58,Default,,0,0,0,,Kudengar kamu sudah mati.
Dialogue: 0,0:05:08.16,0:05:10.79,Default,,0,0,0,,Tujuanku mencari orang yang membunuhku!
Dialogue: 0,0:05:10.79,0:05:12.72,Default,,0,0,0,,Orang yang membunuhmu?
Dialogue: 0,0:05:12.72,0:05:15.17,Default,,0,0,0,,Apa maksudmu?\NBukannya kamu masih hidup.
Dialogue: 0,0:05:15.17,0:05:16.80,Default,,0,0,0,,Aku dibangkitkan!
Dialogue: 0,0:05:16.80,0:05:19.01,Default,,0,0,0,,Dengan sihir peliharaannya En!
Dialogue: 0,0:05:19.01,0:05:20.28,Default,,0,0,0,,Chawantake?
Dialogue: 0,0:05:20.28,0:05:21.30,Default,,0,0,0,,Kikurage.
Dialogue: 0,0:05:24.30,0:05:28.18,Default,,0,0,0,,Orang yang membunuhku\Nadalah pria Mata Silang.
Dialogue: 0,0:05:28.18,0:05:29.81,Default,,0,0,0,,Aku melihatnya sendiri.
Dialogue: 0,0:05:29.81,0:05:33.06,Default,,0,0,0,,Di mana dia? Di mana Bos?\NAku ingin menemuinya sekarang!
Dialogue: 0,0:05:33.56,0:05:34.11,Default,,0,0,0,,Kalau tidak—
Dialogue: 0,0:05:35.73,0:05:37.86,Default,,0,0,0,,Tenang dulu.
Dialogue: 0,0:05:40.74,0:05:44.12,Default,,0,0,0,,Kami tidak tahu apa pun tentang kematianmu.
Dialogue: 0,0:05:45.41,0:05:46.91,Default,,0,0,0,,Koran bekas.
Dialogue: 0,0:05:46.91,0:05:48.37,Default,,0,0,0,,Kalian dengar itu?
Dialogue: 0,0:05:49.12,0:05:54.88,Default,,0,0,0,,Panggil aku kalau ada barang\Nyang tak kalian pakai lagi.
Dialogue: 0,0:05:55.46,0:05:57.00,Default,,0,0,0,,Itu si pengepul koran!
Dialogue: 0,0:05:57.00,0:06:00.30,Default,,0,0,0,,Lima tumpuk koran bekas\Nsetara tiga gulungan kertas toilet.
Dialogue: 0,0:06:01.13,0:06:02.38,Default,,0,0,0,,Cepat kejar dia!
Dialogue: 0,0:06:07.97,0:06:12.27,Default,,0,0,0,,Bikin kaget saja.\NSi pengepul itu sulit dilacak.
Dialogue: 0,0:06:12.27,0:06:16.52,Default,,0,0,0,,Siapa juga yang peduli soal koran bekas?\NNyalakan lampunya!
Dialogue: 0,0:06:16.52,0:06:19.53,Default,,0,0,0,,Belum waktunya, tetap harus mati\Nsampai matahari terbenam.
Dialogue: 0,0:06:24.91,0:06:27.78,Default,,0,0,0,,Yang benar saja, kalian semua.
Dialogue: 0,0:06:28.49,0:06:32.79,Default,,0,0,0,,Di luar, langit sudah cukup gelap.
Dialogue: 0,0:06:33.79,0:06:36.50,Default,,0,0,0,,Ini juga mulai memengaruhi pekerjaan kita.
Dialogue: 0,0:06:36.50,0:06:37.81,Default,,0,0,0,,Mungkin sudah waktunya.
Dialogue: 0,0:06:37.81,0:06:38.71,Default,,0,0,0,,Iya.
Dialogue: 0,0:06:43.92,0:06:45.93,Default,,0,0,0,,Aku Tetsujo.\NSalam kenal.
Dialogue: 0,0:06:45.93,0:06:47.05,Default,,0,0,0,,Aku Ton.
Dialogue: 0,0:06:47.05,0:06:48.05,Default,,0,0,0,,Saji.
Dialogue: 0,0:06:48.05,0:06:49.56,Default,,0,0,0,,Aku Ushishimada.
Dialogue: 0,0:06:50.03,0:06:51.60,Default,,0,0,0,,Namaku Dokuga.
Dialogue: 0,0:06:52.06,0:06:55.52,Default,,0,0,0,,Aku pernah dengar nama kalian.
Dialogue: 0,0:06:55.52,0:06:57.81,Default,,0,0,0,,Kalian yang paling dekat dengan Bos.
Dialogue: 0,0:06:57.81,0:07:01.32,Default,,0,0,0,,Daripada bahas itu, Risu,\Nmau berapa lama kamu tinggal di sini?
Dialogue: 0,0:07:02.40,0:07:06.07,Default,,0,0,0,,Sepertinya keberadaanku di sini\Nakan bawa masalah, ya?
Dialogue: 0,0:07:06.57,0:07:09.37,Default,,0,0,0,,Jatah makan malam kami sekarang\Ntak cukup untukmu.
Dialogue: 0,0:07:09.37,0:07:10.33,Default,,0,0,0,,Dengar itu!
Dialogue: 0,0:07:10.33,0:07:12.08,Default,,0,0,0,,Ayo, waktunya makan!
Dialogue: 0,0:07:12.08,0:07:14.08,Default,,0,0,0,,Siapa yang masak hari ini?
Dialogue: 0,0:07:15.92,0:07:18.40,Default,,0,0,0,,Bos ada di sini.
Dialogue: 0,0:07:20.50,0:07:22.76,Default,,0,0,0,,Selamat datang.
Dialogue: 0,0:07:22.76,0:07:24.84,Default,,0,0,0,,Kamu sedang apa, Ebisu?
Dialogue: 0,0:07:24.84,0:07:27.89,Default,,0,0,0,,Mereka menyuruhku kerja.
Dialogue: 0,0:07:27.89,0:07:31.26,Default,,0,0,0,,Tidak kerja berarti tidak makan, ya?
Dialogue: 0,0:07:31.26,0:07:36.27,Default,,0,0,0,,Aku putri duyung pemakan manusia\Nyang seduktif, Erabisu.
Dialogue: 0,0:07:36.27,0:07:39.98,Default,,0,0,0,,Pemakan manusia?\NIni kelab kanibal?
Dialogue: 0,0:07:39.98,0:07:42.02,Default,,0,0,0,,Itu cuma kiasan.
Dialogue: 0,0:07:42.02,0:07:44.32,Default,,0,0,0,,Oh, kalian sudah di sini.
Dialogue: 0,0:07:45.03,0:07:46.28,Default,,0,0,0,,Oi, bawa sake.
Dialogue: 0,0:07:46.28,0:07:48.03,Default,,0,0,0,,Baik, Bos Besar!
Dialogue: 0,0:07:48.03,0:07:50.16,Default,,0,0,0,,Oi, bawakan mereka wanita.
Dialogue: 0,0:07:50.16,0:07:50.78,Default,,0,0,0,,Baik!
Dialogue: 0,0:07:50.78,0:07:52.33,Default,,0,0,0,,Tidak butuh!
Dialogue: 0,0:07:54.83,0:07:57.16,Default,,0,0,0,,- Halo.\N- Oh, halo.
Dialogue: 0,0:07:57.16,0:07:58.92,Default,,0,0,0,,Halo.
Dialogue: 0,0:08:00.88,0:08:02.88,Default,,0,0,0,,Halo, kalian berdua!
Dialogue: 0,0:08:04.38,0:08:06.97,Default,,0,0,0,,Eh, Fujita kerja di sini juga?
Dialogue: 0,0:08:06.97,0:08:10.51,Default,,0,0,0,,Aku mengajukan diri\Nmengurus keperluan harian En.
Dialogue: 0,0:08:10.51,0:08:14.14,Default,,0,0,0,,Ke mana pun, dia mengikutiku.\NJujur saja, itu mengganggu.
Dialogue: 0,0:08:16.64,0:08:20.65,Default,,0,0,0,,Nikaido, kamu memang tak bisa dipercaya.
Dialogue: 0,0:08:20.65,0:08:23.65,Default,,0,0,0,,Aku akan melindungi En\Napa pun yang terjadi.
Dialogue: 0,0:08:23.65,0:08:25.36,Default,,0,0,0,,Kamu ganggu.
Dialogue: 0,0:08:28.65,0:08:30.07,Default,,0,0,0,,Ini Martini.
Dialogue: 0,0:08:30.99,0:08:32.41,Default,,0,0,0,,Silakan dinikmati.
Dialogue: 0,0:08:33.20,0:08:34.66,Default,,0,0,0,,Ada berita.
Dialogue: 0,0:08:35.16,0:08:36.71,Default,,0,0,0,,Sudah kutemukan.
Dialogue: 0,0:08:37.29,0:08:39.92,Default,,0,0,0,,Tempat membuat bubuk hitam.
Dialogue: 0,0:08:39.92,0:08:40.41,Default,,0,0,0,,Eh?
Dialogue: 0,0:08:40.41,0:08:41.42,Default,,0,0,0,,Serius?
Dialogue: 0,0:08:41.42,0:08:43.13,Default,,0,0,0,,Tapi masih rumor.
Dialogue: 0,0:08:43.13,0:08:45.92,Default,,0,0,0,,Sepertinya ada persembunyian di hutan.
Dialogue: 0,0:08:45.92,0:08:50.68,Default,,0,0,0,,Hutan mana? Bilang di hutan bukan berarti\Nlangsung menemukannya, Bodoh!
Dialogue: 0,0:08:51.97,0:08:53.97,Default,,0,0,0,,Apa dia juga di sana?
Dialogue: 0,0:08:54.56,0:08:58.06,Default,,0,0,0,,Mungkin.\NDugaanku begitu.
Dialogue: 0,0:08:58.06,0:09:00.90,Default,,0,0,0,,Maksudmu pemimpin Mata Silang?
Dialogue: 0,0:09:00.90,0:09:02.40,Default,,0,0,0,,Aku lihat dia di film.
Dialogue: 0,0:09:02.40,0:09:05.44,Default,,0,0,0,,En, kamu sangat imut pakai itu!\NSerius!
Dialogue: 0,0:09:06.44,0:09:07.50,Default,,0,0,0,,Bagus, kan?
Dialogue: 0,0:09:07.50,0:09:11.01,Default,,0,0,0,,Adegan saat keluarga terbentuk\Nmembuatku merinding!
Dialogue: 0,0:09:11.01,0:09:14.70,Default,,0,0,0,,Nikaido tingkahnya seperti Chota, ya?
Dialogue: 0,0:09:14.70,0:09:16.95,Default,,0,0,0,,Ya, kurasa juga begitu.
Dialogue: 0,0:09:16.95,0:09:20.31,Default,,0,0,0,,Kepribadian gadis malang itu berubah total.
Dialogue: 0,0:09:24.21,0:09:28.01,Default,,0,0,0,,Aku kasihan pada Nikaido,\Ntapi setidaknya kita bisa hidup.
Dialogue: 0,0:09:28.01,0:09:29.47,Default,,0,0,0,,Aku lega.
Dialogue: 0,0:09:29.82,0:09:33.37,Default,,0,0,0,,Aku juga sudah tidak percaya Nikaido.
Dialogue: 0,0:09:33.97,0:09:36.47,Default,,0,0,0,,Aku tak akur dengan para penyihir.
Dialogue: 0,0:09:36.47,0:09:40.37,Default,,0,0,0,,Menurutku penyihir dan manusia\Nbisa akur tanpa ada masalah.
Dialogue: 0,0:09:42.19,0:09:47.33,Default,,0,0,0,,Setidaknya, aku ingin memberi tahu\NCaiman tentang situasi saat ini.
Dialogue: 0,0:09:57.85,0:09:58.95,Default,,0,0,0,,Oh, iya.
Dialogue: 0,0:09:58.95,0:10:02.87,Default,,0,0,0,,Caiman kebal sihir, dia mungkin\Nbisa menyelamatkan Nikaido.
Dialogue: 0,0:10:02.87,0:10:07.13,Default,,0,0,0,,Tapi, kita tidak tahu\Ndi mana Caiman sekarang.
Dialogue: 0,0:10:07.78,0:10:09.88,Default,,0,0,0,,Kirim utusan.
Dialogue: 0,0:10:12.63,0:10:14.89,Default,,0,0,0,,Tapi, siapa?
Dialogue: 0,0:10:16.16,0:10:17.83,Default,,0,0,0,,Istriku.
Dialogue: 0,0:10:19.39,0:10:21.89,Default,,0,0,0,,Terima kasih banyak!
Dialogue: 0,0:10:22.25,0:10:25.01,Default,,0,0,0,,Datang lagi, ya!
Dialogue: 0,0:10:26.73,0:10:30.32,Default,,0,0,0,,Dia masih hidup.\NMenurutmu juga begitu, Noi?
Dialogue: 0,0:10:30.32,0:10:32.03,Default,,0,0,0,,Ya.
Dialogue: 0,0:10:32.03,0:10:37.32,Default,,0,0,0,,Kalau kita tahu wajahnya,\Nbanyak cara untuk menemukannya.
Dialogue: 0,0:10:38.08,0:10:41.83,Default,,0,0,0,,Wajah si sialan itu berlumuran darah Tenjin.
Dialogue: 0,0:10:41.83,0:10:45.75,Default,,0,0,0,,Aku bahkan tak bisa melihat tanda silang\Nyang harusnya ada di matanya.
Dialogue: 0,0:10:46.86,0:10:53.13,Default,,0,0,0,,Filmnya En memang penuh omong kosong,\Ntapi yang jelas, mereka hampir membunuh kita.
Dialogue: 0,0:10:59.79,0:11:03.14,Default,,0,0,0,,Senior, akhirnya semua jadi menarik lagi.
Dialogue: 0,0:11:03.14,0:11:05.35,Default,,0,0,0,,Selanjutnya aku tak akan kalah!\NAku janji!
Dialogue: 0,0:11:07.06,0:11:09.33,Default,,0,0,0,,Kamu tahu apa kelebihanmu, Noi?
Dialogue: 0,0:11:10.38,0:11:14.24,Default,,0,0,0,,Sebahaya apa pun pekerjaannya,\Nkamu tak pernah membebaniku.
Dialogue: 0,0:11:15.61,0:11:17.24,Default,,0,0,0,,Senior juga.
Dialogue: 0,0:11:19.99,0:11:24.83,Default,,0,0,0,,Kita pergi tidak bilang Shin dulu.\NDia mungkin ngamuk sekarang.
Dialogue: 0,0:11:24.83,0:11:28.00,Default,,0,0,0,,Aku sudah kirim pesan ke dia,\Nharusnya aman.
Dialogue: 0,0:11:28.37,0:11:30.21,Default,,0,0,0,,Maaf sempit, ya, Jonson.
Dialogue: 0,0:11:30.21,0:11:31.50,Default,,0,0,0,,Syok!
Dialogue: 0,0:11:35.97,0:11:37.55,Default,,0,0,0,,Mereka akan baik-baik saja?
Dialogue: 0,0:11:37.55,0:11:40.89,Default,,0,0,0,,Kalau tahu mereka manusia,\Nmungkin akan dijual.
Dialogue: 0,0:11:40.89,0:11:43.16,Default,,0,0,0,,Mereka bilang akan kembali besok pagi.
Dialogue: 0,0:11:43.16,0:11:43.89,Default,,0,0,0,,Biarkan saja.
Dialogue: 0,0:11:48.98,0:11:50.19,Default,,0,0,0,,Makasih.
Dialogue: 0,0:11:50.19,0:11:53.28,Default,,0,0,0,,Senior, aku akan bawa mereka kembali.
Dialogue: 0,0:11:53.28,0:11:55.86,Default,,0,0,0,,Tidak usah, kenapa harus repot?
Dialogue: 0,0:11:55.86,0:11:59.28,Default,,0,0,0,,Belakangan ini aku bosan,\Nenergiku terlalu banyak.
Dialogue: 0,0:11:59.78,0:12:00.91,Default,,0,0,0,,Oi, tunggu.
Dialogue: 0,0:12:00.91,0:12:02.91,Default,,0,0,0,,Aku pergi dulu.
Dialogue: 0,0:12:03.31,0:12:04.41,Default,,0,0,0,,Oi.
Dialogue: 0,0:12:06.08,0:12:08.17,Default,,0,0,0,,Dasar.
Dialogue: 0,0:12:11.13,0:12:14.30,Default,,0,0,0,,Dok, kapan kali terakhir\Nkamu bertemu istrimu?
Dialogue: 0,0:12:14.30,0:12:17.81,Default,,0,0,0,,Mungkin sekitar 25 tahun lalu?
Dialogue: 0,0:12:17.81,0:12:18.43,Default,,0,0,0,,Eh?
Dialogue: 0,0:12:18.43,0:12:20.51,Default,,0,0,0,,Kamu yakin dia tidak mencampakkanmu?
Dialogue: 0,0:12:20.51,0:12:23.47,Default,,0,0,0,,Dari usianya, mungkin saja dia sudah mati.
Dialogue: 0,0:12:23.47,0:12:25.03,Default,,0,0,0,,Yang benar saja!
Dialogue: 0,0:12:25.03,0:12:25.43,Default,,0,0,0,,Apa itu?
Dialogue: 0,0:12:25.98,0:12:27.67,Default,,0,0,0,,Ada rumah.
Dialogue: 0,0:12:32.61,0:12:34.40,Default,,0,0,0,,Ada apa, Jonson?
Dialogue: 0,0:12:34.40,0:12:36.69,Default,,0,0,0,,Dia terjebak dan tak bisa keluar.
Dialogue: 0,0:12:37.95,0:12:40.95,Default,,0,0,0,,Kami cuma sebentar, tunggu di situ, ya.
Dialogue: 0,0:12:44.31,0:12:45.83,Default,,0,0,0,,Seram.
Dialogue: 0,0:12:48.83,0:12:50.42,Default,,0,0,0,,Apa tidak ada orang di dalam?
Dialogue: 0,0:12:50.92,0:12:51.89,Default,,0,0,0,,Oh, tidak dikunci.
Dialogue: 0,0:12:51.89,0:12:53.34,Default,,0,0,0,,Hei, tunggu!
Dialogue: 0,0:13:03.18,0:13:05.10,Default,,0,0,0,,Ini pasti salah tempat!
Dialogue: 0,0:13:05.10,0:13:09.31,Default,,0,0,0,,Belum pasti, rumah Dokter\Nsangat mirip dengan ini.
Dialogue: 0,0:13:09.31,0:13:10.48,Default,,0,0,0,,Eh?
Dialogue: 0,0:13:12.41,0:13:13.23,Default,,0,0,0,,Hm?
Dialogue: 0,0:13:13.73,0:13:15.12,Default,,0,0,0,,Ini aneh.
Dialogue: 0,0:13:15.12,0:13:17.48,Default,,0,0,0,,Semua yang ada di sini, seperti...
Dialogue: 0,0:13:17.91,0:13:20.53,Default,,0,0,0,,Sepertinya ada ruangan lain di belakang.
Dialogue: 0,0:13:24.46,0:13:25.12,Default,,0,0,0,,Eh?
Dialogue: 0,0:13:39.49,0:13:42.34,Default,,0,0,0,,Kalian tersesat, Nona-Nona Muda?
Dialogue: 0,0:13:44.76,0:13:49.52,Default,,0,0,0,,Bukan.\NMereka mangsa yang dia kirim.
Dialogue: 0,0:13:53.06,0:13:55.02,Default,,0,0,0,,Kita salah rumah, ya?
Dialogue: 0,0:13:55.02,0:13:56.92,Default,,0,0,0,,Jonson! Kemari!
Dialogue: 0,0:14:05.24,0:14:06.99,Default,,0,0,0,,Monster apa itu?
Dialogue: 0,0:14:06.99,0:14:10.50,Default,,0,0,0,,Ayo, Jonson!\NSingkirkan mereka!
Dialogue: 0,0:14:15.04,0:14:16.52,Default,,0,0,0,,Pisau tak mempan!
Dialogue: 0,0:14:18.88,0:14:21.57,Default,,0,0,0,,- Ayo kabur selagi bisa.\N- Sini pegangan!
Dialogue: 0,0:14:22.59,0:14:24.34,Default,,0,0,0,,Pintu masuknya...
Dialogue: 0,0:14:24.34,0:14:26.39,Default,,0,0,0,,Serangga sialan, selalu mengacau!
Dialogue: 0,0:14:26.39,0:14:27.04,Default,,0,0,0,,Lewat sini!
Dialogue: 0,0:14:27.04,0:14:28.85,Default,,0,0,0,,Dasar!
Dialogue: 0,0:14:29.64,0:14:32.31,Default,,0,0,0,,Nishinoya, urus para bocah itu!
Dialogue: 0,0:14:32.31,0:14:33.60,Default,,0,0,0,,Baik!
Dialogue: 0,0:14:38.65,0:14:39.90,Default,,0,0,0,,Hiratsuka!
Dialogue: 0,0:14:52.83,0:14:54.54,Default,,0,0,0,,Bagaimana ini, Kento?
Dialogue: 0,0:14:55.71,0:14:57.79,Default,,0,0,0,,Aku tak yakin bisa berhasil, tapi...
Dialogue: 0,0:14:57.79,0:14:58.79,Default,,0,0,0,,Rasakan ini!
Dialogue: 0,0:15:05.72,0:15:07.68,Default,,0,0,0,,Sial, mereka mengejar kita.
Dialogue: 0,0:15:12.18,0:15:15.44,Default,,0,0,0,,- Dingin.\N- Tunggu di sini, aku akan jadi umpan.
Dialogue: 0,0:15:15.44,0:15:16.56,Default,,0,0,0,,Dok—
Dialogue: 0,0:15:27.31,0:15:28.70,Default,,0,0,0,,Oi!
Dialogue: 0,0:15:28.70,0:15:30.24,Default,,0,0,0,,Ke sini!
Dialogue: 0,0:15:35.21,0:15:36.54,Default,,0,0,0,,Jalan buntu.
Dialogue: 0,0:15:40.92,0:15:41.84,Default,,0,0,0,,Eh?
Dialogue: 0,0:15:42.44,0:15:44.84,Default,,0,0,0,,Ini aku dan Haru.
Dialogue: 0,0:15:48.39,0:15:50.72,Default,,0,0,0,,Ketemu!
Dialogue: 0,0:15:50.72,0:15:55.23,Default,,0,0,0,,Akan kucincang kamu sampai hancur!
Dialogue: 0,0:15:55.85,0:16:00.86,Default,,0,0,0,,Apa kalian membunuh Haru\Ndan mencuri rumah ini?
Dialogue: 0,0:16:16.58,0:16:18.08,Default,,0,0,0,,Dia tangguh juga.
Dialogue: 0,0:16:18.08,0:16:21.21,Default,,0,0,0,,Tapi itu tak akan bertahan lama.
Dialogue: 0,0:16:21.21,0:16:23.09,Default,,0,0,0,,Sampai jumpa di neraka, serangga—
Dialogue: 0,0:16:25.84,0:16:26.84,Default,,0,0,0,,Hah?
Dialogue: 0,0:16:31.43,0:16:36.77,Default,,0,0,0,,Kalian tahu pepatah\N"Jangan pernah remehkan rumput yang dipijak"?
Dialogue: 0,0:16:36.77,0:16:39.77,Default,,0,0,0,,Dia serangga kenalan kenalanku.
Dialogue: 0,0:16:39.77,0:16:42.06,Default,,0,0,0,,Kalau kalian ingin berkelahi, lawan aku!
Dialogue: 0,0:16:42.90,0:16:45.86,Default,,0,0,0,,Kamu makan getah dan pergi ke tempat lain!
Dialogue: 0,0:16:47.76,0:16:50.41,Default,,0,0,0,,Kalau dilihat, kalian dari Mata Silang, ya?
Dialogue: 0,0:16:50.41,0:16:53.70,Default,,0,0,0,,Cemasku ternyata benar,\Naku tak perlu repot mencari kalian.
Dialogue: 0,0:16:53.70,0:16:58.29,Default,,0,0,0,,Dia Noi, sepupu En\Ndan penyihir tipe penyembuh.
Dialogue: 0,0:16:58.29,0:17:00.21,Default,,0,0,0,,Kita dapat mangsa bagus.
Dialogue: 0,0:17:01.25,0:17:03.21,Default,,0,0,0,,Maju sini, aku akan bunuh kalian.
Dialogue: 0,0:17:04.46,0:17:06.71,Default,,0,0,0,,Terima kasih, Bos.
Dialogue: 0,0:17:10.68,0:17:14.18,Default,,0,0,0,,Dasar, ujungnya aku harus terlibat juga.
Dialogue: 0,0:17:15.68,0:17:17.64,Default,,0,0,0,,Oh, Serangga?\NAda apa?
Dialogue: 0,0:17:17.64,0:17:20.14,Default,,0,0,0,,Syok!
Dialogue: 0,0:17:23.15,0:17:26.15,Default,,0,0,0,,Si sialan ini wanita, ya?
Dialogue: 0,0:17:26.15,0:17:28.36,Default,,0,0,0,,Tapi, kamu hebat, Kento.
Dialogue: 0,0:17:28.36,0:17:31.15,Default,,0,0,0,,Menjatuhkan Noi dengan sekali pukul.
Dialogue: 0,0:17:31.15,0:17:34.39,Default,,0,0,0,,Aku cuma melakukan apa yang Bos ajarkan.
Dialogue: 0,0:17:35.66,0:17:38.66,Default,,0,0,0,,Aku akan cabik dia.\NRobek pakaiannya.
Dialogue: 0,0:17:39.16,0:17:40.16,Default,,0,0,0,,Baik.
Dialogue: 0,0:17:46.21,0:17:49.05,Default,,0,0,0,,Kalian sepertinya bersenang-senang, ya?
Dialogue: 0,0:17:49.49,0:17:50.80,Default,,0,0,0,,Shin!
Dialogue: 0,0:17:51.30,0:17:52.38,Default,,0,0,0,,Jangan bergerak!
Dialogue: 0,0:17:53.64,0:17:58.56,Default,,0,0,0,,Kalau kuputar pisau ini sedikit,\Nakan sama seperti memutar keran air,
Dialogue: 0,0:17:58.56,0:18:02.14,Default,,0,0,0,,lalu tumor Iblis dalam kepalanya\Nakan meledak.
Dialogue: 0,0:18:02.14,0:18:06.90,Default,,0,0,0,,Bahkan Kikurage pun tak akan\Nmampu membangkitkannya.
Dialogue: 0,0:18:15.99,0:18:18.04,Default,,0,0,0,,Oh, langsung paham, ya?
Dialogue: 0,0:18:18.45,0:18:21.66,Default,,0,0,0,,Rasakan ini dan ini!
Dialogue: 0,0:18:25.25,0:18:26.17,Default,,0,0,0,,Rasakan ini!
Dialogue: 0,0:18:27.28,0:18:29.67,Default,,0,0,0,,Noi, kalau kamu...
Dialogue: 0,0:18:29.67,0:18:33.05,Default,,0,0,0,,Senior, bertarunglah tanpa mengkhawatirkanku.
Dialogue: 0,0:18:33.05,0:18:37.43,Default,,0,0,0,,Aku lebih baik mati daripada\Ndikeroyok tanpa melawan!
Dialogue: 0,0:18:37.43,0:18:39.89,Default,,0,0,0,,Kamu mungkin akan bilang begitu.
Dialogue: 0,0:18:40.39,0:18:43.94,Default,,0,0,0,,Tapi, aku...
Dialogue: 0,0:19:15.55,0:19:17.72,Default,,0,0,0,,Tetap payah.
Dialogue: 0,0:19:19.22,0:19:22.47,Default,,0,0,0,,Aku sangat kesal sampai tak tahan lagi.
Dialogue: 0,0:19:24.92,0:19:26.73,Default,,0,0,0,,Aduh.
Dialogue: 0,0:19:26.73,0:19:28.65,Default,,0,0,0,,Sepertinya aku masih hidup.
Dialogue: 0,0:19:28.65,0:19:30.23,Default,,0,0,0,,Ketemu!
Dialogue: 0,0:19:32.69,0:19:34.19,Default,,0,0,0,,Bersiaplah!
Dialogue: 0,0:19:37.57,0:19:38.96,Default,,0,0,0,,Kamu baik-baik saja, Kasukabe?
Dialogue: 0,0:19:38.96,0:19:40.08,Default,,0,0,0,,Shin!
Dialogue: 0,0:19:40.08,0:19:41.99,Default,,0,0,0,,Kamu datang untuk menyelamatkan kami?
Dialogue: 0,0:19:41.99,0:19:43.58,Default,,0,0,0,,Di sini berbahaya, mundur!
Dialogue: 0,0:19:43.58,0:19:45.41,Default,,0,0,0,,Shin, lukamu...
Dialogue: 0,0:19:46.81,0:19:49.13,Default,,0,0,0,,Kesadaranku mulai hilang.
Dialogue: 0,0:19:49.13,0:19:52.30,Default,,0,0,0,,Tak ada cara selain menggunakan sihir\Ndan selesaikan dengan cepat.
Dialogue: 0,0:19:52.30,0:19:53.42,Default,,0,0,0,,Dia kabur.
Dialogue: 0,0:19:53.42,0:19:55.22,Default,,0,0,0,,Tidak.
Dialogue: 0,0:19:56.16,0:19:59.47,Default,,0,0,0,,Sialan, dia tahu sihir apa\Nyang akan kukeluarkan.
Dialogue: 0,0:20:00.00,0:20:05.43,Default,,0,0,0,,Karena takut dengan kemampuanku,\Nhanya ada satu hal yang akan dia lakukan.
Dialogue: 0,0:20:13.44,0:20:15.24,Default,,0,0,0,,Mati sana!
Dialogue: 0,0:20:16.32,0:20:18.20,Default,,0,0,0,,Asapnya tak mau keluar?
Dialogue: 0,0:20:19.45,0:20:23.70,Default,,0,0,0,,Sekarang kamu paham\Nbagaimana rasanya tak bisa pakai sihir?
Dialogue: 0,0:20:26.04,0:20:26.79,Default,,0,0,0,,Shin.
Dialogue: 0,0:20:26.79,0:20:27.54,Default,,0,0,0,,Sialan!
Dialogue: 0,0:20:27.54,0:20:29.67,Default,,0,0,0,,Kamu tak bisa bertarung kalau terluka.
Dialogue: 0,0:20:30.88,0:20:35.67,Default,,0,0,0,,Kamu kaget, kan? Kami latihan tiap hari\Nuntuk mengalahkan penyihir.
Dialogue: 0,0:20:35.67,0:20:37.31,Default,,0,0,0,,Kalian berlatih?
Dialogue: 0,0:20:37.31,0:20:42.10,Default,,0,0,0,,Shin, kemungkinan besar mereka menikammu\Ndi titik lemah para penyihir.
Dialogue: 0,0:20:42.10,0:20:44.56,Default,,0,0,0,,Apa maksudnya itu?\NAku baru dengar!
Dialogue: 0,0:20:44.56,0:20:49.06,Default,,0,0,0,,Penyihir punya organ khusus\Nuntuk menghasilkan asap.
Dialogue: 0,0:20:49.06,0:20:53.19,Default,,0,0,0,,Tadi kamu ditikam di situ\Ndan tak bisa mengeluarkan asap.
Dialogue: 0,0:20:53.19,0:20:55.03,Default,,0,0,0,,Begitu.
Dialogue: 0,0:20:55.03,0:20:58.07,Default,,0,0,0,,Pantas Noi dikalahkan dengan mudah.
Dialogue: 0,0:20:58.53,0:21:01.95,Default,,0,0,0,,Akhir-akhir ini,\Ndia bahkan tidak menghindari serangan.
Dialogue: 0,0:21:04.16,0:21:07.48,Default,,0,0,0,,Sudah lama aku tak bersenang-senang.
Dialogue: 0,0:21:09.33,0:21:12.58,Default,,0,0,0,,Menurutmu sebentar lagi akan mati\Nitu menyenangkan?
Dialogue: 0,0:21:12.58,0:21:16.24,Default,,0,0,0,,Ya, ini mengingatkanku pada masa kecilku!
Dialogue: 0,0:21:34.11,0:21:38.65,Default,,0,0,0,,Baik kamu atau palumu tak akan mempan!
Dialogue: 0,0:21:38.65,0:21:41.20,Default,,0,0,0,,Mati!
Dialogue: 0,0:21:54.29,0:21:57.30,Default,,0,0,0,,Sepertinya aku masih punya trik andalan lain.
Dialogue: 0,0:22:00.80,0:22:03.18,Default,,0,0,0,,Kamu tak akan bisa lari.
Dialogue: 0,0:22:14.73,0:22:18.57,Default,,0,0,0,,Tinggal satu pukulan lagi.\NAku tak akan menahan diri!
Dialogue: 0,0:22:18.57,0:22:19.78,Default,,0,0,0,,Hentika—
Dialogue: 0,0:22:27.24,0:22:29.24,Default,,0,0,0,,Ini luar biasa.
Dialogue: 0,0:22:29.24,0:22:32.62,Default,,0,0,0,,Dia menjalani operasi yang tak biasa.
Dialogue: 0,0:22:33.12,0:22:36.88,Default,,0,0,0,,Kupikir ini operasi untuk mengaktifkan\Npenggunaan sihir.
Dialogue: 0,0:22:37.96,0:22:39.46,Default,,0,0,0,,Aku pergi dulu.
Dialogue: 0,0:22:40.09,0:22:41.80,Default,,0,0,0,,Aku harus menyelamatkan Noi.
Dialogue: 0,0:22:41.80,0:22:44.26,Default,,0,0,0,,Eh, Noi juga ditangkap mereka?
Dialogue: 0,0:22:44.26,0:22:49.06,Default,,0,0,0,,Tapi, Shin, kamu hebat masih hidup\Ndengan luka sebanyak itu.
Dialogue: 0,0:22:49.06,0:22:51.52,Default,,0,0,0,,Itu karena aku latihan setiap hari.
Dialogue: 0,0:22:51.52,0:22:55.73,Default,,0,0,0,,Daripada mencemaskanku,\Nada pecahan kaca besar di kepalamu.
Dialogue: 0,0:22:55.73,0:22:56.52,Default,,0,0,0,,Eh?
Dialogue: 0,0:22:56.52,0:22:57.40,Default,,0,0,0,,Ini.
Dialogue: 0,0:23:15.79,0:23:18.65,Default,,0,0,0,,Kamu sedang apa di saat hujan begini?
Dialogue: 0,0:23:19.03,0:23:20.67,Default,,0,0,0,,Apa kamu terluka?
Dialogue: 0,0:23:23.17,0:23:24.63,Default,,0,0,0,,Siapa namamu?
Dialogue: 0,0:23:24.63,0:23:27.68,Default,,0,0,0,,Jangan khawatir, aku dokter.
Dialogue: 0,0:23:27.68,0:23:29.18,Default,,0,0,0,,Tapi masih baru.
Dialogue: 0,0:23:32.17,0:23:34.36,Default,,0,0,0,,Namaku Kasukabe.
Dialogue: 0,0:23:34.81,0:23:38.19,Default,,0,0,0,,Semua orang memanggilku Haru.
Dialogue: 0,0:23:38.19,0:23:39.65,Default,,0,0,0,,Salam kenal, Haru.
Dialogue: 0,0:23:40.15,0:23:41.36,Default,,0,0,0,,Namaku...
Dialogue: 0,0:23:41.36,0:23:43.19,Default,,0,0,0,,Kasukabe! Oi!
Dialogue: 0,0:23:43.19,0:23:44.44,Default,,0,0,0,,Kasukabe!
Dialogue: 0,0:23:48.06,0:23:49.39,Default,,0,0,0,,Kamu baik-baik saja?
Dialogue: 0,0:23:49.39,0:23:50.74,Default,,0,0,0,,Ya.
Dialogue: 0,0:23:55.44,0:24:00.60,Default,,0,0,0,,Haru, apa kamu betulan sudah mati?
Dialogue: 0,0:24:02.67,0:24:03.73,Default,,0,0,0,,Shin.
Dialogue: 0,0:24:03.73,0:24:04.46,Default,,0,0,0,,Ya?
Dialogue: 0,0:24:06.26,0:24:08.64,Default,,0,0,0,,Apa aku boleh ikut?
Dialogue: 0,0:24:08.64,0:24:11.85,Default,,0,0,0,,Eh? Boleh.
Dialogue: 0,0:24:11.85,0:24:14.35,Default,,0,0,0,,Tapi jangan menghambatku, ya.
Dialogue: 0,0:24:14.35,0:24:16.48,Default,,0,0,0,,Kondisi rekanku lagi gawat.
Dialogue: 0,0:24:17.06,0:24:18.48,Default,,0,0,0,,Aku tahu.
Dialogue: 0,0:24:19.38,0:24:24.28,Default,,0,0,0,,Ternyata kamu sangat peduli pada Noi, ya.
Dialogue: 0,0:24:24.86,0:24:27.36,Default,,0,0,0,,Sepertinya kamu sudah dewasa.
Dialogue: 0,0:24:27.36,0:24:28.41,Default,,0,0,0,,Diam.
Dialogue: 0,0:26:01.96,0:26:04.42,Default,,0,0,0,,Yang kita tahu sejauh ini\Ndi Episode 1 Musim Kedua.
Dialogue: 0,0:26:04.42,0:26:06.67,Default,,0,0,0,,Para Mata Silang orangnya cukup irit.
Dialogue: 0,0:26:06.67,0:26:08.30,Default,,0,0,0,,Para Hole perokok.
Dialogue: 0,0:26:08.30,0:26:10.09,Default,,0,0,0,,Shin dan Noi tak butuh wanita.
Dialogue: 0,0:26:10.09,0:26:14.64,Default,,0,0,0,,Lalu yang akan ketahui di Episode 2 Musim Kedua,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:26:14.64,0:26:17.01,Default,,0,0,0,,Itulah... Dorohedoro.
