Dialogue: 0,0:00:02.69,0:00:05.99,tanda,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:00:10.78,0:00:13.37,tanda,,0000,0000,0000,,LINGKARAN MOSH
Dialogue: 0,0:05:40.11,0:05:42.03,tanda,,0000,0000,0000,,PENYEMBUHAN A+
Dialogue: 0,0:10:38.70,0:10:41.04,tanda,,0000,0000,0000,,AWAL
Dialogue: 0,0:10:41.04,0:10:43.54,tanda,,0000,0000,0000,,KABAR MATA SILANG
Dialogue: 0,0:13:41.59,0:13:43.59,tanda,,0000,0000,0000,,JAMUR
Dialogue: 0,0:15:48.39,0:15:51.18,tanda,,0000,0000,0000,,MENERIMA PENDAFTARAN UJI COBA
Dialogue: 0,0:26:13.72,0:26:14.97,tanda,,0000,0000,0000,,AKHIR
Dialogue: 0,0:00:15.37,0:00:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka ada di sini?
Dialogue: 0,0:00:21.25,0:00:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-En?
Dialogue: 0,0:00:23.63,0:00:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mungkin.\NKamu masih hidup?
Dialogue: 0,0:00:26.38,0:00:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar sialan, berhenti pura-pura tak tahu!
Dialogue: 0,0:00:29.93,0:00:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian membunuh En\Ndan mengambil kepalanya, kan?
Dialogue: 0,0:00:33.89,0:00:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En sudah mati.\NItu boneka.
Dialogue: 0,0:00:37.35,0:00:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat yang membawa kami ke yang asli.
Dialogue: 0,0:00:44.77,0:00:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.\NJadi kepalanya ada di ruangan itu.
Dialogue: 0,0:00:48.57,0:00:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti bos Mata Silang juga ada di dalam?
Dialogue: 0,0:00:53.03,0:00:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun, sebagai pembersih Keluarga En,
Dialogue: 0,0:00:57.75,0:00:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku
Dialogue: 0,0:01:01.08,0:01:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membunuh kalian semua!
Dialogue: 0,0:01:05.71,0:01:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!
Dialogue: 0,0:01:15.51,0:01:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ton!
Dialogue: 0,0:01:16.51,0:01:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Noi.
Dialogue: 0,0:01:18.18,0:01:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang hati-hati\Ndengan serangan mereka.
Dialogue: 0,0:01:22.42,0:01:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, sihir!
Dialogue: 0,0:01:23.52,0:01:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyegelnya!
Dialogue: 0,0:01:27.12,0:01:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghindar itu mudah\Nkalau tahu arah sasaran.
Dialogue: 0,0:01:40.54,0:01:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kabur lewat sini!
Dialogue: 0,0:01:43.54,0:01:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Ton!
Dialogue: 0,0:01:44.55,0:01:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi.
Dialogue: 0,0:01:45.42,0:01:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:01:53.79,0:01:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ton, Saji!
Dialogue: 0,0:02:01.06,0:02:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hidup kembali?\NDasar monster!
Dialogue: 0,0:02:03.77,0:02:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ushishimada!
Dialogue: 0,0:02:04.94,0:02:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, panggil Bos.
Dialogue: 0,0:02:09.75,0:02:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat...
Dialogue: 0,0:02:13.43,0:02:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:02:15.07,0:02:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noi, sisanya kuserahkan padamu.\NAku akan mengikuti boneka itu.
Dialogue: 0,0:02:18.91,0:02:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:02:20.29,0:02:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masukkan yang dicincang ke dalam tas.
Dialogue: 0,0:02:23.25,0:02:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:02:29.71,0:02:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:02:36.28,0:02:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang di sini.
Dialogue: 0,0:02:39.49,0:02:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah keluar?
Dialogue: 0,0:02:45.69,0:02:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En...
Dialogue: 0,0:02:53.22,0:02:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:02:54.86,0:02:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lubang di kepalanya?
Dialogue: 0,0:03:34.61,0:03:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cukup gigih, ya?
Dialogue: 0,0:03:45.33,0:03:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kenapa diam saja?
Dialogue: 0,0:03:56.99,0:03:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergerakanmu mulai lamban.
Dialogue: 0,0:04:01.35,0:04:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita akhiri sekarang saja?
Dialogue: 0,0:04:05.31,0:04:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!
Dialogue: 0,0:04:06.23,0:04:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai ini!
Dialogue: 0,0:04:09.02,0:04:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:12.90,0:04:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang ini berakhir.
Dialogue: 0,0:04:19.02,0:04:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos...
Dialogue: 0,0:04:23.52,0:04:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua melakukan hal yang sia-sia.
Dialogue: 0,0:04:25.79,0:04:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!
Dialogue: 0,0:04:32.57,0:04:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa semua baik-baik saja?
Dialogue: 0,0:04:35.05,0:04:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cepat menemukan Bos!
Dialogue: 0,0:04:48.38,0:04:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa dia Bos?
Dialogue: 0,0:04:55.07,0:04:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, En?
Dialogue: 0,0:04:58.90,0:05:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hentikan!
Dialogue: 0,0:05:07.79,0:05:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kehilangan banyak darah!\NBagaimana ini?
Dialogue: 0,0:05:11.50,0:05:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia melakukan operasi\Npada dirinya sendiri?
Dialogue: 0,0:05:16.42,0:05:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana ini?
Dialogue: 0,0:05:18.66,0:05:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini...
Dialogue: 0,0:05:22.76,0:05:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haru, kamu serius tahu Shin\Ndan yang lainnya di mana?
Dialogue: 0,0:05:27.27,0:05:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu hal mudah.
Dialogue: 0,0:05:28.60,0:05:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini membosankan.\NTak ada tantangan.
Dialogue: 0,0:05:33.35,0:05:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sampai.
Dialogue: 0,0:05:35.11,0:05:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemimpin Mata Silang...\NApa itu kamu, Ai?
Dialogue: 0,0:05:47.19,0:05:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silang di matanya berbeda dengan kami.
Dialogue: 0,0:05:52.29,0:05:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu seperti tanda lahir.
Dialogue: 0,0:06:01.05,0:06:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, namaku Natsuki.
Dialogue: 0,0:06:04.72,0:06:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu...
Dialogue: 0,0:06:09.45,0:06:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku...
Dialogue: 0,0:06:16.16,0:06:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kai.
Dialogue: 0,0:06:19.07,0:06:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noi, sudah selesai?
Dialogue: 0,0:06:22.24,0:06:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudah!
Dialogue: 0,0:06:24.24,0:06:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini tak kucincang,\Nlangsung kumasukkan ke tas.
Dialogue: 0,0:06:28.12,0:06:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya sudah.
Dialogue: 0,0:06:29.94,0:06:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, kita tak akan membunuh mereka, kan?
Dialogue: 0,0:06:33.08,0:06:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa membunuh mereka kapan saja.
Dialogue: 0,0:06:35.29,0:06:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak hal yang ingin\Nkutanyakan pada mereka.
Dialogue: 0,0:06:39.14,0:06:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, di mana bonekanya?
Dialogue: 0,0:06:42.97,0:06:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti enam tahun lalu.
Dialogue: 0,0:06:46.70,0:06:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasana ini seperti
Dialogue: 0,0:06:49.93,0:06:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Hole.
Dialogue: 0,0:06:52.27,0:06:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:06:53.10,0:06:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asap?\NSihir?
Dialogue: 0,0:06:58.11,0:06:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mu-Mustahil!
Dialogue: 0,0:07:00.23,0:07:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... sihirnya En...
Dialogue: 0,0:07:13.13,0:07:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu.
Dialogue: 0,0:07:15.32,0:07:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kamu.
Dialogue: 0,0:07:17.77,0:07:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:07:35.06,0:07:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:07:43.93,0:07:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, tempat ini kacau.
Dialogue: 0,0:07:47.07,0:07:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:07:48.32,0:07:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa, Haru?
Dialogue: 0,0:07:50.07,0:07:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru memikirkan lagu yang bagus.\NDengarkan, ya.
Dialogue: 0,0:07:53.79,0:07:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sekarang?
Dialogue: 0,0:07:55.69,0:08:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku pasti akan mengambil\Nsemuanya darimu.
Dialogue: 0,0:08:00.42,0:08:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti kamu merenggut nyawaku.
Dialogue: 0,0:08:07.01,0:08:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Darah menetes di dinding, sangat kotor ♪
Dialogue: 0,0:08:10.01,0:08:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kenapa datang ke tempat sampah ini? ♪
Dialogue: 0,0:08:11.93,0:08:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku ingin pulang ♪
Dialogue: 0,0:08:13.10,0:08:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan nyanyikan lirik seperti itu.\NBilang saja langsung!
Dialogue: 0,0:08:17.85,0:08:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu iblis!
Dialogue: 0,0:08:25.65,0:08:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:08:26.65,0:08:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Hayes?\NKamu tidur?
Dialogue: 0,0:08:30.24,0:08:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengejutkan.
Dialogue: 0,0:08:32.49,0:08:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo pulang.
Dialogue: 0,0:08:47.62,0:08:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-Bos.
Dialogue: 0,0:08:52.93,0:08:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini!
Dialogue: 0,0:09:05.64,0:09:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu bulan kemudian,
Dialogue: 0,0:09:07.91,0:09:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keluarga En hancur.
Dialogue: 0,0:10:43.54,0:10:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fukuyama!
Dialogue: 0,0:10:45.54,0:10:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Satu bulan setelah pembunuhan En,
Dialogue: 0,0:10:48.21,0:10:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wastunya yang besar\Ndiambil alih oleh Mata Silang.
Dialogue: 0,0:10:51.92,0:10:57.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kehilangan bos hebat mereka,\Nkeluarga En melemah dengan cepat,
Dialogue: 0,0:10:57.26,0:11:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan anggotanya,\Ntermasuk para pelayan, berhamburan."
Dialogue: 0,0:11:02.17,0:11:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kembali bekerja, Bodoh!\N- Aduh!
Dialogue: 0,0:11:05.01,0:11:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Bos juga penasaran, kan?
Dialogue: 0,0:11:08.32,0:11:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lama ini kita jualan kue di sana.
Dialogue: 0,0:11:12.32,0:11:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu yang membuatku makin kesal.
Dialogue: 0,0:11:15.07,0:11:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal jualan kita\Nmulai berjalan sangat baik.
Dialogue: 0,0:11:18.99,0:11:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahas soal Mata Silang,\Napa yang terjadi pada Caiman, ya?
Dialogue: 0,0:11:23.04,0:11:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:24.47,0:11:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal dia,\Npasti selamat dan sedang di tempat lain.
Dialogue: 0,0:11:42.70,0:11:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Dokuga!
Dialogue: 0,0:11:45.06,0:11:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa di tempat seperti ini?
Dialogue: 0,0:11:48.52,0:11:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawa barang yang diminta Bos,
Dialogue: 0,0:11:51.95,0:11:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia tak mengizinkanku masuk.
Dialogue: 0,0:11:54.53,0:11:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos ada di ruangan ini?
Dialogue: 0,0:11:56.57,0:12:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, jangan mengganggunya\Nsaat dia melakukan sesuatu sendirian.
Dialogue: 0,0:12:03.62,0:12:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri sedang apa?
Dialogue: 0,0:12:05.29,0:12:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saji memintaku mengumpulkan\Nsemua barang berharga di wastu.
Dialogue: 0,0:12:10.17,0:12:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, masih banyak yang tersisa.
Dialogue: 0,0:12:12.42,0:12:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebanyak itu?
Dialogue: 0,0:12:13.92,0:12:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga.
Dialogue: 0,0:12:14.92,0:12:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Silang kaya sekarang.\NKaya!
Dialogue: 0,0:12:19.26,0:12:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya?
Dialogue: 0,0:12:20.26,0:12:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Dokuga!
Dialogue: 0,0:12:22.05,0:12:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini barang tambahannya.
Dialogue: 0,0:12:23.97,0:12:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wastu ini terlalu luas.\NKita butuh peta.
Dialogue: 0,0:12:28.56,0:12:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ushishimada, Saji,\Nsudah selesai bersih-bersih?
Dialogue: 0,0:12:32.65,0:12:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum mulai.
Dialogue: 0,0:12:34.34,0:12:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat bawahan En yang menolak\Nsaat kita mengambil alih tempat itu
Dialogue: 0,0:12:38.29,0:12:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih tergeletak.
Dialogue: 0,0:12:41.07,0:12:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa isi kotak ini?
Dialogue: 0,0:12:43.41,0:12:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, mau lihat?
Dialogue: 0,0:12:45.84,0:12:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:47.54,0:12:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru periksa masing-masing mayat ini,
Dialogue: 0,0:12:51.04,0:12:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tak melihat para petinggi.
Dialogue: 0,0:12:54.04,0:12:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua Pembersih juga hilang.
Dialogue: 0,0:12:56.88,0:12:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos tak terkalahkan sekarang.
Dialogue: 0,0:12:58.97,0:13:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan masalah besar.
Dialogue: 0,0:13:00.26,0:13:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku menemukan\Nsesuatu yang luar biasa!
Dialogue: 0,0:13:03.93,0:13:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di ruangan itu!
Dialogue: 0,0:13:07.10,0:13:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emas batangan!
Dialogue: 0,0:13:09.50,0:13:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NReaksi kalian biasa saja.
Dialogue: 0,0:13:12.69,0:13:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku menemukan sesuatu\Nyang luar biasa!
Dialogue: 0,0:13:17.69,0:13:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stok kebutuhan sehari-hari\Ndalam jumlah besar!
Dialogue: 0,0:13:20.45,0:13:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah!\N- Hebat!
Dialogue: 0,0:13:23.57,0:13:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu!\NJadi ini rasanya kaya!
Dialogue: 0,0:13:25.66,0:13:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, standarmu aneh sekali!
Dialogue: 0,0:13:29.12,0:13:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan ini?
Dialogue: 0,0:13:31.79,0:13:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pintu yang mengarah ke Hole.
Dialogue: 0,0:13:35.32,0:13:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Digunakan orang-orang\Nyang tak bisa buat pintu dengan sihir.
Dialogue: 0,0:13:38.17,0:13:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini...
Dialogue: 0,0:13:44.18,0:13:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamur!
Dialogue: 0,0:13:47.14,0:13:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Sudah pagi?
Dialogue: 0,0:13:49.18,0:13:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jam sialan.
Dialogue: 0,0:13:50.56,0:13:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan.
Dialogue: 0,0:13:52.77,0:13:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tak bisa membuang\Nbarang yang masih berguna.
Dialogue: 0,0:13:56.11,0:13:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!\NKemari, ini darurat!
Dialogue: 0,0:13:59.15,0:14:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, di luar gerbang wastu.
Dialogue: 0,0:14:02.11,0:14:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku masuk!
Dialogue: 0,0:14:03.74,0:14:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertemu Bos!
Dialogue: 0,0:14:05.28,0:14:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?\NMendadak seperti ini?
Dialogue: 0,0:14:07.87,0:14:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar para oportunis.
Dialogue: 0,0:14:10.16,0:14:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bicarakan ini dengan Bos.
Dialogue: 0,0:14:12.79,0:14:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berpikir begitu dan mencoba\Nmencarinya, tapi dia tidak ada.
Dialogue: 0,0:14:17.42,0:14:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Lagi?
Dialogue: 0,0:14:19.09,0:14:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:14:21.62,0:14:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos...
Dialogue: 0,0:14:23.30,0:14:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang tak bisa menggunakan sihir\Nmulai berkumpul di wastu En.
Dialogue: 0,0:14:28.31,0:14:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuan Mata Silang?
Dialogue: 0,0:14:30.31,0:14:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, siapa identitas bos Mata Silang?
Dialogue: 0,0:14:37.76,0:14:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar orang-orang bodoh.
Dialogue: 0,0:14:39.36,0:14:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi, uangnya kutaruh di sini.
Dialogue: 0,0:14:41.78,0:14:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:14:46.14,0:14:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada kerjaan sama sekali.
Dialogue: 0,0:14:48.20,0:14:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada hal menarik yang bisa dilakukan?
Dialogue: 0,0:14:54.00,0:14:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, pakai sihirmu.
Dialogue: 0,0:14:56.38,0:14:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak bisa.\NAku tak bisa menggunakannya.
Dialogue: 0,0:14:58.50,0:15:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NKamu murid di sana, kan?
Dialogue: 0,0:15:02.34,0:15:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, coba pakai.
Dialogue: 0,0:15:04.13,0:15:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}To-Tolong hentikan!
Dialogue: 0,0:15:05.80,0:15:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sombong, Sampah.
Dialogue: 0,0:15:08.18,0:15:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian seperti orang-orang dari Hole.
Dialogue: 0,0:15:11.56,0:15:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kamu akan jadi boneka latihanku.
Dialogue: 0,0:15:15.35,0:15:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:15:23.36,0:15:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini latihan yang lumayan untuk pencernaan.
Dialogue: 0,0:15:26.28,0:15:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, kamu Aikawa, kan?
Dialogue: 0,0:15:28.24,0:15:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:15:28.81,0:15:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku! Kita di kelas yang sama\Ndi sekolah Zagan.
Dialogue: 0,0:15:32.29,0:15:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:15:34.27,0:15:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah itu ditutup En beberapa tahun lalu.
Dialogue: 0,0:15:38.71,0:15:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana sarang bubuk hitam\Nyang dijual Mata Silang.
Dialogue: 0,0:15:42.30,0:15:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:15:43.38,0:15:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ada sekolah\Nyang baru selesai dibangun.
Dialogue: 0,0:15:46.76,0:15:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat di sini.
Dialogue: 0,0:15:51.87,0:15:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengirimkan pendaftaranmu?
Dialogue: 0,0:15:53.23,0:15:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:54.96,0:15:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini bagus, ya?\NAku suka.
Dialogue: 0,0:15:58.06,0:15:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku khawatir.
Dialogue: 0,0:15:59.94,0:16:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Silang pasti akan menjual\Nbubuk hitam lagi.
Dialogue: 0,0:16:03.36,0:16:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang baru mulai berlatih lagi\Nsetelah itu menghilang.
Dialogue: 0,0:16:09.16,0:16:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang di sekolah pun\Nhanya bahas Mata Silang.
Dialogue: 0,0:16:13.06,0:16:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang senang\Nmereka menghancurkan keluarga En.
Dialogue: 0,0:16:16.66,0:16:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, bagaimana kabar Risu?
Dialogue: 0,0:16:20.36,0:16:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, aku tidak tahu.
Dialogue: 0,0:16:23.17,0:16:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa, aku akan\Nmentraktirmu makanan di kantin.
Dialogue: 0,0:16:26.59,0:16:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:16:32.89,0:16:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, Aikawa!
Dialogue: 0,0:16:34.60,0:16:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bekerja di sekolah ini juga, Paman?
Dialogue: 0,0:16:37.14,0:16:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, jangan datang ke sekolah ini!
Dialogue: 0,0:16:39.90,0:16:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa!\NSampai besok!
Dialogue: 0,0:16:42.15,0:16:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa besok!
Dialogue: 0,0:16:43.44,0:16:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mulai menjaga\Nmakan siang sekolah darinya lagi?
Dialogue: 0,0:16:48.70,0:16:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, apa yang harus kulakukan hari ini?
Dialogue: 0,0:16:58.48,0:17:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama tak ke sini lagi.
Dialogue: 0,0:17:02.61,0:17:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu.\NOi, kamu ada di dalam?
Dialogue: 0,0:17:12.93,0:17:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ton, apa kita akan menerima\Nmereka ke Mata Silang?
Dialogue: 0,0:17:16.84,0:17:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin.
Dialogue: 0,0:17:18.06,0:17:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bukankah mereka hanya mengejar uang?
Dialogue: 0,0:17:22.52,0:17:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin.\NTapi kita akan memanfaatkan mereka.
Dialogue: 0,0:17:27.88,0:17:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bayar mereka untuk bekerja,\Nlalu atur mereka untuk takut pada bos.
Dialogue: 0,0:17:31.99,0:17:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau kita membiarkan\Nmereka masuk ke wastu,
Dialogue: 0,0:17:35.49,0:17:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin ada yang bisa\Nmencoba membunuh bos.
Dialogue: 0,0:17:39.37,0:17:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk masalah itu, aku ada ide.
Dialogue: 0,0:17:43.96,0:17:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan ini tempo hari.
Dialogue: 0,0:17:46.92,0:17:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu bisnis En\Nadalah sistem inspeksi sihir.
Dialogue: 0,0:17:52.02,0:17:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengukur tingkat penyihir.
Dialogue: 0,0:17:55.68,0:17:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita periksa sebelum mereka masuk,
Dialogue: 0,0:17:58.29,0:18:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa tahu apakah mereka pembunuh.
Dialogue: 0,0:18:01.31,0:18:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong periksa aku juga!
Dialogue: 0,0:18:03.94,0:18:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh!
Dialogue: 0,0:18:05.27,0:18:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti akan kecewa.
Dialogue: 0,0:18:10.97,0:18:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cairan hitam apa ini?
Dialogue: 0,0:18:14.72,0:18:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cairan ini sudah lama ada di kamar Bos.
Dialogue: 0,0:18:18.45,0:18:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ke mana Bos pergi?
Dialogue: 0,0:18:22.03,0:18:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi untuk waktu yang lama lagi?
Dialogue: 0,0:18:23.87,0:18:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak akan terjadi.\NIni berbeda dari waktu itu.
Dialogue: 0,0:18:27.40,0:18:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius, Dokuga.\NBisa cerita sekarang?
Dialogue: 0,0:18:30.92,0:18:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi pada Bos saat itu?
Dialogue: 0,0:18:35.95,0:18:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji tak bocorkan ini ke yang lain?
Dialogue: 0,0:18:39.45,0:18:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.\NTapi kenapa?
Dialogue: 0,0:18:42.42,0:18:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos menemukan seseorang\Ndengan sihir khusus
Dialogue: 0,0:18:45.80,0:18:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia menginginkan sihir itu.
Dialogue: 0,0:18:48.38,0:18:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu Risu.
Dialogue: 0,0:18:49.36,0:18:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, tipe Kutukan!
Dialogue: 0,0:18:51.61,0:18:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:52.61,0:18:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir Risu adalah tipe Kutukan.
Dialogue: 0,0:18:55.56,0:18:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menimpa orang yang membunuhnya.
Dialogue: 0,0:18:58.93,0:19:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesepakatannya pukul 16.00 hari ini\Ndi reruntuhan di Medan Salmanazar.
Dialogue: 0,0:19:03.86,0:19:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, aku boleh bawa partnerku?
Dialogue: 0,0:19:07.00,0:19:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan anggota tim,\Ntapi aku percaya padanya.
Dialogue: 0,0:19:10.13,0:19:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.\NKamu harus pergi sendiri.
Dialogue: 0,0:19:17.32,0:19:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Dokuga?
Dialogue: 0,0:19:20.64,0:19:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Risu?\NAku belum pernah melihatnya.
Dialogue: 0,0:19:23.50,0:19:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin dia bisa dipercaya?\NIni bisnis penting, kan?
Dialogue: 0,0:19:26.93,0:19:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:19:29.30,0:19:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pria yang bersama Risu itu?
Dialogue: 0,0:19:31.02,0:19:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia rekan Risu.\NNamanya Aikawa.
Dialogue: 0,0:19:34.07,0:19:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka selalu bersama.
Dialogue: 0,0:19:37.68,0:19:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa...
Dialogue: 0,0:19:40.27,0:19:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, Risu mungkin dibunuh\NBos di Medan Salmanazar.
Dialogue: 0,0:19:44.75,0:19:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Bos dikutuk setelah membunuh Risu?
Dialogue: 0,0:19:48.96,0:19:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu menyimpan\Nrahasia yang sangat penting?
Dialogue: 0,0:19:54.03,0:19:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir lebih baik mereka tak tahu.
Dialogue: 0,0:19:56.97,0:20:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos bisa membunuh\Nanggota Mata Silang tanpa ragu.
Dialogue: 0,0:20:02.97,0:20:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita butuh Bos untuk bertahan, kan?
Dialogue: 0,0:20:07.60,0:20:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetsujo.
Dialogue: 0,0:20:10.84,0:20:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga mungkin memanfaatkan Bos.
Dialogue: 0,0:20:18.31,0:20:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang membunuhku?
Dialogue: 0,0:20:21.91,0:20:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu membunuhku?
Dialogue: 0,0:20:24.33,0:20:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukan penyihir.
Dialogue: 0,0:20:28.19,0:20:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu palsu.
Dialogue: 0,0:20:31.24,0:20:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NKenapa aku dibunuh?
Dialogue: 0,0:20:35.57,0:20:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bertanya?\NKamu harusnya sudah tahu.
Dialogue: 0,0:20:39.13,0:20:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang tahu tentang sihir ini?
Dialogue: 0,0:20:42.01,0:20:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!\NSoalnya...
Dialogue: 0,0:20:44.14,0:20:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo!
Dialogue: 0,0:20:45.27,0:20:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli mesin uji sihir sendiri\Nyang kita bicarakan tempo hari.
Dialogue: 0,0:20:50.77,0:20:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dari merek En.
Dialogue: 0,0:20:52.44,0:20:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku menemukan\Nsesuatu yang menakjubkan.
Dialogue: 0,0:20:55.86,0:20:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum dikonfirmasi,\Ntapi aku hanya akan cerita padamu.
Dialogue: 0,0:21:04.24,0:21:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu!
Dialogue: 0,0:21:05.79,0:21:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu, kamu mengenaliku?
Dialogue: 0,0:21:08.12,0:21:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku, Aikawa.\NRekanmu.
Dialogue: 0,0:21:12.42,0:21:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, Aikawa.
Dialogue: 0,0:21:14.88,0:21:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin aku melupakanmu.
Dialogue: 0,0:21:17.45,0:21:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi padamu?
Dialogue: 0,0:21:20.55,0:21:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu seperti habis disiksa.
Dialogue: 0,0:21:22.72,0:21:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NAku ada di sini.
Dialogue: 0,0:21:25.14,0:21:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi ke sekolah bersama lagi.
Dialogue: 0,0:21:27.39,0:21:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:21:30.39,0:21:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, kamu lapar?\NAku akan ambilkan makanan.
Dialogue: 0,0:21:34.65,0:21:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Aikawa.
Dialogue: 0,0:21:36.90,0:21:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:21:52.81,0:21:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?\NApa yang terjadi?
Dialogue: 0,0:21:55.88,0:21:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, Mata Silang...
Dialogue: 0,0:21:58.63,0:21:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:21:59.59,0:22:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kamu bangun.
Dialogue: 0,0:22:02.93,0:22:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu butuh waktu lama untuk pulih, Noi.
Dialogue: 0,0:22:07.83,0:22:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah tertidur sebulan.
Dialogue: 0,0:22:11.00,0:22:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:22:14.84,0:22:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:22:15.84,0:22:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku!
Dialogue: 0,0:22:17.44,0:22:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggota keluarga En!
Dialogue: 0,0:22:19.45,0:22:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir yang membuat\Nsegalanya tak terlihat!
Dialogue: 0,0:22:23.39,0:22:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Sho!
Dialogue: 0,0:22:24.70,0:22:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Sho, ya!
Dialogue: 0,0:22:27.00,0:22:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan perjalanan sebentar\Nsetelah Festival Malam Biru.
Dialogue: 0,0:22:31.16,0:22:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kudengar En sudah mati,
Dialogue: 0,0:22:33.21,0:22:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku diam-diam kembali ke wastu\Ndan mengawasi kalian semua.
Dialogue: 0,0:22:37.92,0:22:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tetap tak terlihat\Ndengan sihirmu? Kenapa?
Dialogue: 0,0:22:41.34,0:22:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sepertinya semuanya\Nsudah melupakanku.
Dialogue: 0,0:22:46.20,0:22:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dulu bekerja sebagai pembunuh\Nuntuk keluarga En,
Dialogue: 0,0:22:49.89,0:22:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sihirku mungkin sudah\Nmenumpulkan kehadiranku.
Dialogue: 0,0:22:52.64,0:22:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajar untuk semua orang kecuali En\Nsudah benar-benar melupakanku.
Dialogue: 0,0:22:57.11,0:22:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ada di Festival Malam Biru.
Dialogue: 0,0:23:01.20,0:23:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu ada di sana, ya?\NKamu jelas ada di sana!
Dialogue: 0,0:23:03.82,0:23:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu!\NKamu sudah menyelamatkanku, ya.
Dialogue: 0,0:23:07.24,0:23:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, di mana Senior Shin?
Dialogue: 0,0:23:09.20,0:23:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong pakai baju dulu.
Dialogue: 0,0:23:11.61,0:23:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin mungkin sudah...
Dialogue: 0,0:23:15.54,0:23:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:22.67,0:23:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior...
Dialogue: 0,0:23:24.84,0:23:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencoba menggunakan\Nasap penyembuhan agar Shin kembali normal,
Dialogue: 0,0:23:30.06,0:23:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi butuh semua usahaku\Nagar jamur tetap segar.
Dialogue: 0,0:23:33.98,0:23:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Noi!
Dialogue: 0,0:23:34.98,0:23:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?\NKamu belum pulih.
Dialogue: 0,0:23:37.94,0:23:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, sihir bos Mata Silang\Nberbeda dari En.
Dialogue: 0,0:23:45.49,0:23:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin aku kalah\Ndari sihir si sialan itu.
Dialogue: 0,0:23:54.73,0:23:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asapnya sangat padat!
Dialogue: 0,0:24:15.89,0:24:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang kamu lakukan?
Dialogue: 0,0:24:18.40,0:24:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Senior, syukurlah!
Dialogue: 0,0:24:22.07,0:24:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:24:29.93,0:24:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Noi.
Dialogue: 0,0:24:32.99,0:24:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mereka langsung lupa aku di sini.
Dialogue: 0,0:24:38.12,0:24:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus menghilang.
Dialogue: 0,0:26:14.97,0:26:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini di Episode 21.
Dialogue: 0,0:26:17.22,0:26:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mode serius Shin\Nadalah topeng menghadap ke depan.
Dialogue: 0,0:26:19.64,0:26:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi Mata Silang akhirnya terpenuhi.
Dialogue: 0,0:26:21.81,0:26:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa dan Risu bertemu kembali.
Dialogue: 0,0:26:23.52,0:26:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan kita ketahui di Episode 22,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:26:28.15,0:26:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
