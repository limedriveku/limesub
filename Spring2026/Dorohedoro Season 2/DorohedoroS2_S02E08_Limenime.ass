Dialogue: 0,0:00:02.15,0:00:05.99,tanda,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:00:09.99,0:00:11.28,tanda,,0000,0000,0000,,ZAGAN 50 KM\NBERITH 10 KM
Dialogue: 0,0:02:09.90,0:02:11.99,tanda,,0000,0000,0000,,AWAL
Dialogue: 0,0:02:20.75,0:02:22.37,tanda,,0000,0000,0000,,KEJUTAN KEKACAUAN
Dialogue: 0,0:03:57.16,0:03:57.69,tanda,,0000,0000,0000,,KEKACAUAN MENYEBAR
Dialogue: 0,0:04:11.69,0:04:13.98,tanda,,0000,0000,0000,,BERITA: PEMBUNUHAN EN\NMENYINGKAP SANG PEMBUNUH
Dialogue: 0,0:07:13.66,0:07:15.71,tanda,,0000,0000,0000,,KOTAK HITAM
Dialogue: 0,0:09:29.17,0:09:30.78,tanda,,0000,0000,0000,,JIWA TANPA NAMA\NADA DI SINI
Dialogue: 0,0:19:04.87,0:19:06.88,tanda,,0000,0000,0000,,BAHAN BAKAR
Dialogue: 0,0:20:28.04,0:20:30.54,tanda,,0000,0000,0000,,PANGGILAN MASUK
Dialogue: 0,0:20:53.94,0:20:55.07,tanda,,0000,0000,0000,,PANGGILAN BERAKHIR
Dialogue: 0,0:22:16.94,0:22:19.94,tanda,,0000,0000,0000,,KAMAR 501
Dialogue: 0,0:24:28.61,0:24:29.99,tanda,,0000,0000,0000,,AKHIR
Dialogue: 0,0:00:12.49,0:00:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, apa itu?
Dialogue: 0,0:00:29.20,0:00:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En mati.
Dialogue: 0,0:00:31.68,0:00:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua jamur ciptaan sihir En membusuk.
Dialogue: 0,0:00:36.22,0:00:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, seluruh dunia\Nmengetahui kematian En.
Dialogue: 0,0:02:22.37,0:02:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku pingsan,\Nkudengar di wastu terjadi kekacauan besar.
Dialogue: 0,0:02:27.25,0:02:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin dan Noi sadar ada yang tak beres\Ndan kembali, tapi sudah terlambat.
Dialogue: 0,0:02:32.87,0:02:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar pelakunya kabur lewat saluran udara
Dialogue: 0,0:02:37.14,0:02:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membawa kepala En.
Dialogue: 0,0:02:39.75,0:02:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin mengikuti jejak darahnya,
Dialogue: 0,0:02:42.19,0:02:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jejak pelakunya\Ntiba-tiba berhenti di dalam wastu.
Dialogue: 0,0:02:52.28,0:02:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\Npelakunya masih belum tertangkap.
Dialogue: 0,0:03:03.13,0:03:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu mencari Kikurage\Ndengan camilan yang dia bawa.
Dialogue: 0,0:03:07.01,0:03:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:08.42,0:03:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikurage juga menghilang.
Dialogue: 0,0:03:11.42,0:03:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Chota juga.
Dialogue: 0,0:03:13.70,0:03:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Nikaido juga.
Dialogue: 0,0:03:16.87,0:03:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, Ebisu masih tertawa,
Dialogue: 0,0:03:19.43,0:03:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi entah kenapa,\Ndia tampak sangat kesepian.
Dialogue: 0,0:03:24.00,0:03:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin dan yang lainnya menanyaiku\Nbeberapa kali
Dialogue: 0,0:03:26.77,0:03:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang pria tanpa kepala dan pelaku\Nyang mencoba mengambil kepala En.
Dialogue: 0,0:03:32.55,0:03:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekeras apa pun mencoba mengingatnya,
Dialogue: 0,0:03:36.45,0:03:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kegelapan di saluran itu
Dialogue: 0,0:03:39.32,0:03:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlalu menakutkan,
Dialogue: 0,0:03:41.00,0:03:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai tak ingin mengingatnya.
Dialogue: 0,0:03:45.73,0:03:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya seperti berantakan dalam sekejap.
Dialogue: 0,0:03:53.40,0:03:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematiannya membawa dampak\Nyang berbeda di tiap wilayah.
Dialogue: 0,0:03:57.69,0:04:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia Sihir, yang dikuasai\Noleh kekuatan En yang hebat,
Dialogue: 0,0:04:00.85,0:04:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehilangan pemimpinnya
Dialogue: 0,0:04:02.14,0:04:05.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diperkirakan kekacauannya\Nakan menyebar—
Dialogue: 0,0:04:05.53,0:04:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noi, kan?\NMasuk.
Dialogue: 0,0:04:07.60,0:04:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.\NSenior, bisa bicara sebentar?
Dialogue: 0,0:04:13.98,0:04:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, aku benci En.
Dialogue: 0,0:04:18.86,0:04:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil, dia menggunakan sihirku\Nuntuk keperluannya sendiri.
Dialogue: 0,0:04:23.49,0:04:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu cuma jamur bodoh arogan.
Dialogue: 0,0:04:26.00,0:04:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku tak sedih En mati,
Dialogue: 0,0:04:30.40,0:04:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi wastunya makin berantakan tanpa dia.
Dialogue: 0,0:04:35.51,0:04:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang memasak,\Nmembersihkan, atau bekerja!
Dialogue: 0,0:04:40.64,0:04:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang mencari\NMata Silang makin berkurang!
Dialogue: 0,0:04:43.51,0:04:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang ketakutan dan lari.
Dialogue: 0,0:04:46.83,0:04:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang takut pada En,\Ntapi berkat dia,
Dialogue: 0,0:04:50.77,0:04:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dunia ini agak layak dinikmati.
Dialogue: 0,0:04:53.52,0:04:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, bos Mata Silang\Nyang membunuh En, kan?
Dialogue: 0,0:04:57.40,0:04:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir pasti.
Dialogue: 0,0:04:59.11,0:05:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketidaknyamanan fisik yang Fujita\Nrasakan sesaat sebelumnya,
Dialogue: 0,0:05:03.18,0:05:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama seperti saat dia melawannya\Nenam tahun lalu.
Dialogue: 0,0:05:07.41,0:05:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cari dia, ambil kembali kepala En,\Ndan menghidupkannya kembali!
Dialogue: 0,0:05:12.58,0:05:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kikurage yang paling\Ndibutuhkan menghilang.
Dialogue: 0,0:05:16.71,0:05:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Kikurage, Chota, dan Nikaido\Nbelum ditemukan, bukan?
Dialogue: 0,0:05:21.01,0:05:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua mungkin masih hidup.
Dialogue: 0,0:05:25.39,0:05:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, apa rencanamu, Senior?
Dialogue: 0,0:05:29.39,0:05:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku? Aku hanya akan melakukan\Npekerjaanku sebagai pembersih.
Dialogue: 0,0:05:34.23,0:05:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menemukan dan membunuhnya!
Dialogue: 0,0:05:37.40,0:05:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai bersemangat.
Dialogue: 0,0:05:41.15,0:05:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, Senior!
Dialogue: 0,0:05:43.16,0:05:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tugas kita!
Dialogue: 0,0:05:44.87,0:05:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa!
Dialogue: 0,0:05:48.06,0:05:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi lelah memikirkan semua detailnya.
Dialogue: 0,0:05:52.37,0:05:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku tidur dulu sebentar di sini.\N- Tidur di kamarmu sendiri!
Dialogue: 0,0:05:54.88,0:05:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:05:56.00,0:05:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?\N- Wah, apa aku mengganggu?
Dialogue: 0,0:05:57.84,0:05:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah paham!
Dialogue: 0,0:05:58.99,0:05:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:06:01.17,0:06:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turkey!
Dialogue: 0,0:06:02.31,0:06:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa.
Dialogue: 0,0:06:07.01,0:06:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido.
Dialogue: 0,0:06:12.02,0:06:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:06:13.76,0:06:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang Kawajiri.
Dialogue: 0,0:06:23.95,0:06:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:06:25.70,0:06:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Caiman!
Dialogue: 0,0:06:27.70,0:06:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah orang.\NAku Aikawa.
Dialogue: 0,0:06:31.95,0:06:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penyihir, sama sepertimu.
Dialogue: 0,0:06:36.05,0:06:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!\NAku sudah tak pakai sihir lagi!
Dialogue: 0,0:06:41.55,0:06:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara kekuatan itu,\Naku membuat Yakumo...
Dialogue: 0,0:06:53.18,0:06:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido, aku sangat beruntung.\NKamu tahu kenapa?
Dialogue: 0,0:07:02.19,0:07:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakumo!
Dialogue: 0,0:07:08.20,0:07:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja, aku tak menggunakan sihir...
Dialogue: 0,0:07:17.51,0:07:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:07:19.96,0:07:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku ke sini karena benda persegi ini?
Dialogue: 0,0:07:23.38,0:07:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tak tahu fungsi tombol ini.
Dialogue: 0,0:07:26.55,0:07:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar barang tak berguna!
Dialogue: 0,0:07:27.97,0:07:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:07:31.68,0:07:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungai ini...
Dialogue: 0,0:07:35.69,0:07:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Paman dan Bibi!
Dialogue: 0,0:07:37.40,0:07:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, Bibi!
Dialogue: 0,0:07:39.94,0:07:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bibi"?\NAku belum setua itu!
Dialogue: 0,0:07:42.90,0:07:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia anak siapa?
Dialogue: 0,0:07:45.07,0:07:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nikaido, Paman.
Dialogue: 0,0:07:47.24,0:07:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kenal.
Dialogue: 0,0:07:48.32,0:07:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kebetulan\Nsedang jalan-jalan di sekitar sini.
Dialogue: 0,0:07:52.35,0:07:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman dan Bibi tampak berbeda\Ndari biasanya.
Dialogue: 0,0:07:56.71,0:08:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini masa lalu?
Dialogue: 0,0:08:01.11,0:08:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantas, apa ini sihirku?
Dialogue: 0,0:08:09.35,0:08:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang Kawajiri, aku pergi ke masa lalu\Ndengan kotak persegi itu hari ini.
Dialogue: 0,0:08:14.85,0:08:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertemu Paman dan Bibi\Nsaat masih muda di sana!
Dialogue: 0,0:08:22.02,0:08:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir memanipulasi waktu itu cuma legenda.\NItu sebenarnya tidak ada.
Dialogue: 0,0:08:26.36,0:08:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong, Nikaido.
Dialogue: 0,0:08:28.36,0:08:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bohong!
Dialogue: 0,0:08:30.85,0:08:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:32.70,0:08:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Yakumo?
Dialogue: 0,0:08:34.52,0:08:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakumo?
Dialogue: 0,0:08:36.48,0:08:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu Yakumo?
Dialogue: 0,0:08:40.78,0:08:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:45.53,0:08:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa semua orang pura-pura\Ntak kenal Yakumo?
Dialogue: 0,0:08:49.59,0:08:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesannya dia seperti tak pernah ada.
Dialogue: 0,0:08:53.37,0:08:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masih bayi,\Naku mengambang di sungai ini.
Dialogue: 0,0:08:57.60,0:09:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman dan Bibi kebetulan lewat\Nlalu menyelamatkanku.
Dialogue: 0,0:09:01.77,0:09:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka mengabaikanku sebentar saja,\Naku mungkin akan tenggelam.
Dialogue: 0,0:09:20.79,0:09:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakumo!
Dialogue: 0,0:09:30.78,0:09:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:09:33.00,0:09:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang Kawajiri.
Dialogue: 0,0:09:37.33,0:09:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kota sekitar 200 km di selatan wastu En.
Dialogue: 0,0:09:42.57,0:09:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kamu tak sadarkan diri,
Dialogue: 0,0:09:44.86,0:09:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku beli asap penyembuh\Ndan menyembuhkan luka kita!
Dialogue: 0,0:09:48.19,0:09:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Asu.
Dialogue: 0,0:09:50.78,0:09:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengan dan kakiku sembuh total.
Dialogue: 0,0:09:52.95,0:09:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kenapa asap penyembuhnya mempan?
Dialogue: 0,0:09:57.70,0:09:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku juga tak keluar jamur lagi.
Dialogue: 0,0:10:00.94,0:10:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dibunuh?
Dialogue: 0,0:10:02.71,0:10:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, bagaimana mungkin\Nitu bisa terjadi pada En?
Dialogue: 0,0:10:06.21,0:10:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman yang melakukannya?
Dialogue: 0,0:10:08.13,0:10:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:10:09.13,0:10:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kutahu, orang-orang bilang\NMata Silang pelakunya.
Dialogue: 0,0:10:14.66,0:10:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Silang?
Dialogue: 0,0:10:15.97,0:10:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu dia Caiman atau Aikawa,\Ntapi kalau kamu ingin mengejarnya, aku ikut.
Dialogue: 0,0:10:21.27,0:10:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Asu.
Dialogue: 0,0:10:22.98,0:10:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, saat mimpi buruk,\Nkamu terus memanggilku Abang Kawajiri.
Dialogue: 0,0:10:29.23,0:10:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku tak pernah\Nmemberitahumu namaku.
Dialogue: 0,0:10:33.74,0:10:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang aku pernah\Nmenyelamatkanmu dulu.
Dialogue: 0,0:10:37.41,0:10:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, ini ada hubungannya\Ndengan sihirmu?
Dialogue: 0,0:10:41.31,0:10:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingat pertemuan pertama kita?
Dialogue: 0,0:10:47.32,0:10:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru mau masuk\Ntahap akhir ujian iblis.
Dialogue: 0,0:10:52.17,0:10:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujiannya kebetulan bersamaan\Ndengan Festival Malam Biru.
Dialogue: 0,0:11:01.00,0:11:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang ingin menjadi\Npartnerku mengejarku.
Dialogue: 0,0:11:06.44,0:11:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tak bisa menggunakan sihir\Nsampai ujian selesai, aku gelisah.
Dialogue: 0,0:11:12.97,0:11:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itulah, aku pertama kali\Nbertemu denganmu.
Dialogue: 0,0:11:19.45,0:11:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, kamu terus mengikutiku.
Dialogue: 0,0:11:24.00,0:11:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, di hari itu...
Dialogue: 0,0:11:26.92,0:11:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:11:28.42,0:11:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan menggunakan sihir, ya?
Dialogue: 0,0:11:30.17,0:11:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerah tak memilih partner\Natau keluar ujian iblis?
Dialogue: 0,0:11:33.30,0:11:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada aku harus membuat\Nkontrak dengan kalian...
Dialogue: 0,0:11:43.60,0:11:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:44.22,0:11:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi dari sini!
Dialogue: 0,0:11:45.98,0:11:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kubiarkan!
Dialogue: 0,0:11:48.88,0:11:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kamu yang menyelamatkanku,\Naku bisa menjadi iblis.
Dialogue: 0,0:11:55.64,0:11:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi untuk berterima kasih\Nsetelah menjadi Iblis,
Dialogue: 0,0:11:58.74,0:12:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kamu sudah mulai memikirkan\Nuntuk tinggal di Hole.
Dialogue: 0,0:12:03.62,0:12:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kekuatan iblisku, aku tahu sihirmu itu\Nberhubungan dengan waktu.
Dialogue: 0,0:12:09.63,0:12:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menolak menggunakan sihirmu
Dialogue: 0,0:12:13.49,0:12:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kehilangan sesuatu yang berharga.
Dialogue: 0,0:12:16.74,0:12:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu tak sama seperti saat\Ndirimu yang masih kecil.
Dialogue: 0,0:12:20.51,0:12:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan sihirmu, Nikaido.
Dialogue: 0,0:12:23.37,0:12:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan sihirmu untuk mengambil\Nkembali apa yang hilang!
Dialogue: 0,0:12:27.40,0:12:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa, Asu.
Dialogue: 0,0:12:30.52,0:12:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirku sangat berbahaya.
Dialogue: 0,0:12:33.86,0:12:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena diriku saja, kamu ditolak\Nmenjadi penyihir karena aku.
Dialogue: 0,0:12:40.10,0:12:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menjadi iblis berkat dirimu.
Dialogue: 0,0:12:42.91,0:12:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak keberatan berhenti\Nmenjadi iblis untukmu.
Dialogue: 0,0:12:47.41,0:12:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu...
Dialogue: 0,0:12:51.88,0:12:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan gunakan sihirku\Nuntuk merebut kembali apa yang hilang.
Dialogue: 0,0:12:56.78,0:12:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena En sudah mati,
Dialogue: 0,0:12:59.12,0:13:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keamanan di sekitar wastu melemah, Jonson.
Dialogue: 0,0:13:03.64,0:13:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih belum menemukan kamar\Ntempat mereka memanggil iblis...
Dialogue: 0,0:13:07.85,0:13:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Jonson?
Dialogue: 0,0:13:09.56,0:13:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:10.64,0:13:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam, Hayes.
Dialogue: 0,0:13:12.77,0:13:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Haru?\NKamu kembali menjadi penyihir?
Dialogue: 0,0:13:23.39,0:13:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kaget, kan?
Dialogue: 0,0:13:25.49,0:13:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sukses besar!
Dialogue: 0,0:13:28.02,0:13:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:13:29.79,0:13:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membuatmu kaget.
Dialogue: 0,0:13:32.54,0:13:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua adalah aku yang sebenarnya.
Dialogue: 0,0:13:35.29,0:13:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini berbahaya.\NKalau keluar terlalu lama, aku akan mati.
Dialogue: 0,0:13:41.05,0:13:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:13:42.68,0:13:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa lebih nyaman dalam bentuk ini.
Dialogue: 0,0:13:45.68,0:13:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis memang luar biasa, ya.
Dialogue: 0,0:13:48.18,0:13:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas, kami tak terkalahkan.
Dialogue: 0,0:13:50.68,0:13:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ingin membedahmu.
Dialogue: 0,0:13:54.23,0:13:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tak dengar\Nomongan konyolmu itu.
Dialogue: 0,0:14:02.43,0:14:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, untuk merayakan reuni kita,\Naku akan menyanyikan lagu untukmu.
Dialogue: 0,0:14:07.45,0:14:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:08.87,0:14:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Makhluk kecil, rendah, dan tak berarti\NItulah manusia ♪
Dialogue: 0,0:14:11.87,0:14:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku memakannya saat lapar\NTapi rasanya tak enak ♪
Dialogue: 0,0:14:14.46,0:14:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lemah saat takut ♪
Dialogue: 0,0:14:15.46,0:14:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hidup paling lama 90 tahun ♪
Dialogue: 0,0:14:18.46,0:14:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Terlalu lucu ♪
Dialogue: 0,0:14:22.83,0:14:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lagu tentang manusia.
Dialogue: 0,0:14:25.47,0:14:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hobiku menyanyikan\Napa yang kurasakan saat ini.
Dialogue: 0,0:14:29.14,0:14:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku mencarimu\Nkarena ingin minta bantuanmu.
Dialogue: 0,0:14:34.44,0:14:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ikut denganku?
Dialogue: 0,0:14:36.61,0:14:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buru-buru. Belum terlambat\Nuntuk melihat trik khususku.
Dialogue: 0,0:14:43.32,0:14:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu agak berubah, ya.
Dialogue: 0,0:14:49.77,0:14:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, kita akan buat bonekanya\Ndengan metode memanggang tercepat.
Dialogue: 0,0:14:56.44,0:15:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka aku akan membuat\Nboneka En dengan cara ini.
Dialogue: 0,0:15:01.88,0:15:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga ini bisa membantu kita\Nmenangkap pembunuhnya.
Dialogue: 0,0:15:05.80,0:15:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, serahkan pada kami.
Dialogue: 0,0:15:07.97,0:15:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat boneka yang bagus, Turkey.
Dialogue: 0,0:15:13.27,0:15:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, potong keju istimewa,\Nsayuran, dan salami.
Dialogue: 0,0:15:17.02,0:15:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya,
Dialogue: 0,0:15:18.94,0:15:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}taruh di adonan yang sudah\Ndifermentasi sempurna ini,
Dialogue: 0,0:15:23.30,0:15:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beri tepung sedikit,\Ndan gulung menjadi lingkaran.
Dialogue: 0,0:15:28.16,0:15:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, regangkan dan ratakan.
Dialogue: 0,0:15:33.19,0:15:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, oleskan saus tomat\Npada adonan,
Dialogue: 0,0:15:37.40,0:15:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beri hiasan tambahan, dan taburi keju bubuk.
Dialogue: 0,0:15:40.42,0:15:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir,
Dialogue: 0,0:15:41.67,0:15:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasang asap untuk sosok En yang kubayangkan\Ndengan kaleng minyak ini,
Dialogue: 0,0:15:47.18,0:15:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tuangkan di atas adonan,
Dialogue: 0,0:15:51.43,0:15:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan masukkan ke oven.
Dialogue: 0,0:15:55.93,0:15:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita tinggal menunggunya matang.
Dialogue: 0,0:15:59.88,0:16:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mengikuti boneka itu,\Nkita harus melawan Mata Silang lagi.
Dialogue: 0,0:16:05.74,0:16:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga cepat matang.
Dialogue: 0,0:16:07.78,0:16:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lupa bagaimana kita ditugaskan\Noleh mereka di Hutan Hydra, Noi?
Dialogue: 0,0:16:12.62,0:16:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat!
Dialogue: 0,0:16:14.33,0:16:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan menyerang di tempat\Nyang menghalangi asap kita keluar.
Dialogue: 0,0:16:17.71,0:16:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu paham.
Dialogue: 0,0:16:20.15,0:16:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, berdasarkan lokasi pipa,
Dialogue: 0,0:16:23.96,0:16:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe menyuruh menulis\Ntempat-tempat yang mungkin jadi sasaran.
Dialogue: 0,0:16:27.20,0:16:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah itu?
Dialogue: 0,0:16:28.84,0:16:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi matang.
Dialogue: 0,0:16:34.85,0:16:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pisahkan dia dari adonan.
Dialogue: 0,0:16:36.81,0:16:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-Bokong!
Dialogue: 0,0:16:51.16,0:16:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:16:52.62,0:16:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka ini harusnya menuju\Nke mayatnya sekarang.
Dialogue: 0,0:16:56.52,0:16:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tubuh En dari leher ke bawah,\Nada di kamar mayat.
Dialogue: 0,0:17:00.36,0:17:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kemungkinan dia akan pergi ke sana?
Dialogue: 0,0:17:02.25,0:17:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatirkan itu.
Dialogue: 0,0:17:04.25,0:17:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka ini akan bereaksi\Npada tumor di kepala.
Dialogue: 0,0:17:09.95,0:17:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia langsung bergerak.
Dialogue: 0,0:17:11.81,0:17:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ikuti dia!
Dialogue: 0,0:17:13.84,0:17:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En.
Dialogue: 0,0:17:15.57,0:17:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kami bisa bertemu\Ndirimu yang asli lagi.
Dialogue: 0,0:17:21.01,0:17:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang boneka.
Dialogue: 0,0:17:23.48,0:17:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujudnya mirip En, tapi banyak kekurangan\Ndan tak bisa diandalkan.
Dialogue: 0,0:17:27.78,0:17:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, dia tak punya jamur\Nyang dia tanam atau Kikurage.
Dialogue: 0,0:17:33.06,0:17:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma berkeliaran di wastu.
Dialogue: 0,0:17:37.29,0:17:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, semuanya di sini!
Dialogue: 0,0:17:39.69,0:17:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita!
Dialogue: 0,0:17:43.42,0:17:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En!
Dialogue: 0,0:17:45.00,0:17:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ini boneka—
Dialogue: 0,0:17:50.38,0:17:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:17:52.18,0:17:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, bonekanya hilang!
Dialogue: 0,0:17:54.22,0:17:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:02.89,0:18:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka En bisa memakai Sapu?
Dialogue: 0,0:18:05.86,0:18:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:18:07.02,0:18:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu kami!
Dialogue: 0,0:18:23.75,0:18:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, kita kehilangan dia!
Dialogue: 0,0:18:25.54,0:18:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Sapu itu dipenuhi banyak asap?
Dialogue: 0,0:18:28.55,0:18:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terus mengejarnya.\NAku akan mendahuluinya dari atap!
Dialogue: 0,0:18:32.63,0:18:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:18:43.81,0:18:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, dia cepat!
Dialogue: 0,0:18:49.82,0:18:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini harusnya cukup.\NRasakan ini!
Dialogue: 0,0:18:57.23,0:18:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Noi.
Dialogue: 0,0:19:08.28,0:19:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore, dia melambat!
Dialogue: 0,0:19:11.53,0:19:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:19:19.28,0:19:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget saat lihat berita bahwa En mati.
Dialogue: 0,0:19:22.60,0:19:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, benarkah Bos yang membunuh En?
Dialogue: 0,0:19:26.40,0:19:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa lagi yang bisa menghabisi En?\NSudah pasti si Bos!
Dialogue: 0,0:19:29.90,0:19:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terjadi sesuatu,\Nkita punya banyak asap penyembuh.
Dialogue: 0,0:19:35.03,0:19:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cemas saat Dokuga\Nmembunuh orang-orang Shaitan,
Dialogue: 0,0:19:39.49,0:19:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi setidaknya kita tak perlu takut\Nkarena En sudah mati.
Dialogue: 0,0:19:43.04,0:19:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momennya pas.
Dialogue: 0,0:19:44.83,0:19:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memikirkan Bos akan kembali.
Dialogue: 0,0:19:48.03,0:19:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, kamu yakin tahu di mana Bos?
Dialogue: 0,0:19:52.78,0:19:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin.
Dialogue: 0,0:20:36.59,0:20:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos?
Dialogue: 0,0:20:37.42,0:20:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:38.30,0:20:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terus meneleponmu tanpa henti.
Dialogue: 0,0:20:41.92,0:20:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dari mana saja?
Dialogue: 0,0:20:43.01,0:20:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dengan, Bos?\NIni aku, Ushishimada!
Dialogue: 0,0:20:46.60,0:20:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang membunuh En, kan, Bos?
Dialogue: 0,0:20:49.19,0:20:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Bos?\NDia bilang apa?
Dialogue: 0,0:20:51.27,0:20:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!\NBos masih hidup.
Dialogue: 0,0:20:56.26,0:20:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menutup teleponnya.
Dialogue: 0,0:21:01.56,0:21:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu betulan Bos?
Dialogue: 0,0:21:04.41,0:21:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Dokuga?
Dialogue: 0,0:21:07.00,0:21:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga!
Dialogue: 0,0:21:08.61,0:21:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh.
Dialogue: 0,0:21:10.54,0:21:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus cepat.
Dialogue: 0,0:21:20.22,0:21:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kepala En ada di gedung rusak ini?
Dialogue: 0,0:21:24.22,0:21:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, mungkin bos Mata Silang\Njuga ada di sana!
Dialogue: 0,0:21:27.22,0:21:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya bisa membalas sialan itu!
Dialogue: 0,0:21:38.30,0:21:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:21:41.86,0:21:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Senior?
Dialogue: 0,0:21:45.39,0:21:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir-akhir ini, aku merasa\Nseperti ada yang mengawasiku.
Dialogue: 0,0:21:49.37,0:21:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:50.33,0:21:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, jangan khawatir.
Dialogue: 0,0:21:56.43,0:21:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini, kurasa itu ruangannya.
Dialogue: 0,0:22:03.21,0:22:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Bos?
Dialogue: 0,0:22:20.93,0:22:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruangan ini, ya?
Dialogue: 0,0:22:21.95,0:22:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos ada di sini!
Dialogue: 0,0:22:30.89,0:22:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada seseorang di sana.\NAku yakin.
Dialogue: 0,0:22:34.46,0:22:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ki-Kita harus bagaimana?
Dialogue: 0,0:22:36.21,0:22:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Co-Coba buka.\NYa, kan?
Dialogue: 0,0:22:38.67,0:22:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, kita harus sembunyikan\Ninterkomnya dulu.
Dialogue: 0,0:22:45.66,0:22:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah.
Dialogue: 0,0:22:46.97,0:22:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, itu mereka!
Dialogue: 0,0:22:49.22,0:22:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para sialan, ketemu!
Dialogue: 0,0:22:51.18,0:22:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Pembersih dari keluarga En!
Dialogue: 0,0:24:29.99,0:24:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini di Episode 20.
Dialogue: 0,0:24:32.15,0:24:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak hal yang En ciptakan dengan sihirnya.
Dialogue: 0,0:24:34.79,0:24:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haru senang bernyanyi.
Dialogue: 0,0:24:36.50,0:24:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asu memperhatikan Nikaido.
Dialogue: 0,0:24:38.12,0:24:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan kita ketahui di Episode 21,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:24:42.46,0:24:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
