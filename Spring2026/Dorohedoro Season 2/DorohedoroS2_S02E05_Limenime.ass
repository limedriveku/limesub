Dialogue: 0,0:00:02.15,0:00:05.99,tanda,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:00:20.75,0:00:23.75,tanda,,0000,0000,0000,,PERTEMUAN DI TENGAH HUJAN
Dialogue: 0,0:02:17.89,0:02:18.99,tanda,,0000,0000,0000,,HOLE BARAT, 11 OKTOBER, TUMOR IBLIS
Dialogue: 0,0:03:47.04,0:03:49.00,tanda,,0000,0000,0000,,AWAL
Dialogue: 0,0:06:27.91,0:06:28.85,tanda,,0000,0000,0000,,TUTUP
Dialogue: 0,0:07:44.99,0:07:47.03,tanda,,0000,0000,0000,,HARI PERTAMA
Dialogue: 0,0:08:12.76,0:08:14.27,tanda,,0000,0000,0000,,HARI KE-201
Dialogue: 0,0:08:20.02,0:08:23.02,tanda,,0000,0000,0000,,KLINIK KASUKABE
Dialogue: 0,0:09:15.70,0:09:17.41,tanda,,0000,0000,0000,,SEKARANG
Dialogue: 0,0:10:55.05,0:10:57.80,tanda,,0000,0000,0000,,GANG HOLE
Dialogue: 0,0:11:45.35,0:11:46.81,tanda,,0000,0000,0000,,KAWAN PERJALANAN
Dialogue: 0,0:19:38.82,0:19:42.33,tanda,,0000,0000,0000,,MALAM TERAKHIR BERDUA
Dialogue: 0,0:20:07.35,0:20:09.35,tanda,,0000,0000,0000,,MANDI MAGMA
Dialogue: 0,0:24:42.13,0:24:44.00,tanda,,0000,0000,0000,,AKHIR
Dialogue: 0,0:00:54.73,0:00:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma datang berkali-kali ke tempatku.
Dialogue: 0,0:00:57.54,0:01:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa mengubahmu jadi penyihir.
Dialogue: 0,0:01:01.07,0:01:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku itu pun kontennya bukan tentang itu.
Dialogue: 0,0:01:05.82,0:01:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bundel di belakang
Dialogue: 0,0:01:08.17,0:01:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mayat penyihir yang dibunuh asosiasi lokal?
Dialogue: 0,0:01:12.66,0:01:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk riset.
Dialogue: 0,0:01:17.18,0:01:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, itu bisa memberikan beberapa petunjuk\Nuntuk mengobati korban sihir.
Dialogue: 0,0:01:27.97,0:01:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua penyihir?
Dialogue: 0,0:01:30.95,0:01:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku diam-diam mengumpulkan\Npenyihir yang dibunuh asosiasi lokal.
Dialogue: 0,0:01:37.05,0:01:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu, Kasukabe,
Dialogue: 0,0:01:39.98,0:01:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terdengar seperti nama penyihir.
Dialogue: 0,0:01:42.77,0:01:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, istriku seorang penyihir.
Dialogue: 0,0:01:45.71,0:01:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dia sakit, aku terus berpikir\Npasti ada yang bisa kulakukan.
Dialogue: 0,0:01:50.13,0:01:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang membuatku meneliti penyihir.
Dialogue: 0,0:01:54.08,0:01:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istrimu seorang penyihir.
Dialogue: 0,0:01:56.72,0:01:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia mencampakkanku.
Dialogue: 0,0:01:59.43,0:02:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menerbitkan buku pertamaku,\Naku menggunakan nama istriku.
Dialogue: 0,0:02:03.48,0:02:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, bagaimana dengan keluargamu?
Dialogue: 0,0:02:06.15,0:02:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin diizinkan keluar selarut ini?
Dialogue: 0,0:02:09.61,0:02:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya kakekku,\Ntapi dia berjualan dan jarang pulang.
Dialogue: 0,0:02:14.72,0:02:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu ingin jadi penyihir?
Dialogue: 0,0:03:54.51,0:03:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.\NBerikutnya...
Dialogue: 0,0:04:14.78,0:04:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dengan pengobatan,
Dialogue: 0,0:04:16.82,0:04:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuh manusia tak bisa menahan\Nperubahan mendadak yang disebabkan sihir.
Dialogue: 0,0:04:21.74,0:04:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, kebanyakan pasien\Nmeninggal mendadak seperti itu.
Dialogue: 0,0:04:26.25,0:04:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin yang kulakukan ini percuma.
Dialogue: 0,0:04:30.33,0:04:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau, aku hanya...
Dialogue: 0,0:04:34.24,0:04:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini mati karena sihir, kan?\NKalian pasang pelatnya dengan benar, kan?
Dialogue: 0,0:04:41.30,0:04:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum obat ini setelah sarapan\Ndan makan malam.
Dialogue: 0,0:04:44.46,0:04:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:04:45.95,0:04:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:04:46.68,0:04:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai, sebentar lagi kita makan siang.
Dialogue: 0,0:04:51.30,0:04:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tahu apa langit ini\Nterhubung ke dunia sihir?
Dialogue: 0,0:04:55.82,0:04:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak kangen istrimu?
Dialogue: 0,0:04:59.32,0:05:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah setahun sejak kamu membantuku.
Dialogue: 0,0:05:06.06,0:05:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepulang kerja,\Nkenapa kamu selalu bersembunyi di lab?
Dialogue: 0,0:05:10.65,0:05:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu masih belum menyerah?
Dialogue: 0,0:05:17.57,0:05:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu sangat ingin jadi penyihir?
Dialogue: 0,0:05:22.51,0:05:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah tanya itu dulu.
Dialogue: 0,0:05:25.30,0:05:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak menjawabku waktu itu.
Dialogue: 0,0:05:29.78,0:05:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita, manusia di Hole\Nadalah mangsa mereka.
Dialogue: 0,0:05:34.17,0:05:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang membuatmu tak suka?
Dialogue: 0,0:05:36.63,0:05:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membantu korban sihir.\NItu yang membuatmu termotivasi, kan?
Dialogue: 0,0:05:42.81,0:05:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan orang seperti itu.
Dialogue: 0,0:05:46.81,0:05:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:05:53.58,0:05:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak dapat alasan untuk tinggal di kota ini.
Dialogue: 0,0:05:58.38,0:05:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bergegas!
Dialogue: 0,0:05:59.53,0:06:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asosiasi lokal melempar penyihir\Nke danau limbah!
Dialogue: 0,0:06:06.89,0:06:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jatuh ke dalam!
Dialogue: 0,0:06:11.15,0:06:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini campuran mematikan dari kotoran,\Nair limbah, dan mayat penyihir Hole.
Dialogue: 0,0:06:18.30,0:06:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil kita bisa mengeluarkannya.
Dialogue: 0,0:06:21.05,0:06:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya menyerah.
Dialogue: 0,0:06:23.60,0:06:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai?
Dialogue: 0,0:06:28.85,0:06:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai, bertahanlah!
Dialogue: 0,0:06:33.91,0:06:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air danau melelehkan dagingnya\Ndan masuk ke organ dalamnya.
Dialogue: 0,0:06:39.03,0:06:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah terlambat.
Dialogue: 0,0:06:42.78,0:06:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter...
Dialogue: 0,0:06:43.92,0:06:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai!
Dialogue: 0,0:06:45.41,0:06:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lihat buku catatanku.
Dialogue: 0,0:06:50.71,0:06:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang,\Nkamu memberikan ini padaku?
Dialogue: 0,0:06:53.99,0:06:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu mayat lagi.
Dialogue: 0,0:06:56.42,0:07:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada satu lagi mayat penyihir,\Nkita bisa melakukan operasi.
Dialogue: 0,0:07:01.88,0:07:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon, Dokter.
Dialogue: 0,0:07:04.70,0:07:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku mati, jadikan aku penyihir
Dialogue: 0,0:07:07.89,0:07:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski hanya untuk pertunjukan.
Dialogue: 0,0:07:15.84,0:07:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:07:18.11,0:07:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bisa mengubah\Nsedikit keputusasaanmu jadi harapan...
Dialogue: 0,0:07:32.44,0:07:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku gila?
Dialogue: 0,0:07:36.57,0:07:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan operasi pura-pura seperti ini...
Dialogue: 0,0:07:47.03,0:07:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa selamat itu sudah ajaib.
Dialogue: 0,0:07:49.24,0:07:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita masih harus melakukan\Nbeberapa operasi kecil lagi.
Dialogue: 0,0:07:53.43,0:07:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku mencatat\Nbagaimana tubuhmu sembuh.
Dialogue: 0,0:08:00.03,0:08:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa melakukan operasi itu\Nbisa mengubahnya jadi penyihir?
Dialogue: 0,0:08:05.99,0:08:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu mustahil.
Dialogue: 0,0:08:09.54,0:08:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil manusia bisa menciptakan penyihir.
Dialogue: 0,0:08:23.76,0:08:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter.
Dialogue: 0,0:08:24.72,0:08:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:08:25.53,0:08:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah sanggup berjalan lagi,\Nizinkan aku keluar sebentar.
Dialogue: 0,0:08:31.14,0:08:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, sekalian jernihkan pikiranmu.
Dialogue: 0,0:08:38.86,0:08:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter, saat aku jatuh ke danau itu,
Dialogue: 0,0:08:43.41,0:08:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lumpur dan kotoran busuk itu\Nmenyelimutiku sangat berat.
Dialogue: 0,0:08:47.43,0:08:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa jadi satu dengan Hole gila ini.
Dialogue: 0,0:08:51.93,0:08:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, begitu merangkak keluar dari sana,\Naku terlahir kembali.
Dialogue: 0,0:08:58.89,0:09:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Kasukabe.
Dialogue: 0,0:09:00.92,0:09:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya jadi penyihir.
Dialogue: 0,0:09:09.41,0:09:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keesokan harinya, mayat Ai ditemukan.
Dialogue: 0,0:09:17.41,0:09:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat Ai menghilang.
Dialogue: 0,0:09:20.61,0:09:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, ada dua kemungkinan berbeda.
Dialogue: 0,0:09:25.92,0:09:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe, aku sudah baca beberapa\Ndokumen dari 13 tahun lalu.
Dialogue: 0,0:09:30.22,0:09:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai Coleman, nomor pelat 96925.
Dialogue: 0,0:09:34.85,0:09:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor ini...
Dialogue: 0,0:09:38.22,0:09:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus makan bersama\Norang-orang yang menggali kuburan cucuku?
Dialogue: 0,0:09:43.55,0:09:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuburannya kosong,\Nmemangnya ada masalah?
Dialogue: 0,0:09:47.03,0:09:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, ke mana mayatnya?
Dialogue: 0,0:09:49.86,0:09:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana mayat cucuku?
Dialogue: 0,0:09:54.20,0:09:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dokter!\N- Maaf menunggu!
Dialogue: 0,0:09:56.39,0:09:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dari mana?
Dialogue: 0,0:09:57.99,0:10:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Balai Hole,\Ntapi mereka belum menemukan pelatnya.
Dialogue: 0,0:10:03.37,0:10:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok lilin yang kulihat\Ndi rumah itu adalah Ai.
Dialogue: 0,0:10:07.38,0:10:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?\NApa yang terjadi dengan cucuku?
Dialogue: 0,0:10:09.38,0:10:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai, jadi itu namanya, ya.
Dialogue: 0,0:10:12.76,0:10:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coleman, kamu mungkin tak sadar,
Dialogue: 0,0:10:15.18,0:10:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku mengoperasi Ai\Nuntuk mengubahnya jadi penyihir.
Dialogue: 0,0:10:19.39,0:10:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:10:20.64,0:10:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Kakek bawel!
Dialogue: 0,0:10:22.64,0:10:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu maksud dari berkas itu, ya.
Dialogue: 0,0:10:25.48,0:10:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coleman, Ai mungkin\Nmasih hidup di dunia sihir.
Dialogue: 0,0:10:30.40,0:10:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:10:31.61,0:10:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam dulu!
Dialogue: 0,0:10:34.18,0:10:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau kembali ke dunia sihir\Ndan mencari Ai.
Dialogue: 0,0:10:38.78,0:10:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ikut.\NAku tak akan pergi!
Dialogue: 0,0:10:42.54,0:10:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe.
Dialogue: 0,0:10:44.65,0:10:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Noi berencana\Nmembunuh bos Mata Silang.
Dialogue: 0,0:10:48.54,0:10:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku tahu.
Dialogue: 0,0:10:52.93,0:10:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bakal hujan.
Dialogue: 0,0:10:55.95,0:10:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pergi, Noi.
Dialogue: 0,0:10:57.80,0:10:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas makanannya.
Dialogue: 0,0:10:59.46,0:11:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang akan bayar?
Dialogue: 0,0:11:03.06,0:11:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, penyihir!
Dialogue: 0,0:11:05.06,0:11:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Kasukabe.
Dialogue: 0,0:11:06.94,0:11:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu harus bisa jaga dirimu sendiri.
Dialogue: 0,0:11:10.40,0:11:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengandalkanku.
Dialogue: 0,0:11:13.69,0:11:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vaux, tolong bayar makanannya.
Dialogue: 0,0:11:17.20,0:11:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku tak akan kembali\Nuntuk sementara waktu.
Dialogue: 0,0:11:19.70,0:11:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:11:21.20,0:11:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pergi dulu.
Dialogue: 0,0:11:23.27,0:11:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coleman, nanti akan kukabari\Nkalau aku menemukan Ai.
Dialogue: 0,0:11:27.15,0:11:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jonson?
Dialogue: 0,0:11:33.59,0:11:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua penyihir?
Dialogue: 0,0:11:36.09,0:11:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?
Dialogue: 0,0:11:38.47,0:11:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena leher ini, butuh waktu lama\Nuntuk menelan makanan!
Dialogue: 0,0:11:46.81,0:11:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Ebisu.
Dialogue: 0,0:11:48.90,0:11:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Hole, aku diserang pria berwajah kadal
Dialogue: 0,0:11:51.72,0:11:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan lupa siapa diriku sebenarnya.
Dialogue: 0,0:11:54.29,0:11:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat jamur aneh En,\Naku ingat orang tuaku
Dialogue: 0,0:11:58.24,0:12:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ingat siapa diriku sebenarnya.
Dialogue: 0,0:12:01.12,0:12:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bisa pulang.
Dialogue: 0,0:12:03.62,0:12:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehidupan di rumah En brutal.
Dialogue: 0,0:12:06.58,0:12:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyesal, tapi...
Dialogue: 0,0:12:09.08,0:12:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:12:12.11,0:12:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung senggang,\Njadi aku ingin mengantarmu.
Dialogue: 0,0:12:17.70,0:12:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, katakan sesuatu.
Dialogue: 0,0:12:19.64,0:12:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan bicara hal yang tak penting.
Dialogue: 0,0:12:22.39,0:12:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penyihir yang tenang dan pendiam.
Dialogue: 0,0:12:25.81,0:12:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!
Dialogue: 0,0:12:26.84,0:12:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampah.
Dialogue: 0,0:12:28.77,0:12:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:12:30.35,0:12:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan buru-buru naik kereta\Nkarena sangat berbahaya.
Dialogue: 0,0:12:36.43,0:12:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mencoba menggunakan sihir padaku, ya?
Dialogue: 0,0:12:39.11,0:12:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa pulang dengan penampilan ini.
Dialogue: 0,0:12:42.01,0:12:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus ganti baju.
Dialogue: 0,0:12:44.35,0:12:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia pikirkan?
Dialogue: 0,0:12:52.15,0:12:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!\NSialan!
Dialogue: 0,0:12:56.70,0:12:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke toilet?
Dialogue: 0,0:12:57.92,0:13:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tak dapat baju bagus\Ndari tempat En.
Dialogue: 0,0:13:03.37,0:13:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku mengenalku\Nsebagai gadis normal dan manis.
Dialogue: 0,0:13:07.52,0:13:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan marah kalau aku\Nmuncul seperti ini.
Dialogue: 0,0:13:10.69,0:13:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaun yang kupesan rusak gara-gara Fujita.
Dialogue: 0,0:13:15.69,0:13:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lingerinya bahkan tak muat.
Dialogue: 0,0:13:17.69,0:13:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaun tulang ini\Nmembuat celana dalam kelihatan.
Dialogue: 0,0:13:19.95,0:13:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju jelek Fujita\Ndari saat aku pergi ke Hole.
Dialogue: 0,0:13:22.95,0:13:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seragam aneh ini juga sama jeleknya.
Dialogue: 0,0:13:35.84,0:13:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tak usah pusingkan soal baju.
Dialogue: 0,0:13:38.38,0:13:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menghilang selama ini.
Dialogue: 0,0:13:41.18,0:13:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu akan senang aku pulang.
Dialogue: 0,0:13:45.10,0:13:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lama, ya.\NApa kamu diare lagi?
Dialogue: 0,0:13:48.68,0:13:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:13:51.84,0:13:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya bicara juga, ya.
Dialogue: 0,0:13:57.11,0:14:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menyingkirkan pria ini.
Dialogue: 0,0:14:00.03,0:14:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus minta tolong\Nkawan-kawan Black Tent-ku.
Dialogue: 0,0:14:05.95,0:14:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!\NApa ini rumahmu?
Dialogue: 0,0:14:09.45,0:14:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga, keluargamu berantakan!
Dialogue: 0,0:14:12.96,0:14:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:14:14.71,0:14:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Ebisu.\NLama tak jumpa.
Dialogue: 0,0:14:18.07,0:14:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NAda orang aneh yang mengikutimu?
Dialogue: 0,0:14:20.34,0:14:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil jalan keluar di belakang.
Dialogue: 0,0:14:22.37,0:14:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oda akan menunjukkan jalannya.
Dialogue: 0,0:14:24.72,0:14:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Oda.\NAku akan mengantarmu ke pintu keluar.
Dialogue: 0,0:14:27.35,0:14:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pria ini?\NAku belum pernah melihatnya.
Dialogue: 0,0:14:30.53,0:14:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?\NIni bukan rumahmu?
Dialogue: 0,0:14:34.13,0:14:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tunggu!
Dialogue: 0,0:14:36.26,0:14:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:14:37.40,0:14:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, buka!
Dialogue: 0,0:14:38.72,0:14:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Ebisu, kan?
Dialogue: 0,0:14:40.69,0:14:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa bubuk hitam?\NAkhir-akhir ini aku susah dapat.
Dialogue: 0,0:14:44.87,0:14:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubuk hitam...
Dialogue: 0,0:14:47.35,0:14:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu tak mau bicara\Npada orang baru sepertiku?
Dialogue: 0,0:14:50.79,0:14:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:14:57.29,0:14:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang!\NSampai rumah!
Dialogue: 0,0:15:02.84,0:15:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu mungkin akan kaget.
Dialogue: 0,0:15:05.22,0:15:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar!
Dialogue: 0,0:15:07.76,0:15:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan siapa?
Dialogue: 0,0:15:11.54,0:15:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:15:13.52,0:15:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Ebisu.
Dialogue: 0,0:15:17.63,0:15:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong! Kamu bohong!\NAku Ebisu, Bodoh!
Dialogue: 0,0:15:22.28,0:15:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, Ibu!
Dialogue: 0,0:15:31.31,0:15:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tak ada di sini.
Dialogue: 0,0:15:33.12,0:15:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu tak ada di sini.
Dialogue: 0,0:15:35.21,0:15:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pergi bekerja,\Ntapi tak pernah kembali.
Dialogue: 0,0:15:40.21,0:15:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:15:41.71,0:15:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Ebisu, putri keluarga ini!\NKamu yang siapa?
Dialogue: 0,0:15:48.62,0:15:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga Ebisu.
Dialogue: 0,0:15:50.97,0:15:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya wajah yang sama denganku?
Dialogue: 0,0:15:55.98,0:15:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Doppelganger!
Dialogue: 0,0:16:02.59,0:16:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:16:13.41,0:16:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas, dia pergi.
Dialogue: 0,0:16:16.46,0:16:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengasuh!
Dialogue: 0,0:16:17.71,0:16:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, kamu masih hidup, ya!
Dialogue: 0,0:16:20.96,0:16:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengasuh!
Dialogue: 0,0:16:22.96,0:16:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, kamu nonaku yang asli!
Dialogue: 0,0:16:26.83,0:16:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Ayah dan Ibu?
Dialogue: 0,0:16:28.22,0:16:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kamu menghilang,
Dialogue: 0,0:16:31.47,0:16:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang tuamu patah hati.
Dialogue: 0,0:16:35.46,0:16:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, ayahmu mengundang\Npenyihir mencurigakan ke wastu.
Dialogue: 0,0:16:41.36,0:16:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirku sangat ampuh sampai membuat\Numurku makin pendek tiap kali kugunakan.
Dialogue: 0,0:16:46.07,0:16:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, biaya jasanya akan mahal.\NKalian yakin?
Dialogue: 0,0:16:48.86,0:16:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa pun, akan kami bayar!\NTolong selamatkan putri kami.
Dialogue: 0,0:16:52.37,0:16:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rambut putri kami.
Dialogue: 0,0:16:54.62,0:16:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.\NSekarang, taruh rambut itu di dahiku.
Dialogue: 0,0:17:01.12,0:17:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:14.51,0:17:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, buka tutupnya\Ndan keluarkan isinya!
Dialogue: 0,0:17:17.52,0:17:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya!
Dialogue: 0,0:17:24.90,0:17:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, keluarkan!
Dialogue: 0,0:17:55.98,0:17:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu keluarlah dia.
Dialogue: 0,0:17:58.60,0:18:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, Tuan memperlakukannya dengan manja.
Dialogue: 0,0:18:02.60,0:18:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar, dia identik denganmu,
Dialogue: 0,0:18:05.61,0:18:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi di dalam, dia sangat berbeda.
Dialogue: 0,0:18:08.48,0:18:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena takut, Tuan dan Nyonya\Nmeninggalkan wastu dan kabur.
Dialogue: 0,0:18:16.60,0:18:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengasuh, kukisnya hangus.
Dialogue: 0,0:18:18.91,0:18:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukisku yang berharga hangus.
Dialogue: 0,0:18:21.37,0:18:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dipecat.
Dialogue: 0,0:18:25.42,0:18:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu sama denganku.
Dialogue: 0,0:18:28.70,0:18:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.\NKamu peniruku, ya?
Dialogue: 0,0:18:42.39,0:18:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, aku bisa mati!
Dialogue: 0,0:19:11.86,0:19:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal dua kantong.
Dialogue: 0,0:19:38.82,0:19:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, tambah lagi tiga porsi!
Dialogue: 0,0:19:42.33,0:19:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hari ini banyak pelanggan datang.
Dialogue: 0,0:19:44.83,0:19:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kerja lebih keras, Pekerja Paruh Waktu!
Dialogue: 0,0:19:49.33,0:19:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, dia memeras tenaga kita.
Dialogue: 0,0:19:51.67,0:19:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan.
Dialogue: 0,0:19:52.96,0:19:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kurang untuk bayar sewa,\Nkita masih harus menafkahi lima orang.
Dialogue: 0,0:19:57.09,0:19:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya enak, ya.
Dialogue: 0,0:19:59.68,0:20:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pekerjaan yang suram.
Dialogue: 0,0:20:02.10,0:20:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos sebentar lagi kembali.\NBersabarlah.
Dialogue: 0,0:20:05.06,0:20:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu makan?
Dialogue: 0,0:20:14.13,0:20:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berteman dengan Risu\Ndan murid di sekolah itu.
Dialogue: 0,0:20:18.35,0:20:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tahu identitas asliku.
Dialogue: 0,0:20:22.73,0:20:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kecemasan apa yang kurasakan ini?
Dialogue: 0,0:20:28.79,0:20:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga aku bisa bertemu Bos.
Dialogue: 0,0:20:31.38,0:20:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos orangnya seperti apa?
Dialogue: 0,0:20:33.55,0:20:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat kuat.
Dialogue: 0,0:20:35.76,0:20:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia penyelamat bagi orang-orang\Nseperti kami yang tak bisa sihir.
Dialogue: 0,0:20:40.70,0:20:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi selir Bos.
Dialogue: 0,0:20:43.97,0:20:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jadi selirnya Abang juga aku mau.
Dialogue: 0,0:20:49.80,0:20:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju ini aneh.
Dialogue: 0,0:20:50.98,0:20:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru membuat tato salib\Ndan rasanya menyengat.
Dialogue: 0,0:20:54.76,0:20:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membawakan kalian makanan.
Dialogue: 0,0:20:56.78,0:20:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya enak!
Dialogue: 0,0:20:59.43,0:21:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sake lokal, gratis.
Dialogue: 0,0:21:06.30,0:21:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tadi cuma perasaanku saja?
Dialogue: 0,0:21:08.04,0:21:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang, satu lagi!
Dialogue: 0,0:21:14.57,0:21:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua terlalu banyak minum.
Dialogue: 0,0:21:16.55,0:21:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa.\NNikaido, ikut minum juga!
Dialogue: 0,0:21:18.88,0:21:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susyi kecil ini enak.
Dialogue: 0,0:21:22.39,0:21:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Caiman gembira lagi\Nberkat sake dan makanannya.
Dialogue: 0,0:21:26.14,0:21:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:21:27.64,0:21:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang, aku padamu.\NCium!
Dialogue: 0,0:21:33.56,0:21:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki tak sadar silang\Ndi mata Caiman menghilang?
Dialogue: 0,0:21:46.27,0:21:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Nikaido?
Dialogue: 0,0:21:48.66,0:21:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temani aku minum.
Dialogue: 0,0:21:51.82,0:21:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:56.07,0:21:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bertingkah aneh sejak kita pergi\Nke sekolah terbengkalai itu,
Dialogue: 0,0:21:59.59,0:22:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku khawatir.
Dialogue: 0,0:22:01.09,0:22:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu cemas.
Dialogue: 0,0:22:03.77,0:22:05.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Caiman.
Dialogue: 0,0:22:05.10,0:22:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau semua ingatanmu kembali,
Dialogue: 0,0:22:07.72,0:22:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kamu akan tetap hidup di dunia ini\Nsebagai Mata Silang
Dialogue: 0,0:22:11.81,0:22:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersama Natsuki dan yang lainnya?
Dialogue: 0,0:22:13.85,0:22:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku sendiri belum tahu.
Dialogue: 0,0:22:17.32,0:22:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya untuk saat ini,\Naku berencana kembali ke Hole.
Dialogue: 0,0:22:21.36,0:22:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu menanyakan itu?
Dialogue: 0,0:22:24.06,0:22:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman, sudah lama aku ingin\Nmenanyakan ini padamu.
Dialogue: 0,0:22:29.88,0:22:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kamu kembali normal,\Nmaukah bantu di restoranku?
Dialogue: 0,0:22:34.87,0:22:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:35.88,0:22:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku berencana memberitahumu\Nsetelah semua masalahmu beres.
Dialogue: 0,0:22:40.99,0:22:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi entah kenapa,\Naku harus bertanya padamu sekarang.
Dialogue: 0,0:22:45.97,0:22:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu yakin menerima orang sepertiku?
Dialogue: 0,0:22:51.39,0:22:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku mohon, Caiman.
Dialogue: 0,0:22:55.46,0:22:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido.
Dialogue: 0,0:22:57.34,0:23:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bangkrut\Nkalau kamu tetap jadi pelanggan.
Dialogue: 0,0:23:00.61,0:23:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbaik!
Dialogue: 0,0:23:03.14,0:23:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prediksiku benar.
Dialogue: 0,0:23:06.22,0:23:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena, malam itu kali terakhir\Naku bicara dengan Caiman.
Dialogue: 0,0:24:44.00,0:24:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini di Episode 17.
Dialogue: 0,0:24:46.46,0:24:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu bernama Ai.
Dialogue: 0,0:24:48.26,0:24:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu berasal dari keluarga terhormat.
Dialogue: 0,0:24:50.18,0:24:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman dan Nikaido terlihat mesra.
Dialogue: 0,0:24:52.60,0:24:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan kita ketahui di Episode 18,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:24:56.43,0:24:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
