Dialogue: 0,0:00:02.15,0:00:05.99,tanda,,0000,0000,0000,,MUSIM KEDUA
Dialogue: 0,0:00:06.99,0:00:09.41,tanda,,0000,0000,0000,,RUMAHKU, ISTANAKU
Dialogue: 0,0:07:24.01,0:07:25.97,tanda,,0000,0000,0000,,AWAL
Dialogue: 0,0:09:23.25,0:09:25.96,tanda,,0000,0000,0000,,SEKOLAH PELATIHAN SIHIR ZAGAN SELATAN
Dialogue: 0,0:15:07.93,0:15:10.64,tanda,,0000,0000,0000,,INGATAN BERKECAMUK
Dialogue: 0,0:16:42.94,0:16:45.44,tanda,,0000,0000,0000,,KASHIWABARA, NAKATA
Dialogue: 0,0:16:59.29,0:17:00.33,tanda,,0000,0000,0000,,RISU
Dialogue: 0,0:18:22.50,0:18:25.00,tanda,,0000,0000,0000,,RUANG UKS
Dialogue: 0,0:20:22.12,0:20:25.12,tanda,,0000,0000,0000,,KEMBALI KE RUMAH
Dialogue: 0,0:20:57.52,0:20:58.74,tanda,,0000,0000,0000,,SUBJEK UJI: AI COLEMAN
Dialogue: 0,0:21:52.96,0:21:54.96,tanda,,0000,0000,0000,,COLEMAN
Dialogue: 0,0:25:22.67,0:25:23.96,tanda,,0000,0000,0000,,AKHIR
Dialogue: 0,0:00:09.41,0:00:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuat susyi ini.
Dialogue: 0,0:00:11.41,0:00:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka aku akan makan\Nhidangan buatanmu, En!
Dialogue: 0,0:00:15.05,0:00:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, makan.
Dialogue: 0,0:00:16.79,0:00:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susyi dengan daging mentah?
Dialogue: 0,0:00:18.45,0:00:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bahkan potong dagingnya\Nmenjadi bentuk jamur.
Dialogue: 0,0:00:21.00,0:00:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipikal dirimu, En.
Dialogue: 0,0:00:22.63,0:00:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh makan daging\Nbagian atasnya saja?
Dialogue: 0,0:00:30.64,0:00:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak! Ini enak banget!
Dialogue: 0,0:00:32.22,0:00:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak dan berlemak!
Dialogue: 0,0:00:33.64,0:00:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tambah sausnya!
Dialogue: 0,0:00:37.56,0:00:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Di mana kita?
Dialogue: 0,0:00:39.27,0:00:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susyinya habis!
Dialogue: 0,0:00:40.85,0:00:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini tidak ada apa pun!
Dialogue: 0,0:00:42.06,0:00:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang pasti menggunakan sihir
Dialogue: 0,0:00:44.36,0:00:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membuat semuanya\Nkecuali kita menghilang.
Dialogue: 0,0:00:48.49,0:00:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chota, lama tak bertemu.
Dialogue: 0,0:00:50.63,0:00:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:53.35,0:00:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali normal!
Dialogue: 0,0:00:55.12,0:00:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, semuanya.\NKita sedang di dalam mimpi.
Dialogue: 0,0:00:58.75,0:01:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En!
Dialogue: 0,0:01:00.00,0:01:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam mimpi?
Dialogue: 0,0:01:01.46,0:01:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, jamur susyi ini\Njenis baru dari peternakanku.
Dialogue: 0,0:01:07.03,0:01:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Mesin Impian.
Dialogue: 0,0:01:09.63,0:01:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan daging?\NKejam!
Dialogue: 0,0:01:12.55,0:01:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibelah, dalamnya seperti daging.\NBahkan rasanya pun mirip.
Dialogue: 0,0:01:17.68,0:01:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamur ini bisa membuat kita tidur pulas\Ndan memimpikan hal yang kita inginkan.
Dialogue: 0,0:01:23.60,0:01:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau beberapa orang memakannya sekaligus,\Nsemuanya bisa berbagi mimpi yang sama.
Dialogue: 0,0:01:27.40,0:01:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meong.
Dialogue: 0,0:01:28.65,0:01:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan depan, aku berencana meluncurkannya\Ndengan merek makananku.
Dialogue: 0,0:01:32.74,0:01:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kalian semua\Njadi subjek uji coba.
Dialogue: 0,0:01:35.77,0:01:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi yang kuinginkan?\NBerarti...
Dialogue: 0,0:01:42.44,0:01:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap!\NMesin Impian ini hebat!
Dialogue: 0,0:01:46.03,0:01:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu besar sekali.
Dialogue: 0,0:01:48.88,0:01:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido, kenapa wujudmu menjadi Chota?
Dialogue: 0,0:01:50.99,0:01:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:01:51.84,0:01:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mu-Mungkin karena aku memikirkan Chota.
Dialogue: 0,0:01:56.43,0:02:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak ada akhir-akhir ini,\Njadi kupikir kamu merindukannya.
Dialogue: 0,0:02:01.60,0:02:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil. Kembali jadi normal,\Nmerusak pemandangan saja.
Dialogue: 0,0:02:07.84,0:02:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini Hole?
Dialogue: 0,0:02:10.50,0:02:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasanya, kotanya kotor.
Dialogue: 0,0:02:15.85,0:02:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan.
Dialogue: 0,0:02:16.91,0:02:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada si kadal sialan dan Nikaido.
Dialogue: 0,0:02:24.32,0:02:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En, mundur!
Dialogue: 0,0:02:37.25,0:02:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Bos?\NMesin Impian memang luar biasa!
Dialogue: 0,0:02:42.75,0:02:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu, mimpimu...
Dialogue: 0,0:02:45.71,0:02:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jadi, lupakan.
Dialogue: 0,0:02:47.96,0:02:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga,
Dialogue: 0,0:02:48.82,0:02:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya ini akan laris\Nuntuk Fujita yang benci kenyataan.
Dialogue: 0,0:02:53.28,0:02:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido, apa yang kamu inginkan?
Dialogue: 0,0:02:56.78,0:02:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:02:57.99,0:02:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci kamu, En!
Dialogue: 0,0:02:59.73,0:03:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah marah?
Dialogue: 0,0:03:01.16,0:03:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Nikaido!
Dialogue: 0,0:03:02.50,0:03:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahuku pegal.
Dialogue: 0,0:03:04.37,0:03:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita, kamu bawahan yang hebat.
Dialogue: 0,0:03:07.42,0:03:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu semua kekayaanku.
Dialogue: 0,0:03:09.63,0:03:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujita, kamu panutanku.
Dialogue: 0,0:03:23.43,0:03:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu aku?
Dialogue: 0,0:03:30.09,0:03:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:03:36.07,0:03:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah ini...
Dialogue: 0,0:03:44.33,0:03:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topeng ini...
Dialogue: 0,0:03:46.69,0:03:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini topengku.
Dialogue: 0,0:04:00.39,0:04:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisu.
Dialogue: 0,0:04:03.39,0:04:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa studi sihirmu berjalan lancar?
Dialogue: 0,0:04:05.85,0:04:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengandalkanmu, Ebisu.
Dialogue: 0,0:04:11.48,0:04:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama... Papa...
Dialogue: 0,0:04:18.27,0:04:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin Impian ini bagus, ya!
Dialogue: 0,0:04:20.45,0:04:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan makan jamur itu tiap hari\Nagar ke depannya terus sempurna!
Dialogue: 0,0:04:23.62,0:04:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meong!
Dialogue: 0,0:04:24.70,0:04:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersihkan yang benar, ya, Ebisu!
Dialogue: 0,0:04:27.37,0:04:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Tuan.
Dialogue: 0,0:04:29.46,0:04:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, makan malam sudah siap.
Dialogue: 0,0:04:32.50,0:04:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah, ya?
Dialogue: 0,0:04:39.84,0:04:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini?
Dialogue: 0,0:04:41.89,0:04:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah buang semua barang tak berguna?
Dialogue: 0,0:04:44.06,0:04:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah buang barang tak berguna?
Dialogue: 0,0:04:46.56,0:04:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, En.
Dialogue: 0,0:04:48.06,0:04:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-En...
Dialogue: 0,0:04:50.96,0:04:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}En! Semuanya!
Dialogue: 0,0:04:52.81,0:04:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku, Fujita!\NTungg—
Dialogue: 0,0:04:57.36,0:04:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:04:58.32,0:04:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido!
Dialogue: 0,0:05:04.08,0:05:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Pengering rambut?
Dialogue: 0,0:05:08.12,0:05:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hentikan!
Dialogue: 0,0:05:09.58,0:05:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamur ini tidak tahan kering!
Dialogue: 0,0:05:15.42,0:05:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:05:17.05,0:05:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adegan yang kutakutkan\Njauh di lubuk hatiku.
Dialogue: 0,0:05:20.70,0:05:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar mimpi buruk!
Dialogue: 0,0:05:22.54,0:05:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Mesin Impian punya efek\Nseperti ini juga?
Dialogue: 0,0:05:28.22,0:05:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meong.
Dialogue: 0,0:05:29.73,0:05:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ga-Gawat.
Dialogue: 0,0:05:32.14,0:05:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerut.
Dialogue: 0,0:05:38.18,0:05:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Mesin Impian itu jamur\Nyang bisa membuat kita
Dialogue: 0,0:05:41.78,0:05:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihat segala jenis cerminan.
Dialogue: 0,0:05:45.03,0:05:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, para subjek uji cobaku.\NMenurut kalian ini akan laku?
Dialogue: 0,0:05:49.58,0:05:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:05:53.11,0:05:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama... Papa...
Dialogue: 0,0:07:28.47,0:07:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:07:29.97,0:07:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dipikir,
Dialogue: 0,0:07:32.42,0:07:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga sialan itu bisa membunuhku,\Ntapi dia tak melakukannya.
Dialogue: 0,0:07:37.48,0:07:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya tahu\Nsiapa yang membunuhku dan alasannya.
Dialogue: 0,0:07:42.98,0:07:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Silang.
Dialogue: 0,0:07:45.07,0:07:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku bergabung\Ndengan organisasi seperti ini?
Dialogue: 0,0:07:50.02,0:07:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil, aku tak bisa\Nmenghasilkan asap sihir.
Dialogue: 0,0:07:55.02,0:07:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sebenarnya ada\Nbeberapa orang sepertiku.
Dialogue: 0,0:07:58.71,0:08:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang bisa menghasilkan asap,\Ntapi hanya sedikit.
Dialogue: 0,0:08:01.71,0:08:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu orang-orang dengan sihir tak berguna.
Dialogue: 0,0:08:04.38,0:08:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekelompok orang seperti itu
Dialogue: 0,0:08:07.33,0:08:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Mata Silang.
Dialogue: 0,0:08:09.68,0:08:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar elite sialan.
Dialogue: 0,0:08:11.64,0:08:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyantap makanan mewah\Ndi restoran kelas atas.
Dialogue: 0,0:08:16.14,0:08:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu, bantu aku.
Dialogue: 0,0:08:18.47,0:08:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:19.65,0:08:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Satu, dua!
Dialogue: 0,0:08:24.28,0:08:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beres. Pergilah.
Dialogue: 0,0:08:30.56,0:08:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu, kamu tahu ke mana mereka dibawa?
Dialogue: 0,0:08:34.87,0:08:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:08:36.25,0:08:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhnya dibawa ke fasilitas\Npenelitian di Berith.
Dialogue: 0,0:08:39.23,0:08:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kepalanya dibawa ke Bos, kan?
Dialogue: 0,0:08:41.25,0:08:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos menggunakan tubuh\Npara penyihir elite itu
Dialogue: 0,0:08:45.34,0:08:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menjadi penyihir terkuat.
Dialogue: 0,0:08:48.30,0:08:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia mencoba menyelamatkan kita,\Nrekan dia.
Dialogue: 0,0:08:51.93,0:08:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, bubuk hitam ini.
Dialogue: 0,0:08:54.39,0:08:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat ini sebagai imbalan hasil kerja.
Dialogue: 0,0:08:57.02,0:08:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:09:07.68,0:09:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubuk hitam adalah harapan kami.
Dialogue: 0,0:09:10.61,0:09:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bahkan bubuk hitam itu\Ntidak berhasil padaku.
Dialogue: 0,0:09:15.87,0:09:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu, kamu habiskan gajimu untuk apa?
Dialogue: 0,0:09:19.87,0:09:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku berpikir untuk sekolah.
Dialogue: 0,0:09:23.25,0:09:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah? Serius?
Dialogue: 0,0:09:27.38,0:09:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius.
Dialogue: 0,0:09:29.34,0:09:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau belajar di sekolah,\Nmungkin aku bisa menghasilkan asap.
Dialogue: 0,0:09:33.22,0:09:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan, ini murid baru.
Dialogue: 0,0:09:35.83,0:09:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Risu, yang akan ada di kelas ini.
Dialogue: 0,0:09:38.72,0:09:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:09:39.77,0:09:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanda di matanya.
Dialogue: 0,0:09:41.27,0:09:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya, Mata Silang.\N- Apa dia ada rencana khusus ke sini?
Dialogue: 0,0:09:44.80,0:09:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku akan mulai pelajarannya.
Dialogue: 0,0:09:51.59,0:09:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil! Keluar asap!
Dialogue: 0,0:09:52.57,0:09:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil macam apaan itu?
Dialogue: 0,0:09:55.62,0:09:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangatmu kurang!
Dialogue: 0,0:09:56.74,0:10:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti ini akan membantuku\Nbisa menggunakan sihir?
Dialogue: 0,0:10:00.12,0:10:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku buang-buang uang.
Dialogue: 0,0:10:02.33,0:10:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang menyuruhmu duduk?
Dialogue: 0,0:10:05.20,0:10:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:10:07.34,0:10:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, meskipun kamu guru...
Dialogue: 0,0:10:09.80,0:10:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!\NMana semangatnya?
Dialogue: 0,0:10:12.80,0:10:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aikawa.
Dialogue: 0,0:10:14.80,0:10:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Guru, kamu terlihat tegang, ya?
Dialogue: 0,0:10:17.72,0:10:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau cicip sedikit bentoku?
Dialogue: 0,0:10:21.81,0:10:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Hari ini kalian belajar mandiri!
Dialogue: 0,0:10:26.81,0:10:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Aikawa.
Dialogue: 0,0:10:29.61,0:10:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:10:32.10,0:10:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belikan aku makan siang dan kita impas.
Dialogue: 0,0:10:35.66,0:10:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa selalu minta itu.
Dialogue: 0,0:10:42.98,0:10:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Risu, sekolahnya seru?
Dialogue: 0,0:10:46.29,0:10:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan, di sana penuh\Ndengan orang-orang riang.
Dialogue: 0,0:10:50.74,0:10:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak bisa menggunakan sihir\Nhanya dengan belajar.
Dialogue: 0,0:10:55.91,0:10:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu, Risu?
Dialogue: 0,0:10:57.47,0:11:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Organisasi membeli\Ngedung apartemen ini baru-baru ini.
Dialogue: 0,0:11:01.02,0:11:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang tinggal di tempat seperti ini?
Dialogue: 0,0:11:03.14,0:11:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, mungkin beberapa eksekutif.
Dialogue: 0,0:11:07.48,0:11:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:11:08.40,0:11:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kalian lihat, sihir langka
Dialogue: 0,0:11:10.90,0:11:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terdiri dari memanipulasi,
Dialogue: 0,0:11:13.07,0:11:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}restorasi, kehidupan, waktu, dan sebagainya.
Dialogue: 0,0:11:15.57,0:11:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Karena itu...\N- Oi.
Dialogue: 0,0:11:16.66,0:11:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maruyama dan Tachibana\Nbelakangan ini tidak kelihatan, ya.
Dialogue: 0,0:11:19.70,0:11:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak sekolah?
Dialogue: 0,0:11:21.33,0:11:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, mereka tidak ada.
Dialogue: 0,0:11:23.54,0:11:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Shimamura\Ndari Kelas 3 juga menghilang.
Dialogue: 0,0:11:26.17,0:11:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami terlambat.
Dialogue: 0,0:11:29.61,0:11:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, kenapa wajah kalian bonyok begitu?
Dialogue: 0,0:11:34.38,0:11:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami cuma jatuh.
Dialogue: 0,0:11:39.18,0:11:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga, dalam kasus yang sangat langka,
Dialogue: 0,0:11:41.06,0:11:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penyihir bisa memiliki kekuatan kutukan.
Dialogue: 0,0:11:43.81,0:11:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang punya kekuatan seperti itu,
Dialogue: 0,0:11:46.56,0:11:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Silang tak akan tinggal diam.
Dialogue: 0,0:11:49.06,0:11:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ketemu juga! Risu!
Dialogue: 0,0:11:51.32,0:11:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru memanggilmu.
Dialogue: 0,0:11:52.94,0:11:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku?
Dialogue: 0,0:11:56.28,0:11:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:11:58.32,0:12:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu datang juga, murid baru.
Dialogue: 0,0:12:00.82,0:12:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, masuklah.
Dialogue: 0,0:12:04.87,0:12:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut dokumen,\Nkamu tak bisa membuat asap sama sekali.
Dialogue: 0,0:12:08.92,0:12:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu benar, Risu?
Dialogue: 0,0:12:11.28,0:12:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:11.92,0:12:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:12:13.00,0:12:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kamu hadir setiap hari,
Dialogue: 0,0:12:15.51,0:12:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada yang tahu berapa lama\Nkamu akan lulus.
Dialogue: 0,0:12:19.26,0:12:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tak akan mudah.
Dialogue: 0,0:12:21.01,0:12:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu sekarang, ini masalahnya.
Dialogue: 0,0:12:23.01,0:12:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus beli Gelang Sihir ini\Nsebagai bahan pendidikanmu.
Dialogue: 0,0:12:28.67,0:12:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harganya 50 ribu nick.
Dialogue: 0,0:12:31.11,0:12:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai ini, kamu bisa\Nmenghasilkan asap dalam waktu singkat.
Dialogue: 0,0:12:35.97,0:12:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, kamu itu pengajar\Ndan malah menjual barang palsu?
Dialogue: 0,0:12:40.28,0:12:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, beraninya menentang guru—
Dialogue: 0,0:12:44.83,0:12:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:12:46.12,0:12:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ancaman tak akan mempan padaku.
Dialogue: 0,0:12:48.62,0:12:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, tak akan kumaafkan!\NMati sana!
Dialogue: 0,0:12:53.32,0:12:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku tidak sengaja dengar.
Dialogue: 0,0:12:56.71,0:12:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aikawa! Kamu!
Dialogue: 0,0:12:58.72,0:13:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu yang membuat\Norang-orang terluka dan menghilang?
Dialogue: 0,0:13:05.60,0:13:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa, kamu selalu saja mengganggu!
Dialogue: 0,0:13:09.69,0:13:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati sana!
Dialogue: 0,0:13:18.86,0:13:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:13:20.68,0:13:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia bangun,\Nkita mungkin akan dikeluarkan.
Dialogue: 0,0:13:23.91,0:13:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman.
Dialogue: 0,0:13:24.88,0:13:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:25.78,0:13:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya rencana.
Dialogue: 0,0:13:29.79,0:13:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:13:31.28,0:13:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sampai jumpa.
Dialogue: 0,0:13:33.90,0:13:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Truk itu pergi ke mana?
Dialogue: 0,0:13:36.17,0:13:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu tahu.
Dialogue: 0,0:13:39.20,0:13:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tertolong.
Dialogue: 0,0:13:41.55,0:13:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si sialan itu kerabat Kepsek.
Dialogue: 0,0:13:44.18,0:13:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tak membangkang,
Dialogue: 0,0:13:46.68,0:13:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mungkin tak bisa berbuat apa-apa.
Dialogue: 0,0:13:49.24,0:13:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:51.81,0:13:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma gampang marah.
Dialogue: 0,0:13:54.86,0:13:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Aikawa.\NSalam kenal.
Dialogue: 0,0:13:58.57,0:14:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Risu.
Dialogue: 0,0:14:02.93,0:14:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aikawa, ke mana kamu pergi?
Dialogue: 0,0:14:07.52,0:14:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah bangun, Risu.
Dialogue: 0,0:14:09.50,0:14:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga, aku ingin bertemu denganmu.
Dialogue: 0,0:14:12.33,0:14:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kutanyakan.
Dialogue: 0,0:14:14.83,0:14:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sebaiknya bunuh dia saja, Dokuga.
Dialogue: 0,0:14:19.13,0:14:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin datang untuk mencuri sesuatu.
Dialogue: 0,0:14:21.84,0:14:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak ada yang berharga di sini.
Dialogue: 0,0:14:24.22,0:14:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salah paham, Saji.
Dialogue: 0,0:14:26.64,0:14:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga sebenarnya bisa membunuhku.
Dialogue: 0,0:14:29.46,0:14:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tidak mau melakukannya.
Dialogue: 0,0:14:32.50,0:14:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:14:34.10,0:14:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokuga.
Dialogue: 0,0:14:38.32,0:14:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah!
Dialogue: 0,0:14:41.38,0:14:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akhirnya sampai ke Kota Zagan.
Dialogue: 0,0:14:44.11,0:14:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah malam!
Dialogue: 0,0:14:48.64,0:14:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman?
Dialogue: 0,0:14:50.77,0:14:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Caiman!
Dialogue: 0,0:14:56.88,0:14:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat jalan ini.
Dialogue: 0,0:15:12.67,0:15:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah Pelatihan Sihir Zagan?
Dialogue: 0,0:15:17.36,0:15:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kepalaku!
Dialogue: 0,0:15:19.88,0:15:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman!
Dialogue: 0,0:15:20.77,0:15:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang!
Dialogue: 0,0:15:21.98,0:15:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman!\NAda apa tiba-tiba begitu?
Dialogue: 0,0:15:26.03,0:15:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini sekolah?
Dialogue: 0,0:15:29.24,0:15:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sekolah terbengkalai.
Dialogue: 0,0:15:31.08,0:15:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang, kenapa kamu di tempat seperti ini?
Dialogue: 0,0:15:34.16,0:15:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada urusan di sini.
Dialogue: 0,0:15:37.75,0:15:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalian berdua tunggu aku di sini.\N- A-Abang?
Dialogue: 0,0:15:42.03,0:15:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.\NJangan-jangan, ingatannya...
Dialogue: 0,0:15:50.68,0:15:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku ingat suasana lantai ini.
Dialogue: 0,0:15:55.35,0:15:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalaku sakit!
Dialogue: 0,0:15:59.77,0:16:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi padaku?
Dialogue: 0,0:16:10.03,0:16:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu!
Dialogue: 0,0:16:14.41,0:16:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:16:21.21,0:16:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku murid di sini?
Dialogue: 0,0:16:25.51,0:16:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau guru?\NPetugas kebersihan?
Dialogue: 0,0:16:29.51,0:16:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak mungkin.\NKalau begitu, aku...
Dialogue: 0,0:16:35.20,0:16:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti...
Dialogue: 0,0:16:39.12,0:16:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti seorang penyihir.
Dialogue: 0,0:16:45.44,0:16:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ruang guru.
Dialogue: 0,0:17:03.96,0:17:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu.
Dialogue: 0,0:17:21.54,0:17:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Aikawa.\NSalam kenal.
Dialogue: 0,0:17:24.26,0:17:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku...
Dialogue: 0,0:18:15.28,0:18:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman! Ternyata kamu di sini.\NApa yang sebenarnya terja—
Dialogue: 0,0:18:20.00,0:18:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Abang!
Dialogue: 0,0:18:21.49,0:18:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman!
Dialogue: 0,0:18:25.57,0:18:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman, apa yang terjadi?
Dialogue: 0,0:18:29.42,0:18:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisik wajahmu robek.\NSiapa yang melakukan ini padamu?
Dialogue: 0,0:18:36.39,0:18:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kamu melakukannya sendiri?
Dialogue: 0,0:18:39.89,0:18:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:18:41.63,0:18:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:42.39,0:18:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masker perban.
Dialogue: 0,0:18:44.77,0:18:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taruh di kepalamu seperti ini.
Dialogue: 0,0:18:46.65,0:18:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tekan tombol obat\Ndan tarik pin hitamnya.
Dialogue: 0,0:18:50.61,0:18:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir, tarik pin merah.
Dialogue: 0,0:18:52.57,0:18:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini?
Dialogue: 0,0:18:59.53,0:19:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai! Kamu bahkan bisa bicara\Ndan makan dengan ini.
Dialogue: 0,0:19:03.58,0:19:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, ya.
Dialogue: 0,0:19:05.08,0:19:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang kasihan...
Dialogue: 0,0:19:06.92,0:19:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti tiba-tiba mulai membenci\Nwajahnya yang aneh.
Dialogue: 0,0:19:10.67,0:19:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Natsuki.\N- Apa?
Dialogue: 0,0:19:11.80,0:19:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa belikan minuman untuk Caiman?
Dialogue: 0,0:19:15.05,0:19:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, tapi jangan tinggalkan aku, ya?
Dialogue: 0,0:19:26.40,0:19:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman, kamu...
Dialogue: 0,0:19:28.76,0:19:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silang matamu hilang.
Dialogue: 0,0:19:31.78,0:19:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti ingat sesuatu, kan?
Dialogue: 0,0:19:36.53,0:19:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman, jangan-jangan
Dialogue: 0,0:19:40.25,0:19:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu seorang penyihir juga?
Dialogue: 0,0:19:44.98,0:19:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dulu sekolah di sini.
Dialogue: 0,0:19:48.63,0:19:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku di sini bersama Risu.
Dialogue: 0,0:19:51.67,0:19:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:19:54.67,0:19:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman!
Dialogue: 0,0:19:56.51,0:19:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa aku sebenarnya?
Dialogue: 0,0:19:59.05,0:20:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan sesuatu\Nyang sangat menakutkan dalam diriku.
Dialogue: 0,0:20:03.89,0:20:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikaido, aku mungkin akan menyakitimu.
Dialogue: 0,0:20:08.85,0:20:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu terjadi, aku...
Dialogue: 0,0:20:12.86,0:20:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caiman.
Dialogue: 0,0:20:15.14,0:20:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan baik-baik saja.
Dialogue: 0,0:20:26.86,0:20:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai juga!
Dialogue: 0,0:20:28.33,0:20:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pulang.
Dialogue: 0,0:20:30.67,0:20:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangga, kamu menghalangi!
Dialogue: 0,0:20:33.13,0:20:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Shin dan Noi.
Dialogue: 0,0:20:35.34,0:20:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada berterima kasih pada kami,\Nceritakan soal sosok lilin yang kamu lihat.
Dialogue: 0,0:20:40.59,0:20:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku ganti baju dulu,\Ntunggu saja di kotatsu.
Dialogue: 0,0:20:44.85,0:20:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotatsu?
Dialogue: 0,0:20:49.44,0:20:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, perabotan ini menarik.
Dialogue: 0,0:20:53.34,0:20:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh kakiku!
Dialogue: 0,0:20:55.15,0:20:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:20:56.17,0:20:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh aku!
Dialogue: 0,0:20:58.74,0:21:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter, itu berkas berhargamu...
Dialogue: 0,0:21:01.95,0:21:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, titik awal penelitianku tentang Penyihir.
Dialogue: 0,0:21:05.74,0:21:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkas tempat aku\Nmengompilasi semuanya.
Dialogue: 0,0:21:08.25,0:21:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu ini pria patung lilin?
Dialogue: 0,0:21:11.46,0:21:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya tak bisa dikenali.
Dialogue: 0,0:21:13.75,0:21:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membantu penelitianku.
Dialogue: 0,0:21:18.17,0:21:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau lebih tepatnya, aku yang memulai\Npenelitian atas permintaannya.
Dialogue: 0,0:21:22.55,0:21:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pria di berkas ini manusia?
Dialogue: 0,0:21:25.26,0:21:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku sudah memastikannya.
Dialogue: 0,0:21:27.52,0:21:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patung lilin dan pria dalam berkas ini...
Dialogue: 0,0:21:31.27,0:21:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka orang yang sama,
Dialogue: 0,0:21:33.15,0:21:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bos Mata Silang adalah manusia dari Hole.
Dialogue: 0,0:21:36.53,0:21:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:38.26,0:21:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang Mata Silang\Ntak bisa menggunakan sihir.
Dialogue: 0,0:21:41.89,0:21:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mungkin, kan?
Dialogue: 0,0:21:43.66,0:21:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe, dia tinggal di mana?
Dialogue: 0,0:21:46.17,0:21:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diingat,\Ndia tinggal berdua bersama kakeknya.
Dialogue: 0,0:21:56.17,0:21:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin tak ada orang?
Dialogue: 0,0:21:57.42,0:21:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noi.
Dialogue: 0,0:21:58.23,0:21:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:22:04.12,0:22:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Co-Coleman?
Dialogue: 0,0:22:07.39,0:22:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada orang di sini sebelum kita.
Dialogue: 0,0:22:09.81,0:22:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.\NAyo cari foto cucunya.
Dialogue: 0,0:22:12.81,0:22:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!\NSiapa yang melakukan ini?
Dialogue: 0,0:22:15.02,0:22:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, apa kita harus sambung\Nkepala buntung ini pakai sihir Kikurage?
Dialogue: 0,0:22:19.78,0:22:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti Risu!
Dialogue: 0,0:22:21.44,0:22:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:22:22.36,0:22:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kepala buntungnya...
Dialogue: 0,0:22:24.49,0:22:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bicara?
Dialogue: 0,0:22:25.87,0:22:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang kalian panggil kepala buntung?
Dialogue: 0,0:22:28.37,0:22:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku korban sihir betulan!
Dialogue: 0,0:22:31.33,0:22:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat leher ini!
Dialogue: 0,0:22:33.29,0:22:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa membuat kakiku lebih panjang!
Dialogue: 0,0:22:35.46,0:22:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar para penyihir bodoh!
Dialogue: 0,0:22:37.13,0:22:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira dia sudah mati.
Dialogue: 0,0:22:39.17,0:22:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang tidur siang!
Dialogue: 0,0:22:40.88,0:22:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kalian?
Dialogue: 0,0:22:42.09,0:22:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami teman cucumu.
Dialogue: 0,0:22:43.59,0:22:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang apa?
Dialogue: 0,0:22:45.01,0:22:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak dengar!\NAku tuli!
Dialogue: 0,0:22:47.64,0:22:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku paham!
Dialogue: 0,0:22:49.74,0:22:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ke sini ingin mengunjungi\Nmakam cucuku, kan?
Dialogue: 0,0:22:53.60,0:22:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makam?
Dialogue: 0,0:22:55.81,0:23:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak jadi seperti ini tahun lalu,\Naku tak bisa mengunjungi makamnya.
Dialogue: 0,0:23:00.44,0:23:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua sangat membantuku.
Dialogue: 0,0:23:03.03,0:23:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 13 tahun.
Dialogue: 0,0:23:05.78,0:23:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu dibunuh oleh penyihir.
Dialogue: 0,0:23:09.91,0:23:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, bicaralah dengan cucuku.
Dialogue: 0,0:23:12.79,0:23:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo kita gali.
Dialogue: 0,0:23:14.91,0:23:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:23:15.96,0:23:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NKamu tadi bilang apa?
Dialogue: 0,0:23:18.40,0:23:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian! Hentikan!
Dialogue: 0,0:23:21.30,0:23:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bocah terkutuk!\NHentikan!
Dialogue: 0,0:23:24.92,0:23:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!\NKalian tak dengar?
Dialogue: 0,0:23:28.32,0:23:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga belas tahun lalu,\Naku menghadiri pemakamannya
Dialogue: 0,0:23:32.43,0:23:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melihat jenazahnya dikubur.
Dialogue: 0,0:23:35.02,0:23:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia betulan ada di kuburan ini...
Dialogue: 0,0:23:39.52,0:23:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.\NPeti matinya.
Dialogue: 0,0:23:42.19,0:23:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kubuka!
Dialogue: 0,0:23:45.57,0:23:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ditendang!
Dialogue: 0,0:23:48.37,0:23:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini...\N- Apa?
Dialogue: 0,0:23:50.23,0:23:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada apa pun di dalamnya.
Dialogue: 0,0:25:23.96,0:25:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita tahu sejauh ini\Ndi Episode 3 Musim Kedua.
Dialogue: 0,0:25:26.30,0:25:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risu dan Aikawa adalah teman lama.
Dialogue: 0,0:25:28.05,0:25:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatan Caiman kembali.
Dialogue: 0,0:25:30.01,0:25:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasukabe kenal bos Mata Silang.
Dialogue: 0,0:25:32.28,0:25:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang akan ketahui di Episode 4 Musim Kedua,\Nmasih tersembunyi dalam kekacauan.
Dialogue: 0,0:25:36.20,0:25:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah... Dorohedoro.
