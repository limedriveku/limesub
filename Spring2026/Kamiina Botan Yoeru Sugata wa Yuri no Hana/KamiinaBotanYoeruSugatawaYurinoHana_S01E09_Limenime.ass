Dialogue: 0,0:00:16.91,0:00:18.75,sign,,0000,0000,0000,,KAMIINA BOTAN
Dialogue: 0,0:00:46.99,0:00:52.62,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:02:03.56,0:02:08.97,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:09:51.99,0:10:02.00,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:14:41.74,0:14:44.70,sign,,0000,0000,0000,,KERETA KABEL GUNUNG TAKAO
Dialogue: 0,0:15:36.21,0:15:38.17,sign,,0000,0000,0000,,STASIUN KERETA KABEL\NGUNUNG TAKAO
Dialogue: 0,0:00:31.72,0:00:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti baik-baik saja.
Dialogue: 0,0:00:33.01,0:00:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu menghubunginya.
Dialogue: 0,0:02:16.99,0:02:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tampak gugup, Kak Gujyo?
Dialogue: 0,0:02:21.79,0:02:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah menunggu.
Dialogue: 0,0:02:24.17,0:02:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beres-beresnya agak lama.
Dialogue: 0,0:02:26.33,0:02:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tidak usah dipikirkan.
Dialogue: 0,0:02:27.71,0:02:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa begitu.
Dialogue: 0,0:02:29.88,0:02:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beres-beres?
Dialogue: 0,0:02:31.46,0:02:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu menimbun barang\Nke dalam lemari, ya?
Dialogue: 0,0:02:34.93,0:02:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:02:38.85,0:02:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:02:48.23,0:02:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman di kamarmu\Nlebih sedikit dari dugaanku.
Dialogue: 0,0:02:52.99,0:02:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau aku bawakan?
Dialogue: 0,0:02:55.07,0:02:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau ditaruh di kamar,\Naku pasti meminumnya terus.
Dialogue: 0,0:03:00.20,0:03:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:03:03.08,0:03:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah!
Dialogue: 0,0:03:04.21,0:03:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita minum-minum!
Dialogue: 0,0:03:06.79,0:03:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kita mau minum apa?
Dialogue: 0,0:03:09.34,0:03:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah makan malam?
Dialogue: 0,0:03:11.68,0:03:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli kentang miso.
Dialogue: 0,0:03:13.42,0:03:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih? Asyik!
Dialogue: 0,0:03:15.80,0:03:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau nonton sesuatu?
Dialogue: 0,0:03:17.47,0:03:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya film atau video.
Dialogue: 0,0:03:20.87,0:03:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sutradara yang kamu suka, Chin-lan?
Dialogue: 0,0:03:23.89,0:03:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guillaume Brac atau Bong Joon-ho.
Dialogue: 0,0:03:26.56,0:03:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, bagus, tuh!
Dialogue: 0,0:03:28.65,0:03:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus...
Dialogue: 0,0:03:29.86,0:03:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wes Anderson.
Dialogue: 0,0:03:31.98,0:03:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bikin Resident Evil, ya?
Dialogue: 0,0:03:34.82,0:03:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sih Paul Anderson.
Dialogue: 0,0:03:36.61,0:03:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mantap.\NAda prosciutto juga.
Dialogue: 0,0:03:39.45,0:03:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman yang kubawa cukup enak, lo.
Dialogue: 0,0:03:42.20,0:03:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bikin koktail,\Nayo kita coba minum.
Dialogue: 0,0:03:45.58,0:03:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:03:46.96,0:03:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Alchemiae!
Dialogue: 0,0:03:48.96,0:03:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah meminumnya?
Dialogue: 0,0:03:52.21,0:03:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum kalau botolnya seperti ini.
Dialogue: 0,0:03:54.55,0:03:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botolnya unik, ya.
Dialogue: 0,0:03:57.38,0:03:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini botol obat?
Dialogue: 0,0:03:59.39,0:04:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, katanya pakai botol obat\Nyang dibuat di Gifu.
Dialogue: 0,0:04:03.43,0:04:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paling suka absinthe mereka!
Dialogue: 0,0:04:07.46,0:04:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat bingung memilih,
Dialogue: 0,0:04:09.02,0:04:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kayaknya gin lebih mudah diminum.
Dialogue: 0,0:04:11.73,0:04:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bikin tonik gin pakai air tonik.
Dialogue: 0,0:04:14.07,0:04:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap!
Dialogue: 0,0:04:15.11,0:04:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, aku ingin minum\Nyang tanpa campuran!
Dialogue: 0,0:04:17.20,0:04:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.
Dialogue: 0,0:04:18.45,0:04:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chin-lan, biasanya kamu nonton\Nvideo seperti apa?
Dialogue: 0,0:04:22.95,0:04:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Video kecelakaan mobil bagus\Ndi Nürburgring.
Dialogue: 0,0:04:27.12,0:04:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:04:29.42,0:04:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, sudah siap!
Dialogue: 0,0:04:31.79,0:04:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bersulang!
Dialogue: 0,0:04:33.17,0:04:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:04:34.92,0:04:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!
Dialogue: 0,0:04:45.26,0:04:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki?
Dialogue: 0,0:04:49.73,0:04:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa suaramu tidak bisa dikecilkan?
Dialogue: 0,0:05:00.74,0:05:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:05:18.05,0:05:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:05:20.26,0:05:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma lavendernya\Nlebih kuat dari dugaanku.
Dialogue: 0,0:05:23.47,0:05:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.\NMirip seperti di "xūnyīcǎo sēnlín".
Dialogue: 0,0:05:26.76,0:05:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:05:28.14,0:05:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya bunga lavender di Taiwan.
Dialogue: 0,0:05:31.19,0:05:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu minuman seharum ini.
Dialogue: 0,0:05:34.31,0:05:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kak.
Dialogue: 0,0:05:40.70,0:05:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:05:44.28,0:05:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Aku ingin tanya!
Dialogue: 0,0:05:46.60,0:05:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa perusahaan\Ntempat Kak Gujyo magang itu?
Dialogue: 0,0:05:50.54,0:05:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, minumannya masih kurang.
Dialogue: 0,0:05:53.75,0:05:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga\Nakan mengeluarkan minuman.
Dialogue: 0,0:05:58.21,0:06:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!\NAkkeshi New Born lini keempat, Blended.
Dialogue: 0,0:06:04.68,0:06:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:06:05.80,0:06:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merah.\NBotolnya imut.
Dialogue: 0,0:06:09.18,0:06:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini shochu?
Dialogue: 0,0:06:10.89,0:06:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ini wiski.
Dialogue: 0,0:06:15.23,0:06:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya enak banget,\Njadi, tidak usah pakai campuran.
Dialogue: 0,0:06:19.55,0:06:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wiski tanpa campuran, ya?
Dialogue: 0,0:06:22.03,0:06:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kak! Bagaimana magangnya?
Dialogue: 0,0:06:24.57,0:06:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:06:26.12,0:06:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, kamu masih jadi developer\Ndi perusahaan itu?
Dialogue: 0,0:06:30.37,0:06:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Magangnya sudah selesai.
Dialogue: 0,0:06:32.54,0:06:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku bekerja\Nsebagai tenaga kontrak.
Dialogue: 0,0:06:35.25,0:06:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, hebat.
Dialogue: 0,0:06:38.71,0:06:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:42.21,0:06:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:06:43.38,0:06:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:06:45.22,0:06:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di balik rasanya yang pedas,\Nada rasa manis mentega kismis.
Dialogue: 0,0:06:49.85,0:06:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tiram itu terkenal di Akkeshi?
Dialogue: 0,0:06:54.27,0:06:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, tiram lebih enak\Nkalau disiram wiski.
Dialogue: 0,0:06:57.73,0:06:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Serius?
Dialogue: 0,0:06:59.65,0:07:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada budaya\Nseperti itu di Pulau Islay.
Dialogue: 0,0:07:03.11,0:07:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga makan tiram di Taiwan?
Dialogue: 0,0:07:05.07,0:07:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan, dong.\NMisalnya "oa-chien".
Dialogue: 0,0:07:07.95,0:07:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Oa-chien"?
Dialogue: 0,0:07:09.16,0:07:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur dadar isi tiram.
Dialogue: 0,0:07:10.91,0:07:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kayaknya enak!
Dialogue: 0,0:07:14.00,0:07:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki?
Dialogue: 0,0:07:15.33,0:07:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku coba magang saja, ya?
Dialogue: 0,0:07:17.92,0:07:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di perusahaan tempatmu bekerja.
Dialogue: 0,0:07:19.92,0:07:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:21.30,0:07:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuatku bahagia!
Dialogue: 0,0:07:23.05,0:07:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa?
Dialogue: 0,0:07:25.80,0:07:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, itu membuatku senang\Nkarena sepertinya bakal seru.
Dialogue: 0,0:07:32.64,0:07:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru, ya?
Dialogue: 0,0:07:36.23,0:07:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya ada pekerjaan yang seru?
Dialogue: 0,0:07:40.52,0:07:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku harus magang dulu\Nuntuk mencari pekerjaan itu, ya.
Dialogue: 0,0:07:45.53,0:07:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada hal yang kamu suka\Natau membuatmu senang?
Dialogue: 0,0:07:53.16,0:07:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatku senang, ya?\NAda, kok.
Dialogue: 0,0:07:56.91,0:07:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:08:00.00,0:08:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini,
Dialogue: 0,0:08:02.59,0:08:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa paling senang\Nsaat minum miras.
Dialogue: 0,0:08:06.38,0:08:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sebelumnya biasa-biasa saja.
Dialogue: 0,0:08:09.28,0:08:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau jadi pembuat?
Dialogue: 0,0:08:11.51,0:08:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti produsen minuman keras.
Dialogue: 0,0:08:14.35,0:08:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku cuma suka meminumnya.
Dialogue: 0,0:08:22.11,0:08:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak bertemu Botan.
Dialogue: 0,0:08:26.07,0:08:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum bersama Botan itu seru.
Dialogue: 0,0:08:33.40,0:08:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:08:35.83,0:08:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merasa seru adalah hal bagus.
Dialogue: 0,0:08:38.78,0:08:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:40.88,0:08:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku ke toilet sebentar.
Dialogue: 0,0:08:43.96,0:08:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah.
Dialogue: 0,0:08:50.34,0:08:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:08:52.64,0:08:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bawa minuman,\Nkamu mau mencobanya?
Dialogue: 0,0:08:56.14,0:08:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mead dari madu Chichibu.
Dialogue: 0,0:08:59.64,0:09:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:13.45,0:09:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis.
Dialogue: 0,0:09:16.08,0:09:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan\Nkeasaman ringan seperti apel
Dialogue: 0,0:09:18.79,0:09:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan karakter yang mirip seperti sake.
Dialogue: 0,0:09:22.96,0:09:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku meminumnya.
Dialogue: 0,0:09:25.42,0:09:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya lembut, ya.
Dialogue: 0,0:09:28.28,0:09:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar... lembut.
Dialogue: 0,0:09:35.01,0:09:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:04.29,0:10:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika rona merah
Dialogue: 0,0:10:05.79,0:10:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daun musim gugur mulai\Nmemudar dan meranggas,
Dialogue: 0,0:10:11.13,0:10:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terasa keheningan gunung
Dialogue: 0,0:10:13.84,0:10:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sesaat sebelum salju turun.
Dialogue: 0,0:10:17.26,0:10:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu puisinya siapa?
Dialogue: 0,0:10:18.68,0:10:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saito Mokichi.
Dialogue: 0,0:10:28.32,0:10:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah musim gugur, ya.
Dialogue: 0,0:10:30.57,0:10:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:36.62,0:10:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, omong-omong,
Dialogue: 0,0:10:39.20,0:10:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya kafe di ujung sana
Dialogue: 0,0:10:41.12,0:10:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berubah menjadi bar saat malam.
Dialogue: 0,0:10:43.17,0:10:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga menjual miras saat siang.
Dialogue: 0,0:10:46.50,0:10:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Ibuki.
Dialogue: 0,0:10:48.59,0:10:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih harus nyetir, kan?
Dialogue: 0,0:10:50.67,0:10:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, makanya,
Dialogue: 0,0:10:55.97,0:10:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kupikir kamu bisa minum sendiri.
Dialogue: 0,0:10:59.22,0:11:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku minum sendiri,\Njadi enggak asyik.
Dialogue: 0,0:11:04.64,0:11:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:11:05.81,0:11:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:10.27,0:11:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku asyik.
Dialogue: 0,0:11:14.70,0:11:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengajakku hari ini.
Dialogue: 0,0:11:17.62,0:11:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat senang.
Dialogue: 0,0:11:22.87,0:11:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:11:26.67,0:11:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung cuacanya cerah, ya.
Dialogue: 0,0:11:28.38,0:11:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:29.46,0:11:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cuma "eh"!
Dialogue: 0,0:11:33.01,0:11:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita datang ke sini\Nuntuk melihat bintang, kan?
Dialogue: 0,0:11:37.64,0:11:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bintang sungguhan.
Dialogue: 0,0:11:40.22,0:11:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjutan dari planetarium itu.
Dialogue: 0,0:12:00.57,0:12:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan, apa kamu tidak enak badan?
Dialogue: 0,0:12:04.12,0:12:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa?
Dialogue: 0,0:12:06.41,0:12:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:12:08.29,0:12:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, soalnya anteng banget hari ini.
Dialogue: 0,0:12:12.04,0:12:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kamu kelelahan.
Dialogue: 0,0:12:17.13,0:12:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil yang dipinjam\Ndari temannya Akane ini sempit.
Dialogue: 0,0:12:21.01,0:12:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pinggangku jadi sakit.
Dialogue: 0,0:12:24.39,0:12:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:12:26.02,0:12:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin istirahat di penginapan.
Dialogue: 0,0:12:33.32,0:12:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kamu spesial bagiku."
Dialogue: 0,0:12:36.24,0:12:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak sabar untuk minum.
Dialogue: 0,0:12:41.41,0:12:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya
Dialogue: 0,0:12:43.91,0:12:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari kata "spesial" itu?
Dialogue: 0,0:12:47.62,0:12:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sama seperti yang kurasakan?
Dialogue: 0,0:12:50.29,0:12:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin
Dialogue: 0,0:12:52.58,0:12:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedikit berbeda?
Dialogue: 0,0:12:56.84,0:12:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa dia...
Dialogue: 0,0:12:59.38,0:13:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Ibuki memendam\Nrasa seperti itu sejak lama.
Dialogue: 0,0:13:05.22,0:13:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memastikannya.
Dialogue: 0,0:13:09.31,0:13:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:13:11.23,0:13:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kalau aku salah?
Dialogue: 0,0:13:14.31,0:13:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan?
Dialogue: 0,0:13:16.38,0:13:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:13:18.61,0:13:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:13:25.33,0:13:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin segera minum.
Dialogue: 0,0:13:52.56,0:13:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian dalamnya luas banget.
Dialogue: 0,0:14:02.57,0:14:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di belakang sana\Nada pemandian terbuka.
Dialogue: 0,0:14:05.53,0:14:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mewah banget.
Dialogue: 0,0:14:09.24,0:14:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Bota—
Dialogue: 0,0:14:17.25,0:14:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pesan minuman melalui layanan kamar.
Dialogue: 0,0:14:22.59,0:14:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:14:25.26,0:14:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa begini rasanya situasi\Nenggak tahan tanpa minum?
Dialogue: 0,0:14:32.94,0:14:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bota—\N- Hei, Ibuki.
Dialogue: 0,0:14:36.31,0:14:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyampaikan sesuatu.
Dialogue: 0,0:14:45.36,0:14:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah naik kereta kabel?
Dialogue: 0,0:14:47.57,0:14:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah, kok.
Dialogue: 0,0:14:48.91,0:14:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Maokong, Taiwan, aku naik sesuatu\Nyang digantung dengan kabel baja.
Dialogue: 0,0:14:53.33,0:14:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kan gondola.
Dialogue: 0,0:14:55.79,0:14:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama saja, kan?
Dialogue: 0,0:14:59.46,0:15:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda.
Dialogue: 0,0:15:05.73,0:15:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar.\NIni beda dari gondola.
Dialogue: 0,0:15:08.51,0:15:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mirip kereta listrik.
Dialogue: 0,0:15:10.26,0:15:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:15:12.60,0:15:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, hari ini, Bota—
Dialogue: 0,0:15:19.86,0:15:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa!\NGunung Takao, asyik!
Dialogue: 0,0:15:38.71,0:15:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai!
Dialogue: 0,0:15:44.30,0:15:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan sesuatu di atas?
Dialogue: 0,0:15:46.49,0:15:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:48.22,0:15:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.\NTerserah kamu saja.
Dialogue: 0,0:15:53.97,0:15:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:15:55.43,0:15:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang bilang terserah, tapi...
Dialogue: 0,0:15:58.73,0:16:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa panggang daging\Ntanpa bawa apa-apa itu mantap!
Dialogue: 0,0:16:02.73,0:16:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan daging di puncak gunung...
Dialogue: 0,0:16:08.53,0:16:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini terlalu mewah?
Dialogue: 0,0:16:12.45,0:16:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan dan Ibuki\Njuga pasti sedang makan—
Dialogue: 0,0:16:23.79,0:16:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buat aku mengingatnya.
Dialogue: 0,0:16:26.80,0:16:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita minum supaya lupa!
Dialogue: 0,0:16:28.22,0:16:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi! Pesan dua bir besar!
Dialogue: 0,0:16:36.85,0:16:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sepuluh kali\Nlebih banyak dari dugaanku.
Dialogue: 0,0:16:39.52,0:16:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dagingnya banyak banget.
Dialogue: 0,0:16:43.44,0:16:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kamu jadi memanggang semuanya.
Dialogue: 0,0:16:46.49,0:16:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku juga—\N- Santai saja, duduklah.
Dialogue: 0,0:16:50.45,0:16:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi seperti tamu, dong.
Dialogue: 0,0:16:53.03,0:16:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa.
Dialogue: 0,0:16:54.49,0:16:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak boleh.
Dialogue: 0,0:16:57.25,0:16:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:16:59.33,0:17:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong siapkan minuman dan musiknya.
Dialogue: 0,0:17:02.44,0:17:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:17:08.88,0:17:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama-lama, mulai terasa, ya.
Dialogue: 0,0:17:15.51,0:17:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:21.92,0:17:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebahagiaan yang luar biasa.
Dialogue: 0,0:17:28.86,0:17:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang.
Dialogue: 0,0:17:35.45,0:17:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap.
Dialogue: 0,0:17:45.42,0:17:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wine menghangatkan tubuh dari dalam
Dialogue: 0,0:17:49.01,0:17:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan udara di gunung\Nmendinginkan tubuh dari luar.
Dialogue: 0,0:18:01.27,0:18:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmat sekali.
Dialogue: 0,0:18:11.19,0:18:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:18:13.74,0:18:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendung.
Dialogue: 0,0:18:19.65,0:18:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa malam ini
Dialogue: 0,0:18:22.96,0:18:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami bisa melihat bintang?
Dialogue: 0,0:18:31.63,0:18:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi malas ngapa-ngapain.
Dialogue: 0,0:18:37.80,0:18:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Porsinya banyak banget, ya.
Dialogue: 0,0:18:40.56,0:18:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.\NRasa kenyangnya gila.
Dialogue: 0,0:18:45.73,0:18:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana pemandiannya?
Dialogue: 0,0:18:48.36,0:18:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau rebahan sebentar.
Dialogue: 0,0:18:51.99,0:18:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya tidur.
Dialogue: 0,0:18:54.86,0:18:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masuk dulu, ya.
Dialogue: 0,0:18:56.45,0:18:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:59.37,0:19:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tunggu, ya.
Dialogue: 0,0:19:23.43,0:19:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa airnya panas?
Dialogue: 0,0:19:25.85,0:19:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja.
Dialogue: 0,0:19:32.94,0:19:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:19:34.44,0:19:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:19:37.07,0:19:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak penasaran?
Dialogue: 0,0:19:40.41,0:19:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyampaikan sesuatu.
Dialogue: 0,0:19:48.54,0:19:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja penasaran.
Dialogue: 0,0:19:55.67,0:19:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya nyaman, ya.
Dialogue: 0,0:19:57.84,0:19:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:01.60,0:20:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih berapa kali lagi?
Dialogue: 0,0:20:06.69,0:20:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:08.19,0:20:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih berapa kali lagi
Dialogue: 0,0:20:09.94,0:20:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa minum bersama, ya?
Dialogue: 0,0:20:13.82,0:20:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kita sangat akur,
Dialogue: 0,0:20:16.32,0:20:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kesempatan minum\Nbersama teman itu tetap terbatas.
Dialogue: 0,0:20:23.54,0:20:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memilikimu sendirian.
Dialogue: 0,0:20:40.14,0:20:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:21:22.14,0:21:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:21:39.03,0:21:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau berhenti berteman?
Dialogue: 0,0:22:03.09,0:22:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:22:05.72,0:22:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berhenti berteman.
