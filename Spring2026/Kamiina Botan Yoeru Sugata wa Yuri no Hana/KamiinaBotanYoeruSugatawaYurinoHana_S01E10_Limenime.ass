Dialogue: 0,0:01:03.00,0:01:08.63,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:02:19.62,0:02:25.00,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:07:12.58,0:07:15.87,sign,,0000,0000,0000,,KAK GUJYO: APA MENURUTMU TERJADI SESUATU\NDI ANTARA IBUKI DAN BOTAN?
Dialogue: 0,0:07:15.87,0:07:18.08,sign,,0000,0000,0000,,ENTAH
Dialogue: 0,0:07:27.09,0:07:29.10,sign,,0000,0000,0000,,MAU PERGI MINUM-MINUM\NMALAM INI?
Dialogue: 0,0:07:29.10,0:07:30.60,sign,,0000,0000,0000,,BERDUA SAJA
Dialogue: 0,0:12:50.04,0:13:00.05,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:15:11.93,0:15:13.98,sign,,0000,0000,0000,,YUSA AKANE
Dialogue: 0,0:17:04.33,0:17:09.33,sign,,0000,0000,0000,,YUSA AKANE: BISA BAWAKAN LAGU INI?\NMATAHARI TERBENAM MERAH, FUJIFABRIC
Dialogue: 0,0:19:24.64,0:19:25.52,sign,,0000,0000,0000,,INI MINUMAN DARI TEMPAT ASALKU
Dialogue: 0,0:19:25.52,0:19:26.81,sign,,0000,0000,0000,,SILAKAN DINIKMATI SESUKA HATI, YAEKA
Dialogue: 0,0:00:29.84,0:00:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bertemu Botan.
Dialogue: 0,0:00:34.75,0:00:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum bersama Botan itu seru.
Dialogue: 0,0:02:36.64,0:02:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang diajak Kak Gujyo ke sini.
Dialogue: 0,0:02:40.50,0:02:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku juga.
Dialogue: 0,0:02:45.93,0:02:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karya di ruangan ekshibisi khusus\Nyang luas itu.
Dialogue: 0,0:02:49.07,0:02:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cukup menyukainya.\NBukankah itu imut?
Dialogue: 0,0:02:52.08,0:02:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kaca?
Dialogue: 0,0:02:53.49,0:02:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:02:54.32,0:02:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:55.91,0:02:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku agak seram.
Dialogue: 0,0:02:58.03,0:02:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:02:59.49,0:03:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karya berlubang besar\Ndi ruangan gelap itu lebih seram.
Dialogue: 0,0:03:03.62,0:03:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayak blue hole.
Dialogue: 0,0:03:05.16,0:03:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Itu malah indah.
Dialogue: 0,0:03:07.49,0:03:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:03:09.00,0:03:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, aku ingin melihatnya lagi.
Dialogue: 0,0:03:10.84,0:03:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:12.48,0:03:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita lihat lagi?
Dialogue: 0,0:03:14.34,0:03:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Lihat lagi?\NAku agak malas.
Dialogue: 0,0:03:26.27,0:03:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, apa ini sudah valid?
Dialogue: 0,0:03:43.04,0:03:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku melihat sebuah karya\Ntanpa tahu latar belakangnya,
Dialogue: 0,0:03:47.46,0:03:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa memahaminya.
Dialogue: 0,0:03:52.42,0:03:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa karya ini bernilai tinggi?
Dialogue: 0,0:03:58.30,0:04:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan apa yang ingin\Ndisampaikan senimannya?
Dialogue: 0,0:04:04.04,0:04:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat penasaran,
Dialogue: 0,0:04:06.62,0:04:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku membaca banyak buku\Ntentang penjelasan atau wawancara,
Dialogue: 0,0:04:11.61,0:04:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bukankah ini agak berbelit-belit?
Dialogue: 0,0:04:16.16,0:04:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal karyanya ada di depan mataku,
Dialogue: 0,0:04:19.20,0:04:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah mengandalkan\Nsudut pandang orang lain.
Dialogue: 0,0:04:23.41,0:04:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti tidak melihat langsung\Ndengan perasaanku sendiri.
Dialogue: 0,0:04:28.29,0:04:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu sah-sah saja\Nuntuk mengapresiasinya.
Dialogue: 0,0:04:32.39,0:04:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak memahami ini.
Dialogue: 0,0:04:36.44,0:04:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengandalkan garis bantu\Nuntuk memahami sesuatu itu wajar, kan?
Dialogue: 0,0:04:44.08,0:04:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak tidak puas dengan jawabanku.
Dialogue: 0,0:04:48.46,0:04:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau melihat koleksi seni.
Dialogue: 0,0:04:52.10,0:04:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:04:54.37,0:04:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga—
Dialogue: 0,0:05:10.19,0:05:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:05:13.92,0:05:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau di sini sebentar lagi.
Dialogue: 0,0:05:18.42,0:05:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NNikmatilah waktumu.
Dialogue: 0,0:05:22.43,0:05:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:23.30,0:05:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:05:28.21,0:05:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas ajakannya hari ini.
Dialogue: 0,0:05:30.81,0:05:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat seni itu ternyata seru, ya.
Dialogue: 0,0:05:34.36,0:05:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kamu juga merasa begitu.
Dialogue: 0,0:06:10.85,0:06:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuk—
Dialogue: 0,0:06:33.08,0:06:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:06:35.08,0:06:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mustahil.
Dialogue: 0,0:06:45.22,0:06:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... tidak sanggup.
Dialogue: 0,0:06:49.26,0:06:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh garis bantu.
Dialogue: 0,0:06:55.73,0:06:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh garis pembelaan\Nyang berlapis-lapis.
Dialogue: 0,0:07:01.44,0:07:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya,
Dialogue: 0,0:07:04.78,0:07:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak mengerti sama sekali.
Dialogue: 0,0:07:15.87,0:07:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia serius banget.
Dialogue: 0,0:07:34.85,0:07:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak minum sekarang,\Nmau kapan lagi, Kak Gujyo?
Dialogue: 0,0:08:02.17,0:08:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya minum apa?
Dialogue: 0,0:08:05.08,0:08:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu!\NAku ingin minum air putih dulu.
Dialogue: 0,0:08:10.18,0:08:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunggu.
Dialogue: 0,0:08:13.31,0:08:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama apa pun.
Dialogue: 0,0:08:39.22,0:08:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, menurutmu karya apa\Nyang paling bagus tadi?
Dialogue: 0,0:08:45.76,0:08:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karya Cézanne.
Dialogue: 0,0:08:47.74,0:08:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak.\NAku lebih suka melihat karya Richter.
Dialogue: 0,0:08:51.22,0:08:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah membaca bukunya.
Dialogue: 0,0:08:55.71,0:08:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Kamu menjawab dengan cepat, ya.
Dialogue: 0,0:08:59.19,0:09:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Chin-lan.
Dialogue: 0,0:09:03.90,0:09:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang yang kamu suka?
Dialogue: 0,0:09:08.30,0:09:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:10.86,0:09:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NItu tidak berkaitan—
Dialogue: 0,0:09:13.95,0:09:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menentukan pesanan.
Dialogue: 0,0:09:17.87,0:09:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita samakan saja, ya.
Dialogue: 0,0:09:19.79,0:09:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:22.12,0:09:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan dua yang ini.
Dialogue: 0,0:09:23.33,0:09:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai es.
Dialogue: 0,0:09:25.34,0:09:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ngobrol, yuk.
Dialogue: 0,0:09:26.96,0:09:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus!\NAyo kita mengobrol!
Dialogue: 0,0:09:30.72,0:09:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi bahas apa, ya?
Dialogue: 0,0:09:34.39,0:09:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, kok.
Dialogue: 0,0:09:37.67,0:09:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:09:44.23,0:09:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinshu Absinthe.
Dialogue: 0,0:09:50.30,0:09:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinshu Absinthe?
Dialogue: 0,0:09:53.04,0:09:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah labelnya imut?
Dialogue: 0,0:09:55.03,0:09:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:56.76,0:10:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis kecil memberikan\Nbunga matahari ke Van Gogh.
Dialogue: 0,0:10:00.58,0:10:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tadi juga lihat lukisan Van Gogh, ya.
Dialogue: 0,0:10:03.20,0:10:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:08.71,0:10:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya menyenangkan sekali.
Dialogue: 0,0:10:13.81,0:10:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan sengatan lembut di lidah,
Dialogue: 0,0:10:16.53,0:10:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ada rasa manis yang mengikuti.
Dialogue: 0,0:10:18.69,0:10:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini gampang diminum.
Dialogue: 0,0:10:21.02,0:10:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Van Gogh pasti juga menyukainya.
Dialogue: 0,0:10:24.52,0:10:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emang Van Gogh suka absinthe?
Dialogue: 0,0:10:27.11,0:10:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Semua juga tahu.
Dialogue: 0,0:10:28.98,0:10:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lautrec juga menyukainya.
Dialogue: 0,0:10:31.99,0:10:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Aku tidak tahu.
Dialogue: 0,0:10:35.04,0:10:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tahu Van Gogh dari filmnya.
Dialogue: 0,0:10:39.01,0:10:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Film yang dibintangi Kirk Douglas.
Dialogue: 0,0:10:42.04,0:10:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Film lawas?
Dialogue: 0,0:10:43.41,0:10:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, film lawas.
Dialogue: 0,0:10:45.55,0:10:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma nonton film\Nyang digarap Altman.
Dialogue: 0,0:10:48.54,0:10:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sutradara "MASH"?\NDia juga bikin film Van Gogh, ya?
Dialogue: 0,0:10:52.76,0:10:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa bintangnya?
Dialogue: 0,0:10:54.88,0:10:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Roth.
Dialogue: 0,0:10:56.01,0:10:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya.\NMemang cocok, sih.
Dialogue: 0,0:10:59.85,0:11:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong soal Roth,
Dialogue: 0,0:11:01.31,0:11:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku suka film "Legenda Pianis di Laut"\Nyang digarap Tornatore.
Dialogue: 0,0:11:05.27,0:11:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka "Reservoir".
Dialogue: 0,0:11:06.77,0:11:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reservoir, ya?\NAku juga suka.
Dialogue: 0,0:11:09.65,0:11:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus film garapan Stoppard—
Dialogue: 0,0:11:16.66,0:11:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mana?
Dialogue: 0,0:11:19.12,0:11:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi...
Dialogue: 0,0:11:21.60,0:11:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sangat...
Dialogue: 0,0:11:26.58,0:11:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku harus bagaimana?
Dialogue: 0,0:11:33.41,0:11:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa tenang dan senang\Nsaat bersamamu.
Dialogue: 0,0:11:38.54,0:11:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, rasanya agak menakutkan.
Dialogue: 0,0:11:44.10,0:11:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, hatiku sangat ribut\Nseperti badai di malam hari.
Dialogue: 0,0:11:51.11,0:11:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelap dan menyeramkan.
Dialogue: 0,0:11:54.53,0:11:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laut itu berbahaya,\Nbadai itu mengerikan.
Dialogue: 0,0:11:58.91,0:12:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah diketahui nelayan.
Dialogue: 0,0:12:14.61,0:12:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bahaya bukanlah alasan\Nuntuk tidak melaut.
Dialogue: 0,0:12:32.94,0:12:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya itu kata-kata bijak yang ditulis\NVan Gogh dalam suratnya.
Dialogue: 0,0:12:39.78,0:12:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kak.
Dialogue: 0,0:12:41.87,0:12:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kamu melaut bersamaku?
Dialogue: 0,0:13:24.45,0:13:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian berdua!
Dialogue: 0,0:13:28.00,0:13:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa mencoba bas senyap di sana!
Dialogue: 0,0:13:30.66,0:13:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke sana, yuk!
Dialogue: 0,0:13:32.90,0:13:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak senang, Kak Akane.
Dialogue: 0,0:13:35.29,0:13:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama ingin ke pameran ini.
Dialogue: 0,0:13:38.80,0:13:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan, sih?
Dialogue: 0,0:13:42.22,0:13:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mau minum dulu,\Njadi pergilah sendirian.
Dialogue: 0,0:13:46.06,0:13:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Enggak asyik.
Dialogue: 0,0:13:48.06,0:13:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baru saja memesan!
Dialogue: 0,0:13:50.71,0:13:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti temani aku lihat-lihat baju, ya.
Dialogue: 0,0:13:53.20,0:13:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.
Dialogue: 0,0:14:03.61,0:14:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya boleh keliling\Nsambil bawa minuman, lo.
Dialogue: 0,0:14:07.87,0:14:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarin!\NAku enggak ngerti alat musik.
Dialogue: 0,0:14:12.41,0:14:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau minta diajari Kak Akane?
Dialogue: 0,0:14:21.30,0:14:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung di sini—
Dialogue: 0,0:14:23.43,0:14:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak mau.
Dialogue: 0,0:14:26.90,0:14:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia enggak pernah mau\Nsaat kuajak ke taman hiburan.
Dialogue: 0,0:14:33.23,0:14:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus nurutin dia terus?
Dialogue: 0,0:14:37.42,0:14:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ajak aku saja.
Dialogue: 0,0:14:44.36,0:14:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik dan aku suka.
Dialogue: 0,0:14:48.45,0:14:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada lagu yang kamu suka?
Dialogue: 0,0:14:56.63,0:14:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:15:00.21,0:15:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga suka lagu ini.
Dialogue: 0,0:15:03.62,0:15:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu ini...
Dialogue: 0,0:15:06.17,0:15:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku baru mulai kuliah,\NAkane mengenalkannya padaku.
Dialogue: 0,0:15:13.98,0:15:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering belajar di kamarnya\Nsambil mendengar banyak musik.
Dialogue: 0,0:15:24.61,0:15:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah bilang\Nkalau musiknya ganggu konsentrasiku.
Dialogue: 0,0:15:29.53,0:15:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia egois banget.
Dialogue: 0,0:15:44.09,0:15:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:15:50.14,0:15:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat suka lagu ini.
Dialogue: 0,0:19:20.01,0:19:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan?
Dialogue: 0,0:19:21.43,0:19:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak mau pulang
Dialogue: 0,0:19:25.52,0:19:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat tahun baru.
Dialogue: 0,0:19:28.98,0:19:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena salju?
Dialogue: 0,0:19:30.02,0:19:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, itu dia!
Dialogue: 0,0:19:31.02,0:19:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udah bikin susah jalan,\Nbikin repot bersihin, bikin dingin pula.
Dialogue: 0,0:19:35.83,0:19:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim dingin itu budaya jahat.
Dialogue: 0,0:19:38.57,0:19:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan budaya.
Dialogue: 0,0:19:40.33,0:19:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahmu di daerah Toyama, kan?
Dialogue: 0,0:19:42.58,0:19:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, lebih ke barat.\NMelewati Sungai Shogawa.
Dialogue: 0,0:19:48.04,0:19:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak tahu.
Dialogue: 0,0:19:49.21,0:19:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas, sih.
Dialogue: 0,0:19:54.95,0:19:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu naik kereta Shinkansen\Nsaat pulang ke rumah?
Dialogue: 0,0:19:57.51,0:19:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, kok.
Dialogue: 0,0:19:58.76,0:20:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku naik bus malam karena rumahku\Njauh di selatan Stasiun Nagano.
Dialogue: 0,0:20:02.43,0:20:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau naik kereta Azusa dari Hachioji.
Dialogue: 0,0:20:05.63,0:20:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota yang jadi kenangan itu?
Dialogue: 0,0:20:10.05,0:20:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ngomong apa?\NMaaf.
Dialogue: 0,0:20:13.41,0:20:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak ada.\NMaaf.
Dialogue: 0,0:20:18.45,0:20:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nbenda apa di meja itu?
Dialogue: 0,0:20:23.53,0:20:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:25.38,0:20:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maksudmu ini?
Dialogue: 0,0:20:28.75,0:20:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini minuman keras\Nyang dibawa Kak Yaeka
Dialogue: 0,0:20:31.96,0:20:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk kami.
Dialogue: 0,0:20:33.00,0:20:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:34.17,0:20:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu "Kesunyian Seratus Tahun"?
Dialogue: 0,0:20:37.45,0:20:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian berdua.
Dialogue: 0,0:20:40.68,0:20:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponselmu bunyi di kamarmu, lo.
Dialogue: 0,0:20:43.35,0:20:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:45.37,0:20:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah.
Dialogue: 0,0:20:47.31,0:20:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tinggal dulu, ya, Ketua.
Dialogue: 0,0:20:50.06,0:20:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:09.62,0:21:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum, ah.
Dialogue: 0,0:21:10.77,0:21:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya shochu ini enak.
Dialogue: 0,0:21:14.04,0:21:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Itu es milikku, kan?
Dialogue: 0,0:21:24.51,0:21:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta, ya.
Dialogue: 0,0:21:26.16,0:21:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:21:30.38,0:21:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:21:36.82,0:21:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman keras?
Dialogue: 0,0:21:38.83,0:21:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, minuman apa?
Dialogue: 0,0:21:40.36,0:21:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Ada bahasa Inggris di labelnya!
Dialogue: 0,0:21:45.91,0:21:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Seratus Tahun Kesunyian".
Dialogue: 0,0:21:48.71,0:21:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Novel yang ditulis Márquez?
Dialogue: 0,0:21:51.02,0:21:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa, tuh?
Dialogue: 0,0:21:54.21,0:21:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak pemenang\Npenghargaan Nobel bidang sastra
Dialogue: 0,0:21:57.05,0:21:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kamu tahu?
Dialogue: 0,0:21:59.84,0:22:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murakami Haruki!
Dialogue: 0,0:22:02.88,0:22:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ambil gelas, ah.
Dialogue: 0,0:22:12.29,0:22:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa, sih? Seram!
Dialogue: 0,0:22:14.77,0:22:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Asrama!\NShochu ini keren banget!
Dialogue: 0,0:22:18.07,0:22:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"When you hear music,\Nafter it's over, it's gone in the air".
Dialogue: 0,0:22:22.28,0:22:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"You can never capture it again".
Dialogue: 0,0:22:24.57,0:22:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Setelah didengarkan,\Nmusik akan lenyap di udara".
Dialogue: 0,0:22:27.49,0:22:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tidak akan bisa kembali lagi".
Dialogue: 0,0:22:29.95,0:22:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah kutipan terkenal\Ndari Eric Dolphy!
Dialogue: 0,0:22:32.58,0:22:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren banget!
Dialogue: 0,0:22:35.19,0:22:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siapa, tuh?
Dialogue: 0,0:22:36.04,0:22:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:22:38.13,0:22:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Ibuki.\NAku juga minta es.
Dialogue: 0,0:22:40.84,0:22:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil saja.
Dialogue: 0,0:22:42.51,0:22:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:22:43.84,0:22:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia musisi jaz!
Dialogue: 0,0:22:45.22,0:22:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu belum pernah\Ndengar "Out to Lunch"?
Dialogue: 0,0:22:48.46,0:22:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Belum.
Dialogue: 0,0:22:50.39,0:22:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:22:52.48,0:22:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar! Biar kumainkan!
Dialogue: 0,0:22:55.69,0:22:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:22:58.77,0:23:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat menikmati!
Dialogue: 0,0:23:01.80,0:23:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau meminumnya!
Dialogue: 0,0:23:03.89,0:23:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kumainkan dulu!
Dialogue: 0,0:23:06.43,0:23:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak keberatan minum dari gelasku?
Dialogue: 0,0:23:09.35,0:23:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh?
Dialogue: 0,0:23:12.17,0:23:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kok.
Dialogue: 0,0:23:13.12,0:23:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:23:21.71,0:23:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wiski ini enak!
Dialogue: 0,0:23:24.51,0:23:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu shochu.
Dialogue: 0,0:23:26.25,0:23:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:28.05,0:23:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ramai banget!\NKalian minum bareng?
Dialogue: 0,0:23:31.85,0:23:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Sini dong, Neng!
Dialogue: 0,0:23:35.02,0:23:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siapa, tuh?
Dialogue: 0,0:23:37.40,0:23:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mau, deh!\N- Tunggu!
Dialogue: 0,0:23:39.02,0:23:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sisakan juga untukku!\N- Selamat menikmati!
Dialogue: 0,0:23:41.02,0:23:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sisakan juga untukku!\N- Aku juga ingin cepat minum!
Dialogue: 0,0:23:42.65,0:23:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sisakan juga untukku!\N- Kesunyian Seratus Tahun, ya?
