Dialogue: 0,0:10:40.20,0:10:45.42,sign,,0000,0000,0000,,JALUR PENDAKIAN GUNUNG BUKO
Dialogue: 0,0:10:45.42,0:10:47.88,sign,,0000,0000,0000,,TITIK NO 52
Dialogue: 0,0:10:50.34,0:10:52.80,sign,,0000,0000,0000,,KERJA BAGUS!!\NSILAKAN TUANG AIRNYA DI LUBANG INI
Dialogue: 0,0:11:17.74,0:11:21.99,sign,,0000,0000,0000,,BUKO MASAMUNE
Dialogue: 0,0:11:21.99,0:11:32.00,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:13:09.27,0:13:09.94,sign,,0000,0000,0000,,JEMBATAN OSHINARI
Dialogue: 0,0:13:23.82,0:13:25.78,sign,,0000,0000,0000,,SUNGAI KITAJUKKEN
Dialogue: 0,0:18:58.58,0:18:59.37,sign,,0000,0000,0000,,SAKE TUA
Dialogue: 0,0:19:31.61,0:19:33.19,sign,,0000,0000,0000,,KUAT
Dialogue: 0,0:21:05.37,0:21:07.04,sign,,0000,0000,0000,,KRIM TANGAN DARI PADATAN SISA
Dialogue: 0,0:21:07.04,0:21:07.58,sign,,0000,0000,0000,,SAKE PREMIUM
Dialogue: 0,0:21:42.66,0:21:43.53,sign,,0000,0000,0000,,AIR HANGAT TELAH SIAP
Dialogue: 0,0:22:06.89,0:22:07.89,sign,,0000,0000,0000,,AIR HANGAT TELAH SIAP
Dialogue: 0,0:22:08.14,0:22:09.27,sign,,0000,0000,0000,,AIR HANGAT TELAH SIAP
Dialogue: 0,0:00:09.53,0:00:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suhunya turun drastis, kan?
Dialogue: 0,0:00:12.27,0:00:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam seminggu terakhir.
Dialogue: 0,0:00:13.83,0:00:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:15.41,0:00:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berpikir pasti ada yang naik.
Dialogue: 0,0:00:18.50,0:00:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya.
Dialogue: 0,0:00:20.42,0:00:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah lama tidak naik gunung, sih.
Dialogue: 0,0:00:22.59,0:00:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane!
Dialogue: 0,0:00:24.11,0:00:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demamku naik lagi!
Dialogue: 0,0:00:26.80,0:00:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat saja hari ini!
Dialogue: 0,0:00:29.60,0:00:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:00:31.47,0:00:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan semangatku\Nyang sudah naik sampai puncak ini?
Dialogue: 0,0:00:36.02,0:00:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah.
Dialogue: 0,0:00:38.89,0:00:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku kembalikan\Nmobil yang kita sewa dulu.
Dialogue: 0,0:00:41.40,0:00:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah.
Dialogue: 0,0:00:42.94,0:00:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menjaga Yaeka.
Dialogue: 0,0:00:44.77,0:00:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berangkat saja tanpa kami.
Dialogue: 0,0:00:47.53,0:00:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga di asrama saja.
Dialogue: 0,0:00:50.66,0:00:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:26.54,0:02:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aneh
Dialogue: 0,0:02:28.00,0:02:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kita mendaki gunung\Ndengan anggota seperti ini.
Dialogue: 0,0:02:31.04,0:02:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya tim hore absen semua.
Dialogue: 0,0:02:34.68,0:02:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim hore?
Dialogue: 0,0:02:37.35,0:02:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:02:39.43,0:02:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim rumahan.
Dialogue: 0,0:02:43.27,0:02:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat naik, cepat turun,\Ndan langsung pergi ke onsen.
Dialogue: 0,0:02:46.94,0:02:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung sewa mobil juga.
Dialogue: 0,0:02:51.35,0:02:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:02:52.28,0:02:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu menulis sesuatu.
Dialogue: 0,0:02:55.11,0:02:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu yang dikatakan Yaeka.
Dialogue: 0,0:02:58.35,0:03:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kita wajib mengisi ini.
Dialogue: 0,0:03:01.08,0:03:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antisipasi hilang di gunung, ya?
Dialogue: 0,0:03:03.50,0:03:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa ada orang yang bisa hilang\Ndi gunung dekat perkotaan begini?
Dialogue: 0,0:03:10.20,0:03:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emang ada beruang di Saitama?
Dialogue: 0,0:03:12.59,0:03:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kan Chichibu.
Dialogue: 0,0:03:16.97,0:03:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:03:19.01,0:03:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita naik, yuk.
Dialogue: 0,0:03:35.53,0:03:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kolam!
Dialogue: 0,0:03:37.24,0:03:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada ikannya?
Dialogue: 0,0:03:39.12,0:03:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma air.
Dialogue: 0,0:03:41.02,0:03:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma air, ya?
Dialogue: 0,0:04:03.22,0:04:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi!
Dialogue: 0,0:04:04.72,0:04:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat pagi.
Dialogue: 0,0:04:06.81,0:04:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini cukup sejuk, ya.
Dialogue: 0,0:04:08.60,0:04:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:10.43,0:04:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:04:15.23,0:04:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, ya!
Dialogue: 0,0:04:18.19,0:04:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami disapa orang.
Dialogue: 0,0:04:20.67,0:04:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tidak kenal.
Dialogue: 0,0:04:23.03,0:04:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunung tuh... merepotkan.
Dialogue: 0,0:04:30.29,0:04:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air terjun.
Dialogue: 0,0:04:31.67,0:04:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:04:32.75,0:04:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tulisannya, ya.
Dialogue: 0,0:04:35.00,0:04:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, tolong isi\Nbotol plastik itu dengan air,
Dialogue: 0,0:04:37.59,0:04:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu bawa sampai puncak.
Dialogue: 0,0:04:41.34,0:04:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:04:43.01,0:04:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu botolnya bisa dua liter, lo.
Dialogue: 0,0:04:45.97,0:04:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak ada saluran air di puncak, ya?
Dialogue: 0,0:04:48.74,0:04:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya tidak ada, deh.
Dialogue: 0,0:04:51.88,0:04:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:04:53.17,0:04:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawa satu, deh.
Dialogue: 0,0:04:55.40,0:04:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:58.82,0:05:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kayaknya aku enggak—
Dialogue: 0,0:05:01.01,0:05:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga.
Dialogue: 0,0:05:02.37,0:05:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:07.04,0:05:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:05:33.02,0:05:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa disuruh pun, aku sudah berjuang!
Dialogue: 0,0:05:42.99,0:05:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Capek.
Dialogue: 0,0:05:44.41,0:05:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku sakit.
Dialogue: 0,0:05:46.66,0:05:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengin pulang.
Dialogue: 0,0:05:47.95,0:05:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak asyik.
Dialogue: 0,0:05:49.87,0:05:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan ini sangat hening,\Njadi enggak tenang.
Dialogue: 0,0:05:54.75,0:05:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak paham.
Dialogue: 0,0:05:56.46,0:05:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa asyiknya ini?
Dialogue: 0,0:06:04.14,0:06:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang bergerak?
Dialogue: 0,0:06:08.43,0:06:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Ada sesuatu di balik pohon itu!
Dialogue: 0,0:06:11.33,0:06:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Di mana?
Dialogue: 0,0:06:13.26,0:06:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, lo! Di belakang sana!
Dialogue: 0,0:06:15.19,0:06:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu benar.
Dialogue: 0,0:06:17.36,0:06:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu beruang?
Dialogue: 0,0:06:19.07,0:06:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa betulan beruang?
Dialogue: 0,0:06:21.11,0:06:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan teriak-teriak!
Dialogue: 0,0:06:23.53,0:06:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nanti ke sini!\N- Kamu juga teriak-teriak!
Dialogue: 0,0:06:26.70,0:06:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Habisnya, aku takut!\N- Apa itu benar-benar beruang?
Dialogue: 0,0:06:28.24,0:06:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku juga takut!\N- Apa itu benar-benar beruang?
Dialogue: 0,0:06:32.75,0:06:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rusa!
Dialogue: 0,0:06:44.18,0:06:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku melihat rusa liar.
Dialogue: 0,0:06:47.89,0:06:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau hanya dari kejauhan,\Njantungku berdebar-debar.
Dialogue: 0,0:06:54.92,0:06:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku sedang berada\Ndi luar keseharianku.
Dialogue: 0,0:06:59.82,0:07:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu menyadari itu,
Dialogue: 0,0:07:02.08,0:07:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mulai merasa sedikit terhibur.
Dialogue: 0,0:07:27.20,0:07:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah duluan, Kak!
Dialogue: 0,0:07:29.47,0:07:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:30.64,0:07:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Jangan keluyuran sendiri!
Dialogue: 0,0:07:34.35,0:07:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:07:37.15,0:07:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Halo.
Dialogue: 0,0:07:39.61,0:07:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:07:41.69,0:07:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadi mengambil air\Ndi air terjun bawah sana,
Dialogue: 0,0:07:45.53,0:07:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku kelelahan karena\Nmembawanya seperti ini.
Dialogue: 0,0:07:50.85,0:07:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keteledoran lansia, ya.
Dialogue: 0,0:07:53.83,0:07:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.\NSaya saja tidak berniat membawanya.
Dialogue: 0,0:07:59.25,0:08:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Anda sering naik gunung?
Dialogue: 0,0:08:02.21,0:08:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka gunung.
Dialogue: 0,0:08:04.51,0:08:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kita bisa mendengar\Nberbagai macam suara di sini.
Dialogue: 0,0:08:08.05,0:08:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:09.05,0:08:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada suara di sini?
Dialogue: 0,0:08:11.55,0:08:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, kok.
Dialogue: 0,0:08:13.35,0:08:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba fokuskan telingamu\Ndan dengarkan baik-baik.
Dialogue: 0,0:08:48.14,0:08:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:52.41,0:08:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tadi tidak terdengar apa-apa.
Dialogue: 0,0:08:55.39,0:08:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti telingamu pasti akan terbiasa.
Dialogue: 0,0:08:59.57,0:09:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat manusia itu terlalu ramai,
Dialogue: 0,0:09:02.61,0:09:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi telingamu belum terbiasa\Nmendengarkan suara-suara kecil.
Dialogue: 0,0:09:08.33,0:09:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:09:09.55,0:09:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berjalan lagi,\Ntapi lenganku masih sakit.
Dialogue: 0,0:09:13.87,0:09:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa memaksakan diri?
Dialogue: 0,0:09:15.37,0:09:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang saja airnya di sini.
Dialogue: 0,0:09:17.45,0:09:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!\NAir ini berkah dari Gunung Buko!
Dialogue: 0,0:09:21.59,0:09:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air yang mengalir melalui gunung ini
Dialogue: 0,0:09:24.67,0:09:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan dimanfaatkan penduduk sini\Ndengan penuh syukur.
Dialogue: 0,0:09:29.22,0:09:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu sake Buko Masamune?
Dialogue: 0,0:09:32.12,0:09:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sake kesukaanku.
Dialogue: 0,0:09:34.89,0:09:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sake lokal itu\Njuga pakai air Gunung Buko.
Dialogue: 0,0:09:40.02,0:09:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku ingin bawa air ini\Ndengan rasa penuh syukur.
Dialogue: 0,0:09:45.86,0:09:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki!
Dialogue: 0,0:09:47.69,0:09:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kapan kami harus menunggu?
Dialogue: 0,0:09:49.94,0:09:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo jalan lagi!
Dialogue: 0,0:09:51.97,0:09:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:09:54.21,0:09:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:09:56.16,0:09:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah saya membawa air itu?
Dialogue: 0,0:10:01.56,0:10:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:10:06.36,0:10:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kenapa?
Dialogue: 0,0:10:09.01,0:10:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:10:10.46,0:10:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena saya juga—
Dialogue: 0,0:10:18.01,0:10:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek?
Dialogue: 0,0:10:29.34,0:10:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kenapa?
Dialogue: 0,0:10:35.85,0:10:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya juga suka sake Buko Masamune.
Dialogue: 0,0:11:03.13,0:11:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik gunung itu asyik?
Dialogue: 0,0:11:06.81,0:11:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku mulai memahaminya.
Dialogue: 0,0:11:10.47,0:11:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, setelah memahaminya,
Dialogue: 0,0:11:14.92,0:11:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa bisa lebih menyukainya.
Dialogue: 0,0:11:34.53,0:11:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:11:36.84,0:11:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka.
Dialogue: 0,0:11:43.35,0:11:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, itu...
Dialogue: 0,0:11:46.31,0:11:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alam semesta.\NBukankah kita bahas itu?
Dialogue: 0,0:11:50.23,0:11:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ah...
Dialogue: 0,0:11:52.27,0:11:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, ya?
Dialogue: 0,0:11:54.78,0:11:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bintang di langit Nagano\Ntampak sangat indah, lo.
Dialogue: 0,0:11:58.51,0:12:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dataran tinggi Utsukushigahara\Ndesa Achi.
Dialogue: 0,0:12:01.87,0:12:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku sering ke sana naik mobil\Nuntuk memandang bintang-bintang.
Dialogue: 0,0:12:06.54,0:12:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagimu, alam semesta itu\Nadalah langit berbintang, ya?
Dialogue: 0,0:12:09.79,0:12:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu punya pandangan berbeda?
Dialogue: 0,0:12:12.96,0:12:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah memandangi bintang.
Dialogue: 0,0:12:16.72,0:12:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bima sakti itu bisa dilihat\Ndengan mata telanjang?
Dialogue: 0,0:12:19.97,0:12:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, kok. Mirip awan.
Dialogue: 0,0:12:23.39,0:12:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap bintang juga punya warna\Ndan kilauan berbeda-beda.
Dialogue: 0,0:12:28.02,0:12:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah punya kepribadian dan jati diri.
Dialogue: 0,0:12:30.60,0:12:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, romantis banget.
Dialogue: 0,0:12:33.02,0:12:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alam semesta memang penuh roman.
Dialogue: 0,0:12:36.09,0:12:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita bisa melihat\Nbima sakti hari ini, ya?
Dialogue: 0,0:12:38.78,0:12:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, kok.
Dialogue: 0,0:12:40.49,0:12:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kita ke planetarium.
Dialogue: 0,0:12:43.83,0:12:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.\NKamu mau pergi bersamaku.
Dialogue: 0,0:12:46.87,0:12:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku justru senang karena diajak.
Dialogue: 0,0:12:50.61,0:12:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi,
Dialogue: 0,0:12:52.64,0:12:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak mengajak yang lain?
Dialogue: 0,0:12:57.01,0:12:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kamu, kok.
Dialogue: 0,0:13:00.86,0:13:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kamu, kok, Botan.
Dialogue: 0,0:13:04.75,0:13:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya...
Dialogue: 0,0:13:09.94,0:13:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk, yuk.\NMasih ada waktu sebelum mulai.
Dialogue: 0,0:13:16.94,0:13:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungai ini apa namanya, ya?
Dialogue: 0,0:13:20.51,0:13:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungai Sumida?
Dialogue: 0,0:13:22.70,0:13:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya iya, deh.
Dialogue: 0,0:13:23.82,0:13:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bukan!
Dialogue: 0,0:13:26.16,0:13:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lihat, aslinya—\N- Botan.
Dialogue: 0,0:13:30.41,0:13:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum bir?
Dialogue: 0,0:13:35.42,0:13:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bawa dari asrama?
Dialogue: 0,0:13:37.80,0:13:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:39.38,0:13:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:13:40.47,0:13:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum di luar itu enak.
Dialogue: 0,0:13:43.35,0:13:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oalah.
Dialogue: 0,0:13:45.93,0:13:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba baca labelnya, deh.
Dialogue: 0,0:13:47.64,0:13:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Label? Maksudmu label bir?
Dialogue: 0,0:13:52.25,0:13:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan baku: malt, hop, oat...
Dialogue: 0,0:13:57.62,0:13:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu!
Dialogue: 0,0:14:00.09,0:14:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara black hole dan white hole,
Dialogue: 0,0:14:03.20,0:14:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauh di seberang infinit,\Nbersemayam keabadian mutlak.
Dialogue: 0,0:14:07.70,0:14:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah kita!\NKamu adalah alam semesta!
Dialogue: 0,0:14:12.57,0:14:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren, ya.
Dialogue: 0,0:14:14.67,0:14:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren?
Dialogue: 0,0:14:18.05,0:14:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah bir "Uchu Brewing"\Nyang merupakan produsen bir mikro.
Dialogue: 0,0:14:22.76,0:14:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini dibuat di Tanegashima?
Dialogue: 0,0:14:26.05,0:14:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, tapi di Yamanashi.
Dialogue: 0,0:14:28.01,0:14:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:29.65,0:14:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Tanegashima\Njuga punya tempat produksi shochu, lo.
Dialogue: 0,0:14:33.81,0:14:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada, ya?
Dialogue: 0,0:14:35.57,0:14:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:39.72,0:14:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang.
Dialogue: 0,0:14:47.49,0:14:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini IPA! Pahit!
Dialogue: 0,0:14:49.91,0:14:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu paham, ya?
Dialogue: 0,0:14:51.47,0:14:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku sudah dilatih senior sepuh.
Dialogue: 0,0:14:55.46,0:15:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uchu Brewing adalah produsen bir\Nyang fokus memproduksi IPA.
Dialogue: 0,0:15:00.21,0:15:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bir "Thunder" yang kamu minum
Dialogue: 0,0:15:02.26,0:15:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah salah satu bir\Ndari seri kreasi alam semesta.
Dialogue: 0,0:15:05.31,0:15:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya\Nseri kreasi alam semesta itu?
Dialogue: 0,0:15:10.02,0:15:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu.
Dialogue: 0,0:15:12.69,0:15:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, bir ini dibuat\Ndengan memikirkan alam semesta.
Dialogue: 0,0:15:17.45,0:15:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya,
Dialogue: 0,0:15:18.98,0:15:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga ingin menikmatinya\Nsambil memikirkan alam semesta.
Dialogue: 0,0:15:22.94,0:15:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, mungkin saja
Dialogue: 0,0:15:26.07,0:15:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa lebih memahami minuman ini.
Dialogue: 0,0:15:29.81,0:15:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal paling misterius\Ntentang alam semesta
Dialogue: 0,0:15:33.21,0:15:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kenyataan\Nbahwa ia dapat dipahami.
Dialogue: 0,0:15:36.37,0:15:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepler?
Dialogue: 0,0:15:37.79,0:15:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Einstein.
Dialogue: 0,0:15:41.34,0:15:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:15:43.03,0:15:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, bir ini enak,
Dialogue: 0,0:15:46.63,0:15:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku juga ingin
Dialogue: 0,0:15:48.87,0:15:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih memahamimu.
Dialogue: 0,0:15:55.60,0:15:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masuk, yuk.
Dialogue: 0,0:15:57.61,0:15:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anginnya mulai berembus.
Dialogue: 0,0:16:06.65,0:16:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membeli tiketnya.
Dialogue: 0,0:16:10.03,0:16:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:11.07,0:16:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bebas memilih tempatnya, kan?
Dialogue: 0,0:16:14.31,0:16:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:16.98,0:16:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, soal tadi...
Dialogue: 0,0:16:20.94,0:16:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kita berdua saja,\Nbersikaplah lebih akrab.
Dialogue: 0,0:16:24.50,0:16:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti saat memanggilku "Ibuki".
Dialogue: 0,0:16:28.53,0:16:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu—\N- Dengan begitu,
Dialogue: 0,0:16:30.09,0:16:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah kita bisa lebih dekat?
Dialogue: 0,0:16:32.51,0:16:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perasaanku saja?
Dialogue: 0,0:16:37.00,0:16:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang.\NTerima kasih, Ibuki.
Dialogue: 0,0:16:41.98,0:16:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:43.65,0:16:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa di tempat tidur?
Dialogue: 0,0:16:45.15,0:16:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya aku bebas memilih tempat, kan?
Dialogue: 0,0:16:48.95,0:16:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiyat!
Dialogue: 0,0:17:01.42,0:17:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, kalau kita sedekat ini,\Naku merasa bisa lebih memahamimu.
Dialogue: 0,0:17:07.80,0:17:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah memahaminya,
Dialogue: 0,0:17:10.56,0:17:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa bisa lebih...
Dialogue: 0,0:17:15.18,0:17:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:17:30.81,0:17:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:17:32.74,0:17:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya akan pulang agak larut, ya?
Dialogue: 0,0:17:45.84,0:17:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci!
Dialogue: 0,0:17:46.59,0:17:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci pintunya saat mandi!
Dialogue: 0,0:17:49.53,0:17:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:51.05,0:17:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, apa kamu mau mandi?
Dialogue: 0,0:17:54.34,0:17:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau mandi!\NApa kamu bisa sisakan airnya?
Dialogue: 0,0:17:59.02,0:18:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedikit telat.
Dialogue: 0,0:18:04.78,0:18:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengisian air hangat.
Dialogue: 0,0:18:08.15,0:18:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak ritual malam?
Dialogue: 0,0:18:11.03,0:18:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:18:13.74,0:18:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku...
Dialogue: 0,0:18:14.82,0:18:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perawatan wajah?
Dialogue: 0,0:18:17.78,0:18:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah melakukannya.
Dialogue: 0,0:18:20.83,0:18:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:22.04,0:18:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu tidak kering tanpa pelembap?
Dialogue: 0,0:18:25.96,0:18:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terlalu.
Dialogue: 0,0:18:28.67,0:18:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulitku mudah kering.
Dialogue: 0,0:18:30.88,0:18:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung merawat kulitku\Nsetelah mandi.
Dialogue: 0,0:18:34.76,0:18:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tipe orang\Nyang enggak terlalu dandan?
Dialogue: 0,0:18:37.72,0:18:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:38.93,0:18:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kulitmu sangat cantik.
Dialogue: 0,0:18:42.98,0:18:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling hanya menutupi pori-pori.
Dialogue: 0,0:18:45.52,0:18:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saudari dan temanku\Njuga jarang melakukannya.
Dialogue: 0,0:18:48.48,0:18:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Taiwan juga begitu.
Dialogue: 0,0:18:51.19,0:18:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau minum losion?
Dialogue: 0,0:18:53.82,0:18:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Metode perawatan baru?
Dialogue: 0,0:18:55.74,0:18:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak mau pakai\Nmetode ekstrem begitu.
Dialogue: 0,0:18:59.37,0:19:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sake, kok.\NBotolnya imut, kan?
Dialogue: 0,0:19:02.64,0:19:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sake? Warnanya kecokelatan...
Dialogue: 0,0:19:06.25,0:19:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cokelat amber.
Dialogue: 0,0:19:07.83,0:19:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warnanya gelap\Nkarena ini minuman tua...
Dialogue: 0,0:19:10.96,0:19:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya begitu saat aku dikasih.
Dialogue: 0,0:19:13.11,0:19:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh siapa?
Dialogue: 0,0:19:14.63,0:19:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:19:16.72,0:19:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah memberinya minuman keras
Dialogue: 0,0:19:19.90,0:19:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ini adalah gantinya.
Dialogue: 0,0:19:22.43,0:19:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku mau coba.
Dialogue: 0,0:19:25.31,0:19:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:19:31.61,0:19:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuat banget!
Dialogue: 0,0:19:33.19,0:19:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecap asin?
Dialogue: 0,0:19:34.61,0:19:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ada rasa karamel dan madu...
Dialogue: 0,0:19:37.75,0:19:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya kompleks, ya.
Dialogue: 0,0:19:40.18,0:19:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya sake ini sudah\Ndisimpan selama 26 tahun.
Dialogue: 0,0:19:43.79,0:19:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, ya.
Dialogue: 0,0:19:45.46,0:19:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya pernah menang\Nkompetisi di luar negeri juga.
Dialogue: 0,0:19:49.13,0:19:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kata Ibuki, sih.
Dialogue: 0,0:19:51.84,0:19:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lagi suka minuman tua, nih.
Dialogue: 0,0:19:54.09,0:19:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan awamori, tapi sake.
Dialogue: 0,0:19:55.92,0:19:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah minum Kidoizumi\Ndan Daruma Masamune,
Dialogue: 0,0:19:57.84,0:19:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah ketagihan.
Dialogue: 0,0:19:59.55,0:20:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga sake tua yang disimpan\Ndi tong oak atau tong sherry,
Dialogue: 0,0:20:02.14,0:20:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan rasanya sangat dalam seperti wiski.
Dialogue: 0,0:20:04.93,0:20:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa alkoholnya lebih ringan\Ndan tidak bikin teler.
Dialogue: 0,0:20:07.31,0:20:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini minuman berkualitas!\NSilakan dicoba!
Dialogue: 0,0:20:10.27,0:20:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya,
Dialogue: 0,0:20:12.23,0:20:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku hampir\Ntidak pernah minum sake,
Dialogue: 0,0:20:15.69,0:20:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu masih terlalu berat bagiku.
Dialogue: 0,0:20:18.74,0:20:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku ingin memahaminya.
Dialogue: 0,0:20:22.74,0:20:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin sama-sama.
Dialogue: 0,0:20:25.29,0:20:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:26.79,0:20:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memahami.
Dialogue: 0,0:20:28.50,0:20:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh, sih.
Dialogue: 0,0:20:37.80,0:20:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh, iya.
Dialogue: 0,0:20:39.05,0:20:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang lebih mudah dipahami.
Dialogue: 0,0:20:42.51,0:20:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli ini.
Dialogue: 0,0:20:44.79,0:20:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lip balm yang dibuat\Ndari sisa padatan sake tua tadi.
Dialogue: 0,0:20:51.65,0:20:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lip? Bukan krim?
Dialogue: 0,0:20:54.77,0:20:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minyaknya lebih banyak dari krim,\Njadi lebih ampuh melembapkan.
Dialogue: 0,0:20:58.76,0:21:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Produsen sake memanfaatkan padatan\Nuntuk membuat produk perawatan kulit.
Dialogue: 0,0:21:02.41,0:21:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu menarik, ya.
Dialogue: 0,0:21:04.41,0:21:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:21:05.37,0:21:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang begini juga.
Dialogue: 0,0:21:07.58,0:21:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja.
Dialogue: 0,0:21:17.76,0:21:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo.
Dialogue: 0,0:21:24.41,0:21:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba oleskan.
Dialogue: 0,0:21:30.60,0:21:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air hangat telah siap.
Dialogue: 0,0:21:32.94,0:21:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air hangat telah siap.
Dialogue: 0,0:21:35.07,0:21:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air hangat telah siap.
Dialogue: 0,0:21:37.19,0:21:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air hangat telah siap.
Dialogue: 0,0:21:39.24,0:21:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air hangat telah siap.
Dialogue: 0,0:21:50.83,0:21:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
