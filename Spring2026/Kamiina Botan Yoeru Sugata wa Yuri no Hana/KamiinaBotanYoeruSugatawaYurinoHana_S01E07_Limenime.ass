Dialogue: 0,0:06:59.11,0:06:59.82,sign,,0000,0000,0000,,TITIK NO 30
Dialogue: 0,0:07:06.16,0:07:08.87,sign,,0000,0000,0000,,SUDAH SEJAUH INI, 60 MENIT LAGI
Dialogue: 0,0:07:13.83,0:07:16.54,sign,,0000,0000,0000,,JALUR PENDAKIAN GUNUNG BUKO\NDAN GUNUNG OMOCHI
Dialogue: 0,0:07:19.25,0:07:23.26,sign,,0000,0000,0000,,AREA TERBUKA POHON CEDAR BESAR
Dialogue: 0,0:07:40.82,0:07:41.69,sign,,0000,0000,0000,,DILARANG LEWAT
