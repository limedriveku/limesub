Dialogue: 0,0:01:10.01,0:01:15.64,tanda,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:02:26.58,0:02:32.01,tanda,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:09:10.03,0:09:20.04,tanda,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:12:03.66,0:12:06.37,tanda,,0000,0000,0000,,TIMBANGAN DAPUR, GELAS UKUR
Dialogue: 0,0:14:25.26,0:14:27.22,tanda,,0000,0000,0000,,TONAMI IBUKI
Dialogue: 0,0:14:54.46,0:14:57.21,tanda,,0000,0000,0000,,BIR FUJIZAKURA HEIGHTS
Dialogue: 0,0:15:08.18,0:15:10.64,tanda,,0000,0000,0000,,BAGAIMANA KALAU KITA JALAN-JALAN\NAKHIR PEKAN DEPAN?
Dialogue: 0,0:15:24.36,0:15:27.57,tanda,,0000,0000,0000,,TOKO MINUMAN HAPPY
Dialogue: 0,0:18:23.46,0:18:25.17,tanda,,0000,0000,0000,,MENURUTKU, WISKI STROBERINYA\NSUDAH SIAP DIMINUM
Dialogue: 0,0:18:25.17,0:18:26.92,tanda,,0000,0000,0000,,COBA AJAK DIA MINUM BARENG MALAM INI,\NDARI KAMIINA
Dialogue: 0,0:00:55.99,0:00:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Redalah.
Dialogue: 0,0:02:40.68,0:02:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan!
Dialogue: 0,0:02:41.93,0:02:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf aku telat.\NPraktiknya lama banget.
Dialogue: 0,0:02:45.69,0:02:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti lama, ya.\NKamu kepanasan, kan?
Dialogue: 0,0:02:48.52,0:02:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:50.94,0:02:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bercanda, kok.
Dialogue: 0,0:02:53.35,0:02:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menghabiskan waktu\Ndi toko terdekat.
Dialogue: 0,0:02:55.86,0:02:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai 40 menit, sih.
Dialogue: 0,0:02:58.12,0:02:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya, maaf.
Dialogue: 0,0:02:59.62,0:03:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi sekarang!
Dialogue: 0,0:03:01.37,0:03:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke tempat tujuan kita hari ini!
Dialogue: 0,0:03:03.95,0:03:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bar!
Dialogue: 0,0:03:05.37,0:03:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mah tempat minum di film koboi.
Dialogue: 0,0:03:09.75,0:03:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak begitu tahu soal bar.
Dialogue: 0,0:03:12.38,0:03:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pengalaman pertamamu, ya.
Dialogue: 0,0:03:15.47,0:03:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku sudah tahu cara pesannya.
Dialogue: 0,0:03:17.68,0:03:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara pesan?
Dialogue: 0,0:03:19.05,0:03:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:03:20.76,0:03:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat si master menanyakan pesananku.
Dialogue: 0,0:03:24.23,0:03:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa.
Dialogue: 0,0:03:25.52,0:03:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alkoholnya banyak, esnya sedikit.
Dialogue: 0,0:03:28.06,0:03:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir kedai ramen\Ndengan porsi bebas milih?
Dialogue: 0,0:03:31.48,0:03:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju itu...\NApa kamu juga pakai itu saat kuliah?
Dialogue: 0,0:03:35.03,0:03:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku bingung pilih baju.
Dialogue: 0,0:03:39.20,0:03:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terlihat aneh?
Dialogue: 0,0:03:40.95,0:03:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok. Kamu imut.
Dialogue: 0,0:03:44.89,0:03:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:03:47.04,0:03:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, baju biasa pun\Ntak jadi masalah, kok.
Dialogue: 0,0:03:50.04,0:03:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga belum pernah pergi ke bar ini.
Dialogue: 0,0:03:57.44,0:04:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Rasanya susah buat masuk.
Dialogue: 0,0:04:01.68,0:04:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bar memang punya aura tersendiri.
Dialogue: 0,0:04:05.02,0:04:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, berat banget.
Dialogue: 0,0:04:07.06,0:04:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak pasti tidak bisa membukanya.
Dialogue: 0,0:04:09.35,0:04:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak tidak mungkin datang ke bar.
Dialogue: 0,0:04:20.95,0:04:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:04:27.33,0:04:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.\NTidak ada orang.
Dialogue: 0,0:04:30.75,0:04:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh duduk di depan meja bar?
Dialogue: 0,0:04:32.42,0:04:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:04:38.80,0:04:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:04:40.13,0:04:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini handuk basahnya.
Dialogue: 0,0:04:41.64,0:04:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:45.52,0:04:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wangi sekali.\NSeperti aroma salon.
Dialogue: 0,0:04:50.04,0:04:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pesan Salty Dog.
Dialogue: 0,0:04:51.98,0:04:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:52.97,0:04:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memesan tanpa melihat menu?
Dialogue: 0,0:04:54.94,0:04:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Anda?
Dialogue: 0,0:04:57.78,0:04:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga sama.
Dialogue: 0,0:04:59.65,0:05:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, boleh minta menunya?
Dialogue: 0,0:05:02.99,0:05:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:05:04.87,0:05:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada menunya, ya.
Dialogue: 0,0:05:07.12,0:05:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.\NSeharusnya aku minta menunya dulu.
Dialogue: 0,0:05:10.67,0:05:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira biasanya memesan tanpa lihat menu.
Dialogue: 0,0:05:15.55,0:05:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan Salty Dog-nya.
Dialogue: 0,0:05:19.05,0:05:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelas dan minumannya tampak berkilau.
Dialogue: 0,0:05:21.76,0:05:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti permata minuman keras.
Dialogue: 0,0:05:26.08,0:05:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ada di bibir gelas itu?
Dialogue: 0,0:05:28.85,0:05:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garam.
Dialogue: 0,0:05:30.23,0:05:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diminum dengan garam, ya?\NMinuman ini bebas sekali.
Dialogue: 0,0:05:34.23,0:05:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah salah satu daya tarik koktail.
Dialogue: 0,0:05:41.15,0:05:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak sangat menikmatinya.
Dialogue: 0,0:05:43.95,0:05:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf...
Dialogue: 0,0:05:44.45,0:05:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master.
Dialogue: 0,0:05:45.41,0:05:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa!\NBoleh duduk di depan meja bar?
Dialogue: 0,0:05:48.12,0:05:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:05:49.20,0:05:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:05:49.95,0:05:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, halo.
Dialogue: 0,0:05:53.24,0:05:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan bisa bertemu di sini.
Dialogue: 0,0:05:55.63,0:05:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:05:57.55,0:05:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sering ke sini?
Dialogue: 0,0:05:59.23,0:06:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kadang-kadang.
Dialogue: 0,0:06:01.13,0:06:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ibuki, kamu tidak jadi pesan?\N- Yah, mungkin sebulan sekali.
Dialogue: 0,0:06:04.01,0:06:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ibuki, kamu tidak jadi pesan?\N- Mau minum bareng?
Dialogue: 0,0:06:06.05,0:06:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu saja.
Dialogue: 0,0:06:07.51,0:06:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:06:09.02,0:06:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sempat menduga\Nkalau kamu suka minuman keras.
Dialogue: 0,0:06:12.39,0:06:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ketahuan, nih.
Dialogue: 0,0:06:17.65,0:06:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master, apa kami boleh pindah meja?
Dialogue: 0,0:06:22.28,0:06:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki?
Dialogue: 0,0:06:24.74,0:06:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:06:26.12,0:06:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya akan membawakan minumannya.
Dialogue: 0,0:06:28.08,0:06:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan pilih meja.
Dialogue: 0,0:06:30.89,0:06:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:06:38.67,0:06:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, seharusnya kita duduk di sini\Nsejak awal.
Dialogue: 0,0:06:42.09,0:06:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan begitu.
Dialogue: 0,0:06:44.48,0:06:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tempatnya hening begini,\Naku ingin jauh dari tamu lain.
Dialogue: 0,0:06:52.14,0:06:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya cegukanku berisik.
Dialogue: 0,0:06:55.85,0:06:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku cegukanmu\Ntidak semengganggu itu.
Dialogue: 0,0:07:00.01,0:07:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:07:01.73,0:07:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius.
Dialogue: 0,0:07:03.40,0:07:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku saja tidak terlalu mendengarnya.
Dialogue: 0,0:07:07.52,0:07:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya masih kalah\Nsama sendawaku yang keras.
Dialogue: 0,0:07:11.08,0:07:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku bilang apa—
Dialogue: 0,0:07:12.91,0:07:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Botan.
Dialogue: 0,0:07:18.71,0:07:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:07:21.00,0:07:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah ditegur.
Dialogue: 0,0:07:23.84,0:07:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya aku berisik.
Dialogue: 0,0:07:28.72,0:07:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:07:39.15,0:07:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kita minum!
Dialogue: 0,0:07:41.23,0:07:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tadi bilang, kan?
Dialogue: 0,0:07:43.40,0:07:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koktail adalah minuman yang bebas.
Dialogue: 0,0:07:46.70,0:07:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita juga bisa melakukan ini.
Dialogue: 0,0:07:49.70,0:07:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master.
Dialogue: 0,0:07:51.68,0:07:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pesan koktail pembangkit semangat.
Dialogue: 0,0:07:55.75,0:07:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesanan diterima.
Dialogue: 0,0:08:00.50,0:08:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan, kata-kataku tadi...
Dialogue: 0,0:08:03.96,0:08:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan masalah besar.
Dialogue: 0,0:08:06.42,0:08:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipikirkan, ya.
Dialogue: 0,0:08:09.26,0:08:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:08:15.89,0:08:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menunggu.
Dialogue: 0,0:08:17.69,0:08:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini koktail pembangkit semangat.
Dialogue: 0,0:08:20.31,0:08:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ini bonus untuk teman Anda.
Dialogue: 0,0:08:24.19,0:08:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:08:26.61,0:08:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu beruntung, Botan.
Dialogue: 0,0:08:32.91,0:08:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga pertama kalinya\Nkita pergi ke bar bersama.
Dialogue: 0,0:08:36.28,0:08:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bersenang-senang.
Dialogue: 0,0:08:37.96,0:08:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:47.47,0:08:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:08:49.97,0:08:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:08:51.76,0:08:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak pernah merasa terganggu.
Dialogue: 0,0:09:02.89,0:09:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, kok.
Dialogue: 0,0:09:06.15,0:09:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Botan.
Dialogue: 0,0:09:28.17,0:09:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian, vokalis itu dipecat\Nsaat dia sampai di New York.
Dialogue: 0,0:09:33.18,0:09:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:34.35,0:09:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, setelah itu,\Ndia malah bikin band baru.
Dialogue: 0,0:09:37.72,0:09:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, riff di dalam lagu utama\Nalbum pertamanya keren banget.
Dialogue: 0,0:09:41.77,0:09:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya...
Dialogue: 0,0:09:44.69,0:09:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane?
Dialogue: 0,0:09:46.23,0:09:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Kak Gujyo!
Dialogue: 0,0:09:48.57,0:09:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruangan ini panas banget.
Dialogue: 0,0:09:50.90,0:09:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyalakan AC-nya, dong.
Dialogue: 0,0:09:55.07,0:09:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Remotnya, ah ♪
Dialogue: 0,0:09:58.03,0:10:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tidak ada di mana-mana ♪
Dialogue: 0,0:10:01.08,0:10:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba cari di rak paling dalam.
Dialogue: 0,0:10:02.62,0:10:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam kaleng.
Dialogue: 0,0:10:04.00,0:10:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina, boleh minta waktu sebentar?
Dialogue: 0,0:10:07.67,0:10:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:11.34,0:10:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Anak S2 memang top!
Dialogue: 0,0:10:19.06,0:10:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kamiina.
Dialogue: 0,0:10:21.31,0:10:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertolong banget.
Dialogue: 0,0:10:22.98,0:10:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya pisau\Nkarena tidak pernah masak.
Dialogue: 0,0:10:26.23,0:10:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan lupa di mana talenanku.
Dialogue: 0,0:10:29.23,0:10:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa meminjamkan keduanya.
Dialogue: 0,0:10:32.70,0:10:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kak.\NPinjam pisau mau buat apa, hayo?
Dialogue: 0,0:10:36.87,0:10:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ngomong seram begitu!
Dialogue: 0,0:10:38.78,0:10:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja buat masak!
Dialogue: 0,0:10:40.49,0:10:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:10:42.33,0:10:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencurigakan!
Dialogue: 0,0:10:44.54,0:10:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bikin umeshu?
Dialogue: 0,0:10:47.88,0:10:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, Kak Gujyo.\NKamu pinjam pisau buat bikin umeshu?
Dialogue: 0,0:10:52.05,0:10:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kan umeshu bukan masaka—
Dialogue: 0,0:10:55.51,0:10:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku salah.\NItu termasuk masakan.
Dialogue: 0,0:11:01.02,0:11:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebakanmu hampir benar, Kamiina.
Dialogue: 0,0:11:03.59,0:11:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku tidak pakai buah plum.
Dialogue: 0,0:11:06.23,0:11:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pakai ini.
Dialogue: 0,0:11:08.19,0:11:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti direndam pakai wiski.
Dialogue: 0,0:11:10.15,0:11:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wi-Wiski stroberi?\NSepertinya enak!
Dialogue: 0,0:11:14.61,0:11:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:11:15.61,0:11:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak kemanisan?
Dialogue: 0,0:11:17.36,0:11:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Pasti enak, deh!
Dialogue: 0,0:11:21.11,0:11:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bikin bareng, Kamiina?
Dialogue: 0,0:11:24.04,0:11:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa boleh?
Dialogue: 0,0:11:26.50,0:11:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja boleh.
Dialogue: 0,0:11:28.46,0:11:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah meminjamkan banyak hal.
Dialogue: 0,0:11:31.17,0:11:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:32.63,0:11:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang, ah.\NTerus aku bagaimana?
Dialogue: 0,0:11:35.63,0:11:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Akane.\NBisa tolong siapkan timbangan dapur?
Dialogue: 0,0:11:39.22,0:11:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap, Bos!
Dialogue: 0,0:11:41.57,0:11:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina, tolong sterilkan toplesnya\Ndengan air mendidih.
Dialogue: 0,0:11:45.52,0:11:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara itu,\Naku akan menyiapkan stroberinya.
Dialogue: 0,0:11:49.71,0:11:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane, di mana timbangannya?
Dialogue: 0,0:11:52.59,0:11:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Timbangan dapur.
Dialogue: 0,0:11:55.44,0:11:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini, kan?
Dialogue: 0,0:11:59.53,0:12:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir benar, ya?
Dialogue: 0,0:12:01.45,0:12:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, itu meleset jauh!
Dialogue: 0,0:12:04.21,0:12:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau timbangannya sudah siap,
Dialogue: 0,0:12:06.96,0:12:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tambahkan stroberi\Ndan gula batu sesuai takaran.
Dialogue: 0,0:12:10.63,0:12:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir, tuangkan wiski.
Dialogue: 0,0:12:13.13,0:12:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wiskinya bebas, tapi aku memilih wiski\Nyang dibuat di tong kayu ek sherry.
Dialogue: 0,0:12:20.30,0:12:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, sudah selesai!
Dialogue: 0,0:12:22.76,0:12:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, bagus buat difoto!
Dialogue: 0,0:12:25.22,0:12:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip manisan plum di toko jajanan, ya.
Dialogue: 0,0:12:27.87,0:12:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma mirip, kan?
Dialogue: 0,0:12:29.27,0:12:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin makan sisa stroberi ini\Ndengan susu kental manis.
Dialogue: 0,0:12:32.82,0:12:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil saja di laci dapur pribadiku.
Dialogue: 0,0:12:37.61,0:12:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!\NAnak S2 memang baik!
Dialogue: 0,0:12:42.49,0:12:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina.
Dialogue: 0,0:12:44.03,0:12:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untukmu.
Dialogue: 0,0:12:45.49,0:12:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:46.81,0:12:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini wiski yang tersisa.\NHadiah atas kerja kerasmu.
Dialogue: 0,0:12:50.04,0:12:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, selamat menikmati.
Dialogue: 0,0:12:52.00,0:12:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:54.51,0:12:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, rasanya seperti cokelat pahit.
Dialogue: 0,0:12:58.30,0:13:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya\Njika dipadukan stroberi, ya?
Dialogue: 0,0:13:03.24,0:13:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa reaksinya\Nsaat minum miras unik itu, ya?
Dialogue: 0,0:13:07.81,0:13:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo, apa wiski stroberi ini\Nakan dinikmati sendiri?
Dialogue: 0,0:13:18.86,0:13:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menandingimu, Kamiina.
Dialogue: 0,0:13:23.28,0:13:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebakanmu benar.
Dialogue: 0,0:13:25.47,0:13:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wiski ini adalah scotch\Nbernama The Glenlivet.
Dialogue: 0,0:13:31.40,0:13:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini wiski favoritnya.
Dialogue: 0,0:13:35.00,0:13:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:13:39.88,0:13:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kira-kira dia senang atau tidak, ya.
Dialogue: 0,0:13:42.34,0:13:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku memberikan di hari ultahnya?
Dialogue: 0,0:13:46.93,0:13:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia senang atau tidak, ya?
Dialogue: 0,0:13:53.98,0:13:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:13:57.29,0:14:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus minum ini bersama Ibuki.
Dialogue: 0,0:14:07.53,0:14:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tidak bisa menandingimu.
Dialogue: 0,0:14:12.37,0:14:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susu, susu...
Dialogue: 0,0:14:19.17,0:14:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya enggak punya pisau.
Dialogue: 0,0:14:43.32,0:14:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua, ada apa?
Dialogue: 0,0:14:46.74,0:14:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku susah tidur.\NKalau kamu, Yaeka?
Dialogue: 0,0:14:51.45,0:14:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:14:55.08,0:14:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingin minum tipis-tipis.
Dialogue: 0,0:14:57.21,0:14:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya bir seperti itu, ya?
Dialogue: 0,0:14:59.80,0:15:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukannya saat ke onsen\Ndi Yamanashi bersama Akane tempo hari.
Dialogue: 0,0:15:04.13,0:15:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:15:12.43,0:15:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaeka?
Dialogue: 0,0:15:13.89,0:15:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:15.48,0:15:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa onsen di Yamanashi itu bagus?
Dialogue: 0,0:15:24.36,0:15:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali melihat papan reklame itu,
Dialogue: 0,0:15:27.57,0:15:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya seperti sudah\Nsampai di Yamanashi, kan?
Dialogue: 0,0:15:30.88,0:15:32.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:15:32.87,0:15:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak begitu mengerti\Nkarena berasal dari Toyama.
Dialogue: 0,0:15:37.59,0:15:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga dari Gifu,\Njadi, aku kurang paham.
Dialogue: 0,0:15:41.88,0:15:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanan pulangnya cukup lama, kan?
Dialogue: 0,0:15:45.30,0:15:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau beli satu lagi.\NKamu mau sesuatu?
Dialogue: 0,0:15:50.43,0:15:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, biar aku traktir!
Dialogue: 0,0:15:52.35,0:15:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku beli minuman energi saja.
Dialogue: 0,0:15:54.81,0:15:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, minuman energi?
Dialogue: 0,0:15:56.73,0:15:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti di dalam mobil\Nbisa jadi monster, dong.
Dialogue: 0,0:15:59.19,0:16:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pilihannya cuma monster?
Dialogue: 0,0:16:02.82,0:16:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini supaya aku tidak ketiduran\Nsaat menemani sopir.
Dialogue: 0,0:16:06.95,0:16:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu keberatan?
Dialogue: 0,0:16:12.37,0:16:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sih.
Dialogue: 0,0:16:18.35,0:16:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa menyetir mobil matik, ya?
Dialogue: 0,0:16:21.96,0:16:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mirip gokar, kok.
Dialogue: 0,0:16:24.96,0:16:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah naik gokar.
Dialogue: 0,0:16:27.93,0:16:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama.
Dialogue: 0,0:16:31.14,0:16:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:16:32.10,0:16:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kamu berhenti\Nmemutar eurobeat keras-keras?
Dialogue: 0,0:16:35.20,0:16:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa malu kalau berhenti\Ndi lampu merah.
Dialogue: 0,0:16:37.94,0:16:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jalan bebas hambatan, lo.
Dialogue: 0,0:16:41.69,0:16:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:16:48.07,0:16:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim panas sudah tiba, ya.
Dialogue: 0,0:16:49.91,0:16:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:51.40,0:16:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tadi habis mandi,\Nsudah berkeringat lagi.
Dialogue: 0,0:16:54.74,0:16:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen tadi pilihan tepat, ya.\NMatahari terbitnya kelihatan indah.
Dialogue: 0,0:16:59.79,0:17:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus berterima kasih pada Yaeka.
Dialogue: 0,0:17:01.71,0:17:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu tempat itu dari Yaeka?
Dialogue: 0,0:17:03.92,0:17:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.\NAku belum bilang?
Dialogue: 0,0:17:06.52,0:17:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang tahu banyak soal onsen.
Dialogue: 0,0:17:09.47,0:17:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena dia sering naik gunung, ya?
Dialogue: 0,0:17:11.72,0:17:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu salah satu alasannya,\Ntapi Yaeka berasal dari Yamanashi.
Dialogue: 0,0:17:16.75,0:17:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:17:24.56,0:17:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:17:25.65,0:17:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:17:28.06,0:17:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagusan mana dengan onsen\Nyang kamu kunjungi sama Kamiina?
Dialogue: 0,0:17:39.21,0:17:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa maksudmu?
Dialogue: 0,0:17:44.84,0:17:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:17:53.20,0:17:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo,\Nkita sedang menuju Chichibu, kan?
Dialogue: 0,0:17:57.43,0:17:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:58.81,0:18:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita lewat sini saat berangkat?
Dialogue: 0,0:18:01.27,0:18:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:03.44,0:18:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berangkat lewat rute lain.
Dialogue: 0,0:18:06.15,0:18:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar cepat sampai onsen.
Dialogue: 0,0:18:08.72,0:18:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulangnya lewat mana?
Dialogue: 0,0:18:10.90,0:18:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memutar dulu.
Dialogue: 0,0:18:27.59,0:18:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina.
Dialogue: 0,0:18:29.21,0:18:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo!
Dialogue: 0,0:18:31.63,0:18:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang!
Dialogue: 0,0:18:35.05,0:18:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejuk...
Dialogue: 0,0:18:36.60,0:18:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini dingin!
Dialogue: 0,0:18:38.35,0:18:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketinggiannya hampir 2.000 mdpl.
Dialogue: 0,0:18:42.32,0:18:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita harus siap-siap dulu\Nsebelum datang ke sini?
Dialogue: 0,0:18:46.23,0:18:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti pakai jaket tahan angin.
Dialogue: 0,0:18:48.93,0:18:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap-siap?
Dialogue: 0,0:18:50.69,0:18:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku ingat.
Dialogue: 0,0:18:53.07,0:18:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera bersiap-siap\Nkarena ada penghuni baru.
Dialogue: 0,0:18:56.53,0:18:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, penghuni baru...
Dialogue: 0,0:18:58.33,0:18:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok aku tidak tahu?
Dialogue: 0,0:18:59.79,0:19:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum bilang, sih.
Dialogue: 0,0:19:02.80,0:19:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahasiswi asing\Nyang masuk bulan September
Dialogue: 0,0:19:04.62,0:19:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan datang bulan depan.
Dialogue: 0,0:19:06.41,0:19:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian kemahasiswaan\Nmengabari asrama kemarin.
Dialogue: 0,0:19:09.13,0:19:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Bukankah aku ketuanya?
Dialogue: 0,0:19:12.88,0:19:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tolong diurus, ya.
Dialogue: 0,0:19:15.68,0:19:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong diurus?\NEnak banget bicaranya.
Dialogue: 0,0:19:19.14,0:19:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, kenapa harus mahasiswi asing?
Dialogue: 0,0:19:38.03,0:19:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum, yuk.
Dialogue: 0,0:19:40.95,0:19:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:19:44.16,0:19:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wiski stroberi.
Dialogue: 0,0:19:45.91,0:19:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatnya\Nbersama Kamiina dan Akane.
Dialogue: 0,0:19:48.67,0:19:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merendamnya dengan Glenlivet.
Dialogue: 0,0:19:51.91,0:19:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah... tunggu...
Dialogue: 0,0:19:54.44,0:19:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kamu tidak mau minum denganku, ya?
Dialogue: 0,0:19:58.01,0:20:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!\NNanti siapa sopirnya?
Dialogue: 0,0:20:01.85,0:20:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:20:05.23,0:20:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang dikasih minuman,\Ntapi lebih baik saat tidak menyetir—
Dialogue: 0,0:20:09.40,0:20:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalau aku tidak menyetir,\Nkamu mau minum denganku?
Dialogue: 0,0:20:35.71,0:20:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:20:39.76,0:20:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:21:12.33,0:21:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:21:15.67,0:21:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru akulah...
Dialogue: 0,0:21:31.27,0:21:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berasap.
Dialogue: 0,0:21:38.44,0:21:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo.
Dialogue: 0,0:21:40.53,0:21:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku sudah mengisapnya\Ndengan benar?
Dialogue: 0,0:22:11.14,0:22:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak?
