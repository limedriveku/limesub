Dialogue: 0,0:00:20.75,0:00:21.50,tanda,,0000,0000,0000,,TONARI IBUKI
Dialogue: 0,0:00:47.57,0:00:49.65,tanda,,0000,0000,0000,,G!
Dialogue: 0,0:01:39.95,0:01:45.59,tanda,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:02:56.53,0:03:02.04,tanda,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:03:15.47,0:03:16.59,tanda,,0000,0000,0000,,ENDUS...
Dialogue: 0,0:03:43.37,0:03:45.00,tanda,,0000,0000,0000,,KILAS BALIK
Dialogue: 0,0:03:49.96,0:03:51.09,tanda,,0000,0000,0000,,GUNUNG
Dialogue: 0,0:03:51.09,0:03:56.09,tanda,,0000,0000,0000,,10 TAHUN
Dialogue: 0,0:04:45.35,0:04:47.60,tanda,,0000,0000,0000,,SEMBARANGAN
Dialogue: 0,0:05:21.63,0:05:23.09,tanda,,0000,0000,0000,,80?
Dialogue: 0,0:06:28.62,0:06:30.62,tanda,,0000,0000,0000,,KAMIINA BOTAN
Dialogue: 0,0:07:20.04,0:07:20.59,tanda,,0000,0000,0000,,KEPERLUAN ASRAMA (5)\NAKU KEMBALI KE ASRAMA SIANG INI
Dialogue: 0,0:07:20.59,0:07:22.05,tanda,,0000,0000,0000,,CAPEK BANGET, AKU BAWA BANYAK BARANG\NKITAMORI YAEKA: KERJA BAGUS
Dialogue: 0,0:07:22.05,0:07:23.51,tanda,,0000,0000,0000,,KAMIINA BOTAN: AKU DI DEKAT STASIUN,\NJADI AKU BISA MEMBANTUMU
Dialogue: 0,0:07:23.51,0:07:26.51,tanda,,0000,0000,0000,,STASIUN SEIBU-CHICHIBU
Dialogue: 0,0:07:52.66,0:07:54.62,tanda,,0000,0000,0000,,BUS WISATA SEIBU
Dialogue: 0,0:10:12.47,0:10:14.34,tanda,,0000,0000,0000,,RUANG KOMUNAL
Dialogue: 0,0:13:51.02,0:14:01.03,tanda,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:15:25.65,0:15:27.87,tanda,,0000,0000,0000,,RESTORAN TEPI LAUT
Dialogue: 0,0:15:35.16,0:15:38.04,tanda,,0000,0000,0000,,INI ADALAH OPINI PRIBADI
Dialogue: 0,0:15:48.97,0:15:51.18,tanda,,0000,0000,0000,,TUTUP
Dialogue: 0,0:16:06.86,0:16:09.32,tanda,,0000,0000,0000,,KAMI MENJUAL ES KRIM
Dialogue: 0,0:16:59.87,0:17:01.83,tanda,,0000,0000,0000,,PENGIN CEPAT MINUM
Dialogue: 0,0:17:15.31,0:17:16.52,tanda,,0000,0000,0000,,SPA DAN SAUNA PRIBADI\NPEMANDIAN AIR LANGIT
Dialogue: 0,0:17:58.60,0:17:59.06,tanda,,0000,0000,0000,,BERENDAM
Dialogue: 0,0:18:59.12,0:19:00.12,tanda,,0000,0000,0000,,PERTANYAAN
Dialogue: 0,0:23:13.29,0:23:14.54,tanda,,0000,0000,0000,,BERGAUL AKRAB
Dialogue: 0,0:23:40.65,0:23:44.03,tanda,,0000,0000,0000,,BERSAMBUNG
Dialogue: 0,0:00:17.03,0:00:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci petir.
Dialogue: 0,0:00:23.31,0:00:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf...
Dialogue: 0,0:00:26.13,0:00:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh masuk?
Dialogue: 0,0:00:28.84,0:00:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ketua...
Dialogue: 0,0:00:35.04,0:00:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buka pintunya!
Dialogue: 0,0:00:37.35,0:00:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, makhluk di dalam\Nsedang berkeliaran bebas!
Dialogue: 0,0:00:41.23,0:00:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? A-Apa yang ada di dalam?
Dialogue: 0,0:00:45.15,0:00:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk itu!
Dialogue: 0,0:00:51.81,0:00:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?\N- Reaksimu datar banget!
Dialogue: 0,0:00:54.66,0:00:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihat\N"gokiburi" atau kecoak—
Dialogue: 0,0:00:58.20,0:00:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sebut namanya!
Dialogue: 0,0:01:00.36,0:01:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa makhluk itu tidak ada di Nagano?
Dialogue: 0,0:01:03.29,0:01:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada di sekitar Matsumoto.
Dialogue: 0,0:01:06.09,0:01:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku belum bisa masuk\Nkarena kusemprot racun serangga.
Dialogue: 0,0:01:09.97,0:01:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, kenapa kamu—
Dialogue: 0,0:01:13.72,0:01:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu cukup dekat.
Dialogue: 0,0:01:17.93,0:01:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei, apa aku boleh\Ntidur bersamamu malam ini?
Dialogue: 0,0:01:25.61,0:01:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:01:26.94,0:01:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya...
Dialogue: 0,0:03:02.66,0:03:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, terima kasih sudah\Nmau meminjamkan ini, Kamiina.
Dialogue: 0,0:03:06.83,0:03:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian tidurku di dalam kamar.
Dialogue: 0,0:03:10.46,0:03:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang harus berterima kasih.
Dialogue: 0,0:03:12.46,0:03:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena aku merepotkanmu.
Dialogue: 0,0:03:18.12,0:03:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aroma tubuh Kamiina.
Dialogue: 0,0:03:24.60,0:03:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hening sekali.
Dialogue: 0,0:03:26.27,0:03:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar.
Dialogue: 0,0:03:29.06,0:03:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang sedang pergi\Nkarena libur panjang Golden Week.
Dialogue: 0,0:03:33.11,0:03:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu.
Dialogue: 0,0:03:34.82,0:03:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku kamu.
Dialogue: 0,0:03:40.74,0:03:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu takut petir?
Dialogue: 0,0:03:44.16,0:03:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:45.57,0:03:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut petir
Dialogue: 0,0:03:47.17,0:03:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak ikut kemah musim panas
Dialogue: 0,0:03:49.29,0:03:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan anggota kelas renang saat SD.
Dialogue: 0,0:03:51.71,0:03:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunungnya diguyur hujan deras semalaman
Dialogue: 0,0:03:54.17,0:03:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan itu membuatku trauma.
Dialogue: 0,0:03:58.35,0:04:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pernah ikut kemah musim panas.
Dialogue: 0,0:04:00.89,0:04:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga?
Dialogue: 0,0:04:02.10,0:04:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipaksa orang tuaku, sih.
Dialogue: 0,0:04:05.60,0:04:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah pengalaman buruk.
Dialogue: 0,0:04:10.06,0:04:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekarang,\Nmungkin aku bisa menyukai kemah.
Dialogue: 0,0:04:14.23,0:04:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa masak.
Dialogue: 0,0:04:16.44,0:04:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum miras sepuasnya.
Dialogue: 0,0:04:19.02,0:04:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan memandangi bintang.
Dialogue: 0,0:04:22.51,0:04:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sama kamu, mungkin asyik juga.
Dialogue: 0,0:04:25.20,0:04:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita kemah kapan-kapan!
Dialogue: 0,0:04:28.15,0:04:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat minuman sempurna!
Dialogue: 0,0:04:29.54,0:04:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:04:32.75,0:04:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jreng!
Dialogue: 0,0:04:34.79,0:04:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung tidak ada orang hari ini,\Nayo kita lakukan penutupan malam.
Dialogue: 0,0:04:39.30,0:04:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penutupan malam?
Dialogue: 0,0:04:41.01,0:04:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya minum sebelum tidur.
Dialogue: 0,0:04:42.47,0:04:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidur dalam keadaan mabuk,\Nkamu tidak akan takut petir lagi.
Dialogue: 0,0:04:45.35,0:04:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:04:47.73,0:04:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botolnya ramping dan hitam.
Dialogue: 0,0:04:51.13,0:04:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini wine?
Dialogue: 0,0:04:53.61,0:04:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah "absinthe".
Dialogue: 0,0:04:55.69,0:04:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Absinthe adalah miras herbal\Nyang sama seperti Campari.
Dialogue: 0,0:04:59.49,0:05:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibuat dari "wormwood"
Dialogue: 0,0:05:01.24,0:05:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sering diminum\Nbanyak seniman sejak dulu.
Dialogue: 0,0:05:04.66,0:05:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa seniman?
Dialogue: 0,0:05:06.37,0:05:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman ini bisa bikin halusinasi\Nkarena mengandung senyawa beracun.
Dialogue: 0,0:05:10.41,0:05:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Halusinasi? Emang aman?
Dialogue: 0,0:05:15.09,0:05:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin berbahaya dalam arti tertentu.
Dialogue: 0,0:05:17.00,0:05:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miras ini memiliki kadar alkohol\Nmendekati 80%.
Dialogue: 0,0:05:23.09,0:05:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu sama saja alkohol murni?
Dialogue: 0,0:05:25.89,0:05:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan disamakan!\NIni adalah minuman keras.
Dialogue: 0,0:05:31.56,0:05:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini akan diminum langsung?
Dialogue: 0,0:05:33.65,0:05:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak dicampur air atau es?
Dialogue: 0,0:05:36.15,0:05:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya bisa saja,\Ntapi enaknya diminum langsung dulu.
Dialogue: 0,0:05:43.40,0:05:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku akan dapat trauma baru.
Dialogue: 0,0:05:47.74,0:05:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo bersulang.
Dialogue: 0,0:05:51.66,0:05:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman ini agak spesial,\Njadi jangan memaksakan diri.
Dialogue: 0,0:05:56.50,0:06:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenggorokanku sakit!\NRasanya seperti pasta gigi!
Dialogue: 0,0:06:00.67,0:06:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ternyata benar.
Dialogue: 0,0:06:03.05,0:06:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, efeknya bikin ketagihan\Ndi setiap tegukan.
Dialogue: 0,0:06:07.03,0:06:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sulit dijelaskan,
Dialogue: 0,0:06:09.16,0:06:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi absinthe adalah miras\Nyang mendebarkan, ya.
Dialogue: 0,0:06:15.88,0:06:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku tadi mengatakan hal aneh?
Dialogue: 0,0:06:18.36,0:06:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku juga memikirkan hal itu\Nsaat pertama kali meminumnya.
Dialogue: 0,0:06:24.99,0:06:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kita memang mirip.
Dialogue: 0,0:06:31.45,0:06:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku benar-benar boleh\Ntidur sekasur denganmu?
Dialogue: 0,0:06:35.12,0:06:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!\NSebagai tanda terima kasih.
Dialogue: 0,0:06:41.09,0:06:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujannya sudah reda, ya.
Dialogue: 0,0:06:46.01,0:06:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina, kamu sudah tidur?
Dialogue: 0,0:06:55.69,0:07:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku sangat senang saat bersamamu.
Dialogue: 0,0:07:02.76,0:07:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kita minum-minum lagi, ya.\NSelamat malam.
Dialogue: 0,0:07:10.15,0:07:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ketua Asrama! Cepatlah!
Dialogue: 0,0:07:13.44,0:07:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, iya, iya.
Dialogue: 0,0:07:16.42,0:07:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita belum telat, kok.
Dialogue: 0,0:07:18.46,0:07:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi...
Dialogue: 0,0:07:33.02,0:07:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane!
Dialogue: 0,0:07:35.43,0:07:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali!
Dialogue: 0,0:07:36.96,0:07:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barangmu banyak sekali.\NKami harus bawa yang mana?
Dialogue: 0,0:07:40.36,0:07:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.\NKalian sampai menjemputku.
Dialogue: 0,0:07:42.98,0:07:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sekalian makan siang,\Njadi tidak usah dipikirkan.
Dialogue: 0,0:07:47.95,0:07:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akur sekali belakangan ini.
Dialogue: 0,0:07:53.74,0:07:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:07:54.62,0:07:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian tadi makan apa?
Dialogue: 0,0:07:57.04,0:07:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku makan mi soba Chichibu.
Dialogue: 0,0:07:59.08,0:08:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katsudon waraji!
Dialogue: 0,0:08:00.88,0:08:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:08:01.79,0:08:04.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian makan di pujasera depan stasiun?
Dialogue: 0,0:08:04.49,0:08:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:08:05.51,0:08:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak mampir ke onsen di sebelahnya?
Dialogue: 0,0:08:08.01,0:08:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina belum pernah ke sana, kan?
Dialogue: 0,0:08:10.39,0:08:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mampir, tapi Ketua Asrama...
Dialogue: 0,0:08:14.68,0:08:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau repot mengeringkan rambut.
Dialogue: 0,0:08:18.98,0:08:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang saja kamu malu mandi bareng.
Dialogue: 0,0:08:23.86,0:08:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kenapa tiba-tiba begitu?
Dialogue: 0,0:08:26.61,0:08:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, bukankah kamu\Nsering ke onsen sendirian?
Dialogue: 0,0:08:31.57,0:08:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya,\Nkamu suka minum miras di onsen.
Dialogue: 0,0:08:39.13,0:08:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:08:40.96,0:08:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Asrama memang malu\Nkalau minum miras di depan orang.
Dialogue: 0,0:08:49.76,0:08:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di onsen pribadi,\Nmungkin dia tidak akan malu
Dialogue: 0,0:08:52.97,0:08:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kami cuma berdua saja.
Dialogue: 0,0:08:56.18,0:09:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, tuh, Ketua akan malu\Nkalau mandi sama Kamiina, sih.
Dialogue: 0,0:09:00.48,0:09:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah diartikan ke arah yang aneh.
Dialogue: 0,0:09:06.90,0:09:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang!
Dialogue: 0,0:09:08.44,0:09:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat banget!
Dialogue: 0,0:09:10.50,0:09:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:09:12.45,0:09:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa isinya? Beras?
Dialogue: 0,0:09:15.83,0:09:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perangkat efek yang kudapat dari teman...
Dialogue: 0,0:09:19.33,0:09:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat musik.
Dialogue: 0,0:09:20.66,0:09:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:09:22.29,0:09:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa ini juga alat musik?
Dialogue: 0,0:09:25.75,0:09:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kalau itu...
Dialogue: 0,0:09:28.90,0:09:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jreng!
Dialogue: 0,0:09:36.93,0:09:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak tahu benda ini?
Dialogue: 0,0:09:39.02,0:09:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini piringan hitam.
Dialogue: 0,0:09:43.10,0:09:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini...
Dialogue: 0,0:09:44.94,0:09:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:09:46.82,0:09:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu beli piringan hitam?
Dialogue: 0,0:09:49.49,0:09:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak beli, tapi dikasih.
Dialogue: 0,0:09:51.90,0:09:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku punya banyak piringan hitam.
Dialogue: 0,0:09:54.82,0:09:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memutarnya di asrama,\Njadi aku disuruh bawa sesukaku.
Dialogue: 0,0:09:58.79,0:10:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di asrama?\NBagaimana cara memutarnya?
Dialogue: 0,0:10:02.04,0:10:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku baru dikasih pemutarnya.
Dialogue: 0,0:10:05.25,0:10:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya serba dikasih, ya?
Dialogue: 0,0:10:08.83,0:10:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba dengar?
Dialogue: 0,0:10:10.63,0:10:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau banget!
Dialogue: 0,0:10:15.97,0:10:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu!
Dialogue: 0,0:10:19.31,0:10:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:10:20.77,0:10:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa yang kamu bawa, Akane?
Dialogue: 0,0:10:23.06,0:10:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemutar musik.
Dialogue: 0,0:10:24.56,0:10:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan itu!
Dialogue: 0,0:10:26.98,0:10:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang bisa dinikmati\Nsambil mendengarkan musik.
Dialogue: 0,0:10:29.94,0:10:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punk IPA.
Dialogue: 0,0:10:32.28,0:10:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punk?
Dialogue: 0,0:10:33.86,0:10:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu minuman keras?
Dialogue: 0,0:10:36.45,0:10:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ini bir asal Skotlandia.
Dialogue: 0,0:10:40.08,0:10:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bir pahit ini menggunakan
Dialogue: 0,0:10:41.75,0:10:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bunga hop 40 kali lebih banyak\Ndari bir lager standar.
Dialogue: 0,0:10:45.04,0:10:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}40 kali?
Dialogue: 0,0:10:46.63,0:10:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.\NBukan berarti 40 kali lebih pahit, kok.
Dialogue: 0,0:10:51.21,0:10:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma dua kali lebih pahit\Ndari bir lager biasa.
Dialogue: 0,0:10:55.28,0:10:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bir lager?\NAku belum pernah coba.
Dialogue: 0,0:10:58.35,0:11:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, begitu, ya.
Dialogue: 0,0:11:01.10,0:11:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:11:01.89,0:11:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapannya sudah selesai...
Dialogue: 0,0:11:04.89,0:11:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina.
Dialogue: 0,0:11:06.23,0:11:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba taruh jarumnya?
Dialogue: 0,0:11:07.65,0:11:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah?
Dialogue: 0,0:11:11.88,0:11:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini namanya headshell.
Dialogue: 0,0:11:13.49,0:11:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pegangan di dekat tempat jarumnya.
Dialogue: 0,0:11:17.36,0:11:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pindahkan dan letakkan jarumnya\Nke ujung piringan dengan hati-hati.
Dialogue: 0,0:11:49.00,0:11:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka banget.\NNuansanya analog.
Dialogue: 0,0:11:57.71,0:11:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren.
Dialogue: 0,0:12:02.94,0:12:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau menelepon seseorang.
Dialogue: 0,0:12:06.50,0:12:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:07.62,0:12:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, minumlah itu.
Dialogue: 0,0:12:09.83,0:12:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin?
Dialogue: 0,0:12:12.50,0:12:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:12:15.71,0:12:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa ikut minum\Nkarena Kak Yusa tidak ada.
Dialogue: 0,0:12:19.49,0:12:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu memang benar,\Ntapi aku merasa tidak enak.
Dialogue: 0,0:12:25.64,0:12:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:12:26.55,0:12:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah.
Dialogue: 0,0:12:28.14,0:12:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari bersulang saja.
Dialogue: 0,0:12:32.33,0:12:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:33.57,0:12:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membawanya dari koleksi ayahku di rumah.
Dialogue: 0,0:12:36.99,0:12:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, nanti kuputarkan untukmu.
Dialogue: 0,0:12:42.18,0:12:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah ulang tahun terbaik.
Dialogue: 0,0:12:44.83,0:12:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Yaeka.
Dialogue: 0,0:12:53.63,0:12:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahit!
Dialogue: 0,0:12:55.34,0:12:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa pahit jeruknya terasa banget!
Dialogue: 0,0:13:00.14,0:13:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih bisa menikmati rasa pahit ini?
Dialogue: 0,0:13:04.22,0:13:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka karena kemasannya keren!
Dialogue: 0,0:13:06.83,0:13:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok itu?
Dialogue: 0,0:13:08.50,0:13:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku senang.
Dialogue: 0,0:13:10.89,0:13:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat suka Punk IPA ini.
Dialogue: 0,0:13:14.15,0:13:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi senang kalau kamu menyukainya.
Dialogue: 0,0:13:20.82,0:13:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, aku selalu memikirkannya.
Dialogue: 0,0:13:23.27,0:13:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Asrama.
Dialogue: 0,0:13:27.75,0:13:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita ke onsen pribadi?
Dialogue: 0,0:13:31.25,0:13:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdua saja.
Dialogue: 0,0:13:35.00,0:13:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu minum sendirian.
Dialogue: 0,0:13:37.71,0:13:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir itu sudah cukup untukku.
Dialogue: 0,0:13:42.83,0:13:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekarang...
Dialogue: 0,0:13:45.93,0:13:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ayo kita pergi.
Dialogue: 0,0:14:04.49,0:14:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:14:08.48,0:14:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo?
Dialogue: 0,0:14:09.54,0:14:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mencari seseorang?
Dialogue: 0,0:14:11.92,0:14:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yusa?
Dialogue: 0,0:14:13.54,0:14:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu di mana Ibuki?
Dialogue: 0,0:14:15.83,0:14:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua sudah pergi sejak pagi-pagi sekali.
Dialogue: 0,0:14:18.84,0:14:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:14:20.55,0:14:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bersama Kamiina.
Dialogue: 0,0:14:25.72,0:14:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:41.19,0:14:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami benar-benar pergi.
Dialogue: 0,0:14:44.11,0:14:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke tempat onsen.
Dialogue: 0,0:14:45.61,0:14:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua! Lihatlah!
Dialogue: 0,0:14:49.24,0:14:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lautnya indah sekali!
Dialogue: 0,0:14:51.62,0:14:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, aku sudah lihat dari tadi.
Dialogue: 0,0:14:56.25,0:14:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silau sekali.
Dialogue: 0,0:15:02.51,0:15:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdua dengannya.
Dialogue: 0,0:15:04.00,0:15:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh.\NMemang menyilaukan.
Dialogue: 0,0:15:08.48,0:15:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada waktu\Nsampai kita bisa masuk onsennya.
Dialogue: 0,0:15:12.52,0:15:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan hidangan laut?
Dialogue: 0,0:15:14.99,0:15:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:15:16.40,0:15:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga cuma nyemil sedikit\Ndi kereta wisata.
Dialogue: 0,0:15:19.06,0:15:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita makan siang.
Dialogue: 0,0:15:23.69,0:15:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:15:25.65,0:15:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan laut!
Dialogue: 0,0:15:27.87,0:15:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lebai banget.
Dialogue: 0,0:15:29.95,0:15:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari dulu, orang Shinshu\Nmerindukan makanan laut.
Dialogue: 0,0:15:34.33,0:15:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:15:35.16,0:15:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan salah paham,
Dialogue: 0,0:15:36.58,0:15:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Sayur Nozawana!
Dialogue: 0,0:15:38.04,0:15:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan pengkhianatan\Natau penistaan dalam tanda petik!
Dialogue: 0,0:15:41.88,0:15:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah tergoda lobster!
Dialogue: 0,0:15:44.55,0:15:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku orang Shinshu yang baik!
Dialogue: 0,0:15:46.38,0:15:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, sini!
Dialogue: 0,0:15:48.30,0:15:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah?
Dialogue: 0,0:15:49.66,0:15:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, serius?
Dialogue: 0,0:15:55.89,0:15:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangatnya langsung redup.
Dialogue: 0,0:15:58.37,0:16:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lobster...
Dialogue: 0,0:16:02.65,0:16:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti makan di depan stasiun\Nsetelah mandi, ya.
Dialogue: 0,0:16:12.68,0:16:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu aktif, Kamiina!
Dialogue: 0,0:16:14.66,0:16:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:16:16.37,0:16:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:16:18.34,0:16:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada krim di pipimu.
Dialogue: 0,0:16:22.24,0:16:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, sudah hilang.
Dialogue: 0,0:16:24.76,0:16:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:30.29,0:16:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah saatnya masuk onsen.
Dialogue: 0,0:16:35.52,0:16:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina?
Dialogue: 0,0:16:36.89,0:16:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya!
Dialogue: 0,0:16:40.94,0:16:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas nama Nona Kamiina, ya?\NKami menunggu kedatangan Anda.
Dialogue: 0,0:16:45.37,0:16:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen pribadi terbuka kami\Nbisa digunakan selama 50 menit.
Dialogue: 0,0:16:49.61,0:16:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian memiliki pertanyaan?
Dialogue: 0,0:16:52.37,0:16:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tentang minuman keras\Nyang saya tanyakan lewat telepon.
Dialogue: 0,0:16:56.83,0:16:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah menyiapkan\Ndua cangkir untuk kalian.
Dialogue: 0,0:16:59.87,0:17:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengin cepat minum.
Dialogue: 0,0:17:01.83,0:17:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melihat suara hati temannya.
Dialogue: 0,0:17:05.83,0:17:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, selamat menikmati.
Dialogue: 0,0:17:09.47,0:17:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa melihat laut dari onsen.
Dialogue: 0,0:17:11.97,0:17:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tempat gantinya di luar ruangan, ya?
Dialogue: 0,0:17:16.52,0:17:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempatnya.\NPemandian Air Langit.
Dialogue: 0,0:17:19.48,0:17:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir tempatnya lebih kuno,
Dialogue: 0,0:17:22.09,0:17:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ternyata modern banget.
Dialogue: 0,0:17:24.08,0:17:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situs webnya juga sangat keren.
Dialogue: 0,0:17:27.48,0:17:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, ternyata jarang ada onsen\Nyang mengizinkan mandi sambil minum.
Dialogue: 0,0:17:32.86,0:17:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kita tidak boleh berendam\Ndalam keadaan mabuk, sih.
Dialogue: 0,0:17:36.41,0:17:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mari kita lihat\Npemandangan lautnya!
Dialogue: 0,0:17:47.86,0:17:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali!
Dialogue: 0,0:17:49.72,0:17:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin banget!
Dialogue: 0,0:17:51.59,0:17:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angin lautnya langsung menerpa kita.
Dialogue: 0,0:17:53.89,0:17:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo masuk air!
Dialogue: 0,0:17:57.79,0:17:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah!
Dialogue: 0,0:18:00.01,0:18:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bersulang!
Dialogue: 0,0:18:01.94,0:18:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:04.77,0:18:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, langsung habis.
Dialogue: 0,0:18:07.44,0:18:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu sesuai seleramu, ya?
Dialogue: 0,0:18:10.53,0:18:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, biar kutuangkan lagi.
Dialogue: 0,0:18:12.78,0:18:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku bisa menuangnya sendiri.
Dialogue: 0,0:18:15.87,0:18:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:18:17.12,0:18:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau merepotkan sosok penting\Nyang sudah memesankan tempat ini.
Dialogue: 0,0:18:21.04,0:18:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:18:23.37,0:18:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:18:29.84,0:18:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uenak!
Dialogue: 0,0:18:33.11,0:18:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini minuman lokal sini, ya?\NNanti aku tanya mereknya, ah.
Dialogue: 0,0:18:38.06,0:18:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, anginnya segar!
Dialogue: 0,0:18:49.32,0:18:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:18:51.36,0:18:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru menyadari sesuatu.
Dialogue: 0,0:18:55.49,0:18:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:58.18,0:18:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:01.55,0:19:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat terpengaruh minuman keras,
Dialogue: 0,0:19:04.50,0:19:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi sedikit terbuka, ya?
Dialogue: 0,0:19:10.09,0:19:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma sedikit,\Ntapi tidak bisa dibantah.
Dialogue: 0,0:19:17.08,0:19:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh minta sesuatu\Ndengan kekuatan miras?
Dialogue: 0,0:19:21.85,0:19:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kudengarkan.
Dialogue: 0,0:19:25.73,0:19:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa?
Dialogue: 0,0:19:28.65,0:19:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:19:30.88,0:19:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:19:34.24,0:19:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku memanggil namamu?
Dialogue: 0,0:19:36.28,0:19:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti Kak Gujyo!
Dialogue: 0,0:19:38.24,0:19:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:41.02,0:19:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kok.
Dialogue: 0,0:19:44.08,0:19:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa? Cuma itu?
Dialogue: 0,0:19:46.21,0:19:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Syukurlah!
Dialogue: 0,0:19:50.09,0:19:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:19:51.96,0:19:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga
Dialogue: 0,0:19:54.68,0:19:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan memanggilmu Botan.
Dialogue: 0,0:19:58.30,0:19:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:59.09,0:20:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik! Boleh!
Dialogue: 0,0:20:04.70,0:20:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Napa aku juga boleh bilang sesuatu?
Dialogue: 0,0:20:07.94,0:20:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa, nih?\NPengakuan cinta?
Dialogue: 0,0:20:15.86,0:20:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menemaniku minum.
Dialogue: 0,0:20:20.41,0:20:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, saat minum sendirian,
Dialogue: 0,0:20:23.41,0:20:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa ada yang kurang.
Dialogue: 0,0:20:26.40,0:20:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tidak pernah\Nmerasakannya sebelumnya.
Dialogue: 0,0:20:30.08,0:20:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua...
Dialogue: 0,0:20:31.92,0:20:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pasti akan lebih asyik kalau ada dia."
Dialogue: 0,0:20:35.09,0:20:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pasti minumannya akan terasa lebih nikmat."
Dialogue: 0,0:20:40.09,0:20:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:20:42.55,0:20:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lebih sering\Nminum bersamamu, Botan.
Dialogue: 0,0:20:49.41,0:20:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?
Dialogue: 0,0:20:53.78,0:20:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar, Ketua...
Dialogue: 0,0:20:55.98,0:21:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang curang, Ibuki.
Dialogue: 0,0:21:03.06,0:21:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu merah, lo.
Dialogue: 0,0:21:05.39,0:21:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karena minuman keras.
Dialogue: 0,0:22:41.21,0:22:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piza daun bawang kujo\Nditambah ikan teri putih,
Dialogue: 0,0:22:43.47,0:22:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ikan hokke panggang...
Dialogue: 0,0:22:45.30,0:22:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Yaeka, ada kacang ginkgo goreng, lo.
Dialogue: 0,0:22:47.93,0:22:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku mau!
Dialogue: 0,0:22:49.64,0:22:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sate ayam campur.
Dialogue: 0,0:22:51.68,0:22:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, salad tahu dan semur urat sapi.
Dialogue: 0,0:22:56.63,0:22:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, bagaimana kalau kita bersulang dulu?
Dialogue: 0,0:22:59.82,0:23:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merayakan apa?
Dialogue: 0,0:23:01.15,0:23:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa, ya?
Dialogue: 0,0:23:04.99,0:23:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Po-Pokoknya, ayo bersulang!
Dialogue: 0,0:23:09.96,0:23:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Ibuki dan Kamiina
Dialogue: 0,0:23:13.29,0:23:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah bergaul akrab di onsen saat ini.
Dialogue: 0,0:23:16.04,0:23:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?\NBergaul akrab?
Dialogue: 0,0:23:18.96,0:23:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka jadi lebih akrab,\Nsampai memanggil "kau" dan "elu".
Dialogue: 0,0:23:23.01,0:23:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya itu bisa disebut akrab?
Dialogue: 0,0:23:26.43,0:23:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya itu hubungan rival\Nyang saling menghargai seperti teman.
Dialogue: 0,0:23:30.37,0:23:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan Ibuki, hubungan rival\Nyang saling menghargai seperti teman.
Dialogue: 0,0:23:39.31,0:23:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iri!
Dialogue: 0,0:23:42.32,0:23:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu iri, ya?
