Dialogue: 0,0:09:35.05,0:09:37.56,tanda,,0000,0000,0000,,ASRAMA MAHASISWA
Dialogue: 0,0:10:40.58,0:10:42.08,tanda,,0000,0000,0000,,KAMIINA BOTAN
Dialogue: 0,0:11:53.65,0:11:56.11,tanda,,0000,0000,0000,,ANGGUR KYOHO
Dialogue: 0,0:13:17.78,0:13:19.40,tanda,,0000,0000,0000,,PEMINUM BARU:
Dialogue: 0,0:13:19.40,0:13:21.41,tanda,,0000,0000,0000,,KERAS? MANIS? ASAM, RASA ANGGUR
Dialogue: 0,0:13:21.41,0:13:22.99,tanda,,0000,0000,0000,,PEMINUM PRO: AROMA MADU,
Dialogue: 0,0:13:22.99,0:13:23.77,tanda,,0000,0000,0000,,RASA VANILA TIPIS,
Dialogue: 0,0:13:23.77,0:13:25.66,tanda,,0000,0000,0000,,RASA BEKASNYA KUAT
Dialogue: 0,0:14:16.21,0:14:18.00,tanda,,0000,0000,0000,,JUMANGOKU
