Dialogue: 0,0:00:12.97,0:00:18.60,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:01:29.55,0:01:34.99,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:03:23.73,0:03:25.98,sign,,0000,0000,0000,,ORIENTASI PENCARIAN KERJA,\NSELASA DEPAN, DI GEDUNG PERKULIAHAN
Dialogue: 0,0:03:25.98,0:03:27.56,sign,,0000,0000,0000,,MAU PERGI BERSAMA?
Dialogue: 0,0:03:27.56,0:03:29.06,sign,,0000,0000,0000,,OH, KAMU ADA PRAKTIKUM, KAN, YA?
Dialogue: 0,0:03:31.45,0:03:35.74,sign,,0000,0000,0000,,ORANG YANG MEMUTUS KONEKSI ITU\NTIDAK TERMAAFKAN!
Dialogue: 0,0:03:35.74,0:03:37.47,sign,,0000,0000,0000,,BERHENTI PAKAI STIKER ACAK
Dialogue: 0,0:03:53.96,0:03:54.71,sign,,0000,0000,0000,,YAMAGISHI KAITO
Dialogue: 0,0:03:54.71,0:03:55.55,sign,,0000,0000,0000,,KAMI INGIN KONSULTASI PERMINTAAN\NPEMBUATAN MUSIK UNTUK GAME PONSEL
Dialogue: 0,0:03:55.55,0:03:57.25,sign,,0000,0000,0000,,KAMI INGIN BUAT BGM UNTUK GAME\NYANG MASIH DIKEMBANGKAN, "PROJECT K"
Dialogue: 0,0:03:57.25,0:03:58.48,sign,,0000,0000,0000,,KAMI RASA MUSIK Y0US!R DI MEDIA SOSIAL\NSANGAT SESUAI DENGAN CITRA PROYEK INI
Dialogue: 0,0:03:58.48,0:04:00.02,sign,,0000,0000,0000,,KAMI AKAN SANGAT MENGHARGAI\NJIKA ANDA MEMPERTIMBANGKANNYA
Dialogue: 0,0:04:00.02,0:04:03.38,sign,,0000,0000,0000,,UNTUK AKANE, LAMA TIDAK BERJUMPA
Dialogue: 0,0:04:03.38,0:04:05.43,sign,,0000,0000,0000,,INI MEMANG MENDADAK,\NTAPI AKU INGIN MENGADAKAN KONSER
Dialogue: 0,0:04:05.43,0:04:06.98,sign,,0000,0000,0000,,DI TOKYO BULAN DEPAN,\NDAN AKU BUTUH BANTUANMU
Dialogue: 0,0:04:08.77,0:04:10.23,sign,,0000,0000,0000,,INI TIDAK AKAN KEREN TANPAMU
Dialogue: 0,0:06:00.75,0:06:02.03,sign,,0000,0000,0000,,- DJ?
Dialogue: 0,0:10:26.90,0:10:27.37,sign,,0000,0000,0000,,SETELAH INI, KITA MINUM, BERDUA SAJA
Dialogue: 0,0:10:53.43,0:10:55.38,sign,,0000,0000,0000,,BOTAN: SETELAH INI, AKU INGIN KE DRUGSTORE\NBERSAMA CHIN-LAN, APA TIDAK MASALAH?
Dialogue: 0,0:11:47.44,0:11:49.67,sign,,0000,0000,0000,,SETELAH INI, AKU INGIN KE DRUGSTORE
Dialogue: 0,0:11:49.67,0:11:51.40,sign,,0000,0000,0000,,BERSAMA CHIN-LAN, BOLEH, KAN?
Dialogue: 0,0:11:51.40,0:11:53.02,sign,,0000,0000,0000,,OKE
Dialogue: 0,0:11:53.02,0:11:56.48,sign,,0000,0000,0000,,SIAP
Dialogue: 0,0:11:56.48,0:11:59.49,sign,,0000,0000,0000,,NIKMATILAH WAKTU KALIAN
Dialogue: 0,0:11:59.49,0:12:02.37,sign,,0000,0000,0000,,ASYIK
Dialogue: 0,0:16:24.48,0:16:33.92,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:18:17.95,0:18:19.95,sign,,0000,0000,0000,,KANNOI KARAMATSU
Dialogue: 0,0:18:26.96,0:18:30.46,sign,,0000,0000,0000,,KEDAI MAKAN UDON DAN SOBA
Dialogue: 0,0:19:12.51,0:19:15.51,sign,,0000,0000,0000,,SUMBER AIR
Dialogue: 0,0:19:41.24,0:19:42.15,sign,,0000,0000,0000,,DILARANG MENYALAKAN KEMBANG API\NSAMPAI PUKUL 21.00
Dialogue: 0,0:01:52.10,0:01:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara gitarnya terlalu pecah, deh.
Dialogue: 0,0:01:55.21,0:01:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bass.
Dialogue: 0,0:01:56.22,0:01:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mainnya terlalu berat.\NTolong disesuaikan lagi.
Dialogue: 0,0:01:59.72,0:02:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk drum, kurangi tenaga dan rapikan.
Dialogue: 0,0:02:02.32,0:02:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatikan jedanya.
Dialogue: 0,0:02:04.50,0:02:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin nada D bagian reff\Nditurunkan satu oktaf.
Dialogue: 0,0:02:07.65,0:02:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bass-nya bisa pakai lima senar?\NAtau diturunkan ke Drop D.
Dialogue: 0,0:02:10.87,0:02:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane.
Dialogue: 0,0:02:13.42,0:02:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai di sini saja.
Dialogue: 0,0:02:15.03,0:02:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah cukup, kan?
Dialogue: 0,0:02:21.62,0:02:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:02:22.72,0:02:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:02:23.72,0:02:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus!
Dialogue: 0,0:02:25.90,0:02:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, ya?
Dialogue: 0,0:02:27.77,0:02:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal masih ada waktu\Nsebelum latihannya selesai.
Dialogue: 0,0:02:31.87,0:02:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk urusan konser nanti,\Nboleh kirimkan detailnya?
Dialogue: 0,0:02:35.02,0:02:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:02:36.00,0:02:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus!
Dialogue: 0,0:02:39.55,0:02:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asai, selamat atas pekerjaan barumu.
Dialogue: 0,0:02:42.37,0:02:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, terima kasih.
Dialogue: 0,0:02:43.70,0:02:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penetapannya bulan depan.
Dialogue: 0,0:02:45.62,0:02:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, ya, lolos mepet-mepet.
Dialogue: 0,0:02:47.85,0:02:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Traktir aku, dong.
Dialogue: 0,0:02:49.44,0:02:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kebalik!
Dialogue: 0,0:02:54.17,0:02:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, ya.
Dialogue: 0,0:02:55.75,0:02:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, band kita bagaimana?
Dialogue: 0,0:02:58.62,0:03:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaan itu malah bikin masalah.
Dialogue: 0,0:03:02.05,0:03:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efeknya kayak bumerang.
Dialogue: 0,0:03:11.35,0:03:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah selesai lebih awal,\Njadi, aku akan ke tempat itu duluan.
Dialogue: 0,0:03:39.10,0:03:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udah kena bumerang aja, nih.
Dialogue: 0,0:04:00.02,0:04:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda ingin tambah kopi, Nona?
Dialogue: 0,0:04:07.92,0:04:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane, kamu ditawari kopi, tuh.
Dialogue: 0,0:04:13.82,0:04:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Akane!
Dialogue: 0,0:04:18.25,0:04:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami minta menunya.
Dialogue: 0,0:04:20.97,0:04:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:04:23.67,0:04:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah menunggu.
Dialogue: 0,0:04:27.57,0:04:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bengong terus, dasar!
Dialogue: 0,0:04:35.15,0:04:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:04:36.96,0:04:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali,\NKak Gujyo tidak bisa datang.
Dialogue: 0,0:04:39.97,0:04:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia sedang sibuk di kantor.
Dialogue: 0,0:04:42.76,0:04:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kantor?
Dialogue: 0,0:04:43.92,0:04:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang magang.
Dialogue: 0,0:04:46.03,0:04:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Chin-lan.\NApa aku boleh mencicipi itu?
Dialogue: 0,0:04:49.72,0:04:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:51.55,0:04:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kasih punyaku, ya.
Dialogue: 0,0:04:53.57,0:04:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punyaku juga.
Dialogue: 0,0:04:54.86,0:04:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:57.20,0:05:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bangga padamu\Nkarena tidak bawa alat musik hari ini.
Dialogue: 0,0:05:00.70,0:05:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, dengar.
Dialogue: 0,0:05:01.87,0:05:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane pernah bawa alat musik ke restoran
Dialogue: 0,0:05:04.58,0:05:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang punya aturan berpakaian.
Dialogue: 0,0:05:06.80,0:05:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia enggak peka sama situasi.
Dialogue: 0,0:05:10.42,0:05:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana, tuh?
Dialogue: 0,0:05:12.45,0:05:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Ginza!\NSaat ulang tahun.
Dialogue: 0,0:05:15.32,0:05:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:05:16.22,0:05:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kalian ke mana?
Dialogue: 0,0:05:18.82,0:05:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ke restoran Prancis\Nbernama "Rosia" di jalan Namiki.
Dialogue: 0,0:05:21.77,0:05:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kedengaran mahal.
Dialogue: 0,0:05:24.15,0:05:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahal, dong.
Dialogue: 0,0:05:27.27,0:05:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa kamu sakit perut?
Dialogue: 0,0:05:32.47,0:05:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.\NAku tidak apa-apa.
Dialogue: 0,0:05:35.30,0:05:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:39.60,0:05:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku punya ide.
Dialogue: 0,0:05:42.12,0:05:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita ke pemandian umum?
Dialogue: 0,0:05:49.66,0:05:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya unik banget.
Dialogue: 0,0:05:56.20,0:05:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada meja DJ di tempat resepsionisnya.
Dialogue: 0,0:05:59.50,0:06:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren, kan?
Dialogue: 0,0:06:13.17,0:06:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, mandilah duluan.
Dialogue: 0,0:06:15.60,0:06:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa tidak bareng saja?
Dialogue: 0,0:06:18.65,0:06:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan menyusul.
Dialogue: 0,0:06:21.60,0:06:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku di sana, Akane.
Dialogue: 0,0:06:23.66,0:06:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:39.17,0:06:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan dua yang ini.
Dialogue: 0,0:06:40.85,0:06:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan membuatnya.
Dialogue: 0,0:06:43.90,0:06:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandian macam apa\Nyang punya piringan hitam?
Dialogue: 0,0:06:47.27,0:06:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka bisa memutar lagu\Nyang kuminta, ya?
Dialogue: 0,0:06:51.56,0:06:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:06:53.44,0:06:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat ambil ini.
Dialogue: 0,0:06:57.97,0:07:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu? Bir?
Dialogue: 0,0:07:01.02,0:07:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu untukku?
Dialogue: 0,0:07:02.37,0:07:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:04.30,0:07:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, aku terima.
Dialogue: 0,0:07:13.32,0:07:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa?
Dialogue: 0,0:07:16.97,0:07:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:07:18.92,0:07:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku bertanya karena enggak tahu!
Dialogue: 0,0:07:24.45,0:07:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, terserah saja, sih.
Dialogue: 0,0:07:28.12,0:07:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan tunjukkan\Nekspresi suram seperti itu
Dialogue: 0,0:07:32.06,0:07:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bikin juniormu ikut mikir.
Dialogue: 0,0:07:34.82,0:07:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:07:37.47,0:07:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah!
Dialogue: 0,0:07:39.17,0:07:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, soal orientasi cari kerja itu...
Dialogue: 0,0:07:42.32,0:07:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, soal itu.
Dialogue: 0,0:07:47.67,0:07:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, tunggulah sampai\Naku menghabiskan bir ini.
Dialogue: 0,0:07:53.95,0:07:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunggumu.
Dialogue: 0,0:07:56.85,0:07:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja.
Dialogue: 0,0:08:01.65,0:08:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Enak banget!
Dialogue: 0,0:08:15.22,0:08:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka lama sekali, ya.
Dialogue: 0,0:08:17.82,0:08:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:21.00,0:08:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan.
Dialogue: 0,0:08:23.77,0:08:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu menjawab,\Ntapi aku boleh tanya sesuatu?
Dialogue: 0,0:08:28.00,0:08:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:33.15,0:08:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan.
Dialogue: 0,0:08:35.85,0:08:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadian sama Ibuki?
Dialogue: 0,0:10:07.95,0:10:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang paling enak?
Dialogue: 0,0:10:10.80,0:10:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, ayam tagine.
Dialogue: 0,0:10:12.25,0:10:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tuh!\NDitambah asparagus.
Dialogue: 0,0:10:14.27,0:10:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asparagus yang mana?
Dialogue: 0,0:10:15.47,0:10:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ada di linguine.
Dialogue: 0,0:10:17.70,0:10:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, semua.\NSemua hidangan asparagus.
Dialogue: 0,0:10:19.40,0:10:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua hidangan asparagus?
Dialogue: 0,0:10:21.94,0:10:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu suka sama asparagus.
Dialogue: 0,0:10:24.25,0:10:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang suka asparagus!
Dialogue: 0,0:10:27.37,0:10:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, ini waktu paling sempurna\Nuntuk minum di tempat duduk luar.
Dialogue: 0,0:10:31.42,0:10:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, rasanya lebih nikmat.
Dialogue: 0,0:10:39.40,0:10:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Hummus kacang arab" itu apa, sih?
Dialogue: 0,0:10:42.12,0:10:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:10:43.85,0:10:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku cuma penasaran,\Nitu hidangan negara mana?
Dialogue: 0,0:10:46.96,0:10:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hidangan mediterania,\Npaling negara sekitar situ.
Dialogue: 0,0:10:51.47,0:10:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di timur tengah.
Dialogue: 0,0:10:56.22,0:10:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yaeka.
Dialogue: 0,0:10:57.72,0:11:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku ingin ambil\Ngitar di ruangan klub,
Dialogue: 0,0:11:00.78,0:11:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kamu akan marah?
Dialogue: 0,0:11:01.87,0:11:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Sekarang?
Dialogue: 0,0:11:04.02,0:11:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:04.92,0:11:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil besok saja!
Dialogue: 0,0:11:07.10,0:11:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak bisa.\NBesok aku enggak ke kampus.
Dialogue: 0,0:11:09.27,0:11:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi, dong!
Dialogue: 0,0:11:10.60,0:11:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa?\NEnggak ada kelas.
Dialogue: 0,0:11:12.47,0:11:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Bukankah kamu...
Dialogue: 0,0:11:15.12,0:11:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu ambil kelas arsitektur?
Dialogue: 0,0:11:18.40,0:11:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak jadi.
Dialogue: 0,0:11:22.60,0:11:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:11:23.52,0:11:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf banget,\Ntapi apa kalian bisa pulang duluan?
Dialogue: 0,0:11:26.25,0:11:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau menyita waktu kalian.
Dialogue: 0,0:11:27.97,0:11:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada acara televisi\Nyang ingin kutonton malam ini!
Dialogue: 0,0:11:31.37,0:11:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah, kalian berdua.
Dialogue: 0,0:11:33.42,0:11:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sampai ketemu di asrama.
Dialogue: 0,0:11:35.35,0:11:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu dengar atau tidak?
Dialogue: 0,0:11:43.30,0:11:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan kita jadi berdua, ya.
Dialogue: 0,0:11:47.44,0:11:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu sempurna untuk dibilang kebetulan.
Dialogue: 0,0:12:10.12,0:12:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaeka.
Dialogue: 0,0:12:12.32,0:12:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:14.25,0:12:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya repot, deh.\NPulang, yuk.
Dialogue: 0,0:12:16.92,0:12:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:17.76,0:12:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mending kita naik kereta\Nyang sama dengan mereka!
Dialogue: 0,0:12:21.04,0:12:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, ini sama saja.
Dialogue: 0,0:12:24.70,0:12:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaeka.
Dialogue: 0,0:12:25.97,0:12:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa lagi?
Dialogue: 0,0:12:28.10,0:12:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku ingin ke drugstore,\Napa kamu mau ikut?
Dialogue: 0,0:12:31.82,0:12:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Mau.\NAyo pergi.
Dialogue: 0,0:12:34.57,0:12:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ya, enggak jadi, sih.
Dialogue: 0,0:12:36.31,0:12:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:38.02,0:12:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa, sih?
Dialogue: 0,0:12:40.03,0:12:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan pasti senang.
Dialogue: 0,0:12:42.05,0:12:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku pintar baca suasana.
Dialogue: 0,0:12:44.40,0:12:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara yang jelas!
Dialogue: 0,0:13:00.12,0:13:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:13:01.15,0:13:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk dua orang.
Dialogue: 0,0:13:02.40,0:13:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan ke belakang.
Dialogue: 0,0:13:19.95,0:13:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:13:21.15,0:13:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Earl Grey Highball.
Dialogue: 0,0:13:24.37,0:13:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mudah diminum.
Dialogue: 0,0:13:28.07,0:13:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada daun tehnya, ya?
Dialogue: 0,0:13:32.42,0:13:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masuk ke sini begitu saja.
Dialogue: 0,0:13:35.67,0:13:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut.
Dialogue: 0,0:13:38.20,0:13:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia sering ke tempat seperti ini?
Dialogue: 0,0:13:44.83,0:13:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa seperti terbawa olehnya.
Dialogue: 0,0:13:50.95,0:13:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami enggak jadian, kok.
Dialogue: 0,0:13:54.72,0:13:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:13:55.97,0:13:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kamu ingin bahas itu.
Dialogue: 0,0:13:58.82,0:13:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bukan?
Dialogue: 0,0:14:00.72,0:14:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, itu...
Dialogue: 0,0:14:03.02,0:14:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kan.\NAku keduluan.
Dialogue: 0,0:14:07.65,0:14:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Kalau begitu...
Dialogue: 0,0:14:10.67,0:14:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mau ke tahap itu?
Dialogue: 0,0:14:12.04,0:14:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.\NDua Kavalan Classic pakai es batu.
Dialogue: 0,0:14:15.37,0:14:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:14:17.70,0:14:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya itu wiski Taiwan.
Dialogue: 0,0:14:19.92,0:14:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu?
Dialogue: 0,0:14:20.95,0:14:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mau mengalihkan topik?
Dialogue: 0,0:14:28.32,0:14:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke tahap itu, ya?
Dialogue: 0,0:14:32.97,0:14:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang suka pada Ibuki.
Dialogue: 0,0:14:39.52,0:14:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku suka.
Dialogue: 0,0:14:43.60,0:14:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku jadi malu kalau bahas beginian.
Dialogue: 0,0:14:48.20,0:14:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:14:49.79,0:14:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini rasa suka dalam arti romantis, ya?
Dialogue: 0,0:14:54.22,0:14:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:55.07,0:14:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan, apa lagi coba?
Dialogue: 0,0:14:58.60,0:15:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa buahnya kuat banget.\NAda rasa madunya juga.
Dialogue: 0,0:15:08.85,0:15:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lembut dan manis.\NMudah diminum.
Dialogue: 0,0:15:12.02,0:15:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:15:13.31,0:15:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu belum pernah minum ini, ya?
Dialogue: 0,0:15:15.82,0:15:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, Kavalan itu cukup mahal.
Dialogue: 0,0:15:20.57,0:15:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga belum pernah masuk\Nke dalam bar.
Dialogue: 0,0:15:26.24,0:15:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa dia...
Dialogue: 0,0:15:28.80,0:15:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Ibuki memendam\Nrasa seperti itu sejak lama.
Dialogue: 0,0:15:33.52,0:15:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak berniat melanjutkannya...
Dialogue: 0,0:15:37.65,0:15:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, kamu tidak boleh begini terus...
Dialogue: 0,0:15:44.91,0:15:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku kelepasan\Nkarena efek minuman keras?
Dialogue: 0,0:15:49.07,0:15:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, namun...
Dialogue: 0,0:15:53.15,0:15:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku ingin memahaminya.
Dialogue: 0,0:16:04.45,0:16:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kepalaku mulai pusing.
Dialogue: 0,0:16:08.85,0:16:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa, minum banyak.
Dialogue: 0,0:16:10.95,0:16:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus hati-hati sama Kavalan.
Dialogue: 0,0:16:14.32,0:16:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah diminum...
Dialogue: 0,0:16:17.47,0:16:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah diminum,\Nmuncul aroma jeruk, ya.
Dialogue: 0,0:16:21.80,0:16:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah sedikit rasa pahit.
Dialogue: 0,0:16:40.84,0:16:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti musim panas.
Dialogue: 0,0:16:43.47,0:16:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal minggu lalu terasa dingin,\Nsekarang mirip bulan Agustus.
Dialogue: 0,0:16:48.34,0:16:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:50.77,0:16:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah, musim itu sendiri\Nmerasa ragu untuk beranjak.
Dialogue: 0,0:16:58.44,0:16:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:17:00.14,0:17:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku ke sini di awal musim panas,
Dialogue: 0,0:17:04.31,0:17:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada burung layang-layang\Nbeterbangan di dalam stasiun.
Dialogue: 0,0:17:13.81,0:17:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sekarang sudah tidak ada.
Dialogue: 0,0:17:16.92,0:17:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan.
Dialogue: 0,0:17:19.70,0:17:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu?
Dialogue: 0,0:17:22.28,0:17:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar\Nsuara langkah kaki musim dingin.
Dialogue: 0,0:17:29.53,0:17:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:17:30.55,0:17:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada toko bir di depan stasiun.
Dialogue: 0,0:17:32.99,0:17:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang ingin mampir ke Bottle lagi.
Dialogue: 0,0:17:37.63,0:17:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:17:38.90,0:17:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak bir besar!
Dialogue: 0,0:17:42.10,0:17:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bir craft kaleng 500 ml itu\Nternyata susah ditemukan, ya.
Dialogue: 0,0:17:46.21,0:17:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Labelnya juga imut-imut.
Dialogue: 0,0:17:49.05,0:17:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai permulaan,\Nbagaimana kalau kita beli lima?
Dialogue: 0,0:17:51.90,0:17:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima?
Dialogue: 0,0:17:54.48,0:17:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti beli lagi pas pulang.
Dialogue: 0,0:17:59.70,0:18:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:18:02.98,0:18:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja yang bawa.
Dialogue: 0,0:18:04.63,0:18:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku saja.
Dialogue: 0,0:18:08.03,0:18:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita bawa berdua?
Dialogue: 0,0:18:30.78,0:18:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin jalan ini kawasan tempat minum.
Dialogue: 0,0:18:36.29,0:18:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tepi sungainya di depan sana?
Dialogue: 0,0:18:42.50,0:18:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki?
Dialogue: 0,0:18:43.40,0:18:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:45.18,0:18:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:46.68,0:18:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu melamun?
Dialogue: 0,0:18:49.40,0:18:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:18:51.38,0:18:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya merasa...
Dialogue: 0,0:18:55.75,0:18:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahagia banget.
Dialogue: 0,0:19:02.70,0:19:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepi sungainya cuma di seberang sana.
Dialogue: 0,0:19:15.88,0:19:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing!
Dialogue: 0,0:19:17.65,0:19:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia enggak kepanasan, ya?
Dialogue: 0,0:19:21.40,0:19:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia pergi.
Dialogue: 0,0:19:23.98,0:19:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat fotonya?
Dialogue: 0,0:19:25.15,0:19:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat.
Dialogue: 0,0:19:42.15,0:19:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai pukul sembilan malam?\NEmang boleh selama tidak lewat itu?
Dialogue: 0,0:19:46.18,0:19:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembang api itu bagus, ya.\NKesannya musim panas banget.
Dialogue: 0,0:19:49.05,0:19:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah musim gugur, sih.
Dialogue: 0,0:19:52.63,0:19:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah turun sini,\Nkita sampai di lembah Hikawa.
Dialogue: 0,0:20:06.37,0:20:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya bening!
Dialogue: 0,0:20:09.23,0:20:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin minum di tempat seperti ini!
Dialogue: 0,0:20:13.50,0:20:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu semangat banget.
Dialogue: 0,0:20:17.93,0:20:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin!
Dialogue: 0,0:20:19.80,0:20:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei! Kamu ingin minum\Nyang mana, Botan?
Dialogue: 0,0:20:24.80,0:20:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.\NKarena foto ladang bunga ini imut...
Dialogue: 0,0:20:29.04,0:20:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau yang ini!
Dialogue: 0,0:20:32.21,0:20:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!
Dialogue: 0,0:20:38.58,0:20:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada aroma bunganya!
Dialogue: 0,0:20:40.53,0:20:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Blonde Ale dari Bottle ini enak, ya.
Dialogue: 0,0:20:44.60,0:20:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:05.73,0:21:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:21:09.73,0:21:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengajakku ke sini.
Dialogue: 0,0:21:12.40,0:21:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku yang berterima kasih.
Dialogue: 0,0:21:16.90,0:21:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menemaniku, Botan.
Dialogue: 0,0:21:22.93,0:21:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkanmu.
Dialogue: 0,0:21:24.26,0:21:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.\NAku tidak merasa direpotkan.
