Dialogue: 0,0:15:25.07,0:15:25.82,sign,,0,0,0,,DUNIA DARI SUDUT PANDANG HEWAN,\NRISALAH FILSAFAT BAHASA
Dialogue: 0,0:16:20.96,0:16:23.46,sign,,0,0,0,,PETA PERUSAHAAN
Dialogue: 0,0:00:37.20,0:00:39.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hó-chiú tîm àng-té.
Dialogue: 0,0:00:58.62,0:01:00.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}May I help you?
Dialogue: 0,0:01:05.04,0:01:07.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong tunggu sebentar lagi.
Dialogue: 0,0:01:07.05,0:01:10.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, maaf.\NSilakan nikmati waktunya.
Dialogue: 0,0:03:04.58,0:03:06.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, maaf.
Dialogue: 0,0:03:06.54,0:03:08.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu menunggu tanpa memesan apa pun?
Dialogue: 0,0:03:08.58,0:03:12.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan minta maaf.\NAku tidak menunggu lama.
Dialogue: 0,0:03:12.61,0:03:16.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan bohong.\NPadahal aku telat 20 menit.
Dialogue: 0,0:03:17.39,0:03:18.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:03:18.72,0:03:20.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak terasa lama.
Dialogue: 0,0:03:22.43,0:03:24.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menunggumu adalah hal\Nyang menyenangkan.
Dialogue: 0,0:03:28.35,0:03:32.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}A-Ayo kita pesan minuman\Ndan makanan ringan cepat saji.
Dialogue: 0,0:03:32.19,0:03:33.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:03:34.07,0:03:35.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:03:35.70,0:03:38.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mengikuti pesananmu saja.
Dialogue: 0,0:03:41.98,0:03:43.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Silakan memesan.
Dialogue: 0,0:03:43.45,0:03:45.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:03:46.83,0:03:48.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pesan dua Aramasa.
Dialogue: 0,0:03:55.84,0:03:57.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Enak, ya.
Dialogue: 0,0:03:58.87,0:04:02.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika kita memesan yang sama,\Nmending minta teko keramik.
Dialogue: 0,0:04:03.10,0:04:03.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:18.95,0:04:20.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lain kali saja, ya.
Dialogue: 0,0:04:22.98,0:04:25.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belakangan ini,\Naku sering nonton filmnya Cassavetes.
Dialogue: 0,0:04:25.41,0:04:28.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cassavetes?\NSeperti film "Rosemary's Baby"?
Dialogue: 0,0:04:28.66,0:04:30.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu filmnya Polanski.
Dialogue: 0,0:04:31.08,0:04:33.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu tidak pernah nonton\N"Husbands" atau "Gloria"?
Dialogue: 0,0:04:33.42,0:04:36.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu itu.\NSharon Stone membintanginya.
Dialogue: 0,0:04:36.46,0:04:39.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu versi garapannya Lumet.
Dialogue: 0,0:04:39.80,0:04:41.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:04:41.37,0:04:43.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Versi aslinya dibintangi Gena Rowlands.
Dialogue: 0,0:04:44.64,0:04:46.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Komposer musiknya adalah Bill Conti.
Dialogue: 0,0:04:46.85,0:04:48.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Yang di film "Rocky" itu?
Dialogue: 0,0:04:48.81,0:04:49.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:49.69,0:04:51.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, begitu rupanya.
Dialogue: 0,0:04:52.48,0:04:54.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, kenapa kok tiba-tiba?
Dialogue: 0,0:04:54.40,0:04:58.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kemarin kita nonton\N"Drive My Car" bareng, kan?
Dialogue: 0,0:04:58.32,0:05:01.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sutradaranya sempat membahasnya\Ndalam wawancara.
Dialogue: 0,0:05:05.24,0:05:06.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa, sih?
Dialogue: 0,0:05:06.57,0:05:08.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:05:08.28,0:05:10.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana mungkin begitu.
Dialogue: 0,0:05:11.23,0:05:13.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, mau minum apa lagi?
Dialogue: 0,0:05:13.04,0:05:14.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:05:18.20,0:05:21.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menyukai dirimu\Nyang keasyikan bicara.
Dialogue: 0,0:05:22.03,0:05:24.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu juga tertarik pada banyak hal.
Dialogue: 0,0:05:26.10,0:05:27.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:05:33.75,0:05:38.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku nonton film "A Brighter Summer Day"\Nyang digarap Edward Yang.
Dialogue: 0,0:05:40.81,0:05:45.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Film yang digarap Hou Hsiao-hsien\Ndan Ma Ji-hsien juga.
Dialogue: 0,0:05:47.03,0:05:49.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu semua pengalaman pertamaku.
Dialogue: 0,0:05:52.29,0:05:55.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya sutradara dari Taiwan, ya.
Dialogue: 0,0:05:57.11,0:05:58.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Artinya...
Dialogue: 0,0:06:00.51,0:06:03.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa aku boleh berangan-angan
Dialogue: 0,0:06:04.41,0:06:06.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}bahwa kamu mulai tertarik padaku?
Dialogue: 0,0:06:13.02,0:06:14.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terserah kamu saja.
Dialogue: 0,0:06:18.19,0:06:21.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, aku akan berangan-angan seperti itu.
Dialogue: 0,0:06:28.46,0:06:32.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kosmetik, alat tulis,\Ndan busana musim dingin.
Dialogue: 0,0:06:32.37,0:06:33.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:06:33.50,0:06:35.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu mau beli sebanyak itu?
Dialogue: 0,0:06:35.21,0:06:37.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak akan beli dan tidak terbeli.
Dialogue: 0,0:06:37.25,0:06:38.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cuma ingin lihat-lihat.
Dialogue: 0,0:06:38.42,0:06:40.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada kolaborasi Toga sama Porter, kan?
Dialogue: 0,0:06:40.92,0:06:42.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin lihat MM6!
Dialogue: 0,0:06:42.72,0:06:45.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, boleh mampir ke Sacai juga?
Dialogue: 0,0:06:48.43,0:06:50.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mau beli lipstik nuansa musim dingin.
Dialogue: 0,0:06:50.56,0:06:53.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}He-Hei, Botan!
Dialogue: 0,0:06:55.44,0:06:58.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa, Ibuki?
Dialogue: 0,0:06:59.69,0:07:01.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:07:03.72,0:07:07.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mantel itu bagus.\NKayaknya cocok buat kamu.
Dialogue: 0,0:07:07.03,0:07:08.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:07:08.07,0:07:09.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:09.12,0:07:11.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga ingin mencoba\Nwarna baru Nail S.
Dialogue: 0,0:07:11.71,0:07:15.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku melewatkan The Polish\Ndan Pomum musim gugur ini.
Dialogue: 0,0:07:16.65,0:07:18.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lantai berapa, ya?
Dialogue: 0,0:07:18.29,0:07:20.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, kamu ingin ke mana, Ibuki?
Dialogue: 0,0:07:24.84,0:07:27.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga ingin cari\Nbusana musim dingin,
Dialogue: 0,0:07:27.39,0:07:30.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi aku tidak tahu tempat\Natau pilihan yang bagus.
Dialogue: 0,0:07:31.85,0:07:33.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:07:34.42,0:07:38.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu merasa terpaksa\Nsaat kuajak ke sini?
Dialogue: 0,0:07:40.56,0:07:42.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:07:44.24,0:07:46.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:07:46.98,0:07:48.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:07:51.87,0:07:53.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:54.77,0:07:57.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf karena membuatmu kepikiran.
Dialogue: 0,0:07:58.37,0:08:00.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak merasa terpaksa, kok.
Dialogue: 0,0:08:01.29,0:08:02.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini menyenangkan.
Dialogue: 0,0:08:04.13,0:08:05.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:06.13,0:08:08.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bilang saja kalau capek, ya.
Dialogue: 0,0:08:08.64,0:08:09.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:37.27,0:08:39.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Indah.
Dialogue: 0,0:08:39.96,0:08:43.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin aku tambah koleksi, ah.
Dialogue: 0,0:08:44.34,0:08:47.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu punya parfum cukup banyak, kan?
Dialogue: 0,0:08:47.73,0:08:50.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya, sekarang aku juga pakai parfum.
Dialogue: 0,0:08:51.09,0:08:53.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, imutnya.
Dialogue: 0,0:08:53.47,0:08:56.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Permisi.\NBoleh minta kertas uji coba?
Dialogue: 0,0:08:56.89,0:08:58.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa Anda berkenan dengan yang ini?
Dialogue: 0,0:08:58.80,0:09:02.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, kertasnya imut, ya.
Dialogue: 0,0:09:02.65,0:09:05.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika ingin dibawa pergi,\Nsilakan menggunakan ini.
Dialogue: 0,0:09:06.44,0:09:08.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:09:09.60,0:09:10.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:09:10.55,0:09:11.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:11.87,0:09:15.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biasanya kapan kamu pakai parfum?
Dialogue: 0,0:09:18.75,0:09:20.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di berbagai situasi.
Dialogue: 0,0:09:20.50,0:09:24.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biasanya aku menggunakan\N"Lazy Sunday Morning" dari Margiela
Dialogue: 0,0:09:24.08,0:09:27.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}atau "Whisper in the Library".
Dialogue: 0,0:09:27.53,0:09:31.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika parfumnya dipakai saat pagi,\Nwanginya bikin ceria dan rileks.
Dialogue: 0,0:09:31.89,0:09:33.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau di hari-hari spesial,
Dialogue: 0,0:09:33.65,0:09:36.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku pakai "Un Jardin sur le Nil"\Ndari Hermès
Dialogue: 0,0:09:36.89,0:09:38.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}biar tambah semangat.
Dialogue: 0,0:09:43.48,0:09:44.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini pakai yang mana?
Dialogue: 0,0:09:46.82,0:09:48.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rahasia.
Dialogue: 0,0:09:48.69,0:09:49.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:50.89,0:09:52.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar aku tebak, ya.
Dialogue: 0,0:09:52.28,0:09:53.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:53.03,0:09:54.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Ibuki!
Dialogue: 0,0:09:57.45,0:09:59.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang ini, ya?
Dialogue: 0,0:09:59.29,0:10:01.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kurasa bukan, sih.
Dialogue: 0,0:10:01.48,0:10:04.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aromanya agak dominan ke kayu.
Dialogue: 0,0:10:04.51,0:10:06.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti mangga hijau.
Dialogue: 0,0:10:07.11,0:10:08.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa aromanya begitu?
Dialogue: 0,0:10:09.78,0:10:10.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:11.09,0:10:14.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya ada wangi bunga teratai juga.
Dialogue: 0,0:10:15.41,0:10:16.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan yang ini.
Dialogue: 0,0:10:16.89,0:10:19.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak pernah bilang\Nkalau parfumnya di sini.
Dialogue: 0,0:10:20.50,0:10:21.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada, ya?
Dialogue: 0,0:10:23.64,0:10:25.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:10:25.32,0:10:27.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:28.32,0:10:30.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, ini menyenangkan.
Dialogue: 0,0:10:30.49,0:10:32.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita seperti melakukan wisata aroma.
Dialogue: 0,0:10:33.39,0:10:34.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:35.66,0:10:38.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga mau parfum.
Dialogue: 0,0:10:40.12,0:10:43.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya saja, aku bingung memilihnya.
Dialogue: 0,0:10:43.90,0:10:48.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin karena aku belum tahu parfum\Nyang sesuai dengan seleraku.
Dialogue: 0,0:10:50.59,0:10:51.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:10:52.63,0:10:55.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}coba pilihlah parfum\Nuntuk menyenangkan orang lain.
Dialogue: 0,0:10:59.58,0:11:01.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:11:03.17,0:11:04.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin yang ini.
Dialogue: 0,0:11:10.94,0:11:14.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aromanya sangat semerbak seperti bunga.
Dialogue: 0,0:11:15.45,0:11:17.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin beraroma seperti itu
Dialogue: 0,0:11:17.64,0:11:19.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}saat berada di sampingmu.
Dialogue: 0,0:11:30.34,0:11:31.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu membuatku senang.
Dialogue: 0,0:11:34.99,0:11:38.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Parfum itu biasanya\Ndisemprot di bagian mana?
Dialogue: 0,0:11:38.37,0:11:41.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Umumnya di bagian tubuh\Nyang memiliki suhu tinggi.
Dialogue: 0,0:11:41.47,0:11:43.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Misalnya di pergelangan tangan\Natau belakang telinga.
Dialogue: 0,0:11:43.81,0:11:45.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku bantu semprotkan, ya.
Dialogue: 0,0:11:45.35,0:11:47.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, iya. Cepat hadap sini.
Dialogue: 0,0:11:47.65,0:11:48.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:11:58.26,0:11:59.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:00.49,0:12:02.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa disemprotkan ke syal juga, kok.
Dialogue: 0,0:12:09.63,0:12:12.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya. Aromanya bikin bahagia.
Dialogue: 0,0:12:13.38,0:12:14.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:19.84,0:12:22.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal aku belum menyemprotkan parfum.
Dialogue: 0,0:12:26.00,0:12:30.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kapan-kapan, mampir lagi, yuk.\NAku akan belajar soal parfum dulu.
Dialogue: 0,0:12:32.49,0:12:33.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tunggu hasilnya.
Dialogue: 0,0:12:33.98,0:12:36.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini menyenangkan.
Dialogue: 0,0:12:36.32,0:12:37.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:12:37.39,0:12:40.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Produk di tempat yang kita kunjungi tadi\Nternyata digantung di sana.
Dialogue: 0,0:12:40.93,0:12:43.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, benar.
Dialogue: 0,0:12:44.18,0:12:47.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak melihatnya saat baru datang.
Dialogue: 0,0:12:48.58,0:12:51.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat perjalanan pulang,\Nayo kita mampir minum.
Dialogue: 0,0:12:51.13,0:12:55.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menemukan tempat\Nyang jual sake Yamahai enak.
Dialogue: 0,0:12:55.35,0:12:58.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yamahai itu memiliki\Nbanyak minuman unik,
Dialogue: 0,0:12:58.80,0:13:02.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}bahkan ada minuman\Nyang agak sulit diminum pemula,
Dialogue: 0,0:13:02.22,0:13:05.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}- tapi minuman di sana sangat enak!\N- Ibuki.
Dialogue: 0,0:13:05.10,0:13:06.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Kamu tampak senang.\N- Aku meminumnya tanpa es,
Dialogue: 0,0:13:06.93,0:13:10.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}- tapi aku merasakan harmoni rasa.\N- Dia benar-benar suka minuman keras.
Dialogue: 0,0:13:11.42,0:13:15.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selama ada minuman keras,\NIbuki selalu tampak bahagia.
Dialogue: 0,0:13:17.82,0:13:19.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selama ada minuman keras?
Dialogue: 0,0:13:20.57,0:13:23.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana kalau\Ntidak ada minuman keras?
Dialogue: 0,0:13:25.53,0:13:28.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin tambah celupan\Nsirip ikan buntal panggang.
Dialogue: 0,0:13:29.44,0:13:31.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini menyenangkan.
Dialogue: 0,0:13:34.08,0:13:35.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:13:37.42,0:13:40.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa dia benar-benar merasa senang?
Dialogue: 0,0:13:41.70,0:13:45.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa Ibuki benar-benar\Nmerasa senang saat bersamaku?
Dialogue: 0,0:13:46.18,0:13:48.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski tanpa minuman keras?
Dialogue: 0,0:13:49.10,0:13:52.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat menghabiskan waktu\Ntanpa menikmati minuman keras,
Dialogue: 0,0:13:52.69,0:13:56.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}bagi kami berdua,\Napa hal ini menyenangkan?
Dialogue: 0,0:13:57.66,0:13:58.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menurutku...
Dialogue: 0,0:14:07.83,0:14:10.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Ibuki.
Dialogue: 0,0:14:14.57,0:14:16.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita berdua...
Dialogue: 0,0:14:18.07,0:14:20.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}...sudah melangkah maju, kan?
Dialogue: 0,0:14:42.76,0:14:45.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jalur dunia A.
Dialogue: 0,0:14:47.98,0:14:50.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Atau jalur dunia B.
Dialogue: 0,0:15:02.64,0:15:07.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya aku tersiksa karena\Nmemikirkan hal-hal tak berguna.
Dialogue: 0,0:15:11.85,0:15:13.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal semuanya sudah jelas.
Dialogue: 0,0:15:14.56,0:15:16.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa sih yang membuatku bimbang?
Dialogue: 0,0:15:25.82,0:15:27.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hai! Sedang belajar?
Dialogue: 0,0:15:27.57,0:15:29.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kak Akane.
Dialogue: 0,0:15:29.07,0:15:31.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, kok.\NAku cuma baca-baca.
Dialogue: 0,0:15:32.88,0:15:34.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cuma baca?
Dialogue: 0,0:15:36.00,0:15:39.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu suka baca buku?
Dialogue: 0,0:15:39.38,0:15:41.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sering membaca,
Dialogue: 0,0:15:41.55,0:15:42.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi entahlah.
Dialogue: 0,0:15:42.96,0:15:46.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak pernah merenungkan itu\Nsecara mendalam.
Dialogue: 0,0:15:46.53,0:15:48.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin karena aku membacanya\Nsambil melamun
Dialogue: 0,0:15:48.80,0:15:50.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}untuk menyegarkan pikiran\Natau melepas penat.
Dialogue: 0,0:15:52.10,0:15:53.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:15:53.81,0:15:56.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mirip seperti aku dan musik.
Dialogue: 0,0:15:59.13,0:16:03.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa musik itu bisa\Nmenenangkan hatimu?
Dialogue: 0,0:16:08.60,0:16:11.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak pernah merenungkan itu\Nsecara mendalam.
Dialogue: 0,0:16:11.83,0:16:14.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, kamu meniruku.
Dialogue: 0,0:16:14.83,0:16:17.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin jalan-jalan\Ndan mampir minum teh,
Dialogue: 0,0:16:17.36,0:16:18.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}kamu mau ikut?
Dialogue: 0,0:16:27.01,0:16:28.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan siap-siap.
Dialogue: 0,0:16:36.83,0:16:40.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku merasa agak enggan\Nmasuk tempat ini sendirian.
Dialogue: 0,0:16:40.68,0:16:44.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, sepertinya asyik.
Dialogue: 0,0:16:46.15,0:16:48.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu sangat bisa diandalkan.
Dialogue: 0,0:16:52.32,0:16:54.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pernah coba shisha?
Dialogue: 0,0:16:54.01,0:16:56.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu seperti rokok, kan?
Dialogue: 0,0:16:56.51,0:16:59.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, hanya saja,\Nini beda dari rokok biasa.
Dialogue: 0,0:16:59.71,0:17:02.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Asapnya disaring dengan air.
Dialogue: 0,0:17:02.97,0:17:04.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:17:04.71,0:17:06.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada juga yang bebas nikotin, lo.
Dialogue: 0,0:17:08.13,0:17:10.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau minum apa, ya?
Dialogue: 0,0:17:11.58,0:17:13.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kayaknya aku mau minum bir.
Dialogue: 0,0:17:14.05,0:17:15.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu juga mau, Botan?
Dialogue: 0,0:17:15.72,0:17:17.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:17:18.34,0:17:20.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:17:24.10,0:17:28.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bir Chichibu, Hanakuma, dan Yukikuma.
Dialogue: 0,0:17:29.22,0:17:30.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:17:34.24,0:17:37.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana cara memakainya?
Dialogue: 0,0:17:37.80,0:17:41.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Tinggal diisap, kan?
Dialogue: 0,0:18:19.25,0:18:21.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Suaranya bagus, ya.
Dialogue: 0,0:18:23.65,0:18:27.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat ini bikin betah.
Dialogue: 0,0:18:27.79,0:18:30.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masalah pun bisa terlupakan.
Dialogue: 0,0:18:30.77,0:18:32.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu punya masalah, ya.
Dialogue: 0,0:18:32.89,0:18:35.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Punya, lah.
Dialogue: 0,0:18:35.14,0:18:36.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana ada orang tanpa masalah.
Dialogue: 0,0:18:36.68,0:18:38.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa masalahmu itu
Dialogue: 0,0:18:39.43,0:18:41.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}berkaitan dengan cinta?
Dialogue: 0,0:18:43.88,0:18:46.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa aku boleh curhat?
Dialogue: 0,0:18:46.02,0:18:47.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Waduh, serius?
Dialogue: 0,0:18:47.73,0:18:51.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, mungkin aku juga\Nakan menceritakan masalahku.
Dialogue: 0,0:18:51.07,0:18:52.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:18:54.36,0:18:57.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku berpikir untuk berhenti kuliah.
Dialogue: 0,0:19:09.60,0:19:11.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:19:13.51,0:19:16.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, maaf.
Dialogue: 0,0:19:16.13,0:19:18.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Kenapa minta maaf?
Dialogue: 0,0:19:18.59,0:19:20.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:19:24.92,0:19:28.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku lumayan suka musik.
Dialogue: 0,0:19:30.27,0:19:32.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masalahnya,
Dialogue: 0,0:19:32.00,0:19:34.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku tidak yakin\Nbisa tetap menyukainya.
Dialogue: 0,0:19:35.36,0:19:39.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, aku juga berpikir\Nbisa lebih mencintainya.
Dialogue: 0,0:19:43.95,0:19:47.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu ingin memutus\Njalan mundur demi cinta?
Dialogue: 0,0:19:47.25,0:19:50.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, tidak.\NBukan jalan mundur, sih.
Dialogue: 0,0:19:52.25,0:19:57.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Faktanya, kalau aku lulus\Ndan bekerja di suatu tempat,
Dialogue: 0,0:19:57.08,0:20:00.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku masih bisa menjaga hubungan\Nyang lumayan baik dengan musik.
Dialogue: 0,0:20:02.87,0:20:03.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:20:09.10,0:20:13.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku ingin mencintainya\Nsecara ugal-ugalan.
Dialogue: 0,0:20:26.00,0:20:27.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita pergi.
Dialogue: 0,0:20:28.42,0:20:29.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:36.34,0:20:38.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa Kak Yaeka tahu?
Dialogue: 0,0:20:38.96,0:20:44.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa bilang padanya.\NItu bisa meruntuhkan keseimbangan.
Dialogue: 0,0:20:44.47,0:20:46.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mengerti maksudmu.
Dialogue: 0,0:20:52.90,0:20:55.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Membicarakan masa depan\Nmemang sangat menyenangkan,
Dialogue: 0,0:20:55.78,0:20:58.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi belakangan ini,\Naku merasa cemas akan hal itu.
Dialogue: 0,0:21:00.51,0:21:01.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:01.55,0:21:05.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mendukungmu, Kak Akane.
Dialogue: 0,0:21:06.40,0:21:07.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:09.08,0:21:10.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makasih.
Dialogue: 0,0:21:22.01,0:21:24.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masalah cintamu itu...
Dialogue: 0,0:21:51.19,0:21:52.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin mencintainya
Dialogue: 0,0:21:53.50,0:21:55.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}secara ugal-ugalan.
Dialogue: 0,0:21:57.50,0:21:59.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin mencintainya
Dialogue: 0,0:22:00.30,0:22:01.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}secara ugal-ugalan.
