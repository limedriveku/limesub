Dialogue: 0,0:15:18.98,0:15:22.48,tanda,,0000,0000,0000,,BIR CHICHIBU
Dialogue: 0,0:15:29.24,0:15:31.12,tanda,,0000,0000,0000,,AKU AKAN MENGAJAKMU KE SINI\NTAHUN DEPAN
Dialogue: 0,0:15:31.12,0:15:32.58,tanda,,0000,0000,0000,,MAAF, YA
Dialogue: 0,0:00:09.09,0:00:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki, minuman ini sangat enak.
Dialogue: 0,0:00:13.21,0:00:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah.
Dialogue: 0,0:00:14.74,0:00:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Itu untukku?
Dialogue: 0,0:00:17.16,0:00:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:00:22.20,0:00:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kak Gujyo!
Dialogue: 0,0:00:26.71,0:00:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau minum denganku—
Dialogue: 0,0:00:29.51,0:00:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuminum sambil santai sendiri.
Dialogue: 0,0:00:32.27,0:00:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:34.39,0:00:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan apa-apa.
Dialogue: 0,0:00:48.24,0:00:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berani bilang lagi.
Dialogue: 0,0:00:52.97,0:00:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo?\NSiang-siang sudah mabuk tipis?
Dialogue: 0,0:00:58.15,0:01:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu juga mau?
Dialogue: 0,0:01:00.48,0:01:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:01:10.63,0:01:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina, kalau punya waktu,\Nmau menemaniku lagi?
Dialogue: 0,0:01:15.58,0:01:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:49.48,0:02:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko minuman keras?
Dialogue: 0,0:02:51.07,0:02:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, seharusnya di dekat sini.
Dialogue: 0,0:02:54.40,0:02:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih mau minum?
Dialogue: 0,0:02:56.03,0:02:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan sekarang, kok.
Dialogue: 0,0:03:00.57,0:03:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempatnya.
Dialogue: 0,0:03:03.50,0:03:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:03:07.50,0:03:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak minuman keras!
Dialogue: 0,0:03:12.67,0:03:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku masuk toko minuman keras!
Dialogue: 0,0:03:16.05,0:03:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku juga.
Dialogue: 0,0:03:17.59,0:03:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Lantas, dari mana\Nkamu dapat sake kemarin?
Dialogue: 0,0:03:20.60,0:03:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dari toko online.
Dialogue: 0,0:03:22.97,0:03:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku ingin beli di toko spesialis
Dialogue: 0,0:03:25.30,0:03:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya bisa bertanya\Nbanyak hal ke penjaga toko,
Dialogue: 0,0:03:29.01,0:03:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak berani masuk\Ntoko minuman keras sendirian.
Dialogue: 0,0:03:32.40,0:03:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa memahaminya.
Dialogue: 0,0:03:34.89,0:03:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bagaimana kalau\Nmengajak Ketua Asrama?
Dialogue: 0,0:03:38.70,0:03:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah mengajaknya,
Dialogue: 0,0:03:42.49,0:03:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia tampak keberatan banget.
Dialogue: 0,0:03:45.86,0:03:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Ibuki tidak suka bersosialisasi.
Dialogue: 0,0:03:49.58,0:03:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah minum bersamanya,\Ndan dia tidak tampak seperti itu.
Dialogue: 0,0:03:53.88,0:03:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Sejak kapan?
Dialogue: 0,0:03:55.59,0:03:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia asyik, kok.
Dialogue: 0,0:03:58.80,0:04:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari budayakan kebiasaan\Ntidak nyolong start.
Dialogue: 0,0:04:01.18,0:04:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyolong start?\NAku tidak bermaksud begitu.
Dialogue: 0,0:04:04.14,0:04:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oke?\N- Ya!
Dialogue: 0,0:04:09.09,0:04:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya kalem,\Ntapi dia tidak bisa diremehkan.
Dialogue: 0,0:04:12.65,0:04:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!
Dialogue: 0,0:04:14.57,0:04:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau beli minuman seperti apa?
Dialogue: 0,0:04:18.20,0:04:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman yang bisa dinikmati bersama Ibuki!
Dialogue: 0,0:04:20.63,0:04:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa, tuh?
Dialogue: 0,0:04:23.06,0:04:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau minuman\Nyang jarang ditemukan?
Dialogue: 0,0:04:26.04,0:04:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, tuh!\NTapi, masalahnya...
Dialogue: 0,0:04:29.07,0:04:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu yang mana.
Dialogue: 0,0:04:31.42,0:04:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:04:33.18,0:04:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita tanya ke penjaga toko!
Dialogue: 0,0:04:35.51,0:04:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja,
Dialogue: 0,0:04:37.33,0:04:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bagaimana\Nkalau kita lihat-lihat dulu?
Dialogue: 0,0:04:42.61,0:04:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bentuk botol itu\Nbermacam-macam, ya?
Dialogue: 0,0:04:45.39,0:04:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, label minuman keras\Njuga unik-unik, ya.
Dialogue: 0,0:04:50.44,0:04:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada label yang modis,
Dialogue: 0,0:04:51.73,0:04:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ada sake Jepang\Nyang dinamai istilah asing.
Dialogue: 0,0:04:55.22,0:04:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taxi Driver.
Dialogue: 0,0:04:58.03,0:04:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa berkaitan dengan film?
Dialogue: 0,0:05:00.76,0:05:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Seratus Tahun Kesunyian" adalah\Njudul novel dari Amerika Selatan, kan?
Dialogue: 0,0:05:05.33,0:05:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu sake?
Dialogue: 0,0:05:06.95,0:05:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... shochu!
Dialogue: 0,0:05:09.91,0:05:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shochu, ya?
Dialogue: 0,0:05:11.75,0:05:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah pernah coba sake,\Nmungkin itu pilihan bagus.
Dialogue: 0,0:05:14.42,0:05:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu pernah minum shochu?
Dialogue: 0,0:05:17.63,0:05:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum!
Dialogue: 0,0:05:18.71,0:05:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:05:20.47,0:05:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut beli minuman\Nyang belum pernah kurasakan.
Dialogue: 0,0:05:24.00,0:05:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berkenan, silakan dicoba saja.
Dialogue: 0,0:05:27.77,0:05:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh dicoba?
Dialogue: 0,0:05:29.43,0:05:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bisa beli sampelnya\Ndan minum di tempat.
Dialogue: 0,0:05:32.77,0:05:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum di tempat?
Dialogue: 0,0:05:34.27,0:05:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bisa menikmati minuman\Nyang Anda pilih di toko ini.
Dialogue: 0,0:05:37.98,0:05:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku mau yang ini!
Dialogue: 0,0:05:40.49,0:05:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya bunga dan imut!
Dialogue: 0,0:05:44.16,0:05:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah seperti bunga!
Dialogue: 0,0:05:47.16,0:05:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti bunga?
Dialogue: 0,0:05:49.29,0:05:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh pesan dua gelas?
Dialogue: 0,0:05:51.71,0:05:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya menganjurkan minum\Ndengan es batu.
Dialogue: 0,0:05:54.42,0:05:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh banget!
Dialogue: 0,0:05:55.59,0:05:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tunggu sebentar.
Dialogue: 0,0:05:57.59,0:05:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:06:02.87,0:06:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya minuman,\Nmereka juga jual peralatannya.
Dialogue: 0,0:06:07.59,0:06:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo, bagaimana kalau beli cangkir\Nyang sepasang dengan Ketua Asrama?
Dialogue: 0,0:06:11.06,0:06:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepasang?\NEnggak bisa!
Dialogue: 0,0:06:13.19,0:06:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti bisa dijadikan alasan\Nuntuk minum bersama, lo.
Dialogue: 0,0:06:17.23,0:06:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini namanya apa, ya?
Dialogue: 0,0:06:20.23,0:06:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, ski... su...
Dialogue: 0,0:06:24.82,0:06:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suki... suka...
Dialogue: 0,0:06:27.78,0:06:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suki...
Dialogue: 0,0:06:30.95,0:06:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingin makan sukiyaki,\Nsambil minum sake.
Dialogue: 0,0:06:34.50,0:06:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa nyambung ke situ?
Dialogue: 0,0:06:36.13,0:06:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita makan sukiyaki\Nbareng teman-teman malam ini.
Dialogue: 0,0:06:38.92,0:06:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:39.67,0:06:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama.
Dialogue: 0,0:06:41.21,0:06:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokudaime Lili ditambah es batu.
Dialogue: 0,0:06:44.01,0:06:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:06:47.51,0:06:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat menikmati!
Dialogue: 0,0:06:59.65,0:07:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuat banget! Ini rasa ubi!
Dialogue: 0,0:07:02.07,0:07:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokudaime Lili adalah minuman\Nyang agak berat.
Dialogue: 0,0:07:08.52,0:07:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambah lagi!
Dialogue: 0,0:07:10.00,0:07:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:07:10.62,0:07:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatnya!
Dialogue: 0,0:07:14.16,0:07:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya cukup nendang,\Ntapi ada sedikit rasa manis ubi.
Dialogue: 0,0:07:19.17,0:07:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku suka shochu.
Dialogue: 0,0:07:23.17,0:07:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo!
Dialogue: 0,0:07:25.13,0:07:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pilih ini saja!
Dialogue: 0,0:07:28.07,0:07:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Ketua Asrama juga akan menyukainya.
Dialogue: 0,0:07:31.85,0:07:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat banget.\NKamu juga tahu seleranya, ya.
Dialogue: 0,0:07:36.09,0:07:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:07:38.27,0:07:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa kamu yakin\Ntidak beli perangkat minum?
Dialogue: 0,0:07:41.55,0:07:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa beli sepasang?\NPaling Ibuki tidak mau pakai.
Dialogue: 0,0:07:44.74,0:07:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:07:46.24,0:07:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang apa masalahnya?
Dialogue: 0,0:07:48.71,0:07:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia tidak mau,
Dialogue: 0,0:07:51.78,0:07:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nanti sama aku saja.
Dialogue: 0,0:07:53.52,0:07:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan mengada-ada!
Dialogue: 0,0:07:56.19,0:07:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita beli bahan-bahan sukiyaki!
Dialogue: 0,0:07:58.96,0:08:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:08:00.75,0:08:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan mampir lagi!
Dialogue: 0,0:08:40.37,0:08:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dijual di toserba, deh.
Dialogue: 0,0:08:42.40,0:08:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:08:43.71,0:08:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba bilang sekali lagi, Akane!
Dialogue: 0,0:08:46.01,0:08:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, jangan kebangetan\Njadi orang teledor.
Dialogue: 0,0:08:49.13,0:08:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah nantang!\NSiapa yang teledor?
Dialogue: 0,0:08:51.97,0:08:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suruh bilang lagi, kan?
Dialogue: 0,0:08:55.26,0:08:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang harus kamu perbaiki.
Dialogue: 0,0:08:59.98,0:09:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya udah, terserah kamu, deh!
Dialogue: 0,0:09:02.02,0:09:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak peduli kamu lagi!
Dialogue: 0,0:09:04.19,0:09:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Asrama, kita main bareng, yuk!\NSekarang!
Dialogue: 0,0:09:08.03,0:09:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga, Botan!
Dialogue: 0,0:09:09.78,0:09:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yaeka! Maksudku tuh—
Dialogue: 0,0:09:11.74,0:09:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak mau pergi sama aku, kan?
Dialogue: 0,0:09:14.24,0:09:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi, Ketua Asrama, Botan!
Dialogue: 0,0:09:16.49,0:09:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tu-Tunggu!
Dialogue: 0,0:09:18.58,0:09:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kitamori! Kita mau ke mana?
Dialogue: 0,0:09:23.33,0:09:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa bilang enggak mau pergi?
Dialogue: 0,0:09:37.00,0:09:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kak.
Dialogue: 0,0:09:37.89,0:09:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita turun di stasiun berikutnya, kan?
Dialogue: 0,0:09:40.23,0:09:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, Botan!
Dialogue: 0,0:09:41.73,0:09:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan indah Nagatoro\Nsedang menunggu kita!
Dialogue: 0,0:09:44.73,0:09:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai dibiarkan menunggu, dong.
Dialogue: 0,0:09:46.61,0:09:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin enggak sabar, ya.
Dialogue: 0,0:09:48.73,0:09:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian berdua!\NJangan ribut-ribut di dalam kereta.
Dialogue: 0,0:09:52.49,0:09:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitamori Yaeka.
Dialogue: 0,0:09:54.66,0:09:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahasiswi tahun ketiga di universitasku
Dialogue: 0,0:09:56.95,0:10:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan teman dekat Yusa Akane\Nyang seumuran dengannya, tapi...
Dialogue: 0,0:10:02.64,0:10:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemberhentian berikutnya adalah Nagatoro.
Dialogue: 0,0:10:07.90,0:10:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan turun melalui pintu sebelah kiri.
Dialogue: 0,0:10:26.40,0:10:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kitamori, ayo turun sekarang!
Dialogue: 0,0:10:29.05,0:10:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, oke.
Dialogue: 0,0:11:02.45,0:11:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini stasiun Nagatoro, ya?
Dialogue: 0,0:11:05.02,0:11:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga belum pernah ke sini?
Dialogue: 0,0:11:07.19,0:11:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, padahal lumayan dekat\Ndari stasiun Seibu-Chichibu,
Dialogue: 0,0:11:10.48,0:11:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku belum sempat ke sini.
Dialogue: 0,0:11:12.07,0:11:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita lihat pemandangan indah!
Dialogue: 0,0:11:16.78,0:11:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru coba kereta ekspres Chichibu,\Ndan ternyata asyik juga.
Dialogue: 0,0:11:20.91,0:11:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:11:22.20,0:11:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk di kursi berhadapan\Nberasa seperti bertamasya, ya.
Dialogue: 0,0:11:27.33,0:11:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, Pak.\NUntuk tiga orang dewasa.
Dialogue: 0,0:11:29.42,0:11:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, tolong tunjukkan\Ntiket kereta ekspres Anda.
Dialogue: 0,0:11:33.13,0:11:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Bukan tiket kereta dasar?
Dialogue: 0,0:11:35.80,0:11:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:11:37.15,0:11:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu kalau\Nkereta ekspres punya tiket sendiri!
Dialogue: 0,0:11:40.55,0:11:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emang ada pilihannya di mesin tiket?
Dialogue: 0,0:11:42.81,0:11:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabar, sabar.
Dialogue: 0,0:11:44.02,0:11:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting sudah dibayar di loket.
Dialogue: 0,0:11:47.71,0:11:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak teledor, lo.
Dialogue: 0,0:12:11.03,0:12:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku harus bersabar.
Dialogue: 0,0:12:13.42,0:12:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ada Kitamori.
Dialogue: 0,0:12:23.97,0:12:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah, kalian berdua!\NPemandangannya indah sekali!
Dialogue: 0,0:12:38.40,0:12:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya tidak terasa seperti\Ndi ibu kota.
Dialogue: 0,0:12:41.43,0:12:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sini! Ada sungai kecil!
Dialogue: 0,0:12:43.87,0:12:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Mana?
Dialogue: 0,0:12:50.79,0:12:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya dingin.
Dialogue: 0,0:12:53.12,0:12:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batunya tersusun rapi seperti lantai.
Dialogue: 0,0:13:00.84,0:13:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli di tengah perjalanan.
Dialogue: 0,0:13:08.00,0:13:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup untuk kita.
Dialogue: 0,0:13:09.81,0:13:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:13:11.06,0:13:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung di sini,\Nayo kita minum-minum.
Dialogue: 0,0:13:13.40,0:13:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari tempat duduk santai, yuk.
Dialogue: 0,0:13:24.19,0:13:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anginnya lumayan kencang, ya?
Dialogue: 0,0:13:26.91,0:13:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berani ke pinggir.
Dialogue: 0,0:13:29.33,0:13:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai jatuh, ya.
Dialogue: 0,0:13:34.04,0:13:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada minuman keras,\Nsuasana jadi makin asyik, ya.
Dialogue: 0,0:13:37.34,0:13:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:13:43.23,0:13:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak minum?
Dialogue: 0,0:13:45.17,0:13:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sepertinya tidak dulu.
Dialogue: 0,0:14:00.36,0:14:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga belum pernah ke Nagatoro?
Dialogue: 0,0:14:03.82,0:14:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:05.20,0:14:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kegiatan luar\Ndan bepergian sejak dulu.
Dialogue: 0,0:14:09.08,0:14:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum kuliah,\Naku sering melakukannya sendiri.
Dialogue: 0,0:14:13.33,0:14:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kuliah, aku bertemu Akane\Nyang sefrekuensi denganku.
Dialogue: 0,0:14:16.44,0:14:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami suka bahas acara televisi\Ntentang perjalanan naik motor,
Dialogue: 0,0:14:20.44,0:14:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan akhirnya,\Nkami sering bepergian berdua.
Dialogue: 0,0:14:24.26,0:14:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, supaya bisa bepergian lebih jauh,
Dialogue: 0,0:14:28.73,0:14:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bikin SIM motor\Nsaat liburan musim semi
Dialogue: 0,0:14:30.85,0:14:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di tahun ketigaku.
Dialogue: 0,0:14:35.40,0:14:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Akane tidak mau dibonceng sama aku.
Dialogue: 0,0:14:42.09,0:14:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin sakit hati saja.
Dialogue: 0,0:14:44.20,0:14:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu penyebab pertengkaran mereka, ya?
Dialogue: 0,0:14:49.41,0:14:52.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Kak Yusa-lah yang benar.
Dialogue: 0,0:14:52.54,0:14:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:14:53.41,0:14:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kamiina!
Dialogue: 0,0:14:55.48,0:14:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya,
Dialogue: 0,0:14:59.00,0:15:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita baru boleh memboncengkan\Nsetelah SIM-nya berusia satu tahun.
Dialogue: 0,0:15:07.76,0:15:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu banyak, ya?
Dialogue: 0,0:15:10.06,0:15:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:15:11.35,0:15:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma kebetulan tahu\Nkarena ayahku juga naik motor.
Dialogue: 0,0:15:32.58,0:15:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang kumaksud, Yaeka.
Dialogue: 0,0:15:36.29,0:15:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi lapar.
Dialogue: 0,0:15:38.79,0:15:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan es krim?
Dialogue: 0,0:15:40.46,0:15:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, tuh.
Dialogue: 0,0:15:42.00,0:15:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan-kapan, ayo kita ajak Yusa\Ndan Kak Gujyo.
Dialogue: 0,0:15:48.18,0:15:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin ke sini denganmu saja.
Dialogue: 0,0:15:53.00,0:15:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa?
Dialogue: 0,0:15:55.48,0:15:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, jangan pura-pura.
Dialogue: 0,0:16:02.19,0:16:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.\NSupaya bisa minum miras.
Dialogue: 0,0:16:06.40,0:16:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:07.86,0:16:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah, kalian berdua!
Dialogue: 0,0:16:10.24,0:16:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siap!\N- Ah, maaf!
Dialogue: 0,0:16:12.37,0:16:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat, Ketua!
Dialogue: 0,0:16:19.50,0:16:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Es krimnya enak banget, ya.
Dialogue: 0,0:16:22.96,0:16:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:24.88,0:16:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin beli pakaian, nih.\NSoalnya sudah mulai panas juga.
Dialogue: 0,0:16:31.30,0:16:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:36.14,0:16:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah.
Dialogue: 0,0:16:37.23,0:16:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok begitu, sih?
Dialogue: 0,0:16:39.52,0:16:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah! Lupakan saja!
Dialogue: 0,0:16:43.36,0:16:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia marah?
Dialogue: 0,0:16:53.28,0:16:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin ditemani.
Dialogue: 0,0:16:57.29,0:16:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau, ya?
Dialogue: 0,0:17:03.27,0:17:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak juga!
Dialogue: 0,0:17:08.80,0:17:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengok kanan, ada toko baju!
Dialogue: 0,0:17:10.80,0:17:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengok kiri, ada toko baju!
Dialogue: 0,0:17:13.39,0:17:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tokyo kebanyakan penjual baju!
Dialogue: 0,0:17:15.58,0:17:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia semangat banget.
Dialogue: 0,0:17:17.27,0:17:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana rumahmu, Kamiina?
Dialogue: 0,0:17:19.39,0:17:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagano!\NJarang ada butik di Nagano!
Dialogue: 0,0:17:23.98,0:17:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku pernah lihat\Ntempat itu di majalah!
Dialogue: 0,0:17:27.35,0:17:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina tampak lebih\Nkekanak-kanakan hari ini.
Dialogue: 0,0:17:31.19,0:17:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia riang banget.
Dialogue: 0,0:17:33.35,0:17:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak dewasa,\Ntapi ternyata bisa begini, ya?
Dialogue: 0,0:17:37.98,0:17:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau sudah minum miras...
Dialogue: 0,0:17:40.29,0:17:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pengin lidahmu.
Dialogue: 0,0:17:43.58,0:17:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin ke sini denganmu saja.
Dialogue: 0,0:17:46.80,0:17:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu perubahan saat mabuk?
Dialogue: 0,0:17:50.13,0:17:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masuk mana?
Dialogue: 0,0:17:52.26,0:17:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, toko, ya?
Dialogue: 0,0:17:54.26,0:17:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:17:58.93,0:18:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Minuman keras?
Dialogue: 0,0:18:02.00,0:18:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:18:03.60,0:18:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, selamat datang, Ibuki.
Dialogue: 0,0:18:06.92,0:18:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia temanmu?
Dialogue: 0,0:18:08.61,0:18:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juniorku, Master.
Dialogue: 0,0:18:10.53,0:18:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah kenal?\N- Begitu rupanya.
Dialogue: 0,0:18:12.30,0:18:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja di sini, ya.
Dialogue: 0,0:18:17.20,0:18:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa aku boleh lihat-lihat itu?
Dialogue: 0,0:18:20.75,0:18:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!\NPilih saja sepuasmu!
Dialogue: 0,0:18:28.75,0:18:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Ibuki.\NMau mulai dengan wine bersoda?
Dialogue: 0,0:18:32.55,0:18:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Minuman keras?\NBukankah ini toko baju?
Dialogue: 0,0:18:36.64,0:18:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ini toko baju.
Dialogue: 0,0:18:39.33,0:18:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menyediakan baju dan minuman keras.
Dialogue: 0,0:18:43.02,0:18:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga punya keju lezat.
Dialogue: 0,0:18:45.81,0:18:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamunya dibikin mabuk\Nsupaya dompetnya bocor.
Dialogue: 0,0:18:49.78,0:18:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Nanti kita ke belakang, ya, Ibuki.
Dialogue: 0,0:18:52.99,0:18:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tokyo memang seram.
Dialogue: 0,0:18:55.57,0:18:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa aku boleh mencobanya?
Dialogue: 0,0:18:58.03,0:18:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:19:04.06,0:19:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:19:05.58,0:19:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat menikmati.
Dialogue: 0,0:19:12.03,0:19:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa senyum-senyum begitu?
Dialogue: 0,0:19:14.67,0:19:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben kamu mengajak teman.
Dialogue: 0,0:19:18.51,0:19:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini pertama kalinya?
Dialogue: 0,0:19:21.71,0:19:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, begitulah.
Dialogue: 0,0:19:23.81,0:19:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akrab, ya.
Dialogue: 0,0:19:26.77,0:19:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja, kok.\NKami minum bersama, sih.
Dialogue: 0,0:19:30.40,0:19:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Baguslah.
Dialogue: 0,0:19:38.91,0:19:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus!
Dialogue: 0,0:19:41.16,0:19:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat! Bagaimana?\NApa cocok untuk musim panas?
Dialogue: 0,0:19:44.75,0:19:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, bidadari surga!\NSeperti putri bangsawan yang liburan?
Dialogue: 0,0:19:50.00,0:19:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi malu.
Dialogue: 0,0:19:53.22,0:19:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut.
Dialogue: 0,0:19:55.15,0:19:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memakainya tanpa ragu, ya?
Dialogue: 0,0:19:58.87,0:20:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia cocok\Npakai baju apa pun, deh.
Dialogue: 0,0:20:02.93,0:20:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.\NSilakan nikmati minumannya.
Dialogue: 0,0:20:06.60,0:20:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati supaya tidak mengotori baju, ya.
Dialogue: 0,0:20:09.92,0:20:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini wine putih?
Dialogue: 0,0:20:11.86,0:20:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, wine putih bersoda.
Dialogue: 0,0:20:18.56,0:20:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Nyas-nyus" di mulut.
Dialogue: 0,0:20:20.32,0:20:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mengandung soda ringan.
Dialogue: 0,0:20:22.08,0:20:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya ringan di mulut.
Dialogue: 0,0:20:24.45,0:20:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa diminum tanpa henti.
Dialogue: 0,0:20:26.66,0:20:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sodanya tidak terlalu kuat.
Dialogue: 0,0:20:28.25,0:20:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Habiskan!
Dialogue: 0,0:20:29.67,0:20:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berlebihan!
Dialogue: 0,0:20:32.63,0:20:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ternyata masih cegukan.
Dialogue: 0,0:20:35.05,0:20:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ringan, soda tetaplah soda.
Dialogue: 0,0:20:42.29,0:20:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua mirip, ya.
Dialogue: 0,0:20:44.31,0:20:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:47.21,0:20:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!
Dialogue: 0,0:20:48.27,0:20:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pilih baju untukmu,\Njadi tolong dipakai!
Dialogue: 0,0:20:51.35,0:20:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:52.36,0:20:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu... Tunggu...
Dialogue: 0,0:20:57.14,0:20:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:20:58.90,0:21:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini terlalu imut?
Dialogue: 0,0:21:00.57,0:21:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus! Itu cocok banget!
Dialogue: 0,0:21:03.70,0:21:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berasa musim panas banget!
Dialogue: 0,0:21:05.54,0:21:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kamu terlalu sering\Nmemakai baju kedodoran.
Dialogue: 0,0:21:09.00,0:21:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak nyaman.
Dialogue: 0,0:21:11.75,0:21:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sangat cocok untukmu.
Dialogue: 0,0:21:16.21,0:21:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya bagus.
Dialogue: 0,0:21:19.09,0:21:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.\NApa telinga kalian ditindik?
Dialogue: 0,0:21:22.72,0:21:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya anting-anting imut.
Dialogue: 0,0:21:24.80,0:21:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:21:26.01,0:21:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:21:27.18,0:21:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa kami boleh lihat?
Dialogue: 0,0:21:31.06,0:21:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bintang laut!\N- Bintang!
Dialogue: 0,0:21:32.27,0:21:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Imut!
Dialogue: 0,0:21:34.73,0:21:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:21:38.94,0:21:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Asrama, ayo kita tindik telinga\Ndan memakai anting ini.
Dialogue: 0,0:21:43.66,0:21:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar sepasang.
Dialogue: 0,0:21:46.16,0:21:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:47.12,0:21:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepasang?
Dialogue: 0,0:21:48.62,0:21:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau?\NBiar kutindik dengan hati-hati.
Dialogue: 0,0:21:51.62,0:21:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus kamu yang menindik?
Dialogue: 0,0:21:53.88,0:21:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak boleh?
Dialogue: 0,0:21:56.00,0:21:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bilang begitu.
Dialogue: 0,0:21:57.96,0:21:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kamu setuju, ya.
Dialogue: 0,0:22:01.17,0:22:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jadi bawel saat mabuk.
Dialogue: 0,0:22:04.41,0:22:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antingnya kusisihkan untuk kalian, ya.
Dialogue: 0,0:22:06.35,0:22:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:22:08.58,0:22:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
