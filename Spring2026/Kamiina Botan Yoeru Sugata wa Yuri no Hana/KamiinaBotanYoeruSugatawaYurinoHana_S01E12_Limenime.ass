Dialogue: 0,0:03:05.54,0:03:10.96,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:03:32.19,0:03:35.19,sign,,0000,0000,0000,,KERETA GANTUNG GUNUNG HODO
Dialogue: 0,0:03:45.50,0:03:48.00,sign,,0000,0000,0000,,AMAZAKE\NGINKGO PANGGANG CHICHIBU
Dialogue: 0,0:04:38.42,0:04:41.01,sign,,0000,0000,0000,,TALI KAWAT BAJA
Dialogue: 0,0:04:41.01,0:04:43.64,sign,,0000,0000,0000,,GUNUNG HODO, 2.200 YEN
Dialogue: 0,0:04:53.52,0:04:55.27,sign,,0000,0000,0000,,TIKET PERJALANAN DUA ARAH
Dialogue: 0,0:04:57.78,0:04:59.24,sign,,0000,0000,0000,,HARAP MENUNGGU\NSAMPAI KERETA BENAR-BENAR BERHENTI
Dialogue: 0,0:05:49.87,0:05:52.71,sign,,0000,0000,0000,,INFORMASI OBSERVASI
Dialogue: 0,0:06:06.26,0:06:08.22,sign,,0000,0000,0000,,GUNUNG HODO, 497,1 MDPL
Dialogue: 0,0:09:44.36,0:09:46.32,sign,,0000,0000,0000,,FILSAFAT DAN AGAMA
Dialogue: 0,0:11:49.69,0:11:51.40,sign,,0000,0000,0000,,ANTOLOGI PUISI TAIWAN
Dialogue: 0,0:13:37.00,0:13:47.01,sign,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:14:18.17,0:14:21.00,sign,,0000,0000,0000,,STASIUN ECHIGO-YUZAWA
Dialogue: 0,0:14:50.29,0:14:50.91,sign,,0000,0000,0000,,PONSHUKAN, KIKIZAKE BANSHO
Dialogue: 0,0:14:59.29,0:15:01.26,sign,,0000,0000,0000,,PONSHUKAN
Dialogue: 0,0:15:46.72,0:15:49.18,sign,,0000,0000,0000,,KIKIZAKE BANSHO\NECHIGO NO SAKAGURA
Dialogue: 0,0:16:08.99,0:16:11.78,sign,,0000,0000,0000,,SAKE STANDAR PONSHUKAN
Dialogue: 0,0:16:11.78,0:16:15.04,sign,,0000,0000,0000,,DENGAN MENJADIKAN SAKE INI SEBAGAI STANDAR
Dialogue: 0,0:16:15.04,0:16:16.50,sign,,0000,0000,0000,,KAMI MENGGAMBARKAN KEKUATAN RASA
Dialogue: 0,0:16:16.50,0:16:18.50,sign,,0000,0000,0000,,DAN KARAKTERISTIKNYA
Dialogue: 0,0:16:18.50,0:16:19.71,sign,,0000,0000,0000,,DENGAN TANDA BINTANG
Dialogue: 0,0:16:41.23,0:16:44.69,sign,,0000,0000,0000,,KIKIZAKE BANSHO
Dialogue: 0,0:18:09.74,0:18:13.24,sign,,0000,0000,0000,,KAMAR MATSUKAZE
Dialogue: 0,0:21:20.43,0:21:24.89,sign,,0000,0000,0000,,ALAT TINDIK INSTAN
Dialogue: 0,0:22:06.89,0:22:07.41,sign,,0000,0000,0000,,KEPERLUAN ASRAMA (6)
Dialogue: 0,0:22:07.41,0:22:08.27,sign,,0000,0000,0000,,BARU MELEWATI HANNO.\NAKU MAKAN DI IKEBUKURO, JADI LANGSUNG BALIK.
Dialogue: 0,0:22:08.27,0:22:09.35,sign,,0000,0000,0000,,CHIN-LAN: BAIKLAH
Dialogue: 0,0:22:09.35,0:22:11.18,sign,,0000,0000,0000,,KANADE: HATI-HATI DI JALAN, YA
Dialogue: 0,0:22:11.18,0:22:12.19,sign,,0000,0000,0000,,YAEKA: MUNGKIN KAMU LUPA, TAPI BESOK KITA\NAKAN BERSIH-BERSIH TOTAL DI ASRAMA.
Dialogue: 0,0:22:12.19,0:22:13.27,sign,,0000,0000,0000,,EH? BENARKAH?
Dialogue: 0,0:22:13.27,0:22:14.98,sign,,0000,0000,0000,,YAEKA: REAKSIMU SAMA SEPERTI AKANE...
Dialogue: 0,0:22:14.98,0:22:15.94,sign,,0000,0000,0000,,AKANE: APA MASALAHNYA?
Dialogue: 0,0:22:15.94,0:22:17.44,sign,,0000,0000,0000,,MALAS
Dialogue: 0,0:22:17.44,0:22:20.86,sign,,0000,0000,0000,,KITA BICARAKAN SAAT KAMI SUDAH KEMBALI.\NAKU AKAN KASIH KABAR SAAT SAMPAI STASIUN.
Dialogue: 0,0:23:00.98,0:23:01.78,sign,,0000,0000,0000,,SURAT TANDA TERIMA
Dialogue: 0,0:00:14.79,0:00:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mencintainya\Nsecara ugal-ugalan.
Dialogue: 0,0:00:20.88,0:00:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mencintainya
Dialogue: 0,0:00:23.63,0:00:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}secara ugal-ugalan.
Dialogue: 0,0:00:46.78,0:00:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:49.36,0:00:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:00:51.32,0:00:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingat anting itu?
Dialogue: 0,0:00:53.70,0:00:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak yang jaga toko sudah menjualnya.
Dialogue: 0,0:00:57.31,0:00:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:00.16,0:01:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga baru tahu sekarang.
Dialogue: 0,0:01:03.53,0:01:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.\NPadahal aku sudah bilang dari dulu.
Dialogue: 0,0:01:07.82,0:01:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelanggan dari luar negeri juga\Nmembeli lewat situs web,
Dialogue: 0,0:01:11.01,0:01:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, barang populer\Nmemang langsung habis.
Dialogue: 0,0:01:16.41,0:01:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Imut!
Dialogue: 0,0:01:18.32,0:01:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:01:19.68,0:01:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Asrama, ayo kita tindik telinga\Ndan memakai anting-anting ini.
Dialogue: 0,0:01:24.40,0:01:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar berpasangan.
Dialogue: 0,0:01:25.61,0:01:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antingnya kusisihkan untuk kalian, ya.
Dialogue: 0,0:01:27.57,0:01:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:30.25,0:01:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:01:34.45,0:01:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengabariku.
Dialogue: 0,0:03:19.85,0:03:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking dinginnya,
Dialogue: 0,0:03:21.49,0:03:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sampai jadi Esamuel L. Jackson.
Dialogue: 0,0:03:24.97,0:03:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Esamuel?
Dialogue: 0,0:03:25.98,0:03:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai jadi Esam Peckinpah.
Dialogue: 0,0:03:28.53,0:03:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I am Es.
Dialogue: 0,0:03:30.29,0:03:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Es 41!
Dialogue: 0,0:03:32.19,0:03:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik amat.
Dialogue: 0,0:03:36.49,0:03:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, belum ada siapa-siapa.
Dialogue: 0,0:03:42.02,0:03:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke toilet dulu, ya.
Dialogue: 0,0:03:43.39,0:03:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku juga.
Dialogue: 0,0:03:48.00,0:03:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masih cukup gelap,\Ntapi apa kita bisa melihatnya?
Dialogue: 0,0:03:52.31,0:03:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:53.78,0:03:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:03:56.99,0:03:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat ini.\NAda yang jual minuman.
Dialogue: 0,0:04:02.25,0:04:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak punya jiwa kebersamaan, ya?
Dialogue: 0,0:04:05.87,0:04:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa?
Dialogue: 0,0:04:10.76,0:04:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kita bisa melihat lautan awan.
Dialogue: 0,0:04:14.36,0:04:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:15.86,0:04:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bisa karena perbedaan suhu\Nsiang dan malam cukup besar.
Dialogue: 0,0:04:20.01,0:04:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karena pendinginan radiasi.
Dialogue: 0,0:04:24.92,0:04:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin ini mengeluarkan mainan\Nyang tidak berguna.
Dialogue: 0,0:04:27.55,0:04:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa dikembalikan, ditukar,\Natau pengembalian uang.
Dialogue: 0,0:04:30.97,0:04:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringatannya banyak banget.
Dialogue: 0,0:04:33.42,0:04:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sejak kapan, ya?
Dialogue: 0,0:04:35.95,0:04:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah.
Dialogue: 0,0:04:37.22,0:04:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:04:38.42,0:04:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku kaget karena mereka
Dialogue: 0,0:04:41.01,0:04:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jual tali kereta gantung di sini.
Dialogue: 0,0:04:43.64,0:04:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Talinya bisa dibeli, ya?
Dialogue: 0,0:04:46.31,0:04:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:04:48.17,0:04:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta gantungnya sudah beroperasi.
Dialogue: 0,0:04:50.56,0:04:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:12.56,0:05:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta gantung ini seram banget\Nsaat melewati tiang penyangga, ya.
Dialogue: 0,0:05:16.96,0:05:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa goyang-goyang, seperti wahana.
Dialogue: 0,0:05:25.03,0:05:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langit dan gunungnya\Ntampak melebur jadi satu.
Dialogue: 0,0:05:29.38,0:05:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pemandangan yang hanya\Nbisa dilihat di musim ini.
Dialogue: 0,0:05:34.80,0:05:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu ini
Dialogue: 0,0:05:37.59,0:05:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terasa begitu spesial.
Dialogue: 0,0:05:54.71,0:05:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak kelihatan.
Dialogue: 0,0:05:56.54,0:05:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:58.21,0:05:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rusak, ya?
Dialogue: 0,0:05:59.91,0:06:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:06:02.01,0:06:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uangnya sudah dimasukkan?
Dialogue: 0,0:06:03.23,0:06:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:06:04.51,0:06:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:06:09.37,0:06:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini puncaknya?
Dialogue: 0,0:06:11.48,0:06:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinar mataharinya tidak terasa hangat.
Dialogue: 0,0:06:18.26,0:06:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kak.
Dialogue: 0,0:06:20.86,0:06:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:06:22.60,0:06:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita bergandengan tangan,\Nakan terasa lebih hangat.
Dialogue: 0,0:06:33.55,0:06:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganmu kenapa?
Dialogue: 0,0:06:36.82,0:06:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:39.52,0:06:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya berpikir,
Dialogue: 0,0:06:42.73,0:06:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musim-musim seperti ini\Nterasa dingin dan agak sepi.
Dialogue: 0,0:06:50.81,0:06:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sedikit lebih hangat,
Dialogue: 0,0:06:52.65,0:06:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bunga plum dan adonis\Npasti mekar di mana-mana.
Dialogue: 0,0:06:58.17,0:07:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahumu kelihatan, tuh.\NAku akan meminjamkan jaketku.
Dialogue: 0,0:07:02.23,0:07:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah.
Dialogue: 0,0:07:04.57,0:07:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kamu kedinginan.
Dialogue: 0,0:07:07.70,0:07:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mau minum bareng?
Dialogue: 0,0:07:14.41,0:07:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umeshu Buko yang kubeli di bawah.
Dialogue: 0,0:07:17.07,0:07:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak dan bikin hangat.
Dialogue: 0,0:07:24.01,0:07:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:28.58,0:07:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan?
Dialogue: 0,0:07:41.92,0:07:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki?
Dialogue: 0,0:07:45.09,0:07:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki!
Dialogue: 0,0:07:49.14,0:07:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Botan!
Dialogue: 0,0:07:52.03,0:07:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bunga sakura di musim dingin!
Dialogue: 0,0:07:54.92,0:07:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!\NMusim dingin ini tidak sepi!
Dialogue: 0,0:08:07.07,0:08:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kamu benar.
Dialogue: 0,0:08:21.01,0:08:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natal, ya.
Dialogue: 0,0:08:24.08,0:08:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ngapain di malam Natal?
Dialogue: 0,0:08:25.65,0:08:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sendirian aja.
Dialogue: 0,0:08:27.03,0:08:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedih banget, kumpul aja, yuk.
Dialogue: 0,0:08:29.07,0:08:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap!
Dialogue: 0,0:08:31.10,0:08:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum tahu\Ntingkat antusiasme Natal di Jepang.
Dialogue: 0,0:08:34.28,0:08:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip Festival Pertengahan Musim Gugur?
Dialogue: 0,0:08:38.02,0:08:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah enggak tahu\NFestival Pertengahan Musim Gugur.
Dialogue: 0,0:08:42.03,0:08:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Memangnya Natal di Taiwan\Nberbeda dengan di Jepang?
Dialogue: 0,0:08:45.76,0:08:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda banget!
Dialogue: 0,0:08:47.13,0:08:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda 360 derajat!
Dialogue: 0,0:08:49.30,0:08:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu satu putaran penuh.
Dialogue: 0,0:08:51.81,0:08:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan kue bareng keluarga?
Dialogue: 0,0:08:53.57,0:08:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:08:55.12,0:08:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tukar hadiah dengan pasangan?
Dialogue: 0,0:08:57.31,0:08:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak melakukan itu.
Dialogue: 0,0:08:59.71,0:09:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Beda banget.
Dialogue: 0,0:09:02.27,0:09:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:09:04.20,0:09:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natal kelabu, dong.
Dialogue: 0,0:09:06.43,0:09:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:09:15.91,0:09:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, maaf karena aku selalu\Nminta ditemani ke toko buku.
Dialogue: 0,0:09:18.93,0:09:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NAku senang, kok.
Dialogue: 0,0:09:26.15,0:09:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau beli buku apa?
Dialogue: 0,0:09:29.51,0:09:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan pertama buku Foucault di Jepang.
Dialogue: 0,0:09:32.26,0:09:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lagi, ya?
Dialogue: 0,0:09:33.97,0:09:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan membaca saat libur musim dingin.
Dialogue: 0,0:09:37.62,0:09:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini menerbitkan buku baru, ya.
Dialogue: 0,0:09:40.43,0:09:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukunya tebal seperti biasanya.
Dialogue: 0,0:09:54.14,0:09:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka baca buku, ya.
Dialogue: 0,0:09:56.74,0:09:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:00.16,0:10:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuputuskan.
Dialogue: 0,0:10:04.79,0:10:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:05.71,0:10:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita tukar hadiah.
Dialogue: 0,0:10:07.80,0:10:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan buku.
Dialogue: 0,0:10:09.38,0:10:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa?
Dialogue: 0,0:10:10.96,0:10:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Natal.
Dialogue: 0,0:10:13.73,0:10:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah pasangan akan melakukan hal itu?
Dialogue: 0,0:10:38.91,0:10:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pilih buku selama 30 menit,\Nlalu ketemuan di kafe luar toko, ya.
Dialogue: 0,0:10:43.75,0:10:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut pilihanku enggak cocok.
Dialogue: 0,0:10:50.35,0:10:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.\NAku harus buang sifat serakah
Dialogue: 0,0:10:52.84,0:10:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang selalu ingin mencetak "home run"\Ndalam pemberian.
Dialogue: 0,0:10:57.35,0:10:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku menyebutnya "pemberian"?
Dialogue: 0,0:10:59.01,0:11:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya "hadiah".
Dialogue: 0,0:11:00.56,0:11:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya aku Marcel Mauss?
Dialogue: 0,0:11:03.94,0:11:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malu.
Dialogue: 0,0:11:05.78,0:11:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari awal, aku tidak boleh berharap\Nini akan membuatnya senang.
Dialogue: 0,0:11:11.70,0:11:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku juga kesulitan memilih\Nkalau tidak ada harapan seperti itu.
Dialogue: 0,0:11:16.12,0:11:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh.
Dialogue: 0,0:11:17.91,0:11:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memikirkan buku,
Dialogue: 0,0:11:20.08,0:11:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau memikirkan Chin-lan,\Naku jadi bingung sendiri.
Dialogue: 0,0:11:24.32,0:11:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tidak ada satu pun masalah\Nyang mudah diselesaikan."
Dialogue: 0,0:11:28.63,0:11:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam hal seperti ini,\NKobayashi Hideo benar sekali.
Dialogue: 0,0:11:40.19,0:11:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tahu lebih banyak
Dialogue: 0,0:11:42.76,0:11:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang dia.
Dialogue: 0,0:11:47.65,0:11:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:11:49.69,0:11:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memilih ini.
Dialogue: 0,0:11:51.82,0:11:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mirip antologi puisi Taiwan modern.
Dialogue: 0,0:11:55.39,0:11:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya karya Chen Li, bagus banget.
Dialogue: 0,0:11:57.73,0:11:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kamu suka.
Dialogue: 0,0:12:01.28,0:12:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:03.75,0:12:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu suka puisi?
Dialogue: 0,0:12:09.04,0:12:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya wawasannya, tapi suka.
Dialogue: 0,0:12:12.96,0:12:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:12:16.09,0:12:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku menonton film\Ntentang penyair Taiwan.
Dialogue: 0,0:12:20.26,0:12:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan nuansa Jepang di Taiwan\Nuntuk pertama kalinya.
Dialogue: 0,0:12:24.47,0:12:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal itu tiba-tiba terlintas di pikiranku.
Dialogue: 0,0:12:29.13,0:12:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin kamu tahu itu, Kanade.
Dialogue: 0,0:12:43.29,0:12:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:12:44.83,0:12:49.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memang kurang pandai\Nmembicarakan diriku sendiri
Dialogue: 0,0:12:49.46,0:12:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menyampaikan perasaan.
Dialogue: 0,0:12:53.99,0:12:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah ini.
Dialogue: 0,0:12:55.59,0:12:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:12:57.09,0:12:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku foto?
Dialogue: 0,0:12:58.34,0:12:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:13:01.77,0:13:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kartu pos.
Dialogue: 0,0:13:04.43,0:13:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:13:06.10,0:13:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kartu pos dengan foto\Nyang diambil sutradara film favoritku.
Dialogue: 0,0:13:12.76,0:13:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kamu tidak keberatan,
Dialogue: 0,0:13:14.82,0:13:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}suatu saat nanti,
Dialogue: 0,0:13:21.97,0:13:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tulislah sesuatu\Ntentang dirimu di kartu ini,
Dialogue: 0,0:13:25.20,0:13:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kirimkan padaku.
Dialogue: 0,0:13:27.24,0:13:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chin-lan.
Dialogue: 0,0:13:32.95,0:13:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku janji.
Dialogue: 0,0:13:56.77,0:14:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya turun juga, salju menyebalkan.
Dialogue: 0,0:14:01.90,0:14:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salju di Echigo-Yuzawa\Nsetebal di kaki Gunung Tateyama, ya?
Dialogue: 0,0:14:07.12,0:14:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Botan.
Dialogue: 0,0:14:09.87,0:14:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memandumu\Ndalam wisata kita kali ini.
Dialogue: 0,0:14:13.62,0:14:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke?
Dialogue: 0,0:14:18.17,0:14:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku tidak sabar lagi.
Dialogue: 0,0:14:26.60,0:14:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niigata berkaitan dengan beras!
Dialogue: 0,0:14:28.81,0:14:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beras berkaitan dengan sake!
Dialogue: 0,0:14:30.68,0:14:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan sake berkaitan dengan
Dialogue: 0,0:14:32.60,0:14:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponshukan!
Dialogue: 0,0:14:35.38,0:14:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponshukan adalah
Dialogue: 0,0:14:37.19,0:14:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}toko berbagai produk lokal khas Niigata
Dialogue: 0,0:14:40.03,0:14:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bahkan belum diketahui\Noleh orang Niigata itu sendiri.
Dialogue: 0,0:14:44.82,0:14:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di cabang onsen Echigo-Yuzawa
Dialogue: 0,0:14:46.45,0:14:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan ada "Pemandian Sake"\Nyang airnya dicampur sake.
Dialogue: 0,0:14:50.91,0:14:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya tarik utamanya adalah\Nruangan sake Kikizake Bansho,
Dialogue: 0,0:14:54.33,0:14:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat kita bisa mencicipi sake\Ndari semua produsen di Niigata.
Dialogue: 0,0:14:57.00,0:14:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren banget, ya.
Dialogue: 0,0:15:01.26,0:15:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama ingin ke sini.
Dialogue: 0,0:15:04.22,0:15:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga sake orisinal Ponshukan.
Dialogue: 0,0:15:08.01,0:15:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seperti apa rasanya, ya?\N- Ah, dia terlihat senang sekali.
Dialogue: 0,0:15:13.35,0:15:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku merasa lega?
Dialogue: 0,0:15:18.09,0:15:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu merasa terpaksa\Nsaat kuajak ke sini?
Dialogue: 0,0:15:26.53,0:15:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk, yuk.
Dialogue: 0,0:15:30.18,0:15:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujung-ujungnya, minuman keras.
Dialogue: 0,0:15:44.21,0:15:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan?
Dialogue: 0,0:15:49.80,0:15:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:50.76,0:15:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sekitar seratus jenis!
Dialogue: 0,0:15:53.72,0:15:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Semua ini sake Niigata, ya?
Dialogue: 0,0:15:57.48,0:15:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah koin yang dibutuhkan
Dialogue: 0,0:15:59.65,0:16:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berbeda-beda tergantung\Njenis sakenya, ya.
Dialogue: 0,0:16:04.40,0:16:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau yang ini.\NKaganoi.
Dialogue: 0,0:16:06.74,0:16:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Cepat banget!
Dialogue: 0,0:16:08.20,0:16:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:08.99,0:16:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya sake ini dijadikan standar acuan
Dialogue: 0,0:16:11.78,0:16:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membandingkan rasa semua sake di sini.
Dialogue: 0,0:16:15.04,0:16:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:16:16.50,0:16:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga mau.
Dialogue: 0,0:16:18.50,0:16:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, dasar peniru.
Dialogue: 0,0:16:45.11,0:16:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya minum apa, ya?
Dialogue: 0,0:16:46.99,0:16:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumanku masih tersisa sedikit.
Dialogue: 0,0:16:48.86,0:16:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat-lihatlah dulu.
Dialogue: 0,0:16:51.11,0:16:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:02.75,0:17:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:17:06.21,0:17:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman keras ini\Nbisa diminum sambil berdiri
Dialogue: 0,0:17:10.30,0:17:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti beli kopi kaleng\Ndari mesin penjual minuman.
Dialogue: 0,0:17:15.66,0:17:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku tidak bertemu Ibuki,
Dialogue: 0,0:17:18.03,0:17:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku bisa dapat\Npengalaman seperti ini?
Dialogue: 0,0:17:22.44,0:17:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botan!
Dialogue: 0,0:17:24.02,0:17:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan-kapan kita ke sini lagi, yuk.
Dialogue: 0,0:17:26.97,0:17:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus...
Dialogue: 0,0:17:30.26,0:17:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita coba semuanya!
Dialogue: 0,0:17:32.41,0:17:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:17:35.06,0:17:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus.
Dialogue: 0,0:17:36.79,0:17:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang jual kotak sake di luar.
Dialogue: 0,0:17:39.50,0:17:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin penasaran, ya.
Dialogue: 0,0:17:45.01,0:17:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu butuh waktu berapa tahun lagi, ya?
Dialogue: 0,0:17:50.22,0:17:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat itu, mungkin kami sudah lulus.
Dialogue: 0,0:17:56.01,0:18:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kami juga tidak tinggal\Ndi asrama itu lagi.
Dialogue: 0,0:18:02.17,0:18:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa kali lagi\Nkami bisa minum bareng?
Dialogue: 0,0:18:09.74,0:18:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat beristirahat.
Dialogue: 0,0:18:16.25,0:18:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:18:18.46,0:18:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamarnya bagus banget.
Dialogue: 0,0:18:20.61,0:18:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ibuki.
Dialogue: 0,0:18:21.75,0:18:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua bir, cola, dan air soda!
Dialogue: 0,0:18:25.25,0:18:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:18:26.57,0:18:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulkasnya sudah diisi\Nbanyak minuman sambutan!
Dialogue: 0,0:18:30.33,0:18:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu dengar?
Dialogue: 0,0:18:31.67,0:18:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah?\NIya! Maafkan aku!
Dialogue: 0,0:18:35.08,0:18:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jendelanya besar dan bagus, ya.
Dialogue: 0,0:18:37.30,0:18:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taruh botol birmu!
Dialogue: 0,0:18:44.09,0:18:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasurnya dibikin berdempetan!
Dialogue: 0,0:18:46.27,0:18:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencurigakan.
Dialogue: 0,0:18:56.16,0:18:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:00.10,0:19:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:07.11,0:19:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu imut banget, Ibuki.
Dialogue: 0,0:19:14.45,0:19:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Masih ada waktu sebelum makan.
Dialogue: 0,0:19:17.59,0:19:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke pemandian?
Dialogue: 0,0:19:22.44,0:19:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:26.28,0:19:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berduaan saja.
Dialogue: 0,0:19:36.00,0:19:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin
Dialogue: 0,0:19:39.63,0:19:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melakukan banyak hal.
Dialogue: 0,0:19:42.64,0:19:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh?
Dialogue: 0,0:19:45.15,0:19:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memastikannya satu kali.
Dialogue: 0,0:19:48.00,0:19:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan mengulanginya lagi.
Dialogue: 0,0:19:50.96,0:19:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, tunggu!
Dialogue: 0,0:19:53.00,0:19:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku belum siap—
Dialogue: 0,0:20:06.56,0:20:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum siap?
Dialogue: 0,0:20:10.03,0:20:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:20:11.88,0:20:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata cuma aku
Dialogue: 0,0:20:14.51,0:20:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sudah siap sejak awal.
Dialogue: 0,0:20:18.26,0:20:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:20:20.03,0:20:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua,
Dialogue: 0,0:20:22.49,0:20:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah berhenti berteman,\Nsekarang kita menjadi apa?
Dialogue: 0,0:20:49.84,0:20:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:20:51.31,0:20:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:52.90,0:20:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antingnya—\NKatanya sudah terjual habis.
Dialogue: 0,0:20:55.44,0:20:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:20:56.93,0:20:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:20:59.03,0:21:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatmu sedih lagi.
Dialogue: 0,0:21:02.57,0:21:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang membelinya.
Dialogue: 0,0:21:04.64,0:21:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lama ini.
Dialogue: 0,0:21:06.24,0:21:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku belum bisa memberikannya.
Dialogue: 0,0:21:09.53,0:21:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:26.44,0:21:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin
Dialogue: 0,0:21:28.23,0:21:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu menindikku dengan ini.
Dialogue: 0,0:21:32.01,0:21:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu yang melakukannya.
Dialogue: 0,0:21:37.78,0:21:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum melangkah lebih lanjut.
Dialogue: 0,0:21:40.99,0:21:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kalau boleh...
Dialogue: 0,0:21:44.21,0:21:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:21:55.17,0:21:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:21:58.27,0:22:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukanlah padaku juga.
Dialogue: 0,0:22:24.76,0:22:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku sudah tahu\Nkasurnya berdempetan.
Dialogue: 0,0:22:29.52,0:22:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku yang pilih kamarnya.
Dialogue: 0,0:22:35.07,0:22:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum.
Dialogue: 0,0:22:36.46,0:22:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:41.34,0:22:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini sakit?
Dialogue: 0,0:22:42.51,0:22:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak sakit.
Dialogue: 0,0:22:45.01,0:22:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:22:46.39,0:22:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:22:48.06,0:22:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anting pertama tidak boleh dilepas\Nselama enam minggu, ya.
Dialogue: 0,0:22:51.22,0:22:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:22:52.85,0:22:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ganti anting, kita pakai bersama, ya.
Dialogue: 0,0:22:56.49,0:22:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:22:57.81,0:23:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita beli minuman keras\Nyang harus ditunggu lebih lama.
Dialogue: 0,0:23:02.49,0:23:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini harus disimpan selama lima tahun.
Dialogue: 0,0:23:05.31,0:23:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja kita nanti\Nsudah tinggal sendiri-sendiri.
Dialogue: 0,0:23:09.25,0:23:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan sendiri-sendiri.
Dialogue: 0,0:23:12.00,0:23:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:13.12,0:23:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita usahakan, Botan.
Dialogue: 0,0:23:18.44,0:23:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku haus.
Dialogue: 0,0:23:22.92,0:23:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum?
