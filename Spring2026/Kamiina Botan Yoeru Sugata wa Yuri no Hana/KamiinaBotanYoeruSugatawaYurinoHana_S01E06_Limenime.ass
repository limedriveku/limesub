Dialogue: 0,0:02:30.67,0:02:34.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa di Taiwan juga ada\Ngua stalaktit, Chang?
Dialogue: 0,0:02:35.01,0:02:36.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya, Kamiina.
Dialogue: 0,0:02:36.76,0:02:40.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, mungkin tidak sebanyak di Jepang.
Dialogue: 0,0:02:40.52,0:02:42.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku belum pernah masuk.
Dialogue: 0,0:02:42.83,0:02:44.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu,\Nini eksplorasi pertamamu, ya?
Dialogue: 0,0:02:44.98,0:02:46.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eksplorasi?
Dialogue: 0,0:02:46.98,0:02:49.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Penjelajahan gua.
Dialogue: 0,0:02:49.23,0:02:51.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini juga pertama kalinya bagimu, Ibuki?
Dialogue: 0,0:02:51.69,0:02:54.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku pernah masuk\Ngua stalaktit besar di Hida.
Dialogue: 0,0:02:54.99,0:02:56.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:02:56.47,0:02:59.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa gua stalaktit itu seram?
Dialogue: 0,0:02:59.28,0:03:02.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Entahlah.\NAku belum pernah masuk.
Dialogue: 0,0:03:02.33,0:03:03.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetap saja,
Dialogue: 0,0:03:03.50,0:03:06.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}kenapa memilih gua Hashidate?
Dialogue: 0,0:03:06.17,0:03:10.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mumpung pergi dengan Chang,\Nbukankah lebih baik ke Kawagoe?
Dialogue: 0,0:03:10.13,0:03:12.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena tempatnya sejuk.
Dialogue: 0,0:03:12.84,0:03:14.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kawagoe terasa panas.
Dialogue: 0,0:03:16.43,0:03:19.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak suka panas.
Dialogue: 0,0:03:19.56,0:03:21.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku suka sejuk-sejuk.
Dialogue: 0,0:03:22.93,0:03:24.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku suka.
Dialogue: 0,0:03:25.04,0:03:26.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Manis.
Dialogue: 0,0:03:42.57,0:03:44.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masuknya lewat sini, ya.
Dialogue: 0,0:03:44.62,0:03:46.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo masuk.
Dialogue: 0,0:03:47.04,0:03:49.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat ini cukup sejuk, ya.
Dialogue: 0,0:03:49.32,0:03:51.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Suara kita bergema.
Dialogue: 0,0:03:53.46,0:03:56.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempatnya licin, hati-hati!
Dialogue: 0,0:04:07.10,0:04:10.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chang, setelah satu minggu,\Nbagaimana rasanya di asrama?
Dialogue: 0,0:04:10.89,0:04:12.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah mulai terbiasa?
Dialogue: 0,0:04:12.84,0:04:13.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:13.77,0:04:16.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.\NSenang mendengarnya.
Dialogue: 0,0:04:20.76,0:04:22.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika ada masalah, bilang saja.
Dialogue: 0,0:04:22.74,0:04:24.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu tunggu masalah, sih.
Dialogue: 0,0:04:25.33,0:04:26.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:28.56,0:04:32.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu dia tidak terlalu\Nlancar berbahasa Jepang,
Dialogue: 0,0:04:32.00,0:04:35.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi apa dia anteng\Nkarena sifatnya kalem?
Dialogue: 0,0:05:09.29,0:05:10.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan?
Dialogue: 0,0:05:12.32,0:05:13.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:05:14.46,0:05:16.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:05:17.71,0:05:18.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah...
Dialogue: 0,0:05:19.17,0:05:21.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah tidak sanggup.
Dialogue: 0,0:05:22.68,0:05:25.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat ini sempit dan gelap.
Dialogue: 0,0:05:25.10,0:05:27.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seram... dingin...
Dialogue: 0,0:05:27.18,0:05:29.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, sangat basah.
Dialogue: 0,0:05:29.64,0:05:33.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Te-Ternyata lebih serius dari dugaanku.
Dialogue: 0,0:05:35.52,0:05:38.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, kalian baik-baik saja?
Dialogue: 0,0:05:38.03,0:05:38.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:05:38.90,0:05:41.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu duluan saja, Ibuki!
Dialogue: 0,0:05:43.07,0:05:44.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:05:45.83,0:05:47.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nah, bisa berdiri?
Dialogue: 0,0:05:48.12,0:05:49.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan.
Dialogue: 0,0:05:53.71,0:05:55.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku gandeng tanganmu, ya.
Dialogue: 0,0:05:58.92,0:06:00.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa penyebutan namanya sudah benar?
Dialogue: 0,0:06:01.34,0:06:04.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namanya Chang Chin-lan, kan?
Dialogue: 0,0:06:23.93,0:06:25.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf sudah menunggu!
Dialogue: 0,0:06:35.33,0:06:38.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aduh, capek banget!
Dialogue: 0,0:06:38.25,0:06:42.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di dalam tadi lebih sejuk,\Ntapi aku keringatan banget.
Dialogue: 0,0:06:42.47,0:06:43.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:43.92,0:06:46.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, Botan, Chang,\Nkalian mau memesan—
Dialogue: 0,0:06:46.89,0:06:48.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Botan!
Dialogue: 0,0:06:49.25,0:06:51.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih. Soal tadi.
Dialogue: 0,0:06:51.73,0:06:56.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak menyangka\Ntempatnya sempit begitu.
Dialogue: 0,0:06:56.81,0:06:59.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku senang. Karena tanganmu.
Dialogue: 0,0:07:12.57,0:07:15.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makanmu lahap sekali, Chang.
Dialogue: 0,0:07:15.44,0:07:17.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku suka "cuò bīng" mangga.
Dialogue: 0,0:07:17.95,0:07:18.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:07:18.96,0:07:20.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cuò bīng.
Dialogue: 0,0:07:20.84,0:07:21.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:07:21.75,0:07:24.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa lagi yang kamu suka, Chin-lan?
Dialogue: 0,0:07:24.80,0:07:26.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:07:28.01,0:07:29.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin minuman keras.
Dialogue: 0,0:07:30.26,0:07:31.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:07:31.22,0:07:33.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berapa umurmu sekarang?
Dialogue: 0,0:07:33.14,0:07:34.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}20 tahun.
Dialogue: 0,0:07:34.56,0:07:38.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di Taiwan,\N18 tahun sudah boleh minum.
Dialogue: 0,0:07:38.15,0:07:42.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, iya, bagaimana\Nkalau kita bertiga minum bareng?
Dialogue: 0,0:07:45.07,0:07:47.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ibuki sedang tidak bisa...
Dialogue: 0,0:07:47.86,0:07:48.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:07:48.95,0:07:52.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana\Nkalau kita berdua saja, Botan?
Dialogue: 0,0:07:57.75,0:07:58.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ikut.
Dialogue: 0,0:08:01.29,0:08:02.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga ikut.
Dialogue: 0,0:08:07.17,0:08:11.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kepalaku terasa seperti\Ndihantam dengan palu besar
Dialogue: 0,0:08:11.35,0:08:14.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan otakku disiram air dingin.
Dialogue: 0,0:08:15.35,0:08:17.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu terjadi saat perayaan festival\Ndi tahun kedua.
Dialogue: 0,0:08:22.96,0:08:25.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, namamu Tonami, kan?
Dialogue: 0,0:08:27.11,0:08:30.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berisik, tahu.\NSuaramu tidak bisa dikecilkan?
Dialogue: 0,0:08:32.24,0:08:36.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari itu, aku minum miras\Nuntuk pertama kalinya.
Dialogue: 0,0:08:36.64,0:08:37.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maafkan aku...
Dialogue: 0,0:08:41.57,0:08:45.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ma... ho... llo... bar.
Dialogue: 0,0:08:46.01,0:08:47.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mahollo?
Dialogue: 0,0:08:47.20,0:08:48.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chang.
Dialogue: 0,0:08:48.22,0:08:50.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau pesan apa?
Dialogue: 0,0:08:50.05,0:08:52.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Silakan, ini menu minumannya.
Dialogue: 0,0:08:52.01,0:08:53.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:08:54.79,0:08:56.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:08:56.14,0:08:58.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Semua ini bir?
Dialogue: 0,0:08:58.60,0:09:01.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yǒuyìsi!
Dialogue: 0,0:09:01.15,0:09:04.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita minum bir Hanakuma ini\Ndi Nagatoro, ya.
Dialogue: 0,0:09:04.69,0:09:08.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, kita juga pernah minum IPA ini.
Dialogue: 0,0:09:08.36,0:09:11.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, benar!\NIni minuman favoritmu.
Dialogue: 0,0:09:11.11,0:09:12.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, mau pesan apa?
Dialogue: 0,0:09:12.66,0:09:14.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, kalau begitu...
Dialogue: 0,0:09:16.80,0:09:18.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cara memilih?
Dialogue: 0,0:09:18.33,0:09:21.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada banyak bir di tempat ini.
Dialogue: 0,0:09:21.54,0:09:23.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana cara memilihnya?
Dialogue: 0,0:09:23.79,0:09:25.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pakai insting?
Dialogue: 0,0:09:25.17,0:09:27.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku pilih berdasarkan nama.
Dialogue: 0,0:09:27.76,0:09:29.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sama saja pakai insting.
Dialogue: 0,0:09:30.80,0:09:34.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pada akhirnya, memang pakai insting, sih.
Dialogue: 0,0:09:34.26,0:09:35.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, ada petunjuknya.
Dialogue: 0,0:09:36.22,0:09:37.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk bir craft,
Dialogue: 0,0:09:37.64,0:09:39.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita bisa memperkirakan rasanya
Dialogue: 0,0:09:39.31,0:09:41.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}dari gaya, tingkat kepahitan,\Ndan kadar alkoholnya.
Dialogue: 0,0:09:41.94,0:09:43.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika sudah mengenal gaya
Dialogue: 0,0:09:43.90,0:09:45.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}yang disukai dari pengalaman,
Dialogue: 0,0:09:45.06,0:09:47.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita lebih mudah memilih bir baru.
Dialogue: 0,0:09:47.36,0:09:48.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:09:48.69,0:09:50.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa orang tuaku juga
Dialogue: 0,0:09:50.04,0:09:52.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}memikirkan gaya saat beli bir, ya?
Dialogue: 0,0:09:53.74,0:09:57.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}adalah bir gaya "Lager".\NKebanyakan bir yang beredar di Jepang
Dialogue: 0,0:09:57.33,0:10:01.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, kamu tidak perlu\Npusing memilih di izakaya.
Dialogue: 0,0:10:01.25,0:10:04.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu hebat, Ibuki.\NBerpengetahuan luas.
Dialogue: 0,0:10:04.54,0:10:05.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf menunggu lama.
Dialogue: 0,0:10:05.88,0:10:09.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuma Misopoteto, Akakuma X ukuran setengah,
Dialogue: 0,0:10:10.13,0:10:11.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan cola.
Dialogue: 0,0:10:11.34,0:10:12.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:12.47,0:10:13.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:10:13.68,0:10:16.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ibuki minum cola!\NBukan minuman keras!
Dialogue: 0,0:10:16.35,0:10:17.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan!
Dialogue: 0,0:10:17.35,0:10:19.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setiap orang kan beda-beda!
Dialogue: 0,0:10:19.60,0:10:20.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti jadi pemaksaan.
Dialogue: 0,0:10:20.98,0:10:23.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin minum minuman keras\Nsama Ibuki!
Dialogue: 0,0:10:30.69,0:10:32.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Repot juga, ya.
Dialogue: 0,0:10:33.12,0:10:35.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu suka minuman keras, kan?
Dialogue: 0,0:10:37.24,0:10:38.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:10:38.99,0:10:41.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}seharusnya tidak datang ke sini.
Dialogue: 0,0:10:42.20,0:10:46.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Botan dan Ibuki\Nsering minum bareng?
Dialogue: 0,0:10:46.13,0:10:48.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku enggak mau minum\Ndengan orang lain selain Botan.
Dialogue: 0,0:10:48.84,0:10:49.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku takut.
Dialogue: 0,0:10:49.67,0:10:51.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Asyik banget.
Dialogue: 0,0:10:51.67,0:10:52.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:10:52.63,0:10:53.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:10:53.55,0:10:58.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}kamu mau minum\Nberdua denganku lain kali?
Dialogue: 0,0:10:58.30,0:10:58.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:59.47,0:11:00.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:11:00.47,0:11:03.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak tahu kenapa,\Ntapi aku lebih tidak suka itu!
Dialogue: 0,0:11:03.77,0:11:04.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan!
Dialogue: 0,0:11:05.31,0:11:06.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku minta birnya!
Dialogue: 0,0:11:06.60,0:11:08.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:11:19.15,0:11:20.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:11:20.37,0:11:23.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata dia benar-benar...
Dialogue: 0,0:11:29.80,0:11:32.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya nikmat sekali, ya.
Dialogue: 0,0:11:32.09,0:11:33.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:11:33.30,0:11:34.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:35.55,0:11:36.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:11:39.01,0:11:42.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, aku mau pesan bir lagi.
Dialogue: 0,0:11:42.89,0:11:46.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dua, ya.\NUntuk aku dan kamu.
Dialogue: 0,0:11:46.52,0:11:49.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, Botan.\NBisa temani aku?
Dialogue: 0,0:11:50.11,0:11:51.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:51.15,0:11:54.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong bawakan birnya.\NAku mau pesan ukuran pint.
Dialogue: 0,0:11:55.74,0:11:57.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hati-hati, ya.
Dialogue: 0,0:12:01.41,0:12:03.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Ibuki.
Dialogue: 0,0:12:03.70,0:12:04.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:04.62,0:12:05.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah.
Dialogue: 0,0:12:05.66,0:12:07.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:12:08.42,0:12:13.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah birnya akan diantar\Nsampai ke meja kita?
Dialogue: 0,0:12:16.55,0:12:17.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Botan.
Dialogue: 0,0:12:19.63,0:12:23.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada penginapan harian\Ndi atas tempat minum ini.
Dialogue: 0,0:12:25.10,0:12:26.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:12:27.81,0:12:29.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}bagaimana kalau kita menginap?
Dialogue: 0,0:12:30.10,0:12:31.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Malam ini.
Dialogue: 0,0:12:48.21,0:12:50.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, capek banget.
Dialogue: 0,0:12:50.42,0:12:52.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku enggak cocok\Nsama acara minum ramai-ramai.
Dialogue: 0,0:12:52.75,0:12:54.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sadar total hari ini.
Dialogue: 0,0:12:54.50,0:12:55.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Emang sebelumnya bagaimana?
Dialogue: 0,0:12:56.57,0:12:58.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menjalaninya sambil memaksa.
Dialogue: 0,0:12:58.67,0:13:00.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memaksakan diri.
Dialogue: 0,0:13:00.51,0:13:03.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Suaraku enggak kedengaran,\Nsuasananya ribut, bikin gelisah.
Dialogue: 0,0:13:03.64,0:13:05.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasanya sesak saja.
Dialogue: 0,0:13:05.97,0:13:08.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa kamu terlalu\Nmemikirkan perasaan orang?
Dialogue: 0,0:13:08.39,0:13:11.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah hari ini cuma\Nacara minum-minum santai?
Dialogue: 0,0:13:11.79,0:13:14.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukannya apa-apa,\Ntapi aku kepikiran terus.
Dialogue: 0,0:13:14.87,0:13:17.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}"Apa semuanya menikmati makanannya?"
Dialogue: 0,0:13:17.32,0:13:19.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}"Apa ada orang yang merasa bosan?"
Dialogue: 0,0:13:20.36,0:13:22.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal bisa dibawa santai saja.
Dialogue: 0,0:13:23.32,0:13:24.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitulah sifatku!
Dialogue: 0,0:13:25.33,0:13:27.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, aku tahu, sih.
Dialogue: 0,0:13:27.83,0:13:30.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu tidak pernah begitu?
Dialogue: 0,0:13:33.13,0:13:37.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku cenderung menyesali\Nbanyak hal setelah minum
Dialogue: 0,0:13:37.09,0:13:38.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}di hari esok.
Dialogue: 0,0:13:38.01,0:13:39.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:39.71,0:13:42.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dulu ada lagu tentang begituan.
Dialogue: 0,0:13:42.09,0:13:45.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menyesal karena kebanyakan minum\Natau ngomong hal yang enggak perlu.
Dialogue: 0,0:13:45.80,0:13:48.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bertingkah bodoh.\NBenar-benar memalukan.
Dialogue: 0,0:13:48.37,0:13:49.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bertingkah bodoh.
Dialogue: 0,0:13:50.10,0:13:51.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memperlihatkan kondisi memalukan.
Dialogue: 0,0:13:51.94,0:13:53.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:13:53.27,0:13:55.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebaiknya kamu lebih hati-hati.
Dialogue: 0,0:13:57.11,0:13:59.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, hari ini aman.
Dialogue: 0,0:13:59.11,0:14:01.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak kebanyakan minum.
Dialogue: 0,0:14:01.15,0:14:02.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada kamu juga.
Dialogue: 0,0:14:03.52,0:14:07.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, aku juga cukup tertolong\Nkarena ada kamu.
Dialogue: 0,0:14:07.66,0:14:10.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memilih teman minum itu\Nmemang cukup penting, ya.
Dialogue: 0,0:14:11.50,0:14:13.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kita bisa saling melengkapi?
Dialogue: 0,0:14:14.58,0:14:15.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:14:18.42,0:14:19.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin lebih asyik
Dialogue: 0,0:14:20.71,0:14:23.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}jika kita bisa bersatu saja.
Dialogue: 0,0:14:28.58,0:14:30.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maksudmu bersatu padu, kan?
Dialogue: 0,0:14:30.93,0:14:32.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar, itu dia.
Dialogue: 0,0:14:32.24,0:14:33.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:14:40.28,0:14:41.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan?
Dialogue: 0,0:14:41.74,0:14:44.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chang.
Dialogue: 0,0:14:48.20,0:14:51.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aduh, sepertinya dia sudah mabuk berat.
Dialogue: 0,0:14:51.37,0:14:53.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia minum cukup banyak, ya.
Dialogue: 0,0:14:53.89,0:14:55.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Botan.
Dialogue: 0,0:14:55.48,0:14:56.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang, yuk.
Dialogue: 0,0:14:57.69,0:14:59.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:05.05,0:15:07.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Chin-lan?
Dialogue: 0,0:15:09.25,0:15:11.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wǒ xiǎng hē shuǐ...
Dialogue: 0,0:15:11.81,0:15:12.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:13.23,0:15:15.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Air...
Dialogue: 0,0:15:17.15,0:15:20.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan, sudah dekat, kok.
Dialogue: 0,0:15:23.64,0:15:25.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:15:28.24,0:15:32.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong tulis nama teman Anda\Ndan tanda tangan di sini.
Dialogue: 0,0:15:32.57,0:15:35.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada tamu lain hari ini.
Dialogue: 0,0:15:35.91,0:15:38.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Silakan menggunakan\Nfasilitas umum sesuka hati.
Dialogue: 0,0:15:38.32,0:15:39.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:15:40.42,0:15:41.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:15:41.88,0:15:44.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku dan Chin-lan ke kamar duluan, ya.
Dialogue: 0,0:15:44.84,0:15:47.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebaiknya dia segera dibaringkan.
Dialogue: 0,0:15:47.24,0:15:48.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:15:48.22,0:15:50.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mau menyimak peraturannya dulu.
Dialogue: 0,0:15:51.16,0:15:54.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini kuncinya.\NKamar nomor 207.
Dialogue: 0,0:15:54.68,0:15:56.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:01.27,0:16:04.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan, kamu bisa berdiri?
Dialogue: 0,0:16:05.74,0:16:07.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:16:07.91,0:16:09.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bersandarlah padaku.
Dialogue: 0,0:16:09.66,0:16:11.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pelan-pelan saja, ya.
Dialogue: 0,0:16:13.16,0:16:15.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita naik tangga, berhati-hatilah.
Dialogue: 0,0:16:15.83,0:16:17.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:28.22,0:16:30.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lepas sepatunya di sini.
Dialogue: 0,0:16:50.82,0:16:54.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata ruang bersama ini cukup luas.
Dialogue: 0,0:16:57.43,0:17:00.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamar 207.
Dialogue: 0,0:17:05.13,0:17:07.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:17:08.13,0:17:11.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak kuat jalan lagi.
Dialogue: 0,0:17:11.26,0:17:13.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan, ini mau kusiapkan!
Dialogue: 0,0:17:13.51,0:17:15.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidurlah di futon!
Dialogue: 0,0:17:25.15,0:17:28.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin dia tidak terlalu kuat\Nminum minuman keras.
Dialogue: 0,0:17:28.78,0:17:30.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untung saja kami menginap.
Dialogue: 0,0:17:34.20,0:17:35.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Awalnya,
Dialogue: 0,0:17:36.08,0:17:41.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}kupikir Ibuki mengajakku\Nmenginap di sini berdua saja.
Dialogue: 0,0:17:41.83,0:17:44.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Situasinya tidak memungkinkan.
Dialogue: 0,0:17:45.00,0:17:47.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal itu sudah sangat jelas.
Dialogue: 0,0:17:49.76,0:17:51.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetap saja...
Dialogue: 0,0:17:56.93,0:17:58.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Chin-lan...
Dialogue: 0,0:17:58.60,0:18:01.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau tidur.\NTerima kasih untuk futon-nya.
Dialogue: 0,0:18:02.31,0:18:03.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana Ibuki?
Dialogue: 0,0:18:03.81,0:18:05.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masih di luar.
Dialogue: 0,0:18:05.69,0:18:08.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga ingin berterima kasih pada Ibuki.
Dialogue: 0,0:18:08.57,0:18:10.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kukatakan besok.
Dialogue: 0,0:18:10.40,0:18:13.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih sudah\Nmau minum bersamaku.
Dialogue: 0,0:18:17.03,0:18:18.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:18:21.85,0:18:25.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baru kali ini\Naku tidur di atas tatami.
Dialogue: 0,0:18:25.00,0:18:28.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aromanya enak.\NSeperti di hutan.
Dialogue: 0,0:18:34.38,0:18:37.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Botan.
Dialogue: 0,0:18:38.01,0:18:39.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu suka Ibuki?
Dialogue: 0,0:18:48.00,0:18:49.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, aku bawa air.
Dialogue: 0,0:18:50.23,0:18:53.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Katanya ada minuman\Ndi kulkas ruang bersama.
Dialogue: 0,0:18:53.20,0:18:55.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boleh diminum, asal bayar.
Dialogue: 0,0:18:56.32,0:18:58.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu sudah tidur, Chang?
Dialogue: 0,0:18:58.37,0:19:01.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada air minum di ruangan sebelah.
Dialogue: 0,0:19:01.55,0:19:04.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu merasa tidak enak badan?
Dialogue: 0,0:19:04.08,0:19:05.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Botan.
Dialogue: 0,0:19:07.29,0:19:08.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Botan?
Dialogue: 0,0:19:11.88,0:19:13.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belum cukup minum.
Dialogue: 0,0:19:15.55,0:19:17.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku masih ingin minum.
Dialogue: 0,0:19:18.55,0:19:20.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bersamamu, Ibuki.
Dialogue: 0,0:19:25.39,0:19:26.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:27.10,0:19:29.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga berpikir begitu.
Dialogue: 0,0:19:37.61,0:19:39.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, sake? Apa ini juga?
Dialogue: 0,0:19:39.99,0:19:43.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya, harganya 500 yen.\NMereka juga jual bir Chichibu.
Dialogue: 0,0:19:43.61,0:19:46.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kita boleh\Nmenggunakan ruangan ini?
Dialogue: 0,0:19:46.51,0:19:47.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Katanya, boleh.
Dialogue: 0,0:19:49.84,0:19:51.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Duduk, yuk.
Dialogue: 0,0:20:07.98,0:20:09.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tambah lagi.
Dialogue: 0,0:20:11.15,0:20:12.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Minumnya cepat sekali.
Dialogue: 0,0:20:15.77,0:20:17.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soalnya enak.
Dialogue: 0,0:20:18.91,0:20:21.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti cepat habis, dong.
Dialogue: 0,0:20:21.49,0:20:23.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, aku minum pelan-pelan.
Dialogue: 0,0:20:26.62,0:20:31.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini, rasanya sudah lama\Naku tidak minum sama orang lain.
Dialogue: 0,0:20:33.04,0:20:35.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah kita selalu minum bersama?
Dialogue: 0,0:20:35.71,0:20:37.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:20:40.36,0:20:43.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu memang benar,\Ntapi ada yang berbeda.
Dialogue: 0,0:20:45.68,0:20:47.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa bedanya?
Dialogue: 0,0:20:48.39,0:20:49.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:20:50.94,0:20:52.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:20:53.19,0:20:55.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu spesial bagiku.
Dialogue: 0,0:20:56.20,0:20:57.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu mengerti itu?
Dialogue: 0,0:21:05.70,0:21:07.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu menyadarinya?
Dialogue: 0,0:21:07.12,0:21:08.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:08.75,0:21:11.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Entah sejak kapan,
Dialogue: 0,0:21:12.54,0:21:14.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}meski tidak ada sodanya,
Dialogue: 0,0:21:14.38,0:21:17.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku selalu sendawa\Nsaat minum minuman keras.
Dialogue: 0,0:21:25.44,0:21:27.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan begini,
Dialogue: 0,0:21:27.35,0:21:30.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita benar-benar sama, ya.
