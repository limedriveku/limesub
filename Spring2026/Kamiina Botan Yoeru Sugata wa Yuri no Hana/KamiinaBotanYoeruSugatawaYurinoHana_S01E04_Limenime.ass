Dialogue: 0,0:01:52.55,0:01:58.01,tanda,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:03:37.28,0:03:39.24,tanda,,0000,0000,0000,,KUIL MITSUMINE
Dialogue: 0,0:04:52.81,0:04:58.78,tanda,,0000,0000,0000,,MINUMAN KERAS LOKAL
Dialogue: 0,0:05:12.83,0:05:15.13,tanda,,0000,0000,0000,,KUIL MITSUMINE
Dialogue: 0,0:05:19.09,0:05:21.18,tanda,,0000,0000,0000,,POHON PENJALIN JODOH
Dialogue: 0,0:05:21.18,0:05:23.55,tanda,,0000,0000,0000,,TIGA MENIT BERJALAN KAKI
Dialogue: 0,0:05:23.55,0:05:26.73,tanda,,0000,0000,0000,,MIRAS ENAK
Dialogue: 0,0:07:00.94,0:07:04.90,tanda,,0000,0000,0000,,TONARI IBUKI, KAMIINA BOTAN
Dialogue: 0,0:08:23.02,0:08:25.48,tanda,,0000,0000,0000,,GUJYO KANADE
Dialogue: 0,0:09:21.77,0:09:22.29,tanda,,0000,0000,0000,,OLIVER SI ANAK KUCING
Dialogue: 0,0:09:26.09,0:09:29.38,tanda,,0000,0000,0000,,OLIVER SI ANAK KUCING
Dialogue: 0,0:10:44.50,0:10:46.96,tanda,,0000,0000,0000,,PERBEDAAN HIGHBALL DAN CHUHAI
Dialogue: 0,0:10:51.21,0:10:55.93,tanda,,0000,0000,0000,,WISKI + AIR SODA = HIGHBALL
Dialogue: 0,0:10:55.93,0:10:57.85,tanda,,0000,0000,0000,,WISKI, SHOCHU/VODKA + AIR SODA =
Dialogue: 0,0:10:57.85,0:11:00.85,tanda,,0000,0000,0000,,"SHOCHU" HIGHBALL
Dialogue: 0,0:11:00.85,0:11:04.14,tanda,,0000,0000,0000,,"SHOCHU" HIGHBALL = CHUHAI
Dialogue: 0,0:14:11.04,0:14:21.05,tanda,,0000,0000,0000,,KAMIINA BOTAN, SOSOK MABUKNYA\NSEINDAH BUNGA LILI
Dialogue: 0,0:16:24.05,0:16:26.01,tanda,,0000,0000,0000,,GUDANG KAMELIA KAWAGOE
Dialogue: 0,0:00:10.49,0:00:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:00:13.48,0:00:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah naik, kan?
Dialogue: 0,0:00:14.87,0:00:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya!\N- Sudah!
Dialogue: 0,0:00:16.29,0:00:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mari kita ke kuil Mitsumine.
Dialogue: 0,0:00:19.17,0:00:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berangkat!
Dialogue: 0,0:00:21.44,0:00:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ahaha, berisik.
Dialogue: 0,0:01:59.36,0:02:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita benar-benar bisa\Nmelihat lautan awan dari kuil?
Dialogue: 0,0:02:03.69,0:02:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:02:05.98,0:02:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa melihat sebagian besar\Nwilayah Chichibu dari sana.
Dialogue: 0,0:02:09.32,0:02:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena wilayahnya cekung.
Dialogue: 0,0:02:11.11,0:02:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini mobil sewaan?
Dialogue: 0,0:02:13.85,0:02:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:02:14.89,0:02:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane meminjamnya dari temannya.
Dialogue: 0,0:02:17.37,0:02:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil ini sudah dimodifikasi,
Dialogue: 0,0:02:18.87,0:02:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}suspensinya jadi keras\Ndan kurang nyaman, ya.
Dialogue: 0,0:02:21.87,0:02:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mual, bilang saja.
Dialogue: 0,0:02:23.96,0:02:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NMasih aman, kok.
Dialogue: 0,0:02:27.04,0:02:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelan-pelan, ya, Mbak Sopir.
Dialogue: 0,0:02:29.59,0:02:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:02:34.13,0:02:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa menyetir\Nmobil manual, ya, Akane?
Dialogue: 0,0:02:38.43,0:02:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipaksa bikin SIM mobil manual\Nsama orang tuaku.
Dialogue: 0,0:02:41.96,0:02:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai pusing karena keluargaku kuno.
Dialogue: 0,0:02:44.81,0:02:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:02:46.11,0:02:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu keren.
Dialogue: 0,0:02:48.56,0:02:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:02:50.07,0:02:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kamu keren bisa menyetir manual.
Dialogue: 0,0:02:54.07,0:02:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:02:57.17,0:02:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stop.
Dialogue: 0,0:02:58.83,0:03:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti! Ganti sopir!
Dialogue: 0,0:03:05.35,0:03:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa kamu punya SIM, Kak Gujyo?
Dialogue: 0,0:03:09.96,0:03:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bikin di tahun pertama!
Dialogue: 0,0:03:13.13,0:03:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saksikanlah!\NKemampuan mengemudiku yang hebat!
Dialogue: 0,0:03:16.51,0:03:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama kamu, Ibuki!
Dialogue: 0,0:03:22.14,0:03:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, kenapa, nih?\NAku merusaknya?
Dialogue: 0,0:03:25.31,0:03:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo, mesinnya cuma mati.
Dialogue: 0,0:03:28.31,0:03:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kopling dulu dan injak remnya.
Dialogue: 0,0:03:32.32,0:03:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku menyerah.
Dialogue: 0,0:03:34.57,0:03:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sih maunya?
Dialogue: 0,0:03:39.24,0:03:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini Kuil Mitsumine, ya?
Dialogue: 0,0:03:42.03,0:03:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya lautan awan bisa dilihat
Dialogue: 0,0:03:44.00,0:03:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari aula pemujaan Okumiya,\Ndan bukan dari aula utama.
Dialogue: 0,0:03:46.75,0:03:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana arahnya?
Dialogue: 0,0:03:49.46,0:03:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar.\NAula pemujaannya di mana, ya?
Dialogue: 0,0:03:53.13,0:03:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, serius dikit, dong.
Dialogue: 0,0:03:55.92,0:03:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa berlawanan dengan aula utama, ya?
Dialogue: 0,0:04:05.37,0:04:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki!
Dialogue: 0,0:04:06.98,0:04:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ke situ, lo.
Dialogue: 0,0:04:12.40,0:04:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku dipanggil.
Dialogue: 0,0:04:15.21,0:04:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipanggil siapa? Dewa?
Dialogue: 0,0:04:17.20,0:04:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sebentar, kok.
Dialogue: 0,0:04:20.70,0:04:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:04:26.04,0:04:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:04:27.37,0:04:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Kamiina tidak ada.
Dialogue: 0,0:04:29.87,0:04:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Asrama juga.
Dialogue: 0,0:04:31.17,0:04:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua hilang lagi.
Dialogue: 0,0:04:33.71,0:04:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar, deh.
Dialogue: 0,0:04:35.59,0:04:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi duluan!
Dialogue: 0,0:04:41.37,0:04:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:04:44.01,0:04:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:04:48.74,0:04:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku melihatnya.
Dialogue: 0,0:04:51.19,0:04:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku melihatnya.
Dialogue: 0,0:04:53.31,0:04:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada toko minuman keras di kawasan kuil.
Dialogue: 0,0:04:55.98,0:04:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Info internet memang benar.
Dialogue: 0,0:04:59.45,0:05:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki! Kamu terlalu cepat!
Dialogue: 0,0:05:04.24,0:05:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kembali.
Dialogue: 0,0:05:06.08,0:05:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli sake, nih.
Dialogue: 0,0:05:07.54,0:05:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:08.75,0:05:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan minum di sini, ya.
Dialogue: 0,0:05:11.04,0:05:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:05:13.25,0:05:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuil ini sangat hebat.
Dialogue: 0,0:05:15.13,0:05:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menjual wiski hasil kolaborasi\Ndengan tempat penyulingan luar negeri.
Dialogue: 0,0:05:19.09,0:05:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga beli itu?
Dialogue: 0,0:05:21.18,0:05:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin beli, tapi...
Dialogue: 0,0:05:23.55,0:05:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seserahannya tidak cukup.
Dialogue: 0,0:05:29.44,0:05:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuilnya luas banget, ya.
Dialogue: 0,0:05:33.89,0:05:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu buat apa, ya?
Dialogue: 0,0:05:38.40,0:05:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kertas apa itu?
Dialogue: 0,0:05:41.40,0:05:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mempersembahkan kertas
Dialogue: 0,0:05:42.61,0:05:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertuliskan nama dua orang\Nyang ingin berjodoh,
Dialogue: 0,0:05:46.20,0:05:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}konon mereka akan berjodoh.
Dialogue: 0,0:05:51.55,0:05:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sering ada di kuil, ya.
Dialogue: 0,0:05:56.34,0:05:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku dapat pesan\Ndari Akane dan teman-teman.
Dialogue: 0,0:06:00.10,0:06:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya mereka di aula pemujaan.
Dialogue: 0,0:06:04.47,0:06:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa aku boleh menulisnya?
Dialogue: 0,0:06:08.32,0:06:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Apa?
Dialogue: 0,0:06:13.13,0:06:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu, Ibuki.
Dialogue: 0,0:06:21.44,0:06:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, kalau tidak keberatan,\Napa kamu juga mau menulisnya?
Dialogue: 0,0:06:30.04,0:06:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kamiina Botan".
Dialogue: 0,0:06:56.00,0:07:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepulang dari sini,\Nayo kita minum sake itu.
Dialogue: 0,0:07:01.37,0:07:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama.
Dialogue: 0,0:07:11.33,0:07:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip lautan awan.
Dialogue: 0,0:07:27.80,0:07:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki dan Kamiina tidak ke sini, ya.
Dialogue: 0,0:07:30.85,0:07:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:37.60,0:07:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke toilet sebentar.
Dialogue: 0,0:08:02.09,0:08:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cucianku!
Dialogue: 0,0:08:04.67,0:08:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:08:06.63,0:08:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:08:08.91,0:08:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:08:10.05,0:08:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengambil cucianmu.\NMaaf karena lancang, sih.
Dialogue: 0,0:08:14.22,0:08:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak lancang, kok.
Dialogue: 0,0:08:16.23,0:08:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih—
Dialogue: 0,0:08:19.69,0:08:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat masuk sini!\NNanti masuk angin.
Dialogue: 0,0:08:25.48,0:08:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.\NAku sampai meminjam bajumu.
Dialogue: 0,0:08:29.20,0:08:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja.
Dialogue: 0,0:08:34.90,0:08:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutku sudah kering.
Dialogue: 0,0:08:38.87,0:08:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secepat ini?\NJangan bohong!
Dialogue: 0,0:08:42.33,0:08:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut lebat begini\Ntidak mungkin cepat kering.
Dialogue: 0,0:08:45.36,0:08:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:08:47.53,0:08:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga menjemur semua handukmu, kan?
Dialogue: 0,0:08:50.22,0:08:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kupinjamkan, tenang saja.
Dialogue: 0,0:08:52.65,0:08:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:09:01.65,0:09:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu konsol gim.\NJadul banget, sih.
Dialogue: 0,0:09:06.25,0:09:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mirip mainan, ya.
Dialogue: 0,0:09:08.86,0:09:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut, kan?
Dialogue: 0,0:09:10.61,0:09:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin main\Nsetelah nonton video gameplay,
Dialogue: 0,0:09:13.24,0:09:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku membelinya,
Dialogue: 0,0:09:15.33,0:09:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi progresku macet\Nkarena tidak becus main.
Dialogue: 0,0:09:18.79,0:09:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gim lama itu susah-susah, ya.
Dialogue: 0,0:09:22.61,0:09:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita main bersama?
Dialogue: 0,0:09:26.09,0:09:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ini bisa dimainkan dua orang.
Dialogue: 0,0:09:30.01,0:09:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita kerja sama,\Ngimnya pasti tamat.
Dialogue: 0,0:09:36.58,0:09:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:09:40.18,0:09:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu sering main gim?
Dialogue: 0,0:09:42.98,0:09:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering main gim teka-teki.
Dialogue: 0,0:09:45.65,0:09:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah? Aku jatuh!
Dialogue: 0,0:09:47.86,0:09:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.\NKita dapat sanksi.
Dialogue: 0,0:09:50.61,0:09:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada begituan, kok.
Dialogue: 0,0:09:52.95,0:09:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, ini memang tidak bisa\Ndianggap hukuman,
Dialogue: 0,0:09:59.54,0:10:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku cukup kesusahan\Nkarena sendiri.
Dialogue: 0,0:10:02.86,0:10:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menghabiskan minuman ini.
Dialogue: 0,0:10:05.84,0:10:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman keras!
Dialogue: 0,0:10:07.07,0:10:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kebagian sisa minuman dari pesta...
Dialogue: 0,0:10:09.80,0:10:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya terlalu banyak, ya?
Dialogue: 0,0:10:11.99,0:10:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:13.80,0:10:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasih saja ke Ibuki.
Dialogue: 0,0:10:16.05,0:10:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah berpikir begitu,
Dialogue: 0,0:10:18.01,0:10:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sepertinya Ibuki tidak minum\Nmiras toserba seperti ini.
Dialogue: 0,0:10:24.19,0:10:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham maksudmu.
Dialogue: 0,0:10:26.29,0:10:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kita lanjutkan saja dengan santai\Nsambil minum.
Dialogue: 0,0:10:30.73,0:10:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini highball, ya?
Dialogue: 0,0:10:33.92,0:10:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:10:35.20,0:10:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini chuhai.
Dialogue: 0,0:10:38.28,0:10:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bedanya highball dan chuhai?
Dialogue: 0,0:10:47.49,0:10:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, highball adalah variasi koktail.
Dialogue: 0,0:10:51.21,0:10:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sederhananya, highball adalah
Dialogue: 0,0:10:53.08,0:10:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}koktail dari wiski dicampur air soda.
Dialogue: 0,0:10:55.93,0:10:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, shochu atau vodka
Dialogue: 0,0:10:57.85,0:10:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dicampur air soda
Dialogue: 0,0:10:59.38,0:11:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga termasuk highball.
Dialogue: 0,0:11:00.85,0:11:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Shochu" highball disingkat jadi "chuhai", ya?
Dialogue: 0,0:11:04.14,0:11:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bakal keluar dalam ujian, lo.
Dialogue: 0,0:11:08.02,0:11:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis ini...
Dialogue: 0,0:11:09.65,0:11:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip Ibuki, ya?
Dialogue: 0,0:11:12.07,0:11:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:14.49,0:11:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita minum chuhai-nya.
Dialogue: 0,0:11:19.41,0:11:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa lemonnya ramah di mulut, ya.
Dialogue: 0,0:11:23.02,0:11:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina, musuhnya ke arahmu!
Dialogue: 0,0:11:24.79,0:11:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, tidak, tidak!
Dialogue: 0,0:11:26.87,0:11:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Aku bisa mati!
Dialogue: 0,0:11:28.63,0:11:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja!\NNempel saja ke aku!
Dialogue: 0,0:11:31.21,0:11:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:11:31.84,0:11:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aku, tapi karakternya!
Dialogue: 0,0:11:34.81,0:11:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, begitu, ya.
Dialogue: 0,0:11:36.34,0:11:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamiina, di depan!
Dialogue: 0,0:11:38.01,0:11:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:11:38.97,0:11:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget.\NJantungku mau copot.
Dialogue: 0,0:11:43.11,0:11:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nempel...
Dialogue: 0,0:11:44.93,0:11:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku sehat lagi setelah\Nciuman sama Kak Gujyo!
Dialogue: 0,0:11:48.60,0:11:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meneriakkan kalimat\Nyang bikin salah paham!
Dialogue: 0,0:11:53.44,0:11:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita ciuman, tuh.
Dialogue: 0,0:11:56.24,0:11:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:11:57.28,0:12:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, nyawaku habis!\NAku minta cium!
Dialogue: 0,0:12:00.62,0:12:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tuh, ya.
Dialogue: 0,0:12:09.44,0:12:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya jadi pengin main\Nsama teman-teman, ya.
Dialogue: 0,0:12:13.36,0:12:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa minum miras\Ndan ciuman dalam gim...
Dialogue: 0,0:12:16.33,0:12:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:19.84,0:12:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mengajak Ibuki.
Dialogue: 0,0:12:22.85,0:12:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihat Ibuki\Nminum miras lagi.
Dialogue: 0,0:12:27.35,0:12:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu pernah melihatnya?
Dialogue: 0,0:12:30.23,0:12:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:33.07,0:12:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah melihatnya sekali.
Dialogue: 0,0:12:35.78,0:12:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sebuah bar dekat kampus.
Dialogue: 0,0:12:40.39,0:12:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melihatnya, entah kenapa,
Dialogue: 0,0:12:44.95,0:12:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa iri.
Dialogue: 0,0:12:49.62,0:12:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata sama.
Dialogue: 0,0:12:51.94,0:12:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertiku.
Dialogue: 0,0:12:53.17,0:12:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:54.42,0:12:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Kak Gujyo...\Njuga merasa seperti itu, ya?
Dialogue: 0,0:13:00.88,0:13:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin
Dialogue: 0,0:13:03.22,0:13:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo bisa menikmati\Nminuman keras bersama Ibuki.
Dialogue: 0,0:13:15.94,0:13:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari nanti... aku akan...
Dialogue: 0,0:13:29.71,0:13:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa, sih?
Dialogue: 0,0:13:31.39,0:13:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu selalu memonopoli\Ndan minum sama Ibuki sendiri.
Dialogue: 0,0:13:42.25,0:13:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gujyo!
Dialogue: 0,0:13:44.01,0:13:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu pemilik selimut futon\Nyang dijemur di bawah itu?
Dialogue: 0,0:13:49.98,0:13:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masuk, ya.
Dialogue: 0,0:13:54.73,0:13:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa begini?
Dialogue: 0,0:14:28.60,0:14:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan musim hujan akan berakhir, ya?
Dialogue: 0,0:14:31.79,0:14:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru akan memasuki puncaknya, kan?
Dialogue: 0,0:14:35.63,0:14:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin lesu saja, ya.
Dialogue: 0,0:14:38.69,0:14:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang juga begitu, kan?
Dialogue: 0,0:14:40.94,0:14:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki!
Dialogue: 0,0:14:45.43,0:14:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada satu anomali.
Dialogue: 0,0:14:50.12,0:14:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udaranya terasa lembap hari ini.
Dialogue: 0,0:14:52.79,0:14:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:54.25,0:14:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:14:55.08,0:14:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cat kukumu imut sekali, Kak Yusa.
Dialogue: 0,0:14:58.50,0:15:00.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, terima kasih.
Dialogue: 0,0:15:00.38,0:15:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oranye adalah warna yang cocok\Ndengan musim panas.
Dialogue: 0,0:15:03.55,0:15:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasana hati jadi segar saat melihatnya.
Dialogue: 0,0:15:07.05,0:15:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau.
Dialogue: 0,0:15:08.68,0:15:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasana hati memang penting,
Dialogue: 0,0:15:10.93,0:15:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bagaimana kalau kita pergi\Nke tempat bagus yang segar?
Dialogue: 0,0:15:15.74,0:15:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tempat bagus?
Dialogue: 0,0:15:18.31,0:15:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:15:19.77,0:15:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Koedo!
Dialogue: 0,0:15:22.32,0:15:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, Kawagoe terkenal\Ndengan camilan, kan?
Dialogue: 0,0:15:26.28,0:15:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Gang Permen, kan?
Dialogue: 0,0:15:28.99,0:15:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya tariknya bukan cuma camilan!
Dialogue: 0,0:15:31.41,0:15:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawagoe adalah kota kuliner,\Njadi ada banyak makanan enak di sini.
Dialogue: 0,0:15:36.00,0:15:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap Akane bisa ikut.
Dialogue: 0,0:15:39.33,0:15:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja si Akane.
Dialogue: 0,0:15:42.87,0:15:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baginya, latihan band\Njauh lebih penting dari kita.
Dialogue: 0,0:15:50.64,0:15:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lonceng waktu.
Dialogue: 0,0:15:52.31,0:15:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simbol Kawagoe.
Dialogue: 0,0:15:55.50,0:15:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang yang pakai yukata!
Dialogue: 0,0:15:57.48,0:16:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pakai yukata di festival\Nmusim panas Hyakumantou di bulan Juli!
Dialogue: 0,0:16:01.98,0:16:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival?
Dialogue: 0,0:16:03.15,0:16:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:05.03,0:16:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:16:07.74,0:16:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yukata bisa menambah pesona, ya?
Dialogue: 0,0:16:13.62,0:16:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesona kota ini.
Dialogue: 0,0:16:20.83,0:16:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua!
Dialogue: 0,0:16:26.34,0:16:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sampai di tempat tujuan!
Dialogue: 0,0:16:29.47,0:16:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini...
Dialogue: 0,0:16:30.93,0:16:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko pernak-pernik?
Dialogue: 0,0:16:36.60,0:16:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ke dalam.
Dialogue: 0,0:16:38.83,0:16:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ke dalam?
Dialogue: 0,0:16:42.11,0:16:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Enak banget!
Dialogue: 0,0:16:45.94,0:16:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini juga ada kafe rendam kaki.
Dialogue: 0,0:16:48.74,0:16:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa saja menunya?
Dialogue: 0,0:16:50.95,0:16:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona-Nona.
Dialogue: 0,0:16:52.20,0:16:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan birnya.
Dialogue: 0,0:16:54.53,0:16:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bir? Aku tidak pesan.
Dialogue: 0,0:16:57.25,0:16:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang pesan.
Dialogue: 0,0:16:59.29,0:17:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu kamu ingin minum.
Dialogue: 0,0:17:02.67,0:17:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Bir Coedo, ya?
Dialogue: 0,0:17:05.50,0:17:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, produsennya di Kawagoe.
Dialogue: 0,0:17:08.76,0:17:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, terima kasih.
Dialogue: 0,0:17:11.26,0:17:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pesan teh genmaicha untuk kita.
Dialogue: 0,0:17:14.76,0:17:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan diminum selagi dingin.
Dialogue: 0,0:17:17.42,0:17:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyiksaan...
Dialogue: 0,0:17:22.56,0:17:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cangkir tembaga.
Dialogue: 0,0:17:24.81,0:17:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang ada cangkir tembaga untuk bir.
Dialogue: 0,0:17:27.73,0:17:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini boleh juga.
Dialogue: 0,0:17:29.95,0:17:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti modernisasi era Taisho.
Dialogue: 0,0:17:32.70,0:17:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Modernisasi era Taisho.
Dialogue: 0,0:17:34.89,0:17:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu seperti\Npemandangan di Koedo tadi?
Dialogue: 0,0:17:38.37,0:17:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:49.12,0:17:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini... lonceng waktu?
Dialogue: 0,0:17:52.63,0:17:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,
Dialogue: 0,0:17:54.05,0:17:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kelembapan musim hujan\Njadi tidak berasa, ya.
Dialogue: 0,0:17:56.76,0:17:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:58.56,0:18:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaeka, terima kasih\Nsudah mengajak kami ke sini.
Dialogue: 0,0:18:01.60,0:18:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua...
Dialogue: 0,0:18:04.23,0:18:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama...\Nterima kasih kembali.
Dialogue: 0,0:18:10.13,0:18:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:18:11.99,0:18:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf.
Dialogue: 0,0:18:14.16,0:18:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang karena bisa ke sini\Nbersama orang-orang kaya rasa.
Dialogue: 0,0:18:19.35,0:18:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Akane cuma bisa\Nmembahas makanan terus.
Dialogue: 0,0:18:23.87,0:18:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bukankah itu\Ntidak terlalu menyedihkan?
Dialogue: 0,0:18:28.24,0:18:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sedih, kok.
Dialogue: 0,0:18:30.59,0:18:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku lecet saat naik gunung\Nbersama Akane tempo hari.
Dialogue: 0,0:18:34.96,0:18:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya perih.
Dialogue: 0,0:18:37.43,0:18:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:39.06,0:18:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya dikasih plester luka.
Dialogue: 0,0:18:41.73,0:18:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan aku tidak punya.\NNanti aku beli di dekat sini.
Dialogue: 0,0:18:45.94,0:18:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik gunung sepertinya asyik.
Dialogue: 0,0:18:48.22,0:18:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, apa kamu tertarik, Botan?
Dialogue: 0,0:18:50.44,0:18:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi bareng, yuk!
Dialogue: 0,0:18:52.03,0:18:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, kami berencana\Nnaik Gunung Buko di Chichibu.
Dialogue: 0,0:18:55.07,0:18:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua anak asrama harus ikut!
Dialogue: 0,0:18:56.76,0:18:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Semuanya?
Dialogue: 0,0:18:59.74,0:19:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kitamori.
Dialogue: 0,0:19:01.29,0:19:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, Botan?
Dialogue: 0,0:19:03.25,0:19:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakimu itu...
Dialogue: 0,0:19:05.71,0:19:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna cat kukunya sama seperti Kak Yusa.
Dialogue: 0,0:19:10.13,0:19:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar.
Dialogue: 0,0:19:12.26,0:19:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia...
Dialogue: 0,0:19:13.72,0:19:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia suka cat kuku\Nyang kupakai,
Dialogue: 0,0:19:16.93,0:19:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi dia mengecat kukunya.
Dialogue: 0,0:19:19.14,0:19:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi pengin.\NMungkin aku beli warna itu juga.
Dialogue: 0,0:19:22.64,0:19:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan!
Dialogue: 0,0:19:30.38,0:19:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bukan begitu...
Dialogue: 0,0:19:33.40,0:19:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud melarang.
Dialogue: 0,0:19:36.86,0:19:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, benar juga.
Dialogue: 0,0:19:40.25,0:19:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya warna lain\Ndari merek yang sama.
Dialogue: 0,0:19:43.79,0:19:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tertarik, coba saja.
Dialogue: 0,0:19:46.79,0:19:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli plester luka dulu, ya.
Dialogue: 0,0:19:54.51,0:19:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pergi.
Dialogue: 0,0:19:56.43,0:19:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:59.22,0:20:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki, ini kesempatan minum, lo.
Dialogue: 0,0:20:02.19,0:20:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar.
Dialogue: 0,0:20:14.32,0:20:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uenak!
Dialogue: 0,0:20:17.70,0:20:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:20:19.03,0:20:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:20.95,0:20:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku menyinggung\Nperasaan Kak Kitamori?
Dialogue: 0,0:20:30.29,0:20:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu tidak salah.
Dialogue: 0,0:20:33.92,0:20:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu adalah warna\Nyang sangat berharga bagi Yaeka.
Dialogue: 0,0:20:39.52,0:20:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking berharganya,\Nsampai tidak boleh disentuh orang.
Dialogue: 0,0:20:45.64,0:20:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna yang sangat berharga...
Dialogue: 0,0:20:50.48,0:20:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu juga punya warna berharga?
Dialogue: 0,0:20:55.05,0:20:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:21:01.07,0:21:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mau mengecatnya?
Dialogue: 0,0:21:03.20,0:21:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:08.46,0:21:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan cat kuku itu...
Dialogue: 0,0:21:10.83,0:21:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mau mengecat kukuku?
Dialogue: 0,0:21:16.72,0:21:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.\NMau di bagian mana?
Dialogue: 0,0:21:21.54,0:21:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di bagian yang sama.
Dialogue: 0,0:21:26.06,0:21:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Denganmu, Ibuki.
Dialogue: 0,0:21:27.72,0:21:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga, nih?
Dialogue: 0,0:21:37.19,0:21:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, belepotan.
Dialogue: 0,0:21:53.21,0:21:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cantiknya.
Dialogue: 0,0:22:00.65,0:22:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:22:04.22,0:22:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini warna yang berharga, ya.
Dialogue: 0,0:22:11.94,0:22:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
