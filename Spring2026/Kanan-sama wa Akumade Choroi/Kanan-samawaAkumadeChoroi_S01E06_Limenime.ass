Dialogue: 0,0:02:51.19,0:02:55.02,tanda,,0000,0000,0000,,#06 BOLOS PERTAMA KANAN
Dialogue: 0,0:02:56.03,0:02:58.03,tanda,,0000,0000,0000,,RUANG KOMITE DISIPLIN
Dialogue: 0,0:07:00.98,0:07:05.98,tanda,,0000,0000,0000,,TAKAKIYO
Dialogue: 0,0:11:17.57,0:11:18.82,tanda,,0000,0000,0000,,HARI INI SENIOR PAKAI BRA, YA?
Dialogue: 0,0:11:18.82,0:11:22.03,tanda,,0000,0000,0000,,AKU SELALU PAKAI, KOK!\NEH, KAU MELIHAT KE MANA, SIH?
Dialogue: 0,0:11:58.82,0:11:59.53,tanda,,0000,0000,0000,,BAHAGIA SETIAP HARI\NOISHII BOU
Dialogue: 0,0:13:17.44,0:13:19.94,tanda,,0000,0000,0000,,KAFE INTERNET
Dialogue: 0,0:14:55.78,0:15:01.03,tanda,,0000,0000,0000,,3,141592653589793...
Dialogue: 0,0:00:00.33,0:00:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi!
Dialogue: 0,0:00:03.81,0:00:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi!
Dialogue: 0,0:00:06.68,0:00:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeanne.
Dialogue: 0,0:00:08.40,0:00:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Idih, si Santa Mesum.
Dialogue: 0,0:00:13.32,0:00:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi!
Dialogue: 0,0:00:16.28,0:00:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau pakai baju apa?
Dialogue: 0,0:00:17.90,0:00:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa masuk sekolah pakai seragam pelaut?
Dialogue: 0,0:00:21.01,0:00:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:00:22.53,0:00:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan tidak tahu, ya?
Dialogue: 0,0:00:24.99,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:00:26.04,0:00:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau sekolah, harus pakai seragam.
Dialogue: 0,0:00:29.61,0:00:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku tahu.
Dialogue: 0,0:00:31.09,0:00:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kau berpikir\Nselama masih seragam, apa saja boleh.
Dialogue: 0,0:00:33.89,0:00:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seragam pelaut, imutnya.
Dialogue: 0,0:00:36.51,0:00:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin mata segar.
Dialogue: 0,0:00:37.92,0:00:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:00:40.12,0:00:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, aku cocok pakai ini?
Dialogue: 0,0:00:41.94,0:00:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu?
Dialogue: 0,0:00:44.15,0:00:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Keren.
Dialogue: 0,0:00:46.19,0:00:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa semua manusia suka seragam pelaut?
Dialogue: 0,0:00:49.97,0:00:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kami suka.\NManusia?
Dialogue: 0,0:00:52.60,0:00:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk Inferior ini...
Dialogue: 0,0:00:54.85,0:00:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau malah terpesona\Ndengan seragam pelaut?
Dialogue: 0,0:00:58.44,0:01:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm... Oh, begitu.
Dialogue: 0,0:01:00.63,0:01:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternak tukang selingkuh sepertinya\Nharus dikasih pelajaran.
Dialogue: 0,0:01:11.98,0:01:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapkan dirimu.
Dialogue: 0,0:01:13.85,0:01:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperlihatkan betapa\Nmengerikannya bangsa iblis.
Dialogue: 0,0:03:00.88,0:03:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapanku sudah sempurna.
Dialogue: 0,0:03:03.47,0:03:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah betapa mengerikannya bangsa iblis.
Dialogue: 0,0:03:07.05,0:03:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubuat kau paham akibatnya.
Dialogue: 0,0:03:12.31,0:03:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:13.44,0:03:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku agak malu\Nkalau perlihatkan ini pada Kyougi.
Dialogue: 0,0:03:18.42,0:03:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:03:21.45,0:03:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:03:23.03,0:03:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?\NSetidaknya, ketuk pintu dulu!
Dialogue: 0,0:03:25.93,0:03:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Senior, ke-kenapa pakai seragam pelaut?
Dialogue: 0,0:03:30.85,0:03:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tunggu sebentar!
Dialogue: 0,0:03:32.29,0:03:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum siap mental!
Dialogue: 0,0:03:33.81,0:03:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Mengapa? Ada apa gerangan?!
Dialogue: 0,0:03:35.88,0:03:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:03:38.03,0:03:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Youji?
Dialogue: 0,0:03:38.95,0:03:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, di mana kau?
Dialogue: 0,0:03:43.64,0:03:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali yang datang...!
Dialogue: 0,0:03:45.44,0:03:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau si Santa Mesum itu\Nmelihatku pakai seragam ini...
Dialogue: 0,0:03:49.02,0:03:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia meniruku!
Dialogue: 0,0:03:50.88,0:03:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis itu plagiat aku!
Dialogue: 0,0:03:53.12,0:03:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau tukang tiru!
Dialogue: 0,0:03:55.21,0:03:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa, kenapa, kenapa, kenapa?\N- Kalau sudah seperti ini...
Dialogue: 0,0:03:57.49,0:03:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi!
Dialogue: 0,0:03:58.36,0:03:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:58.94,0:04:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi?
Dialogue: 0,0:04:00.74,0:04:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:04:02.97,0:04:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada siapa-siapa.
Dialogue: 0,0:04:05.81,0:04:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aneh.
Dialogue: 0,0:04:07.30,0:04:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku yakin dia ada di sini.
Dialogue: 0,0:04:09.45,0:04:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus...
Dialogue: 0,0:04:11.55,0:04:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, ya.
Dialogue: 0,0:04:12.87,0:04:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku mencium bau Kyougi.
Dialogue: 0,0:04:17.24,0:04:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:04:18.33,0:04:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shh! Nanti kita ketahuan.
Dialogue: 0,0:04:21.33,0:04:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tubuhku menempel ke tubuh Senior.
Dialogue: 0,0:04:24.46,0:04:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}D-Di ruangan-ngin-ngan se-sempit-pit,\Nme-menempel Se-Senio-nio-nior.
Dialogue: 0,0:04:29.02,0:04:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak, jangan nafsu juga!
Dialogue: 0,0:04:32.19,0:04:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak bisa, Senior.
Dialogue: 0,0:04:34.33,0:04:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku menempel ke tubuh Senior\Nyang imut karena seragam pelaut.
Dialogue: 0,0:04:40.08,0:04:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Imut?
Dialogue: 0,0:04:42.59,0:04:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...\NSepertinya aku mencium baunya dari sini.
Dialogue: 0,0:04:47.65,0:04:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus.
Dialogue: 0,0:04:48.77,0:04:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus, endus.
Dialogue: 0,0:04:51.25,0:04:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:04:52.61,0:04:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Loker ini mencurigakan!
Dialogue: 0,0:05:03.74,0:05:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau Kyougi...
Dialogue: 0,0:05:11.51,0:05:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bungkus Oishii Bou yang jatuh.
Dialogue: 0,0:05:13.95,0:05:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:14.75,0:05:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubuang ke tempat sampah.
Dialogue: 0,0:05:16.37,0:05:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau jilat dulu, jangan dibuang!
Dialogue: 0,0:05:21.44,0:05:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Senior...
Dialogue: 0,0:05:23.27,0:05:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Senior pakai seragam pelaut\Nsampai sembunyi segala?
Dialogue: 0,0:05:26.98,0:05:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:27.71,0:05:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu karena...
Dialogue: 0,0:05:30.30,0:05:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malu kalau ada orang lain yang lihat,
Dialogue: 0,0:05:33.54,0:05:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu kupikir...
Dialogue: 0,0:05:35.74,0:05:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi mungkin suka.
Dialogue: 0,0:05:42.93,0:05:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A... Aku suka.
Dialogue: 0,0:05:45.58,0:05:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:05:48.04,0:05:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka yang kau maksud itu ba-bajunya, 'kan?
Dialogue: 0,0:05:54.73,0:05:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Atau...
Dialogue: 0,0:05:58.62,0:05:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat.
Dialogue: 0,0:06:00.21,0:06:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:06:02.21,0:06:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, gawat.
Dialogue: 0,0:06:04.55,0:06:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat, gawat, gawat...!
Dialogue: 0,0:06:08.89,0:06:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasana macam apa ini?
Dialogue: 0,0:06:12.38,0:06:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak, ini gawat banget!
Dialogue: 0,0:06:19.22,0:06:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak diangkat.
Dialogue: 0,0:06:25.79,0:06:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sedang buat anak!
Dialogue: 0,0:06:28.45,0:06:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:06:29.77,0:06:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Buat anak?
Dialogue: 0,0:06:30.94,0:06:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, itu sungguhan?!
Dialogue: 0,0:06:32.37,0:06:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua juga sedang apa di sana?!
Dialogue: 0,0:06:34.30,0:06:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku deg-degan!
Dialogue: 0,0:06:43.89,0:06:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara kejadian kemarin,
Dialogue: 0,0:06:45.89,0:06:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi tidak tahu harus menemui Kyougi\Ndengan ekspresi apa.
Dialogue: 0,0:06:52.00,0:06:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, kau bisa terlambat, lo.
Dialogue: 0,0:07:09.06,0:07:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:07:13.17,0:07:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berangkat bareng, yuk.
Dialogue: 0,0:07:28.14,0:07:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerbongnya penuh, ya.
Dialogue: 0,0:07:30.06,0:07:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:07:41.40,0:07:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:07:43.77,0:07:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan, kenapa kau salting?
Dialogue: 0,0:07:46.17,0:07:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengikat kontrak kekasih dengan Kyougi,
Dialogue: 0,0:07:48.65,0:07:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal seperti ini bukan apa-apa...
Dialogue: 0,0:07:57.07,0:07:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:07:59.37,0:08:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita lanjut ke tempat lain?
Dialogue: 0,0:08:02.14,0:08:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:12.11,0:08:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laut!
Dialogue: 0,0:08:13.19,0:08:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luas sekali!
Dialogue: 0,0:08:15.62,0:08:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku pergi melihat laut.
Dialogue: 0,0:08:18.23,0:08:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya dingin dan nyaman.
Dialogue: 0,0:08:24.73,0:08:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, ada apa?
Dialogue: 0,0:08:28.35,0:08:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau\Nsampai membuatku bolos sekolah.
Dialogue: 0,0:08:31.66,0:08:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau terlihat seperti ini,\Naku siswi teladan, lo.
Dialogue: 0,0:08:36.25,0:08:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, ternyata kau nakal juga, ya.
Dialogue: 0,0:08:41.96,0:08:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malu-malu karena itu?
Dialogue: 0,0:08:44.77,0:08:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:08:46.05,0:08:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rencanakan\Nsampai membawaku ke sini?
Dialogue: 0,0:08:50.10,0:08:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana apa?
Dialogue: 0,0:08:51.90,0:08:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin lakukan sesuatu\Nyang bisa dikenang bersama Senior.
Dialogue: 0,0:08:58.50,0:09:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang bisa dikenang?
Dialogue: 0,0:09:01.42,0:09:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berduaan.
Dialogue: 0,0:09:02.74,0:09:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pengganggu.
Dialogue: 0,0:09:03.98,0:09:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laut yang terbuka.
Dialogue: 0,0:09:06.21,0:09:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau berniat lakukan itu, ya?
Dialogue: 0,0:09:11.44,0:09:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjutan yang kemarin!
Dialogue: 0,0:09:15.97,0:09:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjutan...
Dialogue: 0,0:09:18.31,0:09:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, bisa ke sini dan duduk dulu?
Dialogue: 0,0:09:21.60,0:09:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Hah?
Dialogue: 0,0:09:23.66,0:09:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyuruhku duduk di sebelahnya\Nuntuk dirangkul, ya?
Dialogue: 0,0:09:27.49,0:09:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tunggu, ini masih terlalu cepat!
Dialogue: 0,0:09:31.28,0:09:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:09:32.70,0:09:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau menyuruhku duduk di tanah?
Dialogue: 0,0:09:35.79,0:09:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:09:37.71,0:09:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:09:41.07,0:09:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita begini saja.
Dialogue: 0,0:09:45.53,0:09:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Digendong bak putri?!
Dialogue: 0,0:09:48.13,0:09:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pri-Pria ini sempurna!
Dialogue: 0,0:09:52.23,0:09:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Acara yang penting, lokasi yang sempurna.
Dialogue: 0,0:09:54.70,0:09:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lakukan semua hal\Nyang diidamkan anak gadis!
Dialogue: 0,0:09:58.72,0:10:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menolaknya!
Dialogue: 0,0:10:03.64,0:10:04.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:10:04.59,0:10:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:10:05.74,0:10:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Rambutku berantakan karena angin.
Dialogue: 0,0:10:09.75,0:10:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kok.
Dialogue: 0,0:10:11.29,0:10:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga pakai pelembap bibir.
Dialogue: 0,0:10:14.45,0:10:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior cocok pakai itu.
Dialogue: 0,0:10:17.26,0:10:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai, ya.
Dialogue: 0,0:10:18.82,0:10:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum siap mental...!
Dialogue: 0,0:10:21.67,0:10:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak, tidak, tidak!\N- Angkat wajahmu.
Dialogue: 0,0:10:31.31,0:10:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua bolos sekolah\Ndan pergi kencan ke laut.
Dialogue: 0,0:10:34.18,0:10:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jadi kenang-kenangan yang bagus.
Dialogue: 0,0:10:36.99,0:10:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Senior imut banget meniru mulut gurita.
Dialogue: 0,0:10:41.71,0:10:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:10:42.78,0:10:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah buat aku deg-degan sampai seperti ini,\Ntapi hasilnya hanya foto?
Dialogue: 0,0:10:46.89,0:10:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya dia mempermainkan\Nhati anak gadis bangsa iblis.
Dialogue: 0,0:10:50.44,0:10:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, dasar kau...
Dialogue: 0,0:10:53.32,0:10:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau Makhluk Inferior...
Dialogue: 0,0:11:24.50,0:11:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh.
Dialogue: 0,0:11:26.22,0:11:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa lihat Nona dan pacarnya lagi.
Dialogue: 0,0:11:30.59,0:11:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, padahal ada kesempatan\Nmelihat sesuatu yang seru.
Dialogue: 0,0:11:37.63,0:11:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Endus, endus, endus...\N- Dia, 'kan...
Dialogue: 0,0:11:40.62,0:11:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus, endus.
Dialogue: 0,0:11:42.45,0:11:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bau Kyougi.
Dialogue: 0,0:11:44.59,0:11:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat sini, ya.
Dialogue: 0,0:11:48.40,0:11:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya dia bolos sekolah...\NPasti karena hasutan iblis itu.
Dialogue: 0,0:11:55.23,0:11:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus! Bau ini, 'kan...
Dialogue: 0,0:11:59.59,0:12:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oishii Bou!
Dialogue: 0,0:12:01.86,0:12:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:12:04.44,0:12:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terpancing!
Dialogue: 0,0:12:05.96,0:12:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:12:08.46,0:12:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa Ami ke tempat Nona dan pacarnya.
Dialogue: 0,0:12:12.23,0:12:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau mengabulkan permintaan iblis.
Dialogue: 0,0:12:14.86,0:12:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh!\N- Berarti, kau tidak dapat ini.
Dialogue: 0,0:12:19.15,0:12:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ini, 'kan?
Dialogue: 0,0:12:21.97,0:12:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:12:23.79,0:12:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nih, nih.\N- Ka-Kau pikir kau bisa
Dialogue: 0,0:12:27.35,0:12:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nih, ini, ini.\N- memancing santa dari surga
Dialogue: 0,0:12:30.86,0:12:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan umpan seperti itu?
Dialogue: 0,0:12:32.93,0:12:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekadar informasi, aku juga punya ini, lo.
Dialogue: 0,0:12:38.27,0:12:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lebih panjang dari biasanya!
Dialogue: 0,0:12:40.56,0:12:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ugh. Aku tidak akan kalah\Ndari godaan Oishii Bou.
Dialogue: 0,0:12:44.30,0:12:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau, Ami saja yang makan.
Dialogue: 0,0:12:48.38,0:12:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan kalah dari godaan...
Dialogue: 0,0:12:50.61,0:12:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:12:53.37,0:12:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan kalah\Ndari godaan Oishii Bou...
Dialogue: 0,0:13:10.68,0:13:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Malaikat. Mohon beri ampun.
Dialogue: 0,0:13:14.39,0:13:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamba tak sanggup melawan godaan Oishii Bou.
Dialogue: 0,0:13:24.16,0:13:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah beli baju ganti.
Dialogue: 0,0:13:26.34,0:13:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:28.07,0:13:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah memintamu belikan baju.
Dialogue: 0,0:13:30.03,0:13:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:13:31.13,0:13:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak sangka bisa\Nmuncul ombak setinggi itu.
Dialogue: 0,0:13:35.17,0:13:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ganti baju sebelum masuk angin.
Dialogue: 0,0:13:38.39,0:13:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:13:39.48,0:13:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mulai merasa tidak nyaman.
Dialogue: 0,0:13:46.13,0:13:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kyougi, kau tak boleh melihat ke sini\Nselama aku ganti baju.
Dialogue: 0,0:13:55.99,0:13:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang niat ingin lihat, 'kan?
Dialogue: 0,0:13:58.01,0:13:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Senior.
Dialogue: 0,0:14:00.05,0:14:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau terlihat seperti ini,\Naku pria yang beradab.
Dialogue: 0,0:14:02.95,0:14:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumpah, aku tidak akan mengintip!
Dialogue: 0,0:14:05.94,0:14:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip. Aku percaya, Kak Beradab.
Dialogue: 0,0:14:09.46,0:14:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu akibatnya kalau melepas itu, 'kan?
Dialogue: 0,0:14:12.63,0:14:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Senior? Aku tidak...\NAku tidak bisa lihat apa-apa.
Dialogue: 0,0:14:16.95,0:14:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, cepat ganti baju.
Dialogue: 0,0:14:20.85,0:14:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus.
Dialogue: 0,0:14:22.88,0:14:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus, endus, endus.
Dialogue: 0,0:14:25.18,0:14:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus, endus.
Dialogue: 0,0:14:27.22,0:14:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana!
Dialogue: 0,0:14:28.29,0:14:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencium bau Kyougi dari dalam sana.
Dialogue: 0,0:14:32.34,0:14:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kafe Internet?
Dialogue: 0,0:14:34.71,0:14:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Internet itu apa?
Dialogue: 0,0:14:37.28,0:14:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan, bukan?
Dialogue: 0,0:14:38.67,0:14:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya?
Dialogue: 0,0:14:40.12,0:14:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang praktis yang bisa macam-macam?
Dialogue: 0,0:14:42.20,0:14:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Internet keren!
Dialogue: 0,0:14:44.20,0:14:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona dan pacarnya masuk ke ruang pribadi\Ndan ingin diam-diam bermesraan, ya?
Dialogue: 0,0:14:49.05,0:14:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:14:50.02,0:14:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dibiarkan.
Dialogue: 0,0:14:51.81,0:14:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, aku segera datang menyelamatkanmu!
Dialogue: 0,0:15:02.16,0:15:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:15:03.03,0:15:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu Kyougi pakai penutup mata,\Ntapi aku akan ganti baju di depannya?
Dialogue: 0,0:15:08.26,0:15:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tiba-tiba malu karena menyadari hal itu.
Dialogue: 0,0:15:12.46,0:15:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NDia sudah pakai penutup mata.
Dialogue: 0,0:15:16.67,0:15:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga bukan orang yang akan mengintip\Ndi tempat seperti ini.
Dialogue: 0,0:15:22.44,0:15:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau...
Dialogue: 0,0:15:24.32,0:15:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia melihatku seperti ini...
Dialogue: 0,0:15:30.80,0:15:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Senior ganti baju tepat di belakangku.
Dialogue: 0,0:15:38.25,0:15:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunyi ini... Bunyi dia melepas kait bra.
Dialogue: 0,0:15:45.22,0:15:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, celana dalamnya...!
Dialogue: 0,0:15:50.38,0:15:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bayangkan\Nsituasinya hanya dengan bunyi.
Dialogue: 0,0:15:54.00,0:15:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu pendengaranku\Nakan setajam ini saat pakai penutup mata.
Dialogue: 0,0:16:00.97,0:16:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lihat!
Dialogue: 0,0:16:01.87,0:16:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ingin melihat\Nseperti apa Senior sekarang!
Dialogue: 0,0:16:08.19,0:16:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:16:09.14,0:16:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku ingin lihat dia\Ndan pakaian dalamnya!
Dialogue: 0,0:16:11.86,0:16:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, kamu pakai dalaman\Nyang seperti apa?!
Dialogue: 0,0:16:15.52,0:16:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti pakai... yang seperti ini, 'kan?
Dialogue: 0,0:16:18.85,0:16:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:16:24.35,0:16:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:16:25.36,0:16:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ha-Hadir.
Dialogue: 0,0:16:28.16,0:16:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ke sini.
Dialogue: 0,0:16:30.78,0:16:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:16:31.62,0:16:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tapi bukannya Senior sekarang...
Dialogue: 0,0:16:34.92,0:16:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin Kyougi lihat.
Dialogue: 0,0:16:46.67,0:16:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju macam apa ini?
Dialogue: 0,0:16:48.95,0:16:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dengarkan alasanmu\Nsebagai ganti kata-kata terakhir.
Dialogue: 0,0:16:52.99,0:16:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior cocok banget pakai itu!
Dialogue: 0,0:16:55.06,0:16:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam kau, Pria Cabul Beradab!
Dialogue: 0,0:16:58.25,0:17:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar boleh makan sepuasnya, 'kan?
Dialogue: 0,0:17:01.70,0:17:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan jebakan bangsa iblis, 'kan?
Dialogue: 0,0:17:04.10,0:17:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang,\Ntulisannya juga bilang begitu.
Dialogue: 0,0:17:06.94,0:17:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini surga, ya?
Dialogue: 0,0:17:08.97,0:17:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dulu makan es krimnya,\Nayo kita gerebek mereka.
Dialogue: 0,0:17:13.55,0:17:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak.
Dialogue: 0,0:17:16.50,0:17:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, kalian sedang itu, 'kan?!
Dialogue: 0,0:17:20.94,0:17:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita terlambat.
Dialogue: 0,0:17:23.33,0:17:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami, mesin ini internet\Nyang kau sebut tadi, ya?
Dialogue: 0,0:17:27.78,0:17:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar itu.
Dialogue: 0,0:17:30.38,0:17:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Internet!
Dialogue: 0,0:17:31.92,0:17:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, lihat saja nanti.
Dialogue: 0,0:17:34.10,0:17:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami tidak akan pernah menyerah!
Dialogue: 0,0:17:39.40,0:17:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Internet yang agung,\Nmohon beri aku Oishii Bou.
Dialogue: 0,0:17:47.81,0:17:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, ada apa?
Dialogue: 0,0:17:50.56,0:17:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roda itu besar sekali, ya.
Dialogue: 0,0:17:53.05,0:17:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu apa?
Dialogue: 0,0:17:54.56,0:17:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu komidi putar. Senior tidak tahu?
Dialogue: 0,0:17:57.64,0:18:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komidi... Ya, tidak tahu.
Dialogue: 0,0:18:00.28,0:18:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada itu di Dunia Iblis.
Dialogue: 0,0:18:02.14,0:18:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makau?
Dialogue: 0,0:18:03.20,0:18:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kampung halaman Senior?
Dialogue: 0,0:18:10.61,0:18:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba naik?
Dialogue: 0,0:18:12.92,0:18:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, kok. Aku bukan anak-anak.
Dialogue: 0,0:18:16.00,0:18:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengira aku ingin\Ncoba naik macam-macam, ya.
Dialogue: 0,0:18:18.63,0:18:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau Kyougi sangat ingin naik itu,
Dialogue: 0,0:18:21.92,0:18:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa menemanimu naik, kok!
Dialogue: 0,0:18:24.20,0:18:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya indah, ya.
Dialogue: 0,0:18:26.94,0:18:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Seru sekali.
Dialogue: 0,0:18:29.24,0:18:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang Senior menikmati.
Dialogue: 0,0:18:33.43,0:18:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Kyougi.
Dialogue: 0,0:18:35.46,0:18:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau mengajakku pergi\Nsampai membolos sekolah?
Dialogue: 0,0:18:38.79,0:18:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya ingin berfoto,\Nkita tidak perlu sampai bolos.
Dialogue: 0,0:18:43.63,0:18:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lakukan sesuatu bersama Senior.
Dialogue: 0,0:18:47.85,0:18:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan apa?
Dialogue: 0,0:18:49.56,0:18:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin...
Dialogue: 0,0:18:51.14,0:18:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini... Se... Se...
Dialogue: 0,0:18:54.54,0:18:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata yang dimulai dengan "Se"?!
Dialogue: 0,0:18:57.08,0:19:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seppun, cium?! Ternyata Kyougi\Ningin lanjutkan yang kemarin.
Dialogue: 0,0:19:01.63,0:19:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, hal yang ingin kau lakukan itu...\NItu...
Dialogue: 0,0:19:06.01,0:19:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Se...?\N- Benar.
Dialogue: 0,0:19:08.20,0:19:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lakukan itu.
Dialogue: 0,0:19:09.86,0:19:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se... Se...
Dialogue: 0,0:19:12.05,0:19:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seppun, ciuman!\N- Seishun, masa muda!
Dialogue: 0,0:19:14.56,0:19:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa muda?!
Dialogue: 0,0:19:16.04,0:19:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, masa muda!
Dialogue: 0,0:19:17.70,0:19:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, ternyata Senior\Njuga memikirkan hal yang sama.
Dialogue: 0,0:19:20.87,0:19:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya kita sehati sepemikiran,\N'kan, ya?
Dialogue: 0,0:19:25.70,0:19:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku yang berpikir terlalu jauh!
Dialogue: 0,0:19:28.04,0:19:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolos sekolah dan pergi ke laut\Nbersama orang yang dicintai...
Dialogue: 0,0:19:31.17,0:19:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hal yang diidamkan semua anak SMA.
Dialogue: 0,0:19:33.64,0:19:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang disebut masa muda.
Dialogue: 0,0:19:35.99,0:19:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kita tidak lakukan ini, deh.
Dialogue: 0,0:19:39.47,0:19:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,\NSenior terlihat canggung di kereta.
Dialogue: 0,0:19:44.19,0:19:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:45.58,0:19:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir Senior akan senang\Nkalau aku kasih kejutan.
Dialogue: 0,0:19:56.76,0:20:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, aku masih belum terlalu paham
Dialogue: 0,0:20:01.42,0:20:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal masa muda atau hubungan asmara, tapi...
Dialogue: 0,0:20:06.51,0:20:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, hari ini tak terlalu buruk.
Dialogue: 0,0:20:08.69,0:20:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersenang-senang.
Dialogue: 0,0:20:10.50,0:20:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini lumayan juga, Kyougi.
Dialogue: 0,0:20:16.05,0:20:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:20:18.10,0:20:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah kejutkan aku.
Dialogue: 0,0:20:26.51,0:20:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka pergi ke berbagai tempat bersamamu,
Dialogue: 0,0:20:30.69,0:20:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:20:33.01,0:20:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka?
Dialogue: 0,0:20:35.49,0:20:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka di sini maksudnya\Nsuka kegiatan perginya, ya!
Dialogue: 0,0:20:38.33,0:20:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan perasaan cinta!
Dialogue: 0,0:20:40.21,0:20:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang!
Dialogue: 0,0:20:42.37,0:20:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang, senang, senang, senang!
Dialogue: 0,0:20:45.85,0:20:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berhasil, berhasil! Hore, hore!\N- Aku tahu kau senang, tapi tenang dulu.
Dialogue: 0,0:20:49.81,0:20:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti...!
Dialogue: 0,0:21:06.16,0:21:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah... Itu...
Dialogue: 0,0:21:10.14,0:21:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ada sesuatu di belakangmu!
Dialogue: 0,0:21:12.32,0:21:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjutkan!
Dialogue: 0,0:21:13.90,0:21:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:21:15.54,0:21:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dorong terus! Gulung!
Dialogue: 0,0:21:17.59,0:21:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lakukan sesuatu yang buruk!
Dialogue: 0,0:21:20.47,0:21:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dorong!\N- Jangan!
Dialogue: 0,0:21:25.53,0:21:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar, deh.\NMereka mengikuti kita sampai ke sini.
Dialogue: 0,0:21:29.68,0:21:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mereka bisa membuntuti kita, ya?
Dialogue: 0,0:21:37.28,0:21:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku capek.
Dialogue: 0,0:21:40.99,0:21:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:43.92,0:21:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pinjamkan bahumu.
Dialogue: 0,0:21:49.21,0:21:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kita tiba di bawah.
