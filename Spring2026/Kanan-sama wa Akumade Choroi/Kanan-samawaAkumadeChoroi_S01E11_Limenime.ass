Dialogue: 0,0:02:24.29,0:02:27.50,sign,,0000,0000,0000,,#11 CINTA MIEL YANG DIREBUT
Dialogue: 0,0:03:15.63,0:03:16.44,sign,,0000,0000,0000,,RELI STEMPEL UNTUK MENGAKUI PACAR
Dialogue: 0,0:10:57.42,0:11:01.97,sign,,0000,0000,0000,,- LO? TIDAK JADI DRAMA? MALAH VIRAL...\N- BINGUNG SENDIRI
Dialogue: 0,0:11:43.59,0:11:44.12,sign,,0000,0000,0000,,DUNIA IBLIS BEBAS CURHAT BBS
Dialogue: 0,0:13:14.77,0:13:15.77,sign,,0000,0000,0000,,LANGSUNG KE BOKONGNYA
Dialogue: 0,0:20:37.13,0:20:38.88,sign,,0000,0000,0000,,RELI STEMPEL UNTUK MENGAKUI PACAR
Dialogue: 0,0:00:03.52,0:00:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, halo. Honey Bunny di sini.
Dialogue: 0,0:00:07.83,0:00:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, terima kasih sudah datang, ya.
Dialogue: 0,0:00:10.95,0:00:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini,\Naku mau coba latihan pakai roller ab.
Dialogue: 0,0:00:15.89,0:00:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini,\Naku kebanyakan makan yang manis-manis,
Dialogue: 0,0:00:18.95,0:00:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi harus olahraga.
Dialogue: 0,0:00:22.30,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan karena stres?\NYa, semacam itu.
Dialogue: 0,0:00:28.92,0:00:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudutnya mungkin seperti ini.
Dialogue: 0,0:00:32.59,0:00:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai, ya.
Dialogue: 0,0:00:34.02,0:00:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu... Apaan, nih?\NSusah banget.
Dialogue: 0,0:00:39.00,0:00:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua... Enggak bisa... Enggak sanggup.
Dialogue: 0,0:00:45.57,0:00:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:00:48.81,0:00:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian punya rekomendasi olahraga,\Nkasih tahu, ya.
Dialogue: 0,0:02:28.79,0:02:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Honey, hari ini\Nkau pakai celana dalam warna apa?
Dialogue: 0,0:02:33.64,0:02:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga dia cepat-cepat komentari.
Dialogue: 0,0:02:36.05,0:02:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa Honey itu?
Dialogue: 0,0:02:37.33,0:02:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:02:39.11,0:02:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia penyiar populer\Nyang jumlah pengikutnya 100 ribu, lo.
Dialogue: 0,0:02:42.13,0:02:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak kenal?
Dialogue: 0,0:02:44.55,0:02:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepribadiannya yang lumayan tidak beres itu\Nbikin nagih, tahu?
Dialogue: 0,0:02:48.08,0:02:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau suasana hatinya sedang bagus,\Ndia mau lakukan hal mesum juga.
Dialogue: 0,0:02:51.67,0:02:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang seperti itu, tuh...
Dialogue: 0,0:02:58.36,0:03:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membolos, dasar sampah.
Dialogue: 0,0:03:02.33,0:03:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Honey!
Dialogue: 0,0:03:10.69,0:03:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga Kakak senang.
Dialogue: 0,0:03:16.48,0:03:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa Papa dan Miel, ya.
Dialogue: 0,0:03:18.83,0:03:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus apa supaya Miel\Nmau kasih stempel, ya?
Dialogue: 0,0:03:22.45,0:03:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia anak yang kalem dan baik hati.
Dialogue: 0,0:03:25.66,0:03:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama Kyougi bisa akrab dengannya...
Dialogue: 0,0:03:28.45,0:03:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:03:31.85,0:03:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pergi bertiga, tidak?
Dialogue: 0,0:03:34.42,0:03:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya ke danau!
Dialogue: 0,0:03:35.81,0:03:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danau? Mau pergi, mau lihat!
Dialogue: 0,0:03:38.71,0:03:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat Senior yang imut pakai baju renang!
Dialogue: 0,0:03:42.25,0:03:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sebegitu inginnya lihat aku\Npakai baju renang, ya?
Dialogue: 0,0:03:45.97,0:03:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu! Aku ingin mengabadikan\Npenampilan Senior dalam ingatanku!
Dialogue: 0,0:03:50.57,0:03:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:03:53.24,0:03:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bermain air itu kekanakan.
Dialogue: 0,0:03:55.81,0:03:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak usah pakai baju renang saja.
Dialogue: 0,0:03:58.52,0:03:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lihat.
Dialogue: 0,0:03:59.80,0:04:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lihat, mau lihat!
Dialogue: 0,0:04:01.97,0:04:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Senior tidak mau pakai,\Nbiar aku saja yang pakai...!
Dialogue: 0,0:04:04.93,0:04:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke! Aku pakai, aku mau pakai!
Dialogue: 0,0:04:08.17,0:04:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, aku membawakan teh.
Dialogue: 0,0:04:12.39,0:04:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel?
Dialogue: 0,0:04:16.55,0:04:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, ya, Miel.
Dialogue: 0,0:04:18.66,0:04:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simpan saja di sana, ya.
Dialogue: 0,0:04:21.00,0:04:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, kenapa di kasur?
Dialogue: 0,0:04:23.50,0:04:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ah, begini... Aku tiba-tiba mengantuk.
Dialogue: 0,0:04:28.64,0:04:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, wajahmu merah, lo.
Dialogue: 0,0:04:32.44,0:04:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kau sedang tidak enak badan?
Dialogue: 0,0:04:34.96,0:04:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku baik-baik saja, kok.
Dialogue: 0,0:04:37.18,0:04:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu\Nharus bilang apa kalau ketahuan!
Dialogue: 0,0:04:42.40,0:04:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya tidak baik-baik saja.
Dialogue: 0,0:04:44.55,0:04:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan temani Kakak tidur sampai baikan.
Dialogue: 0,0:04:51.00,0:04:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dada Kakak... bisa bikin rileks.
Dialogue: 0,0:04:55.14,0:04:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Miel memang anak yang manja.
Dialogue: 0,0:04:59.13,0:05:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel, jangan.
Dialogue: 0,0:05:00.90,0:05:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Kyougi.
Dialogue: 0,0:05:02.96,0:05:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Keras?
Dialogue: 0,0:05:09.02,0:05:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aa... Ada apa?
Dialogue: 0,0:05:10.76,0:05:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Tidak apa-apa.
Dialogue: 0,0:05:12.92,0:05:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir saja.
Dialogue: 0,0:05:16.39,0:05:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kak.
Dialogue: 0,0:05:18.14,0:05:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:05:20.45,0:05:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau sukai dari manusia itu?
Dialogue: 0,0:05:24.24,0:05:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Yang aku sukai?
Dialogue: 0,0:05:27.13,0:05:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Kyougi?
Dialogue: 0,0:05:28.33,0:05:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bilang, nih?\NTepat di depan Kyougi?!
Dialogue: 0,0:05:30.25,0:05:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu terlalu memalukan?!
Dialogue: 0,0:05:32.20,0:05:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu kontrak, kok.\NKontrak untuk mengambil jiwanya.
Dialogue: 0,0:05:35.70,0:05:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontrak?\NJadi kau terpaksa jadi kekasihnya...?
Dialogue: 0,0:05:39.44,0:05:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:40.61,0:05:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menjebakku dengan kepiawaian bicaranya\Nsupaya aku mau membuat kontrak kekasih.
Dialogue: 0,0:05:46.28,0:05:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan Kakak.
Dialogue: 0,0:05:47.98,0:05:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju. Merepotkan banget!
Dialogue: 0,0:05:51.44,0:05:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pahaku geli...\Ndan entah kenapa terasa basah?
Dialogue: 0,0:05:57.01,0:05:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi menangis karena terbawa perasaan?
Dialogue: 0,0:06:00.51,0:06:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:06:01.68,0:06:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi... Rasanya seru saat kami bersama.
Dialogue: 0,0:06:05.88,0:06:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru?
Dialogue: 0,0:06:10.12,0:06:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, ngobrol basa-basi selepas sekolah,
Dialogue: 0,0:06:14.00,0:06:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pergi belanja saat hari libur,
Dialogue: 0,0:06:18.48,0:06:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kabur sebentar\Ndari kesibukan sehari-hari.
Dialogue: 0,0:06:23.14,0:06:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungku berdebar\Nseolah semua itu pengalaman pertama.
Dialogue: 0,0:06:30.09,0:06:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak kelihatan dewasa.
Dialogue: 0,0:06:32.74,0:06:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitulah. Mungkin memang sudah dewasa.
Dialogue: 0,0:06:39.57,0:06:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian sudah ciuman?
Dialogue: 0,0:06:42.53,0:06:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Sudah, kok!
Dialogue: 0,0:06:44.21,0:06:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai meninggalkan bekas juga, lo.
Dialogue: 0,0:06:47.42,0:06:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kami sudah dewasa.
Dialogue: 0,0:06:53.40,0:06:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, padahal Kakak sedang tidak enak badan.
Dialogue: 0,0:06:56.52,0:06:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat yang banyak, ya, Kak.
Dialogue: 0,0:07:01.48,0:07:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman.
Dialogue: 0,0:07:02.95,0:07:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya tidak ketahuan.
Dialogue: 0,0:07:05.47,0:07:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau sudah boleh keluar.
Dialogue: 0,0:07:08.47,0:07:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, kita sudah ciuman, ya?
Dialogue: 0,0:07:12.18,0:07:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Sudah, kok. Di tengkuk.
Dialogue: 0,0:07:14.46,0:07:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengkuk...?
Dialogue: 0,0:07:16.21,0:07:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu, ya!
Dialogue: 0,0:07:18.01,0:07:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata itu termasuk ciuman, ya?
Dialogue: 0,0:07:19.84,0:07:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Ralat, bukan! Itu bukan ciuman!
Dialogue: 0,0:07:23.27,0:07:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, maksudku adalah...
Dialogue: 0,0:07:24.49,0:07:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman pertamaku!
Dialogue: 0,0:07:26.50,0:07:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang bukan!
Dialogue: 0,0:07:28.97,0:07:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya gengsi di depan adikku yang polos!
Dialogue: 0,0:07:31.73,0:07:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma kedok saja, kok!
Dialogue: 0,0:07:33.35,0:07:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman pertamaku di tengkuk!
Dialogue: 0,0:07:36.88,0:07:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, cepat ajak Miel pergi!
Dialogue: 0,0:07:40.27,0:07:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau Makhluk Inferior!
Dialogue: 0,0:07:49.39,0:07:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku sudah ciuman?
Dialogue: 0,0:07:54.26,0:07:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan Makhluk Inferior itu.
Dialogue: 0,0:07:57.28,0:08:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat... Aku harus...\NHarus lakukan itu untuk memuaskan diri...
Dialogue: 0,0:08:26.80,0:08:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Honey Bunny!
Dialogue: 0,0:08:31.41,0:08:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, halo. Honey Bunny di sini.
Dialogue: 0,0:08:34.79,0:08:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf tiba-tiba mulai siaran langsung.
Dialogue: 0,0:08:37.54,0:08:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin keluarkan unek-unek.
Dialogue: 0,0:08:42.70,0:08:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini banyak yang datang,\Ndan mereka pasti akan memihakku.
Dialogue: 0,0:08:49.52,0:08:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senangnya!
Dialogue: 0,0:08:52.81,0:08:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku punya kakak perempuan.
Dialogue: 0,0:08:56.16,0:08:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tiba-tiba pulang bawa cowok ke rumah.
Dialogue: 0,0:08:59.39,0:09:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orangnya benar-benar tidak asyik pula.
Dialogue: 0,0:09:01.33,0:09:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rese banget.
Dialogue: 0,0:09:03.25,0:09:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia sudah menipu kakakku.
Dialogue: 0,0:09:08.25,0:09:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin usahakan sesuatu\Nsupaya mereka putus.
Dialogue: 0,0:09:11.43,0:09:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak kepikiran ide yang bagus.
Dialogue: 0,0:09:16.58,0:09:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lenyapkan dia?
Dialogue: 0,0:09:18.33,0:09:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus! Aku terima idemu.
Dialogue: 0,0:09:21.19,0:09:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Permisi...\N- Aku kasih hadiah sebagai ucapan terima kasih.
Dialogue: 0,0:09:24.43,0:09:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Miel.\N- Aku akan jilat kupingmu sampai puas, ya.
Dialogue: 0,0:09:27.80,0:09:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa? Di belakangku?
Dialogue: 0,0:09:34.99,0:09:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mau pergi ke danau, Miel mau ikut?
Dialogue: 0,0:09:40.72,0:09:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ku-Kubunuh kau.
Dialogue: 0,0:09:44.04,0:09:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh kau!
Dialogue: 0,0:09:47.02,0:09:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...!
Dialogue: 0,0:09:48.49,0:09:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, dasar! Kau selalu menggangguku!
Dialogue: 0,0:09:52.14,0:09:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengacau lagi, ya?
Dialogue: 0,0:09:54.63,0:09:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau!
Dialogue: 0,0:09:56.28,0:09:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menghindar!
Dialogue: 0,0:09:59.84,0:10:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menghancurkan hal yang kusayang,\Nsatu demi satu...
Dialogue: 0,0:10:04.42,0:10:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang kamu sayang?\NApa maksudmu?
Dialogue: 0,0:10:07.72,0:10:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja kau tidak ada, Kakak pasti
Dialogue: 0,0:10:11.20,0:10:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan selalu bersamaku!
Dialogue: 0,0:10:16.18,0:10:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci Makhluk Inferior ini!
Dialogue: 0,0:10:20.74,0:10:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Miel.
Dialogue: 0,0:10:22.42,0:10:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:10:23.86,0:10:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat pakaianmu...\NBerarti, kau juga ikut ke danau, ya?
Dialogue: 0,0:10:28.34,0:10:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, Kak.
Dialogue: 0,0:10:30.69,0:10:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:10:32.17,0:10:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manfaatkan kesempatan ini\Nuntuk akrab dengan Kyougi, ya.
Dialogue: 0,0:10:34.56,0:10:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Dengan Makhluk Inferior itu?
Dialogue: 0,0:10:37.66,0:10:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kenapa mulutmu berbusa?
Dialogue: 0,0:10:41.85,0:10:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, sadarlah!
Dialogue: 0,0:10:44.26,0:10:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada menjalin kontrak kekasih dengannya,\Nlebih baik aku saja...
Dialogue: 0,0:10:49.57,0:10:50.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:10:51.84,0:10:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya perlu merebut Kakak darinya.
Dialogue: 0,0:11:03.29,0:11:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren! Tempatnya indah sekali!
Dialogue: 0,0:11:06.22,0:11:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini area privat keluarga kami,\Njadi santai saja.
Dialogue: 0,0:11:09.57,0:11:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini ada hewan\Nyang belum pernah kulihat juga.
Dialogue: 0,0:11:13.15,0:11:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah pikirkan detail lainnya.
Dialogue: 0,0:11:15.66,0:11:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.
Dialogue: 0,0:11:19.43,0:11:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya Makhluk Inferior,\Ntapi malah cengar-cengir dengan Kakak.
Dialogue: 0,0:11:25.48,0:11:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertawalah selagi masih bisa.
Dialogue: 0,0:11:28.61,0:11:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan bahwa akulah\Nyang lebih pantas di samping Kakak.
Dialogue: 0,0:11:33.17,0:11:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku akan rebut dia darimu.
Dialogue: 0,0:11:37.19,0:11:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:11:38.68,0:11:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu teknik apa yang ampuh.
Dialogue: 0,0:11:42.15,0:11:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat seperti ini...
Dialogue: 0,0:11:44.16,0:11:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanya ke forum Dunia Iblis.
Dialogue: 0,0:11:46.98,0:11:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Minta cara merebut wanita orang."
Dialogue: 0,0:11:50.65,0:11:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mana kutahu", "Hipnotis haha",\N"Harusnya aku yang tanya itu".
Dialogue: 0,0:11:54.60,0:11:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih. Dasar tidak berguna.
Dialogue: 0,0:11:58.72,0:12:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rangsang pusat sarafnya,\Ndan buat dia jatuh hati padamu?
Dialogue: 0,0:12:04.84,0:12:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:12:09.46,0:12:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:12:11.09,0:12:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pemandangan indah!\N- Aku akan pakaikan tabir surya.
Dialogue: 0,0:12:13.36,0:12:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Keren!\N- Terima kasih, Miel.
Dialogue: 0,0:12:15.89,0:12:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, aku akan buat Kakak\Nmerasakan kenikmatan.
Dialogue: 0,0:12:20.65,0:12:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel.
Dialogue: 0,0:12:21.92,0:12:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai tubuhnya\Ntak bisa hidup normal lagi tanpaku!
Dialogue: 0,0:12:26.28,0:12:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyusupkan energi sihirku\Nke dalam tabir surya,
Dialogue: 0,0:12:28.62,0:12:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan buat seluruh badannya lemas!
Dialogue: 0,0:12:31.29,0:12:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, aku janji\Nhasil fotonya bakal cantik.
Dialogue: 0,0:12:33.87,0:12:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk Inferior,\Nkuharap kau senang hanya bisa melihat
Dialogue: 0,0:12:37.70,0:12:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku membuat Kakak\Nmenjadi milikku seorang!
Dialogue: 0,0:12:40.66,0:12:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, keluarlah sampai kami selesai.
Dialogue: 0,0:12:42.72,0:12:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lihat, ya.
Dialogue: 0,0:12:44.56,0:12:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Miel. Tolong, ya.
Dialogue: 0,0:12:47.86,0:12:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Kak.
Dialogue: 0,0:12:49.62,0:12:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta metode pijat yang nikmat.
Dialogue: 0,0:12:52.98,0:12:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, hm. Begitu.
Dialogue: 0,0:12:55.57,0:12:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleskan untuk relaksasi di bagian\Ntulang belakang dan kedua ketiak.
Dialogue: 0,0:13:00.64,0:13:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak geli, ya.
Dialogue: 0,0:13:02.73,0:13:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk melindungi kulit cantik Kakak.
Dialogue: 0,0:13:07.52,0:13:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi yang bagus.
Dialogue: 0,0:13:08.85,0:13:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perluas area pijat\Nuntuk menurunkan sikap waspadanya.
Dialogue: 0,0:13:13.79,0:13:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya...
Dialogue: 0,0:13:16.05,0:13:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba berani banget!
Dialogue: 0,0:13:19.38,0:13:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara manis Kakak!
Dialogue: 0,0:13:22.40,0:13:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu menahan diri, lo.
Dialogue: 0,0:13:24.54,0:13:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin dengar suaramu, Kak!
Dialogue: 0,0:13:28.45,0:13:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pijat seolah sedang mendorong,
Dialogue: 0,0:13:30.58,0:13:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tambah tenaga di bagian dalam paha\Nseolah ingin membuatnya panik.
Dialogue: 0,0:13:33.91,0:13:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tunggu!
Dialogue: 0,0:13:35.81,0:13:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksinya lebih bagus dari yang tadi!
Dialogue: 0,0:13:37.65,0:13:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya menyerang dengan ganas!
Dialogue: 0,0:13:39.18,0:13:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:13:40.22,0:13:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini, aku juga mulai menikmati.
Dialogue: 0,0:13:44.35,0:13:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, kalau kakinya ditutup,\Naku tidak bisa oles, lo.
Dialogue: 0,0:13:47.50,0:13:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah oles di sana, kok.
Dialogue: 0,0:13:49.33,0:13:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mulai! Ini sudah mulai!
Dialogue: 0,0:13:51.42,0:13:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tekan payudara\Nseolah sedang meremas dan...
Dialogue: 0,0:13:55.20,0:13:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai!
Dialogue: 0,0:14:00.75,0:14:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Kak?
Dialogue: 0,0:14:03.63,0:14:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang Kakak\Nsudah ketagihan perasaan nikmat.
Dialogue: 0,0:14:06.45,0:14:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhnya tidak akan merasa puas\Nselain dipegang tanganku...
Dialogue: 0,0:14:09.65,0:14:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel, ini pertama kalinya aku...
Dialogue: 0,0:14:12.61,0:14:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:14:13.53,0:14:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu...
Dialogue: 0,0:14:14.20,0:14:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu kau ternyata mahir memijat!
Dialogue: 0,0:14:16.94,0:14:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku rasanya jauh lebih ringan!
Dialogue: 0,0:14:21.23,0:14:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata itu hanya pijatan biasa.
Dialogue: 0,0:14:24.44,0:14:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior! Sudah siap, belum...?
Dialogue: 0,0:14:27.34,0:14:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?! Gaya rambutmu lucu banget!
Dialogue: 0,0:14:33.98,0:14:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!\NAku jadi malu karena di depan adikku!
Dialogue: 0,0:14:38.17,0:14:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:14:39.51,0:14:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut, kok. Imut!
Dialogue: 0,0:14:40.67,0:14:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Astaga...!\N- Reaksi itu...
Dialogue: 0,0:14:44.97,0:14:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin reaksi itu!
Dialogue: 0,0:14:50.06,0:14:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya dingin dan nyaman!
Dialogue: 0,0:14:54.90,0:14:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau terlalu lengah.
Dialogue: 0,0:14:57.25,0:14:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior usil, ya!
Dialogue: 0,0:15:01.00,0:15:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hentikan!
Dialogue: 0,0:15:02.63,0:15:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:15:03.59,0:15:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk Inferior sialan.
Dialogue: 0,0:15:06.15,0:15:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku\Nyang ada di posisimu sekarang.
Dialogue: 0,0:15:09.18,0:15:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa diampuni!
Dialogue: 0,0:15:11.25,0:15:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa diampuni, ya!
Dialogue: 0,0:15:13.02,0:15:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:15.89,0:15:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeanne?
Dialogue: 0,0:15:17.06,0:15:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya bentuk tubuhmu\Nkembali ke semula, deh.
Dialogue: 0,0:15:19.42,0:15:23.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepasang remaja bergumul\Ndengan baju terbuka...
Dialogue: 0,0:15:25.30,0:15:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang berhubungan seks di luar nikah!
Dialogue: 0,0:15:27.44,0:15:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:15:31.34,0:15:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau iblis mesum!
Dialogue: 0,0:15:32.90,0:15:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh-jauh kau dari Kyougi!
Dialogue: 0,0:15:36.58,0:15:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Di mana Kanan?
Dialogue: 0,0:15:39.14,0:15:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada?
Dialogue: 0,0:15:43.72,0:15:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh! Kenapa melihat saja?!
Dialogue: 0,0:15:45.58,0:15:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak tidak bisa berenang, tahu!
Dialogue: 0,0:15:48.37,0:15:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku juga tidak bisa berenang.
Dialogue: 0,0:15:50.62,0:15:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya, dong?! Senior!
Dialogue: 0,0:15:58.99,0:16:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir saja aku tenggelam.
Dialogue: 0,0:16:01.09,0:16:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, aku masih sempat.
Dialogue: 0,0:16:05.87,0:16:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang ingin lakukan itu...!
Dialogue: 0,0:16:09.54,0:16:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Digendong ala putri oleh Kakak\Nadalah momen idaman nomor satu!
Dialogue: 0,0:16:13.49,0:16:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kalau harus pilih,\Naku yang ingin digendong, sih...
Dialogue: 0,0:16:16.42,0:16:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi malah Makhluk Inferior itu yang...!
Dialogue: 0,0:16:19.02,0:16:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lepaskan dia.
Dialogue: 0,0:16:21.04,0:16:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak juga harus segera\Nlepaskan diri dari dia!
Dialogue: 0,0:16:24.25,0:16:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini kakimu masih sampai, kok.
Dialogue: 0,0:16:26.06,0:16:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mau.
Dialogue: 0,0:16:27.92,0:16:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku lemas.
Dialogue: 0,0:16:29.63,0:16:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak takut, tolong jangan lepaskan.
Dialogue: 0,0:16:32.01,0:16:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipeluk, dong?!
Dialogue: 0,0:16:35.12,0:16:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan mereka bermesraan lagi!
Dialogue: 0,0:16:38.07,0:16:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, istirahat dulu di sini\Nsampai kau tenang.
Dialogue: 0,0:16:45.62,0:16:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah tidur di pangkuannya?!
Dialogue: 0,0:16:49.93,0:16:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...\NItu hal yang ingin kulakukan juga, tahu.
Dialogue: 0,0:16:53.80,0:16:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Da-Dadaku sesak. Hentikan!
Dialogue: 0,0:16:56.90,0:17:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, kalau mau tidur di atas pangkuan,
Dialogue: 0,0:17:01.06,0:17:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- pahaku juga bisa...\N- Kyougi.
Dialogue: 0,0:17:03.43,0:17:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Genggam tanganku sampai aku lebih tenang.
Dialogue: 0,0:17:09.36,0:17:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Aku genggam, ya.
Dialogue: 0,0:17:12.53,0:17:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa aku lebih tenang.
Dialogue: 0,0:17:16.78,0:17:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan... Sudah, hentikan.
Dialogue: 0,0:17:19.45,0:17:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku... tak sanggup lagi.
Dialogue: 0,0:17:22.55,0:17:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku... perlahan berubah\Nmenjadi milik Makhluk Inferior itu.
Dialogue: 0,0:17:28.49,0:17:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:29.67,0:17:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah orang yang baru muncul...?
Dialogue: 0,0:17:32.88,0:17:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku yang lebih duluan sayang Kakak!
Dialogue: 0,0:17:36.19,0:17:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesal, tapi... Tapi...!
Dialogue: 0,0:17:39.02,0:17:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nafsu apa yang memenuhi hatiku ini?
Dialogue: 0,0:17:45.16,0:17:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan aku...\Nnafsu karena Kakak direbut?
Dialogue: 0,0:17:50.24,0:17:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Itu tidak mungkin.
Dialogue: 0,0:17:52.53,0:17:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu membuatku seperti...\Nwanita mesum?!
Dialogue: 0,0:17:55.90,0:17:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus buktikan.
Dialogue: 0,0:17:58.85,0:18:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, Nona.
Dialogue: 0,0:18:00.18,0:18:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedotan untuk pasangan yang ingin kugunakan\Nbersama Kakak suatu hari nanti.
Dialogue: 0,0:18:04.79,0:18:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh hina\Njika Makhluk Inferior duluan yang pakai!
Dialogue: 0,0:18:07.99,0:18:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Seharusnya aku akan merasa terhina!
Dialogue: 0,0:18:11.23,0:18:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, silakan.
Dialogue: 0,0:18:13.68,0:18:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman untukmu.
Dialogue: 0,0:18:15.06,0:18:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Miel.
Dialogue: 0,0:18:16.97,0:18:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:18:18.64,0:18:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa ini?!
Dialogue: 0,0:18:21.44,0:18:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedotan untuk pasangan!
Dialogue: 0,0:18:23.38,0:18:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Makhluk Inferior...!
Dialogue: 0,0:18:26.79,0:18:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, Miel.
Dialogue: 0,0:18:27.96,0:18:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin lihat aku dan Kyougi\Nbermesraan, ya?
Dialogue: 0,0:18:31.40,0:18:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dewasa sekali?
Dialogue: 0,0:18:33.50,0:18:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika itu yang Miel inginkan,\Naku akan berusaha.
Dialogue: 0,0:18:38.80,0:18:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ki-Kita mulai, ya.
Dialogue: 0,0:18:40.46,0:18:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:18:41.77,0:18:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Kakak, hentikan itu!
Dialogue: 0,0:18:44.89,0:18:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak. Aku kesal!
Dialogue: 0,0:18:47.45,0:18:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesal... Aku kesal!
Dialogue: 0,0:18:49.58,0:18:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip. Aku masih normal!
Dialogue: 0,0:18:51.58,0:18:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Normal...
Dialogue: 0,0:18:55.93,0:18:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa terhina!
Dialogue: 0,0:18:57.51,0:18:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga nafsu...
Dialogue: 0,0:19:00.62,0:19:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadar!
Dialogue: 0,0:19:03.02,0:19:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku, jangan nafsu.
Dialogue: 0,0:19:05.23,0:19:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih waras, kok. Masih normal!
Dialogue: 0,0:19:08.59,0:19:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kyougi. Aku jadi menyembur wajahmu.
Dialogue: 0,0:19:10.97,0:19:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk Inferior itu kena cairan Kakak?
Dialogue: 0,0:19:15.34,0:19:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kok.
Dialogue: 0,0:19:16.31,0:19:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dijilat!
Dialogue: 0,0:19:17.74,0:19:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jus ini enak karena asamnya pas, ya.
Dialogue: 0,0:19:20.58,0:19:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:19:21.60,0:19:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga jelaskan rasa cairan dari Kakak...!
Dialogue: 0,0:19:26.21,0:19:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:19:28.41,0:19:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi ternyata lumayan berotot, ya.
Dialogue: 0,0:19:34.60,0:19:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya kusentuh langsung.
Dialogue: 0,0:19:36.88,0:19:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh lelaki itu ternyata\Nlebih keras dari bayanganku...
Dialogue: 0,0:19:41.36,0:19:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah erotis?!
Dialogue: 0,0:19:43.53,0:19:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia perlihatkan\Nekspresi seperti itu, aku...
Dialogue: 0,0:19:47.89,0:19:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, ada buah menempel di wajahmu.
Dialogue: 0,0:19:52.25,0:19:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku makan, deh.
Dialogue: 0,0:19:54.87,0:19:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah erotis Kakak!
Dialogue: 0,0:20:02.63,0:20:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel juga ingin makan buahnya?
Dialogue: 0,0:20:05.78,0:20:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:20:13.51,0:20:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis...
Dialogue: 0,0:20:15.13,0:20:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa iba dari orang yang pacarnya\Nseharusnya kurebut.
Dialogue: 0,0:20:18.70,0:20:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya manis.
Dialogue: 0,0:20:20.30,0:20:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka. Aku jadi nafsu.
Dialogue: 0,0:20:23.16,0:20:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Miel ini, ya.\NDia sudah akrab lagi.
Dialogue: 0,0:20:26.97,0:20:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:20:27.90,0:20:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, Kak!
Dialogue: 0,0:20:30.61,0:20:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya. Stempelnya.
Dialogue: 0,0:20:32.22,0:20:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah akrab dengan Kyougi,\Njadi mau kasih stempel, 'kan?
Dialogue: 0,0:20:39.17,0:20:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kertas stempel yang akan\Nmenyerahkan kakak kesayanganku padanya.
Dialogue: 0,0:20:43.58,0:20:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak ingin aku menyuruhnya\Npergi dengan kedua tanganku sendiri...
Dialogue: 0,0:20:50.62,0:20:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tindakan yang mengkhianati\Ncintaku pada Kakak...
Dialogue: 0,0:20:59.27,0:21:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa...
Dialogue: 0,0:21:00.84,0:21:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar membuatku nafsu...
Dialogue: 0,0:21:07.97,0:21:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Miel!
Dialogue: 0,0:21:10.84,0:21:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa Papa saja, ya.
Dialogue: 0,0:21:12.64,0:21:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju. Mari berusaha, Senior!
Dialogue: 0,0:21:15.77,0:21:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... kini paham.
Dialogue: 0,0:21:19.59,0:21:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku
Dialogue: 0,0:21:23.68,0:21:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mesum.
Dialogue: 0,0:22:59.03,0:23:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa dua hari kita menginap di Dunia Iblis.
Dialogue: 0,0:23:02.78,0:23:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kyougi bersenang-senang?
Dialogue: 0,0:23:07.69,0:23:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia tidak suka bertemu keluargaku?
Dialogue: 0,0:23:11.07,0:23:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia berpikir mengumpulkan\Nstempel ini merepotkan?
Dialogue: 0,0:23:14.88,0:23:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya aku lakukan sesuatu\Nyang lebih untuknya...?
Dialogue: 0,0:23:20.82,0:23:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, perasaan apa, sih, ini?
Dialogue: 0,0:23:23.56,0:23:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku gelisah sekali?
Dialogue: 0,0:23:27.46,0:23:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku melupakan sesuatu, deh.
Dialogue: 0,0:23:36.72,0:23:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang, tolong aku.
