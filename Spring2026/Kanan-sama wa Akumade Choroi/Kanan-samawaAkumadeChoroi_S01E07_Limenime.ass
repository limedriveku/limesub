Dialogue: 0,0:19:05.62,0:19:08.62,tanda,,0000,0000,0000,,*KAFEIN MEMILIKI EFEK DIURETIK
Dialogue: 0,0:00:02.73,0:00:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau aku bantu belajar untuk UAS?
Dialogue: 0,0:00:05.85,0:00:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kami, Senior!
Dialogue: 0,0:00:07.88,0:00:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mohon!
Dialogue: 0,0:00:09.60,0:00:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini sibuk, ya.\NMinta orang lain saja, sana.
Dialogue: 0,0:00:13.04,0:00:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ingin dibantu\Nbelajar oleh Senior.
Dialogue: 0,0:00:15.82,0:00:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:00:17.19,0:00:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku ingin mencapai\Nperingkat lebih tinggi!
Dialogue: 0,0:00:21.08,0:00:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, aku ingin diajari Senior,\Nsiswi paling pintar di akademi ini!
Dialogue: 0,0:00:27.26,0:00:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merepotkan.
Dialogue: 0,0:00:28.74,0:00:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:00:30.82,0:00:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, libur musim panasku\Nakan dipenuhi kelas tambahan.
Dialogue: 0,0:00:34.00,0:00:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Senior!
Dialogue: 0,0:00:35.75,0:00:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Be-Berhenti.\N- Tolong banget!
Dialogue: 0,0:00:37.15,0:00:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti lepas, nanti rokku lepas!
Dialogue: 0,0:00:39.29,0:00:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Senior!
Dialogue: 0,0:00:41.29,0:00:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ralat, Bu Guru!
Dialogue: 0,0:00:44.32,0:00:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Tolong kami, Bu Guru Kanan!
Dialogue: 0,0:00:47.31,0:00:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}B-Bu Guru?
Dialogue: 0,0:00:49.20,0:00:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru!
Dialogue: 0,0:00:50.39,0:00:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru!
Dialogue: 0,0:00:51.33,0:00:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru!
Dialogue: 0,0:01:01.73,0:01:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:01:03.19,0:01:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru Kanan akan mendidik ulang kalian,\Npara ternak.
Dialogue: 0,0:01:07.31,0:01:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore, Bu Guru Kanan!
Dialogue: 0,0:01:12.64,0:01:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Kanan.
Dialogue: 0,0:01:14.87,0:01:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak bertemu dengannya hari itu,
Dialogue: 0,0:01:17.79,0:01:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepalaku tak hentinya\Nmemikirkan tentang dia.
Dialogue: 0,0:01:23.89,0:01:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, emosi apa\Nyang kurasakan saat ini?
Dialogue: 0,0:01:28.37,0:01:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, sebenarnya aku...
Dialogue: 0,0:01:33.74,0:01:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa yang baru saja kupikirkan?!
Dialogue: 0,0:03:09.94,0:03:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian ingin aku ajari apa?
Dialogue: 0,0:03:13.52,0:03:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku payah banget di bidang hitungan...
Dialogue: 0,0:03:16.85,0:03:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini matematika, lo?\NKau mau sekolah ulang dari SD?
Dialogue: 0,0:03:20.39,0:03:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar makhluk inferior!
Dialogue: 0,0:03:22.22,0:03:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya.
Dialogue: 0,0:03:24.19,0:03:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kau juga Matematika?
Dialogue: 0,0:03:26.43,0:03:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:27.41,0:03:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, benar.
Dialogue: 0,0:03:29.27,0:03:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ajari,\Nbuka buku paket dan catatan kalian.
Dialogue: 0,0:03:33.14,0:03:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:03:34.23,0:03:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilang apa barusan?
Dialogue: 0,0:03:36.94,0:03:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, coba selesaikan soal ini.
Dialogue: 0,0:03:39.26,0:03:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak paham.
Dialogue: 0,0:03:40.35,0:03:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba pikir dulu, dong.
Dialogue: 0,0:03:42.34,0:03:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan isi kepalamu\Nsama-sama "Youji", kekanakan.
Dialogue: 0,0:03:46.21,0:03:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior. Aku juga...
Dialogue: 0,0:03:48.28,0:03:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga?
Dialogue: 0,0:03:49.55,0:03:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan...\NSoalku sudah selesai.
Dialogue: 0,0:03:52.97,0:03:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kulihat.
Dialogue: 0,0:03:58.17,0:03:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:59.51,0:04:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawaban dan metodenya benar.
Dialogue: 0,0:04:01.80,0:04:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak didikku memang hebat, ya.
Dialogue: 0,0:04:06.92,0:04:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipuji Senior. Senang banget!
Dialogue: 0,0:04:10.68,0:04:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya hatiku seperti terpenuhi...
Dialogue: 0,0:04:16.32,0:04:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan hampa apa ini?
Dialogue: 0,0:04:19.57,0:04:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang bukan!
Dialogue: 0,0:04:21.44,0:04:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyuruhmu kerjakan pakai rumus ini.
Dialogue: 0,0:04:23.98,0:04:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatanmu benar-benar setara burung, ya.
Dialogue: 0,0:04:26.32,0:04:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf.
Dialogue: 0,0:04:28.05,0:04:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau salah, dia akan mengucapkan itu?
Dialogue: 0,0:04:32.50,0:04:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior. Bagaimana kalau ini?
Dialogue: 0,0:04:35.35,0:04:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm... Lo?
Dialogue: 0,0:04:37.53,0:04:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau salah di pertengahan.
Dialogue: 0,0:04:40.22,0:04:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Metode penyelesaianmu sudah betul,\Nkerjakan dengan tenang supaya selesai, ya.
Dialogue: 0,0:04:47.63,0:04:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa wajahmu begitu?
Dialogue: 0,0:04:50.01,0:04:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang itu salah total!
Dialogue: 0,0:04:53.35,0:04:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berapa kali salah\Ndi tempat yang sama, sih?
Dialogue: 0,0:04:56.28,0:04:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih rendah dari serangga, ya?\NDasar makhluk sel tunggal!
Dialogue: 0,0:05:00.74,0:05:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Mengulangi kesalahan yang sama.
Dialogue: 0,0:05:03.59,0:05:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Kanan, mohon diperiksa.
Dialogue: 0,0:05:06.31,0:05:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kau salah di tempat yang sama\Ndengan tadi...
Dialogue: 0,0:05:10.54,0:05:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tidak apa-apa salah berulang kali.
Dialogue: 0,0:05:13.55,0:05:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu yang membantumu\Nhafal sedikit demi sedikit.
Dialogue: 0,0:05:18.85,0:05:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior. Kepalaku sudah tidak sanggup lagi!
Dialogue: 0,0:05:22.08,0:05:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lagi?
Dialogue: 0,0:05:23.15,0:05:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasukkan x sebagai substitusi\Nke dalam pi...
Dialogue: 0,0:05:26.33,0:05:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa soal MTK ini vulgar banget, sih?!
Dialogue: 0,0:05:29.30,0:05:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terangsang sama rumus Matematika!
Dialogue: 0,0:05:31.22,0:05:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otakmu rusak, ya?\NDasar monyet cabul!
Dialogue: 0,0:05:33.24,0:05:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Lelucon vulgar!
Dialogue: 0,0:05:35.29,0:05:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:05:36.73,0:05:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:05:37.94,0:05:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau aku bilang menyisipkan pengganti,\NSenior akan marahi aku karena mesum, tidak?
Dialogue: 0,0:05:42.42,0:05:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga ikutan rusak?!
Dialogue: 0,0:05:44.95,0:05:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:05:46.65,0:05:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau agak capek, deh.
Dialogue: 0,0:05:48.74,0:05:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:05:51.07,0:05:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu yang aku mau!
Dialogue: 0,0:05:55.09,0:05:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa kau malah menangis?
Dialogue: 0,0:05:57.51,0:06:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya... Habisnya Senior...
Dialogue: 0,0:06:00.68,0:06:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior sejak tadi sibuk\Nbermesraan dengan Youji.
Dialogue: 0,0:06:04.29,0:06:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga... Aku juga...
Dialogue: 0,0:06:07.47,0:06:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bermesraan?
Dialogue: 0,0:06:11.16,0:06:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin dicaci maki Senior, tahu!
Dialogue: 0,0:06:17.64,0:06:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:20.41,0:06:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kau... cabul...?
Dialogue: 0,0:06:26.11,0:06:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi macam apa itu?!
Dialogue: 0,0:06:30.20,0:06:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:06:31.53,0:06:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Kanan.
Dialogue: 0,0:06:38.44,0:06:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, dengan Takakiyo.
Dialogue: 0,0:06:40.12,0:06:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, halo. Kanan ada di rumah?
Dialogue: 0,0:06:43.23,0:06:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, maaf... Dengan siapa, ya?
Dialogue: 0,0:06:45.27,0:06:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku papa Kanan.
Dialogue: 0,0:06:47.92,0:06:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa Kanan?
Dialogue: 0,0:06:49.81,0:06:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Papa.
Dialogue: 0,0:06:51.21,0:06:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu mereka manusia,\Ntapi tidak sopan tiba-tiba menyebut itu.
Dialogue: 0,0:06:54.93,0:06:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya aku tidak sabar\Ningin dengar suara Kanan.
Dialogue: 0,0:06:58.75,0:07:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja yang bicara.
Dialogue: 0,0:07:01.90,0:07:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku mama Kanan.
Dialogue: 0,0:07:05.76,0:07:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku mama Kanan.
Dialogue: 0,0:07:09.17,0:07:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menjaga\NKanan-ku dengan baik.
Dialogue: 0,0:07:17.40,0:07:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan.
Dialogue: 0,0:07:20.32,0:07:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama? Ada apa?
Dialogue: 0,0:07:22.19,0:07:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi ada telepon dari papa dan mamamu.
Dialogue: 0,0:07:25.91,0:07:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa dan mama?
Dialogue: 0,0:07:28.80,0:07:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama sedih.
Dialogue: 0,0:07:30.93,0:07:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, Mama!
Dialogue: 0,0:07:32.43,0:07:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud menipu,\Nbegini... Sebenarnya...
Dialogue: 0,0:07:35.90,0:07:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama tidak sangka Kanan punya sugar daddy.
Dialogue: 0,0:07:40.59,0:07:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kamu juga punya sugar mommy!
Dialogue: 0,0:07:48.30,0:07:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian selesai!
Dialogue: 0,0:07:51.76,0:07:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Senior,\Naku bisa punya libur musim panas juga!
Dialogue: 0,0:07:55.11,0:07:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak acara seperti\Npergi ke pantai atau festival, lo.
Dialogue: 0,0:07:58.75,0:08:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya tidak sabar, ya, Senior.
Dialogue: 0,0:08:03.33,0:08:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior kenapa?
Dialogue: 0,0:08:04.63,0:08:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua berkat kamu, lo?
Dialogue: 0,0:08:07.39,0:08:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:08:14.13,0:08:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Senior kenapa?
Dialogue: 0,0:08:16.06,0:08:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak pekaan banget, ya, Manusia.
Dialogue: 0,0:08:18.77,0:08:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kesepian karena tidak bisa menemuimu\Nselama liburan.
Dialogue: 0,0:08:23.47,0:08:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggemaskan banget.
Dialogue: 0,0:08:25.26,0:08:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sembarangan!
Dialogue: 0,0:08:27.16,0:08:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencemaskan\Nternak-ternakku akan buat masalah
Dialogue: 0,0:08:30.26,0:08:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena dimabukkan\Nperasaan bebas saat liburan!
Dialogue: 0,0:08:33.03,0:08:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:08:34.74,0:08:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seks bebas?!
Dialogue: 0,0:08:35.73,0:08:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutonjok kau!
Dialogue: 0,0:08:36.94,0:08:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi juga kelihatannya senang sekali, ya?
Dialogue: 0,0:08:40.00,0:08:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sebegitu bahagianya\Nkarena terbebas dariku?
Dialogue: 0,0:08:43.27,0:08:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior bicara apa?
Dialogue: 0,0:08:45.06,0:08:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat pergi\Nke tempat-tempat tadi bersamamu, tahu.
Dialogue: 0,0:08:52.48,0:08:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior? Ada apa?
Dialogue: 0,0:08:55.30,0:08:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona disuruh pulang ke Dunia Iblis\Nselama liburan.
Dialogue: 0,0:08:59.64,0:09:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:00.69,0:09:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang?
Dialogue: 0,0:09:01.60,0:09:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kita tak bisa sering bertemu, ya.
Dialogue: 0,0:09:03.64,0:09:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku tidak pulang\Nsampai hari terakhir liburan.
Dialogue: 0,0:09:11.14,0:09:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apa aku boleh ikut denganmu?
Dialogue: 0,0:09:14.03,0:09:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:15.24,0:09:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Ada alternatif seperti itu.
Dialogue: 0,0:09:17.76,0:09:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan dulu!
Dialogue: 0,0:09:19.60,0:09:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada manusia yang masuk ke Dunia Iblis
Dialogue: 0,0:09:22.10,0:09:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuhnya akan tercabik-cabik\Ndan hancur lebur.
Dialogue: 0,0:09:24.28,0:09:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar juga.
Dialogue: 0,0:09:29.10,0:09:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku adalah keturunan yang terhormat.
Dialogue: 0,0:09:32.10,0:09:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya.
Dialogue: 0,0:09:33.69,0:09:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah kami bukan tempat yang bisa didatangi\Nmakhluk inferior sepertimu.
Dialogue: 0,0:09:38.81,0:09:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya.
Dialogue: 0,0:09:40.18,0:09:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kau memohon\Ndengan sungguh-sungguh,
Dialogue: 0,0:09:43.04,0:09:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa boleh buat, aku akan secara khusus\Nmemberikan izin kepadamu.
Dialogue: 0,0:09:46.81,0:09:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya.
Dialogue: 0,0:09:49.13,0:09:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:50.11,0:09:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan karena aku\Ningin kau pergi ke sana, ya!
Dialogue: 0,0:09:53.34,0:09:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona!
Dialogue: 0,0:09:55.13,0:09:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau. Izinkan aku pergi ke sana!
Dialogue: 0,0:09:57.71,0:10:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, kalau kau memaksa, apa boleh buat.
Dialogue: 0,0:10:01.94,0:10:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku tidak sabar!
Dialogue: 0,0:10:05.90,0:10:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nantikanlah hari itu, Makhluk Inferior.
Dialogue: 0,0:10:08.53,0:10:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, kau yakin mau\Nmengundang manusia ke Dunia Iblis?
Dialogue: 0,0:10:13.78,0:10:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku baru sadar.
Dialogue: 0,0:10:15.61,0:10:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini, Ami?
Dialogue: 0,0:10:17.82,0:10:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku\Nmengundang seseorang ke rumah.
Dialogue: 0,0:10:21.81,0:10:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus apa, ya?
Dialogue: 0,0:10:23.86,0:10:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku bukan itu.
Dialogue: 0,0:10:25.26,0:10:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Beelzebub akan bilang apa?
Dialogue: 0,0:10:27.43,0:10:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini, bagaimana ini?
Dialogue: 0,0:10:29.30,0:10:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama-tama, aku harus bereskan kamar,\Nlalu siapkan camilan.
Dialogue: 0,0:10:33.46,0:10:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kyougi suka apa, ya?\N- Coba lihat dia.
Dialogue: 0,0:10:35.41,0:10:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku harus tanya makanan kesukaannya.\N- Ekspresi wajahnya makin cerah.
Dialogue: 0,0:10:48.61,0:10:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeanne, kami duluan, ya.
Dialogue: 0,0:10:53.32,0:10:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku!
Dialogue: 0,0:10:57.91,0:11:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah beli oleh-oleh untuk semua,\Nselanjutnya...
Dialogue: 0,0:11:01.33,0:11:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang, ya.
Dialogue: 0,0:11:04.15,0:11:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang?!
Dialogue: 0,0:11:06.17,0:11:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana tidak ada tempat main\Nuntuk manusia selain danau.
Dialogue: 0,0:11:10.93,0:11:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danau. Kedengarannya seru!
Dialogue: 0,0:11:13.57,0:11:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar ingin main air.
Dialogue: 0,0:11:16.16,0:11:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:11:17.67,0:11:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:19.24,0:11:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau ada di sini?
Dialogue: 0,0:11:21.19,0:11:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok masih tanya?
Dialogue: 0,0:11:22.82,0:11:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ada Kyougi,
Dialogue: 0,0:11:26.58,0:11:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sana ada aku!
Dialogue: 0,0:11:28.97,0:11:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:11:30.26,0:11:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Rupanya Senior Kanan.
Dialogue: 0,0:11:33.17,0:11:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sedang belanja?
Dialogue: 0,0:11:35.22,0:11:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Makhluk Inferior Nadeko.
Dialogue: 0,0:11:38.57,0:11:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Makhluk Inferior.
Dialogue: 0,0:11:41.79,0:11:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa cewek cabul ini?
Dialogue: 0,0:11:43.78,0:11:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanya aku.
Dialogue: 0,0:11:58.30,0:12:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tidak usah,\Ntoh aku punya baju renang.
Dialogue: 0,0:12:01.68,0:12:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baju renang sekolah, 'kan?
Dialogue: 0,0:12:04.72,0:12:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya!
Dialogue: 0,0:12:06.09,0:12:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita pilih\Ndan saling perlihatkan baju renang?
Dialogue: 0,0:12:10.34,0:12:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus!
Dialogue: 0,0:12:12.05,0:12:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya seru!
Dialogue: 0,0:12:13.67,0:12:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?\NToh akhirnya kita perlihatkan juga.
Dialogue: 0,0:12:17.19,0:12:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi kalau di tempat seperti ini...
Dialogue: 0,0:12:20.94,0:12:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memperlihatkan baju renang itu...
Dialogue: 0,0:12:25.61,0:12:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau malu, ya?
Dialogue: 0,0:12:28.13,0:12:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Mana mungkin aku malu!
Dialogue: 0,0:12:31.04,0:12:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph!
Dialogue: 0,0:12:31.83,0:12:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperlihatkan fesyen sesungguhnya\Npada orang-orang rendahan seperti kalian!
Dialogue: 0,0:12:35.72,0:12:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, deh. Kita kumpul lagi
Dialogue: 0,0:12:38.20,0:12:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah dapat baju renangnya!
Dialogue: 0,0:12:44.38,0:12:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi suka yang bagaimana, ya?
Dialogue: 0,0:12:48.29,0:12:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku mikir apa, sih?!
Dialogue: 0,0:12:50.51,0:12:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih saja baju renang yang kau suka!
Dialogue: 0,0:12:54.95,0:12:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya ini bagus. Lucu!
Dialogue: 0,0:12:59.31,0:13:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti seru kalau buat Nona panik\Ndengan baju renang provokatif.
Dialogue: 0,0:13:04.60,0:13:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju seksi, baju seksi...
Dialogue: 0,0:13:06.63,0:13:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih baju renang seksi.
Dialogue: 0,0:13:09.03,0:13:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,\Naku juga ikut karena terbawa suasana.
Dialogue: 0,0:13:11.67,0:13:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi malu rasanya memperlihatkan\Nbaju renang pada orang lain.
Dialogue: 0,0:13:14.69,0:13:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih, Senior Kanan akan\Nmelihat tubuhku yang jelek...
Dialogue: 0,0:13:19.18,0:13:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu dulu.
Dialogue: 0,0:13:20.74,0:13:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah perasaan malu ini\Nbisa menjadi hadiah untukku?
Dialogue: 0,0:13:27.52,0:13:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ribet banget harus pilih.
Dialogue: 0,0:13:30.69,0:13:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, waktunya tampil!
Dialogue: 0,0:13:33.44,0:13:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya!
Dialogue: 0,0:13:35.53,0:13:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai dari Ami!
Dialogue: 0,0:13:39.13,0:13:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perpaduan baju renang putih dan kulit gelap.
Dialogue: 0,0:13:42.91,0:13:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kilau cincin emas\Nyang memberikan kesan dewasa!
Dialogue: 0,0:13:46.64,0:13:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren banget!
Dialogue: 0,0:13:48.32,0:13:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Masurao...
Dialogue: 0,0:13:51.18,0:13:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang hitam yang berani...
Dialogue: 0,0:13:52.66,0:13:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih tepatnya, busana BDSM?
Dialogue: 0,0:13:56.60,0:14:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin diseret Senior\Nke berbagai tempat pakai ini.
Dialogue: 0,0:14:00.77,0:14:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan teman kecilku jadi seperti ini?
Dialogue: 0,0:14:04.72,0:14:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, selanjutnya. Jeanne.
Dialogue: 0,0:14:07.53,0:14:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:08.91,0:14:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... E-Ehm...
Dialogue: 0,0:14:12.62,0:14:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:14:14.07,0:14:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Babi?\N- Bukan.
Dialogue: 0,0:14:15.72,0:14:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Penjaga.
Dialogue: 0,0:14:16.84,0:14:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelanggan ini memintaku\Nmemilihkan gaya baju renang untuknya.
Dialogue: 0,0:14:21.55,0:14:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena aku gondok\Ndengan tubuh ranum yang sempurnanya,
Dialogue: 0,0:14:25.02,0:14:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sengaja memilih yang ini\Ndengan penuh dendam.
Dialogue: 0,0:14:27.75,0:14:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, ini bukan babi.
Dialogue: 0,0:14:29.71,0:14:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi daging ham tanpa tulang!
Dialogue: 0,0:14:31.93,0:14:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak ngeri.
Dialogue: 0,0:14:35.81,0:14:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin makan daging ham.
Dialogue: 0,0:14:38.04,0:14:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal Nona saja, lo!
Dialogue: 0,0:14:40.95,0:14:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu sebentar.
Dialogue: 0,0:14:44.35,0:14:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?\NMereka semua kelihatan dewasa.
Dialogue: 0,0:14:46.98,0:14:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa semuanya pilih\Npakaian bergaya dewasa?
Dialogue: 0,0:14:49.76,0:14:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di luar dugaanku.
Dialogue: 0,0:14:51.32,0:14:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa baju renang pilihanku benar-benar...
Dialogue: 0,0:14:54.49,0:14:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang pilihan iblis itu\Nyang bagaimana, ya?
Dialogue: 0,0:14:57.75,0:14:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti yang desainnya agresif.
Dialogue: 0,0:15:00.42,0:15:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspektasinya tinggi banget!
Dialogue: 0,0:15:02.67,0:15:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, kita buka saja.
Dialogue: 0,0:15:03.90,0:15:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tung... Jangan!
Dialogue: 0,0:15:08.07,0:15:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk ukuran iblis, ini manis banget.
Dialogue: 0,0:15:11.07,0:15:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, begini... Bagaimana bilangnya, ya?
Dialogue: 0,0:15:14.90,0:15:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?\NAku paham tanpa perlu kau katakan langsung.
Dialogue: 0,0:15:18.39,0:15:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kekanakan...
Dialogue: 0,0:15:19.74,0:15:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut banget!
Dialogue: 0,0:15:22.61,0:15:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keimutan dari kulit yang tertutup kain!
Dialogue: 0,0:15:25.13,0:15:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior yang menang! Senior pemenangnya!
Dialogue: 0,0:15:29.53,0:15:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?
Dialogue: 0,0:15:30.38,0:15:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, kamu imut banget!
Dialogue: 0,0:15:40.58,0:15:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi macam apa itu?
Dialogue: 0,0:16:15.34,0:16:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata masih ada kereta selarut ini.
Dialogue: 0,0:16:17.79,0:16:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kereta pribadi yang langsung\Nmenuju kediaman Zebul.
Dialogue: 0,0:16:20.59,0:16:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian carter?
Dialogue: 0,0:16:21.97,0:16:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:16:40.63,0:16:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan di luar indah sekali.
Dialogue: 0,0:16:42.85,0:16:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kenapa kau ada di sini?
Dialogue: 0,0:16:57.27,0:16:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku mau ke toilet.
Dialogue: 0,0:17:00.07,0:17:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku malu bilang toilet di depan Kyougi.
Dialogue: 0,0:17:03.99,0:17:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus tutupi pakai apa, ya?
Dialogue: 0,0:17:06.60,0:17:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan terlihat gelisah.
Dialogue: 0,0:17:08.76,0:17:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan,\Ndia ingin lakukan sesuatu pada Kyougi?
Dialogue: 0,0:17:11.82,0:17:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ingin pergi buang air kecil,
Dialogue: 0,0:17:14.15,0:17:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak boleh pergi sekarang.
Dialogue: 0,0:17:16.84,0:17:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona dan Santa sedang menahan buang air!
Dialogue: 0,0:17:20.24,0:17:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Lucu banget.
Dialogue: 0,0:17:21.47,0:17:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak boleh lewatkan meski\Nharus sampai menahan buang air!
Dialogue: 0,0:17:31.94,0:17:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa. Mau pipis...
Dialogue: 0,0:17:34.18,0:17:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:17:35.11,0:17:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka. Dia akan pergi duluan!
Dialogue: 0,0:17:38.36,0:17:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin, Santa?
Dialogue: 0,0:17:40.92,0:17:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin mau mengalihkan\Npandangan dariku dan Kyougi?
Dialogue: 0,0:17:44.96,0:17:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tandai jiwanya, lo.
Dialogue: 0,0:17:53.88,0:17:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Selagi ada kesempatan,\Naku akan pergi dengan santai...
Dialogue: 0,0:17:57.49,0:17:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi dengan santai...
Dialogue: 0,0:17:58.66,0:18:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior mau ke mana?
Dialogue: 0,0:18:02.66,0:18:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ambil barangku.
Dialogue: 0,0:18:05.02,0:18:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang ambilkan. Senior duduk saja.
Dialogue: 0,0:18:08.21,0:18:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Kyougi, baca situasinya, dong!
Dialogue: 0,0:18:12.46,0:18:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah di ujung tanduk,
Dialogue: 0,0:18:14.41,0:18:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai sedikit saja terdorong\Nbisa langsung keluar, tahu.
Dialogue: 0,0:18:17.16,0:18:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ransel ini, ya.
Dialogue: 0,0:18:18.90,0:18:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:18:19.97,0:18:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan simpan di sana!
Dialogue: 0,0:18:23.09,0:18:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior baik-baik saja?
Dialogue: 0,0:18:25.20,0:18:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kocak banget!
Dialogue: 0,0:18:27.99,0:18:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, deh. Karena aku sudah lumayan terhibur,
Dialogue: 0,0:18:31.46,0:18:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami mau pamit ke toilet sebentar.
Dialogue: 0,0:18:37.07,0:18:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku!
Dialogue: 0,0:18:49.78,0:18:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang paham kenapa,\Ntapi mereka kelihatan tegang.
Dialogue: 0,0:18:54.86,0:18:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cairkan suasananya!
Dialogue: 0,0:18:57.37,0:19:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya. Kalau kalian mau, silakan diminum!
Dialogue: 0,0:19:01.19,0:19:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:19:03.17,0:19:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kopi.
Dialogue: 0,0:19:04.34,0:19:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek diuretik?!
Dialogue: 0,0:19:08.91,0:19:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku buatkan sepenuh hati\Ndengan biji kualitas tinggi
Dialogue: 0,0:19:11.20,0:19:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya Senior bisa minum dengan nikmat.
Dialogue: 0,0:19:14.59,0:19:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang, sih! Aku senang, sih...!
Dialogue: 0,0:19:17.15,0:19:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan. Karena masih hangat,\Nbisa sekalian buat hati rileks.
Dialogue: 0,0:19:20.66,0:19:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru tidak boleh rileks!
Dialogue: 0,0:19:23.06,0:19:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan diminum!
Dialogue: 0,0:19:24.79,0:19:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyumnya polos banget!
Dialogue: 0,0:19:26.52,0:19:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menolaknya!
Dialogue: 0,0:19:29.24,0:19:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sudahlah!
Dialogue: 0,0:19:31.04,0:19:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya perlu minum ini, 'kan?!
Dialogue: 0,0:19:35.88,0:19:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget!
Dialogue: 0,0:19:38.48,0:19:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harum buah berkualitas\Ntinggi dan pahit yang kaya rasa,
Dialogue: 0,0:19:41.59,0:19:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diikuti sensasi akhir yang menyegarkan.
Dialogue: 0,0:19:43.46,0:19:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa yang benar-benar bisa buat rileks!
Dialogue: 0,0:19:47.42,0:19:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otot sfingter uretra eksternalku pun\Nikut rileks...
Dialogue: 0,0:19:51.62,0:19:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior sampai terharu karena kopiku.
Dialogue: 0,0:19:54.22,0:19:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senangnya!
Dialogue: 0,0:19:55.72,0:19:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku paham perasaan orang\Nyang buatkan bekal untuk pacarnya.
Dialogue: 0,0:19:59.35,0:20:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku dipenuhi kebahagiaan.
Dialogue: 0,0:20:00.88,0:20:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah penuh\Nsampai hampir tumpah, tahu!
Dialogue: 0,0:20:03.57,0:20:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau bilang kualitas tinggi,\Naku jadi minum.
Dialogue: 0,0:20:07.55,0:20:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Tuhan. Apakah ini cobaan?
Dialogue: 0,0:20:11.19,0:20:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kakiku...
Dialogue: 0,0:20:14.12,0:20:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sangka kalian mau\Nminum dengan senang hati.
Dialogue: 0,0:20:17.37,0:20:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sia-sia aku berusaha menyeduh itu.
Dialogue: 0,0:20:19.62,0:20:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kyougi.
Dialogue: 0,0:20:21.91,0:20:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:20:23.43,0:20:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku sampai di sini saja.
Dialogue: 0,0:20:26.89,0:20:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu pucat, lo.\NSenior baik-baik saja?
Dialogue: 0,0:20:29.54,0:20:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan guncang-guncang tubuhku.
Dialogue: 0,0:20:31.28,0:20:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kandung kemihku bereaksi...!
Dialogue: 0,0:20:33.98,0:20:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:20:36.01,0:20:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi padaku,\Nkau tetap menerimaku apa adanya, 'kan?
Dialogue: 0,0:20:43.67,0:20:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku!
Dialogue: 0,0:20:45.54,0:20:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terima apa pun itu!
Dialogue: 0,0:20:47.51,0:20:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab langsung, ya.
Dialogue: 0,0:20:49.38,0:20:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih? Kau keren juga.
Dialogue: 0,0:20:53.17,0:20:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:54.86,0:20:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah...
Dialogue: 0,0:21:03.55,0:21:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu sok keren, ya?
Dialogue: 0,0:21:06.06,0:21:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini jadi agak panas,\Naku mau dinginkan kepala dulu
Dialogue: 0,0:21:10.40,0:21:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di toilet.
Dialogue: 0,0:21:35.48,0:21:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perang sengit yang mempertaruhkan\Nharga diri wanita pun berakhir.
Dialogue: 0,0:23:12.71,0:23:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, eh. Miel, kau tahu?
Dialogue: 0,0:23:15.93,0:23:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:23:17.56,0:23:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, Kakak akan pulang dekat-dekat ini.
Dialogue: 0,0:23:23.50,0:23:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?
Dialogue: 0,0:23:24.26,0:23:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga bawa pacarnya.
Dialogue: 0,0:23:28.78,0:23:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak punya pacar?\NKocak banget.
Dialogue: 0,0:23:32.53,0:23:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti apa, ya?
