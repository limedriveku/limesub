Dialogue: 0,0:03:08.70,0:03:09.86,tanda,,0000,0000,0000,,#07 LIBUR MUSIM PANAS KANAN
Dialogue: 0,0:15:51.76,0:15:54.76,tanda,,0000,0000,0000,,PUKUL 3.33 - DARI STASIUN KUCHINOMIZO
Dialogue: 0,0:16:09.78,0:16:12.78,tanda,,0000,0000,0000,,KERETA DUNIA IBLIS - MENUJU DUNIA IBLIS
Dialogue: 0,0:16:45.19,0:16:48.19,tanda,,0000,0000,0000,,TAK ADA YANG MENYANGKA BAHWA\NSEBUAH INSIDEN BESAR AKAN SEGERA TERJADI
Dialogue: 0,0:16:54.45,0:16:56.70,tanda,,0000,0000,0000,,RASA INGIN BUANG AIR KECIL
Dialogue: 0,0:18:01.10,0:18:02.32,tanda,,0000,0000,0000,,- A...\N- A?
