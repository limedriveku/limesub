Dialogue: 0,0:02:46.02,0:02:49.77,tanda,,0000,0000,0000,,#05 KANAN DAN SANTA\NRUANG UKS
Dialogue: 0,0:04:01.72,0:04:02.38,tanda,,0000,0000,0000,,DIA HALU TINGKAT AKUT.\NIKUTI SAJA, NANTI JUGA BOSAN SENDIRI.
Dialogue: 0,0:04:25.99,0:04:29.47,tanda,,0000,0000,0000,,"AIR SUCI DARI KAKI GUNUNG FUJI"
Dialogue: 0,0:10:26.81,0:10:30.02,tanda,,0000,0000,0000,,AH... TERNYATA BENAR.
Dialogue: 0,0:14:06.70,0:14:08.45,tanda,,0000,0000,0000,,RUANG KOMITE DISIPLIN
Dialogue: 0,0:16:34.30,0:16:35.17,tanda,,0000,0000,0000,,TENANG - MEJA INFORMASI\NMENUJU SURGA - AMAN
Dialogue: 0,0:21:02.90,0:21:04.95,tanda,,0000,0000,0000,,JEANNE PUN MENANGIS.
Dialogue: 0,0:21:04.95,0:21:08.16,tanda,,0000,0000,0000,,WALAU DIA TIDAK TAHU KENAPA\NDIA MENANGIS,
Dialogue: 0,0:21:08.16,0:21:10.91,tanda,,0000,0000,0000,,TETES AIR MATA YANG JATUH DARI\NMATA SANG SANTA,
Dialogue: 0,0:21:10.91,0:21:16.50,tanda,,0000,0000,0000,,MENJADI HUJAN YANG MENCERITAKAN\NBERAKHIRNYA MASA REMAJA SEORANG GADIS.
Dialogue: 0,0:00:04.68,0:00:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai kelas perwaliannya, ya.
Dialogue: 0,0:00:07.81,0:00:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, Ibu akan kenalkan siswi pindahan.
Dialogue: 0,0:00:11.22,0:00:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:00:12.44,0:00:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendadak sekali, ya.
Dialogue: 0,0:00:31.53,0:00:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, silakan perkenalkan dirimu.
Dialogue: 0,0:00:40.58,0:00:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Anak Baru?
Dialogue: 0,0:00:42.61,0:00:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, akhirnya...
Dialogue: 0,0:00:45.96,0:00:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertemu dengan...
Dialogue: 0,0:00:50.35,0:00:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:00:52.72,0:00:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita bertemu juga!\NKau bisa tenang sekarang,
Dialogue: 0,0:00:56.03,0:00:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku akan melindungimu, Kyougi.
Dialogue: 0,0:00:59.38,0:01:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melindungiku dari apa?
Dialogue: 0,0:01:01.72,0:01:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari iblis.
Dialogue: 0,0:01:03.28,0:01:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iblis...?
Dialogue: 0,0:01:06.32,0:01:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum membahas itu,\Ncelana dalammu kelihatan, lo.
Dialogue: 0,0:01:09.67,0:01:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya celana dalam\Ntidak boleh kelihatan, ya?
Dialogue: 0,0:01:12.41,0:01:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh banget, kok.
Dialogue: 0,0:01:13.41,0:01:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat, jangan perlihatkan juga!
Dialogue: 0,0:02:55.46,0:02:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:02:57.44,0:02:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya anak ini kenapa?
Dialogue: 0,0:02:59.88,0:03:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tiba-tiba membahas\Nsoal iblis dan sebagainya di kelas.
Dialogue: 0,0:03:03.87,0:03:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kubawa ke UKS untuk berjaga-jaga.
Dialogue: 0,0:03:05.86,0:03:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:03:06.90,0:03:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:03:08.61,0:03:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah utusan Tuhan\Nyang turun dari surga, Jeanne.
Dialogue: 0,0:03:13.93,0:03:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:03:15.23,0:03:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwamu benar-benar murni nan indah.
Dialogue: 0,0:03:18.38,0:03:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahayanya memiliki potensi\Nuntuk menjadi santo di masa depan.
Dialogue: 0,0:03:22.04,0:03:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surga begitu antusias\Nmenyambut santo seperti dirimu.
Dialogue: 0,0:03:26.81,0:03:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada masalah.
Dialogue: 0,0:03:28.06,0:03:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada iblis yang mengincar jiwamu.
Dialogue: 0,0:03:31.54,0:03:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak apa-apa.
Dialogue: 0,0:03:33.17,0:03:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak perlu takut.
Dialogue: 0,0:03:35.43,0:03:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena, aku akan melindungimu.
Dialogue: 0,0:03:44.56,0:03:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:03:45.49,0:03:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diterima begitu saja?!
Dialogue: 0,0:03:46.87,0:03:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa masih heran?
Dialogue: 0,0:03:49.09,0:03:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang berada dalam bahaya, lo?
Dialogue: 0,0:03:53.01,0:03:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu serius?
Dialogue: 0,0:03:54.80,0:03:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada iblis yang mengincar jiwamu, lo.
Dialogue: 0,0:03:58.01,0:04:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kau turuti perkataannya.
Dialogue: 0,0:04:02.42,0:04:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta dia melindungimu.
Dialogue: 0,0:04:03.98,0:04:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:04:09.33,0:04:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Mari lakukan ritual\Nuntuk melindungimu dari iblis.
Dialogue: 0,0:04:14.30,0:04:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jelaskan detailnya?
Dialogue: 0,0:04:18.72,0:04:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lupa detail ritualnya,
Dialogue: 0,0:04:22.02,0:04:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hanya perlu mencipratkan\Nair suci yang ada...
Dialogue: 0,0:04:25.99,0:04:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Air sucinya sudah habis, ya.
Dialogue: 0,0:04:29.82,0:04:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Repot juga.
Dialogue: 0,0:04:31.45,0:04:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sudahlah.
Dialogue: 0,0:04:33.17,0:04:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini, cairan apa pun boleh.
Dialogue: 0,0:04:36.80,0:04:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:39.33,0:04:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kamu mau pakai cairan apa?
Dialogue: 0,0:04:41.58,0:04:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surga memintaku menandai\NKyougi dengan air liur.
Dialogue: 0,0:04:46.53,0:04:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kamu salah paham, deh?!
Dialogue: 0,0:04:48.36,0:04:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu tutup gordennya, ya.
Dialogue: 0,0:04:50.26,0:04:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru, jangan tinggalkan aku!
Dialogue: 0,0:04:52.44,0:04:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau tidak lakukan ini,
Dialogue: 0,0:04:54.32,0:04:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak akan terlindungi dari iblis,\Natau pindah ke agama kami.
Dialogue: 0,0:04:57.62,0:05:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan kamu bilang ingin\Nmembuatku pindah agama, ya?
Dialogue: 0,0:05:00.38,0:05:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan pindah agama!
Dialogue: 0,0:05:02.24,0:05:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:05.04,0:05:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:05:06.80,0:05:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa tidak mau masuk?! Masuk, dong!\N- Apa? Ada apa?
Dialogue: 0,0:05:09.78,0:05:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau tidak masuk, aku...
Dialogue: 0,0:05:12.14,0:05:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa pergi ke surga!
Dialogue: 0,0:05:14.71,0:05:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi ke surga bersama!
Dialogue: 0,0:05:17.32,0:05:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan tak senonoh dengan lawan jenis!
Dialogue: 0,0:05:19.71,0:05:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo pergi, ayo pergi.\N- Ah,
Dialogue: 0,0:05:21.06,0:05:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku akan pergi bersamamu.\N- mereka sedang asyik, tolong jangan ganggu.
Dialogue: 0,0:05:23.19,0:05:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:05:23.70,0:05:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi!
Dialogue: 0,0:05:24.58,0:05:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku\Nmembiarkan mereka lakukan itu!
Dialogue: 0,0:05:26.97,0:05:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi. Ayolah.
Dialogue: 0,0:05:29.08,0:05:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lakukan perbuatan tidak senonoh
Dialogue: 0,0:05:32.05,0:05:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di peternakanku!
Dialogue: 0,0:05:42.00,0:05:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupotong.
Dialogue: 0,0:05:43.30,0:05:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian apa?
Dialogue: 0,0:05:44.39,0:05:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K-Ke surga...
Dialogue: 0,0:05:50.69,0:05:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:05:53.84,0:05:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei, tung... Kyougi?
Dialogue: 0,0:05:56.70,0:05:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... Aku ketakutan!
Dialogue: 0,0:05:59.25,0:06:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Bukannya terbalik?\NKau yang diserang?
Dialogue: 0,0:06:01.81,0:06:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya.
Dialogue: 0,0:06:03.73,0:06:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, siapa perempuan ini?
Dialogue: 0,0:06:07.00,0:06:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya hubungan apa dengannya?
Dialogue: 0,0:06:08.74,0:06:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab aku, Makhluk Inferior.
Dialogue: 0,0:06:11.07,0:06:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku juga tak tahu apa-apa.
Dialogue: 0,0:06:13.72,0:06:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kenapa dia pingsan?
Dialogue: 0,0:06:24.55,0:06:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lapar.
Dialogue: 0,0:06:35.15,0:06:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makannya lahap juga, ya.
Dialogue: 0,0:06:40.21,0:06:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya perempuan ini?
Dialogue: 0,0:06:42.47,0:06:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku merasakan\Nkekuatan suci darinya...
Dialogue: 0,0:06:45.04,0:06:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malaikat, ya?
Dialogue: 0,0:06:47.01,0:06:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, aku ketahuan.
Dialogue: 0,0:06:48.69,0:06:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana peternakan jiwaku ini?!
Dialogue: 0,0:06:52.67,0:06:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kenyang.
Dialogue: 0,0:06:54.27,0:06:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan baik seperti malaikat.
Dialogue: 0,0:06:56.25,0:06:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak ketahuan.
Dialogue: 0,0:06:58.32,0:06:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?
Dialogue: 0,0:07:01.14,0:07:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menempeli Kyougi?
Dialogue: 0,0:07:06.92,0:07:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Jeanne.
Dialogue: 0,0:07:09.46,0:07:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah utusan dari surga\Nyang diperintahkan Malaikat Agung
Dialogue: 0,0:07:13.85,0:07:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk turun ke dunia\Ndan melindungi Kyougi dari iblis.
Dialogue: 0,0:07:16.92,0:07:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang dari surga!
Dialogue: 0,0:07:19.15,0:07:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah ketahuan, ya.
Dialogue: 0,0:07:21.15,0:07:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari surga?
Dialogue: 0,0:07:22.55,0:07:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau diperhatikan, kamu tidak punya\Nmahkota cahaya dan sayap, ya.
Dialogue: 0,0:07:26.25,0:07:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, itu detail penting saat cosplay.
Dialogue: 0,0:07:30.04,0:07:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cosplay?
Dialogue: 0,0:07:31.54,0:07:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang paham perkataanmu,\Ntapi aku bukan malaikat.
Dialogue: 0,0:07:37.60,0:07:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, orang yang turun dari surga\Npunya ukiran lambang suci di tubuhnya.
Dialogue: 0,0:07:42.25,0:07:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buktinya.
Dialogue: 0,0:07:43.56,0:07:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu. Berhenti, berhenti!
Dialogue: 0,0:07:45.97,0:07:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau mengangkat rokmu?
Dialogue: 0,0:07:48.26,0:07:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena lambang sucinya ada di bawah pusar...
Dialogue: 0,0:07:50.62,0:07:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu kau perlihatkan!
Dialogue: 0,0:07:52.25,0:07:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celana dalammu sampai kelihatan, tahu!
Dialogue: 0,0:07:54.70,0:07:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya di mana?
Dialogue: 0,0:07:56.18,0:07:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urat malumu sudah putus atau apa?!
Dialogue: 0,0:07:58.79,0:08:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi harus kulakukan supaya Kyougi percaya.
Dialogue: 0,0:08:02.37,0:08:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsep itu memang penting.
Dialogue: 0,0:08:04.09,0:08:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam kau, Makhluk Inferior!
Dialogue: 0,0:08:06.44,0:08:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini.
Dialogue: 0,0:08:08.69,0:08:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hobi aneh apa yang digemari\Nkeparat-keparat di Surga?!
Dialogue: 0,0:08:12.52,0:08:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior dan Jeanne suka cosplay, ya.
Dialogue: 0,0:08:15.86,0:08:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau sudah percaya padaku?
Dialogue: 0,0:08:18.29,0:08:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:18.84,0:08:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi masih mengira aku hanya cosplay?
Dialogue: 0,0:08:22.61,0:08:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungimu\Ndengan seluruh limpahan kasih sayangku.
Dialogue: 0,0:08:28.31,0:08:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan benamkan wajahnya di\Ngumpalan daging itu. Wanita mesum, ya?
Dialogue: 0,0:08:31.56,0:08:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita mesum?!
Dialogue: 0,0:08:33.63,0:08:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu apa, ya?
Dialogue: 0,0:08:35.55,0:08:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi itu punyaku!
Dialogue: 0,0:08:37.90,0:08:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kuserahkan!
Dialogue: 0,0:08:41.66,0:08:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:08:42.90,0:08:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu, jangan salah paham!
Dialogue: 0,0:08:44.35,0:08:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, kau propertiku.
Dialogue: 0,0:08:46.45,0:08:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak ada makna khusus atau aneh-aneh...\N- "Milikku"?
Dialogue: 0,0:08:51.55,0:08:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya apa?
Dialogue: 0,0:08:54.19,0:08:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin merebut orang\Nyang mendapat perlindungan dari surga?
Dialogue: 0,0:08:59.40,0:09:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kau sebenarnya...
Dialogue: 0,0:09:02.51,0:09:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka. Dia sadar kalau aku iblis, ya?
Dialogue: 0,0:09:05.11,0:09:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini,\Naku harus pakai kekerasan!
Dialogue: 0,0:09:08.06,0:09:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mencintai Kyougi, ya?
Dialogue: 0,0:09:12.79,0:09:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta!
Dialogue: 0,0:09:13.88,0:09:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, betapa menakjubkan!
Dialogue: 0,0:09:17.25,0:09:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuhanku, mohon berikan restu\Nkepada mereka berdua.
Dialogue: 0,0:09:20.79,0:09:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu wajah iblisnya seperti apa, 'kan?
Dialogue: 0,0:09:24.26,0:09:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:09:25.50,0:09:27.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya fotonya.
Dialogue: 0,0:09:28.11,0:09:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:09:38.14,0:09:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis!
Dialogue: 0,0:09:39.40,0:09:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telat banget kagetnya!
Dialogue: 0,0:09:41.43,0:09:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, bahaya!
Dialogue: 0,0:09:45.20,0:09:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:09:46.25,0:09:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan benamkan wajahnya di dadamu,\NWanita Mesum!
Dialogue: 0,0:09:48.47,0:09:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan kau menggoda Kyougi!
Dialogue: 0,0:09:51.85,0:09:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kau yang sedang menggodanya?!
Dialogue: 0,0:09:57.38,0:09:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoki pria cabul juga ada batasannya, tahu!
Dialogue: 0,0:10:01.02,0:10:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabul itu apa?
Dialogue: 0,0:10:04.16,0:10:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang yang cabul bisa dapat sesuatu, ya?
Dialogue: 0,0:10:07.08,0:10:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ca-Cabul itu, ya cabul.
Dialogue: 0,0:10:09.70,0:10:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau menyesatkan Kyougi\Ndengan perbuatan tidak bermoral...
Dialogue: 0,0:10:13.24,0:10:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau... kau...
Dialogue: 0,0:10:15.80,0:10:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar iblis!
Dialogue: 0,0:10:23.08,0:10:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iblisnya?!
Dialogue: 0,0:10:32.66,0:10:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau mengikuti kami, sih?
Dialogue: 0,0:10:36.95,0:10:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membimbing Kyougi\Nmenuju jalan yang benar!
Dialogue: 0,0:10:40.65,0:10:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak terlalu paham situasi ini...
Dialogue: 0,0:10:43.67,0:10:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku...
Dialogue: 0,0:10:44.96,0:10:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur kau!
Dialogue: 0,0:10:46.44,0:10:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau saja yang mundur!
Dialogue: 0,0:10:49.48,0:10:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah masuk ke masa populer.
Dialogue: 0,0:10:52.58,0:10:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:10:54.04,0:10:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita pulang bersama saja?
Dialogue: 0,0:10:56.70,0:10:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?!\N- Apa?
Dialogue: 0,0:10:58.24,0:10:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:10:59.42,0:11:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau sudah\Nditaklukkan godaan iblis ini.
Dialogue: 0,0:11:04.04,0:11:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak apa-apa!
Dialogue: 0,0:11:07.23,0:11:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kasih sayangku\Nyang begitu melimpah...
Dialogue: 0,0:11:10.49,0:11:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan itu!
Dialogue: 0,0:11:12.20,0:11:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai budak Tuhan,
Dialogue: 0,0:11:13.47,0:11:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}izinkan aku membimbingmu\Nke jalan iman yang penuh kenikmatan!
Dialogue: 0,0:11:17.34,0:11:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Budak? Kenikmatan?\NPemilihan katamu aneh banget!
Dialogue: 0,0:11:21.50,0:11:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berangkat, Kyougi.
Dialogue: 0,0:11:23.38,0:11:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berangkat ke jalan suci!
Dialogue: 0,0:11:32.59,0:11:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perempuan itu...!
Dialogue: 0,0:11:35.80,0:11:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku belum pernah\Ngandengan dengan Kyougi.
Dialogue: 0,0:11:39.74,0:11:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya dia merebut\Ngenggaman pertama dariku!
Dialogue: 0,0:11:44.23,0:11:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur!
Dialogue: 0,0:11:47.98,0:11:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesal.
Dialogue: 0,0:11:49.09,0:11:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya santa mesum itu mendahuluiku.
Dialogue: 0,0:11:52.16,0:11:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah atas\Nharga diri bangsa iblis...
Dialogue: 0,0:11:54.80,0:11:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga... Aku juga...!
Dialogue: 0,0:11:57.62,0:12:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan menggandeng tangannya!
Dialogue: 0,0:12:04.45,0:12:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gandeng tangan?
Dialogue: 0,0:12:05.91,0:12:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku akhirnya akan menggandeng tangannya?
Dialogue: 0,0:12:08.11,0:12:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:12:09.19,0:12:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau aku hamil karena gandengan?
Dialogue: 0,0:12:11.93,0:12:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini bukan waktunya ragu.
Dialogue: 0,0:12:16.82,0:12:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu punya nyali!
Dialogue: 0,0:12:18.74,0:12:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak peduli lagi!
Dialogue: 0,0:12:25.61,0:12:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:12:28.27,0:12:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar iblis yang keji.
Dialogue: 0,0:12:31.13,0:12:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memberi kutukan tubuh kaku padaku, ya?
Dialogue: 0,0:12:35.41,0:12:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebaskan aku sekarang juga!
Dialogue: 0,0:12:38.06,0:12:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa tersangkut di sana?
Dialogue: 0,0:12:40.45,0:12:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa maju...
Dialogue: 0,0:12:42.93,0:12:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selangkanganmu jadi terlihat\Nseperti pakai leotard, lo?!
Dialogue: 0,0:12:48.23,0:12:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar gadis memalukan.
Dialogue: 0,0:12:50.40,0:12:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bantu lepaskan,\Njadi jangan banyak bergerak.
Dialogue: 0,0:12:53.57,0:12:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyerah!
Dialogue: 0,0:12:55.75,0:12:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah menyerahkan\Ntubuh ini kepada Tuhan.
Dialogue: 0,0:12:58.39,0:13:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan kalah dari iblis...!
Dialogue: 0,0:13:01.40,0:13:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang rendahan, hina,\Ndan berkepribadian buruk!
Dialogue: 0,0:13:07.45,0:13:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garis selangkanganku!
Dialogue: 0,0:13:09.94,0:13:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selangkanganku sakit.
Dialogue: 0,0:13:12.36,0:13:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak akan kalah\Ndi hadapan kekuatan iblis!
Dialogue: 0,0:13:17.22,0:13:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Tuhanku.\NMohon berikan berkat-Mu kepadaku!
Dialogue: 0,0:13:21.04,0:13:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berhenti.\NKalau ditarik sekencang itu...
Dialogue: 0,0:13:44.55,0:13:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah dinodai iblis.
Dialogue: 0,0:13:47.74,0:13:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekadar informasi, yang tadi itu kebanyakan\Nkarena salahmu sendiri.
Dialogue: 0,0:13:52.05,0:13:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku akan membiarkanmu\Npergi untuk hari ini.
Dialogue: 0,0:13:55.49,0:13:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu pembalasanku, dasar iblis!
Dialogue: 0,0:13:58.28,0:14:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, selangkanganku sakit.
Dialogue: 0,0:14:09.76,0:14:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata siap!
Dialogue: 0,0:14:11.10,0:14:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barikade siap!
Dialogue: 0,0:14:12.68,0:14:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umpan juga siap!
Dialogue: 0,0:14:14.64,0:14:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah menerima hukuman\Nkarena sudah merebut
Dialogue: 0,0:14:17.01,0:14:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}genggaman pertama Kyougi dariku,\NSanta Mesum!
Dialogue: 0,0:14:23.02,0:14:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu!
Dialogue: 0,0:14:24.34,0:14:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai putri Iblis Agung Beelzebub,\Naku harus menghajar utusan dari Surga!
Dialogue: 0,0:14:29.64,0:14:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak terlalu paham, sih,
Dialogue: 0,0:14:31.39,0:14:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku berguna untuk Senior, 'kan?
Dialogue: 0,0:14:34.06,0:14:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau berguna.
Dialogue: 0,0:14:38.22,0:14:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka Nona ketahuan\Npara malaikat itu.
Dialogue: 0,0:14:44.58,0:14:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, aku siap dari mana pun kau datang!
Dialogue: 0,0:14:51.53,0:14:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup.
Dialogue: 0,0:14:58.81,0:15:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jam pulang sekolah sudah tiba.
Dialogue: 0,0:15:01.12,0:15:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi siswa yang masih di sekolah,\Nharap segera pulang.
Dialogue: 0,0:15:09.00,0:15:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia tidak masuk sekolah?!
Dialogue: 0,0:15:16.45,0:15:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak datang,\Nbiar aku saja yang hampiri!
Dialogue: 0,0:15:19.21,0:15:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami, kau yakin rumahnya\Nada di daerah ini, 'kan?
Dialogue: 0,0:15:22.67,0:15:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut intel kita, sih, betul.
Dialogue: 0,0:15:25.88,0:15:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, tak kusangka rumah\Ntempat utusan surga bersembunyi
Dialogue: 0,0:15:31.31,0:15:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah rumah dari kardus.
Dialogue: 0,0:15:33.79,0:15:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Surga sedang kekurangan dana, ya?
Dialogue: 0,0:15:42.78,0:15:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Santa.
Dialogue: 0,0:15:45.10,0:15:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku...
Dialogue: 0,0:15:46.61,0:15:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku sudah terlambat untuk bertobat?
Dialogue: 0,0:15:49.25,0:15:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai putra tanpa rumah\Nyang mengakui dosanya...
Dialogue: 0,0:15:53.36,0:15:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuhan pasti akan mengampunimu.
Dialogue: 0,0:15:58.12,0:16:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Santa, terima kasih banyak.
Dialogue: 0,0:16:01.28,0:16:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, ini pengganti sumbangan.
Dialogue: 0,0:16:04.51,0:16:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, makanan. Terima kasih banyak.
Dialogue: 0,0:16:13.60,0:16:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oishii Bou. Aku suka stik ini.
Dialogue: 0,0:16:17.40,0:16:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumbangannya murah banget.
Dialogue: 0,0:16:19.72,0:16:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis?! Kenapa ada di sini?
Dialogue: 0,0:16:21.94,0:16:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri sedang apa di sini\Nsampai mengabaikan Kyougi?
Dialogue: 0,0:16:25.96,0:16:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:28.16,0:16:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang...
Dialogue: 0,0:16:30.11,0:16:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:16:31.28,0:16:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya...
Dialogue: 0,0:16:32.54,0:16:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya berhenti makan dulu.
Dialogue: 0,0:16:35.22,0:16:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku membimbing\Ndomba-domba yang tersesat,
Dialogue: 0,0:16:38.66,0:16:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak sekali orang yang berkumpul.
Dialogue: 0,0:16:41.94,0:16:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:16:42.91,0:16:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kak. Jangan menyerobot antrean, ya.
Dialogue: 0,0:16:46.59,0:16:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah mengantre\Nselama berjam-jam, tahu!
Dialogue: 0,0:16:49.92,0:16:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:16:50.85,0:16:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami semua...
Dialogue: 0,0:16:52.91,0:16:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah diselamatkan oleh Nona Santa ini.
Dialogue: 0,0:16:56.42,0:16:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang seperti kami, lo!
Dialogue: 0,0:16:58.84,0:17:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Santa itu, ya...
Dialogue: 0,0:17:01.41,0:17:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa, sih?
Dialogue: 0,0:17:03.54,0:17:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyemangati kami di atas pahanya\Nyang empuk itu.
Dialogue: 0,0:17:08.01,0:17:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lakukan banyak dosa\Nyang tak ingin kulakukan
Dialogue: 0,0:17:09.95,0:17:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya bisa mengakui dosa berulang kali.
Dialogue: 0,0:17:12.86,0:17:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubar kalian, dasar jiwa-jiwa hina dina!
Dialogue: 0,0:17:16.53,0:17:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubar! Pergi!
Dialogue: 0,0:17:18.21,0:17:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyah! Lenyap!
Dialogue: 0,0:17:20.24,0:17:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Minggir! Pergi ke sana!\N- Tunggu!
Dialogue: 0,0:17:22.28,0:17:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:17:23.28,0:17:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hus, hus!
Dialogue: 0,0:17:28.43,0:17:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumber makananku...
Dialogue: 0,0:17:31.27,0:17:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bukan selamatkan mereka,\Ntapi memotivasi para penjahat.
Dialogue: 0,0:17:35.25,0:17:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyerang suplaiku, dasar iblis!
Dialogue: 0,0:17:39.88,0:17:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tak ingin kelahi lagi.
Dialogue: 0,0:17:42.38,0:17:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pulang ke Surga saja, sana.
Dialogue: 0,0:17:44.78,0:17:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:47.84,0:17:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak diizinkan pulang ke Surga\Nsampai tugas ini selesai.
Dialogue: 0,0:17:55.72,0:17:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin pulang ke Surga.
Dialogue: 0,0:18:02.11,0:18:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surga itu tempat yang bagus.
Dialogue: 0,0:18:06.09,0:18:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuacanya selalu cerah.
Dialogue: 0,0:18:09.47,0:18:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidur pun tetap dapat makanan.
Dialogue: 0,0:18:12.92,0:18:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alkohol di sana enak.
Dialogue: 0,0:18:15.55,0:18:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada malaikat juga cantik.
Dialogue: 0,0:18:18.88,0:18:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar tempat yang indah.
Dialogue: 0,0:18:24.52,0:18:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu.
Dialogue: 0,0:18:26.10,0:18:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa membiarkan iblis\Nyang bermaksud memakan jiwa Kyougi!
Dialogue: 0,0:18:32.25,0:18:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak berniat memakannya.
Dialogue: 0,0:18:35.77,0:18:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang.
Dialogue: 0,0:18:38.61,0:18:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Yang benar?
Dialogue: 0,0:18:40.61,0:18:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:41.74,0:18:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa tanya itu?
Dialogue: 0,0:18:44.49,0:18:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehm...
Dialogue: 0,0:18:45.60,0:18:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya.
Dialogue: 0,0:18:47.63,0:18:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Kyougi... Begini...
Dialogue: 0,0:18:51.03,0:18:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin berhubungan seks, ya?
Dialogue: 0,0:18:54.68,0:18:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Bi-Bicara apa kau?!
Dialogue: 0,0:18:56.73,0:18:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seks?\N- Bukan, lah. Mana mungkin!
Dialogue: 0,0:18:59.68,0:19:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seks itu apa?
Dialogue: 0,0:19:03.44,0:19:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seks? Hm... Kedengarannya mencurigakan.
Dialogue: 0,0:19:07.50,0:19:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu ritual bangsa iblis?
Dialogue: 0,0:19:09.31,0:19:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tunggu.\NKau mungkin santa, tapi masa tidak tahu?
Dialogue: 0,0:19:15.69,0:19:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seks itu kegiatan apa?
Dialogue: 0,0:19:18.60,0:19:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ke-Kegiatan apa, katamu?
Dialogue: 0,0:19:20.92,0:19:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, menyentuh kulit?
Dialogue: 0,0:19:23.63,0:19:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sentuh kulit? Bagaimana caranya?
Dialogue: 0,0:19:25.85,0:19:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau itu...\NMisalkan pakai tangan atau bibir...
Dialogue: 0,0:19:30.69,0:19:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibir? Bibirnya menyentuh apa?
Dialogue: 0,0:19:34.08,0:19:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... Ci-Ci...
Dialogue: 0,0:19:36.92,0:19:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, ciuman?
Dialogue: 0,0:19:39.87,0:19:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman itu apa?
Dialogue: 0,0:19:42.29,0:19:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehm, itu...
Dialogue: 0,0:19:44.65,0:19:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibir satu sama lain
Dialogue: 0,0:19:47.26,0:19:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang saling
Dialogue: 0,0:19:49.25,0:19:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersentuhan.
Dialogue: 0,0:19:50.42,0:19:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bibirnya harus bersentuhan?
Dialogue: 0,0:19:54.08,0:19:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, oke, oke.
Dialogue: 0,0:19:55.76,0:19:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya...
Dialogue: 0,0:19:57.08,0:19:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kopulasi.
Dialogue: 0,0:19:58.68,0:20:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami!
Dialogue: 0,0:20:01.11,0:20:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kopulasi?
Dialogue: 0,0:20:03.37,0:20:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang kuda atau anjing lakukan\Nsupaya punya anak, 'kan?
Dialogue: 0,0:20:10.63,0:20:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Kanan lakukan itu?
Dialogue: 0,0:20:13.97,0:20:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:15.06,0:20:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisik-bisik, bisik-bisik.
Dialogue: 0,0:20:17.26,0:20:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti ini, lalu itu dan itu.
Dialogue: 0,0:20:29.52,0:20:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah bayi itu dibawa oleh burung bangau?
Dialogue: 0,0:21:25.22,0:21:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu melakukan itu ke anu,
Dialogue: 0,0:21:29.90,0:21:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu jadi seperti itu... Lo? Lo?
Dialogue: 0,0:21:35.77,0:21:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya?
Dialogue: 0,0:21:37.70,0:21:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeanne selalu bengong seharian ini,\Napa terjadi sesuatu, ya?
Dialogue: 0,0:21:43.16,0:21:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:21:57.01,0:21:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:22:00.26,0:22:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:22:03.71,0:22:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
