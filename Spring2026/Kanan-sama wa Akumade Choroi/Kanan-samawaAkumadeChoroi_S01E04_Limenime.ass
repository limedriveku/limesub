Dialogue: 0,0:02:35.17,0:02:38.93,tanda,,0000,0000,0000,,#04 KEKUATAN CUPID AMI
Dialogue: 0,0:03:28.47,0:03:30.78,tanda,,0000,0000,0000,,"ADA BERBAGAI MACAM PENDAPAT"
Dialogue: 0,0:10:46.62,0:10:49.12,tanda,,0000,0000,0000,,RUANG KOMITE DISIPLIN
Dialogue: 0,0:11:37.30,0:11:41.18,tanda,,0000,0000,0000,,"AC RUSAK"
Dialogue: 0,0:12:39.11,0:12:39.39,tanda,,0000,0000,0000,,KANAN
Dialogue: 0,0:13:37.63,0:13:38.92,tanda,,0000,0000,0000,,KANAN
Dialogue: 0,0:14:27.05,0:14:31.01,tanda,,0000,0000,0000,,KOK BISA WAJAHNYA TERSELIP\NKE DALAM SINI...
Dialogue: 0,0:14:31.01,0:14:32.30,tanda,,0000,0000,0000,,AKADEMI DEDIKASI KOTA TAMA
Dialogue: 0,0:15:33.07,0:15:34.58,tanda,,0000,0000,0000,,BUAH SEGAR
Dialogue: 0,0:18:06.31,0:18:08.31,tanda,,0000,0000,0000,,RUANG KOMITE DISIPLIN
Dialogue: 0,0:18:08.31,0:18:11.17,tanda,,0000,0000,0000,,"CATATAN HARIAN ANGGOTA KOMITE DISIPLIN"
Dialogue: 0,0:00:05.26,0:00:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona sedang kencan bersama pacarnya.
Dialogue: 0,0:00:07.42,0:00:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami sampai terharu dibuatnya.
Dialogue: 0,0:00:11.45,0:00:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, karena kencannya sudah beres,
Dialogue: 0,0:00:14.67,0:00:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selanjutnya ciuman, berhubungan badan,
Dialogue: 0,0:00:18.27,0:00:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu melakukan ini dan itu!
Dialogue: 0,0:00:29.11,0:00:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas banget, ya.
Dialogue: 0,0:00:30.53,0:00:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelah sekali.
Dialogue: 0,0:00:32.47,0:00:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panasnya.
Dialogue: 0,0:00:34.54,0:00:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas penjas di luar saat musim begini\Npasti bikin keringatan.
Dialogue: 0,0:00:45.52,0:00:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya sangat pas!
Dialogue: 0,0:00:47.83,0:00:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan untuk\Nmengembangkan hubungan kalian!
Dialogue: 0,0:00:51.33,0:00:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior! Kamu tetap imut\Nmeski pakai baju olahraga, ya.
Dialogue: 0,0:00:56.29,0:00:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat.
Dialogue: 0,0:01:00.03,0:01:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:01:02.22,0:01:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia malah mundur!
Dialogue: 0,0:02:46.18,0:02:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dibenci
Dialogue: 0,0:02:47.88,0:02:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:02:49.12,0:02:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa aku melakukan sesuatu\Nyang Senior benci?
Dialogue: 0,0:02:54.26,0:02:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, soal itu...
Dialogue: 0,0:02:55.88,0:02:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu menjauh?
Dialogue: 0,0:02:57.84,0:02:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, sebenarnya...
Dialogue: 0,0:03:00.02,0:03:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita saling mencintai!
Dialogue: 0,0:03:02.46,0:03:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya Senior hanya mengincar\Ntubuhku saja, ya?
Dialogue: 0,0:03:06.70,0:03:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyebarkan fitnah, ya!
Dialogue: 0,0:03:08.66,0:03:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:03:10.91,0:03:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melarangmu mendekat karena\Ntubuhku bau keringat!
Dialogue: 0,0:03:20.55,0:03:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau cium!
Dialogue: 0,0:03:22.03,0:03:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otakmu sungguhan geser sesenti, ya?!
Dialogue: 0,0:03:24.27,0:03:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:03:25.52,0:03:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah aroma masa muda, lo.
Dialogue: 0,0:03:27.04,0:03:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harum idaman seluruh anak lelaki, lo.
Dialogue: 0,0:03:28.47,0:03:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku ingin mencoba menciumnya.
Dialogue: 0,0:03:30.86,0:03:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otakmu memang benar-benar bergeser!
Dialogue: 0,0:03:32.61,0:03:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tak keberatan menjadikan\Nkaus kaki bekas Senior sebagai masker!
Dialogue: 0,0:03:37.55,0:03:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:03:40.03,0:03:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku menciumnya.
Dialogue: 0,0:03:42.57,0:03:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau!
Dialogue: 0,0:03:43.42,0:03:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku menciumnya!
Dialogue: 0,0:03:47.55,0:03:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keringat Senior pasti sangat wangi.
Dialogue: 0,0:03:51.81,0:03:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga, kok!
Dialogue: 0,0:03:53.63,0:03:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keharuman orang yang aku cintai, lo.
Dialogue: 0,0:03:55.63,0:03:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas aku pasti akan menyukainya!
Dialogue: 0,0:03:58.24,0:04:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau sudah cinta, memang begitu, ya?
Dialogue: 0,0:04:01.08,0:04:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa iya akan menjadi seperti itu?!
Dialogue: 0,0:04:08.07,0:04:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau kau bersikeras...
Dialogue: 0,0:04:15.53,0:04:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Co-Coba cium sendiri saja.
Dialogue: 0,0:04:21.08,0:04:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan cium dengan senang hati.
Dialogue: 0,0:04:36.56,0:04:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tunggu sebentar.
Dialogue: 0,0:04:38.00,0:04:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi macam apa ini?
Dialogue: 0,0:04:39.38,0:04:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku melakukan hal\Nyang sangat memalukan ini?
Dialogue: 0,0:04:42.16,0:04:44.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, tak kusangka kamu berani\Nbernegosiasi bagaikan iblis
Dialogue: 0,0:04:44.99,0:04:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi memuaskan nafsu pribadimu.
Dialogue: 0,0:04:49.21,0:04:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, mungkin lebih tepatnya\Naku ini wanita cabul
Dialogue: 0,0:04:52.13,0:04:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena membuat junior berlutut\Ndan mencium bau tubuhku?
Dialogue: 0,0:04:54.62,0:04:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Martabatku sebagai iblis masih aman, 'kan?!
Dialogue: 0,0:05:01.91,0:05:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, dia menghirupnya serius sekali.
Dialogue: 0,0:05:04.44,0:05:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini? Keringatku...
Dialogue: 0,0:05:06.50,0:05:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini membuatku makin berkeringat!
Dialogue: 0,0:05:09.59,0:05:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, harum Senior itu...
Dialogue: 0,0:05:11.84,0:05:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tunggu. Jangan disebutkan.
Dialogue: 0,0:05:13.97,0:05:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu menyebutkannya!
Dialogue: 0,0:05:16.05,0:05:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wangi detergen *ttack, ya.
Dialogue: 0,0:05:18.06,0:05:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detergen?!
Dialogue: 0,0:05:19.21,0:05:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak ada hubungannya\Ndengan bau tubuhku!
Dialogue: 0,0:05:23.01,0:05:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga. Gara-gara kamu,\Nhandukku sampai terjatuh.
Dialogue: 0,0:05:25.96,0:05:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Kalau mau,\NSenior bisa memakai handukku.
Dialogue: 0,0:05:31.40,0:05:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar, deh.
Dialogue: 0,0:05:32.99,0:05:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:05:35.81,0:05:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ini harum segar sitrus.
Dialogue: 0,0:05:39.23,0:05:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harum tubuh Kyougi.
Dialogue: 0,0:05:41.90,0:05:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, perasaanku menjadi tenang.
Dialogue: 0,0:05:43.95,0:05:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku menyukai harum ini.
Dialogue: 0,0:05:46.18,0:05:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menciumnya sampai lama sekali.
Dialogue: 0,0:05:49.69,0:05:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak, tidak! Bukan suka, kok...!
Dialogue: 0,0:05:52.37,0:05:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku terdengar seperti wanita cabul?
Dialogue: 0,0:05:54.80,0:05:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Handukku harum apa?
Dialogue: 0,0:05:57.83,0:05:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada harum apa pun!
Dialogue: 0,0:06:00.81,0:06:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku tidak mencium handukmu, ya!
Dialogue: 0,0:06:04.00,0:06:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kamu Makhluk Inferior!
Dialogue: 0,0:06:06.68,0:06:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang dia lakukan?
Dialogue: 0,0:06:08.61,0:06:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, butuh 5.000 tahun\Nsampai mereka berciuman.
Dialogue: 0,0:06:12.21,0:06:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:06:13.73,0:06:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya Ami menjadi Cupid,\Nsang malaikat cinta mereka!
Dialogue: 0,0:06:23.64,0:06:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, itu Senior Kanan.
Dialogue: 0,0:06:26.08,0:06:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, dilihat kapan pun dia tetap keren!
Dialogue: 0,0:06:29.98,0:06:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telingaku tidak bisa mendengar dengan jelas.
Dialogue: 0,0:06:32.71,0:06:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Senior baik-baik saja?
Dialogue: 0,0:06:34.93,0:06:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, aku bisa mendengar\Nseluruh suara di akademi,
Dialogue: 0,0:06:37.93,0:06:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sekarang jarak 100 meter saja\Ntidak kedengaran.
Dialogue: 0,0:06:40.33,0:06:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telinga Senior tajam banget, ya.
Dialogue: 0,0:06:43.91,0:06:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku berpatroli\Ntanpa tujuan yang jelas, ya?
Dialogue: 0,0:06:47.93,0:06:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau salah besar.
Dialogue: 0,0:06:49.73,0:06:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan siswa yang melanggar aturan
Dialogue: 0,0:06:51.70,0:06:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan pendengaran yang setajam iblis!
Dialogue: 0,0:06:54.09,0:06:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dengan menggunakan
Dialogue: 0,0:06:55.85,0:06:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Devil Ear ini!
Dialogue: 0,0:06:57.74,0:06:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, telinga yang tajam, ya.
Dialogue: 0,0:06:59.47,0:07:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Devil Ear!
Dialogue: 0,0:07:00.69,0:07:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek kuping... Korek kuping.
Dialogue: 0,0:07:05.25,0:07:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Korek kuping sambil rebahan\N- Sekarang aku mendengar ilusi suara yang aneh...
Dialogue: 0,0:07:08.39,0:07:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di pangkuan pacar.
Dialogue: 0,0:07:11.18,0:07:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek kuping di pangkuan pacar.
Dialogue: 0,0:07:13.21,0:07:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek kuping di pangkuan pacar.
Dialogue: 0,0:07:15.21,0:07:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek kuping di pangkuan pacar.
Dialogue: 0,0:07:23.95,0:07:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek kuping...
Dialogue: 0,0:07:26.13,0:07:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek kuping di pangkuan pacar.
Dialogue: 0,0:07:27.95,0:07:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kenapa kau malah terpengaruh?
Dialogue: 0,0:07:30.67,0:07:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan saja padaku.
Dialogue: 0,0:07:32.17,0:07:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lumayan percaya diri\Ndengan bakat membersihkan telingaku!
Dialogue: 0,0:07:35.34,0:07:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:07:38.00,0:07:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek kuping di pangkuan pacar.
Dialogue: 0,0:07:40.30,0:07:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius, nih? Situasi idamanku\Ndatang dengan semudah ini, lo?!
Dialogue: 0,0:07:51.49,0:07:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk Inferior sepertinya\Npunya semangat melayani juga, ya.
Dialogue: 0,0:07:55.57,0:07:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi sebentar lagi dia akan\Nmenyerahkan jiwanya sendiri padaku.
Dialogue: 0,0:07:59.75,0:08:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh. Kuizinkan kau menyentuhku.
Dialogue: 0,0:08:02.90,0:08:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukanlah.
Dialogue: 0,0:08:04.38,0:08:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:06.00,0:08:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi teringat masa lalu.
Dialogue: 0,0:08:08.65,0:08:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masih kecil,\NIbu sering melakukan ini untukku.
Dialogue: 0,0:08:12.31,0:08:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi teringat dengan Dunia Iblis.
Dialogue: 0,0:08:17.67,0:08:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Perasaan apa yang tadi itu?
Dialogue: 0,0:08:20.66,0:08:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti dia membelai\Npusat kenyamananku secara langsung.
Dialogue: 0,0:08:23.65,0:08:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya menyentuhku, 'kan?
Dialogue: 0,0:08:25.99,0:08:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:08:27.31,0:08:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telingaku sangat sensitif sampai bisa\Nmenangkap semua suara di akademi, lo.
Dialogue: 0,0:08:31.76,0:08:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia memasukkan korek kuping\Ndalam kondisi seperti ini...
Dialogue: 0,0:08:38.12,0:08:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gi-Gila, gila, gila!
Dialogue: 0,0:08:39.72,0:08:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gila!
Dialogue: 0,0:08:40.66,0:08:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punggungku langsung merinding.
Dialogue: 0,0:08:43.00,0:08:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dinding di dalam telingaku...
Dialogue: 0,0:08:44.09,0:08:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengelus titik kumpul sarafku\Ndengan sangat presisi!
Dialogue: 0,0:08:51.93,0:08:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:08:52.88,0:08:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya itu bisa masuk\Nsampai sedalam itu, ya?
Dialogue: 0,0:08:54.69,0:08:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gendang telingaku tidak akan pecah?
Dialogue: 0,0:08:57.32,0:09:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, kalau kau menggerakkannya\Ndi sana pasti akan keluar...!
Dialogue: 0,0:09:02.56,0:09:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengeluarkan\Nbanyak suara yang ambigu!
Dialogue: 0,0:09:13.26,0:09:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, Manusia! Lanjutkan!
Dialogue: 0,0:09:15.72,0:09:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek terus! Keluarkan yang banyak!
Dialogue: 0,0:09:21.36,0:09:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior mempunyai telinga yang cantik, ya.
Dialogue: 0,0:09:24.01,0:09:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat imut karena ujungnya meruncing.
Dialogue: 0,0:09:26.78,0:09:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuping telinganya juga terasa empuk.
Dialogue: 0,0:09:30.45,0:09:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahaku terasa geli terkena napas Senior.
Dialogue: 0,0:09:34.20,0:09:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungku juga berdebar dengan kencang.
Dialogue: 0,0:09:36.82,0:09:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek kuping memang juara!
Dialogue: 0,0:09:39.51,0:09:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa. Aku sudah tak sanggup lagi.
Dialogue: 0,0:09:42.63,0:09:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku akan pingsan...
Dialogue: 0,0:09:44.65,0:09:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar hina\Nkarena menunjukkan reaksi ini
Dialogue: 0,0:09:48.08,0:09:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di depan Makhluk Inferior sepertinya.
Dialogue: 0,0:09:50.90,0:09:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak mungkin.
Dialogue: 0,0:09:52.48,0:09:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya dikorek, tapi paket lengkap\Ndengan pijat telinga dan ditiup juga?!
Dialogue: 0,0:09:57.88,0:09:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan itu.
Dialogue: 0,0:09:59.45,0:10:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia melakukan hal yang lain lagi,\Naku akan... aku akan...
Dialogue: 0,0:10:03.63,0:10:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan...
Dialogue: 0,0:10:05.29,0:10:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jatuh!
Dialogue: 0,0:10:18.33,0:10:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil bertahan.
Dialogue: 0,0:10:19.40,0:10:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana, tapi aku bisa bertahan.
Dialogue: 0,0:10:21.37,0:10:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu Kyougi punya\Nbakat seperti ini.
Dialogue: 0,0:10:24.69,0:10:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:10:26.36,0:10:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ahli, 'kan?
Dialogue: 0,0:10:27.98,0:10:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Biasa saja.
Dialogue: 0,0:10:31.25,0:10:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pada akhirnya kamu hanya Makhluk...\N- Tidak mungkin!
Dialogue: 0,0:10:34.48,0:10:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:10:37.51,0:10:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lebih bersemangat\Nsaat mengorek telinga yang satunya.
Dialogue: 0,0:10:44.04,0:10:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, Youji sedang\Nberada di Ruang Komite Disiplin.
Dialogue: 0,0:10:49.56,0:10:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?!
Dialogue: 0,0:10:51.34,0:10:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau. Jangan bergerak!
Dialogue: 0,0:10:53.73,0:10:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, kalau kamu bergerak,\Nnanti bisa robek, lo!
Dialogue: 0,0:10:56.12,0:10:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melakukannya di dalam!
Dialogue: 0,0:10:58.67,0:11:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang berhenti,\Ndasar kamu Makhluk Inferior!
Dialogue: 0,0:11:04.34,0:11:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Kyougi si teknisi andal!
Dialogue: 0,0:11:06.93,0:11:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:11:08.24,0:11:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Youji?
Dialogue: 0,0:11:09.97,0:11:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Kanan?
Dialogue: 0,0:11:12.00,0:11:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih. Padahal tinggal sedikit lagi.
Dialogue: 0,0:11:14.89,0:11:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini,\Naku akan melaksanakan rencana itu.
Dialogue: 0,0:11:25.64,0:11:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, ayo masuk juga.
Dialogue: 0,0:11:28.84,0:11:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya sejuk dan nyaman, lo.
Dialogue: 0,0:11:31.62,0:11:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini hidupnya bebas sekali, ya.
Dialogue: 0,0:11:34.85,0:11:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, hari ini panas sekali!
Dialogue: 0,0:11:37.30,0:11:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari seperti ini, AC-nya malah rusak.
Dialogue: 0,0:11:41.61,0:11:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menulis buku harian pun jadi mandek,\Naku tidak tahan lagi.
Dialogue: 0,0:11:45.77,0:11:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:11:46.97,0:11:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior mau meminta tolong apa, ya?
Dialogue: 0,0:11:49.89,0:11:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Meminta tolong?\NAku baru dengarnya.
Dialogue: 0,0:11:53.18,0:11:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang juga kau, Manusia.
Dialogue: 0,0:11:55.87,0:11:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baju renang!
Dialogue: 0,0:11:57.64,0:11:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pelayan memakai baju renang!
Dialogue: 0,0:12:00.38,0:12:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau bermain bersamaku?
Dialogue: 0,0:12:05.78,0:12:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona juga mau memakai baju renang, 'kan?
Dialogue: 0,0:12:09.87,0:12:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph! Aku yang anggun ini tidak mungkin\Nmemakai baju seksi di tempat seperti ini.
Dialogue: 0,0:12:16.87,0:12:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seksi banget. Sangat emosional!\NTolong lihat ke arah kamera!
Dialogue: 0,0:12:21.90,0:12:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga, anak lelaki pasti\Nmenyukai baju renang.
Dialogue: 0,0:12:25.28,0:12:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, si Manusia semangat banget,\Nsampai tidak kenal rem!
Dialogue: 0,0:12:27.70,0:12:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi memonopoli pandangannya, dong.\NKau yakin hanya mau diam saja?
Dialogue: 0,0:12:30.80,0:12:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau sangat menyukai baju renang...
Dialogue: 0,0:12:33.41,0:12:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat ke sini!
Dialogue: 0,0:12:39.40,0:12:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berlebihan saat bilang\Nbahwa Senior adalah yang terbaik!
Dialogue: 0,0:12:42.72,0:12:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah untukmu. Duduklah,\Ndan lihat baik-baik.
Dialogue: 0,0:12:46.19,0:12:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenggelamlah di dalam pesonaku,\NMakhluk Inferior.
Dialogue: 0,0:12:53.13,0:12:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, dia sangat memperhatikan...
Dialogue: 0,0:12:55.89,0:12:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar memperhatikanku.
Dialogue: 0,0:12:57.89,0:13:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya melihatku, tapi rasanya seperti\Ndisentuh, dan dijilati.
Dialogue: 0,0:13:03.63,0:13:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadaku, bokongku, pahaku...
Dialogue: 0,0:13:09.82,0:13:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan, sih, dasar pria cabul?!
Dialogue: 0,0:13:11.87,0:13:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku!
Dialogue: 0,0:13:13.04,0:13:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mataku!\N- Nona, orang itu hanya diam saja, lo.
Dialogue: 0,0:13:15.67,0:13:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seahli apa, sih, sampai bisa\Nmemainkan tubuhku tanpa sentuhan?!
Dialogue: 0,0:13:18.76,0:13:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ahli dalam hal apa?!
Dialogue: 0,0:13:19.95,0:13:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat keluar dari sini!
Dialogue: 0,0:13:21.98,0:13:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, setidaknya izinkan aku\Nmenempelkan wajahku di baju renangmu.
Dialogue: 0,0:13:25.85,0:13:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ce-Cepat keluar!
Dialogue: 0,0:13:29.09,0:13:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:13:35.50,0:13:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kau baik-baik saja...?
Dialogue: 0,0:13:40.27,0:13:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melihat ke depan!
Dialogue: 0,0:13:41.83,0:13:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuh macam apa yang membuatmu\Nsampai berada di sana?!
Dialogue: 0,0:13:43.84,0:13:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?! Senior ada di mana?
Dialogue: 0,0:13:46.13,0:13:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh! Jangan bergerak!
Dialogue: 0,0:13:49.25,0:13:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster budak nafsu!
Dialogue: 0,0:13:51.49,0:13:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zaman sekarang masih terpeleset dan\Njadi pria cabul hoki? Seperti manga saja!
Dialogue: 0,0:13:54.78,0:13:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, aku mau pulang saja!
Dialogue: 0,0:13:56.32,0:13:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Senior.
Dialogue: 0,0:14:12.01,0:14:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Senior.
Dialogue: 0,0:14:14.03,0:14:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuka mulutmu, Makhluk Inferior!
Dialogue: 0,0:14:16.72,0:14:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm. Bagus, bagus juga.
Dialogue: 0,0:14:21.41,0:14:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lanjut sampai melakukan "hal itu"?
Dialogue: 0,0:14:24.21,0:14:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak akan!
Dialogue: 0,0:14:32.31,0:14:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, ayo kita berangkat berpatroli.
Dialogue: 0,0:14:34.64,0:14:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:14:35.59,0:14:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku harus membuat mereka\Nbersentuhan secara fisik
Dialogue: 0,0:14:39.53,0:14:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan maju sampai berciuman!
Dialogue: 0,0:14:41.48,0:14:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada seorang pelayan.
Dialogue: 0,0:14:43.27,0:14:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:14:44.37,0:14:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ups.
Dialogue: 0,0:14:45.41,0:14:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju ini terlalu mencolok, ya.
Dialogue: 0,0:14:48.33,0:14:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:14:50.95,0:14:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah si gadis gaul nan trendi!
Dialogue: 0,0:14:55.01,0:14:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, waktunya aku menyerang\Ndengan menggunakan anjing.
Dialogue: 0,0:14:57.60,0:14:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guguk, dengarkan baik-baik, ya.
Dialogue: 0,0:14:59.25,0:15:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat mereka menempel karena ketakutan!
Dialogue: 0,0:15:01.82,0:15:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berangkatlah!
Dialogue: 0,0:15:10.32,0:15:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, awas bahaya!
Dialogue: 0,0:15:13.76,0:15:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:15:19.25,0:15:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:15:22.13,0:15:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kamu baik-baik saja?
Dialogue: 0,0:15:23.87,0:15:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tindakan itu terlalu berlebihan.
Dialogue: 0,0:15:26.75,0:15:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:15:27.81,0:15:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjut!
Dialogue: 0,0:15:35.27,0:15:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menabraknya, membuatnya oleng,\Ndan memeluk lengan pacarnya.
Dialogue: 0,0:15:39.11,0:15:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:15:40.32,0:15:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, ya!
Dialogue: 0,0:15:44.51,0:15:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip! Sampai di sini rencananya lancar...
Dialogue: 0,0:15:47.77,0:15:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:15:49.35,0:15:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:15:56.62,0:15:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bra, bra, bra, bra, bra...
Dialogue: 0,0:15:59.98,0:16:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menjadi trauma!
Dialogue: 0,0:16:01.07,0:16:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bra, bra, bra, bra, bra...\N- Senior teringat kencan tanpa bra waktu itu, ya?
Dialogue: 0,0:16:03.67,0:16:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pakai, kok. Hari ini\Nkamu memakai bra!
Dialogue: 0,0:16:06.16,0:16:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bra, bra, bra, bra, bra...
Dialogue: 0,0:16:06.74,0:16:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami tidak akan menyerah!
Dialogue: 0,0:16:11.40,0:16:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:16:29.22,0:16:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sama sekali tidak terjebak\Ndi dalam adegan ambigu!
Dialogue: 0,0:16:32.38,0:16:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah menjadi seperti ini...
Dialogue: 0,0:16:35.07,0:16:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan aku paksakan saja!
Dialogue: 0,0:16:37.30,0:16:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami?!
Dialogue: 0,0:16:39.57,0:16:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah matras untuk lompat tinggi!
Dialogue: 0,0:16:43.69,0:16:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Nona?
Dialogue: 0,0:16:45.30,0:16:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kamu dalam posisi\Nmenempel yang mesra, lo.
Dialogue: 0,0:16:47.84,0:16:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terangsang, belum?
Dialogue: 0,0:16:50.16,0:16:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, Ami. Bicara apa kau ini?
Dialogue: 0,0:16:52.23,0:16:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:16:53.70,0:16:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Senior, lenganku...
Dialogue: 0,0:16:57.00,0:16:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat! Kau terlalu dekat, Kyougi!
Dialogue: 0,0:16:59.29,0:17:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan. Kalau kau lebih dekat\Ndari yang sekarang...
Dialogue: 0,0:17:01.29,0:17:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?
Dialogue: 0,0:17:02.74,0:17:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal berciuman di kecelakaan buatan ini!
Dialogue: 0,0:17:04.99,0:17:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cium, cium, cium, cium!
Dialogue: 0,0:17:08.81,0:17:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tak sanggup lagi.
Dialogue: 0,0:17:10.11,0:17:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak, tidak. Tunggu, tunggu!
Dialogue: 0,0:17:13.23,0:17:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:17:14.84,0:17:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tung...
Dialogue: 0,0:17:16.17,0:17:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cium!
Dialogue: 0,0:17:25.06,0:17:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cium...?
Dialogue: 0,0:17:26.73,0:17:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup!
Dialogue: 0,0:17:39.30,0:17:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami, apa yang sebenarnya kau incar?
Dialogue: 0,0:17:43.58,0:17:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kudengarkan motifmu sebagai\Npengganti kata-kata terakhirmu.
Dialogue: 0,0:17:47.05,0:17:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas nama bangsa Succubus...
Dialogue: 0,0:17:49.91,0:17:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah akan membuat\Nkalian melakukan hubungan badan!
Dialogue: 0,0:17:54.06,0:17:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi!
Dialogue: 0,0:17:56.07,0:17:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tiba-tiba mendapatkan\Nhobi aneh apa, sih?
Dialogue: 0,0:17:59.81,0:18:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku mulai mempunyai\Nselera yang baru...
Dialogue: 0,0:18:02.58,0:18:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah seks di atas matras?
Dialogue: 0,0:18:04.25,0:18:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam kamu, Makhluk Inferior!
Dialogue: 0,0:18:08.31,0:18:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegiatan ekskul hari ini sudah selesai.
Dialogue: 0,0:18:14.73,0:18:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, Nona sebenarnya\Ntidak menarik.
Dialogue: 0,0:18:18.35,0:18:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kenapa tiba-tiba membahas hal itu?
Dialogue: 0,0:18:20.64,0:18:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, Ami sudah melakukan banyak hal,
Dialogue: 0,0:18:24.27,0:18:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi manusia itu sama sekali\Ntidak menyentuhmu.
Dialogue: 0,0:18:29.12,0:18:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami lumayan syok.
Dialogue: 0,0:18:31.68,0:18:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu karena...
Dialogue: 0,0:18:33.33,0:18:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak lengah sama sekali!
Dialogue: 0,0:18:35.43,0:18:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku lengah,\Npejantan mana yang akan diam saja?
Dialogue: 0,0:18:39.99,0:18:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oalah. Mau mencobanya, tidak?
Dialogue: 0,0:18:43.75,0:18:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:49.46,0:18:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, pulang bareng, yuk...
Dialogue: 0,0:18:53.28,0:18:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:18:56.24,0:18:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketiduran, ya?
Dialogue: 0,0:18:59.51,0:19:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sangat kelelahan\Nsampai ketiduran di sini.
Dialogue: 0,0:19:08.50,0:19:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior yang sedang tertidur imut banget.
Dialogue: 0,0:19:17.08,0:19:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang banyak celah dan tidak waspada...
Dialogue: 0,0:19:19.93,0:19:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti tak bisa menahan diri\Ndalam situasi seperti ini, 'kan?
Dialogue: 0,0:19:23.42,0:19:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, majulah, Kyougi!
Dialogue: 0,0:19:26.68,0:19:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba banget!
Dialogue: 0,0:19:28.30,0:19:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga manusia ini!
Dialogue: 0,0:19:29.83,0:19:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju, maju!
Dialogue: 0,0:19:31.25,0:19:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Timpa Nona Kanan dengan tubuh\Npenuh otot yang sia-sia itu!
Dialogue: 0,0:19:36.41,0:19:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syut.
Dialogue: 0,0:19:38.77,0:19:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pria yang beradab.
Dialogue: 0,0:19:40.89,0:19:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih saja menjadi pria beradab\Ndi depanku yang sedang lengah ini?!
Dialogue: 0,0:19:44.84,0:19:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau... Di depan pesonaku ini...!
Dialogue: 0,0:19:51.23,0:19:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir kau masih bisa\Nmenjaga akal sehatmu?!
Dialogue: 0,0:19:53.76,0:19:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Da-Dadanya...?!
Dialogue: 0,0:19:56.00,0:19:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dada yang melimpah ruah itu...!
Dialogue: 0,0:19:57.77,0:19:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:20:00.02,0:20:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin melakukannya?
Dialogue: 0,0:20:08.09,0:20:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sedang apa kau, Kyougi?!
Dialogue: 0,0:20:10.89,0:20:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melampiaskan nafsunya ke olahraga, ya?
Dialogue: 0,0:20:14.58,0:20:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:20:15.95,0:20:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan yang ini?
Dialogue: 0,0:20:21.07,0:20:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, tidak boleh, tidak boleh.
Dialogue: 0,0:20:23.69,0:20:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau yang ini?
Dialogue: 0,0:20:25.40,0:20:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup, hup, hup!
Dialogue: 0,0:20:27.29,0:20:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau yang ini?
Dialogue: 0,0:20:28.40,0:20:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak, tok, tek, tak, tok, tak!
Dialogue: 0,0:20:30.19,0:20:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga tidak mempan?
Dialogue: 0,0:20:31.68,0:20:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Huff, huff, huff, huff!
Dialogue: 0,0:20:33.94,0:20:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa. Asam laktatnya menumpuk,\Nototku tak kuat berolahraga lagi!
Dialogue: 0,0:20:38.95,0:20:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini terus,\Naku akan dikalahkan oleh hawa nafsu!
Dialogue: 0,0:20:42.15,0:20:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memberikan kode sebanyak ini,\Ntapi dia masih belum menyentuhku?
Dialogue: 0,0:20:46.99,0:20:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku memang tidak menarik?
Dialogue: 0,0:20:51.54,0:20:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami benar.
Dialogue: 0,0:20:54.27,0:20:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iblis menyedihkan yang tak mampu\Nmenggoda seorang anak lelaki SMA.
Dialogue: 0,0:20:58.59,0:20:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah diriku.
Dialogue: 0,0:21:00.85,0:21:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\Ndiriku ini hanya biasa-biasa saja.
Dialogue: 0,0:21:16.68,0:21:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sudah kulakukan\Npada Senior yang sedang tertidur?!
Dialogue: 0,0:21:26.61,0:21:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria mesum!
Dialogue: 0,0:21:29.20,0:21:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Youji?
Dialogue: 0,0:21:36.15,0:21:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pengecut.
Dialogue: 0,0:21:38.02,0:21:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Nona sudah selengah itu,\Ntapi kamu tidak melakukan apa-apa.
Dialogue: 0,0:21:42.30,0:21:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan? Nona.
Dialogue: 0,0:21:46.72,0:21:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona?
Dialogue: 0,0:21:54.96,0:21:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Kyougi itu, ya.
Dialogue: 0,0:21:57.32,0:22:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya dia kalah dengan pesonaku\Ndan berbuat usil!
Dialogue: 0,0:22:00.18,0:22:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Makhluk Inferior!
Dialogue: 0,0:22:02.41,0:22:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku tidak akan memaafkannya.
Dialogue: 0,0:22:05.90,0:22:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar pria gampangan!\N- Mereka berdua sudah tidak bisa diobati lagi.
