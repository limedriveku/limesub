Dialogue: 0,0:00:18.20,0:00:19.20,tanda,,0000,0000,0000,,RUANG KOMITE DISIPLIN
Dialogue: 0,0:03:16.11,0:03:18.98,tanda,,0000,0000,0000,,#01 KANAN GAMPANGAN
Dialogue: 0,0:03:18.99,0:03:21.97,tanda,,0000,0000,0000,,BEBERAPA BULAN LALU - DUNIA IBLIS
Dialogue: 0,0:05:00.67,0:05:01.62,tanda,,0000,0000,0000,,AKADEMI DEDIKASI KOTA TAMA
Dialogue: 0,0:05:50.58,0:05:51.08,tanda,,0000,0000,0000,,RUANG KOMITE DISIPLIN
Dialogue: 0,0:10:03.99,0:10:07.96,tanda,,0000,0000,0000,,- COSPLAY GADIS IBLIS, YA!\N- BUKAN, KOK.
Dialogue: 0,0:00:12.00,0:00:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademi Dedikasi Kota Tama.
Dialogue: 0,0:00:14.56,0:00:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah damai, tempat anak-anak\Nsehat menimba ilmu.
Dialogue: 0,0:00:19.66,0:00:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sudut sekolah tersebut,
Dialogue: 0,0:00:21.56,0:00:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah tiba iblis cantik yang misterius.
Dialogue: 0,0:00:31.20,0:00:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:00:33.03,0:00:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kyougi Youji dari kelas 1-2.
Dialogue: 0,0:00:39.20,0:00:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Lo?
Dialogue: 0,0:00:41.43,0:00:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku ada di sini?
Dialogue: 0,0:00:49.56,0:00:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Kyougi.
Dialogue: 0,0:00:52.06,0:00:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggumu.
Dialogue: 0,0:00:57.90,0:01:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanmu ada di ruangan ini,
Dialogue: 0,0:01:00.60,0:01:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku memanggil jiwamu.
Dialogue: 0,0:01:04.00,0:01:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwa?
Dialogue: 0,0:01:05.63,0:01:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:01:06.76,0:01:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memakanmu.
Dialogue: 0,0:01:09.80,0:01:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:01:11.86,0:01:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin... memakanku?
Dialogue: 0,0:01:31.23,0:01:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku putri Iblis Agung Kerakusan, Beelzebub.
Dialogue: 0,0:01:35.66,0:01:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan sang Gourmet.
Dialogue: 0,0:01:39.30,0:01:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, bersiaplah untuk kusantap.
Dialogue: 0,0:01:42.63,0:01:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai Makhluk Inferior.
Dialogue: 0,0:03:31.03,0:03:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:03:35.63,0:03:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa, aku punya permintaan.
Dialogue: 0,0:03:38.30,0:03:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kanan-ku yang imut.
Dialogue: 0,0:03:41.26,0:03:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kudengarkan semua permintaanmu.
Dialogue: 0,0:03:43.06,0:03:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduklah, mari makan bersama.
Dialogue: 0,0:03:46.10,0:03:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Papa.
Dialogue: 0,0:03:47.50,0:03:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang tidak ingin.
Dialogue: 0,0:03:50.46,0:03:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepatnya, aku tak bisa menikmati\Nhidangan apa pun.
Dialogue: 0,0:03:54.46,0:03:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kabar buruk.
Dialogue: 0,0:03:56.03,0:03:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan itu sumber kesehatan.\NPapa cemas.
Dialogue: 0,0:03:59.66,0:04:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku ingin pergi mencari\Nmakanan yang lebih lezat.
Dialogue: 0,0:04:03.52,0:04:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan lezat apa itu?
Dialogue: 0,0:04:07.63,0:04:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwa manusia!
Dialogue: 0,0:04:10.06,0:04:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membesarkan jiwa muda\Nyang belum matang
Dialogue: 0,0:04:12.86,0:04:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kubuat jadi sangat lezat\Nuntuk kunikmati sendiri!
Dialogue: 0,0:04:15.98,0:04:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus, Papa juga pernah memakannya.
Dialogue: 0,0:04:19.63,0:04:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu juga yang membuatku\Nbertengkar dengan malaikat.
Dialogue: 0,0:04:23.08,0:04:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, semua pasti aman.
Dialogue: 0,0:04:26.90,0:04:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:04:28.10,0:04:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini permintaan dari Kanan-ku yang imut.
Dialogue: 0,0:04:30.40,0:04:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Papa.
Dialogue: 0,0:04:32.20,0:04:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku pergi dulu.
Dialogue: 0,0:04:34.40,0:04:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tunggu sebentar.
Dialogue: 0,0:04:38.16,0:04:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan, belakangan ini,\Napa kau makan bersama orang lain?
Dialogue: 0,0:04:44.03,0:04:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh begitu, Papa.\NYang lezat harus dinikmati sendiri.
Dialogue: 0,0:04:48.10,0:04:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh ada keributan.
Dialogue: 0,0:04:51.20,0:04:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:04:53.06,0:04:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga harapanmu bisa terkabul.
Dialogue: 0,0:04:58.00,0:05:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, enak sekali!
Dialogue: 0,0:05:01.63,0:05:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku tiba di dunia manusia...
Dialogue: 0,0:05:05.37,0:05:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memiliki rupa yang cantik jelita.
Dialogue: 0,0:05:08.43,0:05:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa yang pandai.
Dialogue: 0,0:05:11.23,0:05:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ahli di semua bidang olahraga.
Dialogue: 0,0:05:13.16,0:05:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi orang yang dikagumi guru\Nmaupun sesama siswa.
Dialogue: 0,0:05:17.26,0:05:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku memang sempurna.
Dialogue: 0,0:05:21.67,0:05:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berakting sebagai siswa teladan
Dialogue: 0,0:05:24.06,0:05:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjadi Ketua Komite Disiplin\Nuntuk membuat mereka lengah.
Dialogue: 0,0:05:28.10,0:05:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademi ini bagai peternakanku.
Dialogue: 0,0:05:31.30,0:05:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua hewan ternaknya.
Dialogue: 0,0:05:33.90,0:05:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumbuhlah dengan sehat, lalu puaskan aku.
Dialogue: 0,0:05:44.32,0:05:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang cewek gaul paling keren.
Dialogue: 0,0:05:46.00,0:05:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Setuju!\N- Aku suka yang agak gemuk!
Dialogue: 0,0:05:51.12,0:05:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lapar.
Dialogue: 0,0:05:54.40,0:05:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya mau kutunggu sampai\Nmereka lebih dewasa.
Dialogue: 0,0:05:58.03,0:05:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kumakan saja sekarang.
Dialogue: 0,0:06:07.23,0:06:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, 'kan...?!
Dialogue: 0,0:06:08.43,0:06:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kilau alami dan tekstur kenyal,\Nditambah vitalitas membara!
Dialogue: 0,0:06:13.09,0:06:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jiwa berkualitas tinggi.
Dialogue: 0,0:06:21.76,0:06:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Manusia yang ada di sana.
Dialogue: 0,0:06:24.66,0:06:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:25.56,0:06:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:06:26.63,0:06:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarilah.
Dialogue: 0,0:06:40.10,0:06:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau memakanku?
Dialogue: 0,0:06:42.70,0:06:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:44.83,0:06:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama-tama, kulitmu akan kukupas.
Dialogue: 0,0:06:47.00,0:06:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengupas kulit?
Dialogue: 0,0:06:49.63,0:06:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kuuleni sampai rata\Ndan kutarik hingga memanjang.
Dialogue: 0,0:06:53.56,0:06:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diuleni?!
Dialogue: 0,0:06:55.03,0:06:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditarik memanjang?
Dialogue: 0,0:06:56.46,0:06:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini baru pertama,\Nsebaiknya mentah-mentah saja.
Dialogue: 0,0:06:59.60,0:07:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mentah-mentah?!
Dialogue: 0,0:07:01.23,0:07:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimakan olehku adalah\Nsebuah kehormatan besar.
Dialogue: 0,0:07:05.60,0:07:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berterimakasihlah, Makhluk Inferior.
Dialogue: 0,0:07:10.46,0:07:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:07:12.03,0:07:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:07:13.16,0:07:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar tersanjung?!
Dialogue: 0,0:07:16.16,0:07:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, ini kehormatan tertinggi bagiku!
Dialogue: 0,0:07:19.43,0:07:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Kukira kau akan ketakutan,\Nrupanya nyalimu besar juga.
Dialogue: 0,0:07:23.70,0:07:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak!
Dialogue: 0,0:07:24.86,0:07:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu bermimpi "dimakan"\Noleh gadis iblis seperti Senior!
Dialogue: 0,0:07:29.30,0:07:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:07:30.16,0:07:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tak kusangka kita akan...\Nseks sambil memakai kostum cosplay!
Dialogue: 0,0:07:33.67,0:07:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:34.19,0:07:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cosplay gadis iblis Senior\Nbagus banget. Sumpah!
Dialogue: 0,0:07:37.64,0:07:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengira "dimakan" dalam artian\Nseksual, ya?!
Dialogue: 0,0:07:42.03,0:07:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa otak anak cowok SMA\Nhanya dipenuhi hal mesum!
Dialogue: 0,0:07:47.40,0:07:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir bahan makanan sepertimu\Nbisa ada hubungan denganku?
Dialogue: 0,0:07:52.10,0:07:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar makhluk bodoh.
Dialogue: 0,0:07:54.76,0:07:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini kesempatan emas!
Dialogue: 0,0:07:56.86,0:08:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi ada kesempatan, akan kucuri jiwanya!
Dialogue: 0,0:08:01.56,0:08:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada satu hal yang mengkhawatirkan...
Dialogue: 0,0:08:05.96,0:08:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengalamanku masih nol!
Dialogue: 0,0:08:09.16,0:08:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mari kita mulai!
Dialogue: 0,0:08:10.99,0:08:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tung... Tunggu sebentar!
Dialogue: 0,0:08:14.03,0:08:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:08:14.97,0:08:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukankah hal ini harus dilakukan\Ndengan orang yang disukai?
Dialogue: 0,0:08:19.23,0:08:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga. Aku sama sekali tak masalah.
Dialogue: 0,0:08:21.80,0:08:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru saja menyukai Senior!
Dialogue: 0,0:08:24.76,0:08:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, bocah ini nafsu sekali!
Dialogue: 0,0:08:26.90,0:08:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior memanggilku karena suka juga, 'kan?
Dialogue: 0,0:08:29.98,0:08:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:31.83,0:08:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka?
Dialogue: 0,0:08:34.05,0:08:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diingat lagi, aku belum pernah\Nmenyukai seseorang.
Dialogue: 0,0:08:38.46,0:08:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup ribuan tahun,\Ntapi belum pernah bergandengan...
Dialogue: 0,0:08:43.36,0:08:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, rupa anak ini...
Dialogue: 0,0:08:46.16,0:08:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diperhatikan lagi...
Dialogue: 0,0:08:48.54,0:08:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia tipeku, deh!
Dialogue: 0,0:08:51.51,0:08:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, aku suka! Suka!
Dialogue: 0,0:08:53.49,0:08:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku suka!\N- Tunggu, aku mau pikir-pikir dulu!
Dialogue: 0,0:08:56.50,0:08:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin, Kanan Zebul?!
Dialogue: 0,0:08:58.03,0:09:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini putri Iblis Agung Beelzebub, lo!
Dialogue: 0,0:09:00.36,0:09:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin pengalaman pertamamu dihabiskan\Nbersama makhluk inferior?!
Dialogue: 0,0:09:06.23,0:09:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku membuat Senior bingung.
Dialogue: 0,0:09:11.06,0:09:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... tidak ingin melukai Senior.
Dialogue: 0,0:09:15.40,0:09:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak... Itu...
Dialogue: 0,0:09:17.32,0:09:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Senior bisa lakukan pakai mulut?
Dialogue: 0,0:09:19.40,0:09:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembarangan saja kau, bocah tolol!
Dialogue: 0,0:09:21.26,0:09:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, pakai tangan saja.
Dialogue: 0,0:09:22.43,0:09:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau! Dasar cabul!
Dialogue: 0,0:09:24.76,0:09:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, bagaimana kalau kita mulai\Ndengan berpacaran dulu?
Dialogue: 0,0:09:31.60,0:09:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpacaran?
Dialogue: 0,0:09:41.06,0:09:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau hanya itu...
Dialogue: 0,0:09:43.56,0:09:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap!
Dialogue: 0,0:09:45.26,0:09:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya!
Dialogue: 0,0:09:46.77,0:09:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga.
Dialogue: 0,0:09:49.20,0:09:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:09:50.70,0:09:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sampai besok!
Dialogue: 0,0:09:54.50,0:09:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku terbawa suasana dan menjalin\Nkontrak gila dengannya...?
Dialogue: 0,0:09:59.16,0:10:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar makhluk inferior sialan!
Dialogue: 0,0:10:08.86,0:10:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Youji, kau senggang akhir pekan ini?
Dialogue: 0,0:10:11.76,0:10:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bantu aku bersih-bersih\Ndi kuil keluargaku.
Dialogue: 0,0:10:14.86,0:10:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya tak bisa, aku ada janji.
Dialogue: 0,0:10:18.76,0:10:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Masurao.
Dialogue: 0,0:10:20.43,0:10:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil margaku,\Npanggil Nadeko saja!
Dialogue: 0,0:10:24.40,0:10:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terbiasa dengan itu,\Njadi agak sulit ubahnya...
Dialogue: 0,0:10:28.43,0:10:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, tumben kamu\Nyang biasanya luang punya janji.
Dialogue: 0,0:10:33.63,0:10:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Soalnya aku punya pacar.
Dialogue: 0,0:10:36.06,0:10:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Kamu punya pacar.
Dialogue: 0,0:10:38.16,0:10:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat... Apa katamu?!
Dialogue: 0,0:10:40.10,0:10:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya pacar?!
Dialogue: 0,0:10:41.80,0:10:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dia senior setahun di atas kita.
Dialogue: 0,0:10:44.60,0:10:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lebih tua?
Dialogue: 0,0:10:45.70,0:10:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kamu anak yang sulit bergaul,\Nternyata hebat juga!
Dialogue: 0,0:10:50.36,0:10:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, kalian saling panggil apa?
Dialogue: 0,0:10:54.20,0:10:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu?
Dialogue: 0,0:10:55.16,0:10:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian yang saling cinta\Npasti punya panggilan khusus.
Dialogue: 0,0:10:59.03,0:11:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti memanggilnya dengan nama depan.
Dialogue: 0,0:11:01.90,0:11:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama...
Dialogue: 0,0:11:05.23,0:11:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betapa bodohnya.
Dialogue: 0,0:11:06.40,0:11:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tak sadar sudah jadi peliharaanku.
Dialogue: 0,0:11:09.56,0:11:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu alasannya aku suka meremehkan\Nhewan ternak ini.
Dialogue: 0,0:11:13.02,0:11:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:11:15.40,0:11:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi! Jangan muncul tiba-tiba begitu!
Dialogue: 0,0:11:18.50,0:11:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, tolong panggil aku\Ndengan nama depanku!
Dialogue: 0,0:11:21.83,0:11:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Nama depan?
Dialogue: 0,0:11:23.41,0:11:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berpacaran, tapi masih memanggil\N"Senior" dan marga.
Dialogue: 0,0:11:27.80,0:11:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar lebih dekat, kita pakai nama depan.
Dialogue: 0,0:11:30.86,0:11:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Le-Lebih dekat?
Dialogue: 0,0:11:33.03,0:11:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk inferior ini banyak maunya, ya.
Dialogue: 0,0:11:35.66,0:11:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu sebentar.
Dialogue: 0,0:11:38.10,0:11:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin dipanggil pakai nama depan, ya?
Dialogue: 0,0:11:41.03,0:11:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:11:42.66,0:11:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan untuk ingatkan\Nhewan ternak ini siapa bosnya.
Dialogue: 0,0:11:48.40,0:11:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia antusias banget!
Dialogue: 0,0:11:50.60,0:11:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah, perkara nama saja jadi begini.
Dialogue: 0,0:11:53.23,0:11:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu sekali.
Dialogue: 0,0:11:56.03,0:11:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan baik-baik.
Dialogue: 0,0:11:58.46,0:12:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}You... Yo... Yo-Yo... Youh...
Dialogue: 0,0:12:03.76,0:12:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:12:04.99,0:12:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, aku...
Dialogue: 0,0:12:06.36,0:12:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malu panggil nama depan Kyougi?!
Dialogue: 0,0:12:09.95,0:12:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak. Itu cuma nama, pasti bisa!
Dialogue: 0,0:12:12.63,0:12:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kusebut, pasti bisa kusebut!
Dialogue: 0,0:12:14.60,0:12:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Youji, Youji, Youji, Youji, Youji!
Dialogue: 0,0:12:19.26,0:12:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo... Yo...
Dialogue: 0,0:12:21.90,0:12:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Senior malu\Nmemanggil nama depanku, ya?
Dialogue: 0,0:12:25.78,0:12:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Mana mungkin, lah!
Dialogue: 0,0:12:28.76,0:12:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga. Maaf.
Dialogue: 0,0:12:30.56,0:12:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ingin dipanggil dengan nama depan,
Dialogue: 0,0:12:32.12,0:12:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa tidak mulai dengan memanggil\Nnama depanku?
Dialogue: 0,0:12:34.74,0:12:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan.
Dialogue: 0,0:12:39.20,0:12:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zat adiktif di otakku meluap...\NKebahagiaan macam apa ini?!
Dialogue: 0,0:12:44.40,0:12:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya yang seperti ini, ya?
Dialogue: 0,0:12:45.80,0:12:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin bahagia setelah\Nnama depanmu dipanggil, ya?!
Dialogue: 0,0:12:48.27,0:12:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar babi jantan penghibur!
Dialogue: 0,0:12:50.60,0:12:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, giliranmu memanggil nama depanku.
Dialogue: 0,0:12:53.36,0:12:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan.
Dialogue: 0,0:12:54.75,0:12:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kanan.
Dialogue: 0,0:12:57.00,0:12:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Kanan.
Dialogue: 0,0:12:59.70,0:13:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan.
Dialogue: 0,0:13:02.86,0:13:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan.
Dialogue: 0,0:13:05.03,0:13:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan di telingaku...!
Dialogue: 0,0:13:07.60,0:13:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ini meluap...\Nakan meluap keluar...
Dialogue: 0,0:13:09.60,0:13:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibiarkan saja,
Dialogue: 0,0:13:10.81,0:13:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hewan ternak ini akan memikat hatiku...!
Dialogue: 0,0:13:14.80,0:13:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan...
Dialogue: 0,0:13:15.48,0:13:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya panggil "Kak",\Ndasar manusia ternak!
Dialogue: 0,0:13:17.26,0:13:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:13:19.73,0:13:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah kelewatan. Aku mau pulang!
Dialogue: 0,0:13:26.40,0:13:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti.
Dialogue: 0,0:13:28.44,0:13:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Youji.
Dialogue: 0,0:13:33.70,0:13:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja nanti,\Ndasar makhluk inferior sialan!
Dialogue: 0,0:13:36.04,0:13:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Kanan!
Dialogue: 0,0:13:42.30,0:13:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telingaku masih panas.
Dialogue: 0,0:13:45.66,0:13:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kenapa, sih?
Dialogue: 0,0:13:48.00,0:13:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap bersama Kyougi, aku...
Dialogue: 0,0:13:51.38,0:13:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, memangnya kenapa?
Dialogue: 0,0:13:54.25,0:13:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasangan di sana, tolong jaga jarak.
Dialogue: 0,0:13:56.90,0:13:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang bergaul tak pantas\Ndengan lawan jenis.
Dialogue: 0,0:13:59.43,0:14:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, dia Ketua Komite Disiplin.
Dialogue: 0,0:14:01.12,0:14:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi.
Dialogue: 0,0:14:02.76,0:14:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja. Manusia memang makhluk\Nyang sangat cabul.
Dialogue: 0,0:14:07.40,0:14:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memikirkan hal mesum sepanjang hari.
Dialogue: 0,0:14:10.20,0:14:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip kebun binatang\Nyang sedang musim kawin.
Dialogue: 0,0:14:13.26,0:14:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tenang saja.
Dialogue: 0,0:14:14.90,0:14:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjaga kalian tetap murni\Nagar jiwa kalian tak ternoda.
Dialogue: 0,0:14:20.13,0:14:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang seperti itu asyik juga, ya.
Dialogue: 0,0:14:23.80,0:14:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat banget!\NSejak kapan Kyougi ada di sini?
Dialogue: 0,0:14:26.63,0:14:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kali ini aku akan buat dia\Nsadar siapa bosnya.
Dialogue: 0,0:14:33.03,0:14:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kau ada perlu apa?
Dialogue: 0,0:14:35.13,0:14:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Senior jauh-jauh dariku?
Dialogue: 0,0:14:37.50,0:14:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita sepasang kekasih,
Dialogue: 0,0:14:39.90,0:14:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajar kan jika aku ingin ada di sampingmu?
Dialogue: 0,0:14:42.41,0:14:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sepasang kekasih...?!
Dialogue: 0,0:14:45.00,0:14:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Senior.
Dialogue: 0,0:14:47.63,0:14:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk momen pertama kita yang istimewa...
Dialogue: 0,0:14:50.00,0:14:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya dilakukan di mana, ya?
Dialogue: 0,0:14:53.83,0:14:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik tempatnya berkesan, ya.
Dialogue: 0,0:14:56.33,0:14:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin tentukan tempat seks\Npertama kita?!
Dialogue: 0,0:15:00.36,0:15:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar makhluk inferior budak nafsu!
Dialogue: 0,0:15:03.83,0:15:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti itu ada tahapnya...
Dialogue: 0,0:15:05.40,0:15:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan! Kita baru boleh lakukan itu\Nsetelah menikah!
Dialogue: 0,0:15:08.42,0:15:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehem.
Dialogue: 0,0:15:10.00,0:15:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkesan, ya. Rupanya kau romantis juga.
Dialogue: 0,0:15:12.30,0:15:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau menyarankan tempat apa?
Dialogue: 0,0:15:14.70,0:15:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:15:16.03,0:15:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku...
Dialogue: 0,0:15:17.50,0:15:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin taman.
Dialogue: 0,0:15:18.98,0:15:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar?!
Dialogue: 0,0:15:21.06,0:15:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Ternyata kau suka kegiatan outdoor, ya.
Dialogue: 0,0:15:24.37,0:15:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Idealnya taman di jalur\Npulang pergi sekolah.
Dialogue: 0,0:15:27.20,0:15:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bagus, kita akan teringat\Nsetiap lewat sana.
Dialogue: 0,0:15:30.23,0:15:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini cabul tulen, ya? Tidak mau.
Dialogue: 0,0:15:32.60,0:15:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malu kalau sampai ada yang lihat.
Dialogue: 0,0:15:34.80,0:15:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku lupa.
Dialogue: 0,0:15:36.83,0:15:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau cari tempat tak biasa\Nseperti bioskop?
Dialogue: 0,0:15:39.70,0:15:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku jangan sampai kelihatan orang,\Ndasar bodoh!
Dialogue: 0,0:15:42.12,0:15:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita tamasya jauh?
Dialogue: 0,0:15:43.94,0:15:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamasya? Ke mana? Tempat apa?
Dialogue: 0,0:15:46.23,0:15:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja ke pemandian air panas.
Dialogue: 0,0:15:47.96,0:15:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengincar pemandian campuran, ya!\NDasar manusia cabul budak nafsu!
Dialogue: 0,0:15:51.66,0:15:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh, bodoh, bodoh!
Dialogue: 0,0:15:53.16,0:15:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk momen pertama,\Njelas harus berduaan di kamar!
Dialogue: 0,0:15:57.88,0:16:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ngomong apa, sih?!
Dialogue: 0,0:16:00.24,0:16:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen pertamanya di kamarku.
Dialogue: 0,0:16:02.33,0:16:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:16:04.00,0:16:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:16:05.23,0:16:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayangkan bisa penuhi keinginan Senior
Dialogue: 0,0:16:07.60,0:16:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku senang dan bersemangat.
Dialogue: 0,0:16:09.84,0:16:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, tenanglah. Jangan bersemangat.
Dialogue: 0,0:16:13.40,0:16:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari jadikan ini momen tak terlupakan.
Dialogue: 0,0:16:15.96,0:16:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan pertama kita!
Dialogue: 0,0:16:22.50,0:16:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan pertama, ya?
Dialogue: 0,0:16:23.66,0:16:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu. Aku sudah tahu, kok!
Dialogue: 0,0:16:25.00,0:16:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak salah paham sama sekali.
Dialogue: 0,0:16:27.00,0:16:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya.
Dialogue: 0,0:16:28.01,0:16:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya akan masuk kamarmu\Nsaat orang tuamu ada.
Dialogue: 0,0:16:30.33,0:16:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat itu baik-baik!
Dialogue: 0,0:16:32.03,0:16:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar makhluk inferior sialan!
Dialogue: 0,0:16:35.06,0:16:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:16:42.16,0:16:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, para makhluk inferior.
Dialogue: 0,0:16:44.39,0:16:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulanglah sambil mimpikan hari\Nsaat aku memakan kalian.
Dialogue: 0,0:16:48.44,0:16:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, kita pulang bareng, yuk!
Dialogue: 0,0:16:51.23,0:16:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa aku harus pulang bersamamu?!
Dialogue: 0,0:16:54.56,0:16:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku pacar Senior.
Dialogue: 0,0:16:58.46,0:17:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacarku...!
Dialogue: 0,0:17:00.70,0:17:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ini bukan waktunya deg-degan!
Dialogue: 0,0:17:03.06,0:17:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menaksir makanan sendiri!
Dialogue: 0,0:17:04.90,0:17:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya dia ajukan permintaan\Nselancang ini.
Dialogue: 0,0:17:08.30,0:17:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Ya sudahlah.
Dialogue: 0,0:17:10.82,0:17:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau mau pulang bersamaku, ya?
Dialogue: 0,0:17:14.96,0:17:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:17:17.30,0:17:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku akan ajarkan siapa bosnya!
Dialogue: 0,0:17:22.00,0:17:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo pulang.
Dialogue: 0,0:17:23.46,0:17:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan sungkan.
Dialogue: 0,0:17:25.46,0:17:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan saja!
Dialogue: 0,0:17:31.80,0:17:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:17:32.48,0:17:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata jalan bersebelahan itu...
Dialogue: 0,0:17:35.16,0:17:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauh lebih mendebarkan dari bayanganku.
Dialogue: 0,0:17:37.96,0:17:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Senior tak jalan di sebelahku?
Dialogue: 0,0:17:41.16,0:17:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang berstatus sosial setinggi aku\Nbisa diserang kapan saja!
Dialogue: 0,0:17:44.66,0:17:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau kujadikan tameng hidupku!
Dialogue: 0,0:17:47.00,0:17:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Senior mengandalkanku, ya!
Dialogue: 0,0:17:48.92,0:17:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Senior harusnya lebih dekat!
Dialogue: 0,0:17:51.36,0:17:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi menempel ke badannya!
Dialogue: 0,0:17:53.40,0:17:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya kalau Senior terpisah dariku,
Dialogue: 0,0:17:54.96,0:17:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo bergandengan...
Dialogue: 0,0:17:56.96,0:17:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tangan!
Dialogue: 0,0:18:03.46,0:18:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau ada anak yang lahir\Nkarena kita gandengan?!
Dialogue: 0,0:18:07.27,0:18:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya dia mempermalukanku\Ndengan kelakuan sesatnya!
Dialogue: 0,0:18:09.69,0:18:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, dia itu iblis!
Dialogue: 0,0:18:11.19,0:18:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau menolak, aku dianggap pengecut.
Dialogue: 0,0:18:13.90,0:18:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang iblis tak kenal takut, kok!
Dialogue: 0,0:18:17.43,0:18:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:18:18.83,0:18:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?!
Dialogue: 0,0:18:24.23,0:18:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:18:25.36,0:18:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:18:27.00,0:18:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa, sih?
Dialogue: 0,0:18:28.76,0:18:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok akrab dan mengajakku bicara.
Dialogue: 0,0:18:30.54,0:18:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu salah apa?
Dialogue: 0,0:18:32.30,0:18:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shh!
Dialogue: 0,0:18:36.17,0:18:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita jalan bersebelahan dan "gandengan"\Nsesuai keinginanmu.
Dialogue: 0,0:18:39.70,0:18:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, bagaimana perasaanmu saat ini?
Dialogue: 0,0:18:42.63,0:18:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap jiwa.
Dialogue: 0,0:18:44.96,0:18:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja?!
Dialogue: 0,0:18:46.16,0:18:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior tak ingin melepasku\Nsampai pakai tali kekang.
Dialogue: 0,0:18:49.00,0:18:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior ingin mendominasiku\Nsecara fisik dan mental.
Dialogue: 0,0:18:51.96,0:18:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara hati Senior yang seperti itu
Dialogue: 0,0:18:54.23,0:18:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan cintamu tersampaikan dengan jelas!
Dialogue: 0,0:18:57.76,0:19:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kok. Aku tak ada maksud...
Dialogue: 0,0:19:02.10,0:19:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja nanti, dasar makhluk inferior!
Dialogue: 0,0:19:04.96,0:19:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:19:12.10,0:19:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, bikin kesal dan jengkel saja!
Dialogue: 0,0:19:14.80,0:19:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap bersama Kyougi,\Npasti ada yang tidak beres.
Dialogue: 0,0:19:17.40,0:19:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang ke dunia manusia\Nbukan untuk melawak, tahu!
Dialogue: 0,0:19:21.96,0:19:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:19:23.10,0:19:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai berhalusinasi dengar suaranya.
Dialogue: 0,0:19:25.80,0:19:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:19:26.97,0:19:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang tidak beres denganku.
Dialogue: 0,0:19:29.46,0:19:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kyougi?!
Dialogue: 0,0:19:31.83,0:19:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Senior!
Dialogue: 0,0:19:33.50,0:19:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau sampai babak belur?
Dialogue: 0,0:19:35.70,0:19:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, tanganku masih diikat\Nke tangan Senior.
Dialogue: 0,0:19:39.26,0:19:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:19:40.32,0:19:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan bicara seolah aku pacar\Nyang tak ingin berpisah!
Dialogue: 0,0:19:43.96,0:19:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior. Aku... Aku...
Dialogue: 0,0:19:46.30,0:19:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku jalan-jalan\Nseekstrem ini.
Dialogue: 0,0:19:49.23,0:19:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau optimis banget, ya.
Dialogue: 0,0:19:51.56,0:19:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa diperlakukan seperti peliharaan\Ntidak terlalu buruk.
Dialogue: 0,0:19:53.96,0:19:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ubah kecelakaan ini\Njadi roleplay hewan peliharaan!
Dialogue: 0,0:19:57.06,0:20:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, lagi-lagi aku\Nterbawa alur Kyougi.
Dialogue: 0,0:20:01.60,0:20:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:20:03.06,0:20:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sejauh ini,
Dialogue: 0,0:20:06.23,0:20:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin lakukan sesuatu dengan Senior.
Dialogue: 0,0:20:10.46,0:20:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang dilakukan saat di taman itu...?
Dialogue: 0,0:20:19.30,0:20:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:20:20.56,0:20:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kroket dari toko daging di sana.
Dialogue: 0,0:20:22.80,0:20:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu kroket.
Dialogue: 0,0:20:25.56,0:20:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jajan sesuatu bersama pacarku.
Dialogue: 0,0:20:30.63,0:20:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya ini yang ingin dia lakukan.
Dialogue: 0,0:20:32.76,0:20:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:20:33.36,0:20:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior ingin apa tadi?
Dialogue: 0,0:20:35.43,0:20:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin apa-apa!
Dialogue: 0,0:20:37.26,0:20:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sausnya tidak ada?
Dialogue: 0,0:20:38.56,0:20:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, langsung dimakan saja.
Dialogue: 0,0:20:41.30,0:20:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu saja sudah enak banget, kok!
Dialogue: 0,0:20:42.80,0:20:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah lebih enak pakai saus?
Dialogue: 0,0:20:45.10,0:20:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior serius bilang begitu?
Dialogue: 0,0:20:48.03,0:20:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak sopan pada Pak Kroket, lo...
Dialogue: 0,0:20:50.23,0:20:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kecewa.
Dialogue: 0,0:20:51.52,0:20:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, sih? Aku suka pakai saus.
Dialogue: 0,0:20:53.46,0:20:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paling tak ingin melihatmu kecewa.
Dialogue: 0,0:20:55.86,0:20:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik, Senior.
Dialogue: 0,0:20:57.50,0:20:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kroket dari toko ini enak banget,
Dialogue: 0,0:20:59.66,0:21:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sadar saat berusaha ungkap\Nresep rahasianya
Dialogue: 0,0:21:02.39,0:21:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengupas, membongkar, dan memisahkan\Nsetiap bahannya.
Dialogue: 0,0:21:05.60,0:21:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang, daging, dan bentuk elipsnya.
Dialogue: 0,0:21:08.63,0:21:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya rahasianya ada di sana!
Dialogue: 0,0:21:10.60,0:21:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior tahu angka 1 banding 1,618?
Dialogue: 0,0:21:12.69,0:21:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di-Dia jauh lebih cerewet dari biasanya.\N- Ya, itu Rasio Emas!
Dialogue: 0,0:21:15.56,0:21:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kroket ini dibuat dengan Rasio Emas!
Dialogue: 0,0:21:18.46,0:21:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kulitnya bersinar bagai emas!
Dialogue: 0,0:21:21.30,0:21:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kroket ini adalah...
Dialogue: 0,0:21:23.66,0:21:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kroket Emas!
Dialogue: 0,0:21:30.43,0:21:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:21:31.56,0:21:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau hanya cowok cabul,
Dialogue: 0,0:21:33.86,0:21:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata bisa cerita seantusias ini\Nsoal kroket.
Dialogue: 0,0:21:36.80,0:21:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Kyougi punya sisi manis juga.
Dialogue: 0,0:21:39.05,0:21:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, cabul?
Dialogue: 0,0:21:40.43,0:21:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku cuma perlu makan tanpa saus, 'kan?
Dialogue: 0,0:21:42.78,0:21:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja. Nah, silakan dimakan.
Dialogue: 0,0:21:46.60,0:21:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara makannya benar-benar berisik,
Dialogue: 0,0:21:49.16,0:21:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bolehlah untuk sesekali.
Dialogue: 0,0:21:55.63,0:21:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Enak.
Dialogue: 0,0:21:58.06,0:22:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal makanan lain tak ada rasanya.
Dialogue: 0,0:22:00.50,0:22:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:22:02.06,0:22:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kroketnya lebih enak dari biasanya.
Dialogue: 0,0:22:06.03,0:22:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena aku makan bersama Senior.
Dialogue: 0,0:22:12.00,0:22:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak karena makan bersama...
Dialogue: 0,0:22:22.20,0:22:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat apa, sih?
Dialogue: 0,0:22:24.06,0:22:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak. Aku merasa...
Dialogue: 0,0:22:27.30,0:22:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior saat makan imut banget.
Dialogue: 0,0:22:32.36,0:22:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar... Makhluk inferior sialan.
