Dialogue: 0,0:02:19.11,0:02:22.87,sign,,0000,0000,0000,,#08 KELUARGA KANAN YANG MENYAMBUT PULANG
Dialogue: 0,0:10:07.04,0:10:11.00,sign,,0000,0000,0000,,TIDAK MUNGKIN... KANAN TERNYATA SUKA AKU?\NDEG, DEG
Dialogue: 0,0:10:42.78,0:10:43.41,sign,,0000,0000,0000,,RELI STEMPEL UNTUK MENGAKUI PACAR\NMULAI - GARIS FINIS
Dialogue: 0,0:23:05.73,0:23:08.07,sign,,0000,0000,0000,,RELI STEMPEL UNTUK MENGAKUI PACAR\NMULAI - GARIS FINIS
Dialogue: 0,0:00:12.33,0:00:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Beelzebub.
Dialogue: 0,0:00:13.63,0:00:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya Nona Kanan\Ntelah tiba di Dunia Iblis.
Dialogue: 0,0:00:17.00,0:00:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:00:18.33,0:00:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia terlihat imut?
Dialogue: 0,0:00:19.85,0:00:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:00:22.05,0:00:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menerima laporan bahwa\Nbeliau amat sangat imut.
Dialogue: 0,0:00:25.57,0:00:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dong. Ya, ya.
Dialogue: 0,0:00:28.35,0:00:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia imut sekali sampai membuatku kerepotan.
Dialogue: 0,0:00:30.59,0:00:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa benar-benar takut\Nada serangga tidak jelas menempelinya.
Dialogue: 0,0:00:34.88,0:00:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai itu...
Dialogue: 0,0:00:37.28,0:00:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya Nona membawa pulang kekasihnya.
Dialogue: 0,0:00:41.93,0:00:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke... Ke-Ke... Ke, Ke...!
Dialogue: 0,0:00:45.48,0:00:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekasih?!
Dialogue: 0,0:02:29.97,0:02:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah keluarga Senior.
Dialogue: 0,0:02:32.01,0:02:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waw! Itu istana!
Dialogue: 0,0:02:35.15,0:02:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior ternyata anak orang kaya, ya?
Dialogue: 0,0:02:37.41,0:02:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku cerita saat pertama ketemu?
Dialogue: 0,0:02:39.71,0:02:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,\Nternyata Makau itu tempat yang gelap, ya.
Dialogue: 0,0:02:45.23,0:02:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama pergi ke Makau.
Dialogue: 0,0:02:48.13,0:02:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:49.10,0:02:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau?
Dialogue: 0,0:02:50.90,0:02:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan Makau, tapi Makai, Dunia Iblis.
Dialogue: 0,0:02:53.82,0:02:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia Iblis?!
Dialogue: 0,0:02:57.65,0:02:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makau itu prefektur mana, ya?
Dialogue: 0,0:02:59.24,0:03:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Du-Dunia Iblis?
Dialogue: 0,0:03:04.17,0:03:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku pergi ke mabes musuh sendirian...?
Dialogue: 0,0:03:13.09,0:03:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali, Nona.
Dialogue: 0,0:03:18.40,0:03:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:03:20.22,0:03:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama lihat sambutan seperti ini.
Dialogue: 0,0:03:22.61,0:03:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Antusias, antusias.\N- Jangan berisik. Bikin malu saja.
Dialogue: 0,0:03:25.14,0:03:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Nona.
Dialogue: 0,0:03:28.09,0:03:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami bawakan barangnya.
Dialogue: 0,0:03:30.30,0:03:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, yang di belakang itu oleh-oleh.
Dialogue: 0,0:03:33.08,0:03:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:34.53,0:03:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami, aku akan pergi menemui Ayah dulu,
Dialogue: 0,0:03:38.07,0:03:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau antar yang lain ke ruang...
Dialogue: 0,0:03:39.38,0:03:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:03:40.84,0:03:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh ikut ke toilet?
Dialogue: 0,0:03:42.33,0:03:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan diucapkan kencang-kencang!
Dialogue: 0,0:03:44.12,0:03:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat, kok. Di sana.
Dialogue: 0,0:03:51.38,0:03:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:03:53.50,0:03:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat mana, ya?
Dialogue: 0,0:03:56.02,0:03:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:03:57.31,0:03:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tersesat?
Dialogue: 0,0:04:01.85,0:04:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kakaknya cantik banget!
Dialogue: 0,0:04:04.82,0:04:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:04:08.26,0:04:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ah...
Dialogue: 0,0:04:09.93,0:04:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, walah, walah... Walah...
Dialogue: 0,0:04:12.73,0:04:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lelaki!
Dialogue: 0,0:04:15.48,0:04:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada pria yang penuh nafsu berahi\Nd-di dalam istana!
Dialogue: 0,0:04:20.26,0:04:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu? Ada pria mesum?!
Dialogue: 0,0:04:22.26,0:04:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, bersembunyilah di belakangku!
Dialogue: 0,0:04:24.73,0:04:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Bokongnya ada di depan wajahku!
Dialogue: 0,0:04:28.15,0:04:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar kau, pria mesum!
Dialogue: 0,0:04:31.75,0:04:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, kau baik-baik saja?
Dialogue: 0,0:04:34.68,0:04:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh, duh...
Dialogue: 0,0:04:35.83,0:04:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membuat Ibu menangis.
Dialogue: 0,0:04:38.77,0:04:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kuadukan kau memerkosa Ibu, lo.
Dialogue: 0,0:04:43.81,0:04:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau membuat Ibu menangis.\NKeterlaluan.
Dialogue: 0,0:04:47.05,0:04:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada dua gadis iblis?!
Dialogue: 0,0:04:49.64,0:04:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:50.92,0:04:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ini bukan waktunya membahas itu.
Dialogue: 0,0:04:52.94,0:04:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik-adik, katanya ada pria mesum di sini,\Nberhati-hatilah!
Dialogue: 0,0:04:56.20,0:04:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu maksudnya kau, tahu.
Dialogue: 0,0:04:58.62,0:04:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?!
Dialogue: 0,0:04:59.99,0:05:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu punya ketakutan berlebihan pada pria.
Dialogue: 0,0:05:03.59,0:05:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, walau itu tamu,\Ntak boleh ada lelaki yang mendekat.
Dialogue: 0,0:05:07.21,0:05:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu aturannya.
Dialogue: 0,0:05:08.52,0:05:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau akan dipenggal, lo?
Dialogue: 0,0:05:11.93,0:05:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak kasihan sekali, ya.
Dialogue: 0,0:05:15.27,0:05:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... pria mesumnya?
Dialogue: 0,0:05:19.52,0:05:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, dia manusia.
Dialogue: 0,0:05:22.48,0:05:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Aku manusia.
Dialogue: 0,0:05:24.68,0:05:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Kyougi Youji.
Dialogue: 0,0:05:25.93,0:05:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:05:27.99,0:05:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku\Nmelihat babi sesehat dia!
Dialogue: 0,0:05:31.27,0:05:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Babi?
Dialogue: 0,0:05:32.86,0:05:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kak Babi.
Dialogue: 0,0:05:34.67,0:05:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku boleh memakanmu, 'kan?\N- A-Apa?!
Dialogue: 0,0:05:38.66,0:05:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati!
Dialogue: 0,0:05:42.23,0:05:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tak bisa.
Dialogue: 0,0:05:43.63,0:05:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku milik Senior...
Dialogue: 0,0:05:45.66,0:05:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih? Sudah ada yang punya, ya.
Dialogue: 0,0:05:49.48,0:05:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Ja... Jangan-jangan, pemuda itu...\Norang yang dibawa Kanan?
Dialogue: 0,0:05:55.80,0:05:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babi yang dibesarkan Kakak\Ndi peternakannya, ya?
Dialogue: 0,0:05:59.90,0:06:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kalian keluarga Senior Kanan?
Dialogue: 0,0:06:03.83,0:06:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul itu. Aku adiknya, Milch.
Dialogue: 0,0:06:08.93,0:06:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel.
Dialogue: 0,0:06:09.94,0:06:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ibunya, Lilim.
Dialogue: 0,0:06:18.50,0:06:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang, Papa.
Dialogue: 0,0:06:20.60,0:06:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan, kudengar kau bawa pulang kekasih.\NBenar begitu?
Dialogue: 0,0:06:25.80,0:06:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu... Begini...
Dialogue: 0,0:06:29.13,0:06:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku spontan membawa Kyougi ke sini,\Ntapi sekarang harus bilang apa...?
Dialogue: 0,0:06:34.01,0:06:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti dimarahi kalau ketahuan\Nberpacaran dengan manusia.
Dialogue: 0,0:06:37.93,0:06:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Papa.
Dialogue: 0,0:06:41.33,0:06:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebenarnya...
Dialogue: 0,0:06:50.82,0:06:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa senang sekali!
Dialogue: 0,0:06:54.97,0:06:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:55.81,0:06:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan, selamat, ya!
Dialogue: 0,0:06:59.35,0:07:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Ternyata tidak ditentang?
Dialogue: 0,0:07:02.63,0:07:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan, selamat!
Dialogue: 0,0:07:04.84,0:07:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?
Dialogue: 0,0:07:06.35,0:07:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar kau sudah punya pacar.
Dialogue: 0,0:07:09.54,0:07:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Mama takut berlebihan pada lelaki,
Dialogue: 0,0:07:12.04,0:07:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi sempat cemas karena tidak bisa\Nmemberikan edukasi seputar seks.
Dialogue: 0,0:07:16.26,0:07:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Edukasi seputar seks?
Dialogue: 0,0:07:18.17,0:07:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia...
Dialogue: 0,0:07:20.02,0:07:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe kesukaan Mama...
Dialogue: 0,0:07:22.24,0:07:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama senang melihat pacarmu\Ngadis yang cantik sepertinya!
Dialogue: 0,0:07:28.93,0:07:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan lelaki yang hina dina,
Dialogue: 0,0:07:30.87,0:07:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para gadis harus berpacaran\Ndengan gadis lainnya.
Dialogue: 0,0:07:33.89,0:07:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu, dia orang dari Surga.
Dialogue: 0,0:07:35.89,0:07:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar bersyukur.
Dialogue: 0,0:07:37.26,0:07:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa salah paham seperti ini?!
Dialogue: 0,0:07:40.03,0:07:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Perempuan kelebihan daging ini?
Dialogue: 0,0:07:43.10,0:07:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selera Kakak jelek banget, ya?\NPilih babi betina kelebihan daging dari Surga.
Dialogue: 0,0:07:48.99,0:07:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:50.74,0:07:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan sebenarnya suka aku?
Dialogue: 0,0:07:53.19,0:07:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin, lah!
Dialogue: 0,0:07:54.79,0:07:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, tenang dulu.\NKalian salah paham!
Dialogue: 0,0:07:58.75,0:07:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:08:00.54,0:08:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacarku itu Kyougi!
Dialogue: 0,0:08:06.58,0:08:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi?
Dialogue: 0,0:08:08.56,0:08:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Ja-Jangan-jangan...!
Dialogue: 0,0:08:10.69,0:08:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tadi ketemu kita...
Dialogue: 0,0:08:12.75,0:08:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babi yang itu?
Dialogue: 0,0:08:14.44,0:08:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi pacaran di sini\Nmaksudnya berbentuk kontrak.
Dialogue: 0,0:08:17.85,0:08:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku sebenarnya tidak su-suka\Ndengan makhluk inferior itu.
Dialogue: 0,0:08:21.77,0:08:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak bohong, ah!
Dialogue: 0,0:08:23.64,0:08:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak berpacaran dengan manusia?
Dialogue: 0,0:08:25.52,0:08:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Dia lelaki!
Dialogue: 0,0:08:28.60,0:08:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak... saking fokusnya menikmati gourmet,
Dialogue: 0,0:08:31.08,0:08:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai melihat makanannya\Nsebagai objek seksual.
Dialogue: 0,0:08:33.08,0:08:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan perlakukan aku seperti wanita cabul!
Dialogue: 0,0:08:36.34,0:08:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalian kenapa?
Dialogue: 0,0:08:38.26,0:08:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Kanan...
Dialogue: 0,0:08:40.17,0:08:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak berat mengatakan ini.
Dialogue: 0,0:08:44.35,0:08:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia itu...
Dialogue: 0,0:08:46.05,0:08:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah...
Dialogue: 0,0:08:49.36,0:08:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, kami kira manusia itulah\Noleh-oleh yang kau bawa.
Dialogue: 0,0:08:53.66,0:08:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, telah kami masak.
Dialogue: 0,0:08:55.15,0:08:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf.
Dialogue: 0,0:08:58.74,0:09:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:09:01.07,0:09:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menu utama kita hari ini, jiwa segar\Nyang dimakan hidup-hidup.
Dialogue: 0,0:09:05.92,0:09:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi?!
Dialogue: 0,0:09:08.43,0:09:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan pelayan ceroboh ini.
Dialogue: 0,0:09:10.59,0:09:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah lewat dari batas ceroboh, tahu!
Dialogue: 0,0:09:13.03,0:09:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi juga kenapa\Npasrah saja ditelanjangi?!
Dialogue: 0,0:09:15.39,0:09:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira ini tradisi di rumah Senior.
Dialogue: 0,0:09:17.90,0:09:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curigaan sedikit, dong!
Dialogue: 0,0:09:19.77,0:09:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:09:20.48,0:09:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria besar ini ayah Senior, ya?
Dialogue: 0,0:09:24.98,0:09:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kyougi Youji, pacar putri Anda.
Dialogue: 0,0:09:29.13,0:09:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu!
Dialogue: 0,0:09:32.86,0:09:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berani sekali di hadapan Papa\Nyang seorang Iblis Agung.
Dialogue: 0,0:09:38.18,0:09:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maskulin sekali.
Dialogue: 0,0:09:39.61,0:09:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau maskulin sekali.
Dialogue: 0,0:09:43.46,0:09:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:09:48.51,0:09:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau... lumayan keren tadi.
Dialogue: 0,0:09:53.33,0:09:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, ya.
Dialogue: 0,0:09:55.12,0:09:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Senior.\N- Kanan.
Dialogue: 0,0:09:58.63,0:10:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah tidak merestui hubunganmu\Njika pasangannya seorang manusia!
Dialogue: 0,0:10:03.50,0:10:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:10:11.42,0:10:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah tidak merestui hubunganmu\Njika pasangannya seorang manusia!
Dialogue: 0,0:10:16.72,0:10:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:10:19.86,0:10:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah selalu ingin ucapkan kalimat itu.
Dialogue: 0,0:10:22.58,0:10:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:10:23.28,0:10:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kau keren sekali, Suamiku!
Dialogue: 0,0:10:29.20,0:10:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dulu bercandanya.
Dialogue: 0,0:10:31.00,0:10:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai Iblis, aku tak bisa merestui\Nanak kesayanganku
Dialogue: 0,0:10:34.60,0:10:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berpacaran dengan manusia begitu saja.
Dialogue: 0,0:10:36.85,0:10:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:10:38.06,0:10:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:10:43.42,0:10:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reli stempel?
Dialogue: 0,0:10:45.28,0:10:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ingin berpacaran dengan manusia,\Ncoba yakinkan kami berempat.
Dialogue: 0,0:10:50.20,0:10:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stempel akan diberikan\Nmereka yang sudah merestui.
Dialogue: 0,0:10:53.56,0:10:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terkumpul keempatnya,\Naku akan merestui hubungan kalian.
Dialogue: 0,0:10:58.13,0:11:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku butuh izin dari kalian...
Dialogue: 0,0:11:00.58,0:11:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior!
Dialogue: 0,0:11:01.86,0:11:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya perlu meyakinkan\Nanggota keluargamu, 'kan?
Dialogue: 0,0:11:05.95,0:11:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:11:07.01,0:11:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terima jika ini bisa\Nmembuat kita resmi berpacaran.
Dialogue: 0,0:11:11.29,0:11:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian cinta ini!
Dialogue: 0,0:11:17.39,0:11:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia keren juga karena bisa\Nucapkan itu dengan wajah datar.
Dialogue: 0,0:11:21.53,0:11:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:11:23.71,0:11:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch!
Dialogue: 0,0:11:24.99,0:11:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:11:27.16,0:11:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel!
Dialogue: 0,0:11:28.54,0:11:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph.
Dialogue: 0,0:11:30.61,0:11:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:11:32.16,0:11:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:11:33.98,0:11:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya, Ibu!
Dialogue: 0,0:11:35.54,0:11:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lelaki!
Dialogue: 0,0:11:37.88,0:11:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama juga ingin mendukung\Nhubungan asmaramu, Kanan.
Dialogue: 0,0:11:41.96,0:11:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia lelaki...
Dialogue: 0,0:11:44.13,0:11:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NAndai saja Kyougi perempuan.
Dialogue: 0,0:11:48.57,0:11:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:11:49.77,0:11:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:11:56.01,0:11:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:11:57.50,0:11:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:11:58.44,0:11:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah?
Dialogue: 0,0:11:59.15,0:12:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, astaga. Dia manis banget!
Dialogue: 0,0:12:03.45,0:12:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu.
Dialogue: 0,0:12:04.63,0:12:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, aku perempuan.
Dialogue: 0,0:12:06.86,0:12:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Youko!
Dialogue: 0,0:12:16.00,0:12:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?
Dialogue: 0,0:12:16.93,0:12:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu kaki! Tidak suka!
Dialogue: 0,0:12:18.83,0:12:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:12:19.86,0:12:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa cukur bulu kakiku!
Dialogue: 0,0:12:22.02,0:12:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga. Masa pubertas.
Dialogue: 0,0:12:24.80,0:12:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:12:26.13,0:12:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin Ibu takut dengan lelaki\Nyang sudah lewat masa pubertas.
Dialogue: 0,0:12:31.36,0:12:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, minum ini!
Dialogue: 0,0:12:33.23,0:12:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:39.74,0:12:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ini apa?
Dialogue: 0,0:12:41.97,0:12:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat rahasia buatan Dunia Iblis.
Dialogue: 0,0:12:44.09,0:12:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang meminum itu...
Dialogue: 0,0:12:48.17,0:12:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut!
Dialogue: 0,0:12:50.14,0:12:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi imut banget!
Dialogue: 0,0:12:52.86,0:12:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyal, mulus, benar-benar menggemaskan!
Dialogue: 0,0:12:56.77,0:12:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Ibu. Ini Youji.
Dialogue: 0,0:12:59.32,0:13:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba gendong dia.
Dialogue: 0,0:13:01.26,0:13:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:13:06.32,0:13:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal mereka imut saat sekecil ini.
Dialogue: 0,0:13:10.31,0:13:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa seiring mereka tumbuh dewasa,
Dialogue: 0,0:13:12.87,0:13:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka malah menjadi makhluk hina\Nyang penuh nafsu berahi?
Dialogue: 0,0:13:18.52,0:13:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja mereka terus seperti ini,\Ntak perlu tumbuh dewasa.
Dialogue: 0,0:13:31.70,0:13:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:13:36.48,0:13:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa kasih stempel,\Ntapi bisa buatkan kue.
Dialogue: 0,0:13:41.66,0:13:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tidak makan kue buatan Ibu.
Dialogue: 0,0:13:44.56,0:13:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar!
Dialogue: 0,0:13:46.20,0:13:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:13:47.76,0:13:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik... Kyougi.
Dialogue: 0,0:13:50.16,0:13:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadir.
Dialogue: 0,0:13:51.13,0:13:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku tidak\Nenak hati ucapkan ini...
Dialogue: 0,0:13:53.86,0:13:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa usahakan\Nsupaya tidak kelihatan olehku?
Dialogue: 0,0:13:57.15,0:13:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:13:58.61,0:14:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berada di dekat Ibu saja\Nsudah cukup bagiku.
Dialogue: 0,0:14:01.47,0:14:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Tapi jangan mendekat, ya.
Dialogue: 0,0:14:03.67,0:14:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan buatan Ibu...
Dialogue: 0,0:14:05.94,0:14:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar ingin coba.
Dialogue: 0,0:14:11.48,0:14:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, aku juga ingin bantu.
Dialogue: 0,0:14:14.59,0:14:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Kanan, kau belum pernah memasak...
Dialogue: 0,0:14:17.22,0:14:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, aku juga ingin lakukan!
Dialogue: 0,0:14:21.33,0:14:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NDia ingin unjuk kebolehan di depannya.
Dialogue: 0,0:14:25.21,0:14:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama senang bisa memasak bersamamu.
Dialogue: 0,0:14:31.29,0:14:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke. Berhenti, Kanan.
Dialogue: 0,0:14:33.55,0:14:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, Bu?
Dialogue: 0,0:14:35.13,0:14:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bukan ingin membunuhnya,\Njadi jangan dipegang seperti itu.
Dialogue: 0,0:14:39.27,0:14:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisaunya dipegang seperti ini...
Dialogue: 0,0:14:41.62,0:14:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:42.62,0:14:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan apelnya supaya tanganmu tidak teriris.
Dialogue: 0,0:14:49.18,0:14:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Coba lakukan sendiri.
Dialogue: 0,0:14:54.70,0:14:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya jari tidak teriris...
Dialogue: 0,0:15:00.24,0:15:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kanan.
Dialogue: 0,0:15:04.75,0:15:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita latihan dulu pakai mainan.
Dialogue: 0,0:15:07.52,0:15:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak apa-apa, kok!
Dialogue: 0,0:15:09.08,0:15:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai!
Dialogue: 0,0:15:10.91,0:15:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potongannya rapi.\NKerja bagus, Kanan.
Dialogue: 0,0:15:16.81,0:15:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kalinya masak bersama Kanan...
Dialogue: 0,0:15:19.76,0:15:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NHarus kurekam untuk kenang-kenangan!
Dialogue: 0,0:15:23.05,0:15:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan yang sedang memecah telur.
Dialogue: 0,0:15:26.15,0:15:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan hebat!
Dialogue: 0,0:15:28.07,0:15:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang membuka tepung.
Dialogue: 0,0:15:31.69,0:15:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan hebat!
Dialogue: 0,0:15:33.82,0:15:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan sedang mengaduk sampai berbusa.
Dialogue: 0,0:15:37.85,0:15:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan imut!
Dialogue: 0,0:15:40.27,0:15:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan cuci alat masak ini lagi!
Dialogue: 0,0:15:41.94,0:15:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini kenang-kenangan\Nmemasak bersama Kanan,
Dialogue: 0,0:15:44.42,0:15:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan pajang semuanya di kamar!
Dialogue: 0,0:15:46.97,0:15:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Ibu bikin malu saja!
Dialogue: 0,0:15:49.31,0:15:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, Mama sangat senang\Nkarena bisa memasak bersamamu.
Dialogue: 0,0:15:54.97,0:16:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Mama suka melihatmu\Nberusaha demi orang yang kau suka.
Dialogue: 0,0:16:01.65,0:16:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, ini bukan suka atau benci,\Ntapi karena kontrak kami...
Dialogue: 0,0:16:08.34,0:16:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sangka bisa\Nlakukan ini bersama Kanan.
Dialogue: 0,0:16:11.57,0:16:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berkat dia menaksir seseorang.
Dialogue: 0,0:16:15.11,0:16:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:16:16.06,0:16:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, ya.\NJangan nakal dan cicip duluan, ya.
Dialogue: 0,0:16:19.43,0:16:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku marah, lo.
Dialogue: 0,0:16:20.69,0:16:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku kelepasan.
Dialogue: 0,0:16:22.71,0:16:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:16:23.77,0:16:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, kau barusan...
Dialogue: 0,0:16:28.41,0:16:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ah... A-A-Aku...
Dialogue: 0,0:16:31.16,0:16:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sengaja menyentuh lelaki!
Dialogue: 0,0:16:35.12,0:16:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, tenangkan dirimu!
Dialogue: 0,0:16:36.77,0:16:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik napas, keluarkan.
Dialogue: 0,0:16:40.91,0:16:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai!
Dialogue: 0,0:16:42.76,0:16:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah berusaha keras.
Dialogue: 0,0:16:44.51,0:16:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya sangat bagus.
Dialogue: 0,0:16:47.29,0:16:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:16:48.62,0:16:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, masih perlu sentuhan terakhir.
Dialogue: 0,0:16:51.04,0:16:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sentuhan akhir?
Dialogue: 0,0:16:52.35,0:16:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jangan-jangan, "itu"?
Dialogue: 0,0:16:54.53,0:16:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:16:56.82,0:16:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:17:01.85,0:17:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah enak.
Dialogue: 0,0:17:03.86,0:17:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan sihir cinta...
Dialogue: 0,0:17:05.53,0:17:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai topping.
Dialogue: 0,0:17:07.64,0:17:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, imut banget!
Dialogue: 0,0:17:10.75,0:17:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi Dik Kyougi menyebutku imut?
Dialogue: 0,0:17:16.64,0:17:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diingat lagi, sudah berapa ribu tahun\Nsejak aku menyentuh lelaki selain Papa?
Dialogue: 0,0:17:22.89,0:17:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu...
Dialogue: 0,0:17:24.24,0:17:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang menyentuhnya lebih dulu.
Dialogue: 0,0:17:28.21,0:17:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi padaku?
Dialogue: 0,0:17:31.13,0:17:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:17:32.48,0:17:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tembak lagi lasernya!
Dialogue: 0,0:17:34.26,0:17:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah.
Dialogue: 0,0:17:36.88,0:17:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakan laser cinta...
Dialogue: 0,0:17:39.55,0:17:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sedang buat kudapan.
Dialogue: 0,0:17:41.78,0:17:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia tidak pernah lakukan itu.
Dialogue: 0,0:17:45.38,0:17:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:17:46.65,0:17:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kok. I-Ini...
Dialogue: 0,0:17:48.89,0:17:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku paham sekarang!
Dialogue: 0,0:17:50.70,0:17:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak ingin unjuk kebolehan ke Kak Pacar.
Dialogue: 0,0:17:55.02,0:17:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:17:55.98,0:17:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:17:57.13,0:17:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu, kok!
Dialogue: 0,0:17:59.13,0:18:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang mengundangnya, lo!\NJelas perlu sajikan sesuatu, 'kan?
Dialogue: 0,0:18:03.91,0:18:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini sajian, biar Mil cicip dulu.
Dialogue: 0,0:18:09.45,0:18:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:18:10.20,0:18:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, Milch!
Dialogue: 0,0:18:11.85,0:18:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa?
Dialogue: 0,0:18:13.97,0:18:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa masih tanya?
Dialogue: 0,0:18:15.90,0:18:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini kue pertama yang kubuat...
Dialogue: 0,0:18:19.31,0:18:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin Kyougi yang pertama makan.
Dialogue: 0,0:18:22.73,0:18:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku bisa\Nkatakan itu di depan mereka!
Dialogue: 0,0:18:25.16,0:18:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?!
Dialogue: 0,0:18:27.13,0:18:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, Kakak berpikir ingin\Nkue pertamanya dimakan oleh Kak Pacar.
Dialogue: 0,0:18:35.64,0:18:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja bukan!
Dialogue: 0,0:18:36.99,0:18:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi benar juga,\Nkasihan Milch kalau sampai sakit perut.
Dialogue: 0,0:18:41.37,0:18:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cicip untuk tes racun, Kyougi.
Dialogue: 0,0:18:43.18,0:18:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati!
Dialogue: 0,0:18:44.55,0:18:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan Senior,\Nmasakan pertama buatan tangan!
Dialogue: 0,0:18:48.13,0:18:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan!
Dialogue: 0,0:18:49.67,0:18:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:18:51.48,0:18:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah di saat seperti ini\Nlebih baik kalau disuapi?
Dialogue: 0,0:18:55.16,0:18:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku lakukan itu!
Dialogue: 0,0:18:56.86,0:18:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Babi juga ingin disuapi, 'kan?
Dialogue: 0,0:18:59.37,0:19:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin disuapi!
Dialogue: 0,0:19:00.99,0:19:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ngotot banget, deh. Jijik.
Dialogue: 0,0:19:05.18,0:19:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja, kok.
Dialogue: 0,0:19:06.72,0:19:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Kakak tadi bilang tidak mau menyuapi.
Dialogue: 0,0:19:11.50,0:19:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, Kak Babi.
Dialogue: 0,0:19:15.32,0:19:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa boleh buat.
Dialogue: 0,0:19:19.01,0:19:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sentuhan setelah seribu tahun...
Dialogue: 0,0:19:21.87,0:19:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seribu tahun... Sentuhan.
Dialogue: 0,0:19:24.93,0:19:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini.
Dialogue: 0,0:19:25.88,0:19:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka mulut.
Dialogue: 0,0:19:31.20,0:19:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior? Masih belum?
Dialogue: 0,0:19:34.32,0:19:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang dapat kue pertama Kakak.
Dialogue: 0,0:19:40.88,0:19:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch!
Dialogue: 0,0:19:42.64,0:19:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan semarah itu, dong, Kak.
Dialogue: 0,0:19:45.37,0:19:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, kok.
Dialogue: 0,0:19:47.26,0:19:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, Kak Babi juga coba!
Dialogue: 0,0:19:51.43,0:19:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:19:52.55,0:19:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, 'kan?
Dialogue: 0,0:19:55.12,0:19:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, enak!
Dialogue: 0,0:19:57.12,0:19:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas, dong.
Dialogue: 0,0:19:59.78,0:20:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau disuapi dengan garpu\Nyang sudah masuk mulut Mil.
Dialogue: 0,0:20:03.74,0:20:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ciuman tidak langsung\Ndengan babi rendahan sepertimu.
Dialogue: 0,0:20:11.02,0:20:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:20:12.37,0:20:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, kenapa? Marah, ya?
Dialogue: 0,0:20:16.11,0:20:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, dong.\NKan adikmu yang imut ini cuma jahil. Ya?
Dialogue: 0,0:20:22.69,0:20:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa cemberut?
Dialogue: 0,0:20:24.46,0:20:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang seperti sudah makanan sehari-hari, 'kan?\NToh kalian pacaran.
Dialogue: 0,0:20:28.14,0:20:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\Npasti sudah lakukan yang lebih dari ini.
Dialogue: 0,0:20:32.70,0:20:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:20:33.82,0:20:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seriusan yang pertama?
Dialogue: 0,0:20:38.18,0:20:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pecundang.
Dialogue: 0,0:20:41.56,0:20:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch!
Dialogue: 0,0:20:44.19,0:20:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun. Kakak seram!
Dialogue: 0,0:20:47.46,0:20:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti, Milch!
Dialogue: 0,0:20:49.40,0:20:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemari kau!
Dialogue: 0,0:20:52.09,0:20:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku, Ibu!
Dialogue: 0,0:20:55.33,0:21:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyentuh lelaki selain Papa.
Dialogue: 0,0:21:00.34,0:21:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ibu?\N- Menyentuh lelaki selain Papa...
Dialogue: 0,0:21:02.01,0:21:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ah, tadi itu apa, ya?
Dialogue: 0,0:21:05.25,0:21:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin cicip, ya.
Dialogue: 0,0:21:07.31,0:21:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, Dik Kyougi!
Dialogue: 0,0:21:09.01,0:21:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ciuman tidak langsung.
Dialogue: 0,0:21:10.96,0:21:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?!
Dialogue: 0,0:21:17.29,0:21:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau makan dengan lahap, ya.
Dialogue: 0,0:21:19.51,0:21:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami jadi semangat menyajikan hidangan.
Dialogue: 0,0:21:22.11,0:21:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada surga di Dunia Iblis.
Dialogue: 0,0:22:59.31,0:23:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu, kumohon. Tolong stempel kertasnya.
Dialogue: 0,0:23:03.01,0:23:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mohon.
Dialogue: 0,0:23:11.31,0:23:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:23:14.15,0:23:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebelum itu...
Dialogue: 0,0:23:15.98,0:23:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, izinkan aku mengujimu.
Dialogue: 0,0:23:19.37,0:23:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:20.38,0:23:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah tradisi keluarga Zebul.
Dialogue: 0,0:23:22.99,0:23:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian yang seperti apa?
Dialogue: 0,0:23:26.27,0:23:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelaki yang pantas menjadi keluarga Zebul
Dialogue: 0,0:23:28.50,0:23:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah lelaki yang tidak kalah\Npada nafsu, kuat, dan setia.
Dialogue: 0,0:23:32.47,0:23:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:23:33.86,0:23:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lakukan lomba uji nyali!
Dialogue: 0,0:23:37.21,0:23:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
