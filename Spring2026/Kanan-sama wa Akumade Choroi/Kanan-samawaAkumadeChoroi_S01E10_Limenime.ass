Dialogue: 0,0:03:59.01,0:04:02.76,sign,,0000,0000,0000,,#10 MEMORI GADIS NAKAL MILCH
Dialogue: 0,0:11:03.47,0:11:05.56,sign,,0000,0000,0000,,TIDAK BISA DITARIK, YA.
Dialogue: 0,0:11:05.56,0:11:08.02,sign,,0000,0000,0000,,- SETIDAKNYA, BIARKAN AKU PAKAI CELANA...\N- DASAR PECUNDANG!
Dialogue: 0,0:11:13.27,0:11:14.34,sign,,0000,0000,0000,,BEBERAPA RATUS TAHUN YANG LALU
Dialogue: 0,0:00:05.49,0:00:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi Youji.
Dialogue: 0,0:00:06.97,0:00:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk menjemputmu.
Dialogue: 0,0:00:13.48,0:00:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak seharusnya berada di Dunia Iblis.
Dialogue: 0,0:00:15.88,0:00:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah bersamaku.
Dialogue: 0,0:00:17.98,0:00:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehm...
Dialogue: 0,0:00:19.61,0:00:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar. Kau siapa, ya?
Dialogue: 0,0:00:22.29,0:00:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ini aku. Jeanne.
Dialogue: 0,0:00:24.92,0:00:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santa Mesum?!
Dialogue: 0,0:00:26.37,0:00:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar!
Dialogue: 0,0:00:27.33,0:00:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut rancung itu tidak asing!
Dialogue: 0,0:00:29.86,0:00:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi kelihatan kinclong, ya.
Dialogue: 0,0:00:32.34,0:00:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging berlebihnya juga banyak yang hilang.
Dialogue: 0,0:00:34.75,0:00:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mungkin...
Dialogue: 0,0:00:36.97,0:00:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena ini.
Dialogue: 0,0:00:38.32,0:00:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabun?
Dialogue: 0,0:00:40.17,0:00:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa bulan sejak aku turun\Nke Dunia Manusia dan mencari Kyougi,
Dialogue: 0,0:00:44.46,0:00:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuhku selalu tercemar kekotoran manusia.
Dialogue: 0,0:00:47.41,0:00:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, tubuhku penuh oleh kenajisan.
Dialogue: 0,0:00:52.05,0:00:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, begitu mandi dan pakai sabun\Nuntuk pertama kalinya setelah sekian bulan,
Dialogue: 0,0:00:55.53,0:00:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seluruh kotoran di tubuhku\Nlangsung terangkat.
Dialogue: 0,0:00:57.90,0:00:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini, Jeanne sudah bersih!
Dialogue: 0,0:01:00.00,0:01:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru mandi setelah sekian bulan?!
Dialogue: 0,0:01:02.01,0:01:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata rambutmu seperti itu\Nkarena tidak keramas, ya?
Dialogue: 0,0:01:04.92,0:01:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, Kyougi.\NAyo cepat kabur bersamaku!
Dialogue: 0,0:01:08.31,0:01:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau berada di tempat\Nyang kotor seperti ini,
Dialogue: 0,0:01:10.92,0:01:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuh dan batinmu akan mengalami degradasi!
Dialogue: 0,0:01:13.37,0:01:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja kau bilang rumah orang lain kotor!
Dialogue: 0,0:01:15.66,0:01:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah.
Dialogue: 0,0:01:17.05,0:01:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarapan dulu, baru bertengkar.
Dialogue: 0,0:01:20.03,0:01:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, produk populer Dunia Iblis,\N"Makaron Lapis Super Manis
Dialogue: 0,0:01:22.62,0:01:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkalori Tinggi\Nyang Bikin Merasa Bersalah".
Dialogue: 0,0:01:26.48,0:01:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang licik!
Dialogue: 0,0:01:28.30,0:01:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti sedang menghasutku...
Dialogue: 0,0:01:30.78,0:01:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan harap kau bisa menyuap santa\Ndari surga dengan benda seperti ini.
Dialogue: 0,0:01:40.77,0:01:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis banget!
Dialogue: 0,0:01:43.87,0:01:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, daging berlebihnya kembali.
Dialogue: 0,0:01:46.38,0:01:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan ini benar-benar sesat.
Dialogue: 0,0:01:49.11,0:01:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau aku tahu tak boleh,\Naku tak bisa, tak mau berhenti!
Dialogue: 0,0:01:54.13,0:01:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!\NKau ingin menjerumuskan aku lagi, ya?!
Dialogue: 0,0:01:57.70,0:02:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya kau di sini, Pendosa Besar Jeanne.
Dialogue: 0,0:02:01.85,0:02:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Pelayan?
Dialogue: 0,0:02:06.05,0:02:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mewakili Nona Kanan\Nuntuk menghukummu.
Dialogue: 0,0:02:10.97,0:02:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Memangnya aku salah apa, ya?
Dialogue: 0,0:02:16.29,0:02:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santa Jeanne.
Dialogue: 0,0:02:17.74,0:02:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menerima hukuman eksekusi publik
Dialogue: 0,0:02:20.48,0:02:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena sudah mencuri celana dalam Nona!
Dialogue: 0,0:04:03.23,0:04:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Pen-Pencuri celana dalam?
Dialogue: 0,0:04:05.54,0:04:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu, eksekusi, katamu?!
Dialogue: 0,0:04:10.45,0:04:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi orang tak tahu sopan santun\Nyang sudah mencuri
Dialogue: 0,0:04:13.81,0:04:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}celana dalam Nona Kanan\Nyang kami sayang dan hormati...
Dialogue: 0,0:04:17.55,0:04:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api neraka saja tidak akan cukup!
Dialogue: 0,0:04:25.10,0:04:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pula aku mencuri\Nbenda remeh seperti itu?
Dialogue: 0,0:04:28.48,0:04:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Benda remeh"?
Dialogue: 0,0:04:30.77,0:04:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu celana dalam Nona Kanan!
Dialogue: 0,0:04:33.29,0:04:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas-jelas itu benda yang bikin nafsu,\Ndasar bodoh!
Dialogue: 0,0:04:36.26,0:04:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Pelayan?
Dialogue: 0,0:04:37.66,0:04:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semalam, saat Nona sedang mandi...
Dialogue: 0,0:04:41.05,0:04:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mengambil pakaian kalian,\Nkami tak menemukan celana dalam Nona.
Dialogue: 0,0:04:46.34,0:04:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kau yang masih berada\Ndi dalam pemandian.
Dialogue: 0,0:04:50.48,0:04:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keparat...
Dialogue: 0,0:04:51.33,0:04:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang pakai\Ncelana dalam Nona Kanan, 'kan?!
Dialogue: 0,0:04:54.88,0:04:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok!
Dialogue: 0,0:04:58.84,0:04:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Milch?
Dialogue: 0,0:05:00.17,0:05:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan banget babi betina itu,\Ndia dituduh mencuri celana dalam.
Dialogue: 0,0:05:05.71,0:05:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aku!
Dialogue: 0,0:05:09.75,0:05:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menangis?\NSudah hampir menangis?
Dialogue: 0,0:05:13.44,0:05:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cupu banget.
Dialogue: 0,0:05:17.42,0:05:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh saja aku!
Dialogue: 0,0:05:18.55,0:05:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan hina seperti ini...
Dialogue: 0,0:05:19.96,0:05:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati.
Dialogue: 0,0:05:21.69,0:05:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebelum itu,\Nkembalikan celana dalam Nona Kanan.
Dialogue: 0,0:05:25.73,0:05:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang bukan...
Dialogue: 0,0:05:29.97,0:05:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, gadis bernama Milch ini...
Dialogue: 0,0:05:38.14,0:05:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin, kita bertemu\Ndi tempat ganti baju, 'kan?
Dialogue: 0,0:05:41.30,0:05:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa? Aku tidak tahu.
Dialogue: 0,0:05:43.94,0:05:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti, Kak Babi.\NSemangat, ya.
Dialogue: 0,0:05:49.88,0:05:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!\NKau tahu sesuatu, ya?
Dialogue: 0,0:05:52.71,0:05:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur, Babi Betina!
Dialogue: 0,0:05:55.71,0:06:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kelihatannya terjadi kasus\Nyang lumayan besar, ya, Senior.
Dialogue: 0,0:06:00.78,0:06:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian ribut sekali\Nsoal celana dalam orang lain, hah?!
Dialogue: 0,0:06:08.46,0:06:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa lari lagi!
Dialogue: 0,0:06:10.68,0:06:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, katakan semua hal yang kau tahu!
Dialogue: 0,0:06:14.56,0:06:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa kau membawaku\Nke tempat seperti ini?
Dialogue: 0,0:06:18.42,0:06:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NAku akan dijahili oleh Kak Babi Betina.
Dialogue: 0,0:06:23.63,0:06:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam di sana, dan biarkan aku menangkapmu!
Dialogue: 0,0:06:29.36,0:06:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh.
Dialogue: 0,0:06:31.42,0:06:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?!
Dialogue: 0,0:06:33.56,0:06:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:06:34.99,0:06:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tersangkut!
Dialogue: 0,0:06:38.60,0:06:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Norak!
Dialogue: 0,0:06:40.25,0:06:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang, cepat ke sini!
Dialogue: 0,0:06:41.58,0:06:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babi Betina ini menyedihkan sekali!
Dialogue: 0,0:06:43.68,0:06:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berhenti.\NJangan panggil orang lain!
Dialogue: 0,0:06:51.00,0:06:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai ada yang lihat,\Nmartabatku sebagai santa akan...
Dialogue: 0,0:06:55.54,0:06:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyedihkan sekali, Babi Betina.
Dialogue: 0,0:06:57.88,0:06:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa, sih?
Dialogue: 0,0:06:59.73,0:07:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantat di tembok.
Dialogue: 0,0:07:00.78,0:07:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang lihat!
Dialogue: 0,0:07:02.30,0:07:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pose yang sempurna\Nuntuk melepas celananya.
Dialogue: 0,0:07:06.14,0:07:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melepas?\NDi sini, sekarang juga?
Dialogue: 0,0:07:08.06,0:07:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu sebentar.
Dialogue: 0,0:07:11.16,0:07:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh, duh. Tunggu... Tung...\N- Kembalikan celana dalam Nona.
Dialogue: 0,0:07:14.62,0:07:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:07:17.23,0:07:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini, jangan-jangan...
Dialogue: 0,0:07:20.59,0:07:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau tak pakai celana dalam.
Dialogue: 0,0:07:23.11,0:07:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh saja aku!
Dialogue: 0,0:07:25.11,0:07:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa membawa celana dalam ganti,
Dialogue: 0,0:07:27.44,0:07:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak bisa seenaknya\Npakai punya orang lain,
Dialogue: 0,0:07:30.33,0:07:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi ini satu-satunya...
Dialogue: 0,0:07:32.08,0:07:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seleramu bagus juga.
Dialogue: 0,0:07:33.38,0:07:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali tidak membantu!
Dialogue: 0,0:07:35.06,0:07:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, bunuh saja aku!
Dialogue: 0,0:07:38.84,0:07:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, Kak Babi Betina malu-maluin.
Dialogue: 0,0:07:42.41,0:07:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak nakal,\Nberaninya kau berbuat licik padaku!
Dialogue: 0,0:07:44.82,0:07:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu hari nanti aku akan...
Dialogue: 0,0:07:46.43,0:07:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum.
Dialogue: 0,0:07:50.31,0:07:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh saja aku!
Dialogue: 0,0:07:56.80,0:07:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pelakunya bukan\NSanta Tanpa Celana Dalam...
Dialogue: 0,0:07:59.80,0:08:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti Milch.
Dialogue: 0,0:08:01.88,0:08:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau Nona Milch...
Dialogue: 0,0:08:04.33,0:08:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian tahu?
Dialogue: 0,0:08:06.57,0:08:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu sudah punya hobi\Nmerepotkan aku sejak kecil.
Dialogue: 0,0:08:11.01,0:08:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena dia ingin barang kakaknya.
Dialogue: 0,0:08:14.17,0:08:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu imut banget?
Dialogue: 0,0:08:15.61,0:08:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar, dia adik yang imut.
Dialogue: 0,0:08:18.76,0:08:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku juga kurang yakin.
Dialogue: 0,0:08:21.77,0:08:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja dia hanya membenciku.
Dialogue: 0,0:08:27.73,0:08:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, senyum itu untuk apa?
Dialogue: 0,0:08:30.19,0:08:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kerepotan karena sudah direbut,
Dialogue: 0,0:08:32.01,0:08:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Senior tetap berikan barangnya\Nuntuk adik.
Dialogue: 0,0:08:35.45,0:08:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior baik, ya.\NPerhatian juga sama adik.
Dialogue: 0,0:08:39.01,0:08:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Apa?!
Dialogue: 0,0:08:40.51,0:08:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:08:42.11,0:08:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:08:45.84,0:08:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau itu Kyougi, jangan sok jago, ya!
Dialogue: 0,0:08:48.20,0:08:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat temukan anak itu!
Dialogue: 0,0:08:50.59,0:08:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:08:53.27,0:08:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyuruhku pergi cari,\Ntapi aku tak tahu adiknya ada di mana.
Dialogue: 0,0:08:59.77,0:09:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kau sedang mencari Mil, ya?
Dialogue: 0,0:09:04.82,0:09:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:09:07.13,0:09:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kau penguntit Mil?\NYa ampun, seram!
Dialogue: 0,0:09:12.48,0:09:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan. Aku mungkin mesum,
Dialogue: 0,0:09:14.51,0:09:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku bukan penguntit dan semacamnya.
Dialogue: 0,0:09:17.09,0:09:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan orang berbahaya!
Dialogue: 0,0:09:19.31,0:09:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:09:19.93,0:09:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang, tolong aku.\NAda lelaki mesum!
Dialogue: 0,0:09:23.45,0:09:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tunggu!
Dialogue: 0,0:09:25.32,0:09:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau salah paham.\NDengarkan dulu sampai akhir!
Dialogue: 0,0:09:29.02,0:09:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pria mesum!\N- Jangan biarkan
Dialogue: 0,0:09:31.29,0:09:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Makhluk Inferior itu kabur!\N- Bunuh dia!
Dialogue: 0,0:09:33.46,0:09:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku. Maaf.\NTerima kasih banyak!
Dialogue: 0,0:09:36.53,0:09:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus sembunyi.
Dialogue: 0,0:09:43.77,0:09:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah aman...
Dialogue: 0,0:09:49.06,0:09:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia sedang digantung\Npara pelayan sekarang.
Dialogue: 0,0:09:52.94,0:09:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pecundang.
Dialogue: 0,0:09:54.77,0:09:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak ada\Nyang bisa temukan ruangan ini.
Dialogue: 0,0:09:58.72,0:10:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, tempat ini adalah rahasia Mil...
Dialogue: 0,0:10:02.13,0:10:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:10:04.50,0:10:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore. Kau si adik.
Dialogue: 0,0:10:08.72,0:10:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada Kak Babi di sini?!
Dialogue: 0,0:10:11.86,0:10:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Di mana ini?
Dialogue: 0,0:10:13.43,0:10:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar!
Dialogue: 0,0:10:14.69,0:10:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan adukan ke Kakak karena kau\Nmemaksa masuk ke kamar anak gadis!
Dialogue: 0,0:10:19.21,0:10:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau tidak keluar, aku...
Dialogue: 0,0:10:21.13,0:10:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku akan bilang kau menyerang\Ndan kasar padaku!
Dialogue: 0,0:10:24.46,0:10:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kamarmu, Dik?
Dialogue: 0,0:10:27.13,0:10:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan dibenci Kakak\Ndan dicincang olehnya.
Dialogue: 0,0:10:30.33,0:10:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamat sudah kehidupan Kak Babi.
Dialogue: 0,0:10:33.06,0:10:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pecundang. Pecundang!
Dialogue: 0,0:10:35.00,0:10:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamar ini...
Dialogue: 0,0:10:36.11,0:10:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diabaikan!
Dialogue: 0,0:10:37.05,0:10:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, dengar aku, dong!\NJangan lihat-lihat!
Dialogue: 0,0:10:41.30,0:10:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya merchandise
Dialogue: 0,0:10:45.27,0:10:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Kanan...?
Dialogue: 0,0:10:48.72,0:10:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja dia hanya membenciku.
Dialogue: 0,0:10:52.34,0:10:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, dia bukan benci padamu...
Dialogue: 0,0:10:54.89,0:10:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei. Jangan lihat!
Dialogue: 0,0:10:56.89,0:10:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, sih, namanya sayang banget!
Dialogue: 0,0:11:14.35,0:11:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch!
Dialogue: 0,0:11:18.46,0:11:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pulang.
Dialogue: 0,0:11:23.83,0:11:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kanan!
Dialogue: 0,0:11:26.47,0:11:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah gadis\Nyang sayang sekali pada Kakak.
Dialogue: 0,0:11:30.55,0:11:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Milch ini, ya.
Dialogue: 0,0:11:32.61,0:11:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk Kakak.
Dialogue: 0,0:11:35.02,0:11:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Ini untukku?
Dialogue: 0,0:11:36.86,0:11:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak yang disukai semua orang\Ndan serbabisa.
Dialogue: 0,0:11:42.09,0:11:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Milch.
Dialogue: 0,0:11:44.23,0:11:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah panutanku.
Dialogue: 0,0:11:48.45,0:11:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Kakak makin sibuk belajar,
Dialogue: 0,0:11:52.97,0:11:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan waktu kami bersama makin berkurang.
Dialogue: 0,0:12:05.65,0:12:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baju yang dijaga baik-baik oleh Kakak.
Dialogue: 0,0:12:15.91,0:12:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa... menjadi Kakak.
Dialogue: 0,0:12:22.97,0:12:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganku?
Dialogue: 0,0:12:25.88,0:12:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku gelisah.
Dialogue: 0,0:12:28.83,0:12:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus apakan perasaan ini...
Dialogue: 0,0:12:32.76,0:12:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch?
Dialogue: 0,0:12:34.95,0:12:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu gaun favoritku...
Dialogue: 0,0:12:38.05,0:12:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei!
Dialogue: 0,0:12:39.78,0:12:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Aku tak mau kembalikan.
Dialogue: 0,0:12:41.88,0:12:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku bisa menyatu dengan Kakak!
Dialogue: 0,0:12:45.45,0:12:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:12:46.53,0:12:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Milch. Tunggu!
Dialogue: 0,0:12:49.33,0:12:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak akan mengejarku dengan serius!
Dialogue: 0,0:12:52.71,0:12:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya melihatku!
Dialogue: 0,0:12:54.32,0:12:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang!
Dialogue: 0,0:12:56.03,0:12:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch, hentikan semua ini!
Dialogue: 0,0:12:58.58,0:13:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Jangan pasang wajah seperti itu.
Dialogue: 0,0:13:01.17,0:13:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah yang hanya kau tunjukkan padaku...
Dialogue: 0,0:13:04.08,0:13:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingin lihat terus-menerus.
Dialogue: 0,0:13:10.38,0:13:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:13:12.44,0:13:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang ingin, itu untukmu saja.
Dialogue: 0,0:13:15.36,0:13:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Sudah selesai?
Dialogue: 0,0:13:17.82,0:13:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau. Tidak, tidak.
Dialogue: 0,0:13:20.12,0:13:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah lihat aku!
Dialogue: 0,0:13:22.42,0:13:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu khusus hanya milikku dan Kakak.
Dialogue: 0,0:13:25.36,0:13:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu ingin waktu ini...
Dialogue: 0,0:13:29.02,0:13:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kenapa, nih?\NKenapa, kenapa?
Dialogue: 0,0:13:33.73,0:13:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sudah menyerah lagi?
Dialogue: 0,0:13:36.94,0:13:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lebih tua dariku, tapi pemalas banget!
Dialogue: 0,0:13:40.69,0:13:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaanmu sekarang?
Dialogue: 0,0:13:42.04,0:13:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaanmu setelah\Nbarang kesayanganmu diambil Mil?
Dialogue: 0,0:13:46.95,0:13:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar... pecundang.
Dialogue: 0,0:13:54.37,0:13:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch.
Dialogue: 0,0:13:57.46,0:13:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak yang benar-benar marah.
Dialogue: 0,0:13:59.81,0:14:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah yang hanya dia perlihatkan padaku.
Dialogue: 0,0:14:02.45,0:14:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemari kau, Milch!
Dialogue: 0,0:14:04.10,0:14:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur!
Dialogue: 0,0:14:05.80,0:14:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking amat sangat inginnya\Nmelihat wajah itu,
Dialogue: 0,0:14:10.58,0:14:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan merebut\Nbarang-barang kesayangan Kakak.
Dialogue: 0,0:14:13.20,0:14:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu karena... Karena aku...
Dialogue: 0,0:14:17.20,0:14:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sayang Kakak.
Dialogue: 0,0:14:19.63,0:14:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu rahasia milikku seorang.
Dialogue: 0,0:14:22.72,0:14:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya, itu rahasiaku...!
Dialogue: 0,0:14:25.80,0:14:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, sih, namanya sayang banget!
Dialogue: 0,0:14:28.08,0:14:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babi rendahan sepertinya malah...!
Dialogue: 0,0:14:31.51,0:14:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Sayang?\NAku? Sayang Kakak?
Dialogue: 0,0:14:35.82,0:14:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya.
Dialogue: 0,0:14:38.33,0:14:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau?\NMana mungkin!
Dialogue: 0,0:14:42.54,0:14:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin siapa pun tahu perasaan ini!
Dialogue: 0,0:14:46.48,0:14:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai ada yang sadar,
Dialogue: 0,0:14:47.85,0:14:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak akan tahu\Nharus bersikap seperti apa di depan Kakak.
Dialogue: 0,0:14:52.36,0:14:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bersenang-senang\Nmelihat Kakak kerepotan!
Dialogue: 0,0:14:55.56,0:14:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Kakak saat marah benar-benar konyol!
Dialogue: 0,0:14:59.02,0:15:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham, Kak Babi?
Dialogue: 0,0:15:01.20,0:15:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau sayang, 'kan?
Dialogue: 0,0:15:04.37,0:15:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adik yang mencuri barang kakaknya\Nuntuk dikoleksi, lo?
Dialogue: 0,0:15:08.08,0:15:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kesimpulanmu setelah lihat ini?!
Dialogue: 0,0:15:10.17,0:15:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kau sayang dia, 'kan?
Dialogue: 0,0:15:13.98,0:15:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kok.\NAku tidak begitu, kok!
Dialogue: 0,0:15:17.10,0:15:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih, benda yang kau pegang\Nerat-erat itu...
Dialogue: 0,0:15:21.12,0:15:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}celana dalam Senior Kanan, 'kan?
Dialogue: 0,0:15:25.49,0:15:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukti kau sayang dia!
Dialogue: 0,0:15:28.11,0:15:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bodoh banget!
Dialogue: 0,0:15:30.17,0:15:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berakhir sudah...
Dialogue: 0,0:15:31.73,0:15:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa membantah lagi...
Dialogue: 0,0:15:35.14,0:15:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nfigur aksi ini bagus banget, ya.
Dialogue: 0,0:15:39.29,0:15:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk dadanya sempurna.
Dialogue: 0,0:15:46.22,0:15:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kakak!\N- Senior!
Dialogue: 0,0:15:48.36,0:15:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teganya kau melakukan itu\Npada kakakku yang berharga!
Dialogue: 0,0:15:51.85,0:15:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku! Maaf!
Dialogue: 0,0:15:54.20,0:15:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:55.25,0:15:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berharga?
Dialogue: 0,0:15:58.64,0:16:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ya, kau benar!
Dialogue: 0,0:16:00.81,0:16:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sayang Kakak pakai banget!
Dialogue: 0,0:16:03.71,0:16:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menarik perhatian Kakak,
Dialogue: 0,0:16:05.32,0:16:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mencurinya, memakainya,\Nmembuatnya, dan membelainya!
Dialogue: 0,0:16:09.01,0:16:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buatan sendiri?!
Dialogue: 0,0:16:10.72,0:16:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:16:12.42,0:16:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua merchandise di ruangan ini buatanku!
Dialogue: 0,0:16:15.03,0:16:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Jijik, 'kan?
Dialogue: 0,0:16:19.13,0:16:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren banget.
Dialogue: 0,0:16:22.20,0:16:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siluet seperti ini baru bisa dibentuk
Dialogue: 0,0:16:24.25,0:16:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat memperhatikan modelnya dengan saksama.
Dialogue: 0,0:16:26.15,0:16:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detail banget.
Dialogue: 0,0:16:27.82,0:16:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknikmu bagus banget!
Dialogue: 0,0:16:29.50,0:16:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar wujud cinta!
Dialogue: 0,0:16:32.14,0:16:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang untuk menyayangi Senior\Nada sebanyak ini...
Dialogue: 0,0:16:35.06,0:16:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengumpulkan dan membuat sebanyak ini...
Dialogue: 0,0:16:37.70,0:16:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini penuh dengan cinta!
Dialogue: 0,0:16:40.34,0:16:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruangannya bagus banget, Milch.
Dialogue: 0,0:16:44.48,0:16:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku mengira dia akan mengejekku...
Dialogue: 0,0:16:46.84,0:16:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ternyata dia paham perasaanku?
Dialogue: 0,0:16:50.30,0:16:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak menganggap... aku menjijikkan?
Dialogue: 0,0:16:53.86,0:16:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak.\NJustru aku menghormatimu!
Dialogue: 0,0:16:59.50,0:17:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kak Babi.
Dialogue: 0,0:17:01.85,0:17:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:17:02.33,0:17:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa rahasiakan soal ini?
Dialogue: 0,0:17:05.70,0:17:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!\NKalau kau mau rahasiakan, aku akan...
Dialogue: 0,0:17:08.88,0:17:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kabulkan semua permintaanmu!
Dialogue: 0,0:17:11.35,0:17:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Semua?
Dialogue: 0,0:17:13.99,0:17:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:17:15.76,0:17:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Milch...
Dialogue: 0,0:17:17.17,0:17:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung saja,\Napa kau bisa dengarkan permintaanku?
Dialogue: 0,0:17:20.75,0:17:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Apa saja boleh, Kak Babi!
Dialogue: 0,0:17:31.54,0:17:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Babi, apa yang sebenarnya\Ningin kau lakukan?
Dialogue: 0,0:17:36.66,0:17:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham betul\Nrasa cinta Milch pada Senior.
Dialogue: 0,0:17:40.31,0:17:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, sebaiknya kau minta\Ndimanjakan Senior secara langsung.
Dialogue: 0,0:17:44.99,0:17:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah. Mari katakan semua perasaanmu!
Dialogue: 0,0:17:47.90,0:17:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior pasti senang.
Dialogue: 0,0:17:50.20,0:17:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:17:51.72,0:17:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kau... Babi sialan...!
Dialogue: 0,0:17:55.64,0:17:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada apa?
Dialogue: 0,0:17:57.32,0:17:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu...
Dialogue: 0,0:17:59.53,0:18:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau dia suruh aku\Nminta dimanjakan langsung,
Dialogue: 0,0:18:01.81,0:18:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak mungkin bisa katakan...!
Dialogue: 0,0:18:03.50,0:18:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch.
Dialogue: 0,0:18:07.91,0:18:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mil... Begini...
Dialogue: 0,0:18:15.08,0:18:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begini...
Dialogue: 0,0:18:17.92,0:18:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, begini...
Dialogue: 0,0:18:20.51,0:18:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be... Begini...
Dialogue: 0,0:18:27.40,0:18:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti keusilanmu yang seperti biasa.
Dialogue: 0,0:18:30.47,0:18:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar, deh.\NKau memang hobi merepotkan aku.
Dialogue: 0,0:18:34.88,0:18:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking sama seperti biasa,
Dialogue: 0,0:18:36.49,0:18:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku benar-benar merasa\Nsudah pulang ke rumah. Serius.
Dialogue: 0,0:18:40.53,0:18:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak marah... pada Mil?
Dialogue: 0,0:18:43.59,0:18:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marah, kok. Sudah provokasi aku...
Dialogue: 0,0:18:47.01,0:18:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh kau juga yang mencuri celana dalamku.\NYa, 'kan?
Dialogue: 0,0:18:50.23,0:18:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:18:51.58,0:18:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu semua dilakukan oleh adik kesayanganku.
Dialogue: 0,0:18:54.94,0:18:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia imut sekali, 'kan?
Dialogue: 0,0:18:58.66,0:19:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak... sayang Mil...
Dialogue: 0,0:19:01.96,0:19:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kanan!
Dialogue: 0,0:19:05.14,0:19:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semenjak Kakak tidak menemaniku lagi...
Dialogue: 0,0:19:07.79,0:19:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesepian,\Njadi untuk menarik perhatianmu aku...
Dialogue: 0,0:19:11.91,0:19:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Tapi jangan ambil celana dalam lagi, ya.
Dialogue: 0,0:19:15.26,0:19:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya, ya.\N- Kakak... Mil juga sayang sama Kakak...
Dialogue: 0,0:19:22.11,0:19:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch?
Dialogue: 0,0:19:25.26,0:19:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak kira aku akan ucapkan itu?
Dialogue: 0,0:19:27.95,0:19:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak gampangan banget!
Dialogue: 0,0:19:32.95,0:19:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Tunggu, kenapa aku malah bilang begitu?
Dialogue: 0,0:19:35.88,0:19:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sebentar. Ekspresi macam apa itu?
Dialogue: 0,0:19:38.72,0:19:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin Mil langsung\Njadi penurut begitu saja.
Dialogue: 0,0:19:42.64,0:19:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah katakan\Nperasaanku yang sebenarnya!
Dialogue: 0,0:19:45.49,0:19:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celana dalam ini...
Dialogue: 0,0:19:47.11,0:19:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk orang seperti Kakak,\Nlumayan agresif juga, ya?
Dialogue: 0,0:19:50.53,0:19:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku bergerak sendiri...
Dialogue: 0,0:19:52.28,0:19:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa Kakak pakai ini?
Dialogue: 0,0:19:55.49,0:19:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlihatkan pada Kak Babi saja tidak berani.
Dialogue: 0,0:19:58.86,0:20:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau pecundang.
Dialogue: 0,0:20:02.08,0:20:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali jadi gadis nakal!
Dialogue: 0,0:20:07.54,0:20:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch.
Dialogue: 0,0:20:13.44,0:20:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lakukan lagi.
Dialogue: 0,0:20:16.78,0:20:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pecundang.
Dialogue: 0,0:20:23.11,0:20:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau, Milch?
Dialogue: 0,0:20:24.62,0:20:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana permintaan maafnya?!
Dialogue: 0,0:20:27.57,0:20:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Ma...
Dialogue: 0,0:20:29.88,0:20:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau senang, 'kan?\NBisa pukul bokongku yang imut.
Dialogue: 0,0:20:35.05,0:20:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang memintamu introspeksi!
Dialogue: 0,0:20:38.94,0:20:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma... Maaf!
Dialogue: 0,0:20:46.50,0:20:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:20:48.58,0:20:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta kakak-adik yang mengharukan.
Dialogue: 0,0:20:51.44,0:20:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan begitu, kah?
Dialogue: 0,0:20:55.43,0:20:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau berusaha menjadi mediator\Ndengan caramu sendiri, ya?
Dialogue: 0,0:20:59.61,0:21:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan. Aku hanya...
Dialogue: 0,0:21:01.34,0:21:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah maklum karena mungkin\Nitu caranya menunjukkan rasa sayang.
Dialogue: 0,0:21:07.00,0:21:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku lega setelah mendengar isi hatinya.
Dialogue: 0,0:21:10.36,0:21:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:21:11.92,0:21:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:21:13.57,0:21:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi macam apa itu?
Dialogue: 0,0:21:15.37,0:21:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia sesuka itu pada Kak Babi.
Dialogue: 0,0:21:18.55,0:21:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Mil merebutnya,\Ndia akan pasang ekspresi seperti apa, ya?
Dialogue: 0,0:21:23.07,0:21:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lihat wajah Kakak\Nyang seperti itu.
Dialogue: 0,0:21:32.20,0:21:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin!
Dialogue: 0,0:23:10.19,0:23:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi aku tersesat.
Dialogue: 0,0:23:15.57,0:23:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Miel.
Dialogue: 0,0:23:18.59,0:23:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, toilet di mana...?
