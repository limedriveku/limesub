Dialogue: 0,0:02:08.97,0:02:13.94,tanda,,0000,0000,0000,,#03 KENCAN PERTAMA KANAN
Dialogue: 0,0:04:44.81,0:04:46.94,tanda,,0000,0000,0000,,"BERTEMU ORANG TUA"
Dialogue: 0,0:04:46.95,0:04:49.14,tanda,,0000,0000,0000,,"TETANGGA"
Dialogue: 0,0:04:51.19,0:04:52.57,tanda,,0000,0000,0000,,"BELANJA BARENG"
Dialogue: 0,0:04:52.58,0:04:55.08,tanda,,0000,0000,0000,,"KENCAN"
Dialogue: 0,0:14:28.40,0:14:30.90,tanda,,0000,0000,0000,,ASTAGA, AKU HARUS PAKAI BAJU APA, SIH?!
Dialogue: 0,0:14:30.91,0:14:33.01,tanda,,0000,0000,0000,,YA, MARI KITA PIKIRKAN BERSAMA.
Dialogue: 0,0:16:13.30,0:16:14.77,tanda,,0000,0000,0000,,SKY TOWER - FESTIVAL ANAK-ANAK\N4 MEI - 5 MEI
Dialogue: 0,0:17:24.52,0:17:24.83,tanda,,0000,0000,0000,,CAP SUVENIR PENGUNJUNG
Dialogue: 0,0:20:19.45,0:20:20.55,tanda,,0000,0000,0000,,A...
Dialogue: 0,0:00:11.91,0:00:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang pelayan melihat
Dialogue: 0,0:00:14.35,0:00:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekasih majikannya sedang makan siang
Dialogue: 0,0:00:16.85,0:00:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersama betina lain di hari libur.
Dialogue: 0,0:00:30.65,0:00:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tempat itu pun berubah\Nmenjadi TKP sebuah drama.
Dialogue: 0,0:02:14.78,0:02:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, tak kusangka kita bertemu di sini.\NIni pasti takdir!
Dialogue: 0,0:02:18.81,0:02:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong soal takdir.
Dialogue: 0,0:02:20.71,0:02:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, siapa betina ini?
Dialogue: 0,0:02:23.82,0:02:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Betina?
Dialogue: 0,0:02:24.95,0:02:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku belum memperkenalkannya\Nkepada Senior, ya?
Dialogue: 0,0:02:28.65,0:02:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia teman sekelasku, Masurao...
Dialogue: 0,0:02:30.62,0:02:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nadeko.
Dialogue: 0,0:02:31.85,0:02:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Youji, kamu tahu aku benci\Ndipanggil pakai marga, 'kan?
Dialogue: 0,0:02:35.78,0:02:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil aku "Nadeko"!
Dialogue: 0,0:02:37.38,0:02:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeko?
Dialogue: 0,0:02:39.18,0:02:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya dia teman masa kecil Kyougi.
Dialogue: 0,0:02:43.21,0:02:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelakor yang memberi makan ternak\Norang lain, dan berniat merebutnya!
Dialogue: 0,0:02:48.73,0:02:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa kali harus kuingatkan\Nsupaya kamu paham?
Dialogue: 0,0:02:51.35,0:02:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke. Aku mengerti, Masurao.
Dialogue: 0,0:02:53.45,0:02:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, Nadechan!
Dialogue: 0,0:02:55.11,0:02:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadechan?!
Dialogue: 0,0:02:56.11,0:02:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa malah asyik sendiri?
Dialogue: 0,0:02:58.15,0:03:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang pamer, ya?
Dialogue: 0,0:03:00.55,0:03:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Youji bersama sejak kecil,
Dialogue: 0,0:03:04.01,0:03:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kami sudah tidak canggung lagi.
Dialogue: 0,0:03:07.05,0:03:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman masa kecil, ya?
Dialogue: 0,0:03:09.31,0:03:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian para manusia punya cerita\Nsaat masih kecil?
Dialogue: 0,0:03:12.38,0:03:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Manusia?
Dialogue: 0,0:03:14.00,0:03:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami, sejak kapan kau ada di sini?!
Dialogue: 0,0:03:16.11,0:03:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau dengar, dong!
Dialogue: 0,0:03:18.91,0:03:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritanya biasa saja, kok.
Dialogue: 0,0:03:21.15,0:03:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, bermain di taman dekat rumah,\Natau saling menginap.
Dialogue: 0,0:03:25.14,0:03:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Menginap?!
Dialogue: 0,0:03:28.01,0:03:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya. Si Youji ini
Dialogue: 0,0:03:29.95,0:03:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pernah mengompol saat kami tidur\Ndi kasur yang sama.
Dialogue: 0,0:03:33.06,0:03:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidur bersama?!
Dialogue: 0,0:03:36.35,0:03:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jus yang tumpah, tahu.
Dialogue: 0,0:03:39.11,0:03:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal tahu saja, anak ini jauh lebih imut\Nsaat masih kecil.
Dialogue: 0,0:03:45.10,0:03:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, jangan bahas itu.
Dialogue: 0,0:03:46.28,0:03:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Memang benar, kok.\N- Mereka berdua ini, ya...
Dialogue: 0,0:03:49.31,0:03:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya kumakan saja, ya?
Dialogue: 0,0:03:52.71,0:03:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura jahat apa ini?
Dialogue: 0,0:03:56.58,0:03:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalnya dari dia, ya?
Dialogue: 0,0:04:00.59,0:04:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Youji.
Dialogue: 0,0:04:03.01,0:04:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa perempuan itu?
Dialogue: 0,0:04:05.18,0:04:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu asal-usulnya, 'kan?
Dialogue: 0,0:04:07.91,0:04:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku belum bercerita, ya?
Dialogue: 0,0:04:10.05,0:04:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pacarku, Senior Kanan.
Dialogue: 0,0:04:12.71,0:04:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacar?!
Dialogue: 0,0:04:15.35,0:04:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu. Dia pacarnya Youji...
Dialogue: 0,0:04:18.05,0:04:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dia menatapku tajam sejak tadi.
Dialogue: 0,0:04:22.65,0:04:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior pasti salah paham\Nsoal hubunganku dengan Youji.
Dialogue: 0,0:04:27.91,0:04:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu. Aku dan Youji berteman\Nkarena orang tua kami saling kenal.
Dialogue: 0,0:04:32.58,0:04:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kenalan biasa dan teman masa kecil,\Ntidak ada hubungan khusus.
Dialogue: 0,0:04:37.51,0:04:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamer keakraban, ya?
Dialogue: 0,0:04:39.21,0:04:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!
Dialogue: 0,0:04:40.25,0:04:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku begini...
Dialogue: 0,0:04:42.15,0:04:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng... Eng...
Dialogue: 0,0:04:43.75,0:04:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:04:44.81,0:04:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami saling kenal karena orang tua,
Dialogue: 0,0:04:46.95,0:04:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hanya tetangga biasa.
Dialogue: 0,0:04:49.15,0:04:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, dia hanya menemaniku belanja
Dialogue: 0,0:04:51.19,0:04:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kebutuhan rumah.
Dialogue: 0,0:04:52.58,0:04:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sama sekali bukan kencan!
Dialogue: 0,0:04:55.50,0:04:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku dan Youji...
Dialogue: 0,0:04:57.00,0:04:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup.
Dialogue: 0,0:04:58.01,0:04:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:05:00.45,0:05:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau kamu mengerti...!
Dialogue: 0,0:05:04.38,0:05:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti, makanya akan kukuliti\Nkamu hidup-hidup,
Dialogue: 0,0:05:07.91,0:05:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencincang dagingmu untuk pakan babi\Ndi Dunia Iblis...
Dialogue: 0,0:05:12.31,0:05:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih salah paham!
Dialogue: 0,0:05:13.65,0:05:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhancurkan jiwamu\Nsampai tak bisa bereinkarnasi,
Dialogue: 0,0:05:14.51,0:05:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, apa seseorang bisa\Ntersenyum seindah itu
Dialogue: 0,0:05:18.54,0:05:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- lalu kujejalkan ke lava neraka.\N- saat emosinya sudah melewati batas?
Dialogue: 0,0:05:21.38,0:05:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Youji.\NBantulah aku memberi klarifikasi...
Dialogue: 0,0:05:25.15,0:05:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyum yang begitu tulus...
Dialogue: 0,0:05:27.51,0:05:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah yang orang sebut "mulia"?
Dialogue: 0,0:05:28.86,0:05:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar budak cinta tingkat akut!
Dialogue: 0,0:05:31.35,0:05:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat.
Dialogue: 0,0:05:33.01,0:05:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu apanya yang gawat,\Ntapi ini gawat darurat.
Dialogue: 0,0:05:37.05,0:05:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku harus menghibur Senior.
Dialogue: 0,0:05:40.85,0:05:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Youji dan Senior Kanan benar-benar\Npasangan yang serasi!
Dialogue: 0,0:05:44.85,0:05:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior modis, cantik, dan berkepribadian\Nsangat imut!
Dialogue: 0,0:05:47.45,0:05:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Kanan benar-benar sosok ideal\Nbagi seluruh perempuan di dunia!
Dialogue: 0,0:05:51.45,0:05:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman masa kecil sepertiku sama sekali\Nbukan tandinganmu.
Dialogue: 0,0:05:56.11,0:05:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus?
Dialogue: 0,0:05:57.58,0:05:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, tidak mempan.
Dialogue: 0,0:05:59.51,0:06:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Youji, kamu juga harus klarifikasi!
Dialogue: 0,0:06:02.25,0:06:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihat senyum itu.\NHah? Dia itu dewi, ya?
Dialogue: 0,0:06:05.98,0:06:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sama sekali tidak berguna!
Dialogue: 0,0:06:09.31,0:06:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu kata-kata terakhirmu?
Dialogue: 0,0:06:13.68,0:06:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku!
Dialogue: 0,0:06:16.58,0:06:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukuliti,
Dialogue: 0,0:06:18.19,0:06:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencincang dagingnya...
Dialogue: 0,0:06:21.45,0:06:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat iri pada Youji\Nkarena memiliki pacar
Dialogue: 0,0:06:23.75,0:06:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menawan seperti Senior.
Dialogue: 0,0:06:26.05,0:06:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kujadikan pakan babi, meremukkan jiwanya...
Dialogue: 0,0:06:30.41,0:06:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadikannya istri!
Dialogue: 0,0:06:31.87,0:06:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjatuhkannya ke neraka...
Dialogue: 0,0:06:33.91,0:06:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup sang istri!
Dialogue: 0,0:06:35.65,0:06:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istri Youji!
Dialogue: 0,0:06:41.98,0:06:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, ya!
Dialogue: 0,0:06:45.58,0:06:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sembarangan menyebutku istri!
Dialogue: 0,0:06:48.67,0:06:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampangan banget!
Dialogue: 0,0:06:52.41,0:06:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku jadi malu.
Dialogue: 0,0:06:54.11,0:06:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia menyebutku istri, dong!\N- Kata "istri" sangat ampuh, ya?
Dialogue: 0,0:06:58.88,0:07:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu Nadeko. Betul?
Dialogue: 0,0:07:00.98,0:07:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul! Ada perlu apa?
Dialogue: 0,0:07:02.75,0:07:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini. Aku dan Youji\Nbelum sampai sejauh itu, tahu.
Dialogue: 0,0:07:06.38,0:07:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pandai memuji, ya.
Dialogue: 0,0:07:08.03,0:07:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:07:15.91,0:07:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka.
Dialogue: 0,0:07:18.98,0:07:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk Inferior Nadeko.
Dialogue: 0,0:07:21.12,0:07:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Makhluk Inferior Nadeko"?!
Dialogue: 0,0:07:23.92,0:07:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Senior dewi. Senior dewi. Senior dewi.\N- Ya ampun, aku belum bisa disebut istri, tahu.
Dialogue: 0,0:07:28.82,0:07:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu cepat. Bisa-bisanya.
Dialogue: 0,0:07:33.35,0:07:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk Inferior.
Dialogue: 0,0:07:35.35,0:07:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku saja tak pernah memanggilku begitu.
Dialogue: 0,0:07:39.31,0:07:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan macam apa ini?
Dialogue: 0,0:07:45.61,0:07:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, terima kasih sudah memberikan\Ntontonan yang menarik.
Dialogue: 0,0:07:50.15,0:07:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung saja aku mampir ke dunia manusia.
Dialogue: 0,0:07:53.91,0:07:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau memang datang\Nhanya untuk bermain, ya.
Dialogue: 0,0:07:56.71,0:07:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, kenapa kau yang minum?!
Dialogue: 0,0:07:58.98,0:08:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuang sendiri saja, ya.
Dialogue: 0,0:08:00.98,0:08:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku ingin dramanya\Nlebih kacau dan penuh intrik.
Dialogue: 0,0:08:06.91,0:08:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditunggu episode selanjutnya, ya.
Dialogue: 0,0:08:08.27,0:08:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ditunggu!
Dialogue: 0,0:08:10.21,0:08:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, Kyougi juga sama saja.
Dialogue: 0,0:08:13.11,0:08:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia sudah terikat kontrak\Nsebagai kekasihku,
Dialogue: 0,0:08:15.75,0:08:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi malah berduaan dengan betina lain.\NDasar tidak peka.
Dialogue: 0,0:08:20.61,0:08:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku juga ingin makan siang...
Dialogue: 0,0:08:23.91,0:08:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku ingin melakukan itu!
Dialogue: 0,0:08:25.55,0:08:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya harga diri sebagai iblis, tahu!
Dialogue: 0,0:08:28.98,0:08:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku makan bersama\Nternakku sendiri!
Dialogue: 0,0:08:32.21,0:08:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:08:34.80,0:08:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, entah kenapa aku merasa gelisah.
Dialogue: 0,0:08:38.80,0:08:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:08:43.83,0:08:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, akhirnya Nona terlihat\Nlebih feminin, ya.
Dialogue: 0,0:08:47.95,0:08:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Nona yakin ingin bermain\Ncinta-cintaan seperti ini?
Dialogue: 0,0:08:51.34,0:08:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?!
Dialogue: 0,0:08:53.84,0:08:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah afeksi
Dialogue: 0,0:08:55.81,0:08:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa membuatmu patah hati\Nsaat memakan jiwanya?
Dialogue: 0,0:08:58.98,0:09:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwa?
Dialogue: 0,0:09:01.21,0:09:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa!
Dialogue: 0,0:09:02.35,0:09:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona jadi bodoh sejak datang ke sini?
Dialogue: 0,0:09:05.44,0:09:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga. Padahal aku berniat\Nmemakan jiwanya.
Dialogue: 0,0:09:10.05,0:09:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarlah, Kanan!
Dialogue: 0,0:09:13.71,0:09:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru ini kondisi yang ideal.
Dialogue: 0,0:09:23.25,0:09:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menjinakkan Kyougi
Dialogue: 0,0:09:25.53,0:09:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuat pertahanan hatinya melemah.
Dialogue: 0,0:09:37.61,0:09:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Knock Out!
Dialogue: 0,0:09:40.61,0:09:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, buat dia menyerahkan jiwanya\Nsecara sukarela!
Dialogue: 0,0:09:43.85,0:09:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Nona bermaksud menaklukkannya\Nlewat jalur cinta!
Dialogue: 0,0:09:47.98,0:09:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:09:49.51,0:09:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktunya kencan.
Dialogue: 0,0:09:51.05,0:09:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Ken... Kencan?!
Dialogue: 0,0:09:54.38,0:09:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa jadi kencan?
Dialogue: 0,0:09:56.18,0:09:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin membuatnya jatuh cinta,\Nkalian harus kencan.
Dialogue: 0,0:09:59.21,0:10:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi kalian sudah pacaran, segera kencan\Nuntuk lanjut ke tahap berikutnya.
Dialogue: 0,0:10:05.61,0:10:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak tahu cara kencan.
Dialogue: 0,0:10:09.51,0:10:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan itu butuh izin, 'kan?
Dialogue: 0,0:10:11.98,0:10:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, izin orang tua, surat kontrak,\Ndan stempel.
Dialogue: 0,0:10:16.03,0:10:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona bicara apa, sih?
Dialogue: 0,0:10:17.78,0:10:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cukup jalan berdua, makan bareng,\Ndan mengobrol santai.
Dialogue: 0,0:10:22.39,0:10:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dorong dia hingga jatuh\Nsaat perjalanan pulang,
Dialogue: 0,0:10:24.71,0:10:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langsung makan jiwanya, dan semua beres.
Dialogue: 0,0:10:29.77,0:10:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:10:31.21,0:10:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, tidak bisa!\NAku tak bisa melakukan itu!
Dialogue: 0,0:10:34.71,0:10:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abaikan saja bagian akhirnya.\NCoba ajak dia jalan-jalan.
Dialogue: 0,0:10:39.78,0:10:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tapi...
Dialogue: 0,0:10:41.25,0:10:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah pergi bersama teman\Nmasa kecil manusianya, lo.
Dialogue: 0,0:10:45.11,0:10:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan makan siang.
Dialogue: 0,0:10:46.45,0:10:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu bukan kencan...
Dialogue: 0,0:10:48.01,0:10:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak. Pasangan muda-mudi\Nyang membuat janji
Dialogue: 0,0:10:51.11,0:10:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk pergi jalan berdua\Nitu sudah termasuk kencan.
Dialogue: 0,0:10:55.32,0:11:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin putri Iblis Agung\Nakan diam saja saat keduluan
Dialogue: 0,0:11:01.18,0:11:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gadis manusia?
Dialogue: 0,0:11:07.35,0:11:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Akan kulakukan.
Dialogue: 0,0:11:09.48,0:11:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan harga diri bangsa iblis!
Dialogue: 0,0:11:12.35,0:11:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:11:13.45,0:11:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, deh. Kita ajak dia besok.
Dialogue: 0,0:11:16.46,0:11:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar!
Dialogue: 0,0:11:19.31,0:11:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah, Kyougi.
Dialogue: 0,0:11:21.78,0:11:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan kencan ala iblis.
Dialogue: 0,0:11:26.45,0:11:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona luar biasa! Keren!
Dialogue: 0,0:11:30.81,0:11:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memikirkan baju untuk pergi.
Dialogue: 0,0:11:33.41,0:11:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kedengarannya menyenangkan.
Dialogue: 0,0:11:35.21,0:11:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curhat soal asmara, ya. Aku iri.
Dialogue: 0,0:11:39.55,0:11:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:11:40.95,0:11:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup.
Dialogue: 0,0:11:45.05,0:11:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kita mempekerjakan pelayan?
Dialogue: 0,0:11:50.91,0:11:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Pelayan.
Dialogue: 0,0:11:55.01,0:11:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Senior ingin bicara soal apa?
Dialogue: 0,0:11:59.35,0:12:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat. Semangat, Nona.
Dialogue: 0,0:12:01.21,0:12:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajak dia kencan dengan santai.
Dialogue: 0,0:12:03.91,0:12:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehem.
Dialogue: 0,0:12:05.12,0:12:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan, aku senggang akhir pekan nanti.
Dialogue: 0,0:12:10.95,0:12:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada acara.
Dialogue: 0,0:12:12.78,0:12:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:14.71,0:12:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:12:16.75,0:12:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:12:19.35,0:12:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, begini... Ke-Ke...
Dialogue: 0,0:12:23.51,0:12:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat, Nona! Sedikit lagi!
Dialogue: 0,0:12:26.21,0:12:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-ke-ke... Ken...
Dialogue: 0,0:12:28.65,0:12:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke?
Dialogue: 0,0:12:30.21,0:12:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku akan pergi mengajar.
Dialogue: 0,0:12:32.02,0:12:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cari aman!
Dialogue: 0,0:12:33.87,0:12:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengajar, ya.
Dialogue: 0,0:12:35.81,0:12:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi rasanya membosankan\Nkalau hanya itu.
Dialogue: 0,0:12:39.05,0:12:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kesepian, ajak dia!
Dialogue: 0,0:12:40.81,0:12:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya masukan?
Dialogue: 0,0:12:42.55,0:12:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegiatan saat hari libur.
Dialogue: 0,0:12:44.58,0:12:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:12:46.38,0:12:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya, ke...
Dialogue: 0,0:12:48.21,0:12:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, pergi kencan!
Dialogue: 0,0:12:50.95,0:12:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ken...\N- Can!
Dialogue: 0,0:12:54.15,0:12:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, duel sampai mati...?
Dialogue: 0,0:12:55.98,0:12:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin saling bunuh dengan siapa?!
Dialogue: 0,0:12:58.18,0:13:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan! Aku ingin pergi keluar\Ndan melakukan sesuatu.
Dialogue: 0,0:13:01.38,0:13:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin pergi ke-ke-ken...
Dialogue: 0,0:13:03.91,0:13:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjut!
Dialogue: 0,0:13:04.91,0:13:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan harga dirimu sebagai iblis!
Dialogue: 0,0:13:06.81,0:13:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demonstrasi.
Dialogue: 0,0:13:08.21,0:13:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak puas dengan pemerintah saat ini?
Dialogue: 0,0:13:09.98,0:13:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:13:10.93,0:13:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunkan pajak, turunkan pajak!
Dialogue: 0,0:13:11.85,0:13:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita demo sambil duel maut\Ndi tempat Senior mengajar, ya?
Dialogue: 0,0:13:15.38,0:13:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia itu bodoh, ya?
Dialogue: 0,0:13:17.85,0:13:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan. Maksudku bukan itu.
Dialogue: 0,0:13:20.41,0:13:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari libur Senior padat sekali, ya.
Dialogue: 0,0:13:22.55,0:13:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini... Maksudku...
Dialogue: 0,0:13:24.21,0:13:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar menunggu akhir pekan nanti!
Dialogue: 0,0:13:26.16,0:13:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:13:27.71,0:13:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memberi kode sebanyak ini,\Nharusnya kamu peka!
Dialogue: 0,0:13:30.91,0:13:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini
Dialogue: 0,0:13:32.15,0:13:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedang mengajakmu pergi kencan!
Dialogue: 0,0:13:40.98,0:13:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menganggur akhir pekan nanti, 'kan?
Dialogue: 0,0:13:43.05,0:13:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bertemu di stasiun pukul 11.
Dialogue: 0,0:13:45.55,0:13:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham?!
Dialogue: 0,0:13:46.78,0:13:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham.
Dialogue: 0,0:13:49.95,0:13:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kumaafkan kalau kamu terlambat\Nsatu detik pun!
Dialogue: 0,0:14:02.95,0:14:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:14:06.15,0:14:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengajaknya, aku berhasil!
Dialogue: 0,0:14:09.51,0:14:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungku tak bisa berhenti berdebar.
Dialogue: 0,0:14:12.01,0:14:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh...
Dialogue: 0,0:14:13.38,0:14:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar makhluk inferior.
Dialogue: 0,0:14:17.75,0:14:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:14:19.85,0:14:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, kerja bagus.
Dialogue: 0,0:14:26.05,0:14:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mimpi, ya?
Dialogue: 0,0:14:34.35,0:14:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sky Tower, tempat tertinggi\Ndan kebanggaan Jepang!
Dialogue: 0,0:14:37.95,0:14:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lokasi kencan pertama kita, ya.
Dialogue: 0,0:14:41.61,0:14:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, besar sekali!
Dialogue: 0,0:14:44.27,0:14:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, tinggi banget!
Dialogue: 0,0:14:47.85,0:14:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya cantik sekali.
Dialogue: 0,0:14:52.41,0:14:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ramai sekali, ya. Apa itu?\N- Kyougi benar-benar bersemangat.
Dialogue: 0,0:14:56.95,0:14:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya bisa bersemangat sekarang.
Dialogue: 0,0:15:00.65,0:15:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat kau terpikat oleh pesonaku\Nmelalui kencan ini,
Dialogue: 0,0:15:03.68,0:15:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu menyerahkan jiwamu secara sukarela.
Dialogue: 0,0:15:07.51,0:15:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini adalah
Dialogue: 0,0:15:09.11,0:15:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kencan ala iblis yang memanfaatkan\Ntempat tertinggi di Jepang!
Dialogue: 0,0:15:13.81,0:15:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Efek jembatan gantung".
Dialogue: 0,0:15:15.85,0:15:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia itu bodoh, sering menyamakan\Ndebar jantung ketakutan dengan rasa suka.
Dialogue: 0,0:15:20.98,0:15:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah rencana brilian iblis\Nuntuk membuatmu terpikat padaku.
Dialogue: 0,0:15:26.75,0:15:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempurna! Aku memang sempurna!
Dialogue: 0,0:15:30.45,0:15:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:15:32.38,0:15:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:33.91,0:15:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya memang cantik,
Dialogue: 0,0:15:35.41,0:15:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Senior dengan baju kasual\Njauh lebih cantik!
Dialogue: 0,0:15:41.55,0:15:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:15:42.71,0:15:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:43.51,0:15:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:15:45.01,0:15:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:15:46.58,0:15:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:15:48.41,0:15:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, waktunya kau gemetar ketakutan!
Dialogue: 0,0:15:53.45,0:15:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, katanya melihat ke bawah\Nsangat menyeramkan, lo.
Dialogue: 0,0:15:58.15,0:16:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita mendekat ke jendela.\NMau, ya?
Dialogue: 0,0:16:01.78,0:16:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:16:04.25,0:16:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, di sana juga keren, lo.
Dialogue: 0,0:16:07.38,0:16:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, dia menghindariku?
Dialogue: 0,0:16:09.71,0:16:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu tidak mungkin...
Dialogue: 0,0:16:11.89,0:16:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kyougi...
Dialogue: 0,0:16:14.78,0:16:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:16:16.25,0:16:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang menghindariku, ya?
Dialogue: 0,0:16:18.31,0:16:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya dia yang inisiatif\Nmengajak gandengan tangan,
Dialogue: 0,0:16:20.82,0:16:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:16:22.45,0:16:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:24.35,0:16:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi ketakutan, ya.
Dialogue: 0,0:16:26.41,0:16:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia takut kuajak mendekati jendela.
Dialogue: 0,0:16:30.18,0:16:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus. Memang itu yang kuincar.
Dialogue: 0,0:16:32.75,0:16:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal sedikit lagi.
Dialogue: 0,0:16:35.45,0:16:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:16:36.81,0:16:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau kenapa?
Dialogue: 0,0:16:40.55,0:16:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jangan-jangan,
Dialogue: 0,0:16:42.95,0:16:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu takut ketinggian, ya?
Dialogue: 0,0:16:46.21,0:16:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan, aku tidak takut...
Dialogue: 0,0:16:50.11,0:16:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk akal.
Dialogue: 0,0:16:51.91,0:16:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau cowok berbadan besar.
Dialogue: 0,0:16:54.61,0:16:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tung... Senior.
Dialogue: 0,0:16:56.49,0:16:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ayo.
Dialogue: 0,0:16:57.30,0:16:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo, ayolah.\N- Kau tidak mau, ya? Tapi tidak boleh.
Dialogue: 0,0:16:59.62,0:17:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membuatmu lebih berdebar lagi.
Dialogue: 0,0:17:02.27,0:17:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ke sini dan lihat pemandangan di luar.
Dialogue: 0,0:17:05.29,0:17:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Senior salah paham.
Dialogue: 0,0:17:07.57,0:17:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat ke sini!
Dialogue: 0,0:17:10.88,0:17:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kau harus berdebar\Nsaat berada di sampingku!
Dialogue: 0,0:17:18.06,0:17:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Sensasi ini...
Dialogue: 0,0:17:24.84,0:17:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, aku boleh tanya sesuatu\Nyang sedikit lancang?
Dialogue: 0,0:17:28.81,0:17:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan katakan.
Dialogue: 0,0:17:30.90,0:17:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, hari ini...
Dialogue: 0,0:17:32.60,0:17:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak perlu.
Dialogue: 0,0:17:33.95,0:17:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begini, ni, ni, ni...
Dialogue: 0,0:17:35.98,0:17:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan katakan!
Dialogue: 0,0:17:38.15,0:17:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior tidak pakai bra, ya?
Dialogue: 0,0:17:39.78,0:17:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, jangan katakan!
Dialogue: 0,0:17:42.35,0:17:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu grogi sampai lupa pakai bra!
Dialogue: 0,0:17:45.01,0:17:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kulakukan?!
Dialogue: 0,0:17:48.41,0:17:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ini alasan Kyougi menghindar...
Dialogue: 0,0:17:56.95,0:17:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:17:58.35,0:18:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini... Senior sengaja?
Dialogue: 0,0:18:01.41,0:18:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau memang lugu?
Dialogue: 0,0:18:03.85,0:18:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebenarnya...
Dialogue: 0,0:18:05.58,0:18:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini operasi untuk membuat Kyougi deg-degan.
Dialogue: 0,0:18:11.32,0:18:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Deg-degan, tidak?
Dialogue: 0,0:18:15.91,0:18:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}De... Deg-degan!
Dialogue: 0,0:18:19.07,0:18:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena kau, Kyougi!
Dialogue: 0,0:18:21.78,0:18:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kena, Senior!
Dialogue: 0,0:18:23.81,0:18:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasi kencan tanpa bra!
Dialogue: 0,0:18:25.61,0:18:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior memang hebat.\NBoleh aku peluk lagi?
Dialogue: 0,0:18:33.31,0:18:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja, dasar makhluk inferior!
Dialogue: 0,0:18:53.32,0:18:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kulakukan...?
Dialogue: 0,0:18:56.18,0:18:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau akhirnya begini,\Naku takkan mengajaknya kencan.
Dialogue: 0,0:19:00.58,0:19:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, takoyaki-nya enak, lo.
Dialogue: 0,0:19:03.18,0:19:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan?
Dialogue: 0,0:19:04.78,0:19:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, buka mulutnya.
Dialogue: 0,0:19:07.58,0:19:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bisa membaca situasi, ya?
Dialogue: 0,0:19:10.01,0:19:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja tidak cukup untuk menghiburku.
Dialogue: 0,0:19:12.45,0:19:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang buka mulut?
Dialogue: 0,0:19:14.15,0:19:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi klise seperti itu...
Dialogue: 0,0:19:17.45,0:19:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus banget, tahu.
Dialogue: 0,0:19:19.38,0:19:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior malu disuapi aku, ya?
Dialogue: 0,0:19:22.45,0:19:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?! Mana mungkin aku malu!
Dialogue: 0,0:19:25.58,0:19:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan.
Dialogue: 0,0:19:26.78,0:19:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan keluar tanpa bra,\Nhal semacam ini...
Dialogue: 0,0:19:44.05,0:19:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau.
Dialogue: 0,0:19:45.15,0:19:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak malu, ya.
Dialogue: 0,0:19:48.25,0:19:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terlalu buruk.
Dialogue: 0,0:19:49.95,0:19:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini tak terlalu buruk.
Dialogue: 0,0:19:56.01,0:19:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wa-Wajah puas macam apa itu?!
Dialogue: 0,0:19:59.01,0:20:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok. Aku hanya merasa puas.
Dialogue: 0,0:20:02.15,0:20:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya sama saja, bodoh!
Dialogue: 0,0:20:03.81,0:20:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar...
Dialogue: 0,0:20:07.81,0:20:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, sekarang giliranku.
Dialogue: 0,0:20:11.85,0:20:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini.
Dialogue: 0,0:20:12.91,0:20:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang bisa disuapi Senior!
Dialogue: 0,0:20:16.43,0:20:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, buka mulutnya.
Dialogue: 0,0:20:24.81,0:20:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:20:27.91,0:20:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengira akan kusuapi, ya?
Dialogue: 0,0:20:31.11,0:20:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan besar kepala,\Ndasar makhluk inferior.
Dialogue: 0,0:20:35.11,0:20:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang rasanya bisa mempermainkan\Nmakhluk inferior.
Dialogue: 0,0:20:38.81,0:20:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Senior senyum lagi.
Dialogue: 0,0:20:42.11,0:20:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kencan pertama kita,\Ntapi Senior terus terlihat murung.
Dialogue: 0,0:20:47.78,0:20:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka sekali senyuman Senior.
Dialogue: 0,0:20:57.61,0:21:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kenapa memalingkan wajah?
Dialogue: 0,0:21:01.21,0:21:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sanggup menatapnya.
Dialogue: 0,0:21:03.58,0:21:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, bukankah ini seperti...
Dialogue: 0,0:21:07.15,0:21:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar menaksir
Dialogue: 0,0:21:09.85,0:21:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makhluk inferior?
Dialogue: 0,0:21:12.12,0:21:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, Senior. Selanjutnya mau apa?
Dialogue: 0,0:21:15.71,0:21:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberikan apa pun\Ndemi senyum Senior!
Dialogue: 0,0:21:19.51,0:21:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan apa saja demi senyuman?
Dialogue: 0,0:21:21.41,0:21:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku berencana memakan jiwamu.
Dialogue: 0,0:21:26.78,0:21:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku terus berdebar saat di dekatmu.
Dialogue: 0,0:21:33.95,0:21:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum begitu mengerti perasaan ini.
Dialogue: 0,0:21:37.35,0:21:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku harus menunda\Nmenyantap jiwamu sampai aku mengerti.
Dialogue: 0,0:21:42.91,0:21:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mau melakukannya...
Dialogue: 0,0:21:46.11,0:21:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekali lagi?
Dialogue: 0,0:21:49.71,0:21:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?!
Dialogue: 0,0:21:51.65,0:21:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memikirkan apa, sih?!
Dialogue: 0,0:21:52.95,0:21:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, aku ingin menyuapi Kyougi lagi!
Dialogue: 0,0:21:55.11,0:21:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior mau makan aku?!
Dialogue: 0,0:21:56.61,0:21:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku memakan takoyaki Kyougi!
Dialogue: 0,0:21:59.11,0:22:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takoyaki milikku?!
Dialogue: 0,0:22:00.61,0:22:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan yang itu!
Dialogue: 0,0:22:01.58,0:22:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan ini, berarti sebelahnya?
Dialogue: 0,0:22:03.45,0:22:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, ya!
Dialogue: 0,0:22:04.46,0:22:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama-lama benar kumakan kau, ya.\NDasar makhluk inferior!
