Dialogue: 0,0:02:17.15,0:02:19.62,sign,,0000,0000,0000,,#09 TES KEKALAHAN LILIM
Dialogue: 0,0:03:04.24,0:03:07.08,sign,,0000,0000,0000,,BEBERAPA RIBU TAHUN YANG LALU
Dialogue: 0,0:09:30.21,0:09:33.42,sign,,0000,0000,0000,,"KUCING SILUMAN"
Dialogue: 0,0:10:28.56,0:10:33.02,sign,,0000,0000,0000,,PUK— DIA MENGHIBURKU?!
Dialogue: 0,0:21:21.00,0:21:21.79,sign,,0000,0000,0000,,RELI STEMPEL UNTUK MENGAKUI PACAR
Dialogue: 0,0:00:04.34,0:00:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu, Dik Kyougi.
Dialogue: 0,0:00:08.22,0:00:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pakai yukata?
Dialogue: 0,0:00:10.16,0:00:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yukata adalah pakaian resmi untuk uji nyali.
Dialogue: 0,0:00:13.41,0:00:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti... Senior juga?!
Dialogue: 0,0:00:18.30,0:00:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan, cepat keluar.
Dialogue: 0,0:00:21.13,0:00:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Ibu!
Dialogue: 0,0:00:26.50,0:00:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana? Aneh, tidak?
Dialogue: 0,0:00:30.87,0:00:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi?
Dialogue: 0,0:00:34.63,0:00:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pemandangannya, Senior!
Dialogue: 0,0:00:38.72,0:00:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, Kyougi.
Dialogue: 0,0:00:40.27,0:00:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- I-Imut! Imut banget!\N- Jangan kumat di depan ibuku!
Dialogue: 0,0:00:42.78,0:00:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tak punya penyesalan lagi!
Dialogue: 0,0:00:43.87,0:00:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- - Kau bicara apa, sih?!\N- Padahal aku juga pakai yukata.
Dialogue: 0,0:00:45.71,0:00:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Senior!\N- Astaga!
Dialogue: 0,0:02:19.65,0:02:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masih Dunia Iblis, 'kan?
Dialogue: 0,0:02:22.37,0:02:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempat yang cocok untuk uji nyali\Nkarena banyak arwah penasaran berkeliaran.
Dialogue: 0,0:02:26.20,0:02:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oalah.
Dialogue: 0,0:02:27.99,0:02:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,\Naku senang Ibu sudah terbiasa dengan Kyougi.
Dialogue: 0,0:02:32.52,0:02:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ya. Kau benar.
Dialogue: 0,0:02:35.79,0:02:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kenapa kau tidak suka lelaki?
Dialogue: 0,0:02:39.05,0:02:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:02:40.47,0:02:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu terkenal sebagai wanita\Npaling cantik di Dunia Iblis.
Dialogue: 0,0:02:44.15,0:02:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menerima lamaran setiap hari,\Ndan saat lamarannya makin heboh...
Dialogue: 0,0:02:49.34,0:02:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lilim!
Dialogue: 0,0:02:53.02,0:02:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semenjak itu, aku jadi ketakutan.
Dialogue: 0,0:02:56.41,0:03:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kenapa Ibu yang benci lelaki\Nmau menikahi Ayah?
Dialogue: 0,0:03:00.63,0:03:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa dikenalkan oleh nenekmu.
Dialogue: 0,0:03:07.43,0:03:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tunanganmu, iblis baru, Beelzebub.
Dialogue: 0,0:03:11.61,0:03:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?!
Dialogue: 0,0:03:12.47,0:03:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berasal dari keluarga terpandang.\NBagaimana?
Dialogue: 0,0:03:15.79,0:03:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Le-Lelaki...
Dialogue: 0,0:03:19.73,0:03:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... tidak mau.
Dialogue: 0,0:03:23.46,0:03:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Akulah yang seharusnya menolak.
Dialogue: 0,0:03:27.16,0:03:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lagi setelah kau perbaiki wajah itu,\Ndasar jelek.
Dialogue: 0,0:03:33.90,0:03:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?!
Dialogue: 0,0:03:35.15,0:03:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia sendiri badannya pendek!
Dialogue: 0,0:03:37.36,0:03:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa sakit hati\Nkalau dibilang seperti itu, tahu!
Dialogue: 0,0:03:47.42,0:03:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dia orang pertama\Nyang mengatakan itu.
Dialogue: 0,0:03:52.21,0:03:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya kau?
Dialogue: 0,0:03:54.96,0:03:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau berbeda dari lelaki lain?
Dialogue: 0,0:03:57.52,0:04:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku baik-baik saja\Nsaat ada di dekatmu?
Dialogue: 0,0:04:03.73,0:04:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak menoleh ke arahku?
Dialogue: 0,0:04:07.26,0:04:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah sejak kapan, aku...
Dialogue: 0,0:04:09.73,0:04:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya perlu buka saat dia lewat, 'kan?
Dialogue: 0,0:04:14.57,0:04:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya memikirkan soal Papa.
Dialogue: 0,0:04:17.62,0:04:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?!
Dialogue: 0,0:04:19.25,0:04:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walah, walah.\NKenapa Lilim ada di sini-gon?
Dialogue: 0,0:04:24.85,0:04:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau si tentakel\Nyang pernah dijodohkan denganku!
Dialogue: 0,0:04:27.35,0:04:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bahaya kalau kau\Npakai baju seperti itu-gon.
Dialogue: 0,0:04:31.03,0:04:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:32.04,0:04:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bahaya,\Nkau harus ikut ke rumahku-gon.
Dialogue: 0,0:04:35.59,0:04:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubawa kau pulang!
Dialogue: 0,0:04:39.64,0:04:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:04:44.93,0:04:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang... Seseorang, tolong aku!
Dialogue: 0,0:04:58.35,0:05:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh kekasihku.
Dialogue: 0,0:05:06.03,0:05:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sudah mengaku sebagai kekasihmu.
Dialogue: 0,0:05:09.56,0:05:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih, kau diincar karena\Nmemakai pakaian seperti itu.
Dialogue: 0,0:05:15.85,0:05:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau benci lelaki.
Dialogue: 0,0:05:18.88,0:05:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:05:20.93,0:05:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau wanita yang menarik.
Dialogue: 0,0:05:29.29,0:05:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa keren banget!
Dialogue: 0,0:05:30.71,0:05:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan?\NLalu, aku jatuh cinta padanya!
Dialogue: 0,0:05:34.99,0:05:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu-anak ini memang\Ngampangan karena turunan, ya.
Dialogue: 0,0:05:37.59,0:05:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus? Apa yang terjadi setelah itu?
Dialogue: 0,0:05:40.07,0:05:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.\NSetelah itu aku tak kenal rem lagi!
Dialogue: 0,0:05:45.14,0:05:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Apa yang kau lakukan?\NKau sudah gila, ya?!
Dialogue: 0,0:05:48.83,0:05:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah gila.
Dialogue: 0,0:05:50.72,0:05:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku suka, suka, suka, Tuan Beelzebub!
Dialogue: 0,0:05:55.26,0:05:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memohon padamu.
Dialogue: 0,0:05:56.66,0:05:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari ciptakan
Dialogue: 0,0:05:58.45,0:06:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukti nyata cinta kita.
Dialogue: 0,0:06:07.58,0:06:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah cerita bagaimana\Nkalian semua lahir.
Dialogue: 0,0:06:10.07,0:06:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tak bermaksud\Nmendengar sampai sejauh itu!
Dialogue: 0,0:06:16.38,0:06:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peraturannya sederhana.
Dialogue: 0,0:06:18.06,0:06:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian hanya perlu sampai\Nke atas dengan selamat.
Dialogue: 0,0:06:20.90,0:06:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang, ya, Senior!
Dialogue: 0,0:06:22.78,0:06:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kaka... Kau benar.
Dialogue: 0,0:06:24.67,0:06:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku sama sekali tak takut pada hantu.
Dialogue: 0,0:06:27.98,0:06:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu...
Dialogue: 0,0:06:29.62,0:06:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tesnya bukan itu saja.
Dialogue: 0,0:06:33.21,0:06:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dengan dunia manusia,\Ndi sini hantunya benar-benar muncul.
Dialogue: 0,0:06:37.67,0:06:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia harus lindungi Kanan dari ketakutan itu.
Dialogue: 0,0:06:40.80,0:06:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dia baru dinyatakan lulus\Nsaat berhasil menahan diri
Dialogue: 0,0:06:44.68,0:06:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk tidak tergoda oleh rayuan seksiku.
Dialogue: 0,0:06:48.87,0:06:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, penampilan ini sungguh memalukan.
Dialogue: 0,0:06:52.40,0:06:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suamiku,
Dialogue: 0,0:06:53.55,0:06:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- I-Itu mudah. Gampang segampang-gampangnya.\N- maaf, ya.
Dialogue: 0,0:06:54.86,0:06:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi semuanya demi kebaikan Kanan juga!
Dialogue: 0,0:07:04.34,0:07:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:07:05.52,0:07:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan... Bisa repot kalau tersesat.
Dialogue: 0,0:07:09.92,0:07:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pegang kaus\Ndemi kebaikanmu juga, Kyougi!
Dialogue: 0,0:07:13.21,0:07:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imutnya.
Dialogue: 0,0:07:14.42,0:07:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu,\NKanan paling tidak suka dengan hantu.
Dialogue: 0,0:07:17.78,0:07:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Waktunya aku mulai mengusik mereka.
Dialogue: 0,0:07:21.10,0:07:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun. Rambutku berantakan.
Dialogue: 0,0:07:24.74,0:07:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, ya.\NAku mau ikat rambut dulu.
Dialogue: 0,0:07:28.55,0:07:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengkuk! Tengkuk itu!
Dialogue: 0,0:07:31.86,0:07:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya dia terangsang oleh tengkukku.
Dialogue: 0,0:07:34.61,0:07:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Kyougi, kau gagal.
Dialogue: 0,0:07:36.06,0:07:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:07:36.76,0:07:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, kau punya tengkuk yang indah!
Dialogue: 0,0:07:39.70,0:07:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tiba-tiba bilang itu?!
Dialogue: 0,0:07:41.95,0:07:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking indahnya aku sampai\Ntak sadar sudah bersuara.
Dialogue: 0,0:07:44.97,0:07:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi ini, ya...!
Dialogue: 0,0:07:47.13,0:07:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, benar juga.
Dialogue: 0,0:07:48.93,0:07:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu reaksi yang benar, Dik Kyougi.
Dialogue: 0,0:07:52.20,0:07:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, bagaimana kalau ini?
Dialogue: 0,0:07:56.42,0:07:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, di sini panas, ya.
Dialogue: 0,0:08:00.39,0:08:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goyang! I-Itu goyang-goyang!
Dialogue: 0,0:08:03.59,0:08:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata pasti menatap benda yang bergoyang.
Dialogue: 0,0:08:05.73,0:08:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah sifat alami lelaki.
Dialogue: 0,0:08:07.85,0:08:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau gagal, Dik Kyougi.
Dialogue: 0,0:08:10.12,0:08:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat! Tadi bergoyang,\Ntadi ranting itu bergoyang!
Dialogue: 0,0:08:13.42,0:08:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada sesuatu!
Dialogue: 0,0:08:14.90,0:08:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lihat! Itu bergoyang, dada Senior!
Dialogue: 0,0:08:17.78,0:08:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan?\NPasti ada sesuatu di san...
Dialogue: 0,0:08:20.43,0:08:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melihat ke mana, sih?!
Dialogue: 0,0:08:22.44,0:08:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dada Senior!
Dialogue: 0,0:08:24.95,0:08:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menyangka dia bisa\Nabaikan semua godaanku!
Dialogue: 0,0:08:29.58,0:08:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh. Ya ampun, bagian dadaku terlepas.
Dialogue: 0,0:08:32.71,0:08:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:08:34.16,0:08:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengilap sekali... Benar-benar bulat.
Dialogue: 0,0:08:37.59,0:08:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin elus ke sana-kemari, ingin remas!
Dialogue: 0,0:08:40.40,0:08:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, Dik Kyougi.
Dialogue: 0,0:08:41.82,0:08:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin remas dan jilat-jilat, katamu?
Dialogue: 0,0:08:43.63,0:08:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akhirnya takluk di hadapan pesonaku, ya?
Dialogue: 0,0:08:47.13,0:08:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa menahan diri lagi!
Dialogue: 0,0:08:48.43,0:08:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Dik Kyougi!
Dialogue: 0,0:08:51.53,0:08:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing gemuk ini imut banget!
Dialogue: 0,0:08:53.45,0:08:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing?!
Dialogue: 0,0:08:54.56,0:08:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tak kusangka dia bisa\Nmenghindari seluruh godaanku.
Dialogue: 0,0:08:57.75,0:09:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya pilihan selain meluluskannya.
Dialogue: 0,0:09:01.37,0:09:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa aku merasa kalah\Nsebagai wanita?!
Dialogue: 0,0:09:04.43,0:09:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena aku benar-benar tak menarik?
Dialogue: 0,0:09:06.19,0:09:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau karena aku sudah tante-tante?!
Dialogue: 0,0:09:08.41,0:09:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah memberikan sedikit reaksi\Nadalah bagian dari sopan santun?!
Dialogue: 0,0:09:12.10,0:09:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing gemuk ini imut banget.
Dialogue: 0,0:09:16.28,0:09:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang kau sebut kucing gemuk, meong?!
Dialogue: 0,0:09:18.74,0:09:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucingnya membesar!
Dialogue: 0,0:09:21.59,0:09:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, sakit.
Dialogue: 0,0:09:24.45,0:09:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, aku jadi basah kuyup.
Dialogue: 0,0:09:30.21,0:09:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:09:34.02,0:09:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelaki itu memang kalau lengah sedikit\Nlangsung dapat keberuntungan mesum.
Dialogue: 0,0:09:37.66,0:09:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh, duh.
Dialogue: 0,0:09:39.26,0:09:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya tadi aku dijepit\Noleh sesuatu yang empuk...
Dialogue: 0,0:09:47.66,0:09:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulit yang basah,
Dialogue: 0,0:09:49.56,0:09:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yukata yang berantakan.
Dialogue: 0,0:09:51.14,0:09:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah takjub macam apa itu?\NDasar pria liar!
Dialogue: 0,0:09:54.95,0:09:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, perasaan bersalah karena dilihat\Nsebagai wanita oleh pacar putriku...
Dialogue: 0,0:09:59.32,0:10:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulit yang basah, yukata yang berantakan.
Dialogue: 0,0:10:02.64,0:10:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Aku ibunya Kanan, lo?!
Dialogue: 0,0:10:05.97,0:10:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:10:07.10,0:10:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa menahan diri lagi!
Dialogue: 0,0:10:09.20,0:10:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lakukan, Dik Kyougi.
Dialogue: 0,0:10:10.75,0:10:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kalah oleh pesonaku!
Dialogue: 0,0:10:13.46,0:10:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seksi sekali, Senior Kanan!
Dialogue: 0,0:10:17.18,0:10:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Bicara apa kau?
Dialogue: 0,0:10:19.41,0:10:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior yang basah kuyup...
Dialogue: 0,0:10:22.43,0:10:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:10:36.08,0:10:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:10:37.23,0:10:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pergi kagetkan mereka?
Dialogue: 0,0:10:38.90,0:10:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei. Kau bisa mati, lo.
Dialogue: 0,0:10:41.34,0:10:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini pekerjaan kita,\Ntapi salah sedikit bisa dipenggal, tahu.
Dialogue: 0,0:10:45.10,0:10:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi harga diri kita sebagai hantu...
Dialogue: 0,0:10:48.62,0:10:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian semua.\NJangan diam saja di sini-gon.
Dialogue: 0,0:10:52.69,0:10:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas-jelas ada orang asing\Nyang mengganggu pulau kita,
Dialogue: 0,0:10:56.08,0:10:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke mana martabat kalian sebagai hantu-gon?
Dialogue: 0,0:10:59.14,0:11:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, Bos.\NMereka istri dan putri Tuan Beelzebub.
Dialogue: 0,0:11:04.56,0:11:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bilang-gon?!
Dialogue: 0,0:11:06.32,0:11:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lilim Zebul!
Dialogue: 0,0:11:08.90,0:11:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah menyakiti Papa\Ndengan menolak lamarannya,
Dialogue: 0,0:11:11.13,0:11:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sekarang kau datang\Nuntuk mengganggu pulau kami, ya?!
Dialogue: 0,0:11:13.90,0:11:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kau putri si tentakel itu...?
Dialogue: 0,0:11:18.04,0:11:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku putri Dagon, Kodagon-gon!
Dialogue: 0,0:11:21.37,0:11:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat. Bos sayang banget pada ayahnya!
Dialogue: 0,0:11:23.96,0:11:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyimpan dendam pada Lilim\Nkarena menolak ayahnya!
Dialogue: 0,0:11:26.92,0:11:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, rupanya pulau ini milik Tuan Dagon.
Dialogue: 0,0:11:30.57,0:11:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu.
Dialogue: 0,0:11:32.04,0:11:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikir semua akan dimaafkan\Nkarena kau sopan-gon!
Dialogue: 0,0:11:34.65,0:11:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan kau. Dasar, dasar!
Dialogue: 0,0:11:36.50,0:11:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit Papa adalah sakitku juga.
Dialogue: 0,0:11:38.50,0:11:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membalas penghinaan pada Papa-gon!
Dialogue: 0,0:11:44.21,0:11:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan!
Dialogue: 0,0:11:46.86,0:11:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi!
Dialogue: 0,0:11:48.16,0:11:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi menangkap benda aneh-gon!
Dialogue: 0,0:11:50.26,0:11:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu aku-gon!
Dialogue: 0,0:11:52.55,0:11:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikatannya kencang sekali.
Dialogue: 0,0:11:54.77,0:11:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau terlalu gegabah,\Ndia bangsa iblis!
Dialogue: 0,0:11:57.62,0:11:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, kita harus lakukan sesuatu.
Dialogue: 0,0:11:59.92,0:12:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin...\NTadi Dik Kyougi melindungiku.
Dialogue: 0,0:12:03.76,0:12:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan kau\Nmencelakai orang yang kusayang!
Dialogue: 0,0:12:08.72,0:12:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Kyougi menyebutku\Nsebagai orang yang dia sayang?
Dialogue: 0,0:12:12.81,0:12:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini...!
Dialogue: 0,0:12:18.16,0:12:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat seluruh dunia\Nmelihatmu dengan pria ini-gon!
Dialogue: 0,0:12:21.41,0:12:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benci lelaki, 'kan-gon?
Dialogue: 0,0:12:23.32,0:12:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang lebih memalukan
Dialogue: 0,0:12:25.03,0:12:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari dibuat menempel pada seorang pria-gon!
Dialogue: 0,0:12:27.80,0:12:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:12:28.66,0:12:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, Kyougi!
Dialogue: 0,0:12:30.30,0:12:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lakukan sesuatu, bertahanlah!
Dialogue: 0,0:12:32.37,0:12:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, Dik Kyougi.
Dialogue: 0,0:12:33.78,0:12:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lakukan ini di depan Kanan.
Dialogue: 0,0:12:36.26,0:12:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lebih empuk dari yang tadi.
Dialogue: 0,0:12:37.74,0:12:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan, Kyougi!\N- Sensasi macam apa ini? Aku sedang diapakan?
Dialogue: 0,0:12:41.51,0:12:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku seperti melewatkan sesuatu...
Dialogue: 0,0:12:44.75,0:12:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa lihat!
Dialogue: 0,0:12:45.84,0:12:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendalikan dirimu, Dik Kyougi!
Dialogue: 0,0:12:48.73,0:12:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:12:49.30,0:12:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lo? Kenapa mereka terlihat menikmati-gon?\N- Diriku, tenanglah!
Dialogue: 0,0:12:53.13,0:12:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:12:54.48,0:12:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau paksa mereka melakukan NTR, hah?
Dialogue: 0,0:12:58.58,0:13:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau-gon?
Dialogue: 0,0:13:00.49,0:13:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau marah besar-gon?
Dialogue: 0,0:13:18.24,0:13:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kau baik-baik saja?
Dialogue: 0,0:13:20.56,0:13:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ya.
Dialogue: 0,0:13:22.94,0:13:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh...
Dialogue: 0,0:13:25.21,0:13:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tadi posisinya aneh,\Nbadanku jadi sakit.
Dialogue: 0,0:13:27.69,0:13:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Kyougi ini berani sekali\Ndi depan putriku.
Dialogue: 0,0:13:30.91,0:13:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyangka dia sangat menyukaiku.
Dialogue: 0,0:13:33.78,0:13:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!\NAku sudah jadi istri orang lain, lo.
Dialogue: 0,0:13:36.50,0:13:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa membalas perasaanmu.
Dialogue: 0,0:13:40.28,0:13:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu Senior.
Dialogue: 0,0:13:42.38,0:13:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:46.16,0:13:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Kyougi, jangan!\NIni di tempat umum...!
Dialogue: 0,0:13:51.11,0:13:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, pakaianmu kelihatan terlalu vulgar...
Dialogue: 0,0:13:55.76,0:13:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tidak enak karena itu bajuku,
Dialogue: 0,0:13:58.37,0:13:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi pakai saja.
Dialogue: 0,0:14:04.16,0:14:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:14:06.05,0:14:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar.
Dialogue: 0,0:14:10.57,0:14:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu yang empuk di punggungku.\NA-Apa itu?
Dialogue: 0,0:14:15.68,0:14:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma menulis ulang, kok!
Dialogue: 0,0:14:17.54,0:14:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menulis ulang apa?
Dialogue: 0,0:14:19.42,0:14:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik! Ingat saja baik-baik!
Dialogue: 0,0:14:21.49,0:14:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:14:31.21,0:14:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pemandian luas!\N- Meski begitu, aku lega Ibu dan Kyougi akrab.
Dialogue: 0,0:14:36.48,0:14:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam perjalanan pulang pun\Nmereka terlihat bersenang-senang.
Dialogue: 0,0:14:40.43,0:14:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?\NSepertinya mereka berdua terlalu akrab, deh.
Dialogue: 0,0:14:44.22,0:14:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:14:45.40,0:14:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:14:47.01,0:14:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puting Kanan jelas sekali!
Dialogue: 0,0:14:49.23,0:14:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah aku sembunyikan. Kenapa?
Dialogue: 0,0:14:51.49,0:14:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:14:52.17,0:14:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putingmu bisa sejelas itu\Nkarena bangsa iblis, ya?
Dialogue: 0,0:14:54.56,0:14:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau, Santa Mesum!
Dialogue: 0,0:14:56.55,0:14:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Puting?!
Dialogue: 0,0:14:58.24,0:15:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk ke pemandian\Nsetelah cuci badanmu dengan benar!
Dialogue: 0,0:15:01.01,0:15:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Kita gosok-gosok dulu, ya.
Dialogue: 0,0:15:05.01,0:15:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku benci sabun batang!\N- Tidak boleh.
Dialogue: 0,0:15:07.73,0:15:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak mau, tidak mau, tidak mau.\N- Tidak boleh, tidak boleh.
Dialogue: 0,0:15:10.19,0:15:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putingnya kenapa?
Dialogue: 0,0:15:11.54,0:15:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan putingnya?!
Dialogue: 0,0:15:13.43,0:15:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, ya.\NDilarang mengintip, Dik Youji.
Dialogue: 0,0:15:17.09,0:15:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu adab, kok.
Dialogue: 0,0:15:18.43,0:15:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin menguping,\Ntapi tidak akan mengintip.
Dialogue: 0,0:15:22.55,0:15:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubersihkan punggungmu, Dik Youji.
Dialogue: 0,0:15:25.80,0:15:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ibu? Kenapa ada di pemandian lelaki?
Dialogue: 0,0:15:29.67,0:15:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Aku akan keluar sekarang.
Dialogue: 0,0:15:33.29,0:15:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu? Tangan kita bersentuhan, lo?!
Dialogue: 0,0:15:36.15,0:15:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, aku akan membersihkan punggungmu.
Dialogue: 0,0:15:43.40,0:15:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi macam apa ini?
Dialogue: 0,0:15:47.28,0:15:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah melindungiku tadi,\NDik Youji.
Dialogue: 0,0:15:50.49,0:15:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau keren sekali.
Dialogue: 0,0:15:52.33,0:15:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Ah... Sama-sama.
Dialogue: 0,0:15:55.80,0:15:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, Dik Youji...
Dialogue: 0,0:15:57.47,0:15:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merestui hubunganmu dengan Kanan.
Dialogue: 0,0:15:59.98,0:16:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?!
Dialogue: 0,0:16:01.49,0:16:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil, Senior!
Dialogue: 0,0:16:02.85,0:16:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil dapat restu dari ibumu!
Dialogue: 0,0:16:06.12,0:16:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, Dik Youji.
Dialogue: 0,0:16:08.10,0:16:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:09.38,0:16:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.\NAku tak bisa membalas perasaanmu padaku.
Dialogue: 0,0:16:14.54,0:16:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau aku senang mendengarmu\Nberkata bahwa kau sayang padaku.
Dialogue: 0,0:16:19.35,0:16:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku bilang begitu, ya?
Dialogue: 0,0:16:21.57,0:16:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kau adalah pacar Kanan.
Dialogue: 0,0:16:24.57,0:16:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kau sama seperti putraku!
Dialogue: 0,0:16:26.98,0:16:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:27.39,0:16:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku akan mencintaimu\Nseperti putra sendiri.
Dialogue: 0,0:16:31.05,0:16:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:34.45,0:16:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo menghadap ke arahku.
Dialogue: 0,0:16:36.06,0:16:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mandikan bagian depannya juga!
Dialogue: 0,0:16:37.95,0:16:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu bicara apa, sih?
Dialogue: 0,0:16:39.63,0:16:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.\NAku bisa bersihkan bagian depannya sendiri.
Dialogue: 0,0:16:42.15,0:16:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini kontak fisik\Nyang lumrah untuk ibu-anak!
Dialogue: 0,0:16:44.58,0:16:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang masa rewel?
Dialogue: 0,0:16:45.64,0:16:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Youji memang sedang\Nmasa pemberontakan, ya. Sayang, sayang.
Dialogue: 0,0:16:48.27,0:16:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}To-Tolong aku, Senior!
Dialogue: 0,0:16:52.37,0:16:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi? Teriakan apa tadi?
Dialogue: 0,0:16:54.58,0:16:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja, Manusia?
Dialogue: 0,0:16:56.71,0:16:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang, sayang, sayang.
Dialogue: 0,0:16:58.30,0:17:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu melakukan\Nhal tidak senonoh pada Kyougi?!
Dialogue: 0,0:17:02.65,0:17:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak senonoh apa?
Dialogue: 0,0:17:04.26,0:17:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya memandikan\Nputra kesayanganku, lo.
Dialogue: 0,0:17:07.97,0:17:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra? Apa yang terjadi di antara kalian?!
Dialogue: 0,0:17:11.90,0:17:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, sisanya biar Kanan,\Nsi pacarnya saja yang melakukannya.
Dialogue: 0,0:17:15.93,0:17:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mandikan punggung\Ndan bagian atasnya,
Dialogue: 0,0:17:18.21,0:17:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sisa yang bawahnya saja.
Dialogue: 0,0:17:19.52,0:17:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:17:20.91,0:17:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku masih malu menyentuh Kyougi,\Ntapi sekarang menyentuh kulit langsung?!
Dialogue: 0,0:17:24.57,0:17:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu,\Ndalam kondisi dilihat orang tua?!
Dialogue: 0,0:17:27.79,0:17:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa situasinya jadi segila ini?
Dialogue: 0,0:17:30.28,0:17:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak, tidak bisa, tidak bisa.\NTidak akan bisa!
Dialogue: 0,0:17:43.29,0:17:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:17:44.90,0:17:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenda.
Dialogue: 0,0:17:49.01,0:17:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan?!
Dialogue: 0,0:17:50.17,0:17:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona?! Nona, Nona!
Dialogue: 0,0:17:53.16,0:17:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, waduh.
Dialogue: 0,0:17:58.73,0:18:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kenapa aku tidur?
Dialogue: 0,0:18:05.96,0:18:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku sekasur dengan Kyougi?!
Dialogue: 0,0:18:10.07,0:18:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi ada di kamarku.
Dialogue: 0,0:18:11.70,0:18:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, kenapa, kenapa, kenapa?
Dialogue: 0,0:18:15.33,0:18:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena Ibu yang berinisiatif!
Dialogue: 0,0:18:27.15,0:18:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar saja.
Dialogue: 0,0:18:30.28,0:18:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, nyaman banget.
Dialogue: 0,0:18:32.87,0:18:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bilang\Ningin lakukan ini pada Kyougi.
Dialogue: 0,0:18:36.16,0:18:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, lebih seperti...
Dialogue: 0,0:18:41.43,0:18:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah bangun sejak kapan?!
Dialogue: 0,0:18:43.23,0:18:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa berhenti?
Dialogue: 0,0:18:44.83,0:18:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, silakan nikmati lenganku lebih lama!
Dialogue: 0,0:18:47.28,0:18:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Lupakan saja!
Dialogue: 0,0:18:51.26,0:18:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:18:53.20,0:18:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, ini kamar Senior?
Dialogue: 0,0:18:55.32,0:18:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ini kamar Senior!
Dialogue: 0,0:18:58.52,0:19:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata seperti ini, ya?\NHarum sekali.
Dialogue: 0,0:19:01.00,0:19:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat-lihat!\NJangan dihirup juga!
Dialogue: 0,0:19:04.10,0:19:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalaku agak pusing...
Dialogue: 0,0:19:09.12,0:19:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kau terlalu bersemangat.
Dialogue: 0,0:19:11.26,0:19:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tadi pingsan di kamar mandi,\Njangan terlalu heboh.
Dialogue: 0,0:19:16.78,0:19:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... tidur di pangkuan.
Dialogue: 0,0:19:18.61,0:19:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kenapa malah manja?!
Dialogue: 0,0:19:20.90,0:19:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku bakal cepat sembuh\Nkalau dirawat Senior.
Dialogue: 0,0:19:27.51,0:19:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaki ini.\NKulit mulus seperti bayi yang baru lahir.
Dialogue: 0,0:19:32.23,0:19:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paha yang empuk seperti marshmallow.
Dialogue: 0,0:19:34.49,0:19:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya punya khasiat mengobati kegundahan.
Dialogue: 0,0:19:36.73,0:19:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ditambah wangi ini... Hidung, paru-paru...\N- Ka-Kalau bilang begitu...
Dialogue: 0,0:19:39.17,0:19:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau lakukan, kok.
Dialogue: 0,0:19:41.11,0:19:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya wajahnya menghadap\Nke arah yang salah, deh.
Dialogue: 0,0:19:44.34,0:19:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harum setelah mandi...
Dialogue: 0,0:19:46.65,0:19:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin tenang.
Dialogue: 0,0:19:48.23,0:19:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin tenang apa, sih, Kyougi?
Dialogue: 0,0:19:51.04,0:19:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau lebih manja dari biasanya?
Dialogue: 0,0:19:55.73,0:19:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Kyougi...
Dialogue: 0,0:20:00.09,0:20:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya?
Dialogue: 0,0:20:03.17,0:20:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku mengajakmu\Ndengan semangat liburan,
Dialogue: 0,0:20:05.90,0:20:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi malah banyak kejadian aneh.
Dialogue: 0,0:20:09.05,0:20:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin bersenang-senang denganmu.
Dialogue: 0,0:20:13.41,0:20:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersenang-senang, kok.
Dialogue: 0,0:20:16.41,0:20:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:17.84,0:20:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melihat banyak\Nsisi lain dari Senior.
Dialogue: 0,0:20:21.22,0:20:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargamu, terutama ibumu, sangat baik,\Ndan sering membuatku senang.
Dialogue: 0,0:20:28.01,0:20:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:20:29.58,0:20:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersenyumlah.
Dialogue: 0,0:20:38.47,0:20:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:20:45.95,0:20:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh!
Dialogue: 0,0:20:47.75,0:20:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, itu sakit!
Dialogue: 0,0:20:49.29,0:20:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,\Nsepertinya kau terlalu ramah pada ibuku.
Dialogue: 0,0:20:53.20,0:20:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kalau soal itu, aku hanya...
Dialogue: 0,0:20:56.43,0:20:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau terlalu sering\Nmain-main seperti tadi,
Dialogue: 0,0:20:59.31,0:21:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menghukummu.
Dialogue: 0,0:21:06.24,0:21:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:21:10.06,0:21:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Senior...
Dialogue: 0,0:21:12.84,0:21:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh tidur di sini?
Dialogue: 0,0:21:17.21,0:21:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Te-Tentu saja tidak boleh!
Dialogue: 0,0:21:19.17,0:21:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat keluar dari sini!
Dialogue: 0,0:21:21.83,0:21:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi kau bisa tidur\Ndi sofa sebelah sana, kok.
Dialogue: 0,0:21:25.57,0:21:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kasihan.
Dialogue: 0,0:21:26.56,0:21:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:23:04.85,0:23:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak. Ini enak.
Dialogue: 0,0:23:07.26,0:23:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tidak bisa tidur satu detik pun,
Dialogue: 0,0:23:10.13,0:23:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Makhluk Inferior ini...
Dialogue: 0,0:23:12.74,0:23:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah tidur lama, aku jadi lapar.
Dialogue: 0,0:23:15.33,0:23:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berduaan di kamar, dari malam sampai pagi.
Dialogue: 0,0:23:18.28,0:23:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak menyentuhku sedikit pun?!
Dialogue: 0,0:23:20.01,0:23:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini sopannya kebangetan!
Dialogue: 0,0:23:22.03,0:23:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bukan.\NAku tidak mengharapkan apa-apa, kok.
Dialogue: 0,0:23:33.86,0:23:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi Youji.
Dialogue: 0,0:23:35.77,0:23:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk menjemputmu.
