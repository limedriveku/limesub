Dialogue: 0,0:00:10.53,0:00:12.59,sign,,0000,0000,0000,,"PACAR RESMI"
Dialogue: 0,0:01:52.00,0:01:55.51,sign,,0000,0000,0000,,#12 UJIAN CINTA KANAN DAN KYOUGI
Dialogue: 0,0:05:53.08,0:05:54.13,sign,,0000,0000,0000,,UFO?!
Dialogue: 0,0:06:12.51,0:06:14.02,sign,,0000,0000,0000,,RUMAH LAUT - ES SERUT
Dialogue: 0,0:07:53.41,0:07:54.39,sign,,0000,0000,0000,,NYONYA BESAR - NONA
Dialogue: 0,0:10:03.25,0:10:06.95,sign,,0000,0000,0000,,"KANAN"
Dialogue: 0,0:12:31.35,0:12:32.48,sign,,0000,0000,0000,,BOING.
Dialogue: 0,0:12:32.48,0:12:35.12,sign,,0000,0000,0000,,YA, BELUM MELOROT.\NAKU MASIH SINGSET!
Dialogue: 0,0:12:35.12,0:12:36.06,sign,,0000,0000,0000,,CEPAT PAKAI BAJU!
Dialogue: 0,0:20:22.38,0:20:24.45,sign,,0000,0000,0000,,RELI STEMPEL UNTUK MENGAKUI
Dialogue: 0,0:22:51.34,0:22:53.26,sign,,0000,0000,0000,,"RUANG KOMITE DISIPLIN"
Dialogue: 0,0:00:00.64,0:00:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Reli Stempel Untuk Mengakui Pacar", selesai!
Dialogue: 0,0:00:04.46,0:00:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian serasi sekali!
Dialogue: 0,0:00:05.62,0:00:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kau dan Kyougi\Nresmi berpacaran, ya.
Dialogue: 0,0:00:08.75,0:00:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kalian berbahagia.
Dialogue: 0,0:00:10.53,0:00:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, Nona!
Dialogue: 0,0:00:15.95,0:00:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, mohon bimbingannya.
Dialogue: 0,0:00:18.37,0:00:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita langsung saja...
Dialogue: 0,0:00:20.15,0:00:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengalamanku masih sedikit,\Ntolong jangan terlalu keras padaku.
Dialogue: 0,0:00:23.62,0:00:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Hah, apa?!
Dialogue: 0,0:00:29.59,0:00:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kita sudah resmi berpacaran.
Dialogue: 0,0:00:32.18,0:00:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tunggu sebentar!
Dialogue: 0,0:00:33.48,0:00:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kita terlalu cepat, deh?
Dialogue: 0,0:00:35.40,0:00:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah resmi.
Dialogue: 0,0:00:38.60,0:00:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Ba-Ba-Bagaimana ini?
Dialogue: 0,0:00:40.12,0:00:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa tiba-tiba sekali?!
Dialogue: 0,0:00:43.33,0:00:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... akan benar-benar lakukan "itu"?
Dialogue: 0,0:00:46.48,0:00:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika bersama Kyougi...
Dialogue: 0,0:00:48.61,0:00:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku mikir apa, sih?!
Dialogue: 0,0:00:50.26,0:00:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mimpi. Pasti mimpi!
Dialogue: 0,0:00:51.87,0:00:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus segera bangun!
Dialogue: 0,0:00:55.16,0:00:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Kyougi... keras dan hangat.
Dialogue: 0,0:00:58.75,0:01:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika memang mimpi, biarlah aku tetap...
Dialogue: 0,0:01:02.03,0:01:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak!
Dialogue: 0,0:01:03.36,0:01:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti ini baru boleh\Nsetelah tahap tertentu!
Dialogue: 0,0:01:06.00,0:01:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh terbawa suasana!
Dialogue: 0,0:01:07.84,0:01:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka matamu, Kanan.
Dialogue: 0,0:01:09.32,0:01:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarlah, Kanan!
Dialogue: 0,0:01:10.72,0:01:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat... Cepatlah bangun, diriku!
Dialogue: 0,0:01:23.13,0:01:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, kamu baik-baik saja...
Dialogue: 0,0:01:28.06,0:01:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:01:29.00,0:01:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku hanya mendekat\Nkarena dengar teriakanmu.
Dialogue: 0,0:01:32.05,0:01:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan reli stempelnya?
Dialogue: 0,0:01:33.64,0:01:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya apa?
Dialogue: 0,0:01:35.18,0:01:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Sisa ayahmu saja.
Dialogue: 0,0:01:38.36,0:01:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus pikirkan sesuatu\Nkarena pulang besok.
Dialogue: 0,0:01:41.93,0:01:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau sudah dapat stempel,\Naku tetap tidak mau, ya.
Dialogue: 0,0:01:45.24,0:01:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apanya?
Dialogue: 0,0:01:47.26,0:01:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya harus melewati\Ntahap-tahap tertentu dulu.
Dialogue: 0,0:01:49.99,0:01:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior ngomong apa, sih?
Dialogue: 0,0:01:56.06,0:01:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa Papa saja, ya.
Dialogue: 0,0:01:58.24,0:01:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:01:59.84,0:02:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Babi, temani aku main, yuk.
Dialogue: 0,0:02:02.60,0:02:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka jadi seakrab itu?
Dialogue: 0,0:02:05.89,0:02:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel juga bersikap aneh\Nsetelah memberikan stempelnya.
Dialogue: 0,0:02:09.78,0:02:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kenapa aku deg-degan\Nkarena Makhluk Inferior sepertinya?
Dialogue: 0,0:02:14.48,0:02:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan aku juga
Dialogue: 0,0:02:16.05,0:02:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terangsang saat pacar Kakak\Ndirebut orang lain?
Dialogue: 0,0:02:20.01,0:02:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colek, colek.
Dialogue: 0,0:02:21.09,0:02:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch, itu geli, tahu.
Dialogue: 0,0:02:24.06,0:02:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak bisa!
Dialogue: 0,0:02:25.63,0:02:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang merebut, direbut orang lain...
Dialogue: 0,0:02:28.58,0:02:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh menggoda.
Dialogue: 0,0:02:31.25,0:02:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lemah di pipi, ya.
Dialogue: 0,0:02:33.84,0:02:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, bagaimana kalau yang di sebelah sini?
Dialogue: 0,0:02:39.32,0:02:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch, rasanya kau terlalu akrab\Ndengan Kyougi.
Dialogue: 0,0:02:44.39,0:02:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa? Biasa saja, kok.
Dialogue: 0,0:02:47.79,0:02:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan? Kak Pacar!
Dialogue: 0,0:02:50.05,0:02:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kak Pacar", katamu?
Dialogue: 0,0:02:52.31,0:02:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dia nanti jadi suamimu?
Dialogue: 0,0:02:55.73,0:02:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, dia jadi kakak ipar sungguhan, dong.
Dialogue: 0,0:02:58.46,0:02:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suami?!
Dialogue: 0,0:03:00.00,0:03:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menikahi Kyougi...?!
Dialogue: 0,0:03:02.91,0:03:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, jangan pergi!
Dialogue: 0,0:03:05.22,0:03:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sebaiknya pergi saja!
Dialogue: 0,0:03:06.94,0:03:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, mana mungkin\Naku menikahi seorang manusia?!
Dialogue: 0,0:03:09.93,0:03:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, biar Mil saja yang jadi istrinya.
Dialogue: 0,0:03:12.88,0:03:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:03:14.79,0:03:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi pusing sendiri\Nkarena banyak yang suka.
Dialogue: 0,0:03:17.02,0:03:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cengengesan saja,\Ndasar kau Makhluk Inferior!
Dialogue: 0,0:03:20.17,0:03:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mil serius, tahu.
Dialogue: 0,0:03:21.95,0:03:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Mil sayang banget sama Kak Pacar.
Dialogue: 0,0:03:26.86,0:03:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milch.
Dialogue: 0,0:03:29.37,0:03:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:03:31.61,0:03:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak seram!
Dialogue: 0,0:03:33.89,0:03:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kakak... akan menikah...\N- Mereka akrab sekali, ya.
Dialogue: 0,0:03:36.37,0:03:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Dik Youji.
Dialogue: 0,0:03:38.53,0:03:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?!
Dialogue: 0,0:03:39.85,0:03:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?\NMasih pagi tapi sudah berisik sekali.
Dialogue: 0,0:03:43.52,0:03:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:03:45.19,0:03:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, berikan stempelmu!
Dialogue: 0,0:03:47.64,0:03:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku akan kasih.
Dialogue: 0,0:03:50.04,0:03:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, yang benar?!
Dialogue: 0,0:03:52.35,0:03:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, aku ingin bilang itu...
Dialogue: 0,0:03:55.73,0:04:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, kau harus melewati ujianku.
Dialogue: 0,0:04:02.51,0:04:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian.
Dialogue: 0,0:04:07.57,0:04:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, mari lakukan yang terbaik\Nsaat main voli pantai, ya.
Dialogue: 0,0:04:12.10,0:04:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Rasanya ada yang berbeda dengan Senior.
Dialogue: 0,0:04:15.97,0:04:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanmu saja.
Dialogue: 0,0:04:17.61,0:04:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tapi...
Dialogue: 0,0:04:18.50,0:04:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanmu saja!
Dialogue: 0,0:04:20.32,0:04:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi ada kesempatan,\Nkau satu grup dengan Milch saja.
Dialogue: 0,0:04:23.13,0:04:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh kalian berdua benar-benar dekat.
Dialogue: 0,0:04:26.49,0:04:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan, Ami?
Dialogue: 0,0:04:27.67,0:04:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah dilempar ke aku?
Dialogue: 0,0:04:30.91,0:04:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata di mata Senior juga seperti itu.
Dialogue: 0,0:04:34.40,0:04:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Bisa-bisanya kau masih cengengesan.
Dialogue: 0,0:04:37.98,0:04:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak sadar sudah salah, ya?!
Dialogue: 0,0:04:40.29,0:04:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dicium di pipi, lo. Dicium!
Dialogue: 0,0:04:42.13,0:04:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang karena seperti punya adik.
Dialogue: 0,0:04:44.75,0:04:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga lega karena\Nsudah akrab dengan Milch.
Dialogue: 0,0:04:47.16,0:04:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akrab juga harus tahu batasan, dong.
Dialogue: 0,0:04:49.89,0:04:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia bisa semudah itu\Nmencium pipimu, hah?!
Dialogue: 0,0:04:52.37,0:04:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu, ciumannya lebih dekat ke bibir\Ndibandingkan aku!
Dialogue: 0,0:04:55.72,0:04:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Ami.
Dialogue: 0,0:04:56.71,0:04:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah tanya padaku, sih?
Dialogue: 0,0:04:58.51,0:05:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana pendapatmu\Ntentang pria yang bahagia
Dialogue: 0,0:05:00.53,0:05:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena dicium wanita selain pacarnya?
Dialogue: 0,0:05:02.99,0:05:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Biar kupikir dulu.
Dialogue: 0,0:05:05.10,0:05:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja kenalanku yang satu itu\Nseagresif adiknya, pasti dia...
Dialogue: 0,0:05:10.84,0:05:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kau seharusnya memihakku!
Dialogue: 0,0:05:13.15,0:05:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa...!
Dialogue: 0,0:05:15.15,0:05:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga...
Dialogue: 0,0:05:21.24,0:05:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, waktunya makan camilan.
Dialogue: 0,0:05:24.12,0:05:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, gawat.
Dialogue: 0,0:05:26.13,0:05:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku terpeleset!
Dialogue: 0,0:05:28.36,0:05:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku!
Dialogue: 0,0:05:30.23,0:05:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:32.18,0:05:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku sedang sibuk\Nmembersihkan kue dari wajahnya...
Dialogue: 0,0:05:36.10,0:05:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin aku cium dia?!
Dialogue: 0,0:05:39.48,0:05:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku!
Dialogue: 0,0:05:40.05,0:05:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika saat Kyougi tidak bisa\Nmelihat seperti sekarang...
Dialogue: 0,0:05:43.31,0:05:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Manis!\N- Aku juga pasti bisa!
Dialogue: 0,0:05:45.54,0:05:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau tidak apa-apa?
Dialogue: 0,0:05:47.14,0:05:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Se-Senior!\N- Aku akan segera bersihkan.
Dialogue: 0,0:05:48.87,0:05:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa lihat!
Dialogue: 0,0:05:50.69,0:05:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Ada UFO yang terbang, ya?
Dialogue: 0,0:05:54.21,0:05:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, aku harus berani!
Dialogue: 0,0:05:56.40,0:05:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Senior...!
Dialogue: 0,0:06:05.18,0:06:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil! Aku berhasil lakukan!
Dialogue: 0,0:06:07.35,0:06:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dekat dari Milch,\Npunyaku 2 cm dari bibir!
Dialogue: 0,0:06:09.71,0:06:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hebat, 'kan?!
Dialogue: 0,0:06:11.08,0:06:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung di bibir, dong.
Dialogue: 0,0:06:16.28,0:06:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, pertandingan voli\Npantai keluarga Zebul akan dimulai.
Dialogue: 0,0:06:20.90,0:06:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan berakhir\Nsaat skor mencapai 5 poin.
Dialogue: 0,0:06:23.47,0:06:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Nona Kanan.
Dialogue: 0,0:06:25.68,0:06:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Nyonya Besar.\NNona Milch sebagai pemain cadangan.
Dialogue: 0,0:06:29.05,0:06:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miel, semangat!
Dialogue: 0,0:06:30.93,0:06:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Ayah tidak ikut main, ya?
Dialogue: 0,0:06:33.93,0:06:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau bilang, "Penonton mana\Nyang senang lihat baju renang lelaki?"
Dialogue: 0,0:06:38.14,0:06:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penonton?
Dialogue: 0,0:06:39.42,0:06:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tim Nona Kanan menang,
Dialogue: 0,0:06:41.53,0:06:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka akan mendapatkan stempel Tuan Besar.
Dialogue: 0,0:06:43.90,0:06:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,\Nmereka akan resmi menjadi sepasang kekasih.
Dialogue: 0,0:06:47.38,0:06:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpacaran dengan Nona... Aku iri sekali!
Dialogue: 0,0:06:50.81,0:06:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Pelayan?
Dialogue: 0,0:06:53.31,0:06:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang banget hanya tim Kakak\Nyang dapat hadiah.
Dialogue: 0,0:06:56.73,0:06:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga mau hadiah, dong.
Dialogue: 0,0:07:00.30,0:07:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, dia ada benarnya.
Dialogue: 0,0:07:02.88,0:07:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian mau apa?
Dialogue: 0,0:07:06.73,0:07:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan kencan dengan Kak Pacar.
Dialogue: 0,0:07:10.87,0:07:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan?!
Dialogue: 0,0:07:12.27,0:07:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan selingkuh dengan Kak Pacar.
Dialogue: 0,0:07:15.16,0:07:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak akan pasang ekspresi\Nyang seperti apa, ya?
Dialogue: 0,0:07:20.02,0:07:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan untuk merebut manusia itu...?
Dialogue: 0,0:07:23.31,0:07:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang ingin kakakku direbut orang lain,
Dialogue: 0,0:07:25.72,0:07:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah terangsang saat melihat\Nsi perebut direbut orang lain,
Dialogue: 0,0:07:28.57,0:07:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu sekarang aku\Nmerebutnya dari mereka berdua.
Dialogue: 0,0:07:30.97,0:07:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya...
Dialogue: 0,0:07:32.81,0:07:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saling rebut sampai tiga tingkat?
Dialogue: 0,0:07:36.97,0:07:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh terangsang karena ini?
Dialogue: 0,0:07:39.51,0:07:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sedang memikirkan apa, sih?!
Dialogue: 0,0:07:42.46,0:07:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan, Dik Youji, aku mulai, ya!
Dialogue: 0,0:07:49.65,0:07:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima ini!
Dialogue: 0,0:07:54.44,0:07:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu poin.
Dialogue: 0,0:07:55.75,0:07:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, kau harus fokus.
Dialogue: 0,0:07:58.07,0:07:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi kalau yang tadi itu...
Dialogue: 0,0:07:59.98,0:08:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalah, kita tidak dapat stempel, lo.
Dialogue: 0,0:08:02.34,0:08:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bengong saja!
Dialogue: 0,0:08:03.81,0:08:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tahu itu...
Dialogue: 0,0:08:06.65,0:08:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mataku jadi memerhatikan itu...
Dialogue: 0,0:08:08.25,0:08:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang ibumu yang sangat terbuka.
Dialogue: 0,0:08:11.72,0:08:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lihat apa, sih?!
Dialogue: 0,0:08:13.47,0:08:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Youji, aku paham betul perasaanmu.
Dialogue: 0,0:08:17.65,0:08:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kau kekasih Kanan.
Dialogue: 0,0:08:21.19,0:08:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak boleh melirik perempuan lain.
Dialogue: 0,0:08:23.54,0:08:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini,\Naku harus tegas seperti seorang ibu.
Dialogue: 0,0:08:26.48,0:08:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar.\NJika aku menang dalam pertandingan ini,
Dialogue: 0,0:08:29.28,0:08:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan dapat kesempatan\Nkencan dengannya, 'kan?
Dialogue: 0,0:08:33.37,0:08:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Dik Youji.
Dialogue: 0,0:08:35.28,0:08:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah punya Kanan.
Dialogue: 0,0:08:37.65,0:08:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya latihan.
Dialogue: 0,0:08:39.33,0:08:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan untuk aku dan Senior nanti.
Dialogue: 0,0:08:42.17,0:08:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti...
Dialogue: 0,0:08:43.02,0:08:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:08:45.22,0:08:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:08:49.58,0:08:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dapat skor berapa?
Dialogue: 0,0:08:51.29,0:08:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah keluar lapangan.
Dialogue: 0,0:08:53.34,0:08:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di sini, di sini.\N- Semangat, Tuan Beelzebub.
Dialogue: 0,0:08:54.05,0:08:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kau, semangka?
Dialogue: 0,0:08:57.31,0:08:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi!
Dialogue: 0,0:09:01.35,0:09:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, aku harus melihat ke mana?
Dialogue: 0,0:09:03.31,0:09:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola!
Dialogue: 0,0:09:05.02,0:09:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga. Jangan terpesona\Ndengan baju renang orang selain aku!
Dialogue: 0,0:09:09.63,0:09:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya boleh terpesona saat melihatku!
Dialogue: 0,0:09:16.07,0:09:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan... Ralat, jangan lihat aku.
Dialogue: 0,0:09:18.98,0:09:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sedang dilihat dengan mata cabul!
Dialogue: 0,0:09:21.50,0:09:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga. Ibu juga harus ingat\Numur saat pilih baju renang!
Dialogue: 0,0:09:26.71,0:09:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin. Mama juga...\NMama juga masih...
Dialogue: 0,0:09:30.21,0:09:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih singset dan menggoda, tahu!
Dialogue: 0,0:09:33.71,0:09:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:09:34.77,0:09:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penerimaan yang bagus!
Dialogue: 0,0:09:38.42,0:09:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, bola ini\Nhasil kerja sama Kakak dan Makhluk Inferior.
Dialogue: 0,0:09:43.51,0:09:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah simbol cinta mereka?!
Dialogue: 0,0:09:47.96,0:09:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Miel. Kau baik-baik saja?
Dialogue: 0,0:09:50.31,0:09:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Dia tersenyum?
Dialogue: 0,0:09:52.25,0:09:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spike pamer begitu... Aku jadi bernafsu...
Dialogue: 0,0:09:56.46,0:09:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, dasar Miel pemalas.
Dialogue: 0,0:09:59.95,0:10:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, serahkan sisanya padaku.
Dialogue: 0,0:10:03.25,0:10:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tada! Baju renang sekolah punya Kakak!
Dialogue: 0,0:10:07.05,0:10:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matamu terpaku padaku, 'kan?
Dialogue: 0,0:10:08.78,0:10:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang Kakak saat masih kecil\Nyang amat ingin kau lihat.
Dialogue: 0,0:10:14.58,0:10:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan tunjukkan nafsu itu\Npada aku, adiknya,
Dialogue: 0,0:10:17.82,0:10:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu membayangkan hal-hal berbahaya, 'kan?
Dialogue: 0,0:10:21.44,0:10:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau cabul!
Dialogue: 0,0:10:25.94,0:10:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:10:26.73,0:10:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak lihat sama sekali, dong!
Dialogue: 0,0:10:29.42,0:10:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seharusnya menghindar\Nsetelah terima bolanya!
Dialogue: 0,0:10:31.68,0:10:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:33.09,0:10:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka malah bermesraan!
Dialogue: 0,0:10:35.43,0:10:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih singset, kok...
Dialogue: 0,0:10:36.97,0:10:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu juga masih syok!
Dialogue: 0,0:10:47.50,0:10:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skor seri.
Dialogue: 0,0:10:51.11,0:10:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, waktunya kita selesaikan.
Dialogue: 0,0:10:53.77,0:10:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:10:54.60,0:10:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak hebat juga, Mil jadi hampir kalah.
Dialogue: 0,0:10:58.93,0:11:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bohong.
Dialogue: 0,0:11:00.15,0:11:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak yang akan kalah hari ini!
Dialogue: 0,0:11:03.11,0:11:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lempar, ya!
Dialogue: 0,0:11:05.57,0:11:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Pacar, lihat, deh!
Dialogue: 0,0:11:15.10,0:11:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melihat apa
Dialogue: 0,0:11:17.84,0:11:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai sefokus itu, sih?!
Dialogue: 0,0:11:19.55,0:11:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:11:24.32,0:11:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Nona Kanan pemenangnya!
Dialogue: 0,0:11:26.83,0:11:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Besar - Nona
Dialogue: 0,0:11:27.70,0:11:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku kalah, deh.
Dialogue: 0,0:11:29.58,0:11:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lupakan. Lupakan yang kau lihat tadi!\N- Aku diperhatikan oleh Youji.
Dialogue: 0,0:11:34.50,0:11:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direbut... Pamer...
Dialogue: 0,0:11:37.88,0:11:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simbol cinta.
Dialogue: 0,0:11:42.31,0:11:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Ini...
Dialogue: 0,0:11:47.11,0:11:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat tangkapan besar!
Dialogue: 0,0:11:56.74,0:11:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melahirkan sesuatu!
Dialogue: 0,0:12:00.35,0:12:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut rancung itu...
Dialogue: 0,0:12:01.96,0:12:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeanne!
Dialogue: 0,0:12:04.28,0:12:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dimakan cumi.
Dialogue: 0,0:12:07.72,0:12:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu terluka?
Dialogue: 0,0:12:14.22,0:12:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi!
Dialogue: 0,0:12:16.66,0:12:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut sekali!
Dialogue: 0,0:12:19.09,0:12:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bau cumi!
Dialogue: 0,0:12:20.18,0:12:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa yang kau... bau cumi!
Dialogue: 0,0:12:22.43,0:12:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar, dia bau cumi!
Dialogue: 0,0:12:25.79,0:12:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Babi betina bau! Bau cumi!\N- Aku juga jadi bau cumi!
Dialogue: 0,0:12:39.92,0:12:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandian!
Dialogue: 0,0:12:41.90,0:12:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, bahaya kalau melompat masuk begitu.
Dialogue: 0,0:12:44.86,0:12:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:12:46.64,0:12:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku benci sabun!\N- Tapi kau bau cumi. Aku serius!
Dialogue: 0,0:12:49.44,0:12:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Voli pantai tadi seru, ya.
Dialogue: 0,0:12:51.65,0:12:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar. Lumayan seru.
Dialogue: 0,0:12:54.78,0:12:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita bisa dapat stempel dari Ayah.
Dialogue: 0,0:12:58.38,0:13:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya, aku benar-benar\Nresmi mencari pacar Senior, 'kan?
Dialogue: 0,0:13:03.50,0:13:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang berubah\Nmeski kau sudah dapat stempel, tahu.
Dialogue: 0,0:13:07.00,0:13:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa maksudmu...?
Dialogue: 0,0:13:09.89,0:13:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku...
Dialogue: 0,0:13:11.36,0:13:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... Begini...
Dialogue: 0,0:13:14.72,0:13:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikirkan saja sendiri!
Dialogue: 0,0:13:18.97,0:13:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku setelah dari pemandian nanti.
Dialogue: 0,0:13:21.60,0:13:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kuperlihatkan padamu.
Dialogue: 0,0:13:24.88,0:13:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ah, baiklah.
Dialogue: 0,0:13:33.68,0:13:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:13:34.77,0:13:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Manusia! Bisa bantu aku sebentar?
Dialogue: 0,0:13:38.48,0:13:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa lihat ritsleting ini?
Dialogue: 0,0:13:40.03,0:13:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tiba-tiba macet.
Dialogue: 0,0:13:41.68,0:13:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ritsleting?
Dialogue: 0,0:13:44.72,0:13:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ritsleting.
Dialogue: 0,0:13:56.06,0:13:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya lepas juga. Terima kasih.
Dialogue: 0,0:13:58.45,0:14:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada anak kecil di dalam kostumnya?!
Dialogue: 0,0:14:00.16,0:14:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan. Maksudku...
Dialogue: 0,0:14:02.25,0:14:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dewasa banget, ya.
Dialogue: 0,0:14:04.49,0:14:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat apa kau?
Dialogue: 0,0:14:07.73,0:14:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air panasnya nyaman, ya.
Dialogue: 0,0:14:09.50,0:14:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hebat juga, ya.
Dialogue: 0,0:14:11.43,0:14:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kostum badut tadi tidak aneh, ya?
Dialogue: 0,0:14:15.14,0:14:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah. Sebenarnya,
Dialogue: 0,0:14:17.65,0:14:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak bisa perlihatkan\Nwujud ini pada manusia.
Dialogue: 0,0:14:21.15,0:14:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berhasil kumpulkan semua stempelnya, ya?
Dialogue: 0,0:14:24.21,0:14:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Aku berusaha dengan Senior Kanan.
Dialogue: 0,0:14:27.22,0:14:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau begitu.
Dialogue: 0,0:14:30.13,0:14:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terlihat bersenang-senang\Nsaat pura-pura berpacaran.
Dialogue: 0,0:14:33.33,0:14:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pura-pura?
Dialogue: 0,0:14:34.99,0:14:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian menjalin kontrak kekasih, 'kan?
Dialogue: 0,0:14:37.48,0:14:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan untuk formalitas saja.
Dialogue: 0,0:14:39.98,0:14:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak. Aku dan Senior...
Dialogue: 0,0:14:43.76,0:14:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... belum pernah dengar\Ndia bilang "suka"...?
Dialogue: 0,0:14:47.86,0:14:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis dan manusia tak mungkin\Nbisa punya hubungan asmara.
Dialogue: 0,0:14:53.54,0:14:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku duluan, ya.
Dialogue: 0,0:14:55.09,0:14:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kepanasan.
Dialogue: 0,0:14:57.28,0:14:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya...
Dialogue: 0,0:15:00.81,0:15:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelaki pertamanya!
Dialogue: 0,0:15:02.94,0:15:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:15:04.13,0:15:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan kau bilang sesuatu\Nyang tak enak di telinga, ya?!
Dialogue: 0,0:15:07.21,0:15:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, akulah lelaki pertama untuknya!
Dialogue: 0,0:15:10.17,0:15:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang gendong dia saat baru lahir dulu!
Dialogue: 0,0:15:12.71,0:15:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya keluarga dihitung, ya?
Dialogue: 0,0:15:14.03,0:15:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak?!
Dialogue: 0,0:15:15.42,0:15:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, dia pernah bilang,\N"Aku sayang Papa.
Dialogue: 0,0:15:17.48,0:15:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat besar nanti,\Naku mau menikah dengan Papa"!
Dialogue: 0,0:15:21.80,0:15:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?!
Dialogue: 0,0:15:23.58,0:15:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, aku pemenangnya! Sayang sekali!
Dialogue: 0,0:15:26.38,0:15:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa? Kyougi?
Dialogue: 0,0:15:28.85,0:15:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior saat kecil imut banget, ya.\NAku suka!
Dialogue: 0,0:15:32.15,0:15:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang tunjukkan aku\Nlebih sayang dia dari kau!
Dialogue: 0,0:15:34.67,0:15:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kau?
Dialogue: 0,0:15:36.21,0:15:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin lomba siapa yang bisa\Nsebutkan kelebihan Kanan denganku, ya?
Dialogue: 0,0:15:40.38,0:15:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati!
Dialogue: 0,0:15:42.38,0:15:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kepribadiannya yang dewasa!
Dialogue: 0,0:15:44.61,0:15:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kepribadiannya yang usil!
Dialogue: 0,0:15:46.96,0:15:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya saat malu imut!
Dialogue: 0,0:15:48.23,0:15:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia imut karena sok kuat\Nuntuk sembunyikan rasa malu!
Dialogue: 0,0:15:51.18,0:15:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia manis sekali karena\Nmementingkan keluarga!
Dialogue: 0,0:15:53.55,0:15:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gemas karena ternyata lumayan manja!
Dialogue: 0,0:15:55.76,0:15:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka wajahnya saat\Nmakan sesuatu yang lezat!
Dialogue: 0,0:15:57.76,0:15:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sekarang giliranku!
Dialogue: 0,0:16:01.66,0:16:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pernah makan dengan Kanan\Nyang bilang makan sendiri lebih baik?
Dialogue: 0,0:16:05.66,0:16:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gemas saat ingat pipi Senior\Nmenggembung saat makan kroket.
Dialogue: 0,0:16:11.00,0:16:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku yang ingin mengajarinya\Nnikmatnya makan bersama orang lain.
Dialogue: 0,0:16:19.15,0:16:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering menggendongnya\Nsaat dia masih kecil.
Dialogue: 0,0:16:23.13,0:16:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pernah menggendongnya.
Dialogue: 0,0:16:25.62,0:16:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga pernah mandi bersama.
Dialogue: 0,0:16:27.66,0:16:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah masuk ke dalam baju renang Senior!
Dialogue: 0,0:16:30.22,0:16:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Baju renang?
Dialogue: 0,0:16:31.83,0:16:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:16:33.97,0:16:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lemah pada kejutan.
Dialogue: 0,0:16:35.59,0:16:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelemahannya ada di kuping.
Dialogue: 0,0:16:37.08,0:16:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut yang lembut.
Dialogue: 0,0:16:38.51,0:16:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadanya berisi.
Dialogue: 0,0:16:41.23,0:16:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia, hebat juga kau.
Dialogue: 0,0:16:42.99,0:16:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum. Aku masih bisa lanjut.
Dialogue: 0,0:16:46.63,0:16:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Kanan sering cemburu...
Dialogue: 0,0:16:49.43,0:16:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan...
Dialogue: 0,0:16:50.80,0:16:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada sesuatu.
Dialogue: 0,0:16:52.01,0:16:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}obrolan kalian!
Dialogue: 0,0:17:00.17,0:17:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara Kyougi dan Papa\Nsampai terdengar ke sebelah!
Dialogue: 0,0:17:03.18,0:17:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kalian berdua tidak malu...?
Dialogue: 0,0:17:07.65,0:17:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter!
Dialogue: 0,0:17:14.94,0:17:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:17:17.27,0:17:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah baikan?
Dialogue: 0,0:17:19.42,0:17:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudah.
Dialogue: 0,0:17:21.20,0:17:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri, ya.
Dialogue: 0,0:17:23.32,0:17:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi.
Dialogue: 0,0:17:31.48,0:17:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior ingin perlihatkan apa?
Dialogue: 0,0:17:34.39,0:17:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tidak sabaran. Sebentar lagi, kok.
Dialogue: 0,0:17:39.43,0:17:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kita sampai.
Dialogue: 0,0:17:41.21,0:17:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa di sini?
Dialogue: 0,0:17:43.18,0:17:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ke atas.
Dialogue: 0,0:17:45.01,0:17:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas?
Dialogue: 0,0:17:48.72,0:17:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Keren! Keren banget!
Dialogue: 0,0:17:51.82,0:17:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama lihat yang seperti ini!
Dialogue: 0,0:17:54.36,0:17:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat banget, ya. Seperti anak kecil saja.
Dialogue: 0,0:17:57.50,0:17:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali!
Dialogue: 0,0:18:01.34,0:18:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, begini...
Dialogue: 0,0:18:04.37,0:18:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku\Nmengajak seseorang ke rumah...
Dialogue: 0,0:18:09.80,0:18:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga membuatmu\Nterlibat pengumpulan stempel.
Dialogue: 0,0:18:14.92,0:18:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bersenang-senang?
Dialogue: 0,0:18:17.67,0:18:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Senior tanya itu...
Dialogue: 0,0:18:19.43,0:18:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah bertemu dan melihat\Nbetapa sayangnya mereka padamu...
Dialogue: 0,0:18:23.35,0:18:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, aku jadi ikut senang.
Dialogue: 0,0:18:26.60,0:18:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh, aku bersyukur bisa datang ke sini.
Dialogue: 0,0:18:31.40,0:18:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah? Baguslah.
Dialogue: 0,0:18:34.96,0:18:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk dulu.
Dialogue: 0,0:18:36.32,0:18:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:18:40.30,0:18:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nwadah apa yang kau bawa sejak tadi?
Dialogue: 0,0:18:43.82,0:18:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini.
Dialogue: 0,0:18:46.38,0:18:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tada! Kroket.
Dialogue: 0,0:18:48.28,0:18:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pinjam dapur kalian untuk masak.
Dialogue: 0,0:18:50.63,0:18:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ini buatanmu sendiri?
Dialogue: 0,0:18:52.96,0:18:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:54.19,0:18:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hebat juga.
Dialogue: 0,0:18:56.26,0:18:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lumayan ahli memasak kroket.
Dialogue: 0,0:19:00.20,0:19:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan pertama yang kita\Nsantap bersama juga kroket, 'kan?
Dialogue: 0,0:19:06.59,0:19:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:19:08.08,0:19:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:11.82,0:19:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:19:14.62,0:19:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:19:16.23,0:19:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:19:17.48,0:19:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya lebih geli dan terpenuhi\Ndaripada hari itu...
Dialogue: 0,0:19:21.83,0:19:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena Kyougi yang buat, ya?
Dialogue: 0,0:19:27.97,0:19:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Kyougi
Dialogue: 0,0:19:30.00,0:19:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sosok yang spesial?
Dialogue: 0,0:19:33.47,0:19:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kau bawa saus, tidak?
Dialogue: 0,0:19:35.64,0:19:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu mau pakaikan Tuan Kroket ini saus?
Dialogue: 0,0:19:39.66,0:19:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda, kok. Ini enak sekali.
Dialogue: 0,0:19:41.97,0:19:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:19:48.11,0:19:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kyougi.
Dialogue: 0,0:19:50.56,0:19:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau akrab dengan keluargaku.
Dialogue: 0,0:19:53.94,0:19:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahagia\Njika kau bersenang-senang di sini.
Dialogue: 0,0:19:58.72,0:20:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau mampir ke sini lagi?
Dialogue: 0,0:20:01.67,0:20:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:08.07,0:20:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kalian terlalu dekat.
Dialogue: 0,0:20:11.74,0:20:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa?! Kenapa ada di sini?
Dialogue: 0,0:20:13.65,0:20:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang itu, Kanan.
Dialogue: 0,0:20:15.58,0:20:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak boleh bermesraan\Ntanpa izin dari Papa, lo.
Dialogue: 0,0:20:20.09,0:20:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum kasih stempelnya.
Dialogue: 0,0:20:24.83,0:20:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa.
Dialogue: 0,0:20:26.25,0:20:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah surat sumpah bahwa\Nkami akan selalu mendukung Kanan.
Dialogue: 0,0:20:31.50,0:20:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga baik-baik.
Dialogue: 0,0:20:33.13,0:20:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surat sumpah.
Dialogue: 0,0:20:34.87,0:20:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, itu bukti sumpah\Nkalau kau akan celaka jika berkhianat.
Dialogue: 0,0:20:40.42,0:20:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, Youji.
Dialogue: 0,0:20:42.16,0:20:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Ayah!
Dialogue: 0,0:20:45.42,0:20:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sangat sayang Senior!
Dialogue: 0,0:20:50.30,0:20:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau bisa katakan itu di depan Papa?!
Dialogue: 0,0:20:53.51,0:20:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga...
Dialogue: 0,0:20:56.43,0:20:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:21:04.58,0:21:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat aku bilang suka padamu.
Dialogue: 0,0:21:12.73,0:21:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:22:46.00,0:22:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademi Dedikasi Kota Tama.
Dialogue: 0,0:22:49.08,0:22:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah yang damai,
Dialogue: 0,0:22:51.34,0:22:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat anak-anak yang sehat menimba ilmu.
Dialogue: 0,0:22:53.56,0:22:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sudut sekolah tersebut,
Dialogue: 0,0:22:55.15,0:22:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}iblis yang cantik jelita dan misterius\Nkembali berkuasa.
Dialogue: 0,0:23:02.26,0:23:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:23:04.17,0:23:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu libur musim panas saja\Nmembuat mereka degradasi sejauh ini.
Dialogue: 0,0:23:08.46,0:23:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga, para ternak\Nseharusnya aku urus sampai bersih...
Dialogue: 0,0:23:11.96,0:23:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior. Sudah jam patroli.
Dialogue: 0,0:23:15.06,0:23:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, sejak kapan kau ada di sana?!
Dialogue: 0,0:23:17.16,0:23:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak Akademi Tama.
Dialogue: 0,0:23:18.42,0:23:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari awal, dong?!
Dialogue: 0,0:23:20.32,0:23:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior mau main pura-pura\Nsambil cosplay gadis iblis lagi, ya?
Dialogue: 0,0:23:23.68,0:23:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh ikutan, tidak?
