Dialogue: 0,0:02:24.12,0:02:28.00,tanda,,0000,0000,0000,,#02 AMI DATANG
Dialogue: 0,0:02:48.48,0:02:50.98,tanda,,0000,0000,0000,,KELUARGA BIASA ITU YANG SEPERTI APA?
Dialogue: 0,0:03:56.67,0:03:59.17,tanda,,0000,0000,0000,,KENAPA MEMILIH MEREKA?
Dialogue: 0,0:04:31.72,0:04:35.17,tanda,,0000,0000,0000,,TAKAKIYO
Dialogue: 0,0:04:48.44,0:04:48.45,tanda,,0000,0000,0000,,BAGIMU, MANUSIA ITU APA?
Dialogue: 0,0:04:48.45,0:04:49.98,tanda,,0000,0000,0000,,"BAGIMU, MANUSIA ITU APA?"
Dialogue: 0,0:07:39.64,0:07:44.02,tanda,,0000,0000,0000,,AKADEMI DEDIKASI KOTA TAMA
Dialogue: 0,0:08:13.72,0:08:19.72,tanda,,0000,0000,0000,,RUANG KOMITE DISIPLIN
Dialogue: 0,0:12:04.78,0:12:05.99,tanda,,0000,0000,0000,,HIHI
Dialogue: 0,0:13:16.23,0:13:18.08,tanda,,0000,0000,0000,,"BAHAN ORGANIK YANG KUBESARKAN"
Dialogue: 0,0:13:47.30,0:13:47.88,tanda,,0000,0000,0000,,AMARAH
Dialogue: 0,0:13:47.88,0:13:59.89,tanda,,0000,0000,0000,,"AMARAH"
Dialogue: 0,0:17:59.80,0:18:02.31,tanda,,0000,0000,0000,,APA KAU CEMBURU?
Dialogue: 0,0:19:37.90,0:19:39.53,tanda,,0000,0000,0000,,- MAAF, YOUJI.\N- ADA APA, MASURAO?
Dialogue: 0,0:19:39.54,0:19:40.53,tanda,,0000,0000,0000,,"SUDAH KUBILANG NADEKO. NA-DE-KO!"
Dialogue: 0,0:19:41.07,0:19:42.49,tanda,,0000,0000,0000,,"AKU KEBANYAKAN MASAK SEMUR"
Dialogue: 0,0:19:43.20,0:19:44.57,tanda,,0000,0000,0000,,"YOUJI SUKA, 'KAN?"
Dialogue: 0,0:19:45.21,0:19:46.77,tanda,,0000,0000,0000,,"NANTI MAMPIR KE RUMAHKU UNTUK BAWA"
Dialogue: 0,0:00:10.59,0:00:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:00:14.24,0:00:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kanan baik-baik saja\Ndi dunia manusia?
Dialogue: 0,0:00:17.72,0:00:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sakit perut\Nkarena salah makan, tidak, ya?
Dialogue: 0,0:00:31.44,0:00:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa cemas.
Dialogue: 0,0:00:32.67,0:00:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak bisa berhenti makan banyak!
Dialogue: 0,0:00:36.32,0:00:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Tuan Besar sedang kerepotan.
Dialogue: 0,0:00:39.24,0:00:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Ami. Tolong lakukan sesuatu!
Dialogue: 0,0:00:42.91,0:00:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:00:44.43,0:00:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami sang pelayan siap mengabdikan dirinya
Dialogue: 0,0:00:47.41,0:00:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepada Tuan Putri.
Dialogue: 0,0:02:33.57,0:02:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan sang Iblis Gourmet\Nmemulai harinya pagi sekali.
Dialogue: 0,0:02:41.09,0:02:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya demi memastikan\Nia dapat menyusup
Dialogue: 0,0:02:44.31,0:02:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke dalam keluarga manusia\Ndan beraktivitas tanpa dicurigai siapa pun.
Dialogue: 0,0:02:53.02,0:02:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih cepat kalau lihat langsung.
Dialogue: 0,0:02:58.19,0:02:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperkenalkan.
Dialogue: 0,0:03:03.11,0:03:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Papa, Mama.
Dialogue: 0,0:03:06.09,0:03:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi!
Dialogue: 0,0:03:07.42,0:03:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Kakak.
Dialogue: 0,0:03:09.82,0:03:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Kanan.
Dialogue: 0,0:03:12.27,0:03:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka adalah keluarga palsunya di dunia manusia.
Dialogue: 0,0:03:17.91,0:03:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah putri sulung keluarga ini.
Dialogue: 0,0:03:22.32,0:03:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hipnotis mereka menggunakan sihir
Dialogue: 0,0:03:24.02,0:03:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar percaya bahwa dirinya\Nadalah putri sulung mereka.
Dialogue: 0,0:03:30.08,0:03:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat jalan, Kanan.
Dialogue: 0,0:03:33.26,0:03:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa akan kerja dengan semangat hari ini!
Dialogue: 0,0:03:36.45,0:03:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita main saat Kakak pulang nanti, ya.
Dialogue: 0,0:03:38.61,0:03:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Shoutaro.
Dialogue: 0,0:03:45.73,0:03:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama, kau cantik sekali hari ini.
Dialogue: 0,0:03:48.76,0:03:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun. Terima kasih, Kanan.
Dialogue: 0,0:03:51.85,0:03:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi mereka,\NKanan terlihat seperti "putri yang ideal".
Dialogue: 0,0:04:00.01,0:04:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka keluarga yang baik.
Dialogue: 0,0:04:02.26,0:04:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang iblis pasti memanfaatkan\Nkeluarga seperti mereka, 'kan?
Dialogue: 0,0:04:07.34,0:04:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:04:08.53,0:04:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kita punya anak perempuan?
Dialogue: 0,0:04:11.47,0:04:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan aku melahirkannya?
Dialogue: 0,0:04:13.56,0:04:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak itu siapa, ya?
Dialogue: 0,0:04:17.68,0:04:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah putri sulung keluarga ini.
Dialogue: 0,0:04:21.56,0:04:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kalian lihat,
Dialogue: 0,0:04:23.20,0:04:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hipnotisnya harus diperbarui secara berkala.
Dialogue: 0,0:04:26.77,0:04:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, hari ini pun,
Dialogue: 0,0:04:28.52,0:04:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gadis itu berangkat ke area makannya.
Dialogue: 0,0:04:37.51,0:04:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mempermainkan manusia sungguh menyenangkan!
Dialogue: 0,0:04:41.72,0:04:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini,\Naku sering kecurian makhluk inferior, sih...
Dialogue: 0,0:04:45.86,0:04:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru yang namanya iblis!
Dialogue: 0,0:04:48.45,0:04:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:04:49.98,0:04:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bagimu, manusia itu apa?"
Dialogue: 0,0:04:53.21,0:04:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah manusia bagiku?
Dialogue: 0,0:04:56.18,0:04:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaan bagus.
Dialogue: 0,0:04:57.65,0:04:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya makanan, tidak kurang dan tidak...
Dialogue: 0,0:04:59.56,0:05:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Senior berbicara sendiri?
Dialogue: 0,0:05:02.22,0:05:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang ingin pura-pura\Ntampil di film dokumenter, tahu.
Dialogue: 0,0:05:08.06,0:05:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kenapa Kyougi ada di sini?!
Dialogue: 0,0:05:11.06,0:05:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bingung?
Dialogue: 0,0:05:12.38,0:05:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kan pacarnya Senior,
Dialogue: 0,0:05:14.63,0:05:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi ingin berangkat ke sekolah sama-sama.
Dialogue: 0,0:05:16.93,0:05:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pacar...?
Dialogue: 0,0:05:18.55,0:05:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hentikan, kesannya seperti\Nkita kaum bahagia saja...
Dialogue: 0,0:05:21.76,0:05:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, maksudku bukan itu!
Dialogue: 0,0:05:23.67,0:05:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tahu tempatku menyusup...
Dialogue: 0,0:05:25.58,0:05:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ralat, kenapa kau tahu rumahku?
Dialogue: 0,0:05:29.30,0:05:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat tanya ke wali kelas Senior,\Ndia langsung kasih tahu.
Dialogue: 0,0:05:32.74,0:05:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau nembak...?\NKamu mau nyatakan cinta, ya?
Dialogue: 0,0:05:36.39,0:05:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, ini rahasia, ya!
Dialogue: 0,0:05:38.39,0:05:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membocorkan informasi pribadiku?
Dialogue: 0,0:05:42.06,0:05:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Senior.
Dialogue: 0,0:05:43.39,0:05:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kita berangkat...\N- Boleh.
Dialogue: 0,0:05:45.20,0:05:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berangkat bersama.
Dialogue: 0,0:05:46.49,0:05:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada syaratnya.
Dialogue: 0,0:05:47.88,0:05:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus bisa menyusulku!
Dialogue: 0,0:05:50.40,0:05:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:05:51.84,0:05:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda. Mana mungkin\Naku mau berangkat bersama Kyougi.
Dialogue: 0,0:05:54.91,0:05:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa malu kalau sampai ada yang lihat!
Dialogue: 0,0:05:58.14,0:05:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, Kyougi.
Dialogue: 0,0:05:59.88,0:06:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini iblis.
Dialogue: 0,0:06:01.51,0:06:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potensi tubuh fisiknya tak bisa dibandingkan...
Dialogue: 0,0:06:05.96,0:06:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hore!\N- dengan... manusia...
Dialogue: 0,0:06:12.67,0:06:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior sudah capek, ya?
Dialogue: 0,0:06:15.36,0:06:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka.
Dialogue: 0,0:06:17.08,0:06:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan spek lainnya,\Nstaminaku yang paling rendah.
Dialogue: 0,0:06:21.19,0:06:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak... capek.
Dialogue: 0,0:06:24.10,0:06:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior baik-baik saja?
Dialogue: 0,0:06:25.92,0:06:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlihat lemas sekali, lo.
Dialogue: 0,0:06:28.51,0:06:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat.\NKalau dibiarkan saja, martabatku...
Dialogue: 0,0:06:34.78,0:06:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya orang sering bilang?
Dialogue: 0,0:06:36.61,0:06:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita yang baik\Nadalah wanita yang akan berada
Dialogue: 0,0:06:41.80,0:06:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiga langkah di belakang pasangannya\Nbahkan saat dia lebih unggul!
Dialogue: 0,0:06:48.26,0:06:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:06:50.18,0:06:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NAku terlihat sangat anggun, 'kan?
Dialogue: 0,0:06:53.31,0:06:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kalimat yang sering dipakai\Nuntuk menggambarkan istri, 'kan?
Dialogue: 0,0:06:56.97,0:06:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istri?!
Dialogue: 0,0:06:58.63,0:07:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Senior tidak tahu?
Dialogue: 0,0:07:00.41,0:07:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Aku sudah tahu, kok!
Dialogue: 0,0:07:03.04,0:07:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Sialan!
Dialogue: 0,0:07:08.41,0:07:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum? Soalnya Senior kelihatan capek.
Dialogue: 0,0:07:12.25,0:07:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph!
Dialogue: 0,0:07:13.16,0:07:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau minum, sisakan untukku, ya.
Dialogue: 0,0:07:16.29,0:07:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya.
Dialogue: 0,0:07:19.42,0:07:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Sisakan untuknya?
Dialogue: 0,0:07:21.90,0:07:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya itu ci-ciuman tidak lang...?!
Dialogue: 0,0:07:36.09,0:07:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan minta macam-macam, ya.\NDasar makhluk inferior!
Dialogue: 0,0:07:50.35,0:07:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya di sekitar sini.
Dialogue: 0,0:07:52.13,0:07:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu dekat!
Dialogue: 0,0:07:53.58,0:07:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjauh sedikit!
Dialogue: 0,0:07:55.93,0:07:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jaga jarak, untuk apa\Nkita berangkat sekolah bersama?
Dialogue: 0,0:07:59.17,0:08:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang namanya ruang pribadi, tahu.
Dialogue: 0,0:08:01.58,0:08:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona!
Dialogue: 0,0:08:08.53,0:08:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai!
Dialogue: 0,0:08:23.59,0:08:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau datang ke sini, Pelayan Badung?!
Dialogue: 0,0:08:28.11,0:08:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok masih tanya?
Dialogue: 0,0:08:30.03,0:08:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja untuk melayani Nona.
Dialogue: 0,0:08:34.48,0:08:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembohong!
Dialogue: 0,0:08:35.95,0:08:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Senior. Dia siapa?
Dialogue: 0,0:08:39.02,0:08:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kyougi?!
Dialogue: 0,0:08:41.37,0:08:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Itu... Begini...
Dialogue: 0,0:08:45.64,0:08:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Ami, pelayan keluargaku.
Dialogue: 0,0:08:47.54,0:08:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pelayan khusus\Nyang mengasuhku saat kecil dulu.
Dialogue: 0,0:08:51.22,0:08:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan khusus?
Dialogue: 0,0:08:52.50,0:08:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti cari-cari alasan di depan Papa\Nsupaya bisa main ke sini, 'kan?
Dialogue: 0,0:08:56.25,0:09:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona ini, ya. Aku dan Nona teman sejak kecil!
Dialogue: 0,0:09:00.14,0:09:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan kita melebihi pelayan dan majikan.
Dialogue: 0,0:09:02.86,0:09:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang ke sini karena mencemaskanmu.
Dialogue: 0,0:09:06.41,0:09:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang tidak waras yang datang ke sini.
Dialogue: 0,0:09:08.95,0:09:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku paling tidak ingin\Nmembiarkannya bertemu Kyougi.
Dialogue: 0,0:09:13.73,0:09:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Ami adalah Succubus yang tidak keberatan
Dialogue: 0,0:09:16.63,0:09:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan perselingkuhan, perzinaan,\Natau hubungan gelap!
Dialogue: 0,0:09:21.28,0:09:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti Kyougi akan memberikan tubuhnya
Dialogue: 0,0:09:23.80,0:09:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mohon bantuannya!\N- dengan senang hati!
Dialogue: 0,0:09:25.88,0:09:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi, pelayan itu berbahaya!
Dialogue: 0,0:09:28.76,0:09:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, kau jangan dekat-dekat dia!
Dialogue: 0,0:09:30.77,0:09:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, siapa manusia ini?\NKenalkan padaku, dong.
Dialogue: 0,0:09:37.79,0:09:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan lelaki ini?!
Dialogue: 0,0:09:39.46,0:09:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vitalitas dan jiwanya berkualitas tinggi!
Dialogue: 0,0:09:45.48,0:09:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cicip dia.
Dialogue: 0,0:09:48.51,0:09:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:09:50.01,0:09:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak boleh
Dialogue: 0,0:09:51.48,0:09:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyentuh Kyougi!
Dialogue: 0,0:09:53.80,0:09:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:09:55.51,0:09:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cicip sedikit saja, kok.
Dialogue: 0,0:09:57.53,0:09:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:09:59.29,0:10:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Kyougi adalah...
Dialogue: 0,0:10:01.36,0:10:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adalah?
Dialogue: 0,0:10:03.26,0:10:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah
Dialogue: 0,0:10:05.34,0:10:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke-kekasihku.
Dialogue: 0,0:10:07.81,0:10:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekasih?!
Dialogue: 0,0:10:09.47,0:10:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, apa maksudnya ini?!
Dialogue: 0,0:10:12.64,0:10:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Wajahmu merah padam.
Dialogue: 0,0:10:14.42,0:10:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, ini serius?!
Dialogue: 0,0:10:17.29,0:10:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona yang gadis abadi ini punya pacar?
Dialogue: 0,0:10:19.54,0:10:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacar manusia pula?
Dialogue: 0,0:10:20.43,0:10:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berita besar, lo!
Dialogue: 0,0:10:23.08,0:10:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian sudah lakukan sampai mana?
Dialogue: 0,0:10:25.32,0:10:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah lakukan semua dan segalanya?
Dialogue: 0,0:10:28.99,0:10:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat ceritakan padaku!
Dialogue: 0,0:10:31.89,0:10:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ka-kami pulang bersama, lalu...
Dialogue: 0,0:10:36.73,0:10:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan kroket di taman.
Dialogue: 0,0:10:38.93,0:10:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekanakan banget.
Dialogue: 0,0:10:40.79,0:10:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Selain itu, aku memanggil nama kecilnya.
Dialogue: 0,0:10:45.38,0:10:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan asmara bocah TK, ya?
Dialogue: 0,0:10:47.50,0:10:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah hidup ribuan tahun, kenapa masih kikuk?
Dialogue: 0,0:10:50.42,0:10:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria mana pun akan takluk\Nsaat menyentuh payudaramu!
Dialogue: 0,0:10:53.56,0:10:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa dapatkan siapa saja, lo!
Dialogue: 0,0:10:57.21,0:10:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali tidak tulus!
Dialogue: 0,0:10:58.84,0:10:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, iblis.
Dialogue: 0,0:11:01.16,0:11:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau sibuk menunda-nunda,\Nnanti Ami yang makan, lo.
Dialogue: 0,0:11:06.38,0:11:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menolak.
Dialogue: 0,0:11:07.47,0:11:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walah?
Dialogue: 0,0:11:08.79,0:11:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena pacarku
Dialogue: 0,0:11:13.80,0:11:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya Senior Kanan.
Dialogue: 0,0:11:17.28,0:11:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah pamer kemesraan?!
Dialogue: 0,0:11:19.19,0:11:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan pamer kemesraan,\Ntapi hanya menyampaikan fakta.
Dialogue: 0,0:11:23.12,0:11:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membantah!
Dialogue: 0,0:11:30.82,0:11:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, Ami tidak keberatan\Nkalau kalian mau threesome.
Dialogue: 0,0:11:34.45,0:11:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja!
Dialogue: 0,0:11:35.62,0:11:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salahnya punya banyak pacar?
Dialogue: 0,0:11:39.44,0:11:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajak Ami juga, dong.
Dialogue: 0,0:11:41.09,0:11:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang tidak boleh!
Dialogue: 0,0:11:43.67,0:11:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Ami takut banget.
Dialogue: 0,0:11:45.87,0:11:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku, Manusia.
Dialogue: 0,0:11:48.82,0:11:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, aku masuk masa-masa populer, ya?
Dialogue: 0,0:11:53.14,0:11:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malah malu-malu.
Dialogue: 0,0:11:55.51,0:11:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar makhluk inferior!
Dialogue: 0,0:12:07.07,0:12:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:08.34,0:12:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?!
Dialogue: 0,0:12:12.50,0:12:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hewan-hewan ternakku terkapar di lantai.
Dialogue: 0,0:12:14.85,0:12:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, wajah mereka terlihat bahagia.
Dialogue: 0,0:12:19.98,0:12:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka berasal dari\Nruang persiapan sains.
Dialogue: 0,0:12:23.83,0:12:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau sudah lihat pelayan kulit gelap itu?
Dialogue: 0,0:12:26.22,0:12:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, lihat. Dia seksi banget, ya.
Dialogue: 0,0:12:29.02,0:12:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan... Tidak, pasti dia.
Dialogue: 0,0:12:34.40,0:12:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami!
Dialogue: 0,0:12:35.67,0:12:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takakiyo?!
Dialogue: 0,0:12:37.70,0:12:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Yurino, apa yang kau lakukan?!
Dialogue: 0,0:12:39.98,0:12:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak. Kau salah paham, aku... Aku...
Dialogue: 0,0:12:44.60,0:12:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada siswa yang melihatku sedang bercinta!
Dialogue: 0,0:12:50.72,0:12:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Nona.
Dialogue: 0,0:12:53.27,0:12:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semakin hari semakin cantik saja, deh.
Dialogue: 0,0:12:55.80,0:12:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau abaikan kejadian tadi?
Dialogue: 0,0:12:57.81,0:12:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau.
Dialogue: 0,0:12:59.25,0:13:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu apa yang terkapar di luar sana?
Dialogue: 0,0:13:03.62,0:13:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia?
Dialogue: 0,0:13:04.22,0:13:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu!
Dialogue: 0,0:13:05.39,0:13:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, sih, tapi bukan itu maksudku!
Dialogue: 0,0:13:07.75,0:13:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademi ini peternakan jiwaku, tahu!
Dialogue: 0,0:13:11.38,0:13:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berusaha supaya mereka
Dialogue: 0,0:13:12.40,0:13:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hus, hus.\N- tidak ditempeli hama,
Dialogue: 0,0:13:13.45,0:13:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memperhatikan kesehatan mereka,
Dialogue: 0,0:13:15.39,0:13:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kubesarkan dalam keadaan suci dan murni.
Dialogue: 0,0:13:18.33,0:13:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau malah mengisap vitalitas mereka\Ndan menodai jiwanya!
Dialogue: 0,0:13:22.03,0:13:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sendiri belum menyentuh mereka!
Dialogue: 0,0:13:26.40,0:13:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu salah Nona yang buang-buang waktu.
Dialogue: 0,0:13:29.64,0:13:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:13:30.56,0:13:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal kau tahu saja, aku berbeda denganmu\Nyang pemakan segala.
Dialogue: 0,0:13:34.37,0:13:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat banget main tuduh!
Dialogue: 0,0:13:36.41,0:13:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami bukan pemakan segala, tahu.
Dialogue: 0,0:13:39.20,0:13:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mendekati orang\Nyang membuatku terpesona.
Dialogue: 0,0:13:44.12,0:13:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar? Aku mau tanya.
Dialogue: 0,0:13:47.88,0:13:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek ini?
Dialogue: 0,0:13:49.40,0:13:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka.
Dialogue: 0,0:13:51.22,0:13:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswi ini?
Dialogue: 0,0:13:52.75,0:13:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut banget.
Dialogue: 0,0:13:54.69,0:13:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau yang gemuk ini?
Dialogue: 0,0:13:56.02,0:13:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka.
Dialogue: 0,0:13:57.24,0:13:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Preman ini?
Dialogue: 0,0:13:58.82,0:13:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganteng.
Dialogue: 0,0:14:03.14,0:14:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya pemakan segala, tahu!
Dialogue: 0,0:14:06.45,0:14:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya mereka semua memesona.
Dialogue: 0,0:14:08.88,0:14:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih saja beralasan!
Dialogue: 0,0:14:10.77,0:14:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya...
Dialogue: 0,0:14:12.80,0:14:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kakek baik hati\Nyang menyapaku saat tersesat
Dialogue: 0,0:14:15.93,0:14:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyajikan teh untukku.
Dialogue: 0,0:14:19.18,0:14:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswi itu membagikan kukis\Nyang dibuatnya saat kelas memasak.
Dialogue: 0,0:14:23.00,0:14:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya enak banget.
Dialogue: 0,0:14:25.76,0:14:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang gemuk itu tubuhnya empuk\Ndan nyaman saat disentuh.
Dialogue: 0,0:14:30.87,0:14:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Preman itu paham soal manga shojo,
Dialogue: 0,0:14:33.27,0:14:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merekomendasikan manga\Nyang bisa buat deg-degan.
Dialogue: 0,0:14:36.66,0:14:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua manusia\Nyang amat sangat memesona.
Dialogue: 0,0:14:42.58,0:14:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis ini selalu melihat sisi baik orang lain.
Dialogue: 0,0:14:45.76,0:14:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya,\Nhanya melihat sisi baik orang lain.
Dialogue: 0,0:14:49.62,0:14:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami punya kepribadian yang serampangan,
Dialogue: 0,0:14:51.84,0:14:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi entah kenapa disukai banyak orang.
Dialogue: 0,0:14:55.67,0:14:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya karena sifat ini.
Dialogue: 0,0:14:58.37,0:15:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak cemburu.
Dialogue: 0,0:15:01.69,0:15:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap saja!
Dialogue: 0,0:15:03.50,0:15:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga yang buat pemandangan bak di neraka ini.
Dialogue: 0,0:15:09.10,0:15:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Ami.\NAku salah paham tentangmu.
Dialogue: 0,0:15:12.33,0:15:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga punya prinsipmu sendiri, ya.
Dialogue: 0,0:15:16.70,0:15:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, jangan bilang begitu.
Dialogue: 0,0:15:18.38,0:15:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya pelayan Nona "Kanan sang Gourmet",\Ntentu harus punya selera.
Dialogue: 0,0:15:23.03,0:15:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar. Tapi jangan menggoda\Nsiswa sekolah ini lagi, ya.
Dialogue: 0,0:15:26.95,0:15:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ribet menghapus ingatan mereka.
Dialogue: 0,0:15:28.88,0:15:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:30.01,0:15:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku goda yang bukan siswa saja.
Dialogue: 0,0:15:32.19,0:15:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi.
Dialogue: 0,0:15:33.99,0:15:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berbicara tentang itu...
Dialogue: 0,0:15:36.71,0:15:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:37.86,0:15:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut Ami...
Dialogue: 0,0:15:39.13,0:15:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:15:40.46,0:15:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kyougi juga terlihat memesona?
Dialogue: 0,0:15:43.95,0:15:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi?
Dialogue: 0,0:15:45.21,0:15:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, pacar Nona.
Dialogue: 0,0:15:53.74,0:15:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rahasia.
Dialogue: 0,0:15:55.28,0:15:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa?!
Dialogue: 0,0:15:56.64,0:15:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak mau jawab?
Dialogue: 0,0:15:59.90,0:16:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, Nona cemburu, ya?
Dialogue: 0,0:16:03.16,0:16:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok. Aku tidak cemburu!
Dialogue: 0,0:16:14.15,0:16:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:16:15.59,0:16:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau Kyougi jatuh ke pelukan Ami
Dialogue: 0,0:16:17.97,0:16:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku tidak memperhatikan?
Dialogue: 0,0:16:22.37,0:16:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bermanjalah di dada Ami.
Dialogue: 0,0:16:25.13,0:16:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:16:26.72,0:16:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boing, boing.
Dialogue: 0,0:16:32.03,0:16:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:16:38.01,0:16:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik, Kyougi.
Dialogue: 0,0:16:40.08,0:16:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan siswa yang melanggar aturan lolos.
Dialogue: 0,0:16:43.90,0:16:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.\NAku senang bisa membantu Senior!
Dialogue: 0,0:16:48.47,0:16:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku ada di sampingnya,\Naku tak perlu mencemaskan soal Ami.
Dialogue: 0,0:16:53.78,0:16:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga kesempatan bagus untuk\Nberikan pelatihan hewan ternak
Dialogue: 0,0:16:57.54,0:17:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semua aman!\N- agar dia paham siapa bosnya.
Dialogue: 0,0:17:01.79,0:17:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang "aku masuk masa-masa populer, ya?"
Dialogue: 0,0:17:04.01,0:17:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau itu hewan ternakku,\Njangan banyak lagak, deh.
Dialogue: 0,0:17:07.22,0:17:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau makhluk inferior!
Dialogue: 0,0:17:11.14,0:17:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, aku tiba-tiba merinding.
Dialogue: 0,0:17:13.04,0:17:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masuk angin, ya?
Dialogue: 0,0:17:22.40,0:17:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:17:25.86,0:17:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:31.29,0:17:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubantu. Mau dibawa ke mana?
Dialogue: 0,0:17:33.67,0:17:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ke ruang guru... Berdua...
Dialogue: 0,0:17:37.31,0:17:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, maaf mengganggu.
Dialogue: 0,0:17:39.69,0:17:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Takakiyo!
Dialogue: 0,0:17:41.05,0:17:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang patroli bangunan sekolah.
Dialogue: 0,0:17:44.45,0:17:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa pergi sendiri, 'kan?
Dialogue: 0,0:17:46.77,0:17:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, dengan senang hati!
Dialogue: 0,0:17:53.12,0:17:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyougi.
Dialogue: 0,0:17:54.71,0:17:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:17:56.14,0:17:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau... populer, ya?
Dialogue: 0,0:17:58.32,0:17:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:18:03.06,0:18:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salah paham, ya.
Dialogue: 0,0:18:05.03,0:18:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan cemburu, kok.
Dialogue: 0,0:18:13.96,0:18:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlambat!
Dialogue: 0,0:18:18.67,0:18:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf...
Dialogue: 0,0:18:21.37,0:18:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku juga tidak melihat ke depan.
Dialogue: 0,0:18:25.57,0:18:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Deg...
Dialogue: 0,0:18:27.34,0:18:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kyougi. Ikut aku!
Dialogue: 0,0:18:29.14,0:18:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke sini. Ikut aku!
Dialogue: 0,0:18:32.05,0:18:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terpeleset!
Dialogue: 0,0:18:36.01,0:18:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:18:37.23,0:18:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... Siapa namamu...?
Dialogue: 0,0:18:39.25,0:18:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam di sana, Kyougi. Diam di sana!
Dialogue: 0,0:18:45.05,0:18:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kamu yang di sana.
Dialogue: 0,0:18:46.24,0:18:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:18:47.50,0:18:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada naruto di kepalamu, lo.
Dialogue: 0,0:18:50.06,0:18:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan naruto, tapi jepit rambut!
Dialogue: 0,0:18:54.32,0:18:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau katakan itu pada Daifugoin Verika.
Dialogue: 0,0:18:57.64,0:18:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh pria yang menarik.
Dialogue: 0,0:18:59.42,0:19:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?!
Dialogue: 0,0:19:01.13,0:19:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan masukkan unsur komedi romansa!
Dialogue: 0,0:19:03.38,0:19:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan, sih? Punya bakat lahir menggoda, ya?
Dialogue: 0,0:19:05.55,0:19:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya tubuh yang terlahir\Nuntuk membentuk harem, ya?!
Dialogue: 0,0:19:07.73,0:19:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar genit, dari tadi menggoda kiri-kanan.
Dialogue: 0,0:19:10.68,0:19:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku harus tegaskan sekali lagi padamu
Dialogue: 0,0:19:13.38,0:19:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal siapa kau untukku?!
Dialogue: 0,0:19:15.81,0:19:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pacarmu.
Dialogue: 0,0:19:16.67,0:19:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih ingat!
Dialogue: 0,0:19:20.75,0:19:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kalau masih ingat.
Dialogue: 0,0:19:22.95,0:19:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesanku padamu...
Dialogue: 0,0:19:23.97,0:19:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehem.
Dialogue: 0,0:19:24.82,0:19:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya didikanku bekerja dengan baik.
Dialogue: 0,0:19:30.56,0:19:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dari Masurao.
Dialogue: 0,0:19:32.54,0:19:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:19:33.95,0:19:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman sejak kecil yang sekelas denganku.
Dialogue: 0,0:19:36.18,0:19:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman sejak kecil?
Dialogue: 0,0:19:39.54,0:19:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeko.
Dialogue: 0,0:19:41.07,0:19:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semur daging?
Dialogue: 0,0:19:43.20,0:19:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil pakai nama kecil?
Dialogue: 0,0:19:45.21,0:19:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mampir ke rumah?
Dialogue: 0,0:19:47.21,0:19:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:19:49.00,0:19:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masurao memang peka banget, ya.
Dialogue: 0,0:19:52.80,0:19:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mau dikasih makan olehnya!
Dialogue: 0,0:19:55.82,0:20:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar makhluk inferior!
Dialogue: 0,0:20:08.26,0:20:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:20:09.64,0:20:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau marah?
Dialogue: 0,0:20:12.46,0:20:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:20:28.97,0:20:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:20:31.13,0:20:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengikat kontrak denganku.
Dialogue: 0,0:20:35.40,0:20:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang melirik perempuan lain.
Dialogue: 0,0:20:39.02,0:20:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham?
Dialogue: 0,0:20:46.50,0:20:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut...
Dialogue: 0,0:20:48.77,0:20:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut!
Dialogue: 0,0:20:50.18,0:20:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior yang cemburu imut banget!
Dialogue: 0,0:20:52.55,0:20:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Aku tidak cemburu, kok!
Dialogue: 0,0:20:55.46,0:20:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut banget.
Dialogue: 0,0:21:02.29,0:21:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa-apaan ini?
Dialogue: 0,0:21:04.29,0:21:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku rasanya tidak keruan.
Dialogue: 0,0:21:06.70,0:21:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sihir atau apa?
Dialogue: 0,0:21:11.38,0:21:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kau tidak bisa... merayuku dengan...
Dialogue: 0,0:21:17.17,0:21:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang, sayang. Anak baik.
Dialogue: 0,0:21:20.22,0:21:23.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amarahku tak bisa diredakan dengan...
Dialogue: 0,0:21:27.10,0:21:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar makhluk inferior...!
Dialogue: 0,0:21:34.86,0:21:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka Nona akan menaksir manusia.
Dialogue: 0,0:21:38.68,0:21:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan terjadi jika Tuan Besar tahu?
Dialogue: 0,0:21:43.33,0:21:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:21:45.84,0:21:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melihat wajah Nona,
Dialogue: 0,0:21:47.98,0:21:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}entah kenapa,\Naku jadi ingin mendukungnya.
Dialogue: 0,0:21:53.80,0:21:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:21:55.86,0:22:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ami juga akan bersenang-senang\Ndengan cara Ami sendiri.
Dialogue: 0,0:22:04.40,0:22:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senangnya.
