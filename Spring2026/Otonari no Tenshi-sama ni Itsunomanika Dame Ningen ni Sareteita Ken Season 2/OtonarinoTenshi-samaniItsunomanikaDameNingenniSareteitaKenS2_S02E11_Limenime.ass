Dialogue: 0,0:01:51.05,0:01:55.26,sign,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:03:10.96,0:03:15.22,sign,,0000,0000,0000,,#11 KERJA SAMBILAN PERTAMA
Dialogue: 0,0:09:47.98,0:09:50.49,sign,,0000,0000,0000,,TUTUP
Dialogue: 0,0:18:38.99,0:18:42.35,sign,,0000,0000,0000,,BUKA
Dialogue: 0,0:23:34.93,0:23:41.48,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:02.88,0:00:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja sambilan?
Dialogue: 0,0:00:05.24,0:00:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, di tempat kerjanya Kido.
Dialogue: 0,0:00:08.23,0:00:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya itu kedai kopi saudaranya.
Dialogue: 0,0:00:11.28,0:00:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tiba-tiba sekali?
Dialogue: 0,0:00:14.20,0:00:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun depan kita persiapan ujian, lo.
Dialogue: 0,0:00:16.84,0:00:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, soalnya aku ingin beli sesuatu.
Dialogue: 0,0:00:22.72,0:00:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkan, Kido.
Dialogue: 0,0:00:24.53,0:00:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:00:25.92,0:00:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa kamu\Nmendadak mau kerja sambilan?
Dialogue: 0,0:00:30.60,0:00:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasiakan ini terutama dari Mahiru, ya?
Dialogue: 0,0:00:34.23,0:00:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, kamu mau\Nmemberi kado ke Shiina, ya?
Dialogue: 0,0:00:38.59,0:00:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kado Natal?
Dialogue: 0,0:00:40.63,0:00:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan Natal, tapi untuk tahun depan.
Dialogue: 0,0:00:46.23,0:00:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau memberinya cincin.
Dialogue: 0,0:00:52.29,0:00:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin beli sesuatu?
Dialogue: 0,0:00:53.88,0:00:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:55.08,0:00:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sekalian buat mencari pengalaman.
Dialogue: 0,0:00:59.32,0:01:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tetap belajar, kok.
Dialogue: 0,0:01:00.92,0:01:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lagi pula aku tidak berhak melarang.
Dialogue: 0,0:01:05.29,0:01:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang seyakin itu,\Naku cuma bisa mendukungmu.
Dialogue: 0,0:01:11.35,0:01:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski akan sedih kalau kita\Njadi jarang bersama.
Dialogue: 0,0:01:16.14,0:01:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:01:17.64,0:01:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, aku akan terus\Nbersamamu tiap libur kerja.
Dialogue: 0,0:01:21.89,0:01:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu saja mengutamakanku.
Dialogue: 0,0:01:25.80,0:01:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utamakanlah dirimu sendiri.
Dialogue: 0,0:01:28.36,0:01:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru kamu jadi yang utama
Dialogue: 0,0:01:31.35,0:01:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku mengutamakan perasaanku.
Dialogue: 0,0:03:12.52,0:03:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau main sama Chitose hari ini?
Dialogue: 0,0:03:15.22,0:03:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku akan pulang telat.
Dialogue: 0,0:03:18.35,0:03:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi seharusnya aman\Nkarena Shihoko juga ikut.
Dialogue: 0,0:03:21.72,0:03:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok Ibu ikut?
Dialogue: 0,0:03:23.39,0:03:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shihoko bilang ingin bicara dengan Chitose.
Dialogue: 0,0:03:26.77,0:03:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rasa dia akan cerita yang aneh-aneh.
Dialogue: 0,0:03:31.19,0:03:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:03:32.65,0:03:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu Ibu, mungkin saja.
Dialogue: 0,0:03:35.29,0:03:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hentikan dia kalau itu terjadi.
Dialogue: 0,0:03:37.81,0:03:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:03:39.85,0:03:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, sini.
Dialogue: 0,0:03:41.87,0:03:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:03:43.01,0:03:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat.
Dialogue: 0,0:03:47.44,0:03:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:03:49.09,0:03:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:03:50.81,0:03:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah melakukannya?
Dialogue: 0,0:03:52.65,0:03:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:03:55.09,0:03:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan keras-keras!
Dialogue: 0,0:03:57.39,0:04:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh siapa kamu tanya begitu!
Dialogue: 0,0:04:00.09,0:04:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, tingkah Shiina\Ntidak seperti biasanya.
Dialogue: 0,0:04:05.16,0:04:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura kalian berdua terasa berbeda.
Dialogue: 0,0:04:08.41,0:04:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama saja, kok.
Dialogue: 0,0:04:10.09,0:04:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendapatmu tidak objektif.
Dialogue: 0,0:04:12.23,0:04:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya tidak seperti\Nyang kamu bayangkan.
Dialogue: 0,0:04:15.45,0:04:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:04:17.00,0:04:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya tidak sampai tahap akhir.
Dialogue: 0,0:04:19.45,0:04:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, jangan malu-malu.
Dialogue: 0,0:04:22.24,0:04:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula kami belum akan melakukannya.
Dialogue: 0,0:04:25.13,0:04:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah janji pada Mahiru.
Dialogue: 0,0:04:27.00,0:04:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji?
Dialogue: 0,0:04:29.27,0:04:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bisa bertanggung jawab dulu.
Dialogue: 0,0:04:32.43,0:04:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa tanggung jawab seumur hidup,\Naku memintanya menunggu.
Dialogue: 0,0:04:36.88,0:04:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah karena sifatmu
Dialogue: 0,0:04:39.47,0:04:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau karena cinta berat.
Dialogue: 0,0:04:41.23,0:04:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel.
Dialogue: 0,0:04:42.51,0:04:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya, tanteku sudah mengiyakan\Nsoal kerja sambilannya.
Dialogue: 0,0:04:47.91,0:04:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabari kalau kamu sudah siap wawancara.
Dialogue: 0,0:04:50.77,0:04:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, baiklah.
Dialogue: 0,0:04:52.49,0:04:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkanmu.
Dialogue: 0,0:04:54.60,0:04:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, itulah gunanya teman.
Dialogue: 0,0:04:58.47,0:05:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tante juga senang aku mengandalkannya.
Dialogue: 0,0:05:01.59,0:05:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, sampai nanti.
Dialogue: 0,0:05:04.45,0:05:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:05.75,0:05:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah bersiap menata\Nmasa depan bersama Shiina?
Dialogue: 0,0:05:09.54,0:05:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku bilang\Ningin membiayai pernikahannya.
Dialogue: 0,0:05:13.44,0:05:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal aku yang beli cincin.
Dialogue: 0,0:05:18.42,0:05:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ini keputusanku.
Dialogue: 0,0:05:20.83,0:05:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang hebat.
Dialogue: 0,0:05:23.17,0:05:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:05:24.80,0:05:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya bilang-bilang dulu padaku, dong.
Dialogue: 0,0:05:30.13,0:05:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali aku akan mengandalkanmu.
Dialogue: 0,0:05:34.04,0:05:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja Ikkun merajuk.
Dialogue: 0,0:05:36.69,0:05:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja kamu ini.
Dialogue: 0,0:05:39.20,0:05:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja Ikkun merajuk\Nkalau orang lain lebih diandalkan.
Dialogue: 0,0:05:44.17,0:05:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya selain Mahirun,\Ndialah yang paling akrab denganmu.
Dialogue: 0,0:05:49.32,0:05:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku merasa bersalah soal itu.
Dialogue: 0,0:05:53.58,0:05:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikkun ingin kamu mengandalkannya.
Dialogue: 0,0:05:57.32,0:05:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kalian bersahabat.
Dialogue: 0,0:05:59.84,0:06:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikkun juga merasa ditolong olehmu,
Dialogue: 0,0:06:03.60,0:06:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya dia ingin balas budi.
Dialogue: 0,0:06:05.97,0:06:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru dia yang sering menolongku.
Dialogue: 0,0:06:09.61,0:06:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena merasa utang budi,\Naku tidak ingin merepotkannya.
Dialogue: 0,0:06:13.73,0:06:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah sisi burukmu.
Dialogue: 0,0:06:17.19,0:06:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja kalau mau minder,
Dialogue: 0,0:06:20.12,0:06:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kamu jadi seolah\Nmenyangkal perasaannya Ikkun.
Dialogue: 0,0:06:23.67,0:06:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menyesal.
Dialogue: 0,0:06:25.49,0:06:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau begitu.
Dialogue: 0,0:06:28.33,0:06:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curhat lagi saja padanya nanti,\Ntentu saja padaku juga.
Dialogue: 0,0:06:32.32,0:06:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu juga marah?
Dialogue: 0,0:06:36.53,0:06:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kita ini sudah berteman\Nselama satu setengah tahun.
Dialogue: 0,0:06:40.64,0:06:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja aku sedih kalau kamu\Ntidak curhat apa-apa.
Dialogue: 0,0:06:44.88,0:06:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji akan lebih peka.
Dialogue: 0,0:06:47.97,0:06:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:06:49.39,0:06:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah, mustahil kamu merahasiakan ini\Ndari Mahirun kalau tidak bilang sama kami.
Dialogue: 0,0:06:56.36,0:06:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bikin kejutan, kan?
Dialogue: 0,0:06:58.19,0:06:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul sekali.
Dialogue: 0,0:06:59.71,0:07:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya bilang-bilang, dong.
Dialogue: 0,0:07:02.65,0:07:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kami juga tahu\Nkamu berniat serius sama Mahirun.
Dialogue: 0,0:07:07.76,0:07:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cintamu pada Mahirun\Nmakin terpampang nyata.
Dialogue: 0,0:07:11.67,0:07:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka\Nkamu akan jadi bucin begini.
Dialogue: 0,0:07:16.33,0:07:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik, ah.
Dialogue: 0,0:07:18.04,0:07:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya inilah keputusanku.
Dialogue: 0,0:07:20.81,0:07:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, eng...\NMohon kerja samanya.
Dialogue: 0,0:07:26.30,0:07:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa diminta pun pasti kulakukan.
Dialogue: 0,0:07:29.37,0:07:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini demi kebahagiaan sahabatku.
Dialogue: 0,0:07:32.56,0:07:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose...
Dialogue: 0,0:07:33.88,0:07:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja cuma Mahirun.
Dialogue: 0,0:07:36.12,0:07:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Poinmu dikurangi karena sungkan.
Dialogue: 0,0:07:40.16,0:07:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:07:42.49,0:07:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda, kok.
Dialogue: 0,0:07:44.68,0:07:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua sahabat berhargaku.
Dialogue: 0,0:07:47.53,0:07:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga berjalan lancar.
Dialogue: 0,0:07:49.29,0:07:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap membantu kapan pun.
Dialogue: 0,0:07:54.73,0:07:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Ayah tidak ikut?
Dialogue: 0,0:07:58.89,0:08:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya itu khusus para wanita.
Dialogue: 0,0:08:02.35,0:08:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada aku, Shirakawa akan sungkan.
Dialogue: 0,0:08:06.01,0:08:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kamu pasti kesepian\Nkalau makan malam sendirian.
Dialogue: 0,0:08:10.55,0:08:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti siapa yang masak?
Dialogue: 0,0:08:12.08,0:08:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bisa masak sendiri, kok.
Dialogue: 0,0:08:14.89,0:08:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, kalau berusaha kamu pasti bisa.
Dialogue: 0,0:08:19.01,0:08:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak pintar.
Dialogue: 0,0:08:21.72,0:08:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu ingin memasak\Nbersama anak sendiri.
Dialogue: 0,0:08:25.68,0:08:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan akhirnya itu terwujud.
Dialogue: 0,0:08:29.04,0:08:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:32.13,0:08:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok belanjaannya banyak banget?
Dialogue: 0,0:08:34.37,0:08:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, kamu juga kami belikan.
Dialogue: 0,0:08:38.44,0:08:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:08:40.08,0:08:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belanja baju buat Mahiru pakai\Ndan beberapa aksesori lucu.
Dialogue: 0,0:08:45.61,0:08:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga harus rela memakai\Nbaju yang Mahiru belikan.
Dialogue: 0,0:08:51.09,0:08:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok jadi rela?
Dialogue: 0,0:08:53.32,0:08:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu beli baju yang aneh?
Dialogue: 0,0:08:54.77,0:08:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, kok.
Dialogue: 0,0:09:00.53,0:09:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu disuruh pakai apa?
Dialogue: 0,0:09:03.68,0:09:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memberitahumu?
Dialogue: 0,0:09:06.36,0:09:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, wahai sahabat\Nyang melupakanku.
Dialogue: 0,0:09:10.59,0:09:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku disuruh...
Dialogue: 0,0:09:14.12,0:09:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai piama berbentuk kucing.
Dialogue: 0,0:09:19.61,0:09:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertawa!
Dialogue: 0,0:09:21.04,0:09:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru juga pakai yang kelinci, tahu!
Dialogue: 0,0:09:24.63,0:09:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti minta fotomu ke Shiina, ah.
Dialogue: 0,0:09:27.20,0:09:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, jangan!
Dialogue: 0,0:09:28.60,0:09:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah minta jangan sampai difoto!
Dialogue: 0,0:09:31.22,0:09:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, pasti bakal menggemaskan.
Dialogue: 0,0:09:35.48,0:09:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal jangan cengar-cengir, sialan!
Dialogue: 0,0:09:38.97,0:09:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang akrab, ya.
Dialogue: 0,0:09:41.08,0:09:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:48.81,0:09:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tokonya?
Dialogue: 0,0:09:50.49,0:09:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasananya damai, kan?
Dialogue: 0,0:09:53.05,0:09:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya pelajar tidak cocok kerja di sini.
Dialogue: 0,0:09:56.27,0:09:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamunya memang\Nkebanyakan orang dewasa, sih.
Dialogue: 0,0:09:59.43,0:10:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mungkin cocok buatmu.
Dialogue: 0,0:10:02.25,0:10:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di tempat kerjaku\Ntamunya rata-rata anak muda.
Dialogue: 0,0:10:06.87,0:10:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina pasti ogah kalau pacarnya\Nbekerja dikelilingi gadis, kan?
Dialogue: 0,0:10:13.19,0:10:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku ingin Sou\Npunya lebih banyak teman dekat.
Dialogue: 0,0:10:18.41,0:10:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayano?
Dialogue: 0,0:10:19.87,0:10:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga kerja di sini?
Dialogue: 0,0:10:22.08,0:10:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, saat kamu bertanya\Nsoal kerja sambilan.
Dialogue: 0,0:10:25.60,0:10:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung kepikiran,
Dialogue: 0,0:10:28.12,0:10:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin orang kalem sepertimu\Nbisa akrab sama Sou.
Dialogue: 0,0:10:32.24,0:10:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, aku malah aji mumpung.
Dialogue: 0,0:10:35.45,0:10:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru aku senang\Npunya rekan kerja yang sebaya.
Dialogue: 0,0:10:40.11,0:10:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, syukurlah!
Dialogue: 0,0:10:42.33,0:10:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Kayano kerja di sini,\Nkenapa kamu tidak?
Dialogue: 0,0:10:47.03,0:10:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, soalnya...
Dialogue: 0,0:10:50.81,0:10:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:10:51.85,0:10:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang?
Dialogue: 0,0:10:53.84,0:10:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kamu datang juga, Ayaka.
Dialogue: 0,0:11:01.17,0:11:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedih kamu jarang datang\Nmeskipun ada Souji.
Dialogue: 0,0:11:05.62,0:11:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal itu.
Dialogue: 0,0:11:08.27,0:11:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut menganggumu, Tante Fumika.
Dialogue: 0,0:11:11.23,0:11:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak.
Dialogue: 0,0:11:13.28,0:11:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru bagus kalau kalian berduaan.
Dialogue: 0,0:11:16.55,0:11:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti makin semangat bekerja.
Dialogue: 0,0:11:19.87,0:11:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu masalahnya.
Dialogue: 0,0:11:22.36,0:11:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini alasan Kido tidak mau kerja di sini.
Dialogue: 0,0:11:26.00,0:11:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang kamu bilang\Nmau kerja sambilan di sini?
Dialogue: 0,0:11:30.46,0:11:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, dia orangnya.
Dialogue: 0,0:11:34.05,0:11:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya, dia Itomaki Fumika,\Npemilik kedai kopi ini.
Dialogue: 0,0:11:38.97,0:11:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekaligus tanteku.
Dialogue: 0,0:11:40.72,0:11:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Fujimiya Amane, terima kasih\Nsudah meluangkan waktumu.
Dialogue: 0,0:11:45.12,0:11:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa,\Nlagi pula ini permintaan Ayaka.
Dialogue: 0,0:11:49.76,0:11:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayaka sudah pasti tidak akan salah pilih.
Dialogue: 0,0:11:54.57,0:11:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Napa hubunganmu dengan Ayaka?
Dialogue: 0,0:11:59.68,0:12:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia teman sekelas dan teman pacarku.
Dialogue: 0,0:12:03.20,0:12:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, syukurlah.
Dialogue: 0,0:12:05.53,0:12:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Ayaka dan Souji\Nsudah sehati sejiwa.
Dialogue: 0,0:12:09.25,0:12:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak boleh diganggu gugat.
Dialogue: 0,0:12:12.80,0:12:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah punya pacar untuk dilamar,\Njadi itu mustahil.
Dialogue: 0,0:12:17.38,0:12:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, luar biasa!
Dialogue: 0,0:12:20.09,0:12:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komitmen di usia semuda itu\Nsungguh mengagumkan.
Dialogue: 0,0:12:24.11,0:12:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah alasanmu melamar kerja?
Dialogue: 0,0:12:27.04,0:12:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, biar bisa membeli\Ncincin untuk pacarku.
Dialogue: 0,0:12:29.98,0:12:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:12:31.84,0:12:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, bekerjalah di tempat ini.
Dialogue: 0,0:12:34.52,0:12:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung diterima?\NTapi wajar, sih.
Dialogue: 0,0:12:37.99,0:12:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tante, jangan terlalu kepo, ya.
Dialogue: 0,0:12:42.77,0:12:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaanku tidak akan aneh-aneh, kok.
Dialogue: 0,0:12:46.12,0:12:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling awal mula hubungan...
Dialogue: 0,0:12:47.64,0:12:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan kalau Fujimiya dijadikan\Nbahan pekerjaan dan hobimu.
Dialogue: 0,0:12:51.23,0:12:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanya sewajarnya saja.
Dialogue: 0,0:12:53.59,0:12:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan dan hobi?
Dialogue: 0,0:12:55.31,0:12:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjaan utama Tante Fumika\Nbukanlah kedai kopi ini.
Dialogue: 0,0:12:58.59,0:13:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia penulis, tapi melakukan banyak hal.
Dialogue: 0,0:13:01.55,0:13:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bingung\Nkenapa dia buka kedai kopi.
Dialogue: 0,0:13:04.53,0:13:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kedai kopinya kukelola\Ndengan baik, kok.
Dialogue: 0,0:13:08.71,0:13:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak perlu takut bangkrut.
Dialogue: 0,0:13:12.49,0:13:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:13.50,0:13:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tante, tolong gaji dengan benar, ya.
Dialogue: 0,0:13:17.23,0:13:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan beri uang saku atau sejenisnya.
Dialogue: 0,0:13:19.76,0:13:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:13:24.39,0:13:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:13:25.49,0:13:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:13:27.62,0:13:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana wawancaranya?
Dialogue: 0,0:13:30.47,0:13:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku disukai, jadi diterima.
Dialogue: 0,0:13:34.33,0:13:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga kamu pasti diterima.
Dialogue: 0,0:13:37.83,0:13:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Npemilik kedainya seperti apa?
Dialogue: 0,0:13:41.38,0:13:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang, dia wanita yang unik.
Dialogue: 0,0:13:45.17,0:13:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita?
Dialogue: 0,0:13:46.79,0:13:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, dia tipe yang suka\Nmengamati sebuah pasangan.
Dialogue: 0,0:13:51.29,0:13:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia penasaran sama kisah asmara kita.
Dialogue: 0,0:13:54.40,0:13:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya bermaksud curiga,
Dialogue: 0,0:13:58.19,0:14:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku takut dia jatuh hati padamu.
Dialogue: 0,0:14:02.45,0:14:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:14:03.64,0:14:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja.
Dialogue: 0,0:14:05.91,0:14:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun terjadi, mustahil aku mau.
Dialogue: 0,0:14:08.81,0:14:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kalau sampai mengganggu\Npekerjaan, aku akan berhenti.
Dialogue: 0,0:14:14.28,0:14:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak minta sejauh itu.
Dialogue: 0,0:14:17.29,0:14:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma agak cemas.
Dialogue: 0,0:14:21.55,0:14:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, makanya lebih baik aku berhenti\Nkalau misalkan kamu tersakiti.
Dialogue: 0,0:14:27.60,0:14:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ada apa?
Dialogue: 0,0:14:30.88,0:14:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cinta sifatmu itu.
Dialogue: 0,0:14:33.87,0:14:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma yang itu?
Dialogue: 0,0:14:35.45,0:14:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak, bodoh!
Dialogue: 0,0:14:40.44,0:14:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal biasanya begini, rasanya sepi.
Dialogue: 0,0:14:44.51,0:14:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, soalnya Ayah dan Ibu pulang.
Dialogue: 0,0:14:48.57,0:14:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlihat sangat gembira\Nsaat bersama Ibu.
Dialogue: 0,0:14:51.85,0:14:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya memang menyenangkan.
Dialogue: 0,0:14:54.19,0:14:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku bisa dengar cerita masa kecilmu.
Dialogue: 0,0:14:56.71,0:14:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya?
Dialogue: 0,0:14:59.13,0:15:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking kencangnya main ayunan,
Dialogue: 0,0:15:01.87,0:15:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu sampai terpental dan menangis.
Dialogue: 0,0:15:04.68,0:15:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking semangatnya mencium Shihoko,\Nkamu malah menyundulnya.
Dialogue: 0,0:15:09.57,0:15:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi...
Dialogue: 0,0:15:10.81,0:15:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, tidak punya cerita seperti itu.
Dialogue: 0,0:15:16.48,0:15:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak perlu khawatir.
Dialogue: 0,0:15:19.51,0:15:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku saat ini, itu tidak terlalu penting.
Dialogue: 0,0:15:24.55,0:15:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah merasa lengkap.
Dialogue: 0,0:15:27.07,0:15:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah cukup.
Dialogue: 0,0:15:28.57,0:15:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru...
Dialogue: 0,0:15:29.89,0:15:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku pendiam waktu kecil.
Dialogue: 0,0:15:34.20,0:15:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bandel sepertimu.
Dialogue: 0,0:15:37.41,0:15:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi.
Dialogue: 0,0:15:39.37,0:15:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku juga sulit membayangkan\Nkalau kamu tomboi...
Dialogue: 0,0:15:44.72,0:15:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:15:46.22,0:15:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi penasaran kalau kamu tomboi.
Dialogue: 0,0:15:50.32,0:15:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau anak kita mirip kamu, kayaknya bisa.
Dialogue: 0,0:15:54.48,0:15:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku waktu kecil sama sekali tidak lucu.
Dialogue: 0,0:15:59.41,0:16:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bersikap baik agar dipuji.
Dialogue: 0,0:16:03.55,0:16:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan aku sering digosipkan.
Dialogue: 0,0:16:05.91,0:16:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh siapa?
Dialogue: 0,0:16:06.86,0:16:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh ibu-ibu dari teman mainku.
Dialogue: 0,0:16:11.79,0:16:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, tenanglah.
Dialogue: 0,0:16:13.87,0:16:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya...
Dialogue: 0,0:16:15.41,0:16:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja,\Nsoalnya Bu Koyuki rajin memujiku.
Dialogue: 0,0:16:20.37,0:16:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Koyuki...
Dialogue: 0,0:16:22.13,0:16:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak serapuh yang kamu kira, kok.
Dialogue: 0,0:16:26.63,0:16:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru...
Dialogue: 0,0:16:28.53,0:16:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi baiknya, aku bisa\Nbertemu denganmu begini
Dialogue: 0,0:16:33.35,0:16:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena melewati masa lalu itu.
Dialogue: 0,0:16:40.72,0:16:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku makin baik-baik saja\Nkarena sangat dicintai olehmu.
Dialogue: 0,0:16:46.65,0:16:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:55.40,0:16:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau bilang sebelum keburu lupa.
Dialogue: 0,0:16:59.09,0:17:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku pulang larut\Nkalau sudah mulai bekerja,
Dialogue: 0,0:17:02.35,0:17:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makan malam saja duluan.
Dialogue: 0,0:17:04.86,0:17:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunggu, kok.
Dialogue: 0,0:17:06.43,0:17:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti keburu lapar.
Dialogue: 0,0:17:07.84,0:17:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepuasan hati lebih penting dari perut,\Naku mau menunggu saja.
Dialogue: 0,0:17:14.08,0:17:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:17.72,0:17:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kelihatan aneh?
Dialogue: 0,0:17:19.72,0:17:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:17:21.40,0:17:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Shiina akan senang\Nkalau melihatmu.
Dialogue: 0,0:17:24.93,0:17:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berniat\Nmenunjukkan ini ke Mahiru.
Dialogue: 0,0:17:28.76,0:17:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Shiina akan kecewa.
Dialogue: 0,0:17:31.47,0:17:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa kamu tidak pamer ke Kido?
Dialogue: 0,0:17:34.81,0:17:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayaka lebih suka aku tanpa busana.
Dialogue: 0,0:17:38.41,0:17:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:17:39.41,0:17:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:17:41.71,0:17:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya mulai hari ini.
Dialogue: 0,0:17:44.86,0:17:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama, mohon kerja samanya, ya.
Dialogue: 0,0:17:50.03,0:17:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo perkenalkan dirimu\Nke pegawai yang lain.
Dialogue: 0,0:17:53.68,0:17:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada anak baru!\NSalam kenal!
Dialogue: 0,0:17:57.93,0:18:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku Fujimiya.
Dialogue: 0,0:18:00.99,0:18:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Salam kenal.
Dialogue: 0,0:18:03.69,0:18:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, kamu pasti kaget.
Dialogue: 0,0:18:06.50,0:18:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Miyamoto Daichi,\Norang ini Oohashi Rino.
Dialogue: 0,0:18:09.87,0:18:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan saja kalau butuh bantuan.
Dialogue: 0,0:18:12.52,0:18:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil aku "orang ini"!
Dialogue: 0,0:18:14.89,0:18:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku marah banget!\NJangan diangkat!
Dialogue: 0,0:18:17.95,0:18:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya beri salam yang benar.
Dialogue: 0,0:18:19.87,0:18:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, namaku Oohashi Rino.
Dialogue: 0,0:18:23.32,0:18:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mintalah bantuanku kapan saja, Junior.
Dialogue: 0,0:18:25.57,0:18:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan, dia sering berulah.
Dialogue: 0,0:18:28.77,0:18:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, Daichi!
Dialogue: 0,0:18:30.63,0:18:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang sering kena batunya.
Dialogue: 0,0:18:33.43,0:18:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf, deh!\NTidak akan diulangi lagi!
Dialogue: 0,0:19:14.20,0:19:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:19:15.51,0:19:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Amane.
Dialogue: 0,0:19:17.68,0:19:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tidak usah lari-lari.
Dialogue: 0,0:19:20.30,0:19:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama.
Dialogue: 0,0:19:21.47,0:19:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, aku melakukan banyak hal\Nselama kamu tidak ada, kok.
Dialogue: 0,0:19:27.04,0:19:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti tidak kangen, dong?
Dialogue: 0,0:19:30.08,0:19:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu juga.
Dialogue: 0,0:19:37.20,0:19:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mandi atau makan dulu?
Dialogue: 0,0:19:42.90,0:19:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kamu lapar,\Njadi makan ayo dulu.
Dialogue: 0,0:19:47.08,0:19:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, biar kuambil dulu.
Dialogue: 0,0:19:49.70,0:19:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini hari pertamamu bekerja,\Naku sudah menyiapkan tamagoyaki spesial.
Dialogue: 0,0:19:55.36,0:19:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik, hadiahnya mantap.
Dialogue: 0,0:19:59.16,0:20:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebahagiaanmu simpel banget.
Dialogue: 0,0:20:01.39,0:20:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya itu kesukaanku.
Dialogue: 0,0:20:03.35,0:20:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan makin mewah lagi\Nkarena ini buatanmu.
Dialogue: 0,0:20:08.44,0:20:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:20:17.95,0:20:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kamu berterima kasih,\Ntapi jangan menyerang dadakan.
Dialogue: 0,0:20:23.03,0:20:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus lapor dulu sebelum memujimu?
Dialogue: 0,0:20:25.80,0:20:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan begitu juga.
Dialogue: 0,0:20:29.52,0:20:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat kamu juga\Nsalah tingkah suatu hari nanti.
Dialogue: 0,0:20:43.61,0:20:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana pekerjaanmu?
Dialogue: 0,0:20:45.41,0:20:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, lancar-lancar saja.
Dialogue: 0,0:20:48.20,0:20:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak diberi tugas berat\Ndi hari pertama.
Dialogue: 0,0:20:51.13,0:20:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para senior pun kayaknya baik.
Dialogue: 0,0:20:53.19,0:20:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, syukurlah.
Dialogue: 0,0:20:56.40,0:20:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau tempat kerjanya nyaman.
Dialogue: 0,0:20:59.24,0:21:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut lingkungannya buruk.
Dialogue: 0,0:21:02.55,0:21:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aman-aman saja.
Dialogue: 0,0:21:05.20,0:21:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau begitu.
Dialogue: 0,0:21:07.51,0:21:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau kamu bisa berusaha.
Dialogue: 0,0:21:10.53,0:21:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bisa mendukung dari jauh.
Dialogue: 0,0:21:14.81,0:21:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah cukup.
Dialogue: 0,0:21:18.05,0:21:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap pulang, aku sangat bahagia\Ndisediakan air hangat dan makanan enak.
Dialogue: 0,0:21:25.27,0:21:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih selalu.
Dialogue: 0,0:21:27.67,0:21:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa melihatmu bekerja secepatnya,\Naku akan membantu sebisa mungkin.
Dialogue: 0,0:21:33.86,0:21:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sebegitunya ingin lihat?
Dialogue: 0,0:21:35.99,0:21:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin melihat pacar\Ndi tempat kerja itu hal wajar.
Dialogue: 0,0:21:39.55,0:21:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku agak malu\Nkalau dilihat, sih.
Dialogue: 0,0:21:43.78,0:21:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak mau,\Naku mengalah, deh.
Dialogue: 0,0:21:46.37,0:21:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, memangnya kamu\Nsuka melihat senyum karirku?
Dialogue: 0,0:21:51.08,0:21:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena biasanya jarang,\Njustru aku ingin lihat.
Dialogue: 0,0:21:55.27,0:21:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap senyum kapan pun\Nkalau kamu yang minta.
Dialogue: 0,0:21:59.44,0:22:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau senyumnya padaku,\Nhitungannya berbeda.
