Dialogue: 0,0:01:24.15,0:01:28.23,tanda,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:02:51.03,0:02:52.47,tanda,,0000,0000,0000,,SAYUR MUSIM PANAS RENDAM DASHI\NAYAM SAUS TERIYAKI
Dialogue: 0,0:02:52.47,0:02:53.20,tanda,,0000,0000,0000,,SUP TELUR KOCOK
Dialogue: 0,0:02:53.20,0:02:54.15,tanda,,0000,0000,0000,,TUMIS PAPRIKA DAN CHIKUWA PEDAS MANIS
Dialogue: 0,0:04:24.45,0:04:31.33,tanda,,0000,0000,0000,,#2 AWAL LIBURAN MUSIM PANAS
Dialogue: 0,0:23:34.89,0:23:45.35,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:03.67,0:00:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim hujan itu udaranya lembap,\Nbikin suasana hati jadi murung.
Dialogue: 0,0:00:08.82,0:00:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutku jadi sulit diatur dan mudah kusut,\Nini benar-benar merepotkan.
Dialogue: 0,0:00:14.24,0:00:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menatanya jadi lebih sulit\Ndari biasanya, ya.
Dialogue: 0,0:00:17.65,0:00:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaya rambutmu yang ini pun\Nmasih terlihat manis,
Dialogue: 0,0:00:20.31,0:00:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ma-Manis?\N- tapi mau bagaimana lagi.
Dialogue: 0,0:00:28.14,0:00:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, memang ada tidak enaknya,
Dialogue: 0,0:00:31.26,0:00:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi musim hujanlah\Nyang mempertemukan kita,
Dialogue: 0,0:00:34.29,0:00:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku suka.
Dialogue: 0,0:00:38.11,0:00:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen kita berjalan berdua\Ndi bawah hujan pun,
Dialogue: 0,0:00:41.31,0:00:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi kenangan berharga.
Dialogue: 0,0:00:46.91,0:00:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:00:48.11,0:00:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu?
Dialogue: 0,0:00:49.55,0:00:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya diskon supermarket\Ntersisa banyak saat hujan.
Dialogue: 0,0:00:53.50,0:00:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemburu diskonnya juga sedikit,\Njadi gampang memilihnya.
Dialogue: 0,0:00:59.81,0:01:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmu yang didapat dari hidup mandiri, ya?
Dialogue: 0,0:01:03.07,0:01:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk akal, sih.
Dialogue: 0,0:01:04.59,0:01:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kan?
Dialogue: 0,0:01:06.73,0:01:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka memanfaatkan semua yang ada.
Dialogue: 0,0:01:09.06,0:01:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak melarang, kok.
Dialogue: 0,0:02:52.47,0:02:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:02:54.15,0:02:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tadi waktu pelajaran olahraga\Nkayaknya heboh banget,
Dialogue: 0,0:02:57.71,0:02:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada hal yang seru, ya?
Dialogue: 0,0:03:00.40,0:03:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:03:01.58,0:03:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sial!\N- Hm?
Dialogue: 0,0:03:04.17,0:03:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, soal itu...
Dialogue: 0,0:03:07.93,0:03:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian aku tidak berniat pamer\Nsebagai pacar Mahiru,
Dialogue: 0,0:03:12.00,0:03:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maunya seperti biasa saja.
Dialogue: 0,0:03:13.36,0:03:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya, masih waras?
Dialogue: 0,0:03:14.75,0:03:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bautnya lepas?
Dialogue: 0,0:03:15.43,0:03:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benaran anak SMA?
Dialogue: 0,0:03:17.24,0:03:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cuma ingin mengejekku, kan?
Dialogue: 0,0:03:19.18,0:03:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Shiina sedang\Nminta saran sama Chi.
Dialogue: 0,0:03:27.76,0:03:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, jangan dipikirkan.
Dialogue: 0,0:03:30.90,0:03:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:03:32.97,0:03:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap kamu bilang begitu,\Njustru ada yang perlu dikhawatirkan.
Dialogue: 0,0:03:37.78,0:03:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma obrolan para cowok, kok.
Dialogue: 0,0:03:43.30,0:03:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau cerita, tidak apa-apa.
Dialogue: 0,0:03:47.25,0:03:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencintai bukan berarti\Nharus tahu segalanya soal pacarnya.
Dialogue: 0,0:03:51.90,0:03:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada yang aku tidak tahu,\Naku tetap mencintaimu.
Dialogue: 0,0:03:57.72,0:04:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah salah satu daya tarikmu.
Dialogue: 0,0:04:02.64,0:04:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah salah satu daya tarikmu juga.
Dialogue: 0,0:04:05.55,0:04:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, katanya kamu habis dapat\Nbanyak saran dari Chitose.
Dialogue: 0,0:04:11.45,0:04:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga...
Dialogue: 0,0:04:13.59,0:04:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sedikit, kok.
Dialogue: 0,0:04:14.52,0:04:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dapat.
Dialogue: 0,0:04:16.45,0:04:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku melarang,
Dialogue: 0,0:04:18.11,0:04:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak mau hubungan kita\Nsampai diumbar blakblakan.
Dialogue: 0,0:04:21.73,0:04:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku akan berhati-hati.
Dialogue: 0,0:04:26.14,0:04:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, aku mau mampir ke satu tempat,
Dialogue: 0,0:04:28.83,0:04:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa tidak pulang bareng dulu?
Dialogue: 0,0:04:31.33,0:04:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sampai jumpa nanti.
Dialogue: 0,0:04:35.54,0:04:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pulang bareng cewek lain, ya.
Dialogue: 0,0:04:38.84,0:04:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir aku akan begitu?
Dialogue: 0,0:04:40.77,0:04:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sih.
Dialogue: 0,0:04:42.68,0:04:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bisa saja kamu diajak cewek lain.
Dialogue: 0,0:04:46.63,0:04:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka.
Dialogue: 0,0:04:47.92,0:04:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terbakar api cemburu?
Dialogue: 0,0:04:51.82,0:04:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:04:57.36,0:04:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:04:58.79,0:05:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya melihat dirimu seorang,\Ntidak tergoda sama yang lain.
Dialogue: 0,0:05:02.30,0:05:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah kalau begitu.
Dialogue: 0,0:05:04.93,0:05:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, daripada kamu salah paham nanti,
Dialogue: 0,0:05:08.84,0:05:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau kasih tahu tujuanku sekarang.
Dialogue: 0,0:05:12.30,0:05:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau
Dialogue: 0,0:05:14.17,0:05:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beli baju renang bersama Chitose.
Dialogue: 0,0:05:18.92,0:05:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang?
Dialogue: 0,0:05:21.35,0:05:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka dia berinisiatif\Nbeli baju renang sendiri.
Dialogue: 0,0:05:26.40,0:05:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya dia tidak bisa berenang.
Dialogue: 0,0:05:28.43,0:05:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan memilih sekolah yang tidak ada\Npelajaran wajib berenangnya.
Dialogue: 0,0:05:33.69,0:05:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kita mau pergi\Nke kolam renang nanti?
Dialogue: 0,0:05:37.33,0:05:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku masih ingat janjiku, kok.
Dialogue: 0,0:05:40.85,0:05:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:42.50,0:05:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka baju renang seperti apa?
Dialogue: 0,0:05:44.69,0:05:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tidak terbuka.
Dialogue: 0,0:05:47.07,0:05:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihan kamu banget, deh.
Dialogue: 0,0:05:48.86,0:05:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa semaput nanti.\NSebaiknya jangan yang mencolok.
Dialogue: 0,0:05:52.31,0:05:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:05:53.65,0:05:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru!
Dialogue: 0,0:05:54.81,0:05:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau minta saran sama Chitose dulu\Nuntuk cari cara membuatmu bahagia.
Dialogue: 0,0:05:59.48,0:06:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kirim pesan ke Chitose\Nsupaya dia tidak aneh-aneh.
Dialogue: 0,0:06:10.11,0:06:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia belum pulang.
Dialogue: 0,0:06:12.92,0:06:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben masih di sini\Nsampai jam sebegini.
Dialogue: 0,0:06:15.36,0:06:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya...
Dialogue: 0,0:06:17.19,0:06:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:18.20,0:06:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang\Njangan telanjang dada di hadapanku!
Dialogue: 0,0:06:22.71,0:06:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku kira kamu sudah pulang...
Dialogue: 0,0:06:25.49,0:06:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatnya mau mengobrol dulu\Ndenganmu baru pulang.
Dialogue: 0,0:06:29.32,0:06:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:06:32.82,0:06:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin kamu semalu ini, ya?
Dialogue: 0,0:06:34.83,0:06:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku malu!
Dialogue: 0,0:06:37.04,0:06:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu akan melihatku pakai baju renang\Nkalau kita jadi ke kolam renang.
Dialogue: 0,0:06:42.27,0:06:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau biasakan dari sekarang?
Dialogue: 0,0:06:45.34,0:06:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.\NMustahil dengan penampilanmu sekarang.
Dialogue: 0,0:06:49.06,0:06:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:50.06,0:06:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}So-Soalnya kamu terlihat seksi.
Dialogue: 0,0:06:55.68,0:06:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seksi?
Dialogue: 0,0:06:56.81,0:06:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begini...
Dialogue: 0,0:06:59.21,0:07:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, aku tidak kuat\Nkarena kamu terlalu keren!
Dialogue: 0,0:07:01.76,0:07:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makin keren saat percaya diri,\Nbenar-benar curang banget!
Dialogue: 0,0:07:05.72,0:07:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang?
Dialogue: 0,0:07:06.82,0:07:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi deg-degan sendirian...
Dialogue: 0,0:07:09.99,0:07:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak boleh asal menyimpulkan.
Dialogue: 0,0:07:13.70,0:07:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Amane?
Dialogue: 0,0:07:15.75,0:07:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau kamu mengerti\Nperasaanku sedikit...
Dialogue: 0,0:07:19.37,0:07:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku deg-degan juga...
Dialogue: 0,0:07:22.26,0:07:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku lebih memikirkan\Nsemua ini daripada kamu.
Dialogue: 0,0:07:27.69,0:07:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kamu jadi ilfil, ya?
Dialogue: 0,0:07:31.70,0:07:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ilfil...
Dialogue: 0,0:07:34.28,0:07:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kalau diperhatikan,
Dialogue: 0,0:07:38.06,0:07:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu terlihat cowok banget.
Dialogue: 0,0:07:41.78,0:07:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tadinya apa?
Dialogue: 0,0:07:44.58,0:07:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku hanya baru sadar soal itu,
Dialogue: 0,0:07:50.19,0:07:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soalnya tubuhmu ramping.
Dialogue: 0,0:07:52.74,0:07:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, ramping begini,\Njadi tidak bisa diandalkan, ya?
Dialogue: 0,0:07:56.10,0:07:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!
Dialogue: 0,0:07:59.25,0:08:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget ternyata badanmu keras juga.
Dialogue: 0,0:08:04.13,0:08:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku belum pernah\Nmenyentuh tubuh cowok,
Dialogue: 0,0:08:08.41,0:08:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi rasanya baru dan mengejutkan.
Dialogue: 0,0:08:12.07,0:08:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kalau kebanyakan pegang,
Dialogue: 0,0:08:13.93,0:08:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bikin kamu jadi malu, ya?
Dialogue: 0,0:08:18.73,0:08:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga\Nakan balas sentuh yang kamu sentuh!
Dialogue: 0,0:08:28.70,0:08:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku suka disentuh olehmu,\Njadi tidak apa-apa.
Dialogue: 0,0:08:35.95,0:08:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:08:38.21,0:08:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal jangan menggelitik, ya.
Dialogue: 0,0:08:47.18,0:08:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski salahku sendiri,
Dialogue: 0,0:08:49.95,0:08:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya posisi ini bahaya, deh.
Dialogue: 0,0:08:53.22,0:08:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu paham, kan?
Dialogue: 0,0:08:57.58,0:09:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berarti lain kali saja, deh!
Dialogue: 0,0:09:01.02,0:09:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:09:03.40,0:09:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir tidak bisa menahan diri,
Dialogue: 0,0:09:06.30,0:09:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya takut.
Dialogue: 0,0:09:11.27,0:09:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, aku tidak akan macam-macam.
Dialogue: 0,0:09:15.72,0:09:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukannya takut,
Dialogue: 0,0:09:17.97,0:09:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi lebih ke merasa malu
Dialogue: 0,0:09:21.98,0:09:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sedikit berharap...
Dialogue: 0,0:09:24.15,0:09:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berharap?
Dialogue: 0,0:09:25.63,0:09:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya...
Dialogue: 0,0:09:28.03,0:09:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman...
Dialogue: 0,0:09:31.45,0:09:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kamu selalu
Dialogue: 0,0:09:33.59,0:09:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memperlakukanku layaknya\Nharta berharga bagimu.
Dialogue: 0,0:09:39.72,0:09:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta itu membuat ingin merasakan
Dialogue: 0,0:09:44.52,0:09:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak hal.
Dialogue: 0,0:09:46.52,0:09:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud memburu-buru.
Dialogue: 0,0:09:49.43,0:09:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meminta-minta seperti itu juga\Nrasanya kurang sopan...
Dialogue: 0,0:09:59.14,0:10:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tidak enak.
Dialogue: 0,0:10:01.54,0:10:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu bilang begitu,\Naku jadi tidak bisa menahan diri
Dialogue: 0,0:10:04.71,0:10:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak mau membiarkanmu pulang.
Dialogue: 0,0:10:07.64,0:10:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu Koyuki pernah mengajariku banyak hal,
Dialogue: 0,0:10:13.21,0:10:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tahu,\Norang sepertimu itu sangat langka.
Dialogue: 0,0:10:19.57,0:10:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang yang mau mendengarkan
Dialogue: 0,0:10:21.77,0:10:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghargai perasaan pasangannya.
Dialogue: 0,0:10:25.18,0:10:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalau kamu selalu menghargai
Dialogue: 0,0:10:28.71,0:10:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjagaku dengan sepenuh hati.
Dialogue: 0,0:10:32.30,0:10:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beruntung bisa mencintai dirimu
Dialogue: 0,0:10:35.84,0:10:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang seperti itu.
Dialogue: 0,0:10:44.59,0:10:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan aku mencium pipimu,\Nkamu tidak keberatan, kan?
Dialogue: 0,0:10:50.53,0:10:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa kamu baru meminta izin\Nsetelah melakukannya?
Dialogue: 0,0:10:55.93,0:10:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi.
Dialogue: 0,0:10:57.52,0:11:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hitungannya aku masih menahan diri...
Dialogue: 0,0:11:00.74,0:11:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benaran terlalu polos.
Dialogue: 0,0:11:05.05,0:11:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku keberatan\Ndicium pacar sendiri.
Dialogue: 0,0:11:08.84,0:11:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dasar!
Dialogue: 0,0:11:10.96,0:11:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hentikan kalau aku kelewatan.
Dialogue: 0,0:11:13.80,0:11:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran takut kebablasan.
Dialogue: 0,0:11:15.47,0:11:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelewatan?
Dialogue: 0,0:11:17.74,0:11:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kehilangan kendali\Ndan tidak bisa menahan diri.
Dialogue: 0,0:11:31.03,0:11:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf.
Dialogue: 0,0:11:33.05,0:11:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang salah.
Dialogue: 0,0:11:45.26,0:11:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak ada bekasnya?
Dialogue: 0,0:11:49.57,0:11:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gigitan dibalas gigitan!
Dialogue: 0,0:11:52.52,0:11:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kamu ini.
Dialogue: 0,0:11:58.42,0:12:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:12:00.57,0:12:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya liburan musim panas kita dimulai!
Dialogue: 0,0:12:03.84,0:12:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sampai kegirangan banget?
Dialogue: 0,0:12:06.04,0:12:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya sudah jelas?
Dialogue: 0,0:12:08.44,0:12:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran neraka itu akhirnya selesai
Dialogue: 0,0:12:10.44,0:12:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan akhirnya surga pun tiba!
Dialogue: 0,0:12:13.50,0:12:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu saja yang tidak suka belajar,\Naku mah suka-suka saja.
Dialogue: 0,0:12:18.12,0:12:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid pintar diam saja, deh.
Dialogue: 0,0:12:19.81,0:12:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktumu bermesraan dengan Shiina\Njuga akan bertambah, kan?
Dialogue: 0,0:12:23.28,0:12:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bukan berarti aku akan\Nbermesraan seharian.
Dialogue: 0,0:12:26.99,0:12:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, kalian berdua hanya menganggap\N"bermesraan" itu hal yang besar,
Dialogue: 0,0:12:31.24,0:12:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padahal kalian suka bermesraan\Ntanpa sadar.
Dialogue: 0,0:12:33.80,0:12:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada...
Dialogue: 0,0:12:35.03,0:12:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kami yang melihatnya pun ikut malu.
Dialogue: 0,0:12:40.03,0:12:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu ikut-ikutan juga?
Dialogue: 0,0:12:41.64,0:12:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat itu pengganggu pun berkurang,
Dialogue: 0,0:12:44.97,0:12:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi lumayan, deh.
Dialogue: 0,0:12:51.08,0:12:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kapan kita berkunjung\Nke kampung halamanku?
Dialogue: 0,0:12:53.79,0:12:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:56.05,0:12:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, atau kamu tidak mau ikut?
Dialogue: 0,0:12:59.33,0:13:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!
Dialogue: 0,0:13:00.92,0:13:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya belum punya\Nbayangan soal itu...
Dialogue: 0,0:13:05.19,0:13:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa ikut kapan saja.
Dialogue: 0,0:13:08.78,0:13:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:13:12.72,0:13:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berapa lama di sana?
Dialogue: 0,0:13:15.02,0:13:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum punya rencana apa pun,
Dialogue: 0,0:13:17.97,0:13:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kamu bisa menentukan.
Dialogue: 0,0:13:20.51,0:13:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau dua minggu\Nsekalian festival Obon di sana?
Dialogue: 0,0:13:24.63,0:13:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi lumayan lama, kamu keberatan?
Dialogue: 0,0:13:27.24,0:13:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:13:28.65,0:13:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ibuku akan senang banget, deh.
Dialogue: 0,0:13:33.44,0:13:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:13:34.94,0:13:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong...
Dialogue: 0,0:13:38.07,0:13:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kasih tahu\Nkita sudah berpacaran atau tidak, ya?
Dialogue: 0,0:13:43.72,0:13:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana ini?
Dialogue: 0,0:13:45.69,0:13:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malu juga tiba-tiba bahas soal itu.
Dialogue: 0,0:13:49.76,0:13:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, pasti diinterogasi banyak hal, deh.
Dialogue: 0,0:13:53.22,0:13:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya iyalah!
Dialogue: 0,0:13:54.77,0:13:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sudah memacari\Nputra kesayangannya,
Dialogue: 0,0:13:59.56,0:14:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setidaknya aku harus memberi salam.
Dialogue: 0,0:14:01.70,0:14:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku yang memacarimu?
Dialogue: 0,0:14:04.01,0:14:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka gombalanmu yang spontan,
Dialogue: 0,0:14:08.28,0:14:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku juga tidak suka gombalan spontan.
Dialogue: 0,0:14:11.02,0:14:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang benar?
Dialogue: 0,0:14:12.56,0:14:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya kamu hanya begitu padaku.
Dialogue: 0,0:14:15.62,0:14:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir aku akan begitu\Npada yang lain?
Dialogue: 0,0:14:34.40,0:14:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu, Amane.
Dialogue: 0,0:14:38.47,0:14:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:14:41.20,0:14:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang gantinya ramai...
Dialogue: 0,0:14:44.02,0:14:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya...
Dialogue: 0,0:14:54.37,0:14:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:14:58.60,0:15:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane?
Dialogue: 0,0:15:00.98,0:15:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang cocok, ya?
Dialogue: 0,0:15:02.78,0:15:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:15:04.52,0:15:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking cocoknya\Naku hanya ingin ada kita berdua
Dialogue: 0,0:15:07.48,0:15:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di kolam renang ini.
Dialogue: 0,0:15:09.15,0:15:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:14.77,0:15:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar, jangan melirik cewek lain!\N- Meski begitu...
Dialogue: 0,0:15:18.81,0:15:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:15:21.47,0:15:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai ini.
Dialogue: 0,0:15:22.41,0:15:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:15:24.47,0:15:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau ada cowok lain\Nmelihat penampilanmu ini.
Dialogue: 0,0:15:28.04,0:15:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya...
Dialogue: 0,0:15:30.58,0:15:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita ke sana.
Dialogue: 0,0:15:31.90,0:15:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:15:33.64,0:15:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane.
Dialogue: 0,0:15:35.81,0:15:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya kita berdua,
Dialogue: 0,0:15:37.35,0:15:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu akan memandangiku\Nbaju renangku sampai puas?
Dialogue: 0,0:15:43.51,0:15:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya kita berdua,\Nmungkin akan kupandangi sampai puas,
Dialogue: 0,0:15:47.67,0:15:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan menyentuhnya.
Dialogue: 0,0:15:51.93,0:15:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:54.08,0:15:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena, tuh.
Dialogue: 0,0:15:55.83,0:16:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, apa aku harus menjawab,\N"Memang sengaja aku tempelkan," ya?
Dialogue: 0,0:16:00.47,0:16:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bidadari Mahiru lagi mogok kerja...
Dialogue: 0,0:16:03.06,0:16:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sedang di depan pacarnya,\Ncewek bisa jadi bidadari atau sukubus.
Dialogue: 0,0:16:07.91,0:16:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan saja kalau mau memeluk,
Dialogue: 0,0:16:10.19,0:16:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menikmatinya.
Dialogue: 0,0:16:11.50,0:16:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Rasanya malu juga\Nkalau kamu sampai bilang begitu.
Dialogue: 0,0:16:17.44,0:16:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:16:20.06,0:16:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:16:23.27,0:16:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, tenang saja,\Nkamu tidak akan tenggelam.
Dialogue: 0,0:16:27.23,0:16:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, kita bisa mati tenggelam\Nmeski di kedalaman 30 senti, lo.
Dialogue: 0,0:16:33.81,0:16:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:16:35.18,0:16:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan tenggelam,
Dialogue: 0,0:16:37.21,0:16:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan meski kamu tenggelam,\Nakan kuberi napas buatan.
Dialogue: 0,0:16:40.91,0:16:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu tidak mau aku tenggelam?
Dialogue: 0,0:16:43.94,0:16:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih menunggu kesempatan lain,
Dialogue: 0,0:16:47.82,0:16:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soalnya tidak kuat kalau di sini.
Dialogue: 0,0:16:50.70,0:16:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga tidak bilang mau di sini!
Dialogue: 0,0:16:55.05,0:16:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya penasaran\Nkamu ingin melakukannya atau tidak...
Dialogue: 0,0:16:59.79,0:17:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku tidak mau melakukannya!
Dialogue: 0,0:17:02.25,0:17:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan pun aku siap!
Dialogue: 0,0:17:06.05,0:17:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:17:06.88,0:17:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan...
Dialogue: 0,0:17:09.45,0:17:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ya?
Dialogue: 0,0:17:11.51,0:17:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya begitu...
Dialogue: 0,0:17:13.72,0:17:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kalap kalau melakukannya,\Ntunggulah di lain kesempatan.
Dialogue: 0,0:17:19.11,0:17:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Mahiru mengharapkan sekarang?
Dialogue: 0,0:17:24.03,0:17:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengambang...
Dialogue: 0,0:17:27.19,0:17:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengambang...
Dialogue: 0,0:17:34.36,0:17:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani juga kamu!
Dialogue: 0,0:17:36.42,0:17:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini balasannya!
Dialogue: 0,0:17:38.00,0:17:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru!
Dialogue: 0,0:17:44.40,0:17:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:45.63,0:17:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung ada aku...
Dialogue: 0,0:17:48.15,0:17:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan seceroboh itu\Nkalau tidak ada kamu.
Dialogue: 0,0:17:52.63,0:17:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersamamu membuat pemandangan\Nsekitarku berkilauan...
Dialogue: 0,0:17:58.30,0:18:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersamamu jugalah\Nyang membuatku sebahagia ini.
Dialogue: 0,0:18:02.28,0:18:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku yakin\Nkamu pasti menyelamatkanku.
Dialogue: 0,0:18:28.54,0:18:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum?
Dialogue: 0,0:18:34.88,0:18:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aneh, ya?
Dialogue: 0,0:18:36.23,0:18:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, aku hanya jarang minum soda.
Dialogue: 0,0:18:40.74,0:18:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata rasanya menggelitik di lidah.
Dialogue: 0,0:18:44.27,0:18:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba mau coba itu?
Dialogue: 0,0:18:46.57,0:18:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku ingin merasakan\Nhal yang sama denganmu.
Dialogue: 0,0:18:50.32,0:18:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pacarku bisa imut terus, sih?
Dialogue: 0,0:18:53.42,0:18:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei!
Dialogue: 0,0:18:55.01,0:18:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neng cantik yang ada di sana!
Dialogue: 0,0:18:57.42,0:18:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Tuan Muda pengecut!
Dialogue: 0,0:18:59.45,0:19:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau main bareng kami?
Dialogue: 0,0:19:01.53,0:19:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kalian di sini!
Dialogue: 0,0:19:03.56,0:19:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asli cuma kebetulan, kok!
Dialogue: 0,0:19:04.81,0:19:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu waktu mesra kalian, ya!
Dialogue: 0,0:19:08.71,0:19:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini...
Dialogue: 0,0:19:11.82,0:19:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ih, mesum!\N- Urus pacarmu, dong!
Dialogue: 0,0:19:14.01,0:19:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah musim panas,\Ndia kumat lagi, deh.
Dialogue: 0,0:19:20.77,0:19:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun, kamu jadi pakai\Nbaju renang yang itu?
Dialogue: 0,0:19:23.43,0:19:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Yang itu"?
Dialogue: 0,0:19:24.68,0:19:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya ada satu lagi yang talinya hitam?
Dialogue: 0,0:19:29.88,0:19:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:19:31.46,0:19:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada satu lagi.
Dialogue: 0,0:19:32.95,0:19:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, soal itu...
Dialogue: 0,0:19:36.31,0:19:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malu memakainya di depan umum...
Dialogue: 0,0:19:40.09,0:19:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya hampir tumpah-tumpah.
Dialogue: 0,0:19:41.89,0:19:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis banget saat bilang mau memakainya\Nsaat berdua sama Amane.
Dialogue: 0,0:19:45.11,0:19:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulutmu ini benaran harus disumpal, deh!
Dialogue: 0,0:19:48.74,0:19:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seterbuka itu, ya?
Dialogue: 0,0:19:50.81,0:19:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puah!
Dialogue: 0,0:19:51.86,0:19:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya terbuka,
Dialogue: 0,0:19:53.26,0:19:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi postur tubuh Mahirun bagus,\Njadi kelihatan makin minim.
Dialogue: 0,0:19:58.37,0:20:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku teruskan,\Ndia benaran akan marah,
Dialogue: 0,0:20:01.24,0:20:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi mending kamu\Nmelihatnya langsung, Amane.
Dialogue: 0,0:20:04.72,0:20:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kuperlihatkan!
Dialogue: 0,0:20:09.18,0:20:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak?
Dialogue: 0,0:20:11.39,0:20:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa dibicarakan, kok.
Dialogue: 0,0:20:15.14,0:20:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun, Mahirun, nih!
Dialogue: 0,0:20:18.47,0:20:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, kamu ini, Chitose!
Dialogue: 0,0:20:21.13,0:20:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balasannya!
Dialogue: 0,0:20:21.86,0:20:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yah, senang rasanya.\N- Rasakan!
Dialogue: 0,0:20:24.10,0:20:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat para cewek itu akur.
Dialogue: 0,0:20:26.76,0:20:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendapatmu kayak om-om.
Dialogue: 0,0:20:28.75,0:20:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat amat.
Dialogue: 0,0:20:30.26,0:20:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga cengar-cengir saat\Nmelihat mereka akrab, kan?
Dialogue: 0,0:20:34.71,0:20:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sebegitunya, kok.
Dialogue: 0,0:20:36.59,0:20:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya Mahiru\Nterlihat lebih manis dari sebelumnya.
Dialogue: 0,0:20:43.25,0:20:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mulai suka membanggakan pacar, ya.
Dialogue: 0,0:20:46.14,0:20:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih ke merasa\Ndia jadi lebih banyak tertawa saja.
Dialogue: 0,0:20:50.50,0:20:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dulu tersenyum pun tidak.
Dialogue: 0,0:20:52.98,0:20:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski belum pernah melihatnya,\Nkudengar sikapnya dingin, ya?
Dialogue: 0,0:20:56.70,0:20:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:57.65,0:21:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dulu orangnya dingin\Ndan bermulut pedas.
Dialogue: 0,0:21:00.72,0:21:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe yang tidak memercayai siapa pun.
Dialogue: 0,0:21:03.85,0:21:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur\Ndia bisa tersenyum seperti itu.
Dialogue: 0,0:21:08.37,0:21:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei!\NAnak muda yang lagi di pinggir kolam!
Dialogue: 0,0:21:13.38,0:21:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini main bareng!
Dialogue: 0,0:21:16.06,0:21:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah dipanggil cewek cantik,\Naku harus menurutinya.
Dialogue: 0,0:21:21.66,0:21:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:21:32.94,0:21:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puas banget mainnya!
Dialogue: 0,0:21:34.98,0:21:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kita ke sini lagi, ya?
Dialogue: 0,0:21:36.69,0:21:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:37.47,0:21:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ada apa ini?\NMau lihat bikini hitamnya Mahirun?
Dialogue: 0,0:21:42.09,0:21:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bego, ya?
Dialogue: 0,0:21:44.32,0:21:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau memperlihatkan itu\Npada orang lain.
Dialogue: 0,0:21:48.75,0:21:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, Chi.
Dialogue: 0,0:21:50.27,0:21:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti memandangi sampai puas\Nkalau cuma berdua!
Dialogue: 0,0:21:52.92,0:21:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah keistimewaan pacar.
Dialogue: 0,0:21:55.94,0:21:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang begitu, Mahirun!\NJadi mau diperlihatkan?
Dialogue: 0,0:21:58.58,0:22:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, dibicarakan dulu!
