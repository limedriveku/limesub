Dialogue: 0,0:01:52.51,0:01:56.26,tanda,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:05:15.00,0:05:16.71,tanda,,0000,0000,0000,,FUJIMIYA
Dialogue: 0,0:05:46.91,0:05:48.79,tanda,,0000,0000,0000,,#6 PERTEMUAN TAK DIINGINKAN\NYANG SEMPAT DIINGINKAN, DAN KEPUTUSAN
Dialogue: 0,0:08:47.63,0:08:49.97,tanda,,0000,0000,0000,,UNTUK FUJIMIYA
Dialogue: 0,0:08:49.97,0:08:52.39,tanda,,0000,0000,0000,,SHIINA ASAHI
Dialogue: 0,0:23:34.93,0:23:37.94,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:37.94,0:23:39.90,tanda,,0000,0000,0000,,RAPAT PERSIAPAN FESTIVAL BUDAYA
Dialogue: 0,0:00:30.64,0:00:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:00:32.50,0:00:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru sebaliknya.
Dialogue: 0,0:00:34.26,0:00:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena berdiri di tengah jalan.
Dialogue: 0,0:00:37.43,0:00:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku yang salah.
Dialogue: 0,0:00:45.57,0:00:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum ada buktinya, sih.
Dialogue: 0,0:00:48.24,0:00:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kayaknya, orang itu...
Dialogue: 0,0:00:52.24,0:00:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku menikah bukan atas dasar cinta.
Dialogue: 0,0:00:56.02,0:00:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya mereka tidak berniat mengasuhku.
Dialogue: 0,0:00:59.16,0:01:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membebani, buat apa dilahirkan?
Dialogue: 0,0:01:09.80,0:01:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Amane.
Dialogue: 0,0:01:13.80,0:01:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok ekspresimu begitu?
Dialogue: 0,0:01:16.31,0:01:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak.
Dialogue: 0,0:01:18.18,0:01:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget kamu tiba-tiba menjemput.
Dialogue: 0,0:01:21.69,0:01:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi lewat pesan,\Nkamu bilang sudah mau sampai, kan?
Dialogue: 0,0:01:26.11,0:01:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena titipannya banyak,
Dialogue: 0,0:01:27.98,0:01:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berniat membantumu.
Dialogue: 0,0:01:30.24,0:01:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh.
Dialogue: 0,0:01:35.45,0:01:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kemari bukan mencari
Dialogue: 0,0:01:37.99,0:01:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maupun telah bertemu Mahiru?
Dialogue: 0,0:03:15.87,0:03:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa?
Dialogue: 0,0:03:18.05,0:03:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, bagaimana, ya...
Dialogue: 0,0:03:20.56,0:03:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang kamu rahasiakan?
Dialogue: 0,0:03:24.77,0:03:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bilangnya, ya?
Dialogue: 0,0:03:27.10,0:03:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan saja kalau mau.
Dialogue: 0,0:03:30.06,0:03:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau, aku tidak memaksa.
Dialogue: 0,0:03:37.78,0:03:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:03:39.12,0:03:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku bertemu seorang pria.
Dialogue: 0,0:03:42.98,0:03:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:03:46.50,0:03:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terus berdiri sambil menatap
Dialogue: 0,0:03:49.79,0:03:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apartemen kita.
Dialogue: 0,0:03:51.63,0:03:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matanya mirip kamu.
Dialogue: 0,0:03:55.63,0:04:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna mata dan rambutnya persis denganmu.
Dialogue: 0,0:04:01.05,0:04:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk wajahnya pun mirip.
Dialogue: 0,0:04:03.85,0:04:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, mungkin itu ayahku?
Dialogue: 0,0:04:08.77,0:04:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya iya.
Dialogue: 0,0:04:15.61,0:04:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kamu salah orang.
Dialogue: 0,0:04:19.66,0:04:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah tidak pernah sedikit pun peduli padaku.
Dialogue: 0,0:04:24.70,0:04:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak aku mulai bisa mengingat,\Nkami jarang sekali bertemu.
Dialogue: 0,0:04:29.54,0:04:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu sibuk bekerja
Dialogue: 0,0:04:31.67,0:04:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mungkin tidak ingat padaku.
Dialogue: 0,0:04:36.71,0:04:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami nyaris tidak pernah saling kontak.
Dialogue: 0,0:04:40.05,0:04:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun ada,
Dialogue: 0,0:04:41.76,0:04:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}paling cuma seperlunya\Nbeberapa kali setahun.
Dialogue: 0,0:04:45.14,0:04:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak punya alasan menemuiku.
Dialogue: 0,0:04:48.27,0:04:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun mau, pasti menghubungi dulu.
Dialogue: 0,0:04:53.15,0:04:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau hal itu
Dialogue: 0,0:04:55.36,0:04:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak pernah terjadi.
Dialogue: 0,0:05:00.74,0:05:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru.
Dialogue: 0,0:05:02.70,0:05:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bukan orang tua asuhku
Dialogue: 0,0:05:07.12,0:05:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski kami sedarah.
Dialogue: 0,0:05:09.71,0:05:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tua asuhku hanyalah Koyuki.
Dialogue: 0,0:05:16.71,0:05:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:05:18.76,0:05:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesepian banget.
Dialogue: 0,0:05:21.26,0:05:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:05:23.18,0:05:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku.
Dialogue: 0,0:05:26.60,0:05:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:05:28.64,0:05:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kok.
Dialogue: 0,0:05:31.52,0:05:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ada kaitannya juga.
Dialogue: 0,0:05:34.31,0:05:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:35.52,0:05:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku sudah punya keluarga baru.
Dialogue: 0,0:05:40.21,0:05:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu benar.
Dialogue: 0,0:05:43.99,0:05:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tenang saja.
Dialogue: 0,0:05:53.81,0:05:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:05:55.46,0:05:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus apa kalau ketemu orang itu?
Dialogue: 0,0:05:59.94,0:06:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kamu saja.
Dialogue: 0,0:06:04.51,0:06:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:06:05.89,0:06:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya kamu tidak ikut-ikutan, ya?
Dialogue: 0,0:06:08.78,0:06:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:10.60,0:06:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada perlu denganku,\Ntinggal atur jadwal
Dialogue: 0,0:06:15.56,0:06:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kirim email saja.
Dialogue: 0,0:06:18.50,0:06:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa mengamati diam-diam?
Dialogue: 0,0:06:22.49,0:06:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama dia tidak bertindak langsung,
Dialogue: 0,0:06:25.38,0:06:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakal kuabaikan.
Dialogue: 0,0:06:28.86,0:06:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:32.20,0:06:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane?
Dialogue: 0,0:06:41.21,0:06:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku tidak bisa mencampuri\Nurusan keluarga kalian.
Dialogue: 0,0:06:45.72,0:06:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa pun keputusanmu,
Dialogue: 0,0:06:49.06,0:06:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku siap mendukungnya.
Dialogue: 0,0:06:53.70,0:06:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:55.35,0:06:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan kubawa kabur\Nkalau ada apa-apa.
Dialogue: 0,0:06:57.56,0:06:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:07:06.86,0:07:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti.
Dialogue: 0,0:07:09.12,0:07:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:10.96,0:07:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada masalah.
Dialogue: 0,0:07:13.00,0:07:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben kamu cerita pas ada masalah.
Dialogue: 0,0:07:17.46,0:07:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, cerita sama Abang.
Dialogue: 0,0:07:20.21,0:07:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu lahir belakangan.
Dialogue: 0,0:07:22.09,0:07:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar sajalah, ayo cerita.
Dialogue: 0,0:07:27.64,0:07:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau orang yang selama ini jaga jarak\Ntiba-tiba berusaha mendekat,
Dialogue: 0,0:07:33.23,0:07:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurutmu alasannya apa?
Dialogue: 0,0:07:36.02,0:07:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tentangmu?
Dialogue: 0,0:07:38.10,0:07:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia.
Dialogue: 0,0:07:40.82,0:07:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:07:42.44,0:07:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya...
Dialogue: 0,0:07:44.40,0:07:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada maksud tertentu.
Dialogue: 0,0:07:47.70,0:07:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski entah apa hubungan mereka.
Dialogue: 0,0:07:50.99,0:07:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan besar,
Dialogue: 0,0:07:52.49,0:07:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada hal penting\Nyang mengharuskannya ambil tindakan.
Dialogue: 0,0:07:56.58,0:08:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau terjadi sesuatu\Nyang bikin dia berubah pikiran.
Dialogue: 0,0:08:02.04,0:08:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira begitu.
Dialogue: 0,0:08:03.55,0:08:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubah pikiran?
Dialogue: 0,0:08:05.34,0:08:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau orang yang jaga jarak
Dialogue: 0,0:08:08.74,0:08:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiba-tiba datang duluan,
Dialogue: 0,0:08:10.58,0:08:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma itu alasannya.
Dialogue: 0,0:08:12.97,0:08:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau entah apa yang terjadi.
Dialogue: 0,0:08:15.66,0:08:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti, lah.
Dialogue: 0,0:08:17.23,0:08:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, berjuanglah demi gadis\Nyang kamu cintai.
Dialogue: 0,0:08:20.54,0:08:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah?
Dialogue: 0,0:08:21.61,0:08:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu mudah ditebak.
Dialogue: 0,0:08:24.69,0:08:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan begini\Nkalau bahas diri sendiri.
Dialogue: 0,0:08:26.99,0:08:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel.
Dialogue: 0,0:08:29.61,0:08:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan datang tiba-tiba.
Dialogue: 0,0:08:32.83,0:08:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antara ada hal penting
Dialogue: 0,0:08:35.15,0:08:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau berubah pikiran?
Dialogue: 0,0:08:37.53,0:08:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah tidak pernah sedikit pun peduli padaku.
Dialogue: 0,0:08:43.03,0:08:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak peduli,\Nmustahil dia berkunjung, kan?
Dialogue: 0,0:09:00.14,0:09:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:09:02.67,0:09:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkahmu aneh sejak pulang tadi.
Dialogue: 0,0:09:05.86,0:09:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, bagaimana, ya...
Dialogue: 0,0:09:08.94,0:09:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau bilang,\Naku tidak memaksa.
Dialogue: 0,0:09:12.82,0:09:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya tidak mau bilang.
Dialogue: 0,0:09:14.90,0:09:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kamu tidak mau mendengarnya.
Dialogue: 0,0:09:18.25,0:09:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang tidak mau dengar?
Dialogue: 0,0:09:20.58,0:09:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi begitu.
Dialogue: 0,0:09:23.73,0:09:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu ada di sekitar sini lagi?
Dialogue: 0,0:09:26.96,0:09:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:09:29.26,0:09:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengirim surat padaku.
Dialogue: 0,0:09:32.22,0:09:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama pengirimnya, Shiina Asahi.
Dialogue: 0,0:09:37.14,0:09:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, itu ayahku.
Dialogue: 0,0:09:41.14,0:09:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dibaca.
Dialogue: 0,0:09:43.06,0:09:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus pergi dulu?
Dialogue: 0,0:09:45.27,0:09:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bagaimana, ya...
Dialogue: 0,0:09:47.48,0:09:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu di sini.
Dialogue: 0,0:09:50.24,0:09:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak mau, bukan masalah.
Dialogue: 0,0:09:53.15,0:09:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma agak gugup dapat surat
Dialogue: 0,0:09:55.24,0:09:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari orang tua pacarku.
Dialogue: 0,0:10:00.45,0:10:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tetap di sini, deh.
Dialogue: 0,0:10:02.96,0:10:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal memberitahuku isi suratnya atau tidak,
Dialogue: 0,0:10:06.59,0:10:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu terserah kamu.
Dialogue: 0,0:10:14.72,0:10:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang, ingin bertemu denganku.
Dialogue: 0,0:10:17.89,0:10:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Denganmu?\NBukan denganku?
Dialogue: 0,0:10:20.77,0:10:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:26.44,0:10:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak marah, kok.
Dialogue: 0,0:10:30.15,0:10:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma gagal paham.
Dialogue: 0,0:10:32.95,0:10:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa dia menemuimu?
Dialogue: 0,0:10:38.20,0:10:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya,
Dialogue: 0,0:10:39.41,0:10:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena putrinya didekati cowok.
Dialogue: 0,0:10:42.58,0:10:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:10:44.12,0:10:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini dia mengabaikanku.
Dialogue: 0,0:10:46.04,0:10:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telat banget ikut campurnya.
Dialogue: 0,0:10:49.30,0:10:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, aku harus apa?
Dialogue: 0,0:10:52.21,0:10:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebas.
Dialogue: 0,0:10:54.34,0:10:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski entah apa niatnya,
Dialogue: 0,0:10:57.68,0:11:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayahku bukan orang berbahaya.
Dialogue: 0,0:11:00.56,0:11:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak usah takut.
Dialogue: 0,0:11:03.10,0:11:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak aneh berkata begini\Npadahal aku tidak terlalu mengenalnya.
Dialogue: 0,0:11:08.65,0:11:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru...
Dialogue: 0,0:11:10.23,0:11:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menemuinya atau tidak, itu pilihanmu.
Dialogue: 0,0:11:16.70,0:11:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:26.96,0:11:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama.
Dialogue: 0,0:11:29.26,0:11:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Shiina Asahi.
Dialogue: 0,0:11:32.55,0:11:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal...\NTidak juga, ya?
Dialogue: 0,0:11:35.51,0:11:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini pertama kalinya kita bicara\Nsetelah saling mengenal.
Dialogue: 0,0:11:40.72,0:11:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, aku tahu tentangmu dari Mahiru.
Dialogue: 0,0:11:46.06,0:11:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:49.31,0:11:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mendadak begini.
Dialogue: 0,0:11:53.03,0:11:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski mengajak bertemu,
Dialogue: 0,0:11:55.44,0:11:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak kusangka kamu benar-benar datang.
Dialogue: 0,0:11:58.66,0:12:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tahu alasanmu\Nrepot-repot memanggilku.
Dialogue: 0,0:12:03.54,0:12:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah seharusnya kamu menemui Mahiru?
Dialogue: 0,0:12:08.04,0:12:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang benar.
Dialogue: 0,0:12:10.83,0:12:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia pasti tidak mau menemuiku.
Dialogue: 0,0:12:18.30,0:12:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kamu juga ingin menanyakan\Nbanyak hal padaku, kan?
Dialogue: 0,0:12:23.31,0:12:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesanlah yang kamu suka.
Dialogue: 0,0:12:25.89,0:12:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai terima kasih mau datang\Ndi hari libur terakhir musim panas ini.
Dialogue: 0,0:12:33.19,0:12:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada perlu apa denganku?
Dialogue: 0,0:12:36.61,0:12:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:12:39.15,0:12:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tampaknya kalian berpacaran.
Dialogue: 0,0:12:42.32,0:12:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menanyakan kabar putriku.
Dialogue: 0,0:12:46.67,0:12:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah kira-kira.
Dialogue: 0,0:12:51.71,0:12:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja, kok.
Dialogue: 0,0:12:55.66,0:12:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mencurigaiku, ya.
Dialogue: 0,0:12:57.21,0:12:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar, kan?
Dialogue: 0,0:13:00.63,0:13:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, justru aneh kalau tidak.
Dialogue: 0,0:13:07.06,0:13:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, bagaimana ini?
Dialogue: 0,0:13:10.53,0:13:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia berhati dingin
Dialogue: 0,0:13:12.90,0:13:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti ibunya Mahiru,
Dialogue: 0,0:13:15.11,0:13:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa bersikap lebih ketus.
Dialogue: 0,0:13:20.70,0:13:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertanya juga.
Dialogue: 0,0:13:23.32,0:13:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu baru\Nmendekati Mahiru sekarang?
Dialogue: 0,0:13:30.41,0:13:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat menyayangi dia, ya.
Dialogue: 0,0:13:36.05,0:13:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berniat membawanya kembali, kok.
Dialogue: 0,0:13:40.51,0:13:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu takut
Dialogue: 0,0:13:42.63,0:13:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan mengganggu kehidupannya.
Dialogue: 0,0:13:46.22,0:13:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:13:47.54,0:13:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:13:48.72,0:13:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jelas, aku tidak berhak\Nmengusik hidupnya saat ini.
Dialogue: 0,0:13:54.31,0:13:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan tidak berniat begitu.
Dialogue: 0,0:13:57.65,0:14:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kenapa kamu\Nberusaha mendekati Mahiru?
Dialogue: 0,0:14:02.86,0:14:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak sulit menjelaskannya.
Dialogue: 0,0:14:06.38,0:14:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin melihat wajahnya.
Dialogue: 0,0:14:09.45,0:14:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kamu membuangnya?
Dialogue: 0,0:14:12.75,0:14:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terus terang, ya.
Dialogue: 0,0:14:16.46,0:14:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:18.05,0:14:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlambat bagiku untuk bersikap\Nseperti orang tuanya.
Dialogue: 0,0:14:24.05,0:14:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Asahi.
Dialogue: 0,0:14:25.22,0:14:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sadar akan perbuatanmu?
Dialogue: 0,0:14:29.89,0:14:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa terus tutup mata.
Dialogue: 0,0:14:34.31,0:14:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan istriku tidak pernah\Nbersikap layaknya orang tua.
Dialogue: 0,0:14:39.61,0:14:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pantas dihindari.
Dialogue: 0,0:14:43.20,0:14:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu...
Dialogue: 0,0:14:47.79,0:14:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu
Dialogue: 0,0:14:50.04,0:14:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak merangkulnya lebih awal?
Dialogue: 0,0:14:56.67,0:14:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kalau membebani, buat apa dilahirkan?"
Dialogue: 0,0:15:01.55,0:15:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebak itu ucapan siapa?
Dialogue: 0,0:15:04.80,0:15:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ucapan Mahiru.
Dialogue: 0,0:15:08.89,0:15:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian membuatnya\Nsampai berkata sejauh itu.
Dialogue: 0,0:15:19.36,0:15:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:21.78,0:15:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru ditelantarkan.
Dialogue: 0,0:15:24.32,0:15:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyesal sekarang?
Dialogue: 0,0:15:26.53,0:15:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kamu sadar sejak awal!
Dialogue: 0,0:15:30.53,0:15:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,\NMahiru tidak perlu terluka.
Dialogue: 0,0:15:37.67,0:15:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sepenuhnya setuju.
Dialogue: 0,0:15:41.76,0:15:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mau ditanyakan lagi?
Dialogue: 0,0:15:45.17,0:15:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:15:47.47,0:15:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:49.47,0:15:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku izin tanya satu hal.
Dialogue: 0,0:15:54.31,0:15:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:15:56.77,0:16:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa saat ini, dia bahagia?
Dialogue: 0,0:16:02.61,0:16:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, dia yang tahu jawabannya.
Dialogue: 0,0:16:19.06,0:16:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku berniat membuatnya bahagia.
Dialogue: 0,0:16:21.95,0:16:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cukup percaya diri.
Dialogue: 0,0:16:24.56,0:16:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubahagiakan dia.
Dialogue: 0,0:16:27.30,0:16:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:29.15,0:16:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarnya.
Dialogue: 0,0:16:36.18,0:16:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tidak berhak meminta,
Dialogue: 0,0:16:39.69,0:16:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tolong jaga dia.
Dialogue: 0,0:16:45.94,0:16:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak diminta pun,\Naku akan membuatnya bahagia.
Dialogue: 0,0:16:51.66,0:16:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, terima kasih.
Dialogue: 0,0:17:04.75,0:17:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah bertemu.
Dialogue: 0,0:17:06.63,0:17:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:17:08.42,0:17:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang perlu kamu takutkan.
Dialogue: 0,0:17:12.93,0:17:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tahu apa yang kami bahas?
Dialogue: 0,0:17:17.14,0:17:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebas.
Dialogue: 0,0:17:22.19,0:17:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Asahi tidak berniat mengusikmu.
Dialogue: 0,0:17:26.58,0:17:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya begitu...
Dialogue: 0,0:17:31.45,0:17:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:17:33.68,0:17:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia repot-repot ingin melihatku.
Dialogue: 0,0:17:37.54,0:17:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlambat sekali.
Dialogue: 0,0:17:39.83,0:17:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut pendapatku,
Dialogue: 0,0:17:42.33,0:17:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Asahi tidak terlihat seperti\Nbodoh amat denganmu.
Dialogue: 0,0:17:48.34,0:17:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya,
Dialogue: 0,0:17:50.08,0:17:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak terlalu paham arti orang tua.
Dialogue: 0,0:17:54.22,0:17:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak pernah memberiku perhatian.
Dialogue: 0,0:17:58.72,0:18:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peduli seberapa baik
Dialogue: 0,0:18:01.39,0:18:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diriku bersikap.
Dialogue: 0,0:18:02.98,0:18:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku mengulurkan tangan,
Dialogue: 0,0:18:05.34,0:18:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak seorang pun meraihnya.
Dialogue: 0,0:18:08.36,0:18:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, wajar kalau aku\Nberhenti mengulurkan tangan.
Dialogue: 0,0:18:13.78,0:18:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar kalau aku berhenti berharap.
Dialogue: 0,0:18:19.20,0:18:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat terlambat.
Dialogue: 0,0:18:25.67,0:18:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai begitu lebih awal, aku...
Dialogue: 0,0:18:34.59,0:18:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu maunya bagaimana?
Dialogue: 0,0:18:37.51,0:18:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.
Dialogue: 0,0:18:39.64,0:18:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, aku tidak perlu perubahan.
Dialogue: 0,0:18:43.66,0:18:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski didekati,
Dialogue: 0,0:18:46.10,0:18:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak akan bisa\Nmenganggapnya sebagai orang tua.
Dialogue: 0,0:18:49.78,0:18:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:18:53.07,0:18:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku
Dialogue: 0,0:18:55.74,0:18:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak yang durhaka?
Dialogue: 0,0:18:59.95,0:19:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung, soalnya orang beda-beda.
Dialogue: 0,0:19:05.67,0:19:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau ada di posisimu,\Nmenurutku itu wajar.
Dialogue: 0,0:19:09.17,0:19:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyangkalnya.
Dialogue: 0,0:19:11.42,0:19:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menurutmu begitu,
Dialogue: 0,0:19:13.51,0:19:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga setuju.
Dialogue: 0,0:19:15.18,0:19:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mendukung pilihanmu.
Dialogue: 0,0:19:18.80,0:19:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu siap membantu.
Dialogue: 0,0:19:22.27,0:19:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:24.06,0:19:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bersamamu selamanya.
Dialogue: 0,0:19:26.35,0:19:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersandarlah kapan pun kamu resah.
Dialogue: 0,0:19:32.40,0:19:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benaran mau bersamaku?
Dialogue: 0,0:19:36.66,0:19:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:19:40.67,0:19:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:19:42.20,0:19:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku tidak mau pulang."
Dialogue: 0,0:19:45.08,0:19:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan tinggalkan aku sendiri."
Dialogue: 0,0:19:47.63,0:19:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bilang begitu,
Dialogue: 0,0:19:49.00,0:19:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu bersedia menerimaku?
Dialogue: 0,0:19:52.24,0:19:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:19:54.01,0:19:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu mau, aku selalu siap.
Dialogue: 0,0:19:57.94,0:20:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap berada di sampingmu.
Dialogue: 0,0:20:03.82,0:20:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sekalian latihan menginap?
Dialogue: 0,0:20:12.24,0:20:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:20:13.98,0:20:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan kubiarkan sendirian.
Dialogue: 0,0:20:16.42,0:20:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:20:43.22,0:20:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya, Mahiru tidak menginap.
Dialogue: 0,0:20:50.00,0:20:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga dia baik-baik saja.
Dialogue: 0,0:20:53.69,0:20:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:20:55.36,0:20:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi, tidurmu nyenyak?
Dialogue: 0,0:20:57.74,0:21:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak semurung yang kamu takutkan.
Dialogue: 0,0:21:01.49,0:21:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua baik-baik saja.
Dialogue: 0,0:21:05.58,0:21:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang ketinggalan?
Dialogue: 0,0:21:08.12,0:21:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya tidak.
Dialogue: 0,0:21:10.12,0:21:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:21:11.71,0:21:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu seragu itu?
Dialogue: 0,0:21:15.46,0:21:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lupa ini, kan?
Dialogue: 0,0:21:20.18,0:21:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:21:24.14,0:21:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ada upacara sekolah.
Dialogue: 0,0:21:26.62,0:21:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian wajib lengkap.
Dialogue: 0,0:21:30.35,0:21:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:21:32.15,0:21:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:21:34.79,0:21:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma merasa diriku beruntung.
Dialogue: 0,0:21:38.30,0:21:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, sih.
Dialogue: 0,0:21:40.49,0:21:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kadang kamu ceroboh, ya.
Dialogue: 0,0:21:43.37,0:21:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:21:44.90,0:21:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin justru karena ada kamu.
Dialogue: 0,0:21:47.92,0:21:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:21:49.58,0:21:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu saja begitu.
Dialogue: 0,0:21:56.80,0:21:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat.
Dialogue: 0,0:21:59.46,0:22:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat.
