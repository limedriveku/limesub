Dialogue: 0,0:05:19.05,0:05:23.22,tanda,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:06:39.92,0:06:42.61,tanda,,0000,0000,0000,,#1 BERANGKAT SEKOLAH BERSAMA DAN DEBUT PACARAN
Dialogue: 0,0:14:29.97,0:14:31.31,tanda,,0000,0000,0000,,AH!
Dialogue: 0,0:15:55.39,0:15:56.85,tanda,,0000,0000,0000,,KETEBAK
Dialogue: 0,0:16:18.46,0:16:21.46,tanda,,0000,0000,0000,,BERBICARA TANPA HENTI, MAAF KAMI SALAH
Dialogue: 0,0:16:28.38,0:16:29.80,tanda,,0000,0000,0000,,SUPERMARKET YAMASAKO
Dialogue: 0,0:17:12.51,0:17:15.56,tanda,,0000,0000,0000,,BANGGA
Dialogue: 0,0:19:51.90,0:19:56.84,tanda,,0000,0000,0000,,PETUGAS PIKET: KIDO AYAKA, FUJIMIYA AMANE
Dialogue: 0,0:21:06.87,0:21:09.84,tanda,,0000,0000,0000,,BATANG PROTEIN
Dialogue: 0,0:23:34.93,0:23:39.94,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:50.86,0:00:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:00:53.24,0:00:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Selamat pagi.
Dialogue: 0,0:00:59.16,0:01:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pagi.
Dialogue: 0,0:01:01.83,0:01:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bidadari tinggal di sebelah rumahku.
Dialogue: 0,0:01:06.80,0:01:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan bidadari ini...
Dialogue: 0,0:01:10.66,0:01:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:01:12.11,0:01:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya berpacaran
Dialogue: 0,0:01:14.91,0:01:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan cinta pertama dalam hidupku,\NShiina Mahiru.
Dialogue: 0,0:01:36.78,0:01:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu.
Dialogue: 0,0:01:39.00,0:01:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku tidak suka.
Dialogue: 0,0:01:41.33,0:01:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja...
Dialogue: 0,0:01:43.41,0:01:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saling berdekatan sebagai pasangan\Nmembuatku malu
Dialogue: 0,0:01:48.05,0:01:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merasa gugup.
Dialogue: 0,0:01:50.63,0:01:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya...
Dialogue: 0,0:01:51.84,0:01:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa gugup.
Dialogue: 0,0:01:56.05,0:01:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena
Dialogue: 0,0:01:57.66,0:02:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perasaan ingin berada di sisimu
Dialogue: 0,0:02:01.75,0:02:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terasa lebih kuat.
Dialogue: 0,0:02:05.51,0:02:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Karena kita sudah mulai berpacaran,
Dialogue: 0,0:02:09.69,0:02:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurutku lebih baik mengikuti kata hati.
Dialogue: 0,0:02:16.74,0:02:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku lebih mendekatimu?
Dialogue: 0,0:02:20.29,0:02:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati.
Dialogue: 0,0:02:28.92,0:02:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:02:30.92,0:02:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu risi dekat-dekat denganku, ya?
Dialogue: 0,0:02:34.09,0:02:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan begitu.
Dialogue: 0,0:02:36.05,0:02:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu khawatir.
Dialogue: 0,0:02:37.73,0:02:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku bertanya satu hal?
Dialogue: 0,0:02:41.35,0:02:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-Boleh.
Dialogue: 0,0:02:43.39,0:02:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita...
Dialogue: 0,0:02:46.44,0:02:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita baru mulai pacaran, kan?
Dialogue: 0,0:02:49.44,0:02:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:02:51.48,0:02:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya apa yang dilakukan orang pacaran?
Dialogue: 0,0:02:56.74,0:02:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ini pengalaman pertamaku,
Dialogue: 0,0:03:00.41,0:03:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kurang tahu harus bagaimana.
Dialogue: 0,0:03:03.79,0:03:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar juga.
Dialogue: 0,0:03:06.69,0:03:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu kepikiran sesuatu?
Dialogue: 0,0:03:10.17,0:03:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpegangan tangan?
Dialogue: 0,0:03:11.55,0:03:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya juga begitu.
Dialogue: 0,0:03:12.88,0:03:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikmati hari libur bersama?
Dialogue: 0,0:03:14.97,0:03:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keseharian kita.
Dialogue: 0,0:03:17.47,0:03:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau main di luar?
Dialogue: 0,0:03:19.64,0:03:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah biasa.
Dialogue: 0,0:03:24.17,0:03:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan berpelukan?
Dialogue: 0,0:03:26.06,0:03:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah biasa juga.
Dialogue: 0,0:03:29.44,0:03:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku enggak enak bilangnya,
Dialogue: 0,0:03:32.61,0:03:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bilangnya juga bikin malu,
Dialogue: 0,0:03:35.99,0:03:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya tanpa status pacaran pun,\Nkita sudah seperti kekasih.
Dialogue: 0,0:03:45.50,0:03:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dia bilang begitu...
Dialogue: 0,0:03:47.92,0:03:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa dia bilang pun itu memang benar.
Dialogue: 0,0:03:49.90,0:03:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku selalu mengusahakan yang terbaik
Dialogue: 0,0:03:53.96,0:03:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya kamu berpaling padaku.
Dialogue: 0,0:03:56.92,0:03:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,
Dialogue: 0,0:03:58.76,0:04:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu memang hal yang biasa\Ndilakukan orang pacaran.
Dialogue: 0,0:04:02.27,0:04:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:03.85,0:04:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, daripada memusingkan status pacaran,
Dialogue: 0,0:04:07.77,0:04:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baiknya seperti biasanya saja.
Dialogue: 0,0:04:09.35,0:04:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita saling bersentuhan,
Dialogue: 0,0:04:12.06,0:04:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menghabiskan waktu bersama.
Dialogue: 0,0:04:15.78,0:04:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tanpa perlu mengikuti\Nstandar orang lain pun,
Dialogue: 0,0:04:19.77,0:04:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan melanjutkan keseharian kita saja\Nsudah lebih dari cukup, kan?
Dialogue: 0,0:04:27.21,0:04:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:04:28.41,0:04:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:29.71,0:04:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah gelisah begini.
Dialogue: 0,0:04:32.96,0:04:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena baru pertama,
Dialogue: 0,0:04:34.17,0:04:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bingung harus bagaimana.
Dialogue: 0,0:04:36.32,0:04:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:37.91,0:04:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begini,
Dialogue: 0,0:04:40.30,0:04:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memang akan seperti biasanya...
Dialogue: 0,0:04:42.72,0:04:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mulai sekarang,
Dialogue: 0,0:04:45.39,0:04:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menunjukkan perasaan cinta.
Dialogue: 0,0:04:47.64,0:04:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane.
Dialogue: 0,0:04:50.80,0:04:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah cukup membuatku bahagia.
Dialogue: 0,0:04:53.65,0:04:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:04:59.74,0:05:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari Senin,
Dialogue: 0,0:05:01.57,0:05:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}boleh aku berangkat sekolah bersamamu?
Dialogue: 0,0:05:05.12,0:05:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, boleh.
Dialogue: 0,0:06:39.92,0:06:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tibalah hari Senin...
Dialogue: 0,0:06:42.61,0:06:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari pertama ke sekolah\Nsejak kami berpacaran.
Dialogue: 0,0:06:49.18,0:06:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukannya aku sudah pernah bilang?
Dialogue: 0,0:06:52.14,0:06:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melepas baju saat aku di sini.
Dialogue: 0,0:06:55.10,0:06:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian aku tidak keberatan dilihat olehmu.
Dialogue: 0,0:06:57.44,0:06:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang keberatan.
Dialogue: 0,0:06:59.86,0:07:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mau ke kolam renang\Nsaat musim panas nanti?
Dialogue: 0,0:07:03.44,0:07:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membuatnya terbiasa.
Dialogue: 0,0:07:06.28,0:07:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya tidak jadi masalah nanti...
Dialogue: 0,0:07:10.12,0:07:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, begini,
Dialogue: 0,0:07:13.20,0:07:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}boleh minta tolong siapkan sarapan dulu?
Dialogue: 0,0:07:15.46,0:07:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku segera menyiapkannya.
Dialogue: 0,0:07:17.21,0:07:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi-pagi begini aku mikir apa, sih?
Dialogue: 0,0:07:22.70,0:07:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku sedikit rumit.
Dialogue: 0,0:07:24.97,0:07:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumit?
Dialogue: 0,0:07:26.51,0:07:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tidak bisa memonopoli\Ngaya rambutmu yang itu lagi.
Dialogue: 0,0:07:31.22,0:07:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau memonopolinya\Nsekarang selagi sempat?
Dialogue: 0,0:07:36.85,0:07:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang akan kulakukan.
Dialogue: 0,0:07:40.56,0:07:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya akan ada banyak cewek\Nyang mengajakmu mengobrol.
Dialogue: 0,0:07:45.44,0:07:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang melihatmu setampan ini, kok.
Dialogue: 0,0:07:47.61,0:07:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlepas dari tampan atau tidaknya,
Dialogue: 0,0:07:49.95,0:07:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pikir aku akan melirik cewek lain?
Dialogue: 0,0:07:51.99,0:07:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak.
Dialogue: 0,0:07:54.02,0:07:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap membuat hatiku tidak tenang.
Dialogue: 0,0:07:56.64,0:07:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cemburu?
Dialogue: 0,0:07:58.29,0:07:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:59.75,0:08:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, akan kutunjukkan betapa aku mencintaimu,\Nsampai tidak ada celah bagi orang lain.
Dialogue: 0,0:08:05.26,0:08:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berlebihan, ya.
Dialogue: 0,0:08:07.66,0:08:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau orang lain\Nmelihat sisi manismu.
Dialogue: 0,0:08:11.18,0:08:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu saja menggombal begitu!
Dialogue: 0,0:08:13.85,0:08:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya gombalanmu terlalu natural!
Dialogue: 0,0:08:16.39,0:08:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa jadi masalah?
Dialogue: 0,0:08:17.94,0:08:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku belum siap.
Dialogue: 0,0:08:19.90,0:08:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku yang bilang begitu.
Dialogue: 0,0:08:22.15,0:08:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifat manjamu yang tiba-tiba muncul juga
Dialogue: 0,0:08:24.95,0:08:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}suka bikin aku jantungan.
Dialogue: 0,0:08:27.07,0:08:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya gombalan spontanmu\Nefeknya mengena banget.
Dialogue: 0,0:08:33.28,0:08:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, karena kamu juga deg-degan,
Dialogue: 0,0:08:37.40,0:08:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan aku maklumi untuk hari ini.
Dialogue: 0,0:08:45.76,0:08:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya agak malu,
Dialogue: 0,0:08:48.47,0:08:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku senang.
Dialogue: 0,0:08:51.51,0:08:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aku masih capek gara-gara lari.
Dialogue: 0,0:08:54.41,0:08:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama.
Dialogue: 0,0:08:55.39,0:08:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal bidadari di hari festival olahraga...
Dialogue: 0,0:08:58.54,0:08:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bidadari?
Dialogue: 0,0:08:59.89,0:09:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatapan mereka terasa banget.
Dialogue: 0,0:09:02.06,0:09:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin takut masuk kelas.
Dialogue: 0,0:09:04.61,0:09:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah nasibmu.
Dialogue: 0,0:09:06.98,0:09:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kamu keberatan?
Dialogue: 0,0:09:08.82,0:09:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan.
Dialogue: 0,0:09:10.53,0:09:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya sudah memutuskan berubah.
Dialogue: 0,0:09:12.24,0:09:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:09:14.37,0:09:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru!
Dialogue: 0,0:09:18.04,0:09:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi!\NAkhirnya kamu jadian juga, Bang?
Dialogue: 0,0:09:20.79,0:09:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:09:21.75,0:09:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, selamat pagi.
Dialogue: 0,0:09:23.54,0:09:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya berjalan lancar.
Dialogue: 0,0:09:25.00,0:09:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:26.25,0:09:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, Mahiru.
Dialogue: 0,0:09:27.88,0:09:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sia-sia aku mendukungmu!
Dialogue: 0,0:09:30.22,0:09:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku sering curhat padamu.
Dialogue: 0,0:09:34.30,0:09:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya waktu kamu bingung\Nkarena Amane tidak peka, ya?
Dialogue: 0,0:09:36.81,0:09:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru.
Dialogue: 0,0:09:37.56,0:09:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}So-Soalnya kamu memang tidak peka.
Dialogue: 0,0:09:41.31,0:09:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, daripada itu,
Dialogue: 0,0:09:43.60,0:09:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini pertama kalinya aku melihat\Nversi maskulin Amane.
Dialogue: 0,0:09:47.07,0:09:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggilan macam apa itu?
Dialogue: 0,0:09:49.94,0:09:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose.
Dialogue: 0,0:09:51.85,0:09:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya...
Dialogue: 0,0:09:53.99,0:09:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak langsung mengabarimu.
Dialogue: 0,0:09:55.37,0:09:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah, kalian baru mulai pacaran\Nsetelah festival olahraga, kan?
Dialogue: 0,0:09:59.62,0:10:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti habis sibuk bermesraan.
Dialogue: 0,0:10:02.37,0:10:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada lewat pesan,
Dialogue: 0,0:10:04.46,0:10:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu lebih suka\Nmenyampaikan langsung, kan?
Dialogue: 0,0:10:06.84,0:10:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan, kok.
Dialogue: 0,0:10:08.75,0:10:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:09.59,0:10:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu sungkan.
Dialogue: 0,0:10:12.34,0:10:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sang pahlawan\Nyang telah menyatukan kalian berdua,
Dialogue: 0,0:10:15.64,0:10:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo puja aku lebih banyak lagi!
Dialogue: 0,0:10:18.89,0:10:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali aku akan traktir\Nkrep depan stasiun kesukaan Nona Chitose.
Dialogue: 0,0:10:23.69,0:10:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:10:28.52,0:10:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, Fujimiya.
Dialogue: 0,0:10:29.94,0:10:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kamu jadi bucin juga.
Dialogue: 0,0:10:31.69,0:10:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya bucin?\NDasar...
Dialogue: 0,0:10:34.86,0:10:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:10:36.37,0:10:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya perasaan kami berbalas.
Dialogue: 0,0:10:39.12,0:10:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panjang juga perjalanannya.
Dialogue: 0,0:10:41.16,0:10:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kami geregetan melihat kalian,
Dialogue: 0,0:10:43.16,0:10:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}senang mendengar kalian pacaran.
Dialogue: 0,0:10:45.04,0:10:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul itu, bahkan sudah setengah tahun\Naku memperhatikan mereka.
Dialogue: 0,0:10:48.96,0:10:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama banget baru jadi sekarang,\Ndasar pengecut.
Dialogue: 0,0:10:51.88,0:10:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel, ah, tapi maaf.
Dialogue: 0,0:10:54.13,0:10:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng... Fujimiya?
Dialogue: 0,0:10:59.14,0:11:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benaran Fujimiya!
Dialogue: 0,0:11:01.39,0:11:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai pangling\Nkarena kamu beda dari biasanya.
Dialogue: 0,0:11:04.14,0:11:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Auranya jadi sangat berbeda, ya.
Dialogue: 0,0:11:06.35,0:11:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, padahal dulu kelihatan culun.
Dialogue: 0,0:11:09.32,0:11:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, itu tidak sopan.
Dialogue: 0,0:11:11.73,0:11:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Fujimiya.
Dialogue: 0,0:11:13.44,0:11:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, karena memang culun.
Dialogue: 0,0:11:16.53,0:11:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benaran mengubah penampilan.
Dialogue: 0,0:11:18.95,0:11:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aneh tidak?
Dialogue: 0,0:11:20.74,0:11:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.\NJustru terlihat jauh lebih baik.
Dialogue: 0,0:11:24.46,0:11:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, boleh bertanya satu hal?
Dialogue: 0,0:11:26.79,0:11:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:11:28.67,0:11:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian berpacaran?
Dialogue: 0,0:11:31.00,0:11:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku melihat kalian\Nberpegangan tangan.
Dialogue: 0,0:11:33.55,0:11:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, berkat dukungan semuanya.
Dialogue: 0,0:11:35.83,0:11:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mulai pacaran minggu lalu.
Dialogue: 0,0:11:39.18,0:11:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalian bisa pacaran?
Dialogue: 0,0:11:41.89,0:11:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mulai interaksi tahun lalu,
Dialogue: 0,0:11:43.81,0:11:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus tiba-tiba jadi dekat.
Dialogue: 0,0:11:45.94,0:11:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan, Mahiru?
Dialogue: 0,0:11:47.31,0:11:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:48.81,0:11:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang agak sulit dijelaskan,
Dialogue: 0,0:11:50.98,0:11:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kami sudah melalui banyak hal\Nsebelum mulai berpacaran.
Dialogue: 0,0:11:53.86,0:11:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini cintaku\Nyang bertepuk sebelah tangan,
Dialogue: 0,0:11:57.07,0:11:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku benar-benar senang,
Dialogue: 0,0:11:59.24,0:12:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merasa ingin pamer dengan menggandeng\Ntangannya saat berangkat sekolah.
Dialogue: 0,0:12:03.04,0:12:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, seharusnya aku yang naksir duluan.
Dialogue: 0,0:12:06.79,0:12:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku duluan.
Dialogue: 0,0:12:09.83,0:12:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun yang duluan,
Dialogue: 0,0:12:10.96,0:12:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane tidak kunjung nembak aku.
Dialogue: 0,0:12:14.00,0:12:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyesali soal itu.
Dialogue: 0,0:12:17.55,0:12:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah nembak kamu,\Njadi maafkan aku.
Dialogue: 0,0:12:20.34,0:12:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja aku yang inisiatif duluan.
Dialogue: 0,0:12:23.72,0:12:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali aku yang akan begitu.
Dialogue: 0,0:12:25.89,0:12:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ada rencana apa?
Dialogue: 0,0:12:27.56,0:12:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya?
Dialogue: 0,0:12:28.56,0:12:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengelak pertanyaanku lagi.
Dialogue: 0,0:12:31.06,0:12:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali aku kasih tahu.
Dialogue: 0,0:12:33.57,0:12:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:12:43.78,0:12:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane.
Dialogue: 0,0:12:45.14,0:12:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian itu sering bermesraan tanpa sadar,\Njadi berhati-hatilah.
Dialogue: 0,0:12:48.46,0:12:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya...
Dialogue: 0,0:12:57.97,0:13:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bagus sekali.\N- Benar.
Dialogue: 0,0:13:00.97,0:13:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, nanti juga akan dianggap angin lalu.
Dialogue: 0,0:13:03.97,0:13:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:13:05.26,0:13:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti akan bosan\Nkalau gosipnya itu saja.
Dialogue: 0,0:13:08.39,0:13:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga tertutup sama yang lain.
Dialogue: 0,0:13:10.85,0:13:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau begitu.
Dialogue: 0,0:13:13.61,0:13:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tongkrongan langka, nih.
Dialogue: 0,0:13:15.86,0:13:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gabung sama Kokonoe dan Hiiragi\Ndalam pertempuran kavaleri.
Dialogue: 0,0:13:19.07,0:13:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadowaki yang mengajak.
Dialogue: 0,0:13:21.11,0:13:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang melihatmu\Nbisa bergaul dengan temanku.
Dialogue: 0,0:13:23.99,0:13:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kalian berani juga.
Dialogue: 0,0:13:26.20,0:13:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya berangkat sekolah\Nsambil pegangan tangan.
Dialogue: 0,0:13:28.50,0:13:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamer banget, deh.
Dialogue: 0,0:13:30.21,0:13:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya banyak orang\Nyang berterima kasih
Dialogue: 0,0:13:32.54,0:13:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kalian menunjukkan hal itu.
Dialogue: 0,0:13:34.53,0:13:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berterima kasih?
Dialogue: 0,0:13:35.42,0:13:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya para cowok\Nyang mengincar Shiina jadi menyerah.
Dialogue: 0,0:13:38.51,0:13:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para cewek pun lega melihatnya.
Dialogue: 0,0:13:40.38,0:13:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persaingan para cewek ngeri juga.
Dialogue: 0,0:13:43.01,0:13:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku berharap mereka bisa mengerti\Nkalau Mahiru hanya cewek biasa juga.
Dialogue: 0,0:13:48.35,0:13:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia malu juga dipanggil bidadari.
Dialogue: 0,0:13:51.06,0:13:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganku?
Dialogue: 0,0:13:53.69,0:13:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa, kok.
Dialogue: 0,0:13:55.36,0:13:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami cuma membicarakan\Nkalau kamu juga hanya cewek biasa.
Dialogue: 0,0:13:58.23,0:14:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa sampai membicarakan itu?
Dialogue: 0,0:14:01.32,0:14:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal teman-teman kita baru pada sadar\Nkalau kamu cuma cewek biasa juga.
Dialogue: 0,0:14:07.16,0:14:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:09.12,0:14:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sudah mulai\Ntidak memusingkan anggapan sekitar.
Dialogue: 0,0:14:13.50,0:14:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:14:14.50,0:14:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:15.73,0:14:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama Amane menganggapku sebagai\Ncewek biasa, itu sudah cukup.
Dialogue: 0,0:14:23.34,0:14:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya, coba kendalikan sedikit pacarmu.
Dialogue: 0,0:14:27.43,0:14:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat cinta mati padamu.
Dialogue: 0,0:14:29.39,0:14:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:32.14,0:14:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, Amane.
Dialogue: 0,0:14:34.35,0:14:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:35.23,0:14:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bento buatan Mahiru kelihatan lezat sekali.
Dialogue: 0,0:14:38.32,0:14:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kukasih.
Dialogue: 0,0:14:39.15,0:14:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelit.
Dialogue: 0,0:14:40.11,0:14:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose, mau bertukar lauk denganku?
Dialogue: 0,0:14:44.95,0:14:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang terbaik!
Dialogue: 0,0:14:47.16,0:14:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:14:53.00,0:14:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara makanmu lahap banget, Fujimiya.
Dialogue: 0,0:14:56.33,0:14:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena betulan lezat.
Dialogue: 0,0:14:57.54,0:14:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas lezat, sih.
Dialogue: 0,0:14:59.63,0:15:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatmu menikmatinya dengan lahap,
Dialogue: 0,0:15:02.05,0:15:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti jadi kebahagiaan bagi Shiina.
Dialogue: 0,0:15:04.76,0:15:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:15:06.09,0:15:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur tiap kali mendengarnya\Nmemuji masakanku.
Dialogue: 0,0:15:09.85,0:15:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengerti selera Amane,
Dialogue: 0,0:15:12.60,0:15:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi akan kutingkatkan lagi.
Dialogue: 0,0:15:14.39,0:15:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti sekarang juga sudah cukup.
Dialogue: 0,0:15:15.94,0:15:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin hasilnya sesuai seleramu.
Dialogue: 0,0:15:19.44,0:15:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa menyesuaikan seleramu.
Dialogue: 0,0:15:21.90,0:15:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya semua masakanmu pasti lezat.
Dialogue: 0,0:15:24.90,0:15:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengah sedikit langsung bermesraan,\Nbagaimana nantinya ini?
Dialogue: 0,0:15:28.20,0:15:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak bermesraan.
Dialogue: 0,0:15:29.62,0:15:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya dia bilang begitu, Chi.
Dialogue: 0,0:15:31.16,0:15:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya perilaku seperti itu\Ntidak dianggap bermesraan bagi mereka.
Dialogue: 0,0:15:36.75,0:15:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lezatnya!
Dialogue: 0,0:15:38.71,0:15:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini...
Dialogue: 0,0:15:40.46,0:15:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, anggap sama pernyataan hubungan,
Dialogue: 0,0:15:43.13,0:15:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya tidak ada yang mengganggu.
Dialogue: 0,0:15:46.05,0:15:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira kamu sengaja.
Dialogue: 0,0:15:48.47,0:15:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asli.
Dialogue: 0,0:15:49.68,0:15:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang dengan kedekatan kalian.
Dialogue: 0,0:15:51.60,0:15:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kalian gampang merasa\Ndunia milik berdua,
Dialogue: 0,0:15:53.68,0:15:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya lebih berhati-hati lagi.
Dialogue: 0,0:16:01.06,0:16:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini terasa sangat panjang.
Dialogue: 0,0:16:03.90,0:16:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti capek.
Dialogue: 0,0:16:05.78,0:16:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu cukup kesulitan hari ini.
Dialogue: 0,0:16:08.61,0:16:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mereka tidak berniat jahat juga, sih.
Dialogue: 0,0:16:11.41,0:16:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan ingin melampiaskan\Nketidakpuasan saja.
Dialogue: 0,0:16:14.58,0:16:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:16:15.20,0:16:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- karena kamu terlalu memuji kelebihanku,\N- Amane sangat baik...
Dialogue: 0,0:16:18.46,0:16:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka jadi malas memusuhiku.
Dialogue: 0,0:16:21.46,0:16:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau waktunya memungkinkan,
Dialogue: 0,0:16:22.92,0:16:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya aku bisa pamer\Nlebih banyak kelebihanmu.
Dialogue: 0,0:16:26.38,0:16:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampun, dong.
Dialogue: 0,0:16:29.80,0:16:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa keuntungan mempublikasikan\Nhubungan ini adalah
Dialogue: 0,0:16:33.93,0:16:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita jadi bisa belanja bareng begini.
Dialogue: 0,0:16:37.06,0:16:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sebelumnya memang agak susah.
Dialogue: 0,0:16:40.35,0:16:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:41.56,0:16:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang kita bisa berbelanja bersama
Dialogue: 0,0:16:44.11,0:16:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa harus sembunyi-sembunyi lagi.
Dialogue: 0,0:16:45.57,0:16:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:46.92,0:16:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga bisa langsung diskusi\Nmau memasak apa.
Dialogue: 0,0:16:49.92,0:16:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:52.12,0:16:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kebanyakan makan daging,
Dialogue: 0,0:16:53.66,0:16:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik besok ikan saja, ya.
Dialogue: 0,0:16:56.66,0:16:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau yang mana?
Dialogue: 0,0:16:58.08,0:17:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya aku mau bilang terserah...
Dialogue: 0,0:17:01.12,0:17:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:17:02.76,0:17:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin makan ikan makerel.
Dialogue: 0,0:17:04.17,0:17:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan memang lagi musimnya.
Dialogue: 0,0:17:06.55,0:17:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan masak\Nikan makerel goreng asam manis.
Dialogue: 0,0:17:08.80,0:17:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu asam, kan?
Dialogue: 0,0:17:10.58,0:17:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar memahamiku.
Dialogue: 0,0:17:12.51,0:17:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah masak selama enam bulan untukmu.
Dialogue: 0,0:17:16.34,0:17:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacaran setelah pendekatan enam bulan,\Nsebenarnya terhitung cepat juga.
Dialogue: 0,0:17:19.84,0:17:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menurutku, justru terlalu lama.
Dialogue: 0,0:17:22.84,0:17:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tahu aku naksir sama kamu,\Ntapi kamu pura-pura tidak tahu.
Dialogue: 0,0:17:27.15,0:17:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:29.74,0:17:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud mengungkitnya.
Dialogue: 0,0:17:32.86,0:17:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting sekarang aku tahu\Nbahwa kamu mencintaiku.
Dialogue: 0,0:17:37.95,0:17:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:38.70,0:17:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lebih menunjukkan perasaanku lagi.
Dialogue: 0,0:17:41.37,0:17:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, aku juga akan melakukannya.
Dialogue: 0,0:17:45.17,0:17:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan berlebihan, ya,\Nakunya yang tidak kuat.
Dialogue: 0,0:17:49.76,0:17:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak kuat?
Dialogue: 0,0:17:52.09,0:17:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuatku jadi serigala.
Dialogue: 0,0:17:55.30,0:17:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku akan berhati-hati.
Dialogue: 0,0:17:58.03,0:17:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:06.11,0:18:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Itsuki.
Dialogue: 0,0:18:07.32,0:18:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, sobat?
Dialogue: 0,0:18:09.82,0:18:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya Mahiru jadi lebih populer\Ndari sebelum kami pacaran, deh.
Dialogue: 0,0:18:13.45,0:18:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu,
Dialogue: 0,0:18:15.20,0:18:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya aku bisa menebak alasannya.
Dialogue: 0,0:18:18.54,0:18:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:19.75,0:18:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:18:21.33,0:18:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini dia terasa seperti berlian mewah\Nyang tidak boleh disentuh.
Dialogue: 0,0:18:25.63,0:18:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jadi lebih mudah didekati sekarang.
Dialogue: 0,0:18:29.05,0:18:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu dia terasa sangat jauh\Ndan sulit didekati,
Dialogue: 0,0:18:32.09,0:18:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sejak bersamamu,\Nauranya jadi jauh lebih lembut.
Dialogue: 0,0:18:35.89,0:18:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menjelaskannya, ya?
Dialogue: 0,0:18:38.22,0:18:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku sedikit rumit.
Dialogue: 0,0:18:40.83,0:18:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi dirinya yang hanya diketahui\Noleh orang terdekat itu,
Dialogue: 0,0:18:44.31,0:18:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah diketahui banyak orang.
Dialogue: 0,0:18:46.73,0:18:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku merasa senang,
Dialogue: 0,0:18:50.15,0:18:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi malah terasa sesak.
Dialogue: 0,0:18:53.24,0:18:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa sangat egois.
Dialogue: 0,0:18:55.61,0:18:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifat posesifmu mulai keluar, nih!
Dialogue: 0,0:19:00.49,0:19:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah,
Dialogue: 0,0:19:01.20,0:19:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti masih banyak sisi lain dari dirinya, kan?
Dialogue: 0,0:19:04.79,0:19:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu saat nanti dia akan menunjukkan\Nsemuanya padamu.
Dialogue: 0,0:19:08.00,0:19:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga, sih.
Dialogue: 0,0:19:11.63,0:19:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, sepertinya
Dialogue: 0,0:19:13.13,0:19:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan lingkungan di sekitar\NMahiru saja yang berubah.
Dialogue: 0,0:19:17.34,0:19:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah berpacaran dengan Shiina,
Dialogue: 0,0:19:19.10,0:19:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu jadi lebih asyik diajak mengobrol.
Dialogue: 0,0:19:22.69,0:19:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:19:23.73,0:19:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah banyak berubah.
Dialogue: 0,0:19:25.64,0:19:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum mengubah penampilan,\Nkamu juga sulit didekati.
Dialogue: 0,0:19:30.01,0:19:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu memancarkan aura\N"jangan bicara padaku".
Dialogue: 0,0:19:32.90,0:19:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir kamu hanya pemalu.
Dialogue: 0,0:19:34.82,0:19:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:19:37.03,0:19:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malah minta maaf, dong.
Dialogue: 0,0:19:39.81,0:19:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga bagian dari kepribadianmu.
Dialogue: 0,0:19:43.45,0:19:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berhak menghakimi.
Dialogue: 0,0:19:45.58,0:19:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin temanmu sedikit,\Ntapi akrab semua, ya?
Dialogue: 0,0:19:51.90,0:19:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka memperhatikan sekitar, ya?
Dialogue: 0,0:19:54.34,0:19:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang itu salah satu hobiku.
Dialogue: 0,0:19:56.84,0:20:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku merasa tidak boleh\Nterus menutup diri begini.
Dialogue: 0,0:20:02.08,0:20:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu demi Shiina?
Dialogue: 0,0:20:03.60,0:20:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:20:05.21,0:20:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya demi diriku sendiri.
Dialogue: 0,0:20:09.21,0:20:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendampingi Mahiru,
Dialogue: 0,0:20:11.90,0:20:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi perlu berhenti menutup diri.
Dialogue: 0,0:20:13.94,0:20:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini murni keputusanku.
Dialogue: 0,0:20:16.86,0:20:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Shiina sangat dicintai olehmu.
Dialogue: 0,0:20:19.06,0:20:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa menarik kesimpulan seperti itu?
Dialogue: 0,0:20:22.45,0:20:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya memang seperti itu.
Dialogue: 0,0:20:24.94,0:20:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:26.83,0:20:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, kamu benaran mencintainya, Bang.
Dialogue: 0,0:20:30.42,0:20:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, kamu tidak akan berubah.
Dialogue: 0,0:20:33.84,0:20:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubah demi orang yang dicintai...
Dialogue: 0,0:20:36.26,0:20:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kedengarannya kurang bagus.
Dialogue: 0,0:20:39.43,0:20:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuang untuk jadi pantas\Nbagi orang yang dicintai
Dialogue: 0,0:20:41.72,0:20:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu hal yang indah.
Dialogue: 0,0:20:43.76,0:20:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah namanya cinta.
Dialogue: 0,0:20:45.47,0:20:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hubungannya?
Dialogue: 0,0:20:47.39,0:20:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya bagus.
Dialogue: 0,0:20:49.39,0:20:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian Shiina juga\Nterlihat sangat mencintaimu.
Dialogue: 0,0:20:53.32,0:20:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu, Amane.
Dialogue: 0,0:20:55.90,0:20:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusanmu sudah selesai?
Dialogue: 0,0:20:57.19,0:20:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kalau kamu bagaimana?
Dialogue: 0,0:20:59.36,0:21:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah menyelesaikannya.
Dialogue: 0,0:21:01.62,0:21:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya, terima kasih atas bantuannya.
Dialogue: 0,0:21:04.70,0:21:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah terima kasih.
Dialogue: 0,0:21:06.87,0:21:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat enak.
Dialogue: 0,0:21:08.04,0:21:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu kasih hadiah.
Dialogue: 0,0:21:09.84,0:21:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa memberiku ini?
Dialogue: 0,0:21:11.42,0:21:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu.
Dialogue: 0,0:21:17.09,0:21:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu seperti ingin bilang sesuatu.
Dialogue: 0,0:21:20.22,0:21:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak sedang mencurigaimu.
Dialogue: 0,0:21:23.22,0:21:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja kalian kelihatan\Nmengobrol dengan asyik.
Dialogue: 0,0:21:27.10,0:21:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah membuatmu cemas.
Dialogue: 0,0:21:29.28,0:21:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan dia hanya bilang\Nkalau aku berubah.
Dialogue: 0,0:21:34.36,0:21:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini,\Nkamu jadi lebih sering tersenyum.
Dialogue: 0,0:21:38.40,0:21:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku bisa berubah,
Dialogue: 0,0:21:40.45,0:21:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena selalu bersamamu.
Dialogue: 0,0:21:42.95,0:21:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kalau dipikir-pikir lagi,
Dialogue: 0,0:21:45.16,0:21:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pun jadi lebih bersemangat.
Dialogue: 0,0:21:47.58,0:21:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti itu juga\Nkarena aku selalu bersamamu.
Dialogue: 0,0:21:52.21,0:21:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:22:01.22,0:22:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
