Dialogue: 0,0:00:25.42,0:00:27.67,tanda,,0000,0000,0000,,FESTIVAL KEMBANG API
Dialogue: 0,0:01:34.07,0:01:38.24,tanda,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:03:40.20,0:03:45.46,tanda,,0000,0000,0000,,HANADA
Dialogue: 0,0:05:42.49,0:05:48.71,tanda,,0000,0000,0000,,INI CALYLOPHUS HYBRID SUNNY CHIRP
Dialogue: 0,0:05:48.71,0:05:52.69,tanda,,0000,0000,0000,,KAMI BARU MENANAMNYA
Dialogue: 0,0:05:52.69,0:05:55.50,tanda,,0000,0000,0000,,OH, BEGITU...
Dialogue: 0,0:09:39.56,0:09:47.07,tanda,,0000,0000,0000,,#5 FESTIVAL MUSIM PANAS BERSAMA BIDADARI
Dialogue: 0,0:10:41.70,0:10:44.40,tanda,,0000,0000,0000,,TEMBAK HADIAH
Dialogue: 0,0:11:51.52,0:11:54.53,tanda,,0000,0000,0000,,HOT DOG AMERIKA, YAKISOBA, TOPOKKI
Dialogue: 0,0:13:52.77,0:13:53.43,tanda,,0000,0000,0000,,KREP
Dialogue: 0,0:14:54.41,0:14:58.29,tanda,,0000,0000,0000,,KAKIGORI
Dialogue: 0,0:16:33.32,0:16:35.93,tanda,,0000,0000,0000,,DIAMPUNI
Dialogue: 0,0:16:39.98,0:16:42.19,tanda,,0000,0000,0000,,NYUT
Dialogue: 0,0:23:34.93,0:23:45.41,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:06.21,0:00:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang panas, ya.
Dialogue: 0,0:00:09.49,0:00:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pulang saja?
Dialogue: 0,0:00:11.75,0:00:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:00:13.49,0:00:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak pakai payung?
Dialogue: 0,0:00:17.41,0:00:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kamu sudah banyak\Nmengolesiku tabir surya.
Dialogue: 0,0:00:21.49,0:00:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus lebih menyayangi diri sendiri.
Dialogue: 0,0:00:27.67,0:00:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini, Amane.
Dialogue: 0,0:00:30.51,0:00:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, semua tempat lagi heboh\Nfestival musim panas dan kembang api.
Dialogue: 0,0:00:36.39,0:00:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Digelarnya setelah kita pulang.
Dialogue: 0,0:00:39.81,0:00:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:00:41.24,0:00:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi.\NKamu ingin ke sana?
Dialogue: 0,0:00:44.60,0:00:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, soalnya belum pernah.
Dialogue: 0,0:00:47.99,0:00:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa boleh buat.
Dialogue: 0,0:00:50.73,0:00:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:00:52.16,0:00:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama bisa bersamamu,
Dialogue: 0,0:00:55.75,0:00:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah puas.
Dialogue: 0,0:00:57.66,0:01:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan serangan kejutan itu.
Dialogue: 0,0:01:00.66,0:01:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya perasaanku selalu menyertaimu.
Dialogue: 0,0:01:04.64,0:01:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:01:15.53,0:01:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang Amane.
Dialogue: 0,0:01:17.22,0:01:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:54.78,0:02:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...\NAmane, siapa dia?
Dialogue: 0,0:02:58.41,0:03:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf mengagetkanmu.
Dialogue: 0,0:03:01.49,0:03:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adik dari teman\Nyang dulu sering kuajak main.
Dialogue: 0,0:03:05.39,0:03:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang Amane kenal Mbak ini?
Dialogue: 0,0:03:08.88,0:03:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, aku...
Dialogue: 0,0:03:11.33,0:03:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pacarku.
Dialogue: 0,0:03:13.63,0:03:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacar?
Dialogue: 0,0:03:15.59,0:03:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, kekasih?
Dialogue: 0,0:03:17.55,0:03:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, dia kekasihku yang tercinta.
Dialogue: 0,0:03:22.61,0:03:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:03:24.44,0:03:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mu-Mustahil.
Dialogue: 0,0:03:26.52,0:03:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang Amane punya pacar?
Dialogue: 0,0:03:29.32,0:03:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu sekaget itu?
Dialogue: 0,0:03:31.73,0:03:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, abangku belum pernah\Nbawa cewek ke rumah.
Dialogue: 0,0:03:36.33,0:03:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal abangku bilang\NBang Amane juga senasib.
Dialogue: 0,0:03:40.20,0:03:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga jodoh.
Dialogue: 0,0:03:42.92,0:03:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaname, siapa yang kamu...
Dialogue: 0,0:03:45.46,0:03:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Abang!
Dialogue: 0,0:03:48.61,0:03:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:03:52.08,0:03:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir kita bicara, dua...\NEh, malah tiga tahun lalu.
Dialogue: 0,0:03:56.63,0:03:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kamu baik-baik saja.
Dialogue: 0,0:03:58.75,0:04:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya itu ucapanku.
Dialogue: 0,0:04:02.27,0:04:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kamu melebihi perkiraanku.
Dialogue: 0,0:04:07.95,0:04:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaname, antar Mbak ini\Nkeliling halaman kita.
Dialogue: 0,0:04:11.65,0:04:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:04:12.35,0:04:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gih, Ibu mengeluh karena ngebet\Nmemamerkan halamannya, kan?
Dialogue: 0,0:04:17.89,0:04:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang mau mengobrol sama Bang Amane?
Dialogue: 0,0:04:21.77,0:04:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, obrolan antara pria.
Dialogue: 0,0:04:28.04,0:04:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, Mbak, ayo sini.
Dialogue: 0,0:04:31.50,0:04:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, sampai nanti.
Dialogue: 0,0:04:35.29,0:04:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sampai nanti.
Dialogue: 0,0:04:38.17,0:04:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pacarmu?
Dialogue: 0,0:04:40.05,0:04:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dia ikut pulang bersamaku.
Dialogue: 0,0:04:43.41,0:04:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka kamu dapat pacar.
Dialogue: 0,0:04:46.71,0:04:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup memang penuh misteri.
Dialogue: 0,0:04:48.99,0:04:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meremehkan banget.
Dialogue: 0,0:04:52.98,0:04:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya, hidupmu di sana lancar jaya.
Dialogue: 0,0:04:57.09,0:04:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, berkat dirimu juga.
Dialogue: 0,0:04:59.49,0:05:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu sindiran?
Dialogue: 0,0:05:01.35,0:05:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu berpikir begitu?
Dialogue: 0,0:05:05.43,0:05:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, di sini kita gagal.
Dialogue: 0,0:05:10.21,0:05:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga.
Dialogue: 0,0:05:13.08,0:05:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak menyalahkanmu.
Dialogue: 0,0:05:16.85,0:05:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma juga terpaku sama masa lalu.
Dialogue: 0,0:05:21.81,0:05:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:23.72,0:05:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagimu, itu sudah jadi angin lalu, ya.
Dialogue: 0,0:05:27.52,0:05:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sudah kuanggap sebagai angin lalu.
Dialogue: 0,0:05:32.23,0:05:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga tambah tangguh\Ndalam banyak hal, ya.
Dialogue: 0,0:05:36.23,0:05:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:05:37.23,0:05:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku sudah jadi pria\Nyang lebih baik.
Dialogue: 0,0:05:42.49,0:05:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:05:44.40,0:05:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jelas, kamu tampak lebih bahagia.
Dialogue: 0,0:05:48.71,0:05:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, hidupku sudah enak.
Dialogue: 0,0:05:52.69,0:05:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, pacarku menunggu.
Dialogue: 0,0:05:56.04,0:05:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Mbak.
Dialogue: 0,0:05:58.84,0:06:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:06:01.26,0:06:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya.
Dialogue: 0,0:06:06.35,0:06:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dah.
Dialogue: 0,0:06:08.68,0:06:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:12.72,0:06:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata "sampai jumpa" tidak terucap
Dialogue: 0,0:06:16.36,0:06:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kami tidak sungguh-sungguh\Ningin saling bertemu lagi.
Dialogue: 0,0:06:22.35,0:06:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanada di kampung ini
Dialogue: 0,0:06:24.65,0:06:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku di tempat baru.
Dialogue: 0,0:06:27.07,0:06:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menata hidup masing-masing.
Dialogue: 0,0:06:30.57,0:06:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup begitu saja.
Dialogue: 0,0:06:34.46,0:06:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa hari ini, kamu berhasil\Nmenghadapi masa lalumu, ya.
Dialogue: 0,0:06:40.17,0:06:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:41.68,0:06:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, sebuah hubungan\Nmemang perlu evaluasi.
Dialogue: 0,0:06:46.03,0:06:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku itu hal penting
Dialogue: 0,0:06:48.68,0:06:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya selangkah lebih maju.
Dialogue: 0,0:06:50.87,0:06:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:06:53.83,0:07:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku juga harus mencontohmu\Ndalam menghadapi masalah.
Dialogue: 0,0:07:06.99,0:07:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian benaran mau pulang?
Dialogue: 0,0:07:09.41,0:07:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:07:10.62,0:07:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, bolehkah aku datang lagi lain kali?
Dialogue: 0,0:07:16.08,0:07:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh banget!\NPokoknya wajib!
Dialogue: 0,0:07:19.38,0:07:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:21.75,0:07:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, Mahiru.
Dialogue: 0,0:07:24.16,0:07:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:25.04,0:07:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau Shiina betah di sini.
Dialogue: 0,0:07:28.72,0:07:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, aku khawatir\Nkamu akan bersikap sungkan.
Dialogue: 0,0:07:32.77,0:07:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking kuatnya tekanan Ibu,\Ntidak ada waktu untuk sungkan.
Dialogue: 0,0:07:37.24,0:07:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat itu dia jadi terbiasa.
Dialogue: 0,0:07:39.51,0:07:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlepas baik buruknya,\NShihoko memang pemaksa.
Dialogue: 0,0:07:42.51,0:07:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian dengan entengnya menyindirku?
Dialogue: 0,0:07:46.40,0:07:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku itu sisi baik sekaligus pesonamu.
Dialogue: 0,0:07:50.83,0:07:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh!
Dialogue: 0,0:07:52.08,0:07:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa saja.
Dialogue: 0,0:07:55.24,0:07:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, saatnya pergi.
Dialogue: 0,0:07:57.08,0:07:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:58.71,0:08:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, datanglah lagi.
Dialogue: 0,0:08:01.88,0:08:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertengkar sama Amane,
Dialogue: 0,0:08:04.07,0:08:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bilang saja kamu mau pulang,\Nlalu datanglah kemari.
Dialogue: 0,0:08:07.55,0:08:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:08:09.09,0:08:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir aku akan\Nmenyakiti Mahiru separah itu?
Dialogue: 0,0:08:13.00,0:08:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya salah paham\Ndan beda pendapat pasti ada.
Dialogue: 0,0:08:16.96,0:08:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada momen kalian ingin sendiri\Ndan butuh bantuan orang dewasa.
Dialogue: 0,0:08:22.84,0:08:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada apa-apa, datanglah kapan saja.
Dialogue: 0,0:08:26.33,0:08:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan selalu menyambutmu.
Dialogue: 0,0:08:31.43,0:08:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:34.15,0:08:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap, Mahiru bisa sedikit merasakan\Nkebahagiaan sebuah keluarga.
Dialogue: 0,0:08:40.28,0:08:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke depannya pun,
Dialogue: 0,0:08:41.71,0:08:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semoga kami berdua diberkahi
Dialogue: 0,0:08:44.21,0:08:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berbagai kebahagiaan.
Dialogue: 0,0:09:02.77,0:09:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, yukata.
Dialogue: 0,0:09:04.37,0:09:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun imut banget!
Dialogue: 0,0:09:06.90,0:09:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa,\Nyukata ini dari ibuku.
Dialogue: 0,0:09:11.23,0:09:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selera Shihoko memang oke.
Dialogue: 0,0:09:15.19,0:09:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok sekali.
Dialogue: 0,0:09:16.66,0:09:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yey, yey, yey!\N- Ibu memang jagonya soal begini.
Dialogue: 0,0:09:22.12,0:09:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis cantik beryukata\Nmemang memanjakan mata.
Dialogue: 0,0:09:24.48,0:09:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikkun, bagaimana denganku?
Dialogue: 0,0:09:26.80,0:09:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chi selalu imut kapan pun\Ndan di mana pun.
Dialogue: 0,0:09:30.30,0:09:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu terbahak-bahak\Nsaat aku maskeran.
Dialogue: 0,0:09:33.32,0:09:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu juga imut, kok.
Dialogue: 0,0:09:35.44,0:09:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa tertawa?
Dialogue: 0,0:09:40.17,0:09:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo berkeliling.
Dialogue: 0,0:09:41.79,0:09:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung lagi festival.
Dialogue: 0,0:09:43.96,0:09:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo makan!
Dialogue: 0,0:09:47.07,0:09:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramai sekali.
Dialogue: 0,0:09:49.51,0:09:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, jangan sampai terpisah.
Dialogue: 0,0:09:52.53,0:09:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun, jangan lepaskan Amane, ya.
Dialogue: 0,0:09:56.33,0:09:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan.
Dialogue: 0,0:09:57.65,0:09:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cie, cie.
Dialogue: 0,0:09:59.68,0:10:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, kamu mau melihat\Natau makan sesuatu?
Dialogue: 0,0:10:03.64,0:10:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini festival pertamaku.
Dialogue: 0,0:10:06.39,0:10:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang ada apa saja?
Dialogue: 0,0:10:08.21,0:10:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terkenal, ada yakisoba, takoyaki,
Dialogue: 0,0:10:11.88,0:10:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ikayaki, dan sosis bakar.
Dialogue: 0,0:10:14.43,0:10:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku mau permen kapas!
Dialogue: 0,0:10:17.39,0:10:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal ribet kalau beli itu dari awal,
Dialogue: 0,0:10:19.96,0:10:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}didiamkan pun bakal melempem.
Dialogue: 0,0:10:23.03,0:10:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kita tentukan sambil jalan?
Dialogue: 0,0:10:25.52,0:10:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, justru itulah letak serunya festival.
Dialogue: 0,0:10:38.92,0:10:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, apa itu?
Dialogue: 0,0:10:41.70,0:10:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tembak hadiah.
Dialogue: 0,0:10:44.40,0:10:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah yang kita jatuhkan\Npakai peluru gabus boleh diambil.
Dialogue: 0,0:10:48.69,0:10:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba?
Dialogue: 0,0:10:49.87,0:10:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau.
Dialogue: 0,0:10:54.72,0:10:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang kamu bidik?
Dialogue: 0,0:10:56.96,0:10:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya yang itu lucu.
Dialogue: 0,0:11:03.64,0:11:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit, ya.
Dialogue: 0,0:11:05.80,0:11:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, membidik saja cukup sulit\Nkalau buat pemula.
Dialogue: 0,0:11:10.40,0:11:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini pasti kena.
Dialogue: 0,0:11:16.03,0:11:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meleset semua.
Dialogue: 0,0:11:18.40,0:11:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:11:19.78,0:11:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, itu wajar bagi pemula.
Dialogue: 0,0:11:23.05,0:11:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar Amane yang membalasnya.
Dialogue: 0,0:11:25.33,0:11:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:25.77,0:11:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlihatkan sisi kerenmu, dong!
Dialogue: 0,0:11:28.63,0:11:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yo!\N- Jangan asal suruh orang.
Dialogue: 0,0:11:31.88,0:11:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau yang itu.
Dialogue: 0,0:11:40.20,0:11:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok langsung kena, ya?
Dialogue: 0,0:11:42.89,0:11:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:11:45.09,0:11:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut, cocok sekali denganmu.
Dialogue: 0,0:11:48.81,0:11:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun senang banget, tuh.
Dialogue: 0,0:11:56.01,0:11:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Amane.
Dialogue: 0,0:11:59.70,0:12:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, aku senang melihatmu gembira.
Dialogue: 0,0:12:03.32,0:12:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan tunjukkan ekspresi itu\Ndi depan umum.
Dialogue: 0,0:12:05.80,0:12:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:06.96,0:12:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi seimut itu,\Ncocoknya cuma saat kita berdua.
Dialogue: 0,0:12:12.93,0:12:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar khusus buatku saja.
Dialogue: 0,0:12:15.95,0:12:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ditunjukkan ke orang.
Dialogue: 0,0:12:24.85,0:12:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian malah jadi tontonan.
Dialogue: 0,0:12:29.19,0:12:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru imut, apa boleh buat.
Dialogue: 0,0:12:31.33,0:12:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun jadi lembek kalau sama Amane.
Dialogue: 0,0:12:34.03,0:12:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesonanya memang makin dahsyat, sih.
Dialogue: 0,0:12:36.32,0:12:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, dia tampan juga.
Dialogue: 0,0:12:39.32,0:12:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane.
Dialogue: 0,0:12:41.32,0:12:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasihat yang tadi
Dialogue: 0,0:12:44.32,0:12:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berlaku buatmu juga.
Dialogue: 0,0:12:46.77,0:12:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:12:48.62,0:12:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji, ya!
Dialogue: 0,0:12:57.55,0:13:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan festival memang istimewa!
Dialogue: 0,0:13:00.77,0:13:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat suasananya, sih.
Dialogue: 0,0:13:05.37,0:13:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka mulutmu.
Dialogue: 0,0:13:09.37,0:13:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut sekali.
Dialogue: 0,0:13:10.96,0:13:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut, sih, tapi mereka\Nmalah bermesraan di depan kita.
Dialogue: 0,0:13:14.43,0:13:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cemburu?
Dialogue: 0,0:13:17.40,0:13:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Akazawa?
Dialogue: 0,0:13:19.03,0:13:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kalian juga datang?
Dialogue: 0,0:13:21.91,0:13:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa,\Nsejak penutupan tahun ajaran.
Dialogue: 0,0:13:25.49,0:13:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Shiina pakai yukata.
Dialogue: 0,0:13:27.77,0:13:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu cocok banget pakai yukata.
Dialogue: 0,0:13:31.03,0:13:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:32.72,0:13:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarnya.
Dialogue: 0,0:13:34.92,0:13:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memakainya sendiri?
Dialogue: 0,0:13:37.16,0:13:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:38.56,0:13:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, yukata ini dipilihkan\Noleh ibunya Amane.
Dialogue: 0,0:13:44.14,0:13:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:13:44.88,0:13:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dapat restu orang tua!
Dialogue: 0,0:13:46.60,0:13:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ikayaki Chitose sudah habis.
Dialogue: 0,0:13:50.08,0:13:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo jalan lagi.
Dialogue: 0,0:13:51.81,0:13:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:53.43,0:13:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai ketemu setelah libur musim panas.
Dialogue: 0,0:13:55.86,0:13:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:13:59.63,0:14:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua,
Dialogue: 0,0:14:00.99,0:14:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tadi sengaja bahas orang tua, kan?
Dialogue: 0,0:14:04.12,0:14:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:14:06.12,0:14:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi cerdik, ya.
Dialogue: 0,0:14:10.79,0:14:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo makan kakigori!
Dialogue: 0,0:14:13.21,0:14:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perutmu sebesar apa, sih?
Dialogue: 0,0:14:15.92,0:14:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebesar ini.
Dialogue: 0,0:14:17.75,0:14:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose tidak mudah gemuk,\Nbadan rampingmu bikin iri.
Dialogue: 0,0:14:22.83,0:14:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan sehat.
Dialogue: 0,0:14:24.12,0:14:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo puji lagi!
Dialogue: 0,0:14:26.43,0:14:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chi memang langsing, ya.
Dialogue: 0,0:14:29.07,0:14:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terasa banget pas digendong.
Dialogue: 0,0:14:31.02,0:14:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan banyak tapi tidak gemuk.
Dialogue: 0,0:14:34.02,0:14:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, bagian lainnya juga senasib.
Dialogue: 0,0:14:37.75,0:14:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikkun?
Dialogue: 0,0:14:40.15,0:14:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku salah bicara!\NAmpun!
Dialogue: 0,0:14:43.61,0:14:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bincang-bincang di situ.
Dialogue: 0,0:14:45.91,0:14:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam adalah emas.
Dialogue: 0,0:14:49.00,0:14:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau kakigori rasa apa?
Dialogue: 0,0:14:50.97,0:14:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Rasa susu stroberi?
Dialogue: 0,0:14:54.41,0:14:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kita beli.
Dialogue: 0,0:14:58.29,0:15:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Chi ramping dan menawan, ulangi!\N- Mereka akrab, ya.
Dialogue: 0,0:15:01.21,0:15:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Chi ramping dan menawan!\N- Yah, mereka punya cara pacaran sendiri.
Dialogue: 0,0:15:06.04,0:15:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihanmu dewasa, ya.
Dialogue: 0,0:15:07.88,0:15:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya mau rasa matca kacang merah.
Dialogue: 0,0:15:10.27,0:15:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di sini tidak ada.
Dialogue: 0,0:15:12.52,0:15:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matca kacang merah?\NKamu suka makanan manis?
Dialogue: 0,0:15:17.88,0:15:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan.
Dialogue: 0,0:15:19.75,0:15:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kacang merah,\Nterutama yang bertekstur.
Dialogue: 0,0:15:22.80,0:15:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:15:24.81,0:15:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masak kacang merah agak susah, sih.
Dialogue: 0,0:15:27.81,0:15:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di toko juga oke.
Dialogue: 0,0:15:30.08,0:15:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membuatkan makanan enak\Nuntuk orang yang kucintai.
Dialogue: 0,0:15:35.25,0:15:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, aku mau puding matca\Npakai kacang merah.
Dialogue: 0,0:15:39.73,0:15:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama dorayaki.
Dialogue: 0,0:15:42.31,0:15:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, serahkan padaku.
Dialogue: 0,0:15:45.22,0:15:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puding matca terdengar enak!
Dialogue: 0,0:15:47.22,0:15:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukumannya selesai?
Dialogue: 0,0:15:49.07,0:15:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, dia memang suka begitu.
Dialogue: 0,0:15:52.41,0:15:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus mana Itsuki?
Dialogue: 0,0:15:53.73,0:15:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang membeli kakigori dan piscok.
Dialogue: 0,0:15:56.41,0:15:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok ada tambahan?
Dialogue: 0,0:15:57.43,0:15:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat permintaan maaf.
Dialogue: 0,0:15:58.98,0:16:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang mau rata begini.
Dialogue: 0,0:16:02.61,0:16:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, cowok sukanya\Nyang gede kaya Mahirun, kan?
Dialogue: 0,0:16:06.60,0:16:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gede...\N- Chi-Chitose...
Dialogue: 0,0:16:08.66,0:16:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada maksud jelek,\Ntapi jujur aku iri.
Dialogue: 0,0:16:13.73,0:16:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya banyak hal yang tidak kumiliki.
Dialogue: 0,0:16:17.29,0:16:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik, proporsional,
Dialogue: 0,0:16:19.43,0:16:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pandai soal belajar, memasak,\Nurusan rumah, dan anggun.
Dialogue: 0,0:16:23.52,0:16:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sosok idaman para pria.
Dialogue: 0,0:16:27.17,0:16:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:16:30.68,0:16:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Chi, mohon ampuni aku!
Dialogue: 0,0:16:33.32,0:16:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, angkat kepalamu!
Dialogue: 0,0:16:43.69,0:16:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane cinta banget sama Mahirun, ya,\NKelihatan jelas.
Dialogue: 0,0:16:47.82,0:16:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:48.68,0:16:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang, ekspresi dan tatapanmu\Npadanya sangat lembut.
Dialogue: 0,0:16:53.70,0:16:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, benarkah itu?
Dialogue: 0,0:16:56.16,0:17:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, anu, itu...\NIya.
Dialogue: 0,0:17:01.96,0:17:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku foto biar kamu sadar.
Dialogue: 0,0:17:05.91,0:17:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, Mahirun pasti senang\Ndiperlakukan lembut.
Dialogue: 0,0:17:09.88,0:17:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:17:11.83,0:17:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cinta semuanya dari Amane.
Dialogue: 0,0:17:14.83,0:17:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi tegasnya, sisi lembutnya,
Dialogue: 0,0:17:19.14,0:17:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maupun sisi seksinya.
Dialogue: 0,0:17:21.41,0:17:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah melihat keseksian Amane?
Dialogue: 0,0:17:26.02,0:17:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak melakukan hal\Nyang kalian bayangkan.
Dialogue: 0,0:17:29.23,0:17:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawaban jujurmu itu\Nentah termasuk dingin atau tulus.
Dialogue: 0,0:17:34.28,0:17:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sudah ciuman, bukan?
Dialogue: 0,0:17:36.93,0:17:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:38.33,0:17:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sama-sama polos, ya.
Dialogue: 0,0:17:40.87,0:17:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau Amane saja yang payah.
Dialogue: 0,0:17:43.13,0:17:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saja, lagi pula hubungan kami lancar.
Dialogue: 0,0:17:46.59,0:17:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau begitu.
Dialogue: 0,0:17:49.67,0:17:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun juga harus lebih jujur.
Dialogue: 0,0:17:52.85,0:17:56.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada nanti curhat lagi\Nkarena Amane tidak kunjung menciummu.
Dialogue: 0,0:17:58.47,0:18:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan katakan itu!
Dialogue: 0,0:18:02.48,0:18:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kenyang banget!
Dialogue: 0,0:18:05.75,0:18:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Mau pulang?
Dialogue: 0,0:18:07.77,0:18:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja kalau mau pulang.
Dialogue: 0,0:18:11.59,0:18:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, menginap di rumah Mahirun.
Dialogue: 0,0:18:13.74,0:18:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:14.79,0:18:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu begini, aku juga izin\Nmenginap ke Amane.
Dialogue: 0,0:18:17.68,0:18:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah kalau Mahiru tidak keberatan.
Dialogue: 0,0:18:20.91,0:18:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, kamu murung\Nkarena Mahirun direbut?
Dialogue: 0,0:18:25.71,0:18:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru sudah jadi punyaku,\Naman saja.
Dialogue: 0,0:18:30.67,0:18:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose, ini yang kumaksud!
Dialogue: 0,0:18:33.00,0:18:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini Amane jadi begini.
Dialogue: 0,0:18:36.73,0:18:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, kamu pasti repot.
Dialogue: 0,0:18:43.01,0:18:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, ayo main.
Dialogue: 0,0:18:47.02,0:18:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku baru mau tidur.
Dialogue: 0,0:18:50.78,0:18:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, kok.
Dialogue: 0,0:18:51.97,0:18:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tutup, ya.
Dialogue: 0,0:18:53.36,0:18:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, setidaknya\Ntunggu Mahirun kembali dulu.
Dialogue: 0,0:18:57.48,0:18:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru di mana?
Dialogue: 0,0:18:59.20,0:19:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mandi.
Dialogue: 0,0:19:00.60,0:19:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menolak mandi bareng hari ini.
Dialogue: 0,0:19:03.92,0:19:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:19:05.31,0:19:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun sempat sedih karena tidak bisa\Nbilang selamat tidur padamu.
Dialogue: 0,0:19:08.92,0:19:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah alasanku meneleponmu.
Dialogue: 0,0:19:12.36,0:19:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu masalahnya,\Njadi tidak bisa kututup, dong.
Dialogue: 0,0:19:15.72,0:19:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku tidak cerita begitu\Nbakal kamu tutup?
Dialogue: 0,0:19:18.72,0:19:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejamnya.
Dialogue: 0,0:19:20.33,0:19:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu mau bahas apa?
Dialogue: 0,0:19:25.03,0:19:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secinta apa kamu sama Mahirun?
Dialogue: 0,0:19:28.77,0:19:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:19:30.88,0:19:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sangat menyayangi Mahirun,\Naku penasaran sebesar apa cintamu.
Dialogue: 0,0:19:36.91,0:19:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut prasangkaku
Dialogue: 0,0:19:41.37,0:19:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau mungkin orang banyak.
Dialogue: 0,0:19:43.81,0:19:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacaran anak SMA sering dianggap\Nkayak kesenangan sesaat.
Dialogue: 0,0:19:49.04,0:19:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak serius, lebih kayak main-main.
Dialogue: 0,0:19:52.89,0:19:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Daiki bilang begitu padamu?
Dialogue: 0,0:19:57.05,0:20:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kamu peka banget.
Dialogue: 0,0:20:02.09,0:20:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat main ke rumah Ikkun.
Dialogue: 0,0:20:06.17,0:20:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Pak Daiki kurang suka padaku.
Dialogue: 0,0:20:10.31,0:20:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku ingin tahu,\Nadakah orang yang benar-benar serius.
Dialogue: 0,0:20:18.24,0:20:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:20:19.82,0:20:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bingung juga kalau ditanya secinta apa.
Dialogue: 0,0:20:23.83,0:20:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku ingin dia selalu\Ntersenyum bersamaku.
Dialogue: 0,0:20:27.77,0:20:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:20:29.09,0:20:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak begitu?
Dialogue: 0,0:20:30.58,0:20:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku ingin Ikkun\Nselalu tertawa selama bersamaku.
Dialogue: 0,0:20:35.84,0:20:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, wujudkanlah tekadmu.
Dialogue: 0,0:20:40.05,0:20:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omongan orang lain\Ntidak akan bisa mengubahnya.
Dialogue: 0,0:20:46.06,0:20:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi "cowok ideal"mu itu bikin sebal.
Dialogue: 0,0:20:49.19,0:20:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pacar cewek ideal,\Nharus jadi cowok ideal, kan?
Dialogue: 0,0:20:52.57,0:20:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, tengil banget!
Dialogue: 0,0:20:55.75,0:20:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian membicarakan apa?
Dialogue: 0,0:20:58.03,0:21:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacarmu memang cowok ideal.
Dialogue: 0,0:21:01.87,0:21:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang apa yang dia lakukan?
Dialogue: 0,0:21:04.56,0:21:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang curhat soal kehidupan.
Dialogue: 0,0:21:07.88,0:21:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curhat soal kehidupan?
Dialogue: 0,0:21:10.71,0:21:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak curhat padaku?
Dialogue: 0,0:21:15.55,0:21:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun lucu banget!\NJelas aku mau, lah!
Dialogue: 0,0:21:18.59,0:21:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose, bahaya kalau asal lompat begitu.
Dialogue: 0,0:21:23.53,0:21:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cinta Mahirun.
Dialogue: 0,0:21:25.18,0:21:27.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mencintaimu.
Dialogue: 0,0:21:27.32,0:21:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil merebut\Ncinta Mahirun dari Amane!
Dialogue: 0,0:21:31.23,0:21:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:31.94,0:21:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Amane tetap spesial, kok.
Dialogue: 0,0:21:36.52,0:21:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:21:38.68,0:21:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bucin generasi dua.
Dialogue: 0,0:21:40.57,0:21:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diamlah, generasi pertama.
Dialogue: 0,0:21:43.03,0:21:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tutup, ya.
Dialogue: 0,0:21:45.37,0:21:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun, ayo.
Dialogue: 0,0:21:50.24,0:21:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane.
Dialogue: 0,0:21:52.41,0:21:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:21:54.21,0:21:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, selamat tidur.\NSampai jumpa besok.
Dialogue: 0,0:22:00.20,0:22:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sampai jumpa besok.
