Dialogue: 0,0:00:26.97,0:00:35.10,sign,,0000,0000,0000,,#8 FESTIVAL BUDAYA, DIMULAI
Dialogue: 0,0:02:07.11,0:02:11.28,sign,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:11:40.01,0:11:46.52,sign,,0000,0000,0000,,FESTIVAL BUDAYA SEIJOU
Dialogue: 0,0:15:41.88,0:15:44.24,sign,,0000,0000,0000,,BERONDONG JAGUNG 200 YEN
Dialogue: 0,0:16:29.98,0:16:32.10,sign,,0000,0000,0000,,PINTU MASUK\NRUMAH HANTU
Dialogue: 0,0:16:32.10,0:16:33.25,sign,,0000,0000,0000,,RUMAH HANTU
Dialogue: 0,0:17:40.29,0:17:42.93,sign,,0000,0000,0000,,PANEKUK MANIS
Dialogue: 0,0:20:04.60,0:20:13.15,sign,,0000,0000,0000,,KOPI, COKELAT PANAS, TEH, KUE
Dialogue: 0,0:23:34.98,0:23:47.10,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:02.48,0:00:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, pamfletnya salah tulis.
Dialogue: 0,0:00:05.31,0:00:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong perbaiki sebelum dicetak.
Dialogue: 0,0:00:08.02,0:00:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taplak mejanya mana?
Dialogue: 0,0:00:10.14,0:00:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya sudah beli, kok tidak ada?
Dialogue: 0,0:00:13.74,0:00:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan modal kita,\Nmeski cuma ambil untung sedikit,
Dialogue: 0,0:00:17.55,0:00:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}totalnya kira-kira sebegini.
Dialogue: 0,0:00:20.48,0:00:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya, senyum.
Dialogue: 0,0:00:23.46,0:00:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyum.
Dialogue: 0,0:00:24.54,0:00:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih kaku!
Dialogue: 0,0:00:26.97,0:00:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, padahal tinggal senyum biasa.
Dialogue: 0,0:00:30.62,0:00:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu kayak terpaksa kalau disuruh.
Dialogue: 0,0:00:35.10,0:00:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja para tamu itu kentang.
Dialogue: 0,0:00:38.37,0:00:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang, ya.
Dialogue: 0,0:00:39.81,0:00:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur lebih pas buat Amane.
Dialogue: 0,0:00:43.06,0:00:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, banyak yang bilang Amane\Nlebih oke kalau bersikap apa adanya.
Dialogue: 0,0:00:48.26,0:00:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata siapa?
Dialogue: 0,0:00:49.90,0:00:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cewek-cewek di kelas.
Dialogue: 0,0:00:51.68,0:00:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kesan mereka\Nsaat melihatmu bersama Shiina.
Dialogue: 0,0:00:57.58,0:01:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya paling bersinar\Nkalau bersama Shiina, ya.
Dialogue: 0,0:01:02.08,0:01:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:01:03.41,0:01:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang, auramu sangat memikat.
Dialogue: 0,0:01:09.89,0:01:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tenang saja, Shiina.\NAku sudah punya pacar.
Dialogue: 0,0:01:14.16,0:01:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan itu yang kucemaskan.
Dialogue: 0,0:01:18.43,0:01:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tertarik pada cowok super kekar.
Dialogue: 0,0:01:22.38,0:01:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya terlalu kurus buat jadi tipeku.
Dialogue: 0,0:01:25.44,0:01:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, serasa dikatai taoge.
Dialogue: 0,0:01:27.44,0:01:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane bukan taoge!
Dialogue: 0,0:01:30.37,0:01:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulitnya memang putih, sih.
Dialogue: 0,0:01:33.94,0:01:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:01:35.16,0:01:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau buka baju
Dialogue: 0,0:01:38.74,0:01:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lumayan berotot, kok.
Dialogue: 0,0:01:40.87,0:01:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gagah kalau buka baju?
Dialogue: 0,0:01:42.93,0:01:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:01:43.88,0:01:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia lumayan berisi.
Dialogue: 0,0:01:46.96,0:01:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, nanti kamu yang malu sendiri.
Dialogue: 0,0:01:51.01,0:01:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:03:27.42,0:03:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, seragamnya tiba!
Dialogue: 0,0:03:31.87,0:03:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabar, ya, ruang gantinya sudah disiapkan.
Dialogue: 0,0:03:37.23,0:03:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Fujimiya nanti saja.
Dialogue: 0,0:03:39.79,0:03:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:03:42.35,0:03:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlakuan khusus.
Dialogue: 0,0:03:44.04,0:03:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengabulkan
Dialogue: 0,0:03:47.10,0:03:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}permintaan kecil dari Shiina.
Dialogue: 0,0:03:49.88,0:03:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina mau kamu\Njadi yang pertama melihatnya.
Dialogue: 0,0:03:58.63,0:04:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok aku tegang, ya?
Dialogue: 0,0:04:01.66,0:04:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk.
Dialogue: 0,0:04:21.62,0:04:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:04:26.13,0:04:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa cocok.
Dialogue: 0,0:04:29.37,0:04:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?\NSyukurlah.
Dialogue: 0,0:04:32.82,0:04:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama kali berpakaian begini.
Dialogue: 0,0:04:37.73,0:04:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane?
Dialogue: 0,0:04:40.51,0:04:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, maaf.
Dialogue: 0,0:04:41.97,0:04:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking cocoknya, aku tidak mau\Ndikurangi pandangan orang lain.
Dialogue: 0,0:04:47.39,0:04:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dikurangi?
Dialogue: 0,0:04:49.44,0:04:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa senangku.
Dialogue: 0,0:04:51.44,0:04:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kepalamu aku usap, bersabarlah.
Dialogue: 0,0:04:56.82,0:05:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak mau orang lain\Nmelihatmu pakai seragam butler.
Dialogue: 0,0:05:03.44,0:05:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak diminati, tenang saja.
Dialogue: 0,0:05:06.54,0:05:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa!
Dialogue: 0,0:05:08.86,0:05:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf.
Dialogue: 0,0:05:10.78,0:05:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga minta maaf.
Dialogue: 0,0:05:14.03,0:05:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak ganti penampilan,\Nkamu jadi mudah didekati.
Dialogue: 0,0:05:19.15,0:05:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, suka ada cewek lain\Nyang bilang kamu menarik.
Dialogue: 0,0:05:25.17,0:05:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok aku tidak tahu?
Dialogue: 0,0:05:28.27,0:05:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilangnya di belakang!
Dialogue: 0,0:05:31.20,0:05:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma antara para cewek saja.
Dialogue: 0,0:05:35.04,0:05:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku agak waswas
Dialogue: 0,0:05:39.04,0:05:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan gelisah.
Dialogue: 0,0:05:41.62,0:05:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, mereka bilang apa?
Dialogue: 0,0:05:44.51,0:05:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, kamu terlihat baik dan santun.
Dialogue: 0,0:05:50.00,0:05:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kamu terlihat akan fokus\Npada satu wanita saja.
Dialogue: 0,0:05:55.76,0:05:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu benar.
Dialogue: 0,0:05:58.19,0:05:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma fokus padamu.
Dialogue: 0,0:06:00.46,0:06:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu juga sama, kan?
Dialogue: 0,0:06:03.01,0:06:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu melirik cowok lain?
Dialogue: 0,0:06:05.18,0:06:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin!
Dialogue: 0,0:06:06.53,0:06:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti percuma cemas.
Dialogue: 0,0:06:08.96,0:06:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma melirik satu orang,
Dialogue: 0,0:06:11.18,0:06:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yaitu kamu.
Dialogue: 0,0:06:18.10,0:06:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo sama-sama bersabar.
Dialogue: 0,0:06:21.54,0:06:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:22.59,0:06:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja, aku ingin memilikimu sendiri.
Dialogue: 0,0:06:30.70,0:06:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:06:33.04,0:06:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski mereka menyadari pesonamu,\Naku tidak mau mengalah.
Dialogue: 0,0:06:38.75,0:06:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau melihatmu jadi butler.
Dialogue: 0,0:06:42.55,0:06:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi giliran cowok\Nyang ganti baju, bersabarlah.
Dialogue: 0,0:06:48.97,0:06:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Ikkun cocok banget!
Dialogue: 0,0:06:52.18,0:06:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayak buaya darat.
Dialogue: 0,0:06:53.34,0:06:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat banget.
Dialogue: 0,0:06:54.81,0:06:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bagaimana?\NCocok?
Dialogue: 0,0:06:57.30,0:07:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, apa pun cocok untukmu.
Dialogue: 0,0:07:00.94,0:07:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya juga bagus, niat banget!
Dialogue: 0,0:07:05.65,0:07:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini biar Mahiru senang.
Dialogue: 0,0:07:08.56,0:07:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pacar yang baik.
Dialogue: 0,0:07:10.75,0:07:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina, pacarmu jadi butler, nih!
Dialogue: 0,0:07:16.67,0:07:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat menantikannya.
Dialogue: 0,0:07:19.47,0:07:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan melebihi perkiraanmu.
Dialogue: 0,0:07:23.30,0:07:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, mubazir kalau dilihat dari jauh.
Dialogue: 0,0:07:27.22,0:07:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai rekan satu sif,\Nkalian harus saling terbiasa.
Dialogue: 0,0:07:33.79,0:07:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak cocok?
Dialogue: 0,0:07:34.91,0:07:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu!
Dialogue: 0,0:07:37.10,0:07:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat menawan.
Dialogue: 0,0:07:39.31,0:07:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tampak berbeda.
Dialogue: 0,0:07:41.68,0:07:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda apanya?
Dialogue: 0,0:07:44.26,0:07:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lebih seksi dari biasanya.
Dialogue: 0,0:07:47.82,0:07:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski pakaianku lebih tertutup?
Dialogue: 0,0:07:50.72,0:07:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang tertutup lebih oke!
Dialogue: 0,0:07:53.18,0:07:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh.
Dialogue: 0,0:07:59.81,0:08:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:08:04.90,0:08:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihannya langsung gagal.
Dialogue: 0,0:08:06.91,0:08:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:08:07.86,0:08:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini bukan salahmu maupun Shiina.
Dialogue: 0,0:08:12.22,0:08:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, gawat kalau terus begini.
Dialogue: 0,0:08:15.46,0:08:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan banyak korban.
Dialogue: 0,0:08:17.71,0:08:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, tapi aku pribadi juga\Nkurang menyukainya.
Dialogue: 0,0:08:22.06,0:08:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya dongkol melihat pacarku\Nramah ke cowok lain walau cuma bekerja.
Dialogue: 0,0:08:28.94,0:08:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku yang lebai.
Dialogue: 0,0:08:31.82,0:08:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Fujimiya mencintaimu ugal-ugalan.
Dialogue: 0,0:08:37.29,0:08:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu blakblakan, dong.
Dialogue: 0,0:08:42.00,0:08:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatmu cemburu\Nkayak cowok pada umumnya,
Dialogue: 0,0:08:46.40,0:08:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku gemas\Nmelihat hubungan cinta kalian.
Dialogue: 0,0:08:51.66,0:08:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya itu bagus.
Dialogue: 0,0:08:54.14,0:08:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak naksir kamu, kok.
Dialogue: 0,0:08:56.35,0:08:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok jadi ke situ?
Dialogue: 0,0:08:58.21,0:09:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, tatapan Shiina...
Dialogue: 0,0:09:03.57,0:09:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cintanya padamu juga besar.
Dialogue: 0,0:09:07.66,0:09:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau jadi tamunya Kadowaki!
Dialogue: 0,0:09:10.51,0:09:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang, aku juga!
Dialogue: 0,0:09:11.70,0:09:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan seenaknya!
Dialogue: 0,0:09:13.85,0:09:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau, lah!
Dialogue: 0,0:09:15.20,0:09:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung pada antre.
Dialogue: 0,0:09:17.66,0:09:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:09:19.23,0:09:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya pacar, kan?
Dialogue: 0,0:09:21.62,0:09:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tapi anak kelas lain.
Dialogue: 0,0:09:24.80,0:09:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia teman kecilku, ototnya sangat bagus.
Dialogue: 0,0:09:27.97,0:09:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat banget.
Dialogue: 0,0:09:29.76,0:09:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya dia idamanku.
Dialogue: 0,0:09:33.57,0:09:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, latihan bergiliran sama Kadowaki.
Dialogue: 0,0:09:37.01,0:09:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba rundingkan urutannya buat kucatat.
Dialogue: 0,0:09:44.74,0:09:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya aku harus jadi tamu pertamamu.
Dialogue: 0,0:09:52.51,0:09:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:09:54.32,0:09:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuantar ke mejamu.
Dialogue: 0,0:10:00.00,0:10:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, ada apa?
Dialogue: 0,0:10:02.54,0:10:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan apa-apa!
Dialogue: 0,0:10:06.46,0:10:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan duduk sambil menunggu.
Dialogue: 0,0:10:13.12,0:10:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan berhasil, nilai sempurna!
Dialogue: 0,0:10:16.90,0:10:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Mahiru malah begitu.
Dialogue: 0,0:10:19.35,0:10:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kamu keren abis.
Dialogue: 0,0:10:22.69,0:10:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jago banget!
Dialogue: 0,0:10:24.85,0:10:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja di tempatku, yuk!\NPemilik toko pasti senang.
Dialogue: 0,0:10:28.72,0:10:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti saja kalau butuh uang.
Dialogue: 0,0:10:32.05,0:10:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku mau mengecek latihan yang lain.
Dialogue: 0,0:10:35.26,0:10:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampirilah Shiina.
Dialogue: 0,0:10:38.40,0:10:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:39.49,0:10:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana deklarasi cintamu?
Dialogue: 0,0:10:41.86,0:10:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:10:45.76,0:10:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru.
Dialogue: 0,0:10:48.61,0:10:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Amane.
Dialogue: 0,0:10:50.96,0:10:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, cowok yang bikin Mahirun linglung!
Dialogue: 0,0:10:54.24,0:10:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berbakat menaklukkan Mahirun,
Dialogue: 0,0:10:57.73,0:10:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan terlalu usil, ya.
Dialogue: 0,0:10:59.56,0:11:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat macam apa itu?
Dialogue: 0,0:11:01.22,0:11:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat yang khusus aktif ke Mahirun.
Dialogue: 0,0:11:04.77,0:11:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya, bukan cuma aktif padaku.
Dialogue: 0,0:11:09.49,0:11:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sekeren itu?
Dialogue: 0,0:11:11.73,0:11:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:12.90,0:11:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarnya.
Dialogue: 0,0:11:15.20,0:11:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski khusus Mahirun,\Nefeknya mencakup area.
Dialogue: 0,0:11:20.03,0:11:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kalau Mahirun tersipu,\Norang lain juga kena imbasnya.
Dialogue: 0,0:11:25.17,0:11:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang apa?
Dialogue: 0,0:11:26.13,0:11:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:11:29.38,0:11:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari-H nanti pasti bakal lebih ramai.
Dialogue: 0,0:11:35.84,0:11:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus terus di dekatnya.
Dialogue: 0,0:11:41.22,0:11:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari pertama festival telah tiba.
Dialogue: 0,0:11:44.05,0:11:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah akan sebanyak apa yang datang.
Dialogue: 0,0:11:47.33,0:11:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bukan pelopor ide ini,
Dialogue: 0,0:11:51.02,0:11:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kelas kita punya sosok populer.
Dialogue: 0,0:11:55.04,0:11:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mari berjuang sebisa kita.
Dialogue: 0,0:11:58.40,0:12:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmatilah festival ini sepuasnya.
Dialogue: 0,0:12:02.41,0:12:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berusaha selama tiga hari ke depan!
Dialogue: 0,0:12:06.32,0:12:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas kita harus paling laris!
Dialogue: 0,0:12:11.92,0:12:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berjuang.
Dialogue: 0,0:12:13.87,0:12:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:24.01,0:12:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengaruh Bidadari luar biasa.
Dialogue: 0,0:12:26.37,0:12:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sewajarnya.
Dialogue: 0,0:12:28.90,0:12:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia hebat juga.
Dialogue: 0,0:12:30.94,0:12:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mampir.
Dialogue: 0,0:12:33.44,0:12:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menu rekomendasi hari ini adalah paket A.
Dialogue: 0,0:12:37.70,0:12:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:12:38.61,0:12:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Pesan yang itu, deh.
Dialogue: 0,0:12:41.81,0:12:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua paket A.
Dialogue: 0,0:12:43.08,0:12:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesanannya banyak, berjuanglah.
Dialogue: 0,0:12:45.44,0:12:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, antreannya panjang sekali.
Dialogue: 0,0:12:48.66,0:12:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, tinggal menyiapkan\Nyang sudah tersedia.
Dialogue: 0,0:12:53.15,0:12:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kalian yang bakal keteteran.
Dialogue: 0,0:12:57.01,0:12:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:12:58.51,0:13:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, Kadowaki memang\Nbakal menarik banyak tamu, sih.
Dialogue: 0,0:13:02.93,0:13:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudku.
Dialogue: 0,0:13:05.82,0:13:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu paket B.
Dialogue: 0,0:13:06.98,0:13:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:13:09.17,0:13:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seragammu cocok juga, Makoto.
Dialogue: 0,0:13:11.71,0:13:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu di bagian dapur, sih?\NKazuya sialan.
Dialogue: 0,0:13:15.65,0:13:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap Shiina ke dapur,\Nwajahnya terlihat sebal.
Dialogue: 0,0:13:20.54,0:13:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, ya?
Dialogue: 0,0:13:21.70,0:13:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu salahmu.
Dialogue: 0,0:13:24.27,0:13:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa karena ramah ke tamu?
Dialogue: 0,0:13:26.62,0:13:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja, tapi kayaknya bukan.
Dialogue: 0,0:13:30.75,0:13:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:13:31.70,0:13:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak paham maksud kalian.
Dialogue: 0,0:13:34.13,0:13:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cantik sekali.
Dialogue: 0,0:13:37.38,0:13:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menentukan pesanan?
Dialogue: 0,0:13:39.74,0:13:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sih.
Dialogue: 0,0:13:42.56,0:13:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu...
Dialogue: 0,0:13:43.34,0:13:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan panggil\Nkalau sudah siap memesan.
Dialogue: 0,0:13:46.43,0:13:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, kalau kamu luang...
Dialogue: 0,0:13:49.06,0:13:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tidak ada layanan seperti itu.
Dialogue: 0,0:13:53.70,0:13:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan panggil\Nkalau sudah siap memesan.
Dialogue: 0,0:13:58.38,0:14:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kamu khawatir,\Ntapi jangan lupa rileks.
Dialogue: 0,0:14:02.46,0:14:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga pasti mengawasi\Ndan siap membantu.
Dialogue: 0,0:14:06.59,0:14:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadowaki...
Dialogue: 0,0:14:07.99,0:14:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, selain harus saling\Nmenjaga sebagai teman,
Dialogue: 0,0:14:12.78,0:14:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hiburanku tidak boleh diusik.
Dialogue: 0,0:14:16.13,0:14:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiburan?
Dialogue: 0,0:14:17.41,0:14:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan mengusik\Nkemesraan mereka berdua!"
Dialogue: 0,0:14:21.39,0:14:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah isi hati kelas kita.
Dialogue: 0,0:14:23.44,0:14:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku gagal paham.
Dialogue: 0,0:14:26.37,0:14:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, warga kelas kita\Nmenyayangi Shiina.
Dialogue: 0,0:14:31.89,0:14:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja hubungan kalian\Ndipandang positif.
Dialogue: 0,0:14:35.48,0:14:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mengamati kami?
Dialogue: 0,0:14:38.99,0:14:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajar, soalnya kalian bermesraan.
Dialogue: 0,0:14:43.22,0:14:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak begitu.
Dialogue: 0,0:14:44.48,0:14:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kok.
Dialogue: 0,0:14:49.24,0:14:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya?
Dialogue: 0,0:14:51.87,0:14:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan, tolong jangan sembarangan\Nmenyentuh staf kami.
Dialogue: 0,0:14:57.38,0:14:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pelecehan?\N- Ih, najis.
Dialogue: 0,0:14:58.80,0:15:00.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan sentuh Bidadari.\N- Berani-beraninya.
Dialogue: 0,0:15:00.38,0:15:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para tamu, maaf sudah bikin gaduh.
Dialogue: 0,0:15:03.63,0:15:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lanjut menikmati.
Dialogue: 0,0:15:07.62,0:15:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sif kita sudah mau kelar,\Nistirahat duluan sana.
Dialogue: 0,0:15:13.89,0:15:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:15:15.36,0:15:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali.
Dialogue: 0,0:15:16.59,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lebih tenang?
Dialogue: 0,0:15:18.29,0:15:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak perlu khawatir berlebihan.
Dialogue: 0,0:15:22.10,0:15:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti khawatir, lah.
Dialogue: 0,0:15:24.21,0:15:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, pakai.
Dialogue: 0,0:15:26.75,0:15:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar tidak terlalu mencolok pas keliling.
Dialogue: 0,0:15:29.57,0:15:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:15:38.42,0:15:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayo.
Dialogue: 0,0:15:40.48,0:15:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:15:42.42,0:15:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau makan apa?
Dialogue: 0,0:15:44.24,0:15:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, aku mau yang jarang\Ndimakan sehari-hari.
Dialogue: 0,0:15:48.64,0:15:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, takoyaki atau yakisoba.
Dialogue: 0,0:15:53.89,0:15:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sou, itu Fujimiya yang pernah kuceritakan.
Dialogue: 0,0:15:59.65,0:16:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, kamu pacarnya Kido?
Dialogue: 0,0:16:02.61,0:16:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, dia teman masa kecil\Nsekaligus pacarku.
Dialogue: 0,0:16:07.09,0:16:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sou, perkenalkan dirimu.
Dialogue: 0,0:16:09.74,0:16:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kayano Souji.
Dialogue: 0,0:16:11.37,0:16:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gagah kalau buka baju.
Dialogue: 0,0:16:14.20,0:16:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagah kalau buka baju?
Dialogue: 0,0:16:16.33,0:16:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, pacarku gagah, lo.
Dialogue: 0,0:16:21.42,0:16:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane juga gagah kalau buka baju!
Dialogue: 0,0:16:24.07,0:16:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga!
Dialogue: 0,0:16:25.17,0:16:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sekekar itu buat diadu.
Dialogue: 0,0:16:27.68,0:16:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi buatku, iya.
Dialogue: 0,0:16:33.25,0:16:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau masuk rumah hantu?
Dialogue: 0,0:16:34.99,0:16:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:35.97,0:16:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak ada niat begitu.
Dialogue: 0,0:16:39.49,0:16:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira mau.
Dialogue: 0,0:16:42.00,0:16:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu mustahil\Nsoalnya kamu takut hal horor.
Dialogue: 0,0:16:46.29,0:16:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:16:48.11,0:16:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk rumah hantu itu mudah.
Dialogue: 0,0:16:51.49,0:16:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin?
Dialogue: 0,0:16:53.22,0:16:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti nonton film horor, yuk.
Dialogue: 0,0:16:55.70,0:16:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bakal seru, tuh.
Dialogue: 0,0:16:58.00,0:17:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin mau sok berani?\NNanti kamu takut tidur sendirian, lo.
Dialogue: 0,0:17:02.78,0:17:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sok berani.
Dialogue: 0,0:17:04.88,0:17:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada apa-apa,\Nkamu harus tanggung jawab.
Dialogue: 0,0:17:09.97,0:17:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misal aku lebih menakutkan dari hantu?
Dialogue: 0,0:17:12.40,0:17:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah berpikir\Nkamu menakutkan.
Dialogue: 0,0:17:15.65,0:17:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kita sudah sering tidur bersama.
Dialogue: 0,0:17:21.90,0:17:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya kayak ajakan.
Dialogue: 0,0:17:24.10,0:17:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikir yang aneh-aneh.
Dialogue: 0,0:17:26.67,0:17:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kamulah yang mengajakku.
Dialogue: 0,0:17:29.32,0:17:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada niat jelek.
Dialogue: 0,0:17:31.25,0:17:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma pengin lihat reaksi takutmu.
Dialogue: 0,0:17:34.37,0:17:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya niat jelek!
Dialogue: 0,0:17:41.10,0:17:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya.
Dialogue: 0,0:17:45.31,0:17:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Daiki?
Dialogue: 0,0:17:48.24,0:17:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ayahnya Itsuki.
Dialogue: 0,0:17:52.08,0:17:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlihat berbeda.
Dialogue: 0,0:17:55.92,0:17:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dulu aku sangat suram.
Dialogue: 0,0:17:59.25,0:18:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu merendah.
Dialogue: 0,0:18:01.12,0:18:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang melihatmu\Ntampak lebih percaya diri.
Dialogue: 0,0:18:07.33,0:18:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa nona itu?
Dialogue: 0,0:18:09.23,0:18:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pacarku.
Dialogue: 0,0:18:12.00,0:18:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal, aku Shiina Mahiru.
Dialogue: 0,0:18:15.49,0:18:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sopan sekali.
Dialogue: 0,0:18:18.11,0:18:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ayahnya Itsuki, Akazawa Daiki.
Dialogue: 0,0:18:22.86,0:18:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang melihatmu menemukan\Ngadis yang anggun.
Dialogue: 0,0:18:27.50,0:18:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau berkunjung ke kelas kami?
Dialogue: 0,0:18:30.67,0:18:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya begitu.
Dialogue: 0,0:18:34.35,0:18:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sepertinya bakal canggung.
Dialogue: 0,0:18:38.56,0:18:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:18:40.02,0:18:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu kalian.
Dialogue: 0,0:18:42.30,0:18:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ke tempat lain saja.
Dialogue: 0,0:18:44.31,0:18:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:45.54,0:18:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau merusak suasana.
Dialogue: 0,0:18:48.40,0:18:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmatilah festivalnya.
Dialogue: 0,0:18:54.69,0:18:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose belum...
Dialogue: 0,0:18:57.06,0:18:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:58.66,0:19:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap dia dapat restu.
Dialogue: 0,0:19:02.51,0:19:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak semudah itu.
Dialogue: 0,0:19:04.62,0:19:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:07.17,0:19:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, mereka sangat cocok
Dialogue: 0,0:19:11.55,0:19:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan punya ikatan kuat.
Dialogue: 0,0:19:13.90,0:19:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin
Dialogue: 0,0:19:16.70,0:19:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka dipisahkan.
Dialogue: 0,0:19:19.81,0:19:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya jangan.
Dialogue: 0,0:19:22.18,0:19:23.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:24.68,0:19:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:19:26.82,0:19:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan dan Nona.
Dialogue: 0,0:19:28.80,0:19:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, cara menyambut kalian\Nseenaknya sekali.
Dialogue: 0,0:19:32.07,0:19:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun, istirahatnya seru?
Dialogue: 0,0:19:34.69,0:19:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, soalnya sama Amane.
Dialogue: 0,0:19:37.95,0:19:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Itsuki.
Dialogue: 0,0:19:40.32,0:19:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertemu Pak Daiki.
Dialogue: 0,0:19:43.37,0:19:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kata Ikkun, cara menyambutku aneh.\N- Tapi dia tidak membahas Chitose.
Dialogue: 0,0:19:47.09,0:19:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Masa?\N- Dia bilang mau ke tempat lain,
Dialogue: 0,0:19:49.02,0:19:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kayak begini, selamat datang!\N- karena canggung kalau ke sini.
Dialogue: 0,0:19:52.70,0:19:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku cuma basa-basi\Nmemberinya tiket.
Dialogue: 0,0:19:56.34,0:20:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah dia tidak datang,\Ntakutnya Chi kelimpungan.
Dialogue: 0,0:20:04.60,0:20:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang datang, ya.
Dialogue: 0,0:20:07.76,0:20:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain karena unik,
Dialogue: 0,0:20:10.00,0:20:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak yang bertujuan cuci mata.
Dialogue: 0,0:20:13.15,0:20:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas kita memang cocok\Npakai seragam ini, sih.
Dialogue: 0,0:20:18.69,0:20:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:22.51,0:20:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga berpikir mereka imut?
Dialogue: 0,0:20:29.97,0:20:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:32.51,0:20:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi cuma keimutanmu\Nyang bisa memikatku, tenang saja.
Dialogue: 0,0:20:38.05,0:20:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi bilang begitu.
Dialogue: 0,0:20:41.22,0:20:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, nanti kamu cemburu.
Dialogue: 0,0:20:45.66,0:20:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa bodoh\Nkarena cemas berlebihan.
Dialogue: 0,0:20:48.64,0:20:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukatakan berulang kali
Dialogue: 0,0:20:51.66,0:20:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai kamu merasa puas.
Dialogue: 0,0:20:54.23,0:20:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku malah malu sendiri.
Dialogue: 0,0:20:58.86,0:21:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya malah bagus\Nkalau aku memuji penampilanmu?
Dialogue: 0,0:21:03.12,0:21:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau membunuhku, ya?
Dialogue: 0,0:21:05.79,0:21:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebai, deh.
Dialogue: 0,0:21:06.91,0:21:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, lah!
Dialogue: 0,0:21:08.80,0:21:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keusilanmu itu tidak baik buat jantungku.
Dialogue: 0,0:21:15.47,0:21:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu usil lagi, akan kubalas!
Dialogue: 0,0:21:19.05,0:21:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik juga.
Dialogue: 0,0:21:21.05,0:21:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu sengaja,\Naku bakal mogok bicara!
Dialogue: 0,0:21:30.06,0:21:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kumakan punyamu!
Dialogue: 0,0:21:42.72,0:21:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Kadowaki?
Dialogue: 0,0:21:44.28,0:21:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu dia tampil di sini.
Dialogue: 0,0:21:46.69,0:21:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadowaki serbabisa, ya.
Dialogue: 0,0:21:49.31,0:21:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang.
Dialogue: 0,0:21:55.25,0:21:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana suaranya?
Dialogue: 0,0:21:59.31,0:22:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah hari pertama festival selesai.
