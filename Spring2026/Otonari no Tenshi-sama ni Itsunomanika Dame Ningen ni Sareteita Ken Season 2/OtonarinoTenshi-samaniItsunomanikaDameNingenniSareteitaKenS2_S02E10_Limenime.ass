Dialogue: 0,0:02:13.91,0:02:18.99,sign,,0000,0000,0000,,#10 JANJI PENTING DENGAN SANG BIDADARI
Dialogue: 0,0:02:29.50,0:02:33.26,sign,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:05:37.19,0:05:39.94,sign,,0000,0000,0000,,AKULAH MENTORNYA
Dialogue: 0,0:11:35.17,0:11:37.89,sign,,0000,0000,0000,,BLUBUK BLUBUK
Dialogue: 0,0:23:34.98,0:23:41.76,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:05.74,0:00:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, bolehkah aku menginap?
Dialogue: 0,0:00:12.28,0:00:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maksudnya?
Dialogue: 0,0:00:17.12,0:00:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sesuai ucapanku.
Dialogue: 0,0:00:21.58,0:00:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin jauh darimu,
Dialogue: 0,0:00:26.34,0:00:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ingin merasakanmu lebih banyak.
Dialogue: 0,0:00:31.26,0:00:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, ini belum cukup.
Dialogue: 0,0:00:34.43,0:00:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dua hari aku bersabar.
Dialogue: 0,0:00:38.38,0:00:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bersamamu lebih lama.
Dialogue: 0,0:00:43.40,0:00:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:00:45.69,0:00:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, rasanya agak bahaya.
Dialogue: 0,0:00:50.53,0:00:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pasangan,\Nmenginap itu wajar, kan?
Dialogue: 0,0:00:54.41,0:00:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagi pasangan normal, sih, iya.
Dialogue: 0,0:00:58.58,0:01:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kita tidak normal?
Dialogue: 0,0:01:01.50,0:01:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:01:03.75,0:01:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita baru pacaran beberapa bulan, lo.
Dialogue: 0,0:01:06.84,0:01:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di rumah orang tuamu saja\Naku pernah menginap.
Dialogue: 0,0:01:12.93,0:01:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu setidak mau itu?
Dialogue: 0,0:01:15.89,0:01:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:01:17.35,0:01:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku senang.
Dialogue: 0,0:01:19.98,0:01:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kamu bilang tidak mau menjauh,
Dialogue: 0,0:01:22.73,0:01:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya sungguh bahagia.
Dialogue: 0,0:01:25.42,0:01:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin bersamamu.
Dialogue: 0,0:01:28.19,0:01:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih oke lagi kalau bisa\Ntidur berdua tiap hari.
Dialogue: 0,0:01:31.36,0:01:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak mau menyakitimu.
Dialogue: 0,0:01:35.41,0:01:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak takut\Naku berbuat macam-macam?
Dialogue: 0,0:01:39.62,0:01:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memercayaimu.
Dialogue: 0,0:01:43.71,0:01:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kamu pasti\Nbertanggung jawab, kan?
Dialogue: 0,0:01:48.30,0:01:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:01:49.76,0:01:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai seorang manusia\Nsekaligus pacarmu,
Dialogue: 0,0:01:52.55,0:01:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku janji tidak akan bersikap lepas tangan.
Dialogue: 0,0:01:55.09,0:01:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah selesai, kan?
Dialogue: 0,0:01:57.85,0:01:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga.
Dialogue: 0,0:02:01.64,0:02:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:02:02.98,0:02:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong pelan-pelan.
Dialogue: 0,0:02:08.94,0:02:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:02:13.91,0:02:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah, akal sehatku.
Dialogue: 0,0:03:49.81,0:03:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya mandilah dulu\Ndi kamar mandimu.
Dialogue: 0,0:03:54.26,0:03:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya sampoku tidak cocok di kamu.
Dialogue: 0,0:03:57.13,0:03:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mandi?
Dialogue: 0,0:03:58.38,0:04:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu!
Dialogue: 0,0:04:00.05,0:04:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah paham.
Dialogue: 0,0:04:03.47,0:04:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane.
Dialogue: 0,0:04:05.93,0:04:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:04:06.93,0:04:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shihoko dan Shuuto\Nselalu mandi sama-sama, kan?
Dialogue: 0,0:04:12.52,0:04:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:16.11,0:04:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada maksud lain, sih.
Dialogue: 0,0:04:18.49,0:04:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada, sih...
Dialogue: 0,0:04:20.52,0:04:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mumpung menginap,
Dialogue: 0,0:04:25.29,0:04:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin mandi sama-sama.
Dialogue: 0,0:04:31.58,0:04:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukannya itu berbahaya?
Dialogue: 0,0:04:35.59,0:04:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya telanjang.
Dialogue: 0,0:04:37.09,0:04:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, anu...
Dialogue: 0,0:04:39.59,0:04:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pakai baju renang saja.
Dialogue: 0,0:04:51.73,0:04:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Permisi.
Dialogue: 0,0:05:04.95,0:05:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini yang Chitose maksud?
Dialogue: 0,0:05:10.37,0:05:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan aneh?
Dialogue: 0,0:05:12.83,0:05:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja cocok, tapi...
Dialogue: 0,0:05:16.84,0:05:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi?
Dialogue: 0,0:05:17.84,0:05:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dampaknya luar biasa.
Dialogue: 0,0:05:22.68,0:05:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya ini tidak kupakai\Nwaktu di kolam renang.
Dialogue: 0,0:05:25.56,0:05:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan memalukan kalau dilihat orang.
Dialogue: 0,0:05:28.35,0:05:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa dibeli?
Dialogue: 0,0:05:30.31,0:05:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya,
Dialogue: 0,0:05:32.14,0:05:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose bilang harus pakai ini\Nbiar kamu terpikat.
Dialogue: 0,0:05:37.19,0:05:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose...
Dialogue: 0,0:05:40.65,0:05:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sudah pasti aku terpikat\Nkalau dipamerkan yang begini.
Dialogue: 0,0:05:47.49,0:05:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keramas dulu, yuk.
Dialogue: 0,0:05:49.25,0:05:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah.
Dialogue: 0,0:05:51.58,0:05:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan duduk.
Dialogue: 0,0:05:53.96,0:05:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, aku bisa keramas sendiri.
Dialogue: 0,0:05:57.09,0:05:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama aku saja!
Dialogue: 0,0:05:59.88,0:06:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari dulu, aku ingin mencoba\Nmembersihkan rambutmu.
Dialogue: 0,0:06:10.18,0:06:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu santai sekali, ya.
Dialogue: 0,0:06:12.56,0:06:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:06:14.15,0:06:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap menerima
Dialogue: 0,0:06:16.48,0:06:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perawatan apa pun darimu.
Dialogue: 0,0:06:19.01,0:06:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya pasti terasa nyaman.
Dialogue: 0,0:06:22.32,0:06:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga sesuai ekspektasimu, ya.
Dialogue: 0,0:06:27.10,0:06:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, sisir debu dan kotoran rambut
Dialogue: 0,0:06:30.12,0:06:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu jangan lupa dibasuh air hangat.
Dialogue: 0,0:06:33.04,0:06:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu caranya.
Dialogue: 0,0:06:34.62,0:06:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajib bagiku yang berambut panjang.
Dialogue: 0,0:06:38.29,0:06:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja rambutmu bersih\Nmeskipun sepanjang ini.
Dialogue: 0,0:06:42.05,0:06:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti repot, ya.
Dialogue: 0,0:06:43.97,0:06:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar cocok kalau pakai baju apa pun.
Dialogue: 0,0:06:48.72,0:06:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku ingin menjadi diri\Nyang bisa kubanggakan.
Dialogue: 0,0:06:52.48,0:06:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilas, ya.
Dialogue: 0,0:06:54.44,0:06:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:58.23,0:07:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekstur rambutmu bagus.
Dialogue: 0,0:07:01.65,0:07:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi akan lebih bagus kalau dirawat.
Dialogue: 0,0:07:04.78,0:07:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Repot juga kalau harus tiap hari.
Dialogue: 0,0:07:07.99,0:07:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh malas kalau soal itu.
Dialogue: 0,0:07:11.24,0:07:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja ini latihan
Dialogue: 0,0:07:13.50,0:07:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar kita terbiasa melakukan ini\Ntiap mandi bersama nantinya.
Dialogue: 0,0:07:17.08,0:07:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mohon bantuannya.
Dialogue: 0,0:07:22.25,0:07:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Mahiru?
Dialogue: 0,0:07:24.97,0:07:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara begitu dengan santai
Dialogue: 0,0:07:27.59,0:07:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah sisi burukmu.
Dialogue: 0,0:07:31.06,0:07:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, badannya juga, ya.
Dialogue: 0,0:07:34.48,0:07:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan memaksakan dirimu.
Dialogue: 0,0:07:37.27,0:07:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kok.
Dialogue: 0,0:07:41.07,0:07:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tolong urus sendiri bagian depannya.
Dialogue: 0,0:07:45.15,0:07:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gosok bagian punggung saja.
Dialogue: 0,0:07:47.66,0:07:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau begitu.
Dialogue: 0,0:07:51.83,0:07:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punggungmu lebar, ya.
Dialogue: 0,0:07:55.25,0:07:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibandingkan kamu,\Nmemang lebar, sih.
Dialogue: 0,0:07:58.42,0:08:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru terasa lebar\Nkarena ini punggung kamu,
Dialogue: 0,0:08:03.05,0:08:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang selalu kuandalkan.
Dialogue: 0,0:08:06.67,0:08:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu ingat
Dialogue: 0,0:08:08.13,0:08:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktu menggendongku\Nsaat kakiku terkilir?
Dialogue: 0,0:08:11.97,0:08:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kamu menolong kucing, kan?
Dialogue: 0,0:08:14.39,0:08:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat senang waktu itu.
Dialogue: 0,0:08:17.44,0:08:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak kutunjukkan, sih.
Dialogue: 0,0:08:19.90,0:08:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak kebingungan waktu itu.
Dialogue: 0,0:08:22.36,0:08:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru sadar kalau kamu\Nselalu ada di saat seperti itu.
Dialogue: 0,0:08:32.58,0:08:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu menemukanku.
Dialogue: 0,0:08:38.69,0:08:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap menggendongmu kapan pun.
Dialogue: 0,0:08:42.08,0:08:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menopangmu.
Dialogue: 0,0:08:44.14,0:08:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan karena sudah berjanji\Ntidak akan berpaling,
Dialogue: 0,0:08:47.59,0:08:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan selalu ada untukmu.
Dialogue: 0,0:08:49.33,0:08:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:50.93,0:08:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi...
Dialogue: 0,0:08:52.64,0:08:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen ini kurang pas\Nbuat menggendongmu.
Dialogue: 0,0:08:56.22,0:08:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lepaskan dulu.
Dialogue: 0,0:08:58.77,0:09:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau membebanimu.
Dialogue: 0,0:09:01.69,0:09:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus saling bantu.
Dialogue: 0,0:09:04.02,0:09:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:09:04.98,0:09:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan katanya kamu akan senang\Nkalau aku melakukan ini saat menginap.
Dialogue: 0,0:09:09.95,0:09:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose!
Dialogue: 0,0:09:13.07,0:09:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berterimakasihlah!
Dialogue: 0,0:09:18.45,0:09:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, kamu tidak jenuh?
Dialogue: 0,0:09:23.25,0:09:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena apa?
Dialogue: 0,0:09:24.59,0:09:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,
Dialogue: 0,0:09:27.84,0:09:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tindakanku sering tidak sinkron\Ndan setengah-setengah.
Dialogue: 0,0:09:32.64,0:09:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin jenuh.
Dialogue: 0,0:09:35.14,0:09:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham betul cinta dan usahamu\Nmeski ujungnya kalah oleh rasa malu.
Dialogue: 0,0:09:40.39,0:09:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu, dong.
Dialogue: 0,0:09:44.10,0:09:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya...
Dialogue: 0,0:09:45.19,0:09:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah tahu,\Njangan diperjelas terlalu detail.
Dialogue: 0,0:09:49.44,0:09:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak yakin bisa mengendalikan diri,
Dialogue: 0,0:09:53.66,0:09:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa terlalu dipancing, Nona.
Dialogue: 0,0:09:57.28,0:10:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu kelihatan biasa saja dari tadi.
Dialogue: 0,0:10:01.16,0:10:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok, coba saja periksa.
Dialogue: 0,0:10:10.92,0:10:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbukti, kan?
Dialogue: 0,0:10:12.30,0:10:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga deg-degan.
Dialogue: 0,0:10:13.76,0:10:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira kamu sudah terbiasa.
Dialogue: 0,0:10:16.85,0:10:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada.
Dialogue: 0,0:10:18.35,0:10:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ingin melakukan ini dan itu,
Dialogue: 0,0:10:20.47,0:10:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menahannya.
Dialogue: 0,0:10:22.31,0:10:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dan itu...
Dialogue: 0,0:10:37.52,0:10:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melakukannya di sini, takutnya kamu kelimpungan.
Dialogue: 0,0:10:41.58,0:10:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:43.41,0:10:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kecewa?
Dialogue: 0,0:10:46.17,0:10:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat banget, malah bertanya begitu!
Dialogue: 0,0:10:49.17,0:10:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:10:53.34,0:10:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hangat sekali.
Dialogue: 0,0:10:55.13,0:10:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:57.89,0:10:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane.
Dialogue: 0,0:11:00.35,0:11:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal yang tadi...
Dialogue: 0,0:11:02.64,0:11:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tadi?
Dialogue: 0,0:11:04.18,0:11:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal ciuman.
Dialogue: 0,0:11:08.19,0:11:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah selesai mandi,\Nkita boleh ciuman, kan?
Dialogue: 0,0:11:16.91,0:11:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:11:18.99,0:11:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, ucapanmu menggemaskan.
Dialogue: 0,0:11:22.58,0:11:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan keinginan kita sama.
Dialogue: 0,0:11:25.33,0:11:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi setelah mandi, bersiaplah.
Dialogue: 0,0:11:28.83,0:11:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tarik ucapanku!
Dialogue: 0,0:11:31.67,0:11:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:11:32.59,0:11:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat.
Dialogue: 0,0:11:33.63,0:11:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang.
Dialogue: 0,0:11:39.14,0:11:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:11:43.52,0:11:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucingnya dipajang dengan baik, ya.
Dialogue: 0,0:11:47.52,0:11:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak\Nmembawanya tidur kayak kamu.
Dialogue: 0,0:11:51.11,0:11:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengejekku?
Dialogue: 0,0:11:52.86,0:11:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku mengejek\Ntindakan seimut itu.
Dialogue: 0,0:11:55.65,0:11:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kamu menjaganya.
Dialogue: 0,0:11:58.59,0:12:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang pemberianmu\Nakan kujaga baik-baik.
Dialogue: 0,0:12:03.18,0:12:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:12:04.98,0:12:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka beruangmu tidak dibawa?
Dialogue: 0,0:12:07.92,0:12:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya hari ini ada kamu.
Dialogue: 0,0:12:17.42,0:12:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:22.26,0:12:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, anu...
Dialogue: 0,0:12:24.06,0:12:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak risi karena serasa diawasi.
Dialogue: 0,0:12:28.39,0:12:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keresahanmu aneh juga.
Dialogue: 0,0:12:30.94,0:12:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet.
Dialogue: 0,0:12:32.23,0:12:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu imut.
Dialogue: 0,0:12:33.48,0:12:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi enggak tidur sama boneka beruang.
Dialogue: 0,0:12:36.94,0:12:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah dibahas lagi?
Dialogue: 0,0:12:39.20,0:12:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih!
Dialogue: 0,0:12:42.74,0:12:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mewujudkan rencana kita\Nwaktu di kamar mandi?
Dialogue: 0,0:12:47.37,0:12:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:13.86,0:13:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu menginginkanku...
Dialogue: 0,0:13:19.07,0:13:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap mengabulkannya.
Dialogue: 0,0:13:33.29,0:13:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:13:36.13,0:13:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:37.71,0:13:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya,
Dialogue: 0,0:13:40.05,0:13:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menginginkanmu.
Dialogue: 0,0:13:42.26,0:13:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:44.22,0:13:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:13:46.39,0:13:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}usiaku belum cukup dewasa\Nuntuk bertanggung jawab.
Dialogue: 0,0:13:50.56,0:13:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terjadi sesuatu,
Dialogue: 0,0:13:52.23,0:13:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}takutnya kamu malah menderita.
Dialogue: 0,0:13:57.11,0:14:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap hidup bersamamu selamanya,
Dialogue: 0,0:14:00.54,0:14:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi untuk sekarang...
Dialogue: 0,0:14:03.24,0:14:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah diteruskan.
Dialogue: 0,0:14:06.49,0:14:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu betul kamu sangat menghormati
Dialogue: 0,0:14:11.96,0:14:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mencintaiku begitu dalam.
Dialogue: 0,0:14:15.81,0:14:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh bahagia
Dialogue: 0,0:14:19.13,0:14:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diperlakukan sebaik ini.
Dialogue: 0,0:14:30.22,0:14:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah, aku teramat mencintaimu.
Dialogue: 0,0:14:34.94,0:14:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru...
Dialogue: 0,0:14:41.86,0:14:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kamu menunggu sampai aku
Dialogue: 0,0:14:44.57,0:14:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sanggup bertanggung jawab?
Dialogue: 0,0:14:47.53,0:14:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dijaga dengan baik\Nsampai waktunya tiba.
Dialogue: 0,0:14:51.75,0:14:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjagamu.
Dialogue: 0,0:14:54.54,0:14:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, aku boleh berkata hal payah?
Dialogue: 0,0:14:58.04,0:14:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:14:59.04,0:15:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap menerima sisi keren, sisi payah,\Nmaupun permintaan dari orang yang kucintai.
Dialogue: 0,0:15:08.01,0:15:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku menyentuhmu sedikit lagi?
Dialogue: 0,0:15:14.88,0:15:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}To-Tolong pelan-pelan, ya.
Dialogue: 0,0:15:26.05,0:15:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane.
Dialogue: 0,0:15:27.45,0:15:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarapannya sudah siap.
Dialogue: 0,0:15:29.24,0:15:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cuci muka dan ganti bajumu.
Dialogue: 0,0:15:33.54,0:15:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ini kayak mimpi.
Dialogue: 0,0:15:36.79,0:15:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebai, ah.
Dialogue: 0,0:15:38.50,0:15:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau masih melindur,\Nsini aku bangunkan.
Dialogue: 0,0:15:49.79,0:15:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya itu harus ditutupi.
Dialogue: 0,0:15:53.85,0:15:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ulahmu, tahu!
Dialogue: 0,0:15:55.93,0:15:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal itu.
Dialogue: 0,0:15:57.85,0:15:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lepas kendali.
Dialogue: 0,0:15:59.94,0:16:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal niatnya pelan-pelan sesuai janji.
Dialogue: 0,0:16:04.23,0:16:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Po-Pokoknya,
Dialogue: 0,0:16:05.94,0:16:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cepat cuci muka dan ganti baju sana.
Dialogue: 0,0:16:08.41,0:16:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dinginkan kepalamu.
Dialogue: 0,0:16:10.07,0:16:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kepalamu\Nyang harus didinginkan.
Dialogue: 0,0:16:13.41,0:16:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa tadi?
Dialogue: 0,0:16:18.83,0:16:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:21.11,0:16:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:16:22.38,0:16:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu juga, ya, kalau bau kita\Nada di tubuh pasangan.
Dialogue: 0,0:16:26.22,0:16:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bicara apa, sih?
Dialogue: 0,0:16:31.22,0:16:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru!
Dialogue: 0,0:16:33.64,0:16:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:16:35.56,0:16:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Padahal baru ketemu kemarin.\N- Wangi, wangi, wangi.
Dialogue: 0,0:16:37.98,0:16:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah seharian terpisah\Ndari anak imut ini.
Dialogue: 0,0:16:41.73,0:16:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja kalau kangen.
Dialogue: 0,0:16:43.48,0:16:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya waktu itu kuat pisah sebulan?
Dialogue: 0,0:16:46.44,0:16:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan rewel.
Dialogue: 0,0:16:47.99,0:16:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kangen, ya, kangen.
Dialogue: 0,0:16:49.70,0:16:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru.
Dialogue: 0,0:16:50.70,0:16:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan saja kalau kamu risi.
Dialogue: 0,0:16:52.82,0:16:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kamu ini.
Dialogue: 0,0:16:55.37,0:16:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru aku senang.
Dialogue: 0,0:16:57.12,0:16:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, tuh.
Dialogue: 0,0:16:58.12,0:17:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tirulah keimutan Mahiru.
Dialogue: 0,0:17:00.50,0:17:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu bakal enek kalau aku jadi seramah dia.
Dialogue: 0,0:17:03.79,0:17:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:17:05.63,0:17:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu waktu dulu\Nseimut bidadari juga, kok.
Dialogue: 0,0:17:09.80,0:17:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang malah jadi jutek dan tidak imut.
Dialogue: 0,0:17:12.26,0:17:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, deh.
Dialogue: 0,0:17:14.72,0:17:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kok kalian bisa libur\Ndi waktu bersamaan?
Dialogue: 0,0:17:19.56,0:17:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjaanku kelar sebelum tenggat waktunya.
Dialogue: 0,0:17:22.52,0:17:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya, bisa atur waktu.
Dialogue: 0,0:17:24.98,0:17:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku karena beruntung.
Dialogue: 0,0:17:26.98,0:17:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal istirahat saja di rumah,
Dialogue: 0,0:17:29.44,0:17:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak perlu ke sini segala.
Dialogue: 0,0:17:31.61,0:17:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena selalu berduaan di rumah,
Dialogue: 0,0:17:34.74,0:17:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajar kalau ingin\Nberkunjung sesekali, kan?
Dialogue: 0,0:17:40.58,0:17:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:17:42.25,0:17:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Amane.
Dialogue: 0,0:17:44.71,0:17:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku jalan-jalan sama Mahiru?
Dialogue: 0,0:17:47.55,0:17:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izin saja langsung ke orangnya.
Dialogue: 0,0:17:50.55,0:17:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, aku juga pengin\Njalan-jalan bersamamu.
Dialogue: 0,0:17:54.51,0:17:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, deh!
Dialogue: 0,0:17:56.22,0:18:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian jalan-jalan berdua,\NAyah bagaimana?
Dialogue: 0,0:18:00.13,0:18:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Shuuto bilang\Nmau membahas sesuatu denganmu.
Dialogue: 0,0:18:07.19,0:18:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti menurutmu,\NShihoko orangnya periang.
Dialogue: 0,0:18:11.40,0:18:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang menurutmu bagaimana?
Dialogue: 0,0:18:13.78,0:18:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, dia manja dan gampang kesepian.
Dialogue: 0,0:18:17.70,0:18:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kamu pindah,
Dialogue: 0,0:18:19.49,0:18:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia selalu mengeluh kesepian.
Dialogue: 0,0:18:23.25,0:18:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak kelihatan?
Dialogue: 0,0:18:25.50,0:18:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya dia orang dewasa\Nyang bisa mengontrol diri.
Dialogue: 0,0:18:29.05,0:18:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tahu seorang anak\Nmemang harus mandiri.
Dialogue: 0,0:18:35.30,0:18:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan risau.
Dialogue: 0,0:18:37.93,0:18:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku dan Shihoko,
Dialogue: 0,0:18:39.72,0:18:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang penting kamu\Nhidup sehat dan bahagia.
Dialogue: 0,0:18:45.02,0:18:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatmu bisa jadi diri sendiri,
Dialogue: 0,0:18:48.94,0:18:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku turut senang sebagai orang tua.
Dialogue: 0,0:18:51.53,0:18:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku sangat bahagia.
Dialogue: 0,0:18:55.32,0:18:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:18:59.16,0:19:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku mau menyampaikan satu hal.
Dialogue: 0,0:19:03.29,0:19:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:05.17,0:19:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir soal biaya.
Dialogue: 0,0:19:08.71,0:19:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya,\Nkalian sudah siap berkomitmen.
Dialogue: 0,0:19:13.67,0:19:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu
Dialogue: 0,0:19:15.30,0:19:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tipe orang bertekad kuat\Ndan pantang menyerah.
Dialogue: 0,0:19:21.97,0:19:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita benar-benar mirip.
Dialogue: 0,0:19:24.60,0:19:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu cinta pertamanya Ayah juga?
Dialogue: 0,0:19:26.94,0:19:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:30.36,0:19:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali ke topik.
Dialogue: 0,0:19:32.65,0:19:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti memikirkan matang-matang\Nmasa depan bersama Shiina, kan?
Dialogue: 0,0:19:38.70,0:19:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai anak cerdas,
Dialogue: 0,0:19:40.28,0:19:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak berpikir untuk menghadapi semua\Nmasalah cuma bermodalkan perasaan, kan?
Dialogue: 0,0:19:47.54,0:19:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah ngeri banget.
Dialogue: 0,0:19:49.96,0:19:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini seorang ayah,
Dialogue: 0,0:19:51.88,0:19:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajar kalau tahu pikiran anak sendiri.
Dialogue: 0,0:19:54.38,0:19:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencoba menanggung semuanya sendiri
Dialogue: 0,0:19:58.26,0:19:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar sifatmu.
Dialogue: 0,0:20:00.14,0:20:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keputusanku sendiri.
Dialogue: 0,0:20:03.14,0:20:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat menjelaskan ke Mahiru\Nsetelah rencananya matang.
Dialogue: 0,0:20:07.64,0:20:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berencana sejauh itu\Ndi usia semuda ini memang bagus.
Dialogue: 0,0:20:12.61,0:20:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sendiri...
Dialogue: 0,0:20:13.82,0:20:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, kalau berdua\Npasti akan ada batasnya.
Dialogue: 0,0:20:17.32,0:20:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pepatah bilang, "Manfaatkan apa pun\Nbahkan orang tuamu."
Dialogue: 0,0:20:21.37,0:20:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kami berdua\Nyang harus mengatasinya?
Dialogue: 0,0:20:25.29,0:20:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sampai kapan?
Dialogue: 0,0:20:29.25,0:20:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau Shiina menunggu kelamaan?
Dialogue: 0,0:20:31.67,0:20:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi seorang wanita,\Nwaktu sangatlah berharga.
Dialogue: 0,0:20:35.84,0:20:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:37.63,0:20:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perayaan adalah hadiah besar terakhir\Nyang bisa orang tua berikan.
Dialogue: 0,0:20:43.93,0:20:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya putra dan putri mereka\Nakan pergi membangun keluarga baru.
Dialogue: 0,0:20:49.35,0:20:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah,\Norang tua sangat ingin membantu.
Dialogue: 0,0:20:53.15,0:20:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, kami tetap setuju\Nkalau kalian memang mau urus sendiri.
Dialogue: 0,0:20:59.10,0:21:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau tidak, izinkan kami mendukung
Dialogue: 0,0:21:02.82,0:21:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mewakili orang tuanya Shiina juga.
Dialogue: 0,0:21:05.95,0:21:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu, kamu kurang pandai\Nbermanja dan minta tolong.
Dialogue: 0,0:21:10.29,0:21:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku jadi orang tua yang baik.
Dialogue: 0,0:21:13.04,0:21:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah sangat memanjakanku.
Dialogue: 0,0:21:15.84,0:21:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:21:17.42,0:21:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak punya fase memberontak
Dialogue: 0,0:21:20.05,0:21:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan justru mandiri sejak dini,
Dialogue: 0,0:21:22.55,0:21:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah kesepian.
Dialogue: 0,0:21:24.45,0:21:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu saat nanti,\Nmungkin kamu akan mengerti.
Dialogue: 0,0:21:32.06,0:21:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:21:33.81,0:21:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja ini baktimu ke orang tua.
Dialogue: 0,0:21:39.19,0:21:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau kamu pribadi\Ningin memberi sesuatu ke Mahiru,
Dialogue: 0,0:21:43.20,0:21:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tidak akan ikut campur.
Dialogue: 0,0:21:59.63,0:22:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus kerja sambilan\Nuntuk mengumpulkan modal.
