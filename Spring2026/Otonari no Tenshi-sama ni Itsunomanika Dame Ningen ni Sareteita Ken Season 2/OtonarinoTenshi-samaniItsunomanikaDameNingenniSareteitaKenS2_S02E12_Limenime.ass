Dialogue: 0,0:01:07.13,0:01:11.30,sign,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:10:16.01,0:10:22.02,sign,,0000,0000,0000,,#12 HARI YANG DITUNGGU-TUNGGU SANG BIDADARI
Dialogue: 0,0:23:33.35,0:23:42.85,sign,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:00:09.26,0:00:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya?
Dialogue: 0,0:00:11.45,0:00:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget!\NDijual pun pasti laku keras!
Dialogue: 0,0:00:15.91,0:00:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, pahitnya juga pas!\NIni cita rasa orang dewasa!
Dialogue: 0,0:00:20.92,0:00:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta memang hebat.
Dialogue: 0,0:00:23.17,0:00:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usaha demi orang tercintamu\Nsangat tersampaikan.
Dialogue: 0,0:00:27.73,0:00:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kalian menyukainya.
Dialogue: 0,0:00:30.21,0:00:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku butuh masukan.
Dialogue: 0,0:00:32.54,0:00:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Masih mau disempurnakan?
Dialogue: 0,0:00:35.02,0:00:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun niat banget!
Dialogue: 0,0:00:37.02,0:00:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku butuh bantuan Kido\Nbuat menyiapkan bahan rahasia untuk Amane.
Dialogue: 0,0:00:43.63,0:00:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, protein, kan?
Dialogue: 0,0:00:45.68,0:00:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, bukan itu.
Dialogue: 0,0:02:36.76,0:02:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, sudah enak.
Dialogue: 0,0:02:40.01,0:02:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ekstraksinya jangan lama-lama.
Dialogue: 0,0:02:42.96,0:02:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:02:44.27,0:02:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makan waktu karena belum\Nterbiasa sama alatnya, kan?
Dialogue: 0,0:02:48.80,0:02:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akibatnya kopinya jadi agak sepat.
Dialogue: 0,0:02:52.32,0:02:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:02:53.28,0:02:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku juga sempat\Nketakutan merusak alatnya.
Dialogue: 0,0:02:58.28,0:03:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi asal tidak jatuh\Ndan dipakai dengan lembut, aman.
Dialogue: 0,0:03:01.52,0:03:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi kamu tipe orang telaten.
Dialogue: 0,0:03:04.82,0:03:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja begitu.
Dialogue: 0,0:03:06.79,0:03:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi si bod—
Dialogue: 0,0:03:08.40,0:03:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rino memecahkannya waktu baru bekerja.
Dialogue: 0,0:03:10.24,0:03:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kelihatannya itu enak!
Dialogue: 0,0:03:13.55,0:03:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya, minta seteguk, dong.
Dialogue: 0,0:03:16.18,0:03:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hargai perasaan pacar Fujimiya.
Dialogue: 0,0:03:19.36,0:03:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.\NSoalnya kakak laki-lakiku banyak.
Dialogue: 0,0:03:22.61,0:03:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terlihat akrab, ya.
Dialogue: 0,0:03:24.73,0:03:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga teman masa kecil.
Dialogue: 0,0:03:27.06,0:03:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tidak mau jadi akrab.
Dialogue: 0,0:03:29.52,0:03:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat banget!
Dialogue: 0,0:03:32.61,0:03:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:03:34.11,0:03:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Amane, tumben pulang cepat.
Dialogue: 0,0:03:37.86,0:03:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, orang lain yang beres-beres.
Dialogue: 0,0:03:41.17,0:03:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan lariku lebih cepat dari biasanya.
Dialogue: 0,0:03:45.62,0:03:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, maaf.
Dialogue: 0,0:03:47.54,0:03:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegiatan pribadimu jadi terganggu\Nkarena aku pulang cepat, ya?
Dialogue: 0,0:03:52.42,0:03:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru aku senang\Nbisa melihatmu lebih cepat.
Dialogue: 0,0:03:56.88,0:03:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau begitu.
Dialogue: 0,0:04:00.48,0:04:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:04:02.45,0:04:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencium aroma yang manis.
Dialogue: 0,0:04:05.89,0:04:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:07.48,0:04:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu karena aku makan camilan.
Dialogue: 0,0:04:15.44,0:04:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya ada yang Mahiru rahasiakan?
Dialogue: 0,0:04:18.64,0:04:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia?
Dialogue: 0,0:04:19.98,0:04:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, terlihat dari gerak-geriknya.
Dialogue: 0,0:04:23.23,0:04:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya Shiina tidak akan\Nmerahasiakan yang aneh-aneh.
Dialogue: 0,0:04:26.98,0:04:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:29.04,0:04:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana?
Dialogue: 0,0:04:30.77,0:04:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:04:33.59,0:04:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat-lihat,\Nkamu berpendirian kuat, ya.
Dialogue: 0,0:04:38.53,0:04:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:04:39.55,0:04:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sadar setelah kita sering bicara,
Dialogue: 0,0:04:43.00,0:04:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu melakukan peran pacar dengan baik.
Dialogue: 0,0:04:45.77,0:04:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku harus jadi diri yang bisa dibanggakan\Nsupaya layak bersanding dengan Mahiru.
Dialogue: 0,0:04:52.59,0:04:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkat dia.
Dialogue: 0,0:04:54.84,0:04:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah pamer, deh.
Dialogue: 0,0:04:57.25,0:04:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel, ah.
Dialogue: 0,0:05:08.05,0:05:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru.
Dialogue: 0,0:05:08.87,0:05:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:05:10.21,0:05:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku memelukmu?
Dialogue: 0,0:05:13.99,0:05:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:05:19.59,0:05:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap hari kamu beraroma manis.
Dialogue: 0,0:05:26.14,0:05:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:27.10,0:05:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku kelewatan.
Dialogue: 0,0:05:29.47,0:05:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu salah paham!
Dialogue: 0,0:05:32.20,0:05:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukannya tidak suka dipeluk!
Dialogue: 0,0:05:35.75,0:05:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh.
Dialogue: 0,0:05:37.69,0:05:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang khawatir soal perut.
Dialogue: 0,0:05:42.17,0:05:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perut?
Dialogue: 0,0:05:43.44,0:05:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kayaknya tambah gemuk,
Dialogue: 0,0:05:46.33,0:05:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi takut dipegang di pinggang.
Dialogue: 0,0:05:49.20,0:05:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin,\Nlagi pula pola makanmu teratur.
Dialogue: 0,0:05:54.55,0:05:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak teratur?
Dialogue: 0,0:05:55.67,0:06:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Teratur!\NAku makan tiga kali sehari.
Dialogue: 0,0:06:00.64,0:06:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, di luar itu...
Dialogue: 0,0:06:05.18,0:06:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sering nyemil?
Dialogue: 0,0:06:07.37,0:06:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena aku plin-plan\Ndan terlalu perfeksionis.
Dialogue: 0,0:06:11.95,0:06:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:12.57,0:06:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, kalau disentuh sekarang,\Ntakut lemaknya...
Dialogue: 0,0:06:16.94,0:06:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin dimanja olehmu, tidak boleh?
Dialogue: 0,0:06:21.95,0:06:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, sih.
Dialogue: 0,0:06:26.44,0:06:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan!
Dialogue: 0,0:06:34.39,0:06:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tidak berubah, kok.
Dialogue: 0,0:06:36.89,0:06:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja aku khawatir.
Dialogue: 0,0:06:40.37,0:06:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut,\Naku mencintaimu apa adanya.
Dialogue: 0,0:06:46.07,0:06:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kamu harum cokelat.
Dialogue: 0,0:06:48.72,0:06:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang kamu bisa manja juga, ya.
Dialogue: 0,0:06:53.60,0:06:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau begitu pun boleh,\Nasal jangan ada bekasnya.
Dialogue: 0,0:06:58.48,0:07:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi diledek karena bekas menginap\Nwaktu itu kelihatan sama Chitose.
Dialogue: 0,0:07:04.43,0:07:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, seharusnya\Ndi bagian yang tertutup, ya.
Dialogue: 0,0:07:09.49,0:07:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu masalahnya!
Dialogue: 0,0:07:12.69,0:07:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah terbiasa, kamu selalu begini!
Dialogue: 0,0:07:22.71,0:07:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, lakukan di bagian\Nyang tidak terlihat.
Dialogue: 0,0:07:26.79,0:07:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kamu setuju\Nkalau aku lakukan lagi, kan?
Dialogue: 0,0:07:30.01,0:07:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}So-Soal itu...
Dialogue: 0,0:07:33.49,0:07:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang kamu lakukan, aku senang.
Dialogue: 0,0:07:38.20,0:07:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disentuh olehmu rasanya nyaman.
Dialogue: 0,0:07:42.47,0:07:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukainya.
Dialogue: 0,0:07:51.24,0:07:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting, jangan meninggalkan bekas.
Dialogue: 0,0:07:55.03,0:07:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, di hari ulang...
Dialogue: 0,0:07:58.14,0:07:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:59.07,0:08:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa, lupakan saja.
Dialogue: 0,0:08:02.36,0:08:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi kepo, nih.
Dialogue: 0,0:08:04.38,0:08:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:08:08.32,0:08:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ringan sekali.
Dialogue: 0,0:08:16.14,0:08:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin malah main sama kami,\NTuan Pengantin Baru?
Dialogue: 0,0:08:20.39,0:08:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum, woi.
Dialogue: 0,0:08:22.52,0:08:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya tidak lelah?
Dialogue: 0,0:08:24.87,0:08:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kerja empat hari seminggu, kan?
Dialogue: 0,0:08:26.90,0:08:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini saja melelahkan,
Dialogue: 0,0:08:29.15,0:08:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya Kadowaki\Nsudah tepar karena ekskul.
Dialogue: 0,0:08:33.44,0:08:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku tetap ada libur\Ndan tidak kerja sambilan.
Dialogue: 0,0:08:37.52,0:08:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, dan kamu itu pemalu, kan?\NMemangnya tidak stres di tempat kerja?
Dialogue: 0,0:08:43.52,0:08:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:08:45.16,0:08:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamunya kebanyakan\Norang dewasa yang santai.
Dialogue: 0,0:08:48.67,0:08:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para seniorku juga baik.
Dialogue: 0,0:08:50.59,0:08:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:08:52.29,0:08:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu yang merayumu, tidak?
Dialogue: 0,0:08:55.22,0:08:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:08:56.48,0:08:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelihatan gampang\Ndisukai orang yang lebih tua.
Dialogue: 0,0:08:59.69,0:09:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang sering\Nmengajakku bicara, sih.
Dialogue: 0,0:09:02.98,0:09:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kamu populer, dong?
Dialogue: 0,0:09:05.04,0:09:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu juga membayangkan Amane\Ndikerumuni nyonya-nyonya gabut.
Dialogue: 0,0:09:08.84,0:09:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kalian...
Dialogue: 0,0:09:10.83,0:09:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku bukan begitu!
Dialogue: 0,0:09:15.89,0:09:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya.
Dialogue: 0,0:09:17.43,0:09:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:09:19.00,0:09:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:09:20.60,0:09:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batas waktu meminjammu dari sang Istri.
Dialogue: 0,0:09:23.75,0:09:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:09:25.11,0:09:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu luangmu pun makin terbatas.
Dialogue: 0,0:09:27.76,0:09:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti banyak yang ingin\Nkamu lakukan di rumah.
Dialogue: 0,0:09:30.24,0:09:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:09:34.49,0:09:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Amane.
Dialogue: 0,0:09:35.79,0:09:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:38.37,0:09:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai besok.
Dialogue: 0,0:09:40.27,0:09:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kutanyakan, bersiaplah.
Dialogue: 0,0:09:42.99,0:09:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga, sampai besok.
Dialogue: 0,0:09:53.11,0:09:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Amane.
Dialogue: 0,0:09:55.87,0:09:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.\NKok kamu ceria sekali?
Dialogue: 0,0:09:59.15,0:10:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya, kamu belum\Nmenyadarinya selama seharian ini, ya?
Dialogue: 0,0:10:05.69,0:10:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal apa?
Dialogue: 0,0:10:07.19,0:10:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak ingat ini hari apa, ya?
Dialogue: 0,0:10:14.37,0:10:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini...
Dialogue: 0,0:10:16.60,0:10:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ulang tahunmu.
Dialogue: 0,0:10:25.51,0:10:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulang tahun?
Dialogue: 0,0:10:28.75,0:10:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kamu ini.
Dialogue: 0,0:10:32.33,0:10:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun, Amane.
Dialogue: 0,0:10:37.01,0:10:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar lupa.
Dialogue: 0,0:10:39.06,0:10:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, ini hari yang istimewa.
Dialogue: 0,0:10:43.24,0:10:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpamu, aku tidak akan tahu\Nmakna sebenarnya dari memercayai
Dialogue: 0,0:10:48.35,0:10:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mencintai seseorang.
Dialogue: 0,0:10:51.80,0:10:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga jadi bisa merasakan kebahagiaan\Ndari lubuk hati terdalam.
Dialogue: 0,0:10:59.85,0:11:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bersyukur\Nkamu telah terlahir ke dunia.
Dialogue: 0,0:11:06.84,0:11:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak
Dialogue: 0,0:11:09.01,0:11:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena sudah lahir ke dunia
Dialogue: 0,0:11:11.37,0:11:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bertemu denganku.
Dialogue: 0,0:11:13.65,0:11:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih juga
Dialogue: 0,0:11:15.82,0:11:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena sudah berpikir begitu
Dialogue: 0,0:11:18.71,0:11:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merayakan ulang tahunku.
Dialogue: 0,0:11:21.83,0:11:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan juga maaf.
Dialogue: 0,0:11:24.45,0:11:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya ini mau dirayakan beramai-ramai.
Dialogue: 0,0:11:30.68,0:11:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku
Dialogue: 0,0:11:32.87,0:11:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}minta pada mereka agar kita\Nmerayakannya berdua saja.
Dialogue: 0,0:11:41.71,0:11:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka teman yang baik, ya.
Dialogue: 0,0:11:44.80,0:11:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:51.56,0:11:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mewah banget!
Dialogue: 0,0:11:53.28,0:11:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hidangan-hidangan telur kesukaanmu.
Dialogue: 0,0:11:56.40,0:12:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lauk-lauknya dibuat tanpa\Nmenghiraukan variasi dan gizinya, sih.
Dialogue: 0,0:12:01.21,0:12:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma sehari, aman, kok.
Dialogue: 0,0:12:03.92,0:12:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkah ulang tahun.
Dialogue: 0,0:12:06.44,0:12:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamagoyakinya aku buatkan besok pagi, ya.
Dialogue: 0,0:12:10.19,0:12:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutambahkan\Nsalmon panggang miso kesukaanmu.
Dialogue: 0,0:12:14.53,0:12:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sup misonya pakai tahu dan lobak, ya?
Dialogue: 0,0:12:17.51,0:12:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarapannya mantap banget.
Dialogue: 0,0:12:19.91,0:12:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja makan malam ini juga.
Dialogue: 0,0:12:24.61,0:12:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo dimakan sebelum dingin.
Dialogue: 0,0:12:28.15,0:12:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semur daging sapinya\Naku buat selembut mungkin, lo.
Dialogue: 0,0:12:32.75,0:12:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik, nasi omelet yang disiram semur\Npasti enak banget.
Dialogue: 0,0:12:36.74,0:12:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:38.24,0:12:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:12:50.73,0:12:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:52.36,0:12:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:12:53.20,0:12:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatmu sangat lahap,\Naku turut puas sebagai yang masak.
Dialogue: 0,0:12:58.97,0:13:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya memang enak.
Dialogue: 0,0:13:01.16,0:13:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang, kamu yang terbaik.
Dialogue: 0,0:13:04.00,0:13:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang rasanya\Nbisa jadi yang terbaik di matamu.
Dialogue: 0,0:13:09.23,0:13:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku masih harus berlatih.
Dialogue: 0,0:13:14.97,0:13:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, enak sekali.
Dialogue: 0,0:13:19.47,0:13:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubereskan.
Dialogue: 0,0:13:20.52,0:13:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:13:22.61,0:13:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bintang utama harus dimanjakan.
Dialogue: 0,0:13:25.47,0:13:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan juga, masih ada hidangan penutup.
Dialogue: 0,0:13:29.09,0:13:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kamu menyukainya.
Dialogue: 0,0:13:31.97,0:13:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan,\Nyang kamu buat diam-diam?
Dialogue: 0,0:13:35.03,0:13:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku baru berani menyajikannya
Dialogue: 0,0:13:38.92,0:13:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah benar-benar yakin.
Dialogue: 0,0:13:42.89,0:13:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berulang-ulang membuatnya\Nsampai yakin kamu akan menyukainya.
Dialogue: 0,0:13:47.41,0:13:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmatilah bersama susu.
Dialogue: 0,0:13:49.18,0:13:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa, ini gâteau au chocolat?
Dialogue: 0,0:13:52.83,0:13:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku izin mencobanya.
Dialogue: 0,0:14:05.88,0:14:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:14:08.83,0:14:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh melegakan melihat reaksimu!
Dialogue: 0,0:14:13.71,0:14:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usahaku tidak sia-sia.
Dialogue: 0,0:14:15.80,0:14:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius, ini benar-benar enak.
Dialogue: 0,0:14:19.84,0:14:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nkamu tahu bahan rahasianya?
Dialogue: 0,0:14:31.35,0:14:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kopi, sih...
Dialogue: 0,0:14:36.24,0:14:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kopi dari kedaiku?
Dialogue: 0,0:14:38.35,0:14:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, tebakanmu tepat!
Dialogue: 0,0:14:41.28,0:14:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Separuhnya cuma firasatku, kok.
Dialogue: 0,0:14:44.59,0:14:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemilik kedai sampai meraciknya\Nagar dapat cita rasa yang pekat.
Dialogue: 0,0:14:50.24,0:14:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat berutang budi padanya.
Dialogue: 0,0:14:53.00,0:14:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:55.57,0:14:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar...
Dialogue: 0,0:14:58.64,0:15:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung momennya pas,\Nsini aku suapi.
Dialogue: 0,0:15:01.81,0:15:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:03.29,0:15:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung kamu ulang tahun,\Nbiar aku suapi secara langsung.
Dialogue: 0,0:15:07.89,0:15:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh, tapi...
Dialogue: 0,0:15:09.49,0:15:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sungkan.
Dialogue: 0,0:15:23.60,0:15:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kado ulang tahunmu.
Dialogue: 0,0:15:31.51,0:15:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjepit dasi?
Dialogue: 0,0:15:33.08,0:15:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, awalnya bingung mau kado apa.
Dialogue: 0,0:15:37.62,0:15:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli ini karena mungkin\Nkamu tidak akan beli,
Dialogue: 0,0:15:40.88,0:15:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ini akan berguna untuk ke depannya.
Dialogue: 0,0:15:46.61,0:15:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, terima kasih.
Dialogue: 0,0:15:48.81,0:15:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan merawatnya dengan baik.
Dialogue: 0,0:15:51.39,0:15:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, aku takut kamu tidak suka.
Dialogue: 0,0:15:56.03,0:15:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang kamu berikan,\Naku pasi menyukainya.
Dialogue: 0,0:15:59.97,0:16:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:16:02.65,0:16:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku ingin memberikan\Nsesuatu yang berguna bagimu.
Dialogue: 0,0:16:08.05,0:16:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:11.13,0:16:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, satu hal lagi.
Dialogue: 0,0:16:13.36,0:16:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kado ini sepele, sih.
Dialogue: 0,0:16:19.25,0:16:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khusus hari ini,
Dialogue: 0,0:16:22.24,0:16:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan mengabulkan semua permintaanmu\Nselama belum ganti hari.
Dialogue: 0,0:16:31.00,0:16:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya, tahu.
Dialogue: 0,0:16:33.43,0:16:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, aku pacarmu.
Dialogue: 0,0:16:36.43,0:16:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja bahaya.
Dialogue: 0,0:16:39.06,0:16:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu sungkan\Natau memang tidak tamak, sih?
Dialogue: 0,0:16:43.09,0:16:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya begitu.
Dialogue: 0,0:16:45.32,0:16:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kamu tidak akan berbuat jahat.
Dialogue: 0,0:16:50.28,0:16:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku berbuat jahat?
Dialogue: 0,0:16:52.15,0:16:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang,\Naku akan minta pertanggungjawaban.
Dialogue: 0,0:16:58.61,0:16:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:17:03.08,0:17:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:17:05.44,0:17:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama kamu tidak jadi dakimakuraku.
Dialogue: 0,0:17:12.03,0:17:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Kok malah melamun?
Dialogue: 0,0:17:14.69,0:17:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak melamun\Nyang aneh-aneh, kok!
Dialogue: 0,0:17:18.20,0:17:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan, deh.
Dialogue: 0,0:17:21.34,0:17:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-Bodoh, dasar Amane bodoh!
Dialogue: 0,0:17:26.25,0:17:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat!
Dialogue: 0,0:17:27.85,0:17:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku kelepasan saking imutnya kamu.
Dialogue: 0,0:17:35.45,0:17:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubawakan baju salin.
Dialogue: 0,0:17:37.69,0:17:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mandi saja dulu.
Dialogue: 0,0:17:47.20,0:17:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok banget sama gayamu.
Dialogue: 0,0:17:50.00,0:17:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya apa, tuh?
Dialogue: 0,0:17:52.76,0:17:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya mungil, lembut, imut,
Dialogue: 0,0:17:57.35,0:17:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mudah kesepian.
Dialogue: 0,0:17:59.47,0:18:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal seharusnya\Nkamu juga pakai piama hewan.
Dialogue: 0,0:18:03.59,0:18:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup kamu saja yang imut.
Dialogue: 0,0:18:11.72,0:18:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu begini, aku beli piama serigala.
Dialogue: 0,0:18:15.27,0:18:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus.
Dialogue: 0,0:18:16.87,0:18:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat.
Dialogue: 0,0:18:22.44,0:18:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu manja banget.
Dialogue: 0,0:18:24.87,0:18:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saja.
Dialogue: 0,0:18:27.36,0:18:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, deh, hari ini\Nkamu terus terang sekali, ya.
Dialogue: 0,0:18:31.55,0:18:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khusus hari ini, aku ingin\Nmenyentuhmu sebanyak mungkin.
Dialogue: 0,0:18:37.47,0:18:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mungil sekali, ya.
Dialogue: 0,0:18:40.08,0:18:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski mungil, aku lebih tangguh\Ndari yang kamu kira, lo.
Dialogue: 0,0:18:44.33,0:18:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja serasa rapuh.
Dialogue: 0,0:18:47.68,0:18:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memelukmu pelan-pelan,\Ntakutnya patah kalau terlalu erat.
Dialogue: 0,0:18:52.04,0:18:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak pernah sebrutal itu, kok.
Dialogue: 0,0:18:55.92,0:18:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja.
Dialogue: 0,0:18:58.57,0:19:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu wajib diperlakukan\Ndan dijaga dengan hati-hati
Dialogue: 0,0:19:03.53,0:19:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai orang tersayangku.
Dialogue: 0,0:19:07.03,0:19:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:19:11.32,0:19:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu yang ulang tahun,
Dialogue: 0,0:19:14.21,0:19:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah aku yang dilayani begini.
Dialogue: 0,0:19:17.59,0:19:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku juga sama, kok.
Dialogue: 0,0:19:20.69,0:19:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula sudah ganti hari.
Dialogue: 0,0:19:22.83,0:19:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:24.63,0:19:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:19:26.37,0:19:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku masih mau\Nmengabulkan permintaanmu.
Dialogue: 0,0:19:30.81,0:19:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu memang cepat berlalu.
Dialogue: 0,0:19:34.04,0:19:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak bisa\Nmembuat permintaan, ya.
Dialogue: 0,0:19:37.65,0:19:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya mau minta apa?
Dialogue: 0,0:19:42.20,0:19:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum tidur, aku ingin dicium.
Dialogue: 0,0:19:48.88,0:19:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar tidak tamak, ya.
Dialogue: 0,0:19:52.19,0:19:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira akan minta lebih dari itu.
Dialogue: 0,0:19:56.01,0:20:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini saja sudah lebih dari cukup,\Nmau minta apa lagi?
Dialogue: 0,0:20:00.08,0:20:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku yang serakah.
Dialogue: 0,0:20:02.77,0:20:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:04.02,0:20:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, aku sangat kesepian
Dialogue: 0,0:20:08.35,0:20:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak kamu bekerja.
Dialogue: 0,0:20:12.05,0:20:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu berharap kamu pulang cepat.
Dialogue: 0,0:20:16.75,0:20:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga khawatir kamu didekati gadis lain.
Dialogue: 0,0:20:21.97,0:20:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut kamu jadi populer\Nkarena tampan.
Dialogue: 0,0:20:26.96,0:20:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kamu tidak akan selingkuh,\Naku tetap khawatir.
Dialogue: 0,0:20:31.71,0:20:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat berharap kamu tidak pergi.
Dialogue: 0,0:20:36.51,0:20:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin kamu menjauh.
Dialogue: 0,0:20:39.13,0:20:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin disentuh lebih lama.
Dialogue: 0,0:20:42.71,0:20:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kita bersama selamanya.
Dialogue: 0,0:20:46.16,0:20:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena berpikir begitu,
Dialogue: 0,0:20:49.20,0:20:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa serakah\Ndan mencintai terlalu berat.
Dialogue: 0,0:20:54.08,0:20:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin, cintaku lebih berat darimu.
Dialogue: 0,0:20:57.94,0:21:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh melebihi perkiraanmu.
Dialogue: 0,0:21:01.33,0:21:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku sangat besar dan dalam.
Dialogue: 0,0:21:04.83,0:21:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan pernah kulepaskan.
Dialogue: 0,0:21:07.83,0:21:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cuma boleh memperhatikanku.
Dialogue: 0,0:21:10.92,0:21:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, kadang aku takut kamu jadi ilfil.
Dialogue: 0,0:21:17.52,0:21:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu cintai sebegitunya,\Njustru aku sangat senang.
Dialogue: 0,0:21:23.88,0:21:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pegang erat dan jangan lepaskan."
Dialogue: 0,0:21:26.52,0:21:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Perhatikanlah aku seorang."
Dialogue: 0,0:21:29.76,0:21:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu pikiran yang ideal?
Dialogue: 0,0:21:32.88,0:21:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:21:34.23,0:21:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:21:36.23,0:21:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak akan pernah\Nmelepaskanmu, kita impas.
Dialogue: 0,0:21:43.87,0:21:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan kubiarkan berpaling.
Dialogue: 0,0:21:48.09,0:21:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberikanmu diriku.
Dialogue: 0,0:21:51.64,0:21:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikanlah juga dirimu padaku.
Dialogue: 0,0:22:02.13,0:22:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur, Amane,\Nsemoga mimpi indah.
Dialogue: 0,0:22:06.76,0:22:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur, Mahiru.
Dialogue: 0,0:23:34.61,0:23:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi.
Dialogue: 0,0:23:36.00,0:23:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
