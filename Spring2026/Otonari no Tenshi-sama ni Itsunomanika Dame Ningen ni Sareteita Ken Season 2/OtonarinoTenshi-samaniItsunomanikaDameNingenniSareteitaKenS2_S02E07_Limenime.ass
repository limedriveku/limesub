Dialogue: 0,0:00:59.37,0:01:07.38,tanda,,0000,0000,0000,,CATATAN PERSIAPAN
Dialogue: 0,0:01:27.23,0:01:29.14,tanda,,0000,0000,0000,,BIMBANG
Dialogue: 0,0:03:08.08,0:03:12.30,tanda,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:04:28.00,0:04:32.02,tanda,,0000,0000,0000,,#7 PERMINTAAN SANG BIDADARI
Dialogue: 0,0:11:15.91,0:11:17.66,tanda,,0000,0000,0000,,RAPAT PERSIAPAN FESTIVAL BUDAYA
Dialogue: 0,0:11:19.83,0:11:24.54,tanda,,0000,0000,0000,,MAID CAFE, RUMAH HANTU, TEATER
Dialogue: 0,0:11:32.80,0:11:36.80,tanda,,0000,0000,0000,,RAPAT PERSIAPAN FESTIVAL BUDAYA
Dialogue: 0,0:11:55.90,0:12:01.02,tanda,,0000,0000,0000,,RAPAT PERSIAPAN FESTIVAL BUDAYA
Dialogue: 0,0:12:01.02,0:12:03.99,tanda,,0000,0000,0000,,MAID CAFE, RUMAH HANTU, TEATER
Dialogue: 0,0:12:48.87,0:12:51.50,tanda,,0000,0000,0000,,SISTEM TOMBOL KHUSUS MALAM HARI
Dialogue: 0,0:13:28.45,0:13:31.21,tanda,,0000,0000,0000,,MENATAP
Dialogue: 0,0:15:12.60,0:15:15.29,tanda,,0000,0000,0000,,SHIHOKO
Dialogue: 0,0:15:15.29,0:15:16.73,tanda,,0000,0000,0000,,FESTIVAL BUDAYA SUDAH DEKAT, YA?
Dialogue: 0,0:16:34.47,0:16:36.93,tanda,,0000,0000,0000,,HASIL UTS: 1. SHIINA MAHIRU,\N2. KOKONOE MAKOTO, 3. TAMURA KENSUKE
Dialogue: 0,0:16:36.93,0:16:38.94,tanda,,0000,0000,0000,,4. YOKO YUUMA, 5. FUJIMIYA AMANE,\N6. YAMAMOTO YUKA
Dialogue: 0,0:16:46.69,0:16:50.70,tanda,,0000,0000,0000,,5. FUJIMIYA AMANE
Dialogue: 0,0:23:34.93,0:23:42.48,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:05.53,0:00:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malas ujian.
Dialogue: 0,0:00:08.66,0:00:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:00:10.20,0:00:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sering belajar, tinggal mengulas saja.
Dialogue: 0,0:00:12.85,0:00:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa pulang lebih cepat pula.
Dialogue: 0,0:00:15.87,0:00:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pendapat siswa teladan\Nsepertimu dan Mahirun!
Dialogue: 0,0:00:19.68,0:00:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang biasa pasti ogah ujian!
Dialogue: 0,0:00:22.30,0:00:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Yuu?
Dialogue: 0,0:00:25.20,0:00:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju sama dua-duanya.
Dialogue: 0,0:00:27.61,0:00:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sepi karena ekskul libur,\Ntapi enaknya bisa istirahat.
Dialogue: 0,0:00:32.10,0:00:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Yuu juga siswa teladan!
Dialogue: 0,0:00:35.18,0:00:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikkun, mereka jahat!
Dialogue: 0,0:00:37.63,0:00:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat, Chi.
Dialogue: 0,0:00:39.39,0:00:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga pengkhianat!\NBelajar diam-diam waktu libur musim panas!
Dialogue: 0,0:00:43.94,0:00:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku bakal dikekang\Nkalau dapat nilai jelek.
Dialogue: 0,0:00:48.65,0:00:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama.
Dialogue: 0,0:00:51.11,0:00:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku mengobrol dengan guru.
Dialogue: 0,0:00:53.50,0:00:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, Chitose cuma\Nsedang merengek tidak mau ujian.
Dialogue: 0,0:00:57.42,0:00:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaan.
Dialogue: 0,0:00:59.37,0:01:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tahu akan begini,
Dialogue: 0,0:01:01.41,0:01:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mencatat materi yang akan keluar.
Dialogue: 0,0:01:03.66,0:01:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun bidadariku!
Dialogue: 0,0:01:07.38,0:01:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane juga ikut membantu.
Dialogue: 0,0:01:10.30,0:01:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berterimakasihlah juga padanya.
Dialogue: 0,0:01:13.89,0:01:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Amane, terima kasih!
Dialogue: 0,0:01:18.43,0:01:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau foto Mahirun yang lahap makan krep\Ndengan krim di pipinya
Dialogue: 0,0:01:22.50,0:01:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau fotonya yang berkaca-kaca\Nketakutan nonton film horor?
Dialogue: 0,0:01:26.38,0:01:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose!
Dialogue: 0,0:01:27.23,0:01:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau dua-duanya.
Dialogue: 0,0:01:29.14,0:01:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane malah samanya.
Dialogue: 0,0:01:31.25,0:01:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda, kok.
Dialogue: 0,0:01:33.39,0:01:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:01:34.62,0:01:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku mau saja kalau dikasih.
Dialogue: 0,0:01:36.85,0:01:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose bodoh!
Dialogue: 0,0:01:38.13,0:01:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu bagus, Mahirun!
Dialogue: 0,0:01:41.37,0:01:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking cintanya,\NAmane selalu menginginkan fotomu.
Dialogue: 0,0:01:45.68,0:01:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dan itu beda urusan.
Dialogue: 0,0:01:49.98,0:01:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fotonya kamu terima?
Dialogue: 0,0:01:52.09,0:01:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:01:53.59,0:01:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap-siap mi punyamu diisi wasabi.
Dialogue: 0,0:01:56.61,0:01:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampun, aku tidak menerimanya.
Dialogue: 0,0:01:58.77,0:02:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:02:00.78,0:02:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu setidak mau itu?
Dialogue: 0,0:02:02.52,0:02:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:02:05.09,0:02:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresiku menyedihkan dan memalukan.
Dialogue: 0,0:02:09.03,0:02:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti aku terlihat jelek.
Dialogue: 0,0:02:11.78,0:02:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya tidak mungkin.
Dialogue: 0,0:02:14.45,0:02:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu selalu memesona.
Dialogue: 0,0:02:17.26,0:02:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi bilang begitu.
Dialogue: 0,0:02:19.41,0:02:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau aku yang dapat\Nfoto memalukanmu?
Dialogue: 0,0:02:27.25,0:02:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung, aku tidak keberatan\Nselama fotonya aman dikonsumsi publik.
Dialogue: 0,0:02:36.26,0:02:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan telinga kucing?
Dialogue: 0,0:02:37.85,0:02:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dipakaikan padaku waktu karaoke?
Dialogue: 0,0:02:40.85,0:02:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:02:42.10,0:02:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, justru aku yang menyimpan\Nfotomu tanpa izin.
Dialogue: 0,0:02:48.06,0:02:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki memang biang kerok.
Dialogue: 0,0:04:29.02,0:04:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, mau hadiah apa kali ini?
Dialogue: 0,0:04:32.02,0:04:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, hadiah?
Dialogue: 0,0:04:34.71,0:04:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama aku sanggup, apa pun boleh.
Dialogue: 0,0:04:38.86,0:04:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya kamu diberi\Nhadiah pangkuan paha, kan?
Dialogue: 0,0:04:43.35,0:04:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu juga perlu hadiah, kan?
Dialogue: 0,0:04:47.85,0:04:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebahagiaanmu adalah hadiah buatku.
Dialogue: 0,0:04:52.56,0:04:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang, aku juga sama kalau begitu.
Dialogue: 0,0:04:56.28,0:04:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini giliranku.
Dialogue: 0,0:05:00.22,0:05:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku mau benda.
Dialogue: 0,0:05:03.30,0:05:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda?
Dialogue: 0,0:05:05.22,0:05:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kamarmu ada bantalan, kan?
Dialogue: 0,0:05:09.26,0:05:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:10.05,0:05:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau itu.
Dialogue: 0,0:05:11.65,0:05:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu sudah sering kupakai tidur.
Dialogue: 0,0:05:15.36,0:05:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin?
Dialogue: 0,0:05:16.46,0:05:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru bagus.
Dialogue: 0,0:05:20.78,0:05:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya...
Dialogue: 0,0:05:23.47,0:05:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, aromamu menenangkan!
Dialogue: 0,0:05:26.98,0:05:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya fetis aroma?
Dialogue: 0,0:05:29.89,0:05:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:05:31.54,0:05:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka aromamu karena mencintaimu\Ndan senang kalau bisa terasa dekat!
Dialogue: 0,0:05:38.02,0:05:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau dijadikan penggantiku?
Dialogue: 0,0:05:40.61,0:05:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, bahaya\Nkalau sama orangnya langsung.
Dialogue: 0,0:05:46.12,0:05:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya?
Dialogue: 0,0:05:50.43,0:05:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya.
Dialogue: 0,0:05:52.62,0:05:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya kamu wangi dan hangat.
Dialogue: 0,0:05:56.06,0:05:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh atletismu juga bikin deg-degan.
Dialogue: 0,0:05:59.38,0:06:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuatku sulit rileks.
Dialogue: 0,0:06:12.27,0:06:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebas!
Dialogue: 0,0:06:14.73,0:06:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun , ayo main ke kafe\Nkarena ujiannya sudah kelar!
Dialogue: 0,0:06:19.10,0:06:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:06:21.34,0:06:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:06:22.45,0:06:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan saja, aku mau main sama Itsuki.
Dialogue: 0,0:06:25.52,0:06:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:26.20,0:06:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabari kalau pulangnya larut.
Dialogue: 0,0:06:28.96,0:06:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku jemput.
Dialogue: 0,0:06:30.34,0:06:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:31.89,0:06:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:06:32.96,0:06:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun, aku menemukan kafe menarik\Nmeski agak ramai, sih.
Dialogue: 0,0:06:37.47,0:06:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Katanya kuenya enak!\N- Sejak kapan kita janjian main?
Dialogue: 0,0:06:41.01,0:06:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang.
Dialogue: 0,0:06:42.24,0:06:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula kamu harus\Nmentraktirku hamburger.
Dialogue: 0,0:06:44.94,0:06:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok begitu?
Dialogue: 0,0:06:46.22,0:06:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telinga kucing di karaoke.
Dialogue: 0,0:06:48.22,0:06:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan, ya.
Dialogue: 0,0:06:49.54,0:06:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja, sih, asal izin dulu.
Dialogue: 0,0:06:52.26,0:06:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, berikutnya foto yang mana, ya?
Dialogue: 0,0:06:55.65,0:06:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia enggak menyesal.
Dialogue: 0,0:06:58.42,0:07:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana situasimu?
Dialogue: 0,0:07:00.98,0:07:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada perubahan.
Dialogue: 0,0:07:03.82,0:07:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal menjaga nilai agar tidak kena omel\Nsembari menyuarakan pendapat.
Dialogue: 0,0:07:09.24,0:07:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:07:12.48,0:07:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja.
Dialogue: 0,0:07:14.91,0:07:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah berbuat apa di musim panas?
Dialogue: 0,0:07:17.27,0:07:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak mau buru-buru.
Dialogue: 0,0:07:20.77,0:07:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah kalau kamu\Ntidak mau berinisiatif.
Dialogue: 0,0:07:24.55,0:07:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling Shiina bakal minta nasihat Chi lagi.
Dialogue: 0,0:07:31.76,0:07:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti Mahiru diajari yang aneh-aneh lagi.
Dialogue: 0,0:07:42.27,0:07:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu diajari apa?
Dialogue: 0,0:07:44.00,0:07:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak ada.
Dialogue: 0,0:07:47.53,0:07:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada, coba lihat wajahku.
Dialogue: 0,0:07:54.91,0:07:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru.
Dialogue: 0,0:07:56.33,0:07:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang!
Dialogue: 0,0:07:57.98,0:07:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:07:58.91,0:08:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu curang, mentang-mentang\Ntahu telingaku lemah!
Dialogue: 0,0:08:02.42,0:08:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, cepat katakan sebelum aku main fisik.
Dialogue: 0,0:08:06.80,0:08:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Main fisik?
Dialogue: 0,0:08:12.93,0:08:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda, kok.\NAku tidak memaksa.
Dialogue: 0,0:08:17.42,0:08:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu mengatakannya.
Dialogue: 0,0:08:19.90,0:08:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan telan mentah-mentah\Nomongan Chitose.
Dialogue: 0,0:08:23.14,0:08:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, aku diajari hal bermanfaat\Nsoal hubungan pria dan wanita.
Dialogue: 0,0:08:27.82,0:08:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya?
Dialogue: 0,0:08:29.15,0:08:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Rahasia.
Dialogue: 0,0:08:31.82,0:08:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu tidak perlu.
Dialogue: 0,0:08:34.87,0:08:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang tahu perlu atau tidaknya!
Dialogue: 0,0:08:39.33,0:08:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa usaha memperdalam hubungan
Dialogue: 0,0:08:43.33,0:08:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan rasa ingin lebih dicintai\Noleh orang yang kita cinta
Dialogue: 0,0:08:49.26,0:08:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak diperlukan?
Dialogue: 0,0:09:06.32,0:09:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ajaran Chitose?
Dialogue: 0,0:09:08.75,0:09:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, aku kurang inisiatif.
Dialogue: 0,0:09:14.33,0:09:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus tadi cuma pura-pura?
Dialogue: 0,0:09:17.52,0:09:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku benar-benar sedih.
Dialogue: 0,0:09:24.72,0:09:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf malah bilang tidak perlu.
Dialogue: 0,0:09:28.71,0:09:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bebas meminta saran Chitose.
Dialogue: 0,0:09:32.75,0:09:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagiku itu tidak seru.
Dialogue: 0,0:09:37.28,0:09:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak seru?
Dialogue: 0,0:09:39.23,0:09:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku maunya kita\Nmenjalaninya dengan alami.
Dialogue: 0,0:09:45.52,0:09:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terlalu fokus ke masa depan,
Dialogue: 0,0:09:47.73,0:09:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita tidak bisa menikmati momen saat ini.
Dialogue: 0,0:09:54.62,0:09:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, omonganku memalukan.
Dialogue: 0,0:09:57.70,0:10:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku cuma pengecut saja.
Dialogue: 0,0:10:00.21,0:10:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:10:02.10,0:10:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa cinta dan sayangmu padaku
Dialogue: 0,0:10:04.91,0:10:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat tersampaikan.
Dialogue: 0,0:10:09.98,0:10:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, bagaimana, ya...
Dialogue: 0,0:10:12.69,0:10:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak berniat buru-buru.
Dialogue: 0,0:10:17.94,0:10:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma takut kamu tidak nyaman.
Dialogue: 0,0:10:22.02,0:10:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya...
Dialogue: 0,0:10:24.38,0:10:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu jadi menahan diri.
Dialogue: 0,0:10:33.66,0:10:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:10:35.35,0:10:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tentu ada keluhan,
Dialogue: 0,0:10:38.38,0:10:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan berarti harus buru-buru.
Dialogue: 0,0:10:40.79,0:10:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kamu masih takut, kan?
Dialogue: 0,0:10:46.32,0:10:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:47.39,0:10:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, jalani perlahan saja.
Dialogue: 0,0:10:52.80,0:10:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, bisakah kamu turun?
Dialogue: 0,0:10:56.80,0:10:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berat?
Dialogue: 0,0:10:57.98,0:11:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, tapi cobalah mengerti.
Dialogue: 0,0:11:03.46,0:11:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku begini sedikit lebih lama?
Dialogue: 0,0:11:11.14,0:11:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:11:14.50,0:11:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:11:15.91,0:11:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari tentukan tema kelas kita!
Dialogue: 0,0:11:17.66,0:11:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:11:19.83,0:11:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maid cafe dapat suara terbanyak.
Dialogue: 0,0:11:24.54,0:11:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina pakai baju maid...
Dialogue: 0,0:11:26.61,0:11:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada si Fujimiya!
Dialogue: 0,0:11:28.69,0:11:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai cowok, Fujimiya juga\Npasti pengin melihatnya.
Dialogue: 0,0:11:37.57,0:11:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya, kamu sedang kesal?
Dialogue: 0,0:11:40.22,0:11:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan banget, ya?
Dialogue: 0,0:11:42.18,0:11:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, wajahmu seperti biasa.
Dialogue: 0,0:11:45.39,0:11:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma perasaanku saja.
Dialogue: 0,0:11:48.78,0:11:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, rasanya campur aduk\Nmelihat pacarku dipuja-puja begitu.
Dialogue: 0,0:11:53.58,0:11:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:11:55.90,0:12:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena Kido mengusulkan ada butler juga,
Dialogue: 0,0:12:01.02,0:12:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin perhatian ke Mahiru akan berkurang.
Dialogue: 0,0:12:03.99,0:12:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bakal sulit,\Naku mengandalkanmu, Kadowaki.
Dialogue: 0,0:12:07.67,0:12:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja.
Dialogue: 0,0:12:09.87,0:12:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga bakal jadi butler.
Dialogue: 0,0:12:12.50,0:12:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:13.31,0:12:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa masak?
Dialogue: 0,0:12:14.80,0:12:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tapi tidak jago.
Dialogue: 0,0:12:18.45,0:12:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, bukankah kamu khawatir\Nkalau jauh dari Shiina?
Dialogue: 0,0:12:23.07,0:12:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya dia kena masalah.
Dialogue: 0,0:12:25.63,0:12:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:12:28.23,0:12:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi siapa yang akan tertarik padaku?
Dialogue: 0,0:12:30.73,0:12:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja Shiina, dia pasti senang.
Dialogue: 0,0:12:34.70,0:12:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:12:36.11,0:12:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ganti penampilan,\Nkamu mulai dilirik orang-orang.
Dialogue: 0,0:12:40.75,0:12:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:12:43.79,0:12:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar, soalnya kamu cuma fokus pada Shiina.
Dialogue: 0,0:12:49.98,0:12:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lega
Dialogue: 0,0:12:51.50,0:12:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihat hubunganmu dan Shiina\Ndiakui orang-orang.
Dialogue: 0,0:12:55.94,0:13:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau kamu\Njadi seperti Shirakawa waktu dulu.
Dialogue: 0,0:13:00.35,0:13:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak saingannya?
Dialogue: 0,0:13:02.95,0:13:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akibatnya, dia sampai keluar dari klub lari.
Dialogue: 0,0:13:06.98,0:13:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat benci perundungan semacam itu.
Dialogue: 0,0:13:10.64,0:13:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamerkanlah kemesraan kalian\Ndi festival nanti, seperti biasanya.
Dialogue: 0,0:13:15.87,0:13:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar Shiina tidak didekati orang lain.
Dialogue: 0,0:13:19.36,0:13:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah berniat pamer.
Dialogue: 0,0:13:22.83,0:13:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:13:25.46,0:13:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:13:26.45,0:13:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:13:31.21,0:13:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:13:32.96,0:13:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, selamat datang.
Dialogue: 0,0:13:35.21,0:13:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:36.00,0:13:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak agak murung.
Dialogue: 0,0:13:39.62,0:13:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski berusaha tidak menolak,
Dialogue: 0,0:13:43.79,0:13:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti hatimu gelisah.
Dialogue: 0,0:13:46.67,0:13:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar, kan?
Dialogue: 0,0:13:48.29,0:13:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:13:50.10,0:13:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, aku mau membuatmu ceria lagi.
Dialogue: 0,0:13:58.15,0:14:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kurang setuju maid cafe\Nkarena mengkhawatirkanku?
Dialogue: 0,0:14:04.70,0:14:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, aku juga tidak mau\Nkamu jadi tontonan orang-orang.
Dialogue: 0,0:14:12.24,0:14:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cemburu?
Dialogue: 0,0:14:14.17,0:14:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah karena cemburu atau posesif.
Dialogue: 0,0:14:18.42,0:14:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya aku tidak suka.
Dialogue: 0,0:14:22.30,0:14:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bukan\Npakai baju pelayan karena mau.
Dialogue: 0,0:14:27.70,0:14:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hasil rapatnya.
Dialogue: 0,0:14:31.12,0:14:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kami sudah membuat perjanjian.
Dialogue: 0,0:14:34.75,0:14:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjanjian?
Dialogue: 0,0:14:35.81,0:14:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu orang pertama\Nyang akan kuperlihatkan.
Dialogue: 0,0:14:43.95,0:14:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin akan ada banyak tamu,
Dialogue: 0,0:14:51.79,0:14:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi suamiku cuma kamu.
Dialogue: 0,0:15:06.82,0:15:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku akan bersabar.
Dialogue: 0,0:15:09.09,0:15:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:15:12.60,0:15:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival budaya sudah dekat, ya?
Dialogue: 0,0:15:15.29,0:15:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu...
Dialogue: 0,0:15:16.73,0:15:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shihoko juga akan datang?
Dialogue: 0,0:15:19.84,0:15:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun lalu aku kena marah\Nkarena tidak memberitahunya.
Dialogue: 0,0:15:23.18,0:15:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kuajak, asal tidak\Nbermesraan di depan umum.
Dialogue: 0,0:15:29.63,0:15:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bisa kuajak.
Dialogue: 0,0:15:34.19,0:15:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ART-mu bagaimana?
Dialogue: 0,0:15:36.42,0:15:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih ingat Bu Koyuki?
Dialogue: 0,0:15:40.42,0:15:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kalian cuma bicara sebentar.
Dialogue: 0,0:15:43.57,0:15:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kami membicarakanmu.
Dialogue: 0,0:15:46.08,0:15:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mengajaknya?
Dialogue: 0,0:15:48.82,0:15:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:15:51.15,0:15:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:15:51.94,0:15:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu.
Dialogue: 0,0:15:55.02,0:16:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Koyuki sudah berhenti\Nsejak aku masuk SMP
Dialogue: 0,0:16:00.42,0:16:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena pinggangnya sakit.
Dialogue: 0,0:16:03.89,0:16:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sayang sekali.
Dialogue: 0,0:16:06.80,0:16:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:07.86,0:16:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Koyuki sudah seperti ibumu.
Dialogue: 0,0:16:11.65,0:16:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku harus minta restu padanya.
Dialogue: 0,0:16:14.56,0:16:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta restu?
Dialogue: 0,0:16:16.78,0:16:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, nanti saja kalau kita\Nsudah ke ranah yang lebih serius.
Dialogue: 0,0:16:23.25,0:16:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru?
Dialogue: 0,0:16:24.50,0:16:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan apa-apa.
Dialogue: 0,0:16:29.05,0:16:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya ada apa-apa.
Dialogue: 0,0:16:31.58,0:16:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada!
Dialogue: 0,0:16:38.94,0:16:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat dapat peringkat satu.
Dialogue: 0,0:16:40.62,0:16:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:42.16,0:16:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja kerasmu berbuah manis, bagus.
Dialogue: 0,0:16:46.69,0:16:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga peringkat lima kali ini.
Dialogue: 0,0:16:50.70,0:16:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup memuaskan.
Dialogue: 0,0:16:52.55,0:16:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu telah mengajariku dengan baik.
Dialogue: 0,0:16:56.88,0:16:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih pujiannya.
Dialogue: 0,0:16:59.04,0:17:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang karena kamu cepat paham.
Dialogue: 0,0:17:02.62,0:17:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:04.75,0:17:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku ingin bisa percaya diri\Nberada di sampingmu.
Dialogue: 0,0:17:11.26,0:17:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu minta bantalanku buat hadiah, kan?
Dialogue: 0,0:17:14.72,0:17:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh!
Dialogue: 0,0:17:15.72,0:17:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku mau bantalan itu.
Dialogue: 0,0:17:21.69,0:17:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau benda lain?
Dialogue: 0,0:17:25.56,0:17:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan benda.
Dialogue: 0,0:17:29.22,0:17:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:17:31.42,0:17:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau
Dialogue: 0,0:17:35.26,0:17:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ciuman.
Dialogue: 0,0:17:37.60,0:17:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman?
Dialogue: 0,0:17:48.80,0:17:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:17:50.30,0:17:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukabulkan.
Dialogue: 0,0:18:05.02,0:18:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, jangan berhenti tiba-tiba.
Dialogue: 0,0:18:13.01,0:18:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kamu minta berhenti.
Dialogue: 0,0:18:16.40,0:18:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah!
Dialogue: 0,0:18:18.95,0:18:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:18:20.83,0:18:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku...
Dialogue: 0,0:18:23.10,0:18:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahap setelah ciuman.
Dialogue: 0,0:18:28.59,0:18:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tahu ini kurang pantas.
Dialogue: 0,0:18:34.37,0:18:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku ingin menjawab perasaanmu.
Dialogue: 0,0:18:39.01,0:18:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lebih mengenalmu.
Dialogue: 0,0:18:43.27,0:18:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke.
Dialogue: 0,0:18:50.51,0:18:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pasang wajah memelas begitu,\Nbisa-bisa aku mati.
Dialogue: 0,0:18:54.46,0:18:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak...
Dialogue: 0,0:18:55.89,0:18:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kok.
Dialogue: 0,0:18:57.81,0:18:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginanmu sudah terkabul?
Dialogue: 0,0:19:00.59,0:19:01.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:19:03.37,0:19:05.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris saja.
Dialogue: 0,0:19:05.71,0:19:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian itu terasa geli.
Dialogue: 0,0:19:09.65,0:19:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu wangi sekali.
Dialogue: 0,0:19:11.88,0:19:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kulitku pakai losion biar lembap.
Dialogue: 0,0:19:15.89,0:19:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa kamu mau tambah mulus?
Dialogue: 0,0:19:19.36,0:19:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kamu kecewa\Nkalau kulitku kasar saat disentuh.
Dialogue: 0,0:19:24.00,0:19:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:24.98,0:19:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginanku adalah sering disentuh olehmu.
Dialogue: 0,0:19:31.40,0:19:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keinginanmu?
Dialogue: 0,0:19:33.86,0:19:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa nyaman\Ndan bahagia saat disentuh.
Dialogue: 0,0:19:40.16,0:19:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa wajar merawat diri
Dialogue: 0,0:19:43.18,0:19:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar kamu ketagihan menyentuhku.
Dialogue: 0,0:19:47.67,0:19:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:20:11.40,0:20:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf melakukannya mendadak.
Dialogue: 0,0:20:15.15,0:20:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa bilang aku tidak mau?
Dialogue: 0,0:20:18.67,0:20:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:19.91,0:20:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau mendadak begitu,\Naku bakal terkejut.
Dialogue: 0,0:20:24.91,0:20:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kamu menunjukkan rasa cinta
Dialogue: 0,0:20:32.16,0:20:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebesar ini.
Dialogue: 0,0:20:34.80,0:20:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}La-Lain kali, tunggu aku siap dulu.
Dialogue: 0,0:20:41.87,0:20:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, maaf...
Dialogue: 0,0:20:43.01,0:20:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan minta maaf!
Dialogue: 0,0:20:45.94,0:20:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:47.28,0:20:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:20:52.44,0:20:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat mudah ditebak.
Dialogue: 0,0:20:55.49,0:20:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:56.34,0:21:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresimu berkata,\N"Lain kali aku harus lebih hati-hati."
Dialogue: 0,0:21:01.58,0:21:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga takut kelepasan.
Dialogue: 0,0:21:05.02,0:21:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau benaran tidak mau,\Nkamu sudah kuhajar dari awal.
Dialogue: 0,0:21:12.19,0:21:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, Amane...
Dialogue: 0,0:21:15.17,0:21:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ulangi lagi.
Dialogue: 0,0:21:40.78,0:21:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah di ambang batas.
Dialogue: 0,0:21:46.29,0:21:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita sudahi.
Dialogue: 0,0:21:48.77,0:21:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:50.82,0:21:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah buatku kebanyakan.
