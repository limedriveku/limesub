Dialogue: 0,0:00:00.69,0:00:08.36,sign,,0000,0000,0000,,FESTIVAL BUDAYA SEIJOU
Dialogue: 0,0:01:00.21,0:01:04.29,sign,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:02:19.99,0:02:25.00,sign,,0000,0000,0000,,KLUB KERAJINAN TANGAN\NMENUAL PRODUK BUATAN TANGAN
Dialogue: 0,0:02:42.64,0:02:46.19,sign,,0000,0000,0000,,MAAF, MAAF
Dialogue: 0,0:03:32.02,0:03:32.90,sign,,0000,0000,0000,,PEMBUATAN TAS
Dialogue: 0,0:11:11.98,0:11:14.49,sign,,0000,0000,0000,,KOPI, COKELAT PANAS, TEH, KUE
Dialogue: 0,0:11:30.59,0:11:31.92,sign,,0000,0000,0000,,MAAF
Dialogue: 0,0:14:13.12,0:14:20.37,sign,,0000,0000,0000,,FESTIVAL BUDAYA SEIJOU
Dialogue: 0,0:21:58.96,0:22:04.97,sign,,0000,0000,0000,,#9 PERMOHONAN SANG BIDADARI
Dialogue: 0,0:23:34.93,0:23:39.94,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:04.61,0:00:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah lama tidak kemari,
Dialogue: 0,0:00:06.59,0:00:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekolah lama kita masih sama.
Dialogue: 0,0:00:08.36,0:00:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah direnovasi,\Nsuasananya tidak berubah.
Dialogue: 0,0:00:12.16,0:00:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir kemari,\Nwaktu Amane baru masuk.
Dialogue: 0,0:00:15.57,0:00:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:00:16.87,0:00:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga harus ikut keliling?
Dialogue: 0,0:00:19.37,0:00:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih.
Dialogue: 0,0:00:20.13,0:00:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu masa begitu?
Dialogue: 0,0:00:22.88,0:00:24.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin banget.
Dialogue: 0,0:00:24.17,0:00:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak zaman jalan bareng ortu.
Dialogue: 0,0:00:26.63,0:00:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu telat puber, ya?
Dialogue: 0,0:00:30.97,0:00:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah,
Dialogue: 0,0:00:32.29,0:00:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo lihat-lihat.
Dialogue: 0,0:00:33.68,0:00:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jadi kamu ikut?
Dialogue: 0,0:00:36.02,0:00:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat mengawasi kalian.
Dialogue: 0,0:00:37.56,0:00:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:00:38.94,0:00:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa saja kalian yang lebih bucin.
Dialogue: 0,0:00:41.85,0:00:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Shuuto?
Dialogue: 0,0:00:44.77,0:00:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:02:25.00,0:02:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shuuto, apa ini bagus?
Dialogue: 0,0:02:27.79,0:02:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya, itu bagus.\N- Orang tuamu akur banget.
Dialogue: 0,0:02:29.50,0:02:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Produknya beragam, ya.\N- Orang tuamu akur banget.
Dialogue: 0,0:02:31.71,0:02:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak jadi manajer klub olahraga?
Dialogue: 0,0:02:35.55,0:02:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar bisa melihat otot cowok secara legal, ya?
Dialogue: 0,0:02:39.14,0:02:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi nanti Sou merajuk.
Dialogue: 0,0:02:41.43,0:02:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayano merajuk?
Dialogue: 0,0:02:42.64,0:02:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di TV atau majalah masih boleh.
Dialogue: 0,0:02:46.19,0:02:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi katanya, "Jangan menatap\Nsiswa lain sambil cengar-cengir."
Dialogue: 0,0:02:51.23,0:02:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada cemburu,
Dialogue: 0,0:02:53.15,0:02:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kayaknya dia khawatir sama nama baikmu.
Dialogue: 0,0:02:56.03,0:02:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja.
Dialogue: 0,0:02:57.53,0:03:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak asal cengar-cengir.
Dialogue: 0,0:03:00.95,0:03:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ototnya tanggung, tidak akan.
Dialogue: 0,0:03:04.12,0:03:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku masuk klub kerajinan tangan\Nbiar bisa bikin baju buat Sou
Dialogue: 0,0:03:09.67,0:03:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengukur tubuhnya secara langsung.
Dialogue: 0,0:03:13.56,0:03:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, gila banget.
Dialogue: 0,0:03:15.59,0:03:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan ilfil, dong!
Dialogue: 0,0:03:18.01,0:03:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina juga sama.
Dialogue: 0,0:03:19.55,0:03:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti akan membuatkan baju
Dialogue: 0,0:03:22.52,0:03:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau diizinkan mengukur tubuhmu.
Dialogue: 0,0:03:25.44,0:03:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ajarkan fetis aneh pada Mahiru-ku.
Dialogue: 0,0:03:29.15,0:03:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian membahas apa?
Dialogue: 0,0:03:32.90,0:03:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membahas kamu akan senang\Nkalau Fujimiya buka baju.
Dialogue: 0,0:03:36.24,0:03:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan.
Dialogue: 0,0:03:37.91,0:03:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Mahiru?
Dialogue: 0,0:03:39.49,0:03:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ku-Kurasa akan.
Dialogue: 0,0:03:44.20,0:03:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, Mahiru pengin lihat.
Dialogue: 0,0:03:46.75,0:03:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kepikiran hal begitu
Dialogue: 0,0:03:49.71,0:03:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma sedikit, kok.
Dialogue: 0,0:03:58.30,0:04:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mengerti\Nbetapa imutnya Mahiru, ya?
Dialogue: 0,0:04:03.51,0:04:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:04:05.81,0:04:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun itu penuh pesona!
Dialogue: 0,0:04:08.19,0:04:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin kenal sifatnya makin imut!
Dialogue: 0,0:04:12.44,0:04:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kombinasi berbahaya...
Dialogue: 0,0:04:15.19,0:04:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menjaga Amane.
Dialogue: 0,0:04:17.89,0:04:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:04:20.57,0:04:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Amane?
Dialogue: 0,0:04:22.58,0:04:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak menyangkal?
Dialogue: 0,0:04:24.54,0:04:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya itu fakta.
Dialogue: 0,0:04:27.25,0:04:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kadang tidak perlu.
Dialogue: 0,0:04:30.29,0:04:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal begini kamu terus terang, ya.
Dialogue: 0,0:04:33.63,0:04:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi biasanya aku nyeleneh?
Dialogue: 0,0:04:36.38,0:04:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara menyimpulkanmu inilah buktinya.
Dialogue: 0,0:04:40.26,0:04:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu sadar dirimu nyeleneh?
Dialogue: 0,0:04:43.76,0:04:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel.
Dialogue: 0,0:04:44.76,0:04:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:04:53.77,0:04:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo beli makan.
Dialogue: 0,0:04:56.15,0:04:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak cepat,
Dialogue: 0,0:04:57.99,0:05:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan kelaparan saat sif sore.
Dialogue: 0,0:05:00.80,0:05:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai, lah.
Dialogue: 0,0:05:02.53,0:05:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melayani tamu itu bikin capek.
Dialogue: 0,0:05:05.87,0:05:09.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami pergi duluan, ya.
Dialogue: 0,0:05:09.37,0:05:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:05:10.79,0:05:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan datang sore nanti,\Nsampai ketemu.
Dialogue: 0,0:05:13.42,0:05:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, kami tunggu!
Dialogue: 0,0:05:20.26,0:05:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok jadi begini?
Dialogue: 0,0:05:22.68,0:05:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu kalian.
Dialogue: 0,0:05:26.45,0:05:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ayahnya Itsuki.
Dialogue: 0,0:05:29.14,0:05:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah, terima kasih\Nsudah menjaga putraku.
Dialogue: 0,0:05:33.02,0:05:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru sebaliknya.
Dialogue: 0,0:05:36.24,0:05:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, Pak Daiki, barusan...
Dialogue: 0,0:05:40.24,0:05:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga akan begitu.
Dialogue: 0,0:05:42.74,0:05:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering bersikap kasar pada pacarnya,
Dialogue: 0,0:05:45.74,0:05:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajar kalau Itsuki menjauhkan kami.
Dialogue: 0,0:05:48.91,0:05:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Shiina tampak akrab\Ndengan orang tuamu.
Dialogue: 0,0:05:54.42,0:05:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut melihatnya.
Dialogue: 0,0:05:56.29,0:05:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih pujiannya.
Dialogue: 0,0:05:58.17,0:06:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ini calon putriku.
Dialogue: 0,0:06:00.88,0:06:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bukan pun, dia anak baik.
Dialogue: 0,0:06:03.09,0:06:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat menggemaskan.
Dialogue: 0,0:06:07.18,0:06:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, wajar kalau dia direstui.
Dialogue: 0,0:06:11.93,0:06:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:06:13.77,0:06:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia gadis pilihan putra kami.
Dialogue: 0,0:06:16.31,0:06:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak salah pilih.
Dialogue: 0,0:06:18.94,0:06:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melihat Mahiru,
Dialogue: 0,0:06:20.94,0:06:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami jadi yakin untuk menitipkan Amane.
Dialogue: 0,0:06:25.87,0:06:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa iri.
Dialogue: 0,0:06:28.20,0:06:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra bodohku malah sebaliknya.
Dialogue: 0,0:06:30.58,0:06:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak memercayai putra sendiri?
Dialogue: 0,0:06:34.83,0:06:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putraku bukan pria sematang putramu.
Dialogue: 0,0:06:39.84,0:06:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih naif.
Dialogue: 0,0:06:42.21,0:06:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, menurutku tidak.
Dialogue: 0,0:06:45.59,0:06:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata Amane,
Dialogue: 0,0:06:47.93,0:06:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki baik dan penuh perhatian.
Dialogue: 0,0:06:52.56,0:06:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:06:53.81,0:06:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai orang tua, wajar punya\Nkeluhan akan pilihan anak kita.
Dialogue: 0,0:06:58.61,0:07:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwa mandiri anak lelaki tumbuhnya cepat.
Dialogue: 0,0:07:02.40,0:07:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dikekang, takutnya malah berontak.
Dialogue: 0,0:07:05.80,0:07:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tumbuh jadi anak baik.
Dialogue: 0,0:07:08.49,0:07:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memercayai dan mendukung pilihannya
Dialogue: 0,0:07:11.99,0:07:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah tugas orang tua.
Dialogue: 0,0:07:16.33,0:07:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mungkin terasa menggurui
Dialogue: 0,0:07:19.63,0:07:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kita baru saling kenal.
Dialogue: 0,0:07:22.25,0:07:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar menentang\Nkalau pilihannya jelas salah.
Dialogue: 0,0:07:26.09,0:07:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau melarang anak\Nmemilih jalannya sendiri,
Dialogue: 0,0:07:29.64,0:07:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tidak akan terima.
Dialogue: 0,0:07:33.14,0:07:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Daiki.
Dialogue: 0,0:07:34.60,0:07:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku izin menambahkan.
Dialogue: 0,0:07:37.02,0:07:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:07:38.40,0:07:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kamu tidak menyukai Chitose.
Dialogue: 0,0:07:42.40,0:07:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tidak seburuk itu.
Dialogue: 0,0:07:45.40,0:07:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang kepikiran dan berusaha keras
Dialogue: 0,0:07:49.28,0:07:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar diakui olehmu.
Dialogue: 0,0:07:52.49,0:07:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memintamu merestuinya.
Dialogue: 0,0:07:55.87,0:07:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:07:56.66,0:07:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong perhatikan dia baik-baik.
Dialogue: 0,0:08:01.88,0:08:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu Fujimiya menilai tinggi putraku\Ndan memercayai gadis itu.
Dialogue: 0,0:08:09.12,0:08:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tahu usaha putraku.
Dialogue: 0,0:08:14.18,0:08:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:08:15.64,0:08:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya gadis itu tidak memberi\Ndampak positif pada putraku.
Dialogue: 0,0:08:21.73,0:08:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tenang.
Dialogue: 0,0:08:23.57,0:08:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berniat menyingkirkannya.
Dialogue: 0,0:08:26.44,0:08:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah putraku punya kawan sepertimu.
Dialogue: 0,0:08:31.79,0:08:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pedulikan aku
Dialogue: 0,0:08:34.12,0:08:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tetaplah berteman baik dengannya.
Dialogue: 0,0:08:37.91,0:08:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:50.84,0:08:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu begitu tegas\Nmembela Akazawa dan Chitose,
Dialogue: 0,0:08:55.39,0:08:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padahal biasanya judes sama mereka.
Dialogue: 0,0:08:58.18,0:09:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, karena kami teman.
Dialogue: 0,0:09:00.98,0:09:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang saja.
Dialogue: 0,0:09:03.48,0:09:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau padamu, memang selalu, kok.
Dialogue: 0,0:09:05.23,0:09:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah itu terus terang atau blakblakan.
Dialogue: 0,0:09:08.53,0:09:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang kamu sampai bikin aku deg-degan.
Dialogue: 0,0:09:13.16,0:09:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau deg-degan.
Dialogue: 0,0:09:17.58,0:09:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih.
Dialogue: 0,0:09:19.81,0:09:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku tidak akan\Nmembela terang-terangan.
Dialogue: 0,0:09:25.21,0:09:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya mereka sungkan.
Dialogue: 0,0:09:27.88,0:09:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku paham maksud Pak Daiki.
Dialogue: 0,0:09:32.51,0:09:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Itsuki lumayan berada.
Dialogue: 0,0:09:35.76,0:09:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan kakaknya juga sudah dewasa.
Dialogue: 0,0:09:39.43,0:09:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki maunya hidup bebas\Nkarena bukan pewaris.
Dialogue: 0,0:09:44.44,0:09:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak mau hubungan asmaranya\Ndiatur-atur orang tua.
Dialogue: 0,0:09:49.36,0:09:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Pak Daiki juga\Npunya pertimbangan sendiri.
Dialogue: 0,0:09:54.74,0:09:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak iri pada Akazawa.
Dialogue: 0,0:09:59.08,0:10:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iri?
Dialogue: 0,0:10:00.83,0:10:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini kurang etis.
Dialogue: 0,0:10:03.71,0:10:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ayahnya begitu demi Akazawa, kan?
Dialogue: 0,0:10:09.63,0:10:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski memaksakan idealismenya,
Dialogue: 0,0:10:14.89,0:10:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu tetaplah bentuk kasih sayang orang tua.
Dialogue: 0,0:10:22.35,0:10:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir.
Dialogue: 0,0:10:25.86,0:10:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengharapkan apa-apa\Nsoal orang tua, kok.
Dialogue: 0,0:10:31.03,0:10:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagiku yang ikatannya samar,
Dialogue: 0,0:10:35.16,0:10:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ikatan keluarga mereka bikin iri.
Dialogue: 0,0:10:39.87,0:10:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekarang diajak pun
Dialogue: 0,0:10:42.96,0:10:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah tidak akan mau.
Dialogue: 0,0:10:47.08,0:10:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa merasakan ikatan itu
Dialogue: 0,0:10:49.55,0:10:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari orang tuaku, kok.
Dialogue: 0,0:10:51.76,0:10:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan mereka bilang mubazir\Nkalau buatku terus.
Dialogue: 0,0:10:57.09,0:10:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:10:59.26,0:11:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu luar biasa.
Dialogue: 0,0:11:01.56,0:11:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:11:03.52,0:11:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu disayangi.
Dialogue: 0,0:11:05.77,0:11:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi jangan cemas.
Dialogue: 0,0:11:08.83,0:11:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:14.49,0:11:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, seragam Mahiru imut banget.
Dialogue: 0,0:11:18.24,0:11:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya, tolong jangan sentuh maid kami.
Dialogue: 0,0:11:22.24,0:11:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia maid pribadimu?
Dialogue: 0,0:11:25.04,0:11:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, dia maid milik kafe ini!
Dialogue: 0,0:11:31.92,0:11:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pelayannya kasar sekali.
Dialogue: 0,0:11:35.09,0:11:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dilarang menyentuhnya olehmu?
Dialogue: 0,0:11:37.47,0:11:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh aturan di sini.
Dialogue: 0,0:11:40.47,0:11:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan meski aku ibunya?
Dialogue: 0,0:11:42.22,0:11:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:11:43.18,0:11:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamu belum jadi ibunya.
Dialogue: 0,0:11:44.68,0:11:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Biar saja!\N- Belum...
Dialogue: 0,0:11:45.89,0:11:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma masalah waktu.
Dialogue: 0,0:11:47.90,0:11:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah...
Dialogue: 0,0:11:49.48,0:11:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah, cepat pesan.
Dialogue: 0,0:11:52.23,0:11:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, pelanggannya masih banyak.
Dialogue: 0,0:11:55.90,0:11:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya, Pelayan.
Dialogue: 0,0:11:57.70,0:11:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:11:59.31,0:12:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, biar kuantar.
Dialogue: 0,0:12:03.95,0:12:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini menu kami.
Dialogue: 0,0:12:06.08,0:12:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berbentuk paket.
Dialogue: 0,0:12:08.00,0:12:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap maklum.
Dialogue: 0,0:12:09.25,0:12:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:12:11.04,0:12:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau pesan apa?
Dialogue: 0,0:12:12.80,0:12:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya...\NAda rekomendasi?
Dialogue: 0,0:12:16.26,0:12:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paket A cocok buat penyuka kopi.
Dialogue: 0,0:12:19.30,0:12:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paket C cocok buat penyuka teh.
Dialogue: 0,0:12:21.89,0:12:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maid-nya bisa dibawa pulang?
Dialogue: 0,0:12:24.10,0:12:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada layanan seperti itu.
Dialogue: 0,0:12:27.02,0:12:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu bisa.
Dialogue: 0,0:12:29.27,0:12:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapanmu sulit dimengerti, Nyonya.
Dialogue: 0,0:12:34.36,0:12:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mau pesan apa?
Dialogue: 0,0:12:36.15,0:12:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Fujimiya.
Dialogue: 0,0:12:37.86,0:12:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadowaki?
Dialogue: 0,0:12:39.74,0:12:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membawakan air dingin\Nsekalian mau menyapa.
Dialogue: 0,0:12:43.28,0:12:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ibu Fujimiya cantik sekali.
Dialogue: 0,0:12:46.54,0:12:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bisa saja.
Dialogue: 0,0:12:48.58,0:12:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kalah dari Shuuto,\Nkamu ganteng, ya.
Dialogue: 0,0:12:53.54,0:12:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:54.88,0:12:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah berteman\Ndengan putraku.
Dialogue: 0,0:12:57.88,0:13:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia judes dan agak kasar, kan?
Dialogue: 0,0:13:01.05,0:13:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:13:03.18,0:13:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini ekspresinya lembut.
Dialogue: 0,0:13:06.44,0:13:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini berkat Shiina.
Dialogue: 0,0:13:08.64,0:13:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh.
Dialogue: 0,0:13:09.60,0:13:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon hentikan.
Dialogue: 0,0:13:11.40,0:13:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NAku tidak bohong.
Dialogue: 0,0:13:13.86,0:13:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu masalahnya.
Dialogue: 0,0:13:16.44,0:13:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu di depan orangnya.
Dialogue: 0,0:13:18.19,0:13:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu maunya dinilai apa adanya?
Dialogue: 0,0:13:23.53,0:13:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali boleh, kan?
Dialogue: 0,0:13:24.91,0:13:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:13:26.08,0:13:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya jangan di depan orang tuaku.
Dialogue: 0,0:13:29.96,0:13:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih selalu.
Dialogue: 0,0:13:31.54,0:13:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur jadi temanmu.
Dialogue: 0,0:13:34.75,0:13:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:13:35.92,0:13:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang melihat kalian akrab.
Dialogue: 0,0:13:37.96,0:13:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet.
Dialogue: 0,0:13:39.21,0:13:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadowaki, kembalilah bekerja.
Dialogue: 0,0:13:41.13,0:13:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:13:42.09,0:13:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengambil waktumu.
Dialogue: 0,0:13:44.55,0:13:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:13:48.10,0:13:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya teman-teman yang baik, ya.
Dialogue: 0,0:13:51.06,0:13:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:13:53.19,0:13:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku berlebihan karena khawatir.
Dialogue: 0,0:13:57.36,0:13:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya kelas kalian akur.
Dialogue: 0,0:13:59.94,0:14:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan mereka senyam-senyum\Nmelihatmu dan Shiina.
Dialogue: 0,0:14:04.28,0:14:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kayaknya hari ini karena kalian.
Dialogue: 0,0:14:07.62,0:14:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal itu.
Dialogue: 0,0:14:09.33,0:14:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat, kan?
Dialogue: 0,0:14:11.79,0:14:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel, ah.
Dialogue: 0,0:14:13.96,0:14:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah berkunjung.
Dialogue: 0,0:14:18.80,0:14:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini,
Dialogue: 0,0:14:20.37,0:14:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}festival budaya resmi selesai.
Dialogue: 0,0:14:24.64,0:14:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ayo kita rayakan!
Dialogue: 0,0:14:27.85,0:14:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:14:30.32,0:14:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah bekerja keras.
Dialogue: 0,0:14:32.85,0:14:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kido yang paling berjasa kali ini.
Dialogue: 0,0:14:35.44,0:14:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya, bosku.
Dialogue: 0,0:14:39.15,0:14:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipinjami seragam saja sudah bagus.
Dialogue: 0,0:14:42.19,0:14:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tahunya dia punya banyak.
Dialogue: 0,0:14:44.86,0:14:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus memberinya bingkisan\Nuntuk berterima kasih.
Dialogue: 0,0:14:48.62,0:14:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben kamu seserius ini.
Dialogue: 0,0:14:51.20,0:14:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chi, kamu terlalu meremehkanku.
Dialogue: 0,0:14:54.75,0:14:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa serius.
Dialogue: 0,0:14:57.38,0:14:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberapa sering?
Dialogue: 0,0:14:59.13,0:15:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam bulan sekali.
Dialogue: 0,0:15:00.75,0:15:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang, dong!
Dialogue: 0,0:15:03.76,0:15:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, jangan cuma menonton.
Dialogue: 0,0:15:07.09,0:15:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini ikut, jangan cuma berduaan.
Dialogue: 0,0:15:09.64,0:15:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:15:11.27,0:15:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahirun juga, sini!
Dialogue: 0,0:15:12.93,0:15:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo jaili Ikkun!
Dialogue: 0,0:15:14.39,0:15:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, lah.
Dialogue: 0,0:15:17.23,0:15:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina, kamu tidak suka karaoke?
Dialogue: 0,0:15:19.86,0:15:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu.
Dialogue: 0,0:15:24.32,0:15:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Mahirun tidak mau menyanyi
Dialogue: 0,0:15:27.57,0:15:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena cuma tahu sedikit lagu.
Dialogue: 0,0:15:30.53,0:15:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Mako dan Kazu?
Dialogue: 0,0:15:31.95,0:15:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tahu lagu yang viral.
Dialogue: 0,0:15:36.46,0:15:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak terlalu tahu.
Dialogue: 0,0:15:38.21,0:15:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling cuma pernah\Nmendengar nenekku main Koto.
Dialogue: 0,0:15:41.25,0:15:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:15:43.51,0:15:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membahas lagu bikin aku ingat Yuuta.
Dialogue: 0,0:15:46.09,0:15:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak bilang-bilang mau tampil?
Dialogue: 0,0:15:49.72,0:15:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kayaknya biar enggak heboh.\N- Aku tidak berniat menunjukkannya.
Dialogue: 0,0:15:53.35,0:15:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Amane juga nonton, curang.
Dialogue: 0,0:15:56.94,0:15:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Betul!\N- Bukan masalah, kan?
Dialogue: 0,0:15:58.77,0:16:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula kita sering karaokean bareng.
Dialogue: 0,0:16:01.36,0:16:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja aku ingin melihatmu tampil.
Dialogue: 0,0:16:04.74,0:16:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar dimaafkan,\Nkamu harus konser di sini.
Dialogue: 0,0:16:10.66,0:16:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, tapi Fujimiya juga harus ikut.
Dialogue: 0,0:16:13.87,0:16:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok begitu?
Dialogue: 0,0:16:15.29,0:16:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karaoke memang buat menyanyi\Ndi depan umum, kan?
Dialogue: 0,0:16:19.50,0:16:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya, aku belum pernah\Nmendengarmu menyanyi.
Dialogue: 0,0:16:24.25,0:16:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang-jarang bisa begini.
Dialogue: 0,0:16:28.97,0:16:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas saja nanti.
Dialogue: 0,0:16:30.80,0:16:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagunya sudah dipilih.
Dialogue: 0,0:16:44.73,0:16:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita nyanyi bersama saja, ya?
Dialogue: 0,0:16:47.03,0:16:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau lagu ini, sih, ayo.\N- Apa boleh buat.
Dialogue: 0,0:16:54.95,0:16:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Amane.
Dialogue: 0,0:16:56.87,0:16:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:58.29,0:17:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku membawa Chi pergi,\Nkamu bilang apa sama ayahku?
Dialogue: 0,0:17:02.96,0:17:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak sulit dijelaskan.
Dialogue: 0,0:17:07.05,0:17:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami tidak bicara jelek soal kalian.
Dialogue: 0,0:17:10.05,0:17:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyapa orang tuaku\Nlalu berbincang sebentar.
Dialogue: 0,0:17:13.14,0:17:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:17:14.64,0:17:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira Ayah bilang yang aneh-aneh.
Dialogue: 0,0:17:17.77,0:17:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir.
Dialogue: 0,0:17:22.02,0:17:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya, aku tahu Ayah mau bilang apa.
Dialogue: 0,0:17:27.19,0:17:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tahu alasannya menolak Chi.
Dialogue: 0,0:17:30.20,0:17:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh tahu itu?
Dialogue: 0,0:17:33.12,0:17:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pendapat pribadiku.
Dialogue: 0,0:17:35.49,0:17:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:17:37.60,0:17:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, Itsuki curhat\Ntentang kondisi keluarganya
Dialogue: 0,0:17:43.04,0:17:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk pertama kali.
Dialogue: 0,0:17:46.67,0:17:49.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki dan abangnya beda delapan tahun.
Dialogue: 0,0:17:49.46,0:17:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abangnya rajin, lurus, dan tulus.
Dialogue: 0,0:17:52.18,0:17:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia putra kebanggaan Pak Daiki.
Dialogue: 0,0:17:55.97,0:17:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:57.72,0:17:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dengan Itsuki.
Dialogue: 0,0:17:59.56,0:18:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abangnya baru berontak setelah dewasa
Dialogue: 0,0:18:03.37,0:18:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menolak jalan hidup\Nyang ditentukan orang tuanya.
Dialogue: 0,0:18:07.73,0:18:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia kabur bersama pacarnya.
Dialogue: 0,0:18:13.99,0:18:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya Abang berdamai dengan Ayah
Dialogue: 0,0:18:16.78,0:18:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mau jadi pewaris keluarga.
Dialogue: 0,0:18:19.62,0:18:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat abangnya kabur,
Dialogue: 0,0:18:22.12,0:18:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki yang mendadak dijadikan pewaris
Dialogue: 0,0:18:25.08,0:18:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dikontrol sangat keras
Dialogue: 0,0:18:26.75,0:18:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akibat perkara itu.
Dialogue: 0,0:18:29.13,0:18:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi,
Dialogue: 0,0:18:30.59,0:18:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose memberi kesan yang sama\Ndengan pacarnya abang Itsuki.
Dialogue: 0,0:18:37.01,0:18:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah alasan utama ayahku menolak Chi.
Dialogue: 0,0:18:43.31,0:18:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:18:46.48,0:18:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin karena aku terluka\Nakibat melindungi Chi.
Dialogue: 0,0:18:50.90,0:18:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kamu sudah mendengar
Dialogue: 0,0:18:54.11,0:18:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masalah percintaan\Nklub lari kami waktu SMP, kan?
Dialogue: 0,0:18:59.08,0:19:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya, senior itu melabrak Chi\Nsaat kami mulai pacaran.
Dialogue: 0,0:19:04.75,0:19:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukanya tidak fatal.
Dialogue: 0,0:19:08.17,0:19:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena melibatkan putra pewarisnya,
Dialogue: 0,0:19:13.27,0:19:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayahku makin sinis sama Chi.
Dialogue: 0,0:19:17.55,0:19:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chitose tahu soal ini?
Dialogue: 0,0:19:19.43,0:19:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:21.06,0:19:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chi tidak bersalah.
Dialogue: 0,0:19:23.35,0:19:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan dia merasa bersalah.
Dialogue: 0,0:19:28.48,0:19:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas begitu.
Dialogue: 0,0:19:31.07,0:19:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasiakan ini dari Chi, ya.
Dialogue: 0,0:19:34.57,0:19:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:19:37.41,0:19:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru sahabatku.
Dialogue: 0,0:19:40.99,0:19:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kok tidak menyangkal?
Dialogue: 0,0:19:43.79,0:19:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau aku menyangkal?
Dialogue: 0,0:19:51.67,0:19:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu ke toilet di karaoke tadi,
Dialogue: 0,0:19:55.59,0:20:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada cewek kelas kita\Nyang bilang kamu menarik.
Dialogue: 0,0:20:02.10,0:20:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:03.35,0:20:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu festival budaya juga sama.
Dialogue: 0,0:20:06.35,0:20:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu keren,
Dialogue: 0,0:20:08.60,0:20:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak tamu yang tertarik.
Dialogue: 0,0:20:11.90,0:20:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyadarinya.
Dialogue: 0,0:20:15.07,0:20:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur, aku agak tidak rela melihatmu\Nyang sekeren itu senyum pada tamu.
Dialogue: 0,0:20:26.88,0:20:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, kamu milikku.
Dialogue: 0,0:20:30.46,0:20:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dia disayangi.
Dialogue: 0,0:20:33.50,0:20:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:20:35.71,0:20:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kamu yang akan tahu sisi lainku\Nyang orang tidak tahu.
Dialogue: 0,0:20:44.01,0:20:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah jadi pusat perhatian\Nselama dua hari beruntun,
Dialogue: 0,0:20:48.89,0:20:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak akan kulepaskan.
Dialogue: 0,0:20:52.11,0:20:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:20:54.33,0:20:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kamu yang kuperhatikan.
Dialogue: 0,0:20:58.65,0:21:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kamu hanya milikku.
Dialogue: 0,0:21:04.83,0:21:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buatlah aku jadi milikmu seorang.
Dialogue: 0,0:21:07.68,0:21:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pun akan kumiliki seorang.
Dialogue: 0,0:21:40.45,0:21:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:21:43.32,0:21:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini...
Dialogue: 0,0:21:47.56,0:21:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini,
Dialogue: 0,0:21:51.50,0:21:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bolehkah aku menginap?
