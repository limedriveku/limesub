Dialogue: 0,0:01:12.09,0:01:16.22,tanda,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:06:38.50,0:06:42.51,tanda,,0000,0000,0000,,#4 KENCAN RUMAH BERSAMA BIDADARI
Dialogue: 0,0:15:02.01,0:15:05.59,tanda,,0000,0000,0000,,CATATAN PERKEMBANGAN AMANE\NUSIA 3 TAHUN
Dialogue: 0,0:23:34.98,0:23:41.83,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:21.41,0:00:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, semalam aku tidur sama Mahiru.
Dialogue: 0,0:00:28.97,0:00:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imutnya.
Dialogue: 0,0:00:38.27,0:00:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, kamu sudah bangun?
Dialogue: 0,0:00:41.08,0:00:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:00:43.13,0:00:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masuk, ya.
Dialogue: 0,0:00:44.24,0:00:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:00:56.63,0:00:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga dia tidak salah paham.
Dialogue: 0,0:02:37.25,0:02:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku membangunkanmu?
Dialogue: 0,0:02:42.56,0:02:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi manja kalau baru bangun, ya.
Dialogue: 0,0:02:49.69,0:02:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Amane?\NKok ada kamu?
Dialogue: 0,0:02:53.62,0:02:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:02:58.05,0:03:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak ingat\Nmalam penuh gairah yang kita lalui?
Dialogue: 0,0:03:05.34,0:03:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma bercanda,\Nkita tidak berbuat apa-apa.
Dialogue: 0,0:03:08.94,0:03:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah.
Dialogue: 0,0:03:10.81,0:03:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tadi aku mencium pipimu, sih.
Dialogue: 0,0:03:13.66,0:03:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih pagi sudah brutal banget!
Dialogue: 0,0:03:16.63,0:03:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya tidurmu nyenyak.
Dialogue: 0,0:03:18.74,0:03:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, tidur di lenganmu terasa nyaman.
Dialogue: 0,0:03:23.75,0:03:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak deg-degan?
Dialogue: 0,0:03:25.91,0:03:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tentu saja deg-degan.
Dialogue: 0,0:03:30.19,0:03:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:03:31.32,0:03:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terasa tenang.
Dialogue: 0,0:03:33.57,0:03:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang deg-degan lagi, sih.
Dialogue: 0,0:03:36.49,0:03:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tidur bersama tiap hari.
Dialogue: 0,0:03:38.93,0:03:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau itu...
Dialogue: 0,0:03:42.48,0:03:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang-kadang saja.
Dialogue: 0,0:03:44.83,0:03:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu serius?
Dialogue: 0,0:03:46.58,0:03:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebagai pacar,
Dialogue: 0,0:03:49.58,0:03:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada salahnya menginap bersama, kan?
Dialogue: 0,0:03:54.34,0:03:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Betul, sih.
Dialogue: 0,0:03:59.77,0:04:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menginap,
Dialogue: 0,0:04:01.99,0:04:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti kita akan...
Dialogue: 0,0:04:03.81,0:04:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maksudku bukan ke arah situ.
Dialogue: 0,0:04:09.65,0:04:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang bisa bersamamu lebih lama,
Dialogue: 0,0:04:13.25,0:04:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu alasannya.
Dialogue: 0,0:04:15.15,0:04:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:04:16.08,0:04:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau?
Dialogue: 0,0:04:18.26,0:04:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin tidak mau,\Njustru aku senang.
Dialogue: 0,0:04:22.64,0:04:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, nanti lagi, deh.
Dialogue: 0,0:04:25.82,0:04:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya kita bangun.
Dialogue: 0,0:04:42.25,0:04:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu sudah banyak menggodaku,
Dialogue: 0,0:04:46.00,0:04:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini balasannya.
Dialogue: 0,0:04:49.33,0:04:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi saat kalian jalan-jalan?
Dialogue: 0,0:04:53.27,0:04:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kalian tanya begitu?
Dialogue: 0,0:04:55.53,0:04:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena suasananya berubah\Nsaat kami pulang.
Dialogue: 0,0:04:58.66,0:05:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Firasat orang tua itu kuat.
Dialogue: 0,0:05:00.78,0:05:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:05:02.38,0:05:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bertemu Toujou\Ndan dikomentari saat jalan-jalan.
Dialogue: 0,0:05:06.54,0:05:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu rupanya.
Dialogue: 0,0:05:10.37,0:05:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya, kamu sudah lega.
Dialogue: 0,0:05:15.07,0:05:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:05:16.71,0:05:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada lega, lebih tepatnya sudah teratasi.
Dialogue: 0,0:05:21.05,0:05:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia tidak akan menggangguku lagi.
Dialogue: 0,0:05:27.34,0:05:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah tambah dewasa, itu bagus.
Dialogue: 0,0:05:30.14,0:05:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak keluarga Toujou\Ntidak ada perubahan, ya.
Dialogue: 0,0:05:33.81,0:05:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saja dia mau apa.
Dialogue: 0,0:05:36.72,0:05:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga tidak akan bertemu lagi.
Dialogue: 0,0:05:40.55,0:05:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak.
Dialogue: 0,0:05:41.69,0:05:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta membuat orang lebih kuat, ya.
Dialogue: 0,0:05:44.03,0:05:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapanmu pasaran.
Dialogue: 0,0:05:45.93,0:05:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi memang benar, kan?
Dialogue: 0,0:05:47.87,0:05:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:05:50.33,0:05:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kamu dapat orang yang tepat.
Dialogue: 0,0:05:54.57,0:05:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sepertiku yang mendapatkan Shihoko.
Dialogue: 0,0:05:57.28,0:05:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh.
Dialogue: 0,0:05:57.84,0:05:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:05:59.21,0:06:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru juga, andalkanlah Amane.
Dialogue: 0,0:06:01.98,0:06:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kamu terus yang direpotkan.
Dialogue: 0,0:06:05.47,0:06:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, aku selalu bergantung pada Amane.
Dialogue: 0,0:06:10.16,0:06:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia banyak membantuku.
Dialogue: 0,0:06:12.15,0:06:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarnya.
Dialogue: 0,0:06:13.98,0:06:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, jangan keenakan\Nsama kebaikan Shiina.
Dialogue: 0,0:06:17.39,0:06:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus saling bantu.
Dialogue: 0,0:06:19.11,0:06:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, kami selalu bersama,
Dialogue: 0,0:06:22.27,0:06:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah pasti saling bantu.
Dialogue: 0,0:06:24.31,0:06:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, lucu banget!
Dialogue: 0,0:06:26.86,0:06:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja tidak ada kerjaan,\Nakan kumanjakan kalian.
Dialogue: 0,0:06:30.63,0:06:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kerja sana.
Dialogue: 0,0:06:32.50,0:06:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar kalian bisa bermesraan?
Dialogue: 0,0:06:35.25,0:06:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, terus kenapa?
Dialogue: 0,0:06:40.17,0:06:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:06:42.51,0:06:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya bermesraan?
Dialogue: 0,0:06:46.86,0:06:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya ciuman...
Dialogue: 0,0:06:48.29,0:06:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman, dan?
Dialogue: 0,0:06:50.64,0:06:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman lagi?
Dialogue: 0,0:06:52.25,0:06:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok cuma ciuman?
Dialogue: 0,0:06:54.60,0:06:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bingung.
Dialogue: 0,0:06:57.88,0:07:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu harus apa biar lebih mesra?
Dialogue: 0,0:07:02.61,0:07:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pelukan dulu?
Dialogue: 0,0:07:05.28,0:07:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:07:08.77,0:07:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka begini.
Dialogue: 0,0:07:11.99,0:07:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau?
Dialogue: 0,0:07:12.78,0:07:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Mau, kok.
Dialogue: 0,0:07:15.83,0:07:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, aku serasa didekap olehmu.
Dialogue: 0,0:07:26.13,0:07:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane!
Dialogue: 0,0:07:27.37,0:07:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kelepasan.
Dialogue: 0,0:07:29.57,0:07:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mentang-mentang aku gampang geli,
Dialogue: 0,0:07:32.53,0:07:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu jahat.
Dialogue: 0,0:07:34.39,0:07:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ceritakan masa lalumu\Nyang waktu itu, ya?
Dialogue: 0,0:07:38.31,0:07:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jangan, dong.
Dialogue: 0,0:07:42.67,0:07:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganmu besar, ya.
Dialogue: 0,0:07:47.13,0:07:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka tanganmu.
Dialogue: 0,0:07:50.03,0:07:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka disentuh olehmu.
Dialogue: 0,0:07:54.80,0:07:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bilang begitu, aku sentuh, nih!
Dialogue: 0,0:07:57.65,0:07:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan saja.
Dialogue: 0,0:08:04.05,0:08:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menelan omonganmu bulat-bulat,
Dialogue: 0,0:08:07.15,0:08:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti jariku boleh naik lebih jauh.
Dialogue: 0,0:08:14.05,0:08:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga termasuk bermesraan.
Dialogue: 0,0:08:18.90,0:08:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane...
Dialogue: 0,0:08:20.94,0:08:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang aku juga lelaki,\Njadi hati-hati.
Dialogue: 0,0:08:27.39,0:08:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu memang ingin menyentuh,
Dialogue: 0,0:08:31.37,0:08:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku siap meskipun malu.
Dialogue: 0,0:08:43.13,0:08:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti saja.
Dialogue: 0,0:08:45.38,0:08:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut tidak bisa menahan diri.
Dialogue: 0,0:08:56.55,0:08:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Mahiru.
Dialogue: 0,0:08:58.48,0:09:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok mukamu merah sekali?
Dialogue: 0,0:09:01.53,0:09:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak apa-apa.
Dialogue: 0,0:09:03.73,0:09:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, jangan-jangan...
Dialogue: 0,0:09:06.08,0:09:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah tidak macam-macam.
Dialogue: 0,0:09:08.19,0:09:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak macam-macam
Dialogue: 0,0:09:10.47,0:09:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bermesraan, kan?
Dialogue: 0,0:09:12.70,0:09:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bermesraannya baik-baik,\Nitu boleh, kan?
Dialogue: 0,0:09:16.24,0:09:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu saja kamu!
Dialogue: 0,0:09:18.34,0:09:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau bermesraan sama Mahiru!
Dialogue: 0,0:09:21.12,0:09:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru itu milikku, jadi tidak boleh!
Dialogue: 0,0:09:23.31,0:09:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Waduh.\N- Milikku?
Dialogue: 0,0:09:24.84,0:09:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bercengkerama\Nsebagai keluarga boleh, kan?
Dialogue: 0,0:09:28.53,0:09:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:29.34,0:09:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina pernah bilang,\Nmau jalan-jalan sekeluarga, kan?
Dialogue: 0,0:09:34.38,0:09:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga, hari libur nanti\Nayo kita jalan-jalan.
Dialogue: 0,0:09:40.08,0:09:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau?
Dialogue: 0,0:09:41.39,0:09:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima kasih.\NAku sangat senang.
Dialogue: 0,0:09:53.94,0:09:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata hujan.
Dialogue: 0,0:09:55.20,0:09:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Amane.
Dialogue: 0,0:09:57.16,0:09:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujannya cukup lebat, ya.
Dialogue: 0,0:09:59.65,0:10:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:10:04.59,0:10:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sepertinya cuma sementara,\Nhujannya cukup lebat.
Dialogue: 0,0:10:08.77,0:10:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kamu mandi dulu.
Dialogue: 0,0:10:11.71,0:10:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kusiapkan air hangat.
Dialogue: 0,0:10:13.51,0:10:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, terima kasih.
Dialogue: 0,0:10:18.49,0:10:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali, ya.
Dialogue: 0,0:10:19.85,0:10:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:20.91,0:10:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disiapkan air untuk mandi\Ndan disambut begini.
Dialogue: 0,0:10:26.19,0:10:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku mandi dulu.
Dialogue: 0,0:10:31.61,0:10:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski seolah tidak merawat diri,\Nlembut rambutmu begitu curang.
Dialogue: 0,0:10:37.69,0:10:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:10:39.25,0:10:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terlihat repot,\Nrambutmu begitu halus dan lembut.
Dialogue: 0,0:10:44.57,0:10:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi butuh waktu lama\Nmerawat rambut sepanjang ini.
Dialogue: 0,0:10:48.34,0:10:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, wajar saja kalau sepanjang itu.
Dialogue: 0,0:10:52.45,0:10:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat berniat memotongnya.
Dialogue: 0,0:10:56.34,0:11:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lebih suka rambut pendek atau panjang?
Dialogue: 0,0:11:01.60,0:11:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya selera khusus,
Dialogue: 0,0:11:04.81,0:11:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dua-duanya cocok untukmu.
Dialogue: 0,0:11:07.21,0:11:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka melihatmu berdandan\Ndan bersenang-senang.
Dialogue: 0,0:11:10.61,0:11:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang selama kamu nyaman.
Dialogue: 0,0:11:14.38,0:11:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah?
Dialogue: 0,0:11:16.74,0:11:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya, menurutmu\Ngaya rambut apa yang cocok buatku?
Dialogue: 0,0:11:21.45,0:11:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka apa pun gaya rambutmu.
Dialogue: 0,0:11:24.73,0:11:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?\NItu maksudku.
Dialogue: 0,0:11:27.00,0:11:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tapi...
Dialogue: 0,0:11:30.88,0:11:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kamu menyibakkan rambut\Nyang basah, itu sangat...
Dialogue: 0,0:11:35.87,0:11:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat?
Dialogue: 0,0:11:37.26,0:11:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat seksi
Dialogue: 0,0:11:40.02,0:11:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan keren.
Dialogue: 0,0:11:42.64,0:11:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lihat lagi?
Dialogue: 0,0:11:43.89,0:11:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan, aku bisa mati!
Dialogue: 0,0:11:46.55,0:11:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelemahanmu banyak banget.
Dialogue: 0,0:11:50.26,0:11:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau ditatap manja olehmu\Nyang baru selesai mandi,
Dialogue: 0,0:11:54.53,0:11:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga pasti terduduk lemas.
Dialogue: 0,0:11:56.81,0:12:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sejak tiba di sini\Nkamu melihatnya tiap hari?
Dialogue: 0,0:12:00.56,0:12:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berusaha\Ntidak menatapmu langsung, tahu.
Dialogue: 0,0:12:03.54,0:12:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, aku dapat info mahal.
Dialogue: 0,0:12:07.00,0:12:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, dasar.
Dialogue: 0,0:12:09.62,0:12:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembunyi di kamar seharian, ah.
Dialogue: 0,0:12:11.21,0:12:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang!
Dialogue: 0,0:12:13.09,0:12:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak curang.
Dialogue: 0,0:12:14.90,0:12:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang!
Dialogue: 0,0:12:16.30,0:12:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pengin memojokkanmu!
Dialogue: 0,0:12:24.14,0:12:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini atau ini?\NMana yang cocok buat Mahiru?
Dialogue: 0,0:12:28.27,0:12:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pilih yang Mahiru inginkan saja.
Dialogue: 0,0:12:32.40,0:12:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga ingin tahu pendapatmu.
Dialogue: 0,0:12:40.39,0:12:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini.
Dialogue: 0,0:12:41.05,0:12:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, ya!
Dialogue: 0,0:12:42.35,0:12:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar imut, ya.
Dialogue: 0,0:12:44.62,0:12:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang.
Dialogue: 0,0:12:45.95,0:12:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu sudah tidak malu-malu?
Dialogue: 0,0:12:48.93,0:12:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet.
Dialogue: 0,0:12:50.87,0:12:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya cocok di Shuuto!
Dialogue: 0,0:12:54.84,0:12:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, anu...
Dialogue: 0,0:12:57.55,0:12:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:12:58.45,0:12:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak.
Dialogue: 0,0:13:00.51,0:13:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:13:01.59,0:13:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:04.41,0:13:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:13:06.16,0:13:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak pakai baju\Nyang kita beli pas Golden Week?
Dialogue: 0,0:13:09.56,0:13:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memperlihatkannya\Nsaat kita kencan berdua saja.
Dialogue: 0,0:13:14.06,0:13:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh, begitu.
Dialogue: 0,0:13:15.94,0:13:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan mengajakku, kan?
Dialogue: 0,0:13:17.99,0:13:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga, ini hitungannya\Njalan-jalan keluarga.
Dialogue: 0,0:13:22.16,0:13:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi berdua nanti.
Dialogue: 0,0:13:24.37,0:13:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:25.53,0:13:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maunya ke mana?
Dialogue: 0,0:13:27.01,0:13:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama bersamamu, ke mana pun boleh.
Dialogue: 0,0:13:33.50,0:13:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujan, deh.
Dialogue: 0,0:13:36.27,0:13:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujan, deh.
Dialogue: 0,0:13:39.11,0:13:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bersedih, kita bisa pergi lain kali.
Dialogue: 0,0:13:43.18,0:13:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:13:45.76,0:13:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, janji kita jadinya batal.
Dialogue: 0,0:13:50.02,0:13:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sebegitunya ingin kencan?
Dialogue: 0,0:13:52.52,0:13:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:13:54.27,0:13:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh.
Dialogue: 0,0:13:56.73,0:14:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu seantusias ini,\Nmaafkan ucapanku.
Dialogue: 0,0:14:01.38,0:14:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku tetap senang\Nbisa berduaan santai denganmu.
Dialogue: 0,0:14:07.56,0:14:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan menyentuh telingaku\Nkayak waktu itu.
Dialogue: 0,0:14:11.79,0:14:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu mengingatkanku\Nbiar menyentuhnya?
Dialogue: 0,0:14:14.91,0:14:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:14:16.34,0:14:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caramu menyentuh dan berbisik\Ntidak baik buat tubuhku!
Dialogue: 0,0:14:22.01,0:14:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan membalasmu sampai lemas!
Dialogue: 0,0:14:26.22,0:14:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bikin kamu lemas?
Dialogue: 0,0:14:30.14,0:14:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, aku harus coba\Nsegala cara biar Amane terpesona.
Dialogue: 0,0:14:35.31,0:14:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tergila-gila,\Nmemangnya bisa lebih?
Dialogue: 0,0:14:39.02,0:14:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam hal itu kamu terus terang, ya.
Dialogue: 0,0:14:42.65,0:14:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan berarti aku tidak malu.
Dialogue: 0,0:14:45.57,0:14:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi banyak yang bilang,\Nkomunikasi itu penting.
Dialogue: 0,0:14:49.74,0:14:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga suka sisi rasionalmu itu.
Dialogue: 0,0:14:53.89,0:14:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:55.29,0:14:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tersipu, ya?
Dialogue: 0,0:14:57.43,0:14:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya salah?
Dialogue: 0,0:14:58.34,0:15:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tapi akhirnya aku membalasmu.
Dialogue: 0,0:15:18.97,0:15:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan rumah yang diminta sudah selesai.
Dialogue: 0,0:15:21.28,0:15:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang mau apa?
Dialogue: 0,0:15:25.13,0:15:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:15:26.66,0:15:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sedang kencan di rumah,
Dialogue: 0,0:15:31.21,0:15:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku rasa harus memakai baju\Nyang sudah disiapkan.
Dialogue: 0,0:15:35.86,0:15:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NCocok, tidak?
Dialogue: 0,0:15:40.57,0:15:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok.
Dialogue: 0,0:15:42.85,0:15:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat cocok.
Dialogue: 0,0:15:44.93,0:15:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:47.18,0:15:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya aku memujimu lebih detail, ya?
Dialogue: 0,0:15:50.47,0:15:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena punya kulit mulus,\Ndari sini kamu terlihat menyilaukan.
Dialogue: 0,0:15:55.52,0:15:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tubuh ramping,
Dialogue: 0,0:15:57.36,0:16:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu sangat pas memakai baju\Nyang menonjolkan lekuk tubuh begini.
Dialogue: 0,0:16:02.65,0:16:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kamu terlihat lebih tinggi.
Dialogue: 0,0:16:06.32,0:16:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desain simpelnya menambah kesan dewasamu.
Dialogue: 0,0:16:09.99,0:16:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah, sudah cukup!
Dialogue: 0,0:16:13.37,0:16:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah bikin aku malu, sih?
Dialogue: 0,0:16:18.29,0:16:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Amane.
Dialogue: 0,0:16:21.29,0:16:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini boleh, kan?
Dialogue: 0,0:16:23.39,0:16:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pegang bagian lain, kok.
Dialogue: 0,0:16:28.56,0:16:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkali-kali kubilang, jangan ke telinga!
Dialogue: 0,0:16:32.95,0:16:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi lemas?
Dialogue: 0,0:16:34.56,0:16:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sampai begitu, sih.
Dialogue: 0,0:16:37.44,0:16:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bikin gelisah, jadi tidak boleh.
Dialogue: 0,0:16:40.19,0:16:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kusimpan buat hari spesial saja.
Dialogue: 0,0:16:43.18,0:16:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya itu juga bakal gawat, deh.
Dialogue: 0,0:16:50.16,0:16:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku tahu selera bajumu seperti apa.
Dialogue: 0,0:16:55.13,0:16:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan soal selera,\Naku cuma pikir ini cocok buatmu.
Dialogue: 0,0:16:59.66,0:17:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau begitu.
Dialogue: 0,0:17:01.78,0:17:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membelinya\Nuntuk diperlihatkan padamu.
Dialogue: 0,0:17:05.17,0:17:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku mau lihat lebih jelas.
Dialogue: 0,0:17:18.65,0:17:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat cocok, kamu imut.
Dialogue: 0,0:17:21.92,0:17:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tahu
Dialogue: 0,0:17:24.24,0:17:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pasti berpikir aku imut.
Dialogue: 0,0:17:28.35,0:17:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini memalukan.
Dialogue: 0,0:17:32.00,0:17:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu paling imut sedunia.
Dialogue: 0,0:17:35.10,0:17:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini,
Dialogue: 0,0:17:37.33,0:17:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu lebih terus terang\Ndan berani dari biasanya.
Dialogue: 0,0:17:42.00,0:17:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ini kencan, meski cuma di rumah.
Dialogue: 0,0:17:46.26,0:17:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu seagresif ini,\Naku bakal kewalahan.
Dialogue: 0,0:17:51.84,0:17:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya kulakukan tiap hari?
Dialogue: 0,0:17:53.90,0:17:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan!\NJantungku tidak akan kuat!
Dialogue: 0,0:17:58.02,0:18:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak deg-degan juga,\Nini tidak adil!
Dialogue: 0,0:18:04.00,0:18:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku deg-degan banget, kok.
Dialogue: 0,0:18:06.27,0:18:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:18:13.44,0:18:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:17.70,0:18:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipikir-pikir,
Dialogue: 0,0:18:19.66,0:18:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau ini dihitung kencan,\Nberarti kita kencan tiap hari.
Dialogue: 0,0:18:25.77,0:18:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:18:27.25,0:18:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cuma di rumahku,\Nsesekali ayo kita ke rumahmu.
Dialogue: 0,0:18:32.00,0:18:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahku?
Dialogue: 0,0:18:34.72,0:18:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak ada maksud aneh, kok.
Dialogue: 0,0:18:38.77,0:18:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma penasaran saja.
Dialogue: 0,0:18:40.95,0:18:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja, tapi tidak ada\Nhal menarik di sana.
Dialogue: 0,0:18:45.15,0:18:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran
Dialogue: 0,0:18:46.90,0:18:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ingin memastikan sesuatu.
Dialogue: 0,0:18:50.06,0:18:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memastikan apa?
Dialogue: 0,0:18:51.53,0:18:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tahu foto diriku seperti apa
Dialogue: 0,0:18:54.50,0:18:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ada di bingkai foto di atas mejamu.
Dialogue: 0,0:18:58.66,0:18:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:59.66,0:19:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu sudah tahu?
Dialogue: 0,0:19:03.28,0:19:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyadarinya setelah kita pacaran.
Dialogue: 0,0:19:08.75,0:19:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak ilfil?
Dialogue: 0,0:19:11.29,0:19:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin.
Dialogue: 0,0:19:16.86,0:19:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Foto saat kamu tertawa.
Dialogue: 0,0:19:20.06,0:19:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akazawa yang memfotonya.
Dialogue: 0,0:19:23.92,0:19:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyummu yang belum pernah kulihat.
Dialogue: 0,0:19:27.23,0:19:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya dia menyebarkannya.
Dialogue: 0,0:19:30.57,0:19:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:19:32.57,0:19:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut kamu jadi membenciku.
Dialogue: 0,0:19:35.11,0:19:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar manja.
Dialogue: 0,0:19:36.98,0:19:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katamu aku boleh bersikap manja.
Dialogue: 0,0:19:39.68,0:19:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, bersikaplah manja sepuasmu.
Dialogue: 0,0:19:43.12,0:19:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, nanti aku jadi ketergantungan.
Dialogue: 0,0:19:48.88,0:19:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membuatku ketergantungan.
Dialogue: 0,0:19:51.93,0:19:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, harus sama.
Dialogue: 0,0:19:53.26,0:19:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu sama kalau soal itu.
Dialogue: 0,0:20:02.70,0:20:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya nanti kamu manfaatkan.
Dialogue: 0,0:20:05.98,0:20:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau?
Dialogue: 0,0:20:07.25,0:20:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya tidak mau.
Dialogue: 0,0:20:09.86,0:20:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu curang.
Dialogue: 0,0:20:17.36,0:20:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga manja.
Dialogue: 0,0:20:20.57,0:20:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet.
Dialogue: 0,0:20:22.58,0:20:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan bermanja-manja.
Dialogue: 0,0:20:25.95,0:20:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kamu ketergantungan padaku.
Dialogue: 0,0:20:28.62,0:20:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dari dulu.
Dialogue: 0,0:20:30.58,0:20:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sedang begini kamu serasa kecil.
Dialogue: 0,0:20:35.17,0:20:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal biasanya terasa besar\Ndan bisa diandalkan.
Dialogue: 0,0:20:38.98,0:20:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:20:40.59,0:20:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kecil dan ramping.
Dialogue: 0,0:20:43.75,0:20:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang sekali didekap.
Dialogue: 0,0:20:45.67,0:20:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang kamulah\Nyang sedang kudekap.
Dialogue: 0,0:20:49.23,0:20:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin tubuhku tercipta buat kamu dekap.
Dialogue: 0,0:20:53.76,0:20:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kamu khusus milikku.
Dialogue: 0,0:20:56.46,0:20:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kamu juga milikku.
Dialogue: 0,0:21:01.99,0:21:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai berbekas, ya.
Dialogue: 0,0:21:04.94,0:21:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan, tapi akan tetap kucium.
Dialogue: 0,0:21:07.76,0:21:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa gelinya bikin agak risi.
Dialogue: 0,0:21:10.58,0:21:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan saja kalau tidak suka.
Dialogue: 0,0:21:13.46,0:21:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat.
Dialogue: 0,0:21:16.91,0:21:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betapa bahagianya,
Dialogue: 0,0:21:18.92,0:21:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa bersantai dan merasa damai
Dialogue: 0,0:21:22.53,0:21:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di rumahmu.
Dialogue: 0,0:21:24.39,0:21:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akhirnya terbiasa tinggal di sini, ya.
Dialogue: 0,0:21:27.61,0:21:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, rasanya sedih karena\Nsebentar lagi harus pulang.
Dialogue: 0,0:21:32.51,0:21:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau begitu.
Dialogue: 0,0:21:34.21,0:21:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:35.02,0:21:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kamu merasa nyaman di sini, kan?
Dialogue: 0,0:21:38.24,0:21:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu benar.
Dialogue: 0,0:21:40.98,0:21:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tinggal datang lagi nanti.
Dialogue: 0,0:21:43.51,0:21:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin akhir tahun ini\Natau musim panas tahun depan?
Dialogue: 0,0:21:47.38,0:21:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang lagi?
Dialogue: 0,0:21:48.83,0:21:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau?
Dialogue: 0,0:21:50.10,0:21:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:21:52.10,0:21:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:21:53.63,0:21:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja ini sebagai rumahmu juga.
Dialogue: 0,0:22:01.38,0:22:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
