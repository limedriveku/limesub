Dialogue: 0,0:01:21.73,0:01:23.07,tanda,,0000,0000,0000,,#3 PULANG KAMPUNG
Dialogue: 0,0:01:23.07,0:01:24.98,tanda,,0000,0000,0000,,DAN PERPISAHAN DENGAN MASA LALU
Dialogue: 0,0:01:35.03,0:01:39.25,tanda,,0000,0000,0000,,THE ANGEL NEXT DOOR SPOILS ME ROTTEN SEASON 2
Dialogue: 0,0:23:34.93,0:23:41.25,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:08.45,0:00:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini kampung halamanmu?
Dialogue: 0,0:00:11.53,0:00:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tapi rumahku masih jauh, sih.
Dialogue: 0,0:00:20.61,0:00:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum bilang bahwa kita pacaran.
Dialogue: 0,0:00:24.70,0:00:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:00:25.86,0:00:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, selamat datang!
Dialogue: 0,0:00:27.26,0:00:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:00:28.89,0:00:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya datang juga.
Dialogue: 0,0:00:30.89,0:00:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengundangku.
Dialogue: 0,0:00:33.51,0:00:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini momen khusus keluarga kalian,
Dialogue: 0,0:00:36.41,0:00:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah ikut-ikutan.
Dialogue: 0,0:00:38.83,0:00:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir,\Nkami memang ingin bertemu kamu.
Dialogue: 0,0:00:43.40,0:00:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatnya mau bertemu juga\Nsaat libur musim semi,
Dialogue: 0,0:00:46.40,0:00:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi terhalang jadwal.
Dialogue: 0,0:00:48.45,0:00:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:00:49.28,0:00:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:00:50.96,0:00:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putramu tidak disapa?
Dialogue: 0,0:00:53.28,0:00:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, selamat datang kembali, Amane.
Dialogue: 0,0:00:56.21,0:00:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah bawa Mahiru, ya.
Dialogue: 0,0:00:58.53,0:01:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya, mana Ayah?
Dialogue: 0,0:01:00.75,0:01:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shuuto menunggu di rumah\Nsambil membuat makan siang.
Dialogue: 0,0:01:04.39,0:01:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:01:05.84,0:01:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu beruntung, Mahiru,\Nmasakan Ayah sangat enak.
Dialogue: 0,0:01:08.95,0:01:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak sabar.
Dialogue: 0,0:01:11.69,0:01:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmatilah cita rasa khas keluarga kami.
Dialogue: 0,0:01:16.62,0:01:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo.
Dialogue: 0,0:01:21.73,0:01:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:03:00.54,0:03:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:03:01.79,0:03:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pulang, Shuuto.\NAku bawa Mahiru, lo.
Dialogue: 0,0:03:05.43,0:03:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina, lama tidak berjumpa.
Dialogue: 0,0:03:07.86,0:03:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa,\Nsenang melihatmu sehat.
Dialogue: 0,0:03:11.09,0:03:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah seformal itu.
Dialogue: 0,0:03:15.55,0:03:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane juga terlihat makin dewasa.
Dialogue: 0,0:03:18.75,0:03:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa baru enam bulan sudah berubah?
Dialogue: 0,0:03:21.01,0:03:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kamu terlihat makin maskulin\Ndan lebih percaya diri.
Dialogue: 0,0:03:26.14,0:03:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shihoko, tolong antar Mahiru keliling rumah.
Dialogue: 0,0:03:29.95,0:03:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:03:31.06,0:03:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, silakan masuk.
Dialogue: 0,0:03:33.36,0:03:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sempit, anggap saja rumah sendiri.
Dialogue: 0,0:03:35.90,0:03:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:03:39.39,0:03:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:03:42.27,0:03:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah repot-repot\Nmenyiapkan kamar untukku.
Dialogue: 0,0:03:45.91,0:03:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja.
Dialogue: 0,0:03:48.31,0:03:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toilet lantai dua ada di situ
Dialogue: 0,0:03:50.13,0:03:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan di sebelahmu ada kamar Amane.
Dialogue: 0,0:03:52.38,0:03:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, balkonnya terhubung.
Dialogue: 0,0:03:56.01,0:03:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan lupa menguncinya,\Nkamu juga, ya.
Dialogue: 0,0:03:59.39,0:04:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak keberatan, kok.
Dialogue: 0,0:04:02.07,0:04:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus keberatan, dong.
Dialogue: 0,0:04:04.85,0:04:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka polos sekali.
Dialogue: 0,0:04:07.28,0:04:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau menyiapkan makan siang.
Dialogue: 0,0:04:09.82,0:04:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan cek barang-barang kalian.
Dialogue: 0,0:04:12.23,0:04:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima kasih.
Dialogue: 0,0:04:14.86,0:04:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kayaknya cuma kamar ini yang kosong.
Dialogue: 0,0:04:18.33,0:04:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak apa-apa.
Dialogue: 0,0:04:19.70,0:04:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal seharusnya\NIbu tidak tahu kita pacaran.
Dialogue: 0,0:04:23.02,0:04:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:04:24.93,0:04:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalau balkonnya terhubung,
Dialogue: 0,0:04:29.00,0:04:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa lihat bintang sama-sama.
Dialogue: 0,0:04:31.69,0:04:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:04:34.07,0:04:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina, apa putraku merepotkanmu?
Dialogue: 0,0:04:37.55,0:04:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak.
Dialogue: 0,0:04:39.41,0:04:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab jujur saja,\Nkamu memang mengurusi aku.
Dialogue: 0,0:04:43.58,0:04:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama bersama Amane\Naku tidak pernah merasa direpotkan.
Dialogue: 0,0:04:48.72,0:04:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya selalu menyenangkan.
Dialogue: 0,0:04:52.51,0:04:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:04:53.69,0:04:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gengsimu tinggi banget.
Dialogue: 0,0:04:56.47,0:04:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itulah yang bikin Amane imut.
Dialogue: 0,0:04:59.49,0:05:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, Amane memang imut.
Dialogue: 0,0:05:02.24,0:05:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, kayaknya kita perlu bicara.
Dialogue: 0,0:05:05.69,0:05:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, nanti kita bicara lagi, ya.
Dialogue: 0,0:05:08.91,0:05:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Shiina.
Dialogue: 0,0:05:11.68,0:05:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selepas ini, maukah kamu\Nmenemaniku belanja?
Dialogue: 0,0:05:15.18,0:05:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:17.62,0:05:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shihoko minta dibelikan sesuatu.
Dialogue: 0,0:05:20.34,0:05:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu mengajaknya?
Dialogue: 0,0:05:22.39,0:05:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Shuuto tidak akan heboh
Dialogue: 0,0:05:25.62,0:05:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membawanya keliling sana-sini sepertiku.
Dialogue: 0,0:05:29.27,0:05:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:05:31.76,0:05:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jaga rumah, ya.
Dialogue: 0,0:05:33.35,0:05:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:05:34.69,0:05:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, kamu bakal jadi pengganggu\Nkalau kami mau bahas masa lalu.
Dialogue: 0,0:05:38.95,0:05:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengganggu?
Dialogue: 0,0:05:45.10,0:05:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:05:49.06,0:05:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mulai terbiasa bekerja, ya.
Dialogue: 0,0:05:52.18,0:05:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:53.50,0:05:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, tampaknya Mahiru\Ntidak sepenuhnya kerja sendirian.
Dialogue: 0,0:05:57.48,0:06:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pikir aku sejahat itu?
Dialogue: 0,0:06:03.50,0:06:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, sudah sejauh mana\Nhubunganmu dan Mahiru?
Dialogue: 0,0:06:07.11,0:06:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:07.93,0:06:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah kaget?
Dialogue: 0,0:06:09.97,0:06:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kelihatan jelas sedang berpacaran.
Dialogue: 0,0:06:14.19,0:06:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma merahasiakannya.
Dialogue: 0,0:06:16.65,0:06:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya tidak boleh?
Dialogue: 0,0:06:18.15,0:06:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, justru bagus\Nkalau dia bisa jadi putriku.
Dialogue: 0,0:06:23.22,0:06:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:06:24.49,0:06:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking mesranya tatapan dan aura kalian,
Dialogue: 0,0:06:27.55,0:06:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kukira "semuanya" sudah dilakukan.
Dialogue: 0,0:06:30.05,0:06:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:32.64,0:06:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada!
Dialogue: 0,0:06:34.87,0:06:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, jangan bicara begitu ke Mahiru, ya.
Dialogue: 0,0:06:38.40,0:06:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ke Mahiru, tidak akan.
Dialogue: 0,0:06:41.59,0:06:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, karena menginginkan seorang putri,
Dialogue: 0,0:06:45.44,0:06:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi berharap.
Dialogue: 0,0:06:47.05,0:06:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu harus menjaganya\Nsupaya tidak pergi.
Dialogue: 0,0:06:50.30,0:06:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir aku akan melepas\Nhal yang kuinginkan?
Dialogue: 0,0:06:53.28,0:06:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifatmu yang itu mirip sama Shuuto.
Dialogue: 0,0:06:56.19,0:06:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku bukan penggoda alami seperti Ayah.\N- Dasar kamu ini.
Dialogue: 0,0:06:59.86,0:07:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum tentu, coba kita tanya Mahiru.
Dialogue: 0,0:07:03.14,0:07:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, woi!
Dialogue: 0,0:07:06.61,0:07:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Mahiru.\NKamu lelah?
Dialogue: 0,0:07:09.53,0:07:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma duduk sejak pagi,
Dialogue: 0,0:07:12.16,0:07:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi lumayan buat menggerakkan badan.
Dialogue: 0,0:07:15.25,0:07:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:07:19.21,0:07:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Ayah bilang apa\Nsampai bikin kamu segelisah ini?
Dialogue: 0,0:07:25.60,0:07:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Ayah, dia bilang apa, sih?
Dialogue: 0,0:07:28.83,0:07:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hal penting, kok.
Dialogue: 0,0:07:31.51,0:07:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bertanya soal keadaanmu
Dialogue: 0,0:07:34.27,0:07:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan cerita soal masa kecilmu yang lucu.
Dialogue: 0,0:07:37.44,0:07:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cerita apa?
Dialogue: 0,0:07:38.97,0:07:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, soal itu...
Dialogue: 0,0:07:41.46,0:07:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu buang muka?
Dialogue: 0,0:07:43.36,0:07:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya aku tahu bahwa kamu imut.
Dialogue: 0,0:07:51.50,0:07:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:07:53.58,0:07:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah hukuman bagi anak nakal\Nyang tidak mau jujur.
Dialogue: 0,0:07:58.42,0:08:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Amane?
Dialogue: 0,0:08:00.78,0:08:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu gampang geli, kan?
Dialogue: 0,0:08:03.67,0:08:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu!\NMari bicarakan baik-baik!
Dialogue: 0,0:08:06.80,0:08:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasibmu tidak akan begini\Nkalau jujur dari awal.
Dialogue: 0,0:08:12.00,0:08:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu...\NAmane...
Dialogue: 0,0:08:15.86,0:08:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelinya gampang banget.
Dialogue: 0,0:08:17.94,0:08:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Amane bodoh.
Dialogue: 0,0:08:21.19,0:08:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat banget, padahal obrolan kami\Ntidak sepenting itu.
Dialogue: 0,0:08:25.86,0:08:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma tentang kamu yang menangis\Nkarena kesusahan mengendarai sepeda.
Dialogue: 0,0:08:31.71,0:08:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang memeluk Shihoko seharian\Ndi hari ibu sambil bilang, "Aku cayang Ibu."
Dialogue: 0,0:08:37.11,0:08:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang ingin sekeren Shuuto
Dialogue: 0,0:08:39.67,0:08:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai bikin rambutmu lancip kaya duri\Npakai gel rambut, cuma itu.
Dialogue: 0,0:08:43.98,0:08:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parah banget!
Dialogue: 0,0:08:45.88,0:08:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu imut.
Dialogue: 0,0:08:48.11,0:08:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lupakan soal itu.
Dialogue: 0,0:08:50.74,0:08:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah digelitiki, aku tidak mau lupa.
Dialogue: 0,0:08:53.74,0:08:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya, maaf.
Dialogue: 0,0:08:56.27,0:08:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menggelitik lagi,
Dialogue: 0,0:08:58.22,0:09:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan membisikkan cerita itu\Nlangsung di telingamu.
Dialogue: 0,0:09:02.81,0:09:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya, maaf.
Dialogue: 0,0:09:12.61,0:09:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, kalian sedang melihat apa?
Dialogue: 0,0:09:15.95,0:09:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:09:16.94,0:09:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:09:18.37,0:09:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kok kalian melihat album itu\Ntanpa mengajak pemiliknya?
Dialogue: 0,0:09:23.04,0:09:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau melihat foto imutmu?
Dialogue: 0,0:09:26.82,0:09:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang, dong.
Dialogue: 0,0:09:28.49,0:09:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!\NMaksudku, jangan melihat tanpa izin!
Dialogue: 0,0:09:32.01,0:09:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tidak boleh?
Dialogue: 0,0:09:33.89,0:09:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, sih, tapi aku malu.
Dialogue: 0,0:09:38.06,0:09:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu imut, kok.
Dialogue: 0,0:09:39.60,0:09:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiina benar-benar mencintai Amane, ya.
Dialogue: 0,0:09:43.53,0:09:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai orang tua, aku senang\Nanak serajin kamu mendampingi Amane.
Dialogue: 0,0:09:50.07,0:09:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sayangnya, kami tidak dikabari apa-apa.
Dialogue: 0,0:09:55.27,0:09:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malu kalau harus lapor segala.
Dialogue: 0,0:09:58.41,0:10:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah tahu duluan, sih.
Dialogue: 0,0:10:00.45,0:10:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, bawa cewek ke sini saja\Nsudah jelas banget.
Dialogue: 0,0:10:04.99,0:10:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mudah ditebak pula.
Dialogue: 0,0:10:07.77,0:10:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet, apa salahnya kalau pacaran?
Dialogue: 0,0:10:10.38,0:10:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi gengsi.
Dialogue: 0,0:10:12.79,0:10:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin mau sama dia, Mahiru?
Dialogue: 0,0:10:15.15,0:10:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane memang pemalu,
Dialogue: 0,0:10:18.60,0:10:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi justru aku suka sifatnya itu.
Dialogue: 0,0:10:20.77,0:10:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah, ya ampun!
Dialogue: 0,0:10:22.85,0:10:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang melihat kalian akur.
Dialogue: 0,0:10:25.10,0:10:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Betul.\N- Aku serasa orang luar di rumah sendiri.
Dialogue: 0,0:10:26.65,0:10:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mahiru, lihat ini.\N- Aku serasa orang luar di rumah sendiri.
Dialogue: 0,0:10:29.01,0:10:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane imut banget, kan?
Dialogue: 0,0:10:33.52,0:10:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:10:35.73,0:10:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mengobrol sama Ibu dan Ayah?
Dialogue: 0,0:10:38.23,0:10:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku ingin mengobrol denganmu.
Dialogue: 0,0:10:41.52,0:10:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:43.05,0:10:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ini buatanmu, ya?
Dialogue: 0,0:10:45.17,0:10:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:46.38,0:10:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu marah?
Dialogue: 0,0:10:49.90,0:10:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tidak, kok.
Dialogue: 0,0:10:53.17,0:10:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma kesepian karena kamu direbut.
Dialogue: 0,0:10:56.55,0:10:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, maksudmu...
Dialogue: 0,0:10:59.59,0:11:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tahu kamu menikmati\Nwaktu bersama Ibu dan Ayah.
Dialogue: 0,0:11:05.10,0:11:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma merajuk sendiri, kok.
Dialogue: 0,0:11:09.85,0:11:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu bersama ibu dan ayahmu\Nmemang seru dan menyenangkan,
Dialogue: 0,0:11:15.74,0:11:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku paling senang saat bersamamu.
Dialogue: 0,0:11:27.36,0:11:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, ayo jalan-jalan berdua besok.
Dialogue: 0,0:11:31.30,0:11:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdua saja?
Dialogue: 0,0:11:33.46,0:11:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu dan Ayah akan bekerja
Dialogue: 0,0:11:35.73,0:11:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku belum mengajakmu berkeliling.
Dialogue: 0,0:11:39.20,0:11:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau, aku bersedia pergi\Nke mana pun kalau bersamamu.
Dialogue: 0,0:11:43.84,0:11:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:45.35,0:11:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku ingin tetap begini lebih lama.
Dialogue: 0,0:11:49.70,0:11:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu dan ayahmu pun menyuruhku\Nmenghabiskan waktu bersamamu.
Dialogue: 0,0:11:55.78,0:11:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:58.05,0:12:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo makan kue susnya sama-sama.
Dialogue: 0,0:12:01.11,0:12:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:04.81,0:12:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di daerah ini cuma ada\Ntaman dan supermarket.
Dialogue: 0,0:12:08.62,0:12:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain cerita kalau di pusat kota,\Nmau ke sana?
Dialogue: 0,0:12:11.97,0:12:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah, jalan-jalan\Nbersamamu saja sudah cukup.
Dialogue: 0,0:12:15.59,0:12:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jalan berduaan saja aku bahagia.
Dialogue: 0,0:12:18.66,0:12:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:12:20.65,0:12:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah melebihi pacaran biasa.
Dialogue: 0,0:12:23.43,0:12:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu muda, kita juga begitu, kan?
Dialogue: 0,0:12:27.06,0:12:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kamu tidak setenang Shiina.
Dialogue: 0,0:12:31.54,0:12:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, nyelekit.
Dialogue: 0,0:12:33.68,0:12:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itulah yang membuatmu imut.
Dialogue: 0,0:12:36.34,0:12:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh!
Dialogue: 0,0:12:42.93,0:12:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tampak bugar, ya.
Dialogue: 0,0:12:44.81,0:12:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku sudah tidak kuat\Nberlarian seperti itu.
Dialogue: 0,0:12:48.46,0:12:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang tidak suka berlari, kan?
Dialogue: 0,0:12:51.06,0:12:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak benci lari, kok.
Dialogue: 0,0:12:53.54,0:12:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma benci dipaksa berlari\Ndengan tempo tertentu saat olahraga.
Dialogue: 0,0:12:57.39,0:13:00.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mau ikut main sama anak-anak?
Dialogue: 0,0:13:00.38,0:13:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku dikira penculik.
Dialogue: 0,0:13:02.51,0:13:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku tidak mau meninggalkanmu.
Dialogue: 0,0:13:06.02,0:13:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena pakai rok, kamu tidak bisa\Nlari maupun jongkok, kan?
Dialogue: 0,0:13:09.27,0:13:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:10.77,0:13:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku agak iri.
Dialogue: 0,0:13:14.11,0:13:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya waktu kecil,\Naku tidak pernah seperti mereka.
Dialogue: 0,0:13:19.53,0:13:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu main sendirian di halaman rumah.
Dialogue: 0,0:13:24.06,0:13:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sekarang belum bisa.
Dialogue: 0,0:13:27.14,0:13:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, anu...
Dialogue: 0,0:13:29.99,0:13:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu saat, pasti kamu bisa\Nbermain seperti mereka.
Dialogue: 0,0:13:33.46,0:13:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:34.72,0:13:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah.
Dialogue: 0,0:13:38.05,0:13:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi.
Dialogue: 0,0:13:40.00,0:13:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:46.31,0:13:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujimiya?
Dialogue: 0,0:13:49.52,0:13:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga, kalau pulang kampung,
Dialogue: 0,0:13:53.71,0:13:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa saja bertemu dengannya.
Dialogue: 0,0:13:56.74,0:13:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benaran kamu, toh.
Dialogue: 0,0:13:58.78,0:14:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekilas aku sempat pangling.
Dialogue: 0,0:14:02.32,0:14:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu kelihatan sehat, Toujou.
Dialogue: 0,0:14:05.53,0:14:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa cewek itu?
Dialogue: 0,0:14:07.24,0:14:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang menggodanya?
Dialogue: 0,0:14:09.76,0:14:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin.
Dialogue: 0,0:14:11.98,0:14:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini pacarku.
Dialogue: 0,0:14:15.13,0:14:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu wajahmu masih imut,
Dialogue: 0,0:14:17.63,0:14:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang sudah jadi lelaki sejati\Ndan bawa cewek segala.
Dialogue: 0,0:14:21.78,0:14:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu cuma anak buah kami.
Dialogue: 0,0:14:30.05,0:14:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi berasa nostalgia.
Dialogue: 0,0:14:34.02,0:14:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Pacar, kenapa mau sama dia?
Dialogue: 0,0:14:37.19,0:14:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma anak mami, lo.
Dialogue: 0,0:14:39.27,0:14:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu penampilannya culun abis, lo!
Dialogue: 0,0:14:42.50,0:14:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane sudah menceritakan semuanya.
Dialogue: 0,0:14:46.11,0:14:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku baru tahu soal "wajah imutnya".
Dialogue: 0,0:14:50.21,0:14:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bilang,\Nkamu pasti maksa mau lihat fotonya.
Dialogue: 0,0:14:54.10,0:14:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya aku sudah lihat, sangat imut.
Dialogue: 0,0:14:58.53,0:15:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah mau bilang apa tentangku.
Dialogue: 0,0:15:01.17,0:15:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu pendapatmu.
Dialogue: 0,0:15:03.93,0:15:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia tidak akan berubah pikiran\Nsebanyak apa pun kamu mengejekku.
Dialogue: 0,0:15:10.93,0:15:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toujou.
Dialogue: 0,0:15:12.89,0:15:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua hal di masa itu
Dialogue: 0,0:15:14.90,0:15:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma kuanggap sebagai masa lalu.
Dialogue: 0,0:15:19.92,0:15:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru.
Dialogue: 0,0:15:26.01,0:15:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bertanya alasanku\Nmau bersama Amane, kan?
Dialogue: 0,0:15:30.89,0:15:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memilih orang dari hartanya?
Dialogue: 0,0:15:34.82,0:15:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memilih teman\Ndari berguna atau tidaknya?
Dialogue: 0,0:15:39.22,0:15:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kamu tidak akan\Npernah dapat apa-apa
Dialogue: 0,0:15:44.19,0:15:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan akan selalu merasa kosong.
Dialogue: 0,0:15:47.69,0:15:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku selalu merasa kosong.
Dialogue: 0,0:15:51.49,0:15:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terlihat makmur,
Dialogue: 0,0:15:53.83,0:15:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hatiku selalu kedinginan.
Dialogue: 0,0:15:57.59,0:16:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah bertemu Amane,\Nuntuk pertama kalinya
Dialogue: 0,0:16:01.44,0:16:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hatiku terisi oleh kebahagiaan.
Dialogue: 0,0:16:05.47,0:16:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku...
Dialogue: 0,0:16:08.59,0:16:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup selama ini
Dialogue: 0,0:16:11.10,0:16:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk bertemu dengan Amane.
Dialogue: 0,0:16:14.54,0:16:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan kalau mau menghargai orang\Ncuma lewat harta dan penampilannya.
Dialogue: 0,0:16:20.45,0:16:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau menghakimi\Npandangan orang lain.
Dialogue: 0,0:16:24.05,0:16:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama Amane paham\Nbetapa berharganya dia bagi diriku,
Dialogue: 0,0:16:28.95,0:16:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu lebih dari cukup.
Dialogue: 0,0:16:33.42,0:16:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, Mahiru.
Dialogue: 0,0:16:35.22,0:16:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:16:37.26,0:16:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toujou.
Dialogue: 0,0:16:39.00,0:16:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:40.63,0:16:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:43.34,0:16:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sempat terluka,
Dialogue: 0,0:16:45.20,0:16:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin justru pengalaman itulah\Nyang menempaku jadi lebih kuat.
Dialogue: 0,0:16:50.38,0:16:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara tidak langsung,\Nkalian memberiku pelajaran berharga.
Dialogue: 0,0:16:55.30,0:16:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat itu juga,\Naku berjumpa dengan pacarku.
Dialogue: 0,0:16:59.38,0:17:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak akan bergaul\Ndan bicara lagi denganmu,
Dialogue: 0,0:17:02.79,0:17:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku ingin mengatakan itu.
Dialogue: 0,0:17:05.58,0:17:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahiru, ayo pulang.
Dialogue: 0,0:17:07.92,0:17:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:20.19,0:17:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung aku pindah ke luar kota\Nsesuai saran Ayah.
Dialogue: 0,0:17:26.61,0:17:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih bangun?
Dialogue: 0,0:17:27.94,0:17:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa tidur.
Dialogue: 0,0:17:30.95,0:17:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu juga masih bangun?
Dialogue: 0,0:17:34.57,0:17:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya banyak yang terjadi.
Dialogue: 0,0:17:37.14,0:17:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:17:38.70,0:17:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tapi, aku begini bukan karena bersedih.
Dialogue: 0,0:17:43.63,0:17:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sedang memikirkan,\Nkayaknya aku sudah berkembang.
Dialogue: 0,0:17:51.39,0:17:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tambah kuat dan besar.
Dialogue: 0,0:17:56.05,0:17:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu maupun hatimu.
Dialogue: 0,0:17:59.60,0:18:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:18:01.39,0:18:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu percaya diri, kan?
Dialogue: 0,0:18:03.54,0:18:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:18:04.47,0:18:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, aku akan menopangmu\Nkalau kehilangan percaya diri.
Dialogue: 0,0:18:09.55,0:18:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh bersyukur.
Dialogue: 0,0:18:13.19,0:18:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mahiru.
Dialogue: 0,0:18:14.80,0:18:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:18:15.91,0:18:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengin sentuh.
Dialogue: 0,0:18:17.16,0:18:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:18.91,0:18:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang ingin menyentuhmu,\Nenggak boleh?
Dialogue: 0,0:18:25.79,0:18:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:18:34.24,0:18:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan macam-macam, kok.
Dialogue: 0,0:18:36.24,0:18:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:18:38.01,0:18:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kecewa?
Dialogue: 0,0:18:38.97,0:18:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Mana mungkin!
Dialogue: 0,0:18:42.07,0:18:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawaban itu bikin campur aduk, sih.
Dialogue: 0,0:18:44.31,0:18:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:45.22,0:18:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda, kok.
Dialogue: 0,0:18:47.14,0:18:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku cuma ingin menyentuhmu.
Dialogue: 0,0:18:53.09,0:18:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat mencintaimu.
Dialogue: 0,0:18:59.51,0:19:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, aku terkejut.
Dialogue: 0,0:19:02.86,0:19:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru aku yang tiba-tiba.
Dialogue: 0,0:19:05.89,0:19:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:19:07.13,0:19:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku tidak mau, kok.
Dialogue: 0,0:19:10.99,0:19:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma terkejut.
Dialogue: 0,0:19:15.22,0:19:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:19:17.85,0:19:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}To...
Dialogue: 0,0:19:19.37,0:19:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ulang sekali lagi.
Dialogue: 0,0:19:22.85,0:19:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku siap.
Dialogue: 0,0:19:47.33,0:19:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah berkali-kali?
Dialogue: 0,0:19:51.34,0:19:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau?
Dialogue: 0,0:19:53.34,0:19:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu.
Dialogue: 0,0:19:55.74,0:19:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih ke tidak siap.
Dialogue: 0,0:19:58.39,0:20:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekaligus malu.
Dialogue: 0,0:20:04.22,0:20:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amane, kamu benaran\Nbaru pertama kali pacaran?
Dialogue: 0,0:20:07.94,0:20:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terasa lebih santai dariku.
Dialogue: 0,0:20:10.94,0:20:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:20:12.88,0:20:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, saking inginnya menciummu,\Naku jadi agak memaksa.
Dialogue: 0,0:20:18.95,0:20:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku bukannya tidak mau.
Dialogue: 0,0:20:22.70,0:20:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal dikasih tahu dulu, aku siap.
Dialogue: 0,0:20:28.03,0:20:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lagi juga boleh...
Dialogue: 0,0:20:39.26,0:20:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum jatuh cinta padamu,
Dialogue: 0,0:20:42.11,0:20:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak paham kenapa orang berciuman.
Dialogue: 0,0:20:45.64,0:20:49.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau dilakukan\Nbersama orang yang dicintai,
Dialogue: 0,0:20:49.46,0:20:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata rasanya sebahagia ini.
Dialogue: 0,0:20:53.42,0:20:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, kamu bahagia?
Dialogue: 0,0:20:55.18,0:20:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:57.12,0:20:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:20:59.91,0:21:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sama, ya.
Dialogue: 0,0:21:02.81,0:21:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terasa hangat.
Dialogue: 0,0:21:05.23,0:21:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kedinginan?
Dialogue: 0,0:21:06.58,0:21:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:08.31,0:21:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya AC-nya masih menyala.
Dialogue: 0,0:21:12.13,0:21:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kuhangatkan?
Dialogue: 0,0:21:14.50,0:21:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu mau menghangatkanku?
Dialogue: 0,0:21:17.59,0:21:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus apa?
Dialogue: 0,0:21:19.41,0:21:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu?
Dialogue: 0,0:21:21.85,0:21:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus apa, ya?
Dialogue: 0,0:21:24.35,0:21:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba tebak.
Dialogue: 0,0:21:27.03,0:21:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi sulit digoda juga, deh.
Dialogue: 0,0:21:30.62,0:21:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan kalah kali ini.
Dialogue: 0,0:21:32.30,0:21:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:21:33.62,0:21:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nmari lakukan ini pada Nona Mahiru.
Dialogue: 0,0:21:39.25,0:21:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini, kita sama-sama hangat.
Dialogue: 0,0:21:42.23,0:21:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:43.70,0:21:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai layanan tambahan,\Nbisa dapat bantal lengan juga, lo.
Dialogue: 0,0:21:46.87,0:21:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai layanan tambahan,\Nharganya jadi berapa?
Dialogue: 0,0:21:50.91,0:21:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khusus untuk Mahiru,
Dialogue: 0,0:21:53.21,0:21:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bayar pakai omelet besok pagi.
Dialogue: 0,0:21:56.09,0:21:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuterima tawarannya.
Dialogue: 0,0:21:57.61,0:21:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi juga sudah.
