Dialogue: 0,0:00:47.03,0:00:47.53,tanda,,0000,0000,0000,,KELAS 2-D: AYANOKOJI KIYOTAKA
Dialogue: 0,0:02:34.13,0:02:36.47,tanda,,0000,0000,0000,,"#9 PEMBUKAAN MENCURIGAKAN"
Dialogue: 0,0:06:54.98,0:06:55.31,tanda,,0000,0000,0000,,ATURAN UJIAN KHUSUS PULAU TAK BERPENGHUNI
Dialogue: 0,0:08:47.59,0:08:47.97,tanda,,0000,0000,0000,,SMA KODO IKUSEI TOKYO\NUJIAN KHUSUS PULAU TAK BERPENGHUNI
Dialogue: 0,0:09:46.32,0:09:52.32,tanda,,0000,0000,0000,,HARI PERTAMA
Dialogue: 0,0:10:19.47,0:10:20.77,tanda,,0000,0000,0000,,WAKTU HINGGA PENGUMUMAN AREA YANG DITUNJUK\NBATAS WAKTU TIBA - AREA YANG DITUNJUK: D7
Dialogue: 0,0:14:50.37,0:14:52.75,tanda,,0000,0000,0000,,"TUGAS: MENYALAKAN API"
Dialogue: 0,0:19:13.09,0:19:17.84,tanda,,0000,0000,0000,,HARI KEDUA
Dialogue: 0,0:19:21.85,0:19:22.33,tanda,,0000,0000,0000,,WAKTU HINGGA PENGUMUMAN AREA YANG DITUNJUK\NBATAS WAKTU TIBA - AREA YANG DITUNJUK: E8
Dialogue: 0,0:00:01.23,0:00:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guncangan di waktu itu
Dialogue: 0,0:00:03.94,0:00:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang pun masih teringat jelas.
Dialogue: 0,0:00:07.19,0:00:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah kenyataan kejam yang datang
Dialogue: 0,0:00:09.91,0:00:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa ada pertanda apa-apa.
Dialogue: 0,0:00:18.62,0:00:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan hangat yang membelai kepalaku.
Dialogue: 0,0:00:23.71,0:00:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyum hangat yang menenangkan hatiku.
Dialogue: 0,0:00:29.01,0:00:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kuat dan lembut.
Dialogue: 0,0:00:31.84,0:00:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pernah berhenti berjuang\Nmelebihi siapa pun.
Dialogue: 0,0:00:35.22,0:00:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika orang seperti dia tak bisa\Nmenggapai mimpinya,
Dialogue: 0,0:00:38.64,0:00:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu tidak seharusnya dibiarkan.
Dialogue: 0,0:00:41.56,0:00:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan berarti tidak merasa bersalah.
Dialogue: 0,0:00:45.48,0:00:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja,
Dialogue: 0,0:00:47.57,0:00:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak bisa juga untuk memaafkan.
Dialogue: 0,0:00:49.95,0:00:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mengalahkan dirinya...
Dialogue: 0,0:00:52.24,0:00:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku yang lemah ini,
Dialogue: 0,0:00:54.33,0:00:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang akan menopangnya.
Dialogue: 0,0:00:57.12,0:01:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menuju tujuan sebenarnya\Nyang ada di ujung sana.
Dialogue: 0,0:01:11.51,0:01:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:21.33,0:02:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:34.13,0:02:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya keren sekali, ya.
Dialogue: 0,0:02:36.47,0:02:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tahun kemarin tidak lihat?
Dialogue: 0,0:02:38.60,0:02:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang lihat sedikit, sih.
Dialogue: 0,0:02:41.43,0:02:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi cuma pelengkap saja karena aku\Nmain sama teman-teman terus.
Dialogue: 0,0:02:46.52,0:02:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya masih seperti mimpi.
Dialogue: 0,0:02:49.48,0:02:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan naik kapal pesiar\Nmemang tidak datang sesering itu.
Dialogue: 0,0:02:53.36,0:02:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan yang itu.
Dialogue: 0,0:02:55.53,0:02:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi rasanya pacaran sama Kiyotaka.
Dialogue: 0,0:02:58.49,0:03:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya kamu betulan tidak jago\Ndi bagian itu.
Dialogue: 0,0:03:02.33,0:03:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana?
Dialogue: 0,0:03:04.71,0:03:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang bisa kamu rasakan?
Dialogue: 0,0:03:08.00,0:03:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, bagaimana, ya?
Dialogue: 0,0:03:10.59,0:03:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibilang ada mungkin iya,\Ndibilang tidak juga bisa.
Dialogue: 0,0:03:14.47,0:03:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa coba?
Dialogue: 0,0:03:16.18,0:03:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa ketemuan di luar tanpa\Nketahuan orang seperti ini
Dialogue: 0,0:03:19.14,0:03:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak pernah terbayang olehku sebelumnya.
Dialogue: 0,0:03:21.68,0:03:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:03:23.72,0:03:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung isi ujian khusus\Nyang akan diumumkan sehabis ini,
Dialogue: 0,0:03:27.48,0:03:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa jadi aku akan minta tolong padamu.
Dialogue: 0,0:03:30.36,0:03:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tahu.
Dialogue: 0,0:03:32.36,0:03:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, selama itu masih bisa kulakukan.
Dialogue: 0,0:03:37.66,0:03:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kelas satu seperti sudah selesai.
Dialogue: 0,0:03:40.41,0:03:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa ke sana sama-sama,\Njadi aku duluan, ya.
Dialogue: 0,0:03:51.63,0:03:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh?!
Dialogue: 0,0:03:52.67,0:03:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa duduk di situ?
Dialogue: 0,0:03:54.96,0:03:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak sengaja, kan?
Dialogue: 0,0:03:57.17,0:03:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak.
Dialogue: 0,0:03:58.43,0:04:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, kenapa harus aku...
Dialogue: 0,0:04:03.31,0:04:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang akan kujelaskan aturan dari\Nujian khusus pulau tak berpenghuni.
Dialogue: 0,0:04:07.85,0:04:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai besok selama dua pekan,
Dialogue: 0,0:04:09.44,0:04:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian akan mengikuti ujian bertahan hidup\Ndengan bersaing mengumpulkan poin.
Dialogue: 0,0:04:13.32,0:04:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung didiskualifikasi\Njika seluruh anggota menyerah.
Dialogue: 0,0:04:16.24,0:04:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh anggota lima regu terbawah akan\Ndikeluarkan dari sekolah.
Dialogue: 0,0:04:19.57,0:04:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada dua cara untuk mengumpulkan poin.
Dialogue: 0,0:04:22.24,0:04:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama pergerakan dasar.
Dialogue: 0,0:04:23.95,0:04:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendapat poin dengan menuju petak tertentu\Nyang membagi pulau jadi seratus bagian.
Dialogue: 0,0:04:28.79,0:04:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam sehari,\Nakan ada empat area yang ditunjuk
Dialogue: 0,0:04:30.99,0:04:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diumumkan tiap beberapa jam sekali.
Dialogue: 0,0:04:33.46,0:04:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area yang ditunjuk akan punya ketentuan.
Dialogue: 0,0:04:35.50,0:04:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu tiga kali sehari akan berada\Ndi dua petak vertikal atau horizontal
Dialogue: 0,0:04:38.63,0:04:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau satu petak diagonal.
Dialogue: 0,0:04:41.47,0:04:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, akan ada satu kali dalam sehari\Nyang ditentukan secara acak
Dialogue: 0,0:04:45.10,0:04:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak ada yang tahu akan berada di mana.
Dialogue: 0,0:04:47.60,0:04:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdasar urutan tiba di titik yang ditunjuk,
Dialogue: 0,0:04:49.89,0:04:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}posisi pertama mendapat 10 poin,\Nkedua 5 poin dan ketiga 3 poin.
Dialogue: 0,0:04:54.02,0:04:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bonus 1 poin akan diberikan pada\Nsemua peserta bila tiba dalam batas waktu.
Dialogue: 0,0:04:59.11,0:05:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, untuk hadiah kedatangan
Dialogue: 0,0:05:00.65,0:05:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan diberikan menurut catatan waktu\Nsaat seluruh anggota grup tiba.
Dialogue: 0,0:05:04.53,0:05:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila telah berada di lokasi\Nsaat area yang ditunjuk diberitahukan,
Dialogue: 0,0:05:09.00,0:05:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan mendapat 1 poin per anggota\Nnamun hadiah kedatangan tidak dihitung.
Dialogue: 0,0:05:13.00,0:05:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila tiga kali beruntun mengabaikan\Narea yang ditunjuk, maka diberi penalti.
Dialogue: 0,0:05:17.76,0:05:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum kujelaskan cara lain mendapat poin,
Dialogue: 0,0:05:21.22,0:05:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}coba lihat ini.
Dialogue: 0,0:05:23.39,0:05:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga ujian berakhir, kalian semua\Nharus mengenakan jam tangan ini
Dialogue: 0,0:05:26.85,0:05:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta akan dibagikan tablet yang\Nterhubung dengan ini.
Dialogue: 0,0:05:29.89,0:05:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan menjadi alat wajib karena\Npoin yang didapat akan dihitung di sini.
Dialogue: 0,0:05:34.52,0:05:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga untuk terus memantau\Nkondisi kesehatan kalian.
Dialogue: 0,0:05:38.48,0:05:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila melewati batas yang ditentukan,
Dialogue: 0,0:05:40.78,0:05:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan muncul alarm peringatan.
Dialogue: 0,0:05:43.70,0:05:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah diatur untuk otomatis berhenti\Nsetelah lima detik.
Dialogue: 0,0:05:46.78,0:05:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bila kondisi di luar batas berlanjut,\Nalarm akan kembali berbunyi.
Dialogue: 0,0:05:51.91,0:05:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila keanehan masih terus berlanjut,
Dialogue: 0,0:05:54.25,0:05:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan berubah jadi alarm darurat.
Dialogue: 0,0:05:56.59,0:06:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situasi ini, kalian akan diminta\Nmenjalani pemeriksaan medis di titik start.
Dialogue: 0,0:06:01.22,0:06:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bila tidak bisa sampai ke sana,
Dialogue: 0,0:06:03.35,0:06:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka diberi penalti\Nkarena dianggap menyerah.
Dialogue: 0,0:06:06.55,0:06:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila alarm darurat tidak berhenti\Nselama lima menit,
Dialogue: 0,0:06:09.97,0:06:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}staf pengajar dan tim medis\Nakan menuju lokasi berdasar titik di GPS.
Dialogue: 0,0:06:13.60,0:06:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, bila dilepas paksa
Dialogue: 0,0:06:16.44,0:06:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau ada kerusakan pada alatnya,\Nmaka fitur perolehan nilai akan mati.
Dialogue: 0,0:06:20.44,0:06:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu terjadi, perlu dilakukan\Npenggantian di titik start.
Dialogue: 0,0:06:24.53,0:06:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali ke topik pergerakan dasar.
Dialogue: 0,0:06:26.91,0:06:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ujian, bukan berarti semua grup\Nakan menuju area yang sama.
Dialogue: 0,0:06:32.04,0:06:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di jam tangan kalian terdapat 12 tabel.
Dialogue: 0,0:06:35.75,0:06:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area tiap tabel
Dialogue: 0,0:06:37.10,0:06:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak hari pertama hingga akhir\Nsudah ditentukan secara internal.
Dialogue: 0,0:06:41.21,0:06:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu seluruh anggota grup\Nakan mendapat tabel yang sama.
Dialogue: 0,0:06:44.76,0:06:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika membentuk grup besar, semua anggota\Nakan berganti ke tabel yang sama.
Dialogue: 0,0:06:48.85,0:06:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara mendapat poin yang kedua adalah
Dialogue: 0,0:06:51.10,0:06:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan menyelesaikan tugas yang\Ntersebar di penjuru pulau tak berpenghuni.
Dialogue: 0,0:06:55.35,0:06:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi dan materi tugasnya\Ntidak bisa diprediksi.
Dialogue: 0,0:06:58.90,0:07:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat ikut serta memang bisa ditampilkan.
Dialogue: 0,0:07:01.48,0:07:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi perlu datang ke lokasi untuk tahu\Nbagaimana pelaksanaannya.
Dialogue: 0,0:07:05.74,0:07:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan dan air akan diberikan\Nsebagai hadiah dari tugas.
Dialogue: 0,0:07:09.95,0:07:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup yang ingin bergabung akan disetujui\Ndengan menautkan jam tangan.
Dialogue: 0,0:07:15.25,0:07:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya akan beralih ke sambutan\Noleh Kepala Yayasan Sementara Tsukishiro.
Dialogue: 0,0:07:26.26,0:07:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya Tsukishiro.
Dialogue: 0,0:07:28.09,0:07:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian pulau tak berpenghuni ini
Dialogue: 0,0:07:30.01,0:07:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan jadi ujian skala besar\Nyang belum pernah ada sebelumnya.
Dialogue: 0,0:07:34.93,0:07:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujelaskan satu hal\Nyang perlu kalian perhatikan.
Dialogue: 0,0:07:40.52,0:07:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah sebagai pihak\Nyang melindungi kalian semua
Dialogue: 0,0:07:43.48,0:07:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan melakukan pengawasan secara maksimal.
Dialogue: 0,0:07:46.78,0:07:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, bukan berarti bisa menjangkau\Nseluruh pulau tak berpenghuni ini.
Dialogue: 0,0:07:52.03,0:07:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila terjadi masalah seksual,\Ntanpa ragu akan diberi penalti.
Dialogue: 0,0:07:57.50,0:08:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga akan dilaporkan ke polisi\Nbila sampai terjadi tindak kriminal.
Dialogue: 0,0:08:02.42,0:08:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu satu lagi.
Dialogue: 0,0:08:04.42,0:08:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat stres bertumpuk akibat\Nkekurangan makanan dan air,
Dialogue: 0,0:08:08.63,0:08:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti akan ada perselisihan kecil\Nantar siswa.
Dialogue: 0,0:08:12.05,0:08:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai itu, secara pribadi aku akan\Nmengizinkannya sampai batas tertentu.
Dialogue: 0,0:08:18.19,0:08:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak menimbulkan pertengkaran sama sekali\Nitu pada dasarnya mustahil dilakukan.
Dialogue: 0,0:08:23.32,0:08:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, sekolah akan mengintervensi bila\Ntelah dianggap sebagai tindak kriminal.
Dialogue: 0,0:08:28.86,0:08:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung situasinya,
Dialogue: 0,0:08:30.57,0:08:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa juga akan langsung didiskualifikasi\Ndan dikeluarkan dari sekolah.
Dialogue: 0,0:08:35.90,0:08:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian, itu saja.
Dialogue: 0,0:08:37.78,0:08:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kalian bertindak sepantasnya\Nsebagai siswa SMA Kodo Ikusei.
Dialogue: 0,0:08:48.01,0:08:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sambutannya,\NBapak Kepala Yayasan Sementara Tsukishiro.
Dialogue: 0,0:08:52.01,0:08:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang terakhir
Dialogue: 0,0:08:53.39,0:08:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beralih ke penjelasan makanan dan peralatan\Nyang vital untuk pulau tak berpenghuni.
Dialogue: 0,0:09:02.60,0:09:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:09:04.44,0:09:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius ini jatah untuk semua orang?
Dialogue: 0,0:09:07.28,0:09:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?
Dialogue: 0,0:09:08.57,0:09:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya? Kita rasanya sama-sama\Npunya sifat yang menyulitkan.
Dialogue: 0,0:09:12.70,0:09:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit untuk masuk ke kerumunan di sana.
Dialogue: 0,0:09:14.99,0:09:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:09:15.78,0:09:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan samakan aku denganmu!
Dialogue: 0,0:09:17.12,0:09:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa saja ke sana!
Dialogue: 0,0:09:22.33,0:09:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kau ini?
Dialogue: 0,0:09:24.00,0:09:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatku, mau mengamankan jatah air\Nyang kita butuhkan...
Dialogue: 0,0:09:33.30,0:09:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang air minum yang berharga.
Dialogue: 0,0:09:35.60,0:09:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sepertinya harus mengumpulkan\Nair hujan di lokasi atau selesaikan tugas.
Dialogue: 0,0:09:55.12,0:09:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin bisa tidur nyenyak?
Dialogue: 0,0:09:59.83,0:10:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sewajarnya saja.
Dialogue: 0,0:10:01.66,0:10:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badan Horikita sendiri apa tidak sakit?
Dialogue: 0,0:10:04.33,0:10:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih saja menyalahkan\Nkejadian tahun lalu, ya.
Dialogue: 0,0:10:07.59,0:10:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, cuma kuungkit sedikit.
Dialogue: 0,0:10:10.46,0:10:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ujian khusus mau dimulai,\Ntapi kelihatannya kamu santai sekali.
Dialogue: 0,0:10:15.01,0:10:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau panik pun tidak ada gunanya, kan?
Dialogue: 0,0:10:20.81,0:10:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat F9.
Dialogue: 0,0:10:22.81,0:10:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita di tabel yang berbeda.
Dialogue: 0,0:10:25.69,0:10:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan mengkhawatirkan\Nsoal dirimu lagi.
Dialogue: 0,0:10:28.65,0:10:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesaikanlah ini dengan\Nperingkat setinggi mungkin.
Dialogue: 0,0:10:31.28,0:10:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin saja begitu.
Dialogue: 0,0:10:33.65,0:10:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi akan sangat tidak lucu kalau nanti\Ncuma aku sendiri yang akan dikeluarkan.
Dialogue: 0,0:10:37.91,0:10:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu, jujur aku akan kesusahan.
Dialogue: 0,0:10:40.91,0:10:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lama ini juga\Nbaru saja kupinjami poin.
Dialogue: 0,0:10:44.16,0:10:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah itu masalahnya.
Dialogue: 0,0:10:46.08,0:10:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dipahami kalau dirimu kekurangan uang\Nkarena kontrak dengan Kushida,
Dialogue: 0,0:10:50.80,0:10:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi berlebihan sekali kalau tiap bulan\Nharus menyetor setengah poinmu.
Dialogue: 0,0:10:54.76,0:10:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sakit kalau dibahas.
Dialogue: 0,0:10:56.93,0:10:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jangan memaksakan diri, ya.
Dialogue: 0,0:10:58.97,0:11:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswi yang bergerak sendiri\Nakan jadi pertarungan yang cukup berat.
Dialogue: 0,0:11:02.27,0:11:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuterima peringatanmu\Ndengan senang hati.
Dialogue: 0,0:11:05.98,0:11:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya tidak ada\Ngrup kelas dua yang panik.
Dialogue: 0,0:11:08.90,0:11:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada selisih sepuluh menit dengan\Nanak kelas satu yang start lebih dulu.
Dialogue: 0,0:11:12.78,0:11:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuang stamina demi berebut area pertama\Nmemang bukan langkah yang baik.
Dialogue: 0,0:11:20.41,0:11:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa si Koenji serius ingin\Nmeraih peringkat pertama?
Dialogue: 0,0:11:24.79,0:11:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah.
Dialogue: 0,0:11:26.04,0:11:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sudah bertaruh dengannya,
Dialogue: 0,0:11:28.33,0:11:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sama sekali tidak tahu\Nbagaimana dia akan bergerak.
Dialogue: 0,0:11:32.38,0:11:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji memang tidak punya\Nkekuatan yang mengikat, sih.
Dialogue: 0,0:11:35.34,0:11:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!\NAyo sekarang incar posisi pertama!
Dialogue: 0,0:11:39.55,0:11:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nishino buruan, dong!\NTsube juga!
Dialogue: 0,0:11:42.89,0:11:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini panas, jangan minta yang tidak-tidak!
Dialogue: 0,0:11:46.14,0:11:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, mana bisa sekarang\Nmenyalip anak kelas satu.
Dialogue: 0,0:11:49.81,0:11:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyerah, bakal berakhir di situ!
Dialogue: 0,0:11:52.52,0:11:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kelas satu bisa saja sedang lengah.
Dialogue: 0,0:11:55.99,0:11:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, dong!\NBuang-buang tenaga banget, tahu!
Dialogue: 0,0:11:59.53,0:12:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu saja duluan sana.
Dialogue: 0,0:12:01.28,0:12:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti enggak dapat hadiah\Nperingkat kedatangan!
Dialogue: 0,0:12:04.70,0:12:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga berabe kalau sampai terpisah!
Dialogue: 0,0:12:07.71,0:12:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:12:11.88,0:12:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa?
Dialogue: 0,0:12:13.25,0:12:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ada urusan apa-apa.
Dialogue: 0,0:12:15.05,0:12:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja aku tidak akan kalah darimu!
Dialogue: 0,0:12:21.43,0:12:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia paham tingkat kesulitan ujiannya?
Dialogue: 0,0:12:24.85,0:12:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal motivasi, kelihatannya lumayan tinggi.
Dialogue: 0,0:12:27.93,0:12:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya rival itu bagus.
Dialogue: 0,0:12:30.44,0:12:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya aku tidak kuanggap begitu.
Dialogue: 0,0:12:33.48,0:12:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya bisa tenang karena\Nsepertinya beda tabel dengan dia.
Dialogue: 0,0:12:37.57,0:12:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:12:39.32,0:12:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku berangkat dulu.
Dialogue: 0,0:12:54.00,0:12:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu poin dari\Nujian khusus ini adalah
Dialogue: 0,0:12:56.80,0:13:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan sampai melewatkan poin\Nyang bisa didapat dari mencapai area.
Dialogue: 0,0:13:01.09,0:13:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dapat hadiah dari peringkat\Nkedatangan atau tugas,
Dialogue: 0,0:13:04.26,0:13:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa saja langsung dapat 5 atau 10 poin.
Dialogue: 0,0:13:07.60,0:13:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi akan butuh stamina,\Nakademik serta keberuntungan yang cukup.
Dialogue: 0,0:13:12.19,0:13:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah, mengumpulkan 1 poin\Nsecara perlahan akan jadi hal yang esensial.
Dialogue: 0,0:13:18.07,0:13:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang membahas area selanjutnya?
Dialogue: 0,0:13:20.86,0:13:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kiyopon.
Dialogue: 0,0:13:22.82,0:13:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area pertama kami di D8 ini,\Njadinya sudah selesai.
Dialogue: 0,0:13:28.37,0:13:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiyotaka di area mana?
Dialogue: 0,0:13:30.46,0:13:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu petak lagi ke utara di D7.
Dialogue: 0,0:13:32.58,0:13:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja tabelnya sama,\Nkita bisa gerak bersama-sama.
Dialogue: 0,0:13:36.80,0:13:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga dibagi 12 tabel.
Dialogue: 0,0:13:38.63,0:13:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin segera menyelesaikan areaku.
Dialogue: 0,0:13:42.09,0:13:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak sepi rasanya,
Dialogue: 0,0:13:43.72,0:13:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi semoga kita bisa ketemu lagi\Ndi waktu yang santai!
Dialogue: 0,0:13:47.68,0:13:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak aspek untuk kerja sama\Nmeski di grup yang berbeda.
Dialogue: 0,0:13:52.10,0:13:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, ya!
Dialogue: 0,0:13:52.49,0:13:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bergerak bersama anggota yang\Njadi beban karena kurang cakap
Dialogue: 0,0:13:56.11,0:13:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus benar-benar dihindari.
Dialogue: 0,0:13:59.03,0:14:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk kali ini untung saja\Ntabel kami berbeda.
Dialogue: 0,0:14:09.20,0:14:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar siap untuk area\Nyang ditunjuk selanjutnya,
Dialogue: 0,0:14:11.71,0:14:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin sebaiknya\Naku pindah lebih ke tengah.
Dialogue: 0,0:14:15.67,0:14:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengidentifikasi rival\Ndi tabel yang sama,
Dialogue: 0,0:14:18.59,0:14:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau tidak mau harus lihat\Ndan dipastikan langsung di lokasi.
Dialogue: 0,0:14:21.30,0:14:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:14:23.13,0:14:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase?\NMana Hosen dan Amasawa?
Dialogue: 0,0:14:26.68,0:14:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya sedang memeriksa sekitar.
Dialogue: 0,0:14:29.10,0:14:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya memutuskan untuk memeriksa\Nberapa grup lain yang ada di sini.
Dialogue: 0,0:14:34.35,0:14:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti sama denganku.
Dialogue: 0,0:14:36.86,0:14:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya yakin Kakak juga\Nkesusahan seorang diri.
Dialogue: 0,0:14:39.86,0:14:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tolong hati-hati.
Dialogue: 0,0:14:41.57,0:14:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya permisi.
Dialogue: 0,0:14:46.11,0:14:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada tiga jam sampai pengumuman\Narea yang ditunjuk selanjutnya.
Dialogue: 0,0:14:50.37,0:14:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya menunggu saja
Dialogue: 0,0:14:53.14,0:14:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menuju lokasi penugasan.
Dialogue: 0,0:14:59.29,0:15:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Ayanokoji.
Dialogue: 0,0:15:02.13,0:15:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata datang ke sini.
Dialogue: 0,0:15:03.97,0:15:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sayang sekali.
Dialogue: 0,0:15:05.63,0:15:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu tugasnya sudah habis\Nsekitar lima menit yang lalu.
Dialogue: 0,0:15:08.97,0:15:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya memang begitu...
Dialogue: 0,0:15:10.72,0:15:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya tidak perlu seburu-buru itu?
Dialogue: 0,0:15:13.48,0:15:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebas saja kalau mau melihat-lihat.
Dialogue: 0,0:15:15.73,0:15:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa, seorang guru secara sepihak\Nmerampas waktu siswanya itu sebuah masalah.
Dialogue: 0,0:15:21.48,0:15:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa kata-katamu tidak berlebihan?
Dialogue: 0,0:15:24.49,0:15:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin bicara sebentar saja.
Dialogue: 0,0:15:29.37,0:15:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir kali kita bicara begini\Nitu sejak ujian akhir tahun pelajaran, ya.
Dialogue: 0,0:15:33.58,0:15:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:15:35.00,0:15:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, belakangan ini\Nkamu dapat banyak perhatian, ya.
Dialogue: 0,0:15:38.58,0:15:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kukira kamu\Ntidak suka menarik perhatian.
Dialogue: 0,0:15:41.63,0:15:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya memang tidak suka.
Dialogue: 0,0:15:43.51,0:15:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kenapa malah dapat\Nnilai sempurna di mapel matematika?
Dialogue: 0,0:15:47.88,0:15:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu tidak wajar.
Dialogue: 0,0:15:50.51,0:15:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa, tidak sedikit siswa di sekolah\Nyang bisa menyelesaikan soal seperti itu.
Dialogue: 0,0:15:56.27,0:15:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada?
Dialogue: 0,0:15:57.56,0:15:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya ada?
Dialogue: 0,0:15:59.27,0:16:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun ada, tapi kamu dari kelas D, lo.
Dialogue: 0,0:16:03.11,0:16:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai ada anak dengan spek luar biasa\Nseperti Ayanokoji di sana,
Dialogue: 0,0:16:07.24,0:16:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memangnya boleh?
Dialogue: 0,0:16:09.53,0:16:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kelas 2-D sekalipun,\Nsaya rasa ada siswa yang cukup berprestasi.
Dialogue: 0,0:16:14.33,0:16:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama halnya dengan kelas 1-D.
Dialogue: 0,0:16:17.50,0:16:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar, sih.
Dialogue: 0,0:16:20.04,0:16:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sepertinya sejak tahun kemarin,\Nhaluan sekolah memang sedikit berubah.
Dialogue: 0,0:16:26.17,0:16:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak berprestasi memang benar adanya.
Dialogue: 0,0:16:29.18,0:16:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi seharusnya tidak sampai\Nbisa menggerakkan kelas,
Dialogue: 0,0:16:32.80,0:16:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau untuk kasus Ayanokoji, terasa seperti\Nmengubah lingkungan sekitarmu.
Dialogue: 0,0:16:37.43,0:16:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sudah cukup mengumpulkan informasi\Ntanpa sepengetahuanku, ya?
Dialogue: 0,0:16:43.19,0:16:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini sudah tidak bisa santai lagi.
Dialogue: 0,0:16:46.74,0:16:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru pertama kali ini turun ke Kelas C.
Dialogue: 0,0:16:49.86,0:16:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kukira kelas ini\Nbisa kubawa jadi Kelas A.
Dialogue: 0,0:16:53.99,0:16:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah memang tugas wali kelas\Nuntuk mengatasi itu?
Dialogue: 0,0:16:58.08,0:17:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang menyakitkan kalau dibahas.
Dialogue: 0,0:17:00.42,0:17:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau begitu ada ide brilian\Ndari Bu Guru!
Dialogue: 0,0:17:03.96,0:17:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti Katsuragi yang pindah ke Kelas B,\NAyanokoji mau tidak pindah ke kelasku?
Dialogue: 0,0:17:09.51,0:17:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide Ibu gila juga, ya.
Dialogue: 0,0:17:12.30,0:17:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo incar Kelas A sama kami, ya!
Dialogue: 0,0:17:15.59,0:17:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sampai lulus sekalipun,\Nsaya tak akan bisa menyiapkan 20 juta poin.
Dialogue: 0,0:17:20.77,0:17:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi di tahap ini,
Dialogue: 0,0:17:22.98,0:17:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada yang tahu kelas mana\Nyang akan berakhir jadi Kelas A.
Dialogue: 0,0:17:26.23,0:17:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak usah ditanggapi setenang itu.
Dialogue: 0,0:17:32.36,0:17:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudo juga sudah banyak berubah.
Dialogue: 0,0:17:35.99,0:17:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa coba yang sudah mengubahnya?
Dialogue: 0,0:17:38.45,0:17:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saya perjelas, kalau itu bukan saya.
Dialogue: 0,0:17:41.58,0:17:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, saya izin mundur dulu.
Dialogue: 0,0:17:45.00,0:17:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai ujian selesai,\Nrencananya aku akan sibuk ke sana ke mari.
Dialogue: 0,0:17:49.38,0:17:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa saja kita ketemu lagi!
Dialogue: 0,0:17:56.89,0:17:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji?
Dialogue: 0,0:17:58.64,0:18:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang kedua.
Dialogue: 0,0:18:00.31,0:18:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kebetulan sekali.
Dialogue: 0,0:18:02.85,0:18:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hasil Kakak hari ini?
Dialogue: 0,0:18:04.90,0:18:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat 3 poin bonus kedatangan saja\Nsudah setengah mati.
Dialogue: 0,0:18:08.73,0:18:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri?
Dialogue: 0,0:18:09.90,0:18:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bertiga dapat 8 poin\Ndari area yang ditentukan.
Dialogue: 0,0:18:12.61,0:18:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dapat peringkat satu di tugas,\Njadi total poin kami 13.
Dialogue: 0,0:18:16.49,0:18:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permulaan kalian lancar sekali.
Dialogue: 0,0:18:18.83,0:18:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:20.04,0:18:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:18:21.96,0:18:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, saya izin permisi.
Dialogue: 0,0:18:29.55,0:18:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Tsukishiro ingin\Nmengeluarkanku dari sekolah
Dialogue: 0,0:18:32.97,0:18:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}secara legal menjatuhkanku\Nke peringkat lima terbawah,
Dialogue: 0,0:18:36.97,0:18:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kendali untuk mendapat poin\Nada di tanganku.
Dialogue: 0,0:18:39.85,0:18:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ada kemungkinan\Njam tangan dan tablet dikendalikan
Dialogue: 0,0:18:43.43,0:18:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menampilkan poin palsu.
Dialogue: 0,0:18:48.11,0:18:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kuajukan keberatan ke sekolah,
Dialogue: 0,0:18:50.98,0:18:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka strategi ini\Nakan berakhir setengah-setengah.
Dialogue: 0,0:18:55.45,0:18:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memanfaatkan siswa White Room,
Dialogue: 0,0:18:58.24,0:19:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya akan mengincar diskualifikasi\Nkarena terluka atau sakit, ya.
Dialogue: 0,0:19:02.37,0:19:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, akan menyerangku di tempat\Nyang tidak dijangkau pengawasan.
Dialogue: 0,0:19:08.59,0:19:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu langkah realistis untuk\Nmengeluarkanku dari sekolah.
Dialogue: 0,0:19:22.33,0:19:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E8, ya.
Dialogue: 0,0:19:34.44,0:19:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir waktu tempuhnya,\Nlebih baik diabaikan saja.
Dialogue: 0,0:19:44.20,0:19:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berturut-turut di posisi kedua.
Dialogue: 0,0:19:46.58,0:19:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi ada rival kuat\Ndi tabel yang sama denganku.
Dialogue: 0,0:19:50.75,0:19:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali saja ke E6 menunggu tugas.
Dialogue: 0,0:19:58.13,0:20:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji.
Dialogue: 0,0:20:00.60,0:20:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bertemu lagi.
Dialogue: 0,0:20:02.81,0:20:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin kita di tabel yang sama?
Dialogue: 0,0:20:06.60,0:20:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi.
Dialogue: 0,0:20:08.65,0:20:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski menuju area yang sama sekalipun,
Dialogue: 0,0:20:11.23,0:20:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemungkinan bertatap muka\Ntidaklah setinggi itu.
Dialogue: 0,0:20:14.53,0:20:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang bisa saja sekadar\Nkebetulan yang beruntun.
Dialogue: 0,0:20:18.49,0:20:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Kak, saya ada permintaan.
Dialogue: 0,0:20:22.08,0:20:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permintaan?
Dialogue: 0,0:20:23.95,0:20:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mengganggu, bolehkah\Nuntuk sementara saya bergerak sama Kakak?
Dialogue: 0,0:20:29.04,0:20:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersamaku?
Dialogue: 0,0:20:30.54,0:20:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:20:32.04,0:20:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya tadi malam,
Dialogue: 0,0:20:33.96,0:20:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen dan Amasawa bilang ingin\Ngerak sendiri-sendiri.
Dialogue: 0,0:20:38.26,0:20:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pun jadinya terpisah.
Dialogue: 0,0:20:40.51,0:20:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga bisa disebut salah satu strategi.
Dialogue: 0,0:20:43.85,0:20:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan kalau saya sendiri tidak bisa\Nsegera mengejar ke area yang ditunjuk.
Dialogue: 0,0:20:49.19,0:20:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sisi lain, sejak kemarin\Nsudah tiga kali bertemu Kak Ayanokoji.
Dialogue: 0,0:20:53.90,0:20:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain yang pertama, Kakak selalu\Nlebih dulu sampai dari saya.
Dialogue: 0,0:20:58.19,0:21:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergerak bersama grup dari angkatan lain\Ntidak bisa dibilang langkah yang cerdas.
Dialogue: 0,0:21:03.87,0:21:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ketemu tugas yang hanya bisa\Ndiikuti satu grup lagi,
Dialogue: 0,0:21:07.45,0:21:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan langsung terjadi perselisihan.
Dialogue: 0,0:21:10.08,0:21:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak masalah untuk\Nselalu mengalah pada Kakak.
Dialogue: 0,0:21:14.38,0:21:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Poin perolehan Nanase nantinya\Njelas akan berkurang.
Dialogue: 0,0:21:17.92,0:21:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya baru pertama ini ikut\Nujian pulau tak berpenghuni.
Dialogue: 0,0:21:21.09,0:21:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipilihkan rute yang tepat saja\Nsudah sangat membantu.
Dialogue: 0,0:21:26.10,0:21:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalkan aku memang memilih\Nrute yang tepat,
Dialogue: 0,0:21:29.52,0:21:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kamu bisa mengikuti lajuku?
Dialogue: 0,0:21:32.35,0:21:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya yakin dengan stamina saya.
Dialogue: 0,0:21:35.06,0:21:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding disebut merepotkan,\Napa Kakak tidak bisa memercayai saya?
Dialogue: 0,0:21:40.53,0:21:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:21:41.95,0:21:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak masalah kalau itu\Nmemang yang Nanase inginkan.
Dialogue: 0,0:21:45.12,0:21:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:21:47.33,0:21:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ini mau bagaimana?
Dialogue: 0,0:21:49.25,0:21:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada satu jam lebih sampai\Npemberitahuan area.
Dialogue: 0,0:21:52.33,0:21:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tugas kuis di area F8 arah tenggara.
Dialogue: 0,0:21:56.09,0:21:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau mengincar itu.
Dialogue: 0,0:21:57.63,0:22:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, akan saya temani.
