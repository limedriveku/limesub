Dialogue: 0,0:01:21.60,0:01:22.38,tanda,,0000,0000,0000,,HOSEN KAZUOMI
Dialogue: 0,0:01:30.86,0:01:32.14,tanda,,0000,0000,0000,,"HOSEN KAZUOMI"
Dialogue: 0,0:01:40.96,0:01:44.08,tanda,,0000,0000,0000,,"HOSEN KAZUOMI"
Dialogue: 0,0:01:46.25,0:01:46.96,tanda,,0000,0000,0000,,TELEPON TELAH BERAKHIR
Dialogue: 0,0:02:14.58,0:02:20.37,tanda,,0000,0000,0000,,CLASSROOM OF THE ELITE 4TH SEASON:\NSECOND YEAR, FIRST SEMESTER
Dialogue: 0,0:03:24.40,0:03:30.99,tanda,,0000,0000,0000,,CLASSROOM OF THE ELITE 4TH SEASON:\NSECOND YEAR, FIRST SEMESTER
Dialogue: 0,0:03:37.53,0:03:41.03,tanda,,0000,0000,0000,,#3 TEKAD SEORANG PEMIMPIN
Dialogue: 0,0:03:42.37,0:03:43.74,tanda,,0000,0000,0000,,K.K MEMANGGIL
Dialogue: 0,0:00:00.81,0:00:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu hal yang sekarang kutahu.
Dialogue: 0,0:00:03.69,0:00:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi cuma Hosen yang tidak ikut\Nmengatrol poin.
Dialogue: 0,0:00:07.70,0:00:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:00:08.99,0:00:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira, Hosen hanya akan menyetujui\Npartner dengan poin yang tinggi,
Dialogue: 0,0:00:14.41,0:00:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena dia sendiri yang\Ningin menyedot poin itu.
Dialogue: 0,0:00:19.08,0:00:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau seperti itu,\Nsiswa dengan prestasi di bawah
Dialogue: 0,0:00:22.50,0:00:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya boleh kalau\Ndipasangkan secara lebih aktif.
Dialogue: 0,0:00:25.34,0:00:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga itu.
Dialogue: 0,0:00:27.09,0:00:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Poin penalti saat dapat nilai merah\Nitu tidak biasa diabaikan.
Dialogue: 0,0:00:31.39,0:00:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar dugaan Kak Ayanokoji.
Dialogue: 0,0:00:34.31,0:00:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen tidak menerima\Nimbalan apa pun dari teman sekelas.
Dialogue: 0,0:00:38.14,0:00:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya menguasai kelas\Ndan memanfaatkan aturan, ya.
Dialogue: 0,0:00:43.48,0:00:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu siswa yang melanggar itu\Nakan dikucilkan dari kelas.
Dialogue: 0,0:00:49.32,0:00:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, hubungan yang dijalin dengan poin,
Dialogue: 0,0:00:52.36,0:00:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya akan terhubung dengan poin.
Dialogue: 0,0:00:54.95,0:00:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membangun kepercayaan yang setara.
Dialogue: 0,0:00:59.83,0:01:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku bicara dengan Hosen.
Dialogue: 0,0:01:02.67,0:01:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang pun aku siap\Nuntuk membicarakannya.
Dialogue: 0,0:01:05.54,0:01:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, biar coba saya telepon.
Dialogue: 0,0:01:12.64,0:01:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tersambung dengan Hosen.
Dialogue: 0,0:01:15.35,0:01:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, aku sudah dengar dari Nanase.
Dialogue: 0,0:01:18.81,0:01:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, aku ingin bicara\Nsecara langsung.
Dialogue: 0,0:01:22.39,0:01:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:01:23.85,0:01:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu maksudnya, kami bahkan tidak\Ndiizinkan melakukan nego, begitu?
Dialogue: 0,0:01:27.94,0:01:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang begitu.
Dialogue: 0,0:01:29.82,0:01:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Hosen...
Dialogue: 0,0:01:30.86,0:01:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik, woi!
Dialogue: 0,0:01:32.15,0:01:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kamu punya kuasa apa?
Dialogue: 0,0:01:34.45,0:01:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa kubunuh.
Dialogue: 0,0:01:36.41,0:01:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak berniat dibunuh, tapi tolong\Ntemuilah Kak Horikita dulu.
Dialogue: 0,0:01:40.96,0:01:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyiapkan poin saja tidak becus,
Dialogue: 0,0:01:44.08,0:01:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan berani hubungi aku lagi.
Dialogue: 0,0:01:48.63,0:01:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mohon maaf!
Dialogue: 0,0:01:50.80,0:01:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkat kepalamu.
Dialogue: 0,0:01:52.51,0:01:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat berterima kasih\Nkamu sudah mau membantu.
Dialogue: 0,0:01:56.05,0:01:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:01:57.64,0:02:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya apa yang ingin kulakukan\Nsudah sampai ke Hosen.
Dialogue: 0,0:02:02.06,0:02:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah cukup untuk sekarang.
Dialogue: 0,0:03:43.74,0:03:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama banget angkat teleponnya!
Dialogue: 0,0:03:45.41,0:03:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:03:46.66,0:03:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu soal yang kuminta tadi pagi\Napa sudah kamu cari tahu?
Dialogue: 0,0:03:50.54,0:03:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kucari tahu makanya kutelepon.
Dialogue: 0,0:03:54.55,0:03:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut pegawai toko,\Nsejak April tahun ini baru terjual satu.
Dialogue: 0,0:04:00.18,0:04:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang ada siswa baru\Nyang kelihatan mau beli.
Dialogue: 0,0:04:03.68,0:04:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi waktu selesai dihitung di kasir,\Ndia panggil anak lain
Dialogue: 0,0:04:07.18,0:04:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus kelihatannya tidak jadi beli.
Dialogue: 0,0:04:09.77,0:04:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa yang mau mengembalikannya\Nsetelah beli?
Dialogue: 0,0:04:12.82,0:04:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu katanya tidak tahu.
Dialogue: 0,0:04:15.40,0:04:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, sih, cewek.
Dialogue: 0,0:04:19.02,0:04:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa informasi dariku berguna?
Dialogue: 0,0:04:21.62,0:04:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, lebih dari yang kuduga.
Dialogue: 0,0:04:26.45,0:04:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kan memang bisa diandalkan.
Dialogue: 0,0:04:29.04,0:04:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus berterima kasih, lo.
Dialogue: 0,0:04:31.17,0:04:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berterima kasih.
Dialogue: 0,0:04:33.21,0:04:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Napa belajarmu sendiri lancar, Kei?
Dialogue: 0,0:04:37.13,0:04:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kalau itu...
Dialogue: 0,0:04:39.30,0:04:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:04:41.01,0:04:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berangkat belajar kelompok pun\Nkamu enggak ada, Kiyotaka.
Dialogue: 0,0:04:44.43,0:04:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada aku, kamu bakal giat belajar?
Dialogue: 0,0:04:47.22,0:04:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu jelas, di depan pacarku\Ntentu aku pengin giat berusaha.
Dialogue: 0,0:04:52.06,0:04:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, besok mau ke kamarku?
Dialogue: 0,0:04:55.57,0:04:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh main ke sana?!
Dialogue: 0,0:04:57.69,0:05:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan buat main, tapi belajar.
Dialogue: 0,0:05:03.37,0:05:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koenji.
Dialogue: 0,0:05:05.12,0:05:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelihatannya belum dapat pasangan, ya.
Dialogue: 0,0:05:08.58,0:05:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?
Dialogue: 0,0:05:10.87,0:05:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun pasangannya,
Dialogue: 0,0:05:12.96,0:05:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendapat nilai di atas batas kelulusan\Nitu perkara mudah buatku.
Dialogue: 0,0:05:18.21,0:05:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, boleh tidak kalau aku\Nyang menentukan siapa pasanganmu?
Dialogue: 0,0:05:22.47,0:05:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menolak.
Dialogue: 0,0:05:24.35,0:05:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:05:26.72,0:05:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku adalah diriku.
Dialogue: 0,0:05:29.77,0:05:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah puas?
Dialogue: 0,0:05:31.48,0:05:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:33.52,0:05:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya untuk sekarang.
Dialogue: 0,0:05:42.40,0:05:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf sudah menunggu lama.
Dialogue: 0,0:05:45.82,0:05:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:05:47.83,0:05:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya coba negosiasi agar Hosen\Nmau ikut datang.
Dialogue: 0,0:05:52.16,0:05:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya tidak berhasil.
Dialogue: 0,0:05:54.54,0:05:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kami memang harus\Nmenemuinya secara paksa.
Dialogue: 0,0:05:58.88,0:06:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada titik temunya kalau terus begini.
Dialogue: 0,0:06:01.51,0:06:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, maukah mendengar usulan saya?
Dialogue: 0,0:06:05.26,0:06:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila dengan cara main Hosen,
Dialogue: 0,0:06:07.30,0:06:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami menilai tidak akan mampu\Nbertahan di pertempuran ke depannya.
Dialogue: 0,0:06:10.89,0:06:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang langkah terakhir,
Dialogue: 0,0:06:12.60,0:06:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi saya rasa sebaiknya\Nsaya saja yang memimpin Kelas 1-D.
Dialogue: 0,0:06:16.27,0:06:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu serius?
Dialogue: 0,0:06:18.23,0:06:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu usulan yang\Nterlalu membebani buatmu?
Dialogue: 0,0:06:23.90,0:06:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah.
Dialogue: 0,0:06:25.36,0:06:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak ingin kehilangan
Dialogue: 0,0:06:27.12,0:06:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepercayaan dan kesempatan\Nyang Kak Horikita berikan.
Dialogue: 0,0:06:31.04,0:06:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Hosen dan kamu berselisih.
Dialogue: 0,0:06:33.71,0:06:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya jadi satu,\Nkelas malah bisa terbelah jadi dua.
Dialogue: 0,0:06:37.58,0:06:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membiarkan itu.
Dialogue: 0,0:06:39.96,0:06:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang benar.
Dialogue: 0,0:06:42.01,0:06:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua masalah Kelas 1-D akan selesai\Njika berkubu dengan Hosen.
Dialogue: 0,0:06:47.72,0:06:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bisa biarkan aku membantu\Nuntuk mengubah cara pikir dia?
Dialogue: 0,0:06:52.93,0:06:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pertaruhan yang berbahaya.
Dialogue: 0,0:06:54.89,0:06:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekadku sudah bulat.
Dialogue: 0,0:06:57.06,0:07:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi, aku yakin kemungkinan\Nkerja samanya cukup tinggi.
Dialogue: 0,0:07:03.24,0:07:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah diperlakukan seburuk itu?
Dialogue: 0,0:07:06.16,0:07:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuanggap sebagai\Nniat baik yang ditutupi.
Dialogue: 0,0:07:08.87,0:07:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya untuk sekarang.
Dialogue: 0,0:07:13.00,0:07:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya saya juga berpikir\Nmembujuk Hosen adalah solusi terbaik.
Dialogue: 0,0:07:18.83,0:07:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika boleh dipercayakan pada saya,\Nsebelum hari Minggu besok lusa.
Dialogue: 0,0:07:23.34,0:07:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen pasti akan saya bawa\Nke depan Kak Horikita.
Dialogue: 0,0:07:27.51,0:07:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya padamu.
Dialogue: 0,0:07:29.97,0:07:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunggu besok lusa.
Dialogue: 0,0:07:32.43,0:07:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, akan saya pastikan.
Dialogue: 0,0:07:36.19,0:07:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:37.64,0:07:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya belajar kelompok.
Dialogue: 0,0:07:39.73,0:07:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembicaraannya sudah selesai,\Nsisanya bisa kuserahkan padamu?
Dialogue: 0,0:07:43.53,0:07:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:07:45.99,0:07:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Horikita sibuk sekali, ya?
Dialogue: 0,0:07:49.57,0:07:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang itu juga termasuk\Ndalam menyatukan kelas.
Dialogue: 0,0:07:54.41,0:07:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Horikita adalah pemimpin kelas.
Dialogue: 0,0:07:57.92,0:08:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, kalau Kak Ayanokoji...
Dialogue: 0,0:08:01.79,0:08:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang seperti apa?
Dialogue: 0,0:08:04.84,0:08:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji adalah orang\Nyang jahat dan licik.
Dialogue: 0,0:08:11.35,0:08:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang saya pikirkan.
Dialogue: 0,0:08:14.06,0:08:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:08:16.64,0:08:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:08:18.81,0:08:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia siswa dari White Room.
Dialogue: 0,0:08:21.36,0:08:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan mengamati diriku dari dekat.
Dialogue: 0,0:08:26.07,0:08:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membuktikan dengan jelas\Nbahwa dia yang lebih unggul.
Dialogue: 0,0:08:29.66,0:08:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, untuk meyakinkan pria itu.
Dialogue: 0,0:08:34.65,0:08:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, untuk kalimat yang dia pakai\Nsebagai sesama siswa White Room.
Dialogue: 0,0:08:39.62,0:08:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang terasa beda.
Dialogue: 0,0:08:42.96,0:08:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tolong lupakan saja.
Dialogue: 0,0:08:46.00,0:08:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Kak, saya izin permisi.
Dialogue: 0,0:08:49.42,0:08:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase.
Dialogue: 0,0:08:51.01,0:08:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tahu soal poin proteksi?
Dialogue: 0,0:08:54.64,0:08:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum, saya baru dengar.
Dialogue: 0,0:08:56.60,0:08:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sistem yang saat dipakai
Dialogue: 0,0:08:58.39,0:09:01.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menganulir jika\Ndikeluarkan dari sekolah.
Dialogue: 0,0:09:03.23,0:09:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa menceritakan itu pada saya?
Dialogue: 0,0:09:05.98,0:09:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balasan karena sudah membantu.
Dialogue: 0,0:09:08.57,0:09:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:09:20.50,0:09:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang keluar masuk jam segini,
Dialogue: 0,0:09:22.87,0:09:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku hati-hati biar tidak dilihat, lo.
Dialogue: 0,0:09:25.38,0:09:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, langsung saja kita mulai.
Dialogue: 0,0:09:27.71,0:09:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!\NApa enggak mau apa dulu, gitu?
Dialogue: 0,0:09:31.13,0:09:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau akademismu tidak bermasalah,
Dialogue: 0,0:09:33.51,0:09:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kutemani mengobrol\Nsebanyak yang kau mau.
Dialogue: 0,0:09:39.22,0:09:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begini.
Dialogue: 0,0:09:40.77,0:09:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah peringkat akademis Kiyotaka itu C?
Dialogue: 0,0:09:43.60,0:09:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aslinya kamu bisa dapat\Nlebih tinggi, kan?
Dialogue: 0,0:09:46.52,0:09:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya begitu.
Dialogue: 0,0:09:48.53,0:09:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tutupi sampai sebegitunya?
Dialogue: 0,0:09:51.32,0:09:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin menarik perhatian.
Dialogue: 0,0:09:54.78,0:09:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, misalkan kamu serius,\Nbakal dapat nilai berapa?
Dialogue: 0,0:09:58.91,0:10:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat ratus.
Dialogue: 0,0:10:00.37,0:10:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumpah?!
Dialogue: 0,0:10:01.50,0:10:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat ratus, tuh...
Dialogue: 0,0:10:03.33,0:10:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kelas satu, tidak ada soal\Nyang tidak bisa kuselesaikan.
Dialogue: 0,0:10:07.67,0:10:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:10:09.67,0:10:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah paham, ayo kita mulai.
Dialogue: 0,0:10:14.93,0:10:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ke sini.
Dialogue: 0,0:10:17.60,0:10:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajari sambil duduk di sebelahku, dong.
Dialogue: 0,0:10:39.53,0:10:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:41.62,0:10:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, apa?
Dialogue: 0,0:10:43.66,0:10:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, sih, rambut.
Dialogue: 0,0:10:45.83,0:10:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut warna merah!\NSudah begitu panjang!
Dialogue: 0,0:10:48.63,0:10:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari mana pun ini rambut cewek!
Dialogue: 0,0:10:58.05,0:11:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cewek rambut merah tidak kukenal!
Dialogue: 0,0:11:03.18,0:11:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?!
Dialogue: 0,0:11:04.14,0:11:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ini kamar Kak Ayanokoji, kan?
Dialogue: 0,0:11:09.94,0:11:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ini aku.
Dialogue: 0,0:11:11.57,0:11:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa?
Dialogue: 0,0:11:12.86,0:11:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada tamu ternyata.
Dialogue: 0,0:11:15.61,0:11:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku datang nanti saja?
Dialogue: 0,0:11:18.99,0:11:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tidak masalah.\NMasuk saja.
Dialogue: 0,0:11:24.62,0:11:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izin ganggu.
Dialogue: 0,0:11:26.50,0:11:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku Amasawa Ichika.
Dialogue: 0,0:11:29.38,0:11:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:11:30.84,0:11:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak kelas, kan?\NBoleh tahu namanya?
Dialogue: 0,0:11:34.59,0:11:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karuizawa Kei.
Dialogue: 0,0:11:36.26,0:11:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Karuizawa, ya.
Dialogue: 0,0:11:38.30,0:11:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jangan-jangan pacar Kak Ayanokoji?
Dialogue: 0,0:11:41.64,0:11:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hubungannya sama kamu, kan?!
Dialogue: 0,0:11:44.14,0:11:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula apa hubunganmu sama Kiyotaka?
Dialogue: 0,0:11:48.19,0:11:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabannya tunggu sebentar, ya.
Dialogue: 0,0:11:50.86,0:11:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku mungkin\Nketinggalan sesuatu di sini.
Dialogue: 0,0:11:54.32,0:11:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karet rambut kesukaanku.
Dialogue: 0,0:11:56.53,0:11:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:11:57.82,0:12:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah pernah\Nkulepas sekali di sini.
Dialogue: 0,0:12:00.91,0:12:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin jatuh ke suatu tempat.
Dialogue: 0,0:12:05.41,0:12:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, suasananya malah\Nterasa agak mesum, nih.
Dialogue: 0,0:12:10.21,0:12:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar coba kucarikan.
Dialogue: 0,0:12:12.50,0:12:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jawab pertanyaanku yang tadi.
Dialogue: 0,0:12:16.67,0:12:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, sebaiknya kujawab seperti apa, ya?
Dialogue: 0,0:12:20.39,0:12:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji adalah...\Njuru masakku?
Dialogue: 0,0:12:24.18,0:12:26.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!\NApa itu?!
Dialogue: 0,0:12:26.39,0:12:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Partner untuk Sudo.
Dialogue: 0,0:12:28.52,0:12:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memasak untuk dia sekali.
Dialogue: 0,0:12:30.56,0:12:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa cari partner buat Sudo\Nmalah jadi masak?!
Dialogue: 0,0:12:35.73,0:12:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal kucoba lihat ke dapur,\NKakak cari di situ saja, ya.
Dialogue: 0,0:12:40.53,0:12:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:42.03,0:12:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:12:43.49,0:12:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, kan.
Dialogue: 0,0:12:44.74,0:12:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kuajak ke sini sekali\Nlalu kubuatkan masakan.
Dialogue: 0,0:12:47.33,0:12:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma itu.
Dialogue: 0,0:12:48.08,0:12:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?
Dialogue: 0,0:12:50.00,0:12:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupastikan ke...
Dialogue: 0,0:12:51.42,0:12:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:12:53.50,0:12:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya jatuh ke sela-sela kulkas.
Dialogue: 0,0:12:56.88,0:13:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku ganggu suasana,\Njadi pulang dulu, ya.
Dialogue: 0,0:13:00.09,0:13:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sedang agak sibuk.
Dialogue: 0,0:13:02.39,0:13:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak.
Dialogue: 0,0:13:03.26,0:13:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu aku permisi.
Dialogue: 0,0:13:05.60,0:13:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kakak ternyata pemain juga.
Dialogue: 0,0:13:08.73,0:13:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka punya pacar semanis ini.
Dialogue: 0,0:13:13.27,0:13:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti nanti itu, ya.
Dialogue: 0,0:13:15.36,0:13:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak enak kalau berduaan saja\Nsaat minta dibuatkan masakan.
Dialogue: 0,0:13:19.03,0:13:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja itu!
Dialogue: 0,0:13:20.90,0:13:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu ke depannya,\NKak Karuizawa ikut makan juga.
Dialogue: 0,0:13:25.28,0:13:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, selamat tinggal.
Dialogue: 0,0:13:28.04,0:13:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya dia sudah jadi adik kelas dan\Nkenalan yang manis padamu, Kiyotaka, hmph!
Dialogue: 0,0:13:39.51,0:13:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Partner yang sudah terbentuk saat ini\Nada 105 pasangan.
Dialogue: 0,0:13:43.51,0:13:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir 70 persen.
Dialogue: 0,0:13:45.55,0:13:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potensi ada siswa White Room\Ndi jumlah yang tersisa lumayan tinggi.
Dialogue: 0,0:13:51.39,0:13:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:13:53.48,0:13:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Ayanokoji ternyata.
Dialogue: 0,0:13:56.23,0:13:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakayanagi.
Dialogue: 0,0:13:58.40,0:14:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini kelihatan sedang aktif\Nmendekati siswa kelas satu, ya.
Dialogue: 0,0:14:03.61,0:14:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma membantu Horikita\Nmencarikan partner untuk Sudo dan Ike.
Dialogue: 0,0:14:08.95,0:14:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:14:10.58,0:14:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, apa betul hanya itu saja?
Dialogue: 0,0:14:14.12,0:14:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:14:15.71,0:14:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengeluarkan Ayanokoji dari sekolah,
Dialogue: 0,0:14:18.67,0:14:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kupikir apakah ada asasin\Nyang dikirim dari White Room atau tidak.
Dialogue: 0,0:14:23.68,0:14:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah khawatir soal itu.
Dialogue: 0,0:14:25.89,0:14:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa beri tahu alasannya?
Dialogue: 0,0:14:28.81,0:14:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bermaksud untuk membuang\Ncara pikirku selama ini.
Dialogue: 0,0:14:32.64,0:14:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke depannya aku tidak berniat\Nmenahan diri lagi.
Dialogue: 0,0:14:37.31,0:14:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:40.23,0:14:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau masih belum mendapat partner,\Napa perlu kuberi bantuan?
Dialogue: 0,0:14:46.11,0:14:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik hati sekali dirimu.
Dialogue: 0,0:14:48.87,0:14:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak terima kasih.
Dialogue: 0,0:14:50.87,0:14:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah keputusanku tidak bisa dipercaya?
Dialogue: 0,0:14:54.62,0:14:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengakui kemampuanmu.
Dialogue: 0,0:14:57.38,0:15:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, akan kutentukan sendiri nasibku.
Dialogue: 0,0:15:01.55,0:15:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:15:03.26,0:15:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sebaiknya kuhentikan\Nketidaksopananku.
Dialogue: 0,0:15:06.26,0:15:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuperhatikan dari jauh bagaimana\NAyanokoji akan maju bertarung.
Dialogue: 0,0:15:16.65,0:15:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, bisa minta waktunya sebentar?
Dialogue: 0,0:15:20.32,0:15:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Kak Ayanokoji dari Kelas 2-D, kan?
Dialogue: 0,0:15:25.70,0:15:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Utomiya dari Kelas 1-C.
Dialogue: 0,0:15:28.66,0:15:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia, namanya Tsubaki.
Dialogue: 0,0:15:30.83,0:15:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bicara sebentar soal partner?
Dialogue: 0,0:15:36.16,0:15:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kalau langsung intinya,\Nbisa dengar cerita kami?
Dialogue: 0,0:15:41.09,0:15:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka berutang atau memberi utang.
Dialogue: 0,0:15:45.76,0:15:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku ingin menjalin\Nhubungan tanpa drama ke depannya.
Dialogue: 0,0:15:49.47,0:15:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh tanya sesuatu?
Dialogue: 0,0:15:52.14,0:15:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:15:53.60,0:15:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum aku, kalian sudah\Ntanya ke berapa orang?
Dialogue: 0,0:15:57.56,0:16:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sebenarnya Kak Ayanokoji\Norang pertama.
Dialogue: 0,0:16:02.98,0:16:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan saja aku jadi yang pertama?
Dialogue: 0,0:16:05.82,0:16:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kebetulan, tapi ada alasannya.
Dialogue: 0,0:16:08.66,0:16:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kakak kelas dari kelas A atau C.
Dialogue: 0,0:16:11.20,0:16:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi akan dimintai poin pribadi.
Dialogue: 0,0:16:14.45,0:16:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu, logikanya masuk.
Dialogue: 0,0:16:17.83,0:16:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum menentukan partner,\Ntapi sudah dapat kandidatnya.
Dialogue: 0,0:16:23.84,0:16:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sedang berunding\Napa bisa berpasangan atau tidak.
Dialogue: 0,0:16:27.67,0:16:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begitu.
Dialogue: 0,0:16:31.14,0:16:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat kalau begitu.
Dialogue: 0,0:16:34.60,0:16:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya lebih cepat\Nkalau cari orang lain.
Dialogue: 0,0:16:38.02,0:16:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:39.52,0:16:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya ini kontakku.
Dialogue: 0,0:16:43.11,0:16:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini seenaknya.
Dialogue: 0,0:16:45.32,0:16:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau misalkan aku ditolak,\Nmungkin aku akan bicara ke kalian lagi.
Dialogue: 0,0:16:50.36,0:16:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:16:52.24,0:16:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Tsubaki.
Dialogue: 0,0:16:54.99,0:16:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsubaki Sakurako dan Utomiya Riku.
Dialogue: 0,0:16:59.00,0:17:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kuingat lagi baik-baik.
Dialogue: 0,0:17:03.29,0:17:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Karuizawa,\Ntiba-tiba memanggil kemari.
Dialogue: 0,0:17:06.96,0:17:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sama sekali enggak masalah.
Dialogue: 0,0:17:09.47,0:17:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mau bahas apa?
Dialogue: 0,0:17:12.51,0:17:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karuizawa kenapa putus sama Hirata?
Dialogue: 0,0:17:17.14,0:17:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku tidak bilang alasannya, ya?
Dialogue: 0,0:17:19.59,0:17:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang dengar,\Ntapi masih belum puas rasanya.
Dialogue: 0,0:17:24.56,0:17:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu putus bukannya\Nkarena ada tujuan lain?!
Dialogue: 0,0:17:29.69,0:17:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa maksudnya itu?
Dialogue: 0,0:17:31.65,0:17:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang paham sama omonganmu.
Dialogue: 0,0:17:34.16,0:17:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karuizawa itu pacaran sama Ayanokoji?
Dialogue: 0,0:17:39.00,0:17:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:40.08,0:17:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar begitu, ya?!
Dialogue: 0,0:17:42.08,0:17:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan.
Dialogue: 0,0:17:43.50,0:17:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa jadi begitu?
Dialogue: 0,0:17:45.67,0:17:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kamu incar sejak aku minta tolong\Nbuat bisa dekat sama Ayanokoji?!
Dialogue: 0,0:17:51.30,0:17:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah suka sejak sebelum itu?!
Dialogue: 0,0:17:54.05,0:17:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu dulu, dong.
Dialogue: 0,0:17:55.85,0:17:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab yang jujur!
Dialogue: 0,0:17:57.68,0:18:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, aku tidak bisa menganggap\NKaruizawa sebagai teman lagi.
Dialogue: 0,0:18:03.73,0:18:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu...
Dialogue: 0,0:18:08.11,0:18:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kamu bilang, aku...
Dialogue: 0,0:18:11.74,0:18:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku pacaran sama Kiyotaka.
Dialogue: 0,0:18:15.45,0:18:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah memanggilnya dengan "Kiyotaka", ya.
Dialogue: 0,0:18:19.16,0:18:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mulai pacaran akhir libur musim semi,\Nbetulan belum lama ini.
Dialogue: 0,0:18:23.75,0:18:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang paling ingin kutahu itu\Nsejak kamu suka padanya?!
Dialogue: 0,0:18:28.71,0:18:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak tahu.
Dialogue: 0,0:18:30.21,0:18:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sudah tertarik sama Kiyotaka\Nsaat kamu konsultasi padaku.
Dialogue: 0,0:18:37.10,0:18:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:18:38.56,0:18:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu marah, ya?
Dialogue: 0,0:18:42.52,0:18:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merasa tenang juga tidak.
Dialogue: 0,0:18:44.77,0:18:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu perasaanku tapi di belakang...
Dialogue: 0,0:18:47.31,0:18:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya cuma ditolak Ayanokoji.
Dialogue: 0,0:18:50.82,0:18:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak berhak buat marah, kan?
Dialogue: 0,0:18:53.99,0:18:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi!
Dialogue: 0,0:19:07.33,0:19:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini kita impas,\Nbagaimana, Karuizawa?
Dialogue: 0,0:19:13.05,0:19:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sekali lagi?
Dialogue: 0,0:19:15.63,0:19:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, kalau itu rasanya tidak berani.
Dialogue: 0,0:19:19.97,0:19:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau justru, maaf sudah menampar.
Dialogue: 0,0:19:23.35,0:19:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku juga minta maaf.
Dialogue: 0,0:19:26.52,0:19:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah suka dengan\Norang yang sama denganmu.
Dialogue: 0,0:19:31.07,0:19:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi?\NAyanokoji memang keren.
Dialogue: 0,0:19:35.03,0:19:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh lebih ganteng dari Hirata.
Dialogue: 0,0:19:40.16,0:19:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh?!
Dialogue: 0,0:19:41.16,0:19:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa, Karuizawa?
Dialogue: 0,0:19:44.62,0:19:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku betulan minta maaf!
Dialogue: 0,0:19:54.09,0:19:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggu malam.
Dialogue: 0,0:19:56.17,0:20:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu yang ditentukan Nanase untuk\Nbernegosiasi dengan Hosen sudah tiba.
Dialogue: 0,0:20:02.68,0:20:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo!
Dialogue: 0,0:20:04.72,0:20:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar buat tesmu lancar?
Dialogue: 0,0:20:07.44,0:20:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas, dong.
Dialogue: 0,0:20:09.23,0:20:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf saja, kali ini setidaknya\Naku berniat dapat nilai 250.
Dialogue: 0,0:20:14.78,0:20:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya sekarang jadi suka belajar.
Dialogue: 0,0:20:17.49,0:20:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya suka.
Dialogue: 0,0:20:20.11,0:20:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, disemangati Suzune saja\Nbikin semangatku naik.
Dialogue: 0,0:20:26.96,0:20:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya, Ayanokoji.
Dialogue: 0,0:20:29.12,0:20:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekarang aku menyatakan perasaan...
Dialogue: 0,0:20:32.50,0:20:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa menurutmu Suzune akan bilang oke?
Dialogue: 0,0:20:36.38,0:20:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, sih.
Dialogue: 0,0:20:39.09,0:20:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ya.
Dialogue: 0,0:20:42.43,0:20:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini sudah merepotkan Suzu...
Dialogue: 0,0:20:45.06,0:20:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:20:45.93,0:20:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah seberapa banyak\Nmerepotkan anak kelas.
Dialogue: 0,0:20:49.10,0:20:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau sekarang kerja keras pun, aku\Ntidak kepikiran itu akan hilang begitu saja.
Dialogue: 0,0:20:54.73,0:20:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dua tahun dari sekarang,\Nakan kukembangkan kelebihanku
Dialogue: 0,0:20:59.36,0:21:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sedikit demi sedikit\Nmenghilangkan kekuranganku.
Dialogue: 0,0:21:02.16,0:21:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, saat kelulusan nanti\Naku pasti akan berguna untuk kelas.
Dialogue: 0,0:21:07.79,0:21:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah berjuang\Ndan berjasa untuk kelas,
Dialogue: 0,0:21:11.71,0:21:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Horikita masih\Ntidak berpaling padamu, bagaimana?
Dialogue: 0,0:21:15.30,0:21:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu akan benci belajar?
Dialogue: 0,0:21:17.55,0:21:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku bakal pengin mati\Ndan pukul orang.
Dialogue: 0,0:21:21.63,0:21:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ya, kalau begitu\NSuzune bakal kecewa, kan?
Dialogue: 0,0:21:27.77,0:21:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau kalau begitu.
Dialogue: 0,0:21:34.02,0:21:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:21:35.44,0:21:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo berangkat.
Dialogue: 0,0:21:38.82,0:21:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya.
Dialogue: 0,0:21:41.70,0:21:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen si anak kelas\Nsatu tidak tahu diri itu.
Dialogue: 0,0:21:44.95,0:21:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin bisa kita jadikan teman?
Dialogue: 0,0:21:47.33,0:21:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dirasa tidak,\Nkita tidak akan ada di sini.
Dialogue: 0,0:21:51.21,0:21:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudo, jangan bilang yang tidak perlu, ya.
Dialogue: 0,0:21:54.96,0:21:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, tahu.
Dialogue: 0,0:21:57.21,0:21:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu, Kak.
Dialogue: 0,0:21:59.26,0:22:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir, Nanase.
