Dialogue: 0,0:02:07.23,0:02:09.97,sign,,0000,0000,0000,,"#12 DI UJUNG PERMUSUHAN"
Dialogue: 0,0:00:05.61,0:00:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area yang ditunjuk selanjutnya E2,\Nrute terpendek adalah lewat gunung.
Dialogue: 0,0:00:11.07,0:00:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih aman kalau pilih memutar.
Dialogue: 0,0:00:13.49,0:00:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya pribadi ingin lewat gunung.
Dialogue: 0,0:00:16.87,0:00:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena yang lain akan pilih jalan memutar,
Dialogue: 0,0:00:19.46,0:00:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah sebaiknya mengincar\Nurutan tiba pertama di sini?
Dialogue: 0,0:00:24.09,0:00:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:00:25.34,0:00:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Nanase siap untuk itu,\Nakan kutemani lewat gunung.
Dialogue: 0,0:00:29.63,0:00:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:00:42.56,0:00:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:01:52.38,0:01:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:04.81,0:02:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji.
Dialogue: 0,0:02:07.23,0:02:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin saya tanyakan.
Dialogue: 0,0:02:09.97,0:02:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak tadi pagi?
Dialogue: 0,0:02:11.78,0:02:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sejak minta ikut bersamaku,\Nsepertinya kau sudah memikirkan sesuatu.
Dialogue: 0,0:02:17.49,0:02:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi memang ketahuan, ya.
Dialogue: 0,0:02:21.04,0:02:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan saya minta maaf akan satu hal.
Dialogue: 0,0:02:24.25,0:02:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini Kakak tidak akan bisa\Nsampai ke area yang ditunjuk selanjutnya.
Dialogue: 0,0:02:30.46,0:02:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan saya meminta lewat gunung,\Nadalah untuk menggiring Kakak ke tempat ini.
Dialogue: 0,0:02:35.89,0:02:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekolah ini Kakak telah punya banyak teman,
Dialogue: 0,0:02:39.39,0:02:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendapat banyak kepercayaan.
Dialogue: 0,0:02:41.72,0:02:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu meski secara perlahan,
Dialogue: 0,0:02:43.64,0:02:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan jelas menunjukkan\Nkemampuan sebenarnya Kakak.
Dialogue: 0,0:02:46.65,0:02:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi Kak Ayanokoji bukanlah seseorang\Nyang pantas berada di sekolah ini.
Dialogue: 0,0:02:52.03,0:02:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa katakan apa alasannya?
Dialogue: 0,0:02:54.90,0:03:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena Anda berasal dari White Room.
Dialogue: 0,0:03:00.16,0:03:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa Kakak sudah bisa menebak.
Dialogue: 0,0:03:02.87,0:03:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya masuk ke sekolah ini atas perintah\NKepala Yayasan Sementara Tsukishiro.
Dialogue: 0,0:03:07.79,0:03:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perintah yang dimaksud adalah\Nmengeluarkan Kak Ayanokoji dari sekolah.
Dialogue: 0,0:03:13.55,0:03:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini saya akan membuat Kakak terluka,\Nhingga alarm menyala.
Dialogue: 0,0:03:18.14,0:03:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu akan didiskualifikasi oleh guru yang tiba\Nsehingga dikeluarkan dari sekolah.
Dialogue: 0,0:03:23.06,0:03:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kekalahan di sini\Nartinya akan dikeluarkan, ya.
Dialogue: 0,0:03:28.94,0:03:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, pilihan yang bisa\Nkuambil di sini hanya ada satu.
Dialogue: 0,0:03:34.57,0:03:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tindak kekerasan pada saya akan dianggap\Nkedua pihak berkelahi lalu dikeluarkan, lo.
Dialogue: 0,0:03:40.20,0:03:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja begitu.
Dialogue: 0,0:03:44.08,0:03:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan saya mulai.
Dialogue: 0,0:03:48.71,0:03:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu pukulan dulu.
Dialogue: 0,0:03:50.71,0:03:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelelahan, ya?\NAtau malah ragu?
Dialogue: 0,0:03:53.88,0:03:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potensimu seharusnya lebih tinggi lagi.
Dialogue: 0,0:03:56.97,0:04:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap bisa mengalahkan saya\Ntanpa panik membalas, begitu?
Dialogue: 0,0:04:03.43,0:04:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pukulan kedua.
Dialogue: 0,0:04:05.14,0:04:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau yang ini juga kena langsung,\Nseharusnya sudah selesai.
Dialogue: 0,0:04:08.69,0:04:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebas saja kalau mau\Nmembahas keunggulan Kakak.
Dialogue: 0,0:04:11.19,0:04:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak akan bisa menang\Nkalau tidak membalas.
Dialogue: 0,0:04:14.07,0:04:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kubalas sekalipun,\Ntetap tidak bisa menang, kan?
Dialogue: 0,0:04:16.86,0:04:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:04:18.45,0:04:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang mau bagaimana?
Dialogue: 0,0:04:20.45,0:04:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang kupikirkan.
Dialogue: 0,0:04:22.02,0:04:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga bisa dapat jawabannya\Nlagi masih kuat berdiri!
Dialogue: 0,0:04:28.54,0:04:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekadar kuberi tahu,\Nini pukulan yang ketiga.
Dialogue: 0,0:04:32.29,0:04:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Kakak punya kemampuan\Nsesuai kabar angin.
Dialogue: 0,0:04:38.30,0:04:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tahu apa yang Kakak incar.
Dialogue: 0,0:04:41.43,0:04:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencoba mematahkan hati saya\Ntanpa melukai, ya.
Dialogue: 0,0:04:45.81,0:04:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, Kakak sepertinya bukan lawan\Nyang bisa dikalahkan di pertarungan biasa.
Dialogue: 0,0:04:50.89,0:04:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Saya" pasti tidak akan bisa menang.
Dialogue: 0,0:04:59.36,0:05:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghentikanmu di sini.
Dialogue: 0,0:05:04.28,0:05:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau siapa?
Dialogue: 0,0:05:06.12,0:05:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menghentikanmu di sini,\Naku kembali dari tempat itu.
Dialogue: 0,0:05:11.75,0:05:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat itu?
Dialogue: 0,0:05:13.17,0:05:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tempat gelap itu.
Dialogue: 0,0:05:15.96,0:05:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah kembali dari sana.
Dialogue: 0,0:05:18.63,0:05:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi yang sangat wajar.
Dialogue: 0,0:05:20.72,0:05:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang belum pernah\Nbertemu langsung denganmu.
Dialogue: 0,0:05:24.93,0:05:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukanlah Nanase.
Dialogue: 0,0:05:27.14,0:05:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang sedang berdiri di sini\Nadalah Matsuo Eiichiro.
Dialogue: 0,0:05:32.39,0:05:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matsuo Eiichiro?
Dialogue: 0,0:05:35.15,0:05:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra dari pria yang dibunuh ayahandamu.
Dialogue: 0,0:05:39.28,0:05:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badan ini hanyalah barang pinjaman.
Dialogue: 0,0:05:41.45,0:05:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sekarang ada di depan matamu\Nuntuk mengalahkanmu.
Dialogue: 0,0:05:45.87,0:05:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang pinjaman?
Dialogue: 0,0:05:47.37,0:05:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guyonan yang menarik.
Dialogue: 0,0:05:49.62,0:05:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengalahkanmu maka aku ada di sini.
Dialogue: 0,0:05:53.87,0:05:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada di sini!
Dialogue: 0,0:06:07.26,0:06:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti!
Dialogue: 0,0:06:08.26,0:06:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan mengalahkanmu!
Dialogue: 0,0:06:11.77,0:06:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kukalahkan!
Dialogue: 0,0:06:14.02,0:06:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu harus menerima balasannya!
Dialogue: 0,0:06:23.53,0:06:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat paham apa yang\Nmau kau sampaikan.
Dialogue: 0,0:06:26.49,0:06:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase.
Dialogue: 0,0:06:27.78,0:06:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidaklah berkepribadian ganda,\Nataupun dirasuki persona lain.
Dialogue: 0,0:06:33.41,0:06:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kalau begitu bagaimana\Ncaranya menjelaskan keberadaanku ini?!
Dialogue: 0,0:06:38.09,0:06:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lebih dari kepribadian lain yang\Ndibuat secara paksa di dalam hati.
Dialogue: 0,0:06:44.38,0:06:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sengaja memakai "saya" dan "aku"\Nsecara terpisah untuk mensugesti diri sendiri.
Dialogue: 0,0:06:49.26,0:06:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini adalah bukti terkuat\Ndari aku adalah diriku sendiri!
Dialogue: 0,0:06:53.98,0:06:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebatas menunjukkan fluktuasi dari\Ncakupan kemampuan yang sudah kau miliki.
Dialogue: 0,0:06:59.65,0:07:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan, aku...\NAku adalah Matsuo!
Dialogue: 0,0:07:04.90,0:07:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun itu benar, maka seharusnya\Nkau tidak perlu gusar.
Dialogue: 0,0:07:10.66,0:07:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya memakai pergantian kata ganti diri
Dialogue: 0,0:07:13.04,0:07:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai pemicu untuk beralih\Nke diri yang lebih agresif.
Dialogue: 0,0:07:15.79,0:07:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:07:16.79,0:07:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin percaya bahwa kepribadian Matsuo\Nmerasuki dirimu.
Dialogue: 0,0:07:20.25,0:07:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kau sendiri tidak memercayai itu.
Dialogue: 0,0:07:23.92,0:07:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:07:25.47,0:07:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:07:26.88,0:07:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sedikit lagi...\NPadahal tinggal sedikit lagi!
Dialogue: 0,0:07:31.05,0:07:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kemampuan selevel dirimu,\Nmeski diulang terus sampai mati,
Dialogue: 0,0:07:35.39,0:07:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan bisa mengenaiku.
Dialogue: 0,0:07:38.35,0:07:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang ingin\Nmengeluarkanku dari sekolah,
Dialogue: 0,0:07:41.61,0:07:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pura-pura jadi korban yang diserang\Nadalah yang terbaik.
Dialogue: 0,0:07:44.94,0:07:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal baju yang kau kenakan berantakan,\Nitu sudah cukup untuk menyudutkanku.
Dialogue: 0,0:07:51.07,0:07:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... Aku...
Dialogue: 0,0:08:05.34,0:08:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal laporan yang kuterima\Ndari radio panggil tadi pagi.
Dialogue: 0,0:08:09.22,0:08:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bakal menjelaskan maksudnya, kan?
Dialogue: 0,0:08:11.97,0:08:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yagami.
Dialogue: 0,0:08:13.35,0:08:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini Kak Ayanokoji sedang\Ndiikuti oleh Nanase.
Dialogue: 0,0:08:18.48,0:08:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, Nanase dari Kelas 1-D itu?
Dialogue: 0,0:08:21.98,0:08:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase berniat membuat Kak Ayanokoji\Nmembalas dan terlibat dalam tindak kekerasan,
Dialogue: 0,0:08:27.03,0:08:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar dikeluarkan dari sekolah.
Dialogue: 0,0:08:29.36,0:08:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mau menyuruhku lapor ke sekolah\Nkalau Nanase dihajar Ayanokoji?
Dialogue: 0,0:08:34.87,0:08:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah akan kita rekam\Nkejadian di lokasi dengan tablet.
Dialogue: 0,0:08:39.75,0:08:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku ingin minta tolong Kak Kushida\Nuntuk melakukan perekaman itu.
Dialogue: 0,0:08:44.50,0:08:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha? Kenapa harus aku?
Dialogue: 0,0:08:47.21,0:08:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak kau saja sendiri?
Dialogue: 0,0:08:49.26,0:08:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini anak cowok.
Dialogue: 0,0:08:51.22,0:08:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku lihat di lokasi, bisa jadi dicurigai\Nkarena dianggap seharusnya melerai.
Dialogue: 0,0:08:56.01,0:08:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi Kak Kushida adalah gadis yang lemah.
Dialogue: 0,0:08:59.10,0:09:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ketakutan dan tidak bisa apa-apa,
Dialogue: 0,0:09:01.23,0:09:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak menyalakan tablet untuk\Nsetidaknya menyimpan bukti.
Dialogue: 0,0:09:06.28,0:09:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang bersedia, kan, Kak Kushida?
Dialogue: 0,0:09:09.15,0:09:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tidak mau harus kulakukan, bukan.
Dialogue: 0,0:09:14.95,0:09:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua kelihatannya\Nsudah benar-benar berhenti.
Dialogue: 0,0:09:18.66,0:09:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jalan perlahan ke arah barat laut.
Dialogue: 0,0:09:22.17,0:09:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa juga untuk merekam.
Dialogue: 0,0:09:26.04,0:09:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shh.
Dialogue: 0,0:09:27.38,0:09:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berisik.
Dialogue: 0,0:09:29.42,0:09:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti repot kalau sampai ketahuan\Nsama Kak Ayanokoji dan Nanase.
Dialogue: 0,0:09:35.05,0:09:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kushida.
Dialogue: 0,0:09:41.44,0:09:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, kenapa Amasawa bisa ada di sini?
Dialogue: 0,0:09:46.02,0:09:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kebetulan lewat, aku lihat Kak Kushida\Nsedang sembunyi-sembunyi.
Dialogue: 0,0:09:51.07,0:09:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sembunyi-sembunyi, kok.
Dialogue: 0,0:09:53.41,0:09:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma...
Dialogue: 0,0:09:54.53,0:09:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar, bisa dibilang\Naku sedang jalan-jalan sendiri.
Dialogue: 0,0:10:01.96,0:10:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini?!
Dialogue: 0,0:10:03.46,0:10:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sendirian datang jauh-jauh\Nke dalam gunung begini,
Dialogue: 0,0:10:06.46,0:10:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sambil memeriksa ke sana-kemari,\Nmemangnya mau apa?
Dialogue: 0,0:10:10.59,0:10:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa maksudmu?
Dialogue: 0,0:10:12.97,0:10:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amasawa, bilang apa kamu ini?!
Dialogue: 0,0:10:16.22,0:10:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran sampai kapan\Nbisa terus memakai topeng itu.
Dialogue: 0,0:10:21.85,0:10:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hentikan!
Dialogue: 0,0:10:23.35,0:10:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan berhenti.
Dialogue: 0,0:10:27.86,0:10:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu paham apa yang sudah\Nkau lakukan itu?!
Dialogue: 0,0:10:31.65,0:10:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah kuusahakan agak lembut, lo.
Dialogue: 0,0:10:34.91,0:10:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sakit, tidak sakit, kok.
Dialogue: 0,0:10:38.16,0:10:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?!\NAku tidak paham maksudnya!
Dialogue: 0,0:10:40.49,0:10:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:42.16,0:10:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin baru bisa mengerti kalau\Nkuberi bogem mentah sekali lagi.
Dialogue: 0,0:10:49.75,0:10:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, ya.
Dialogue: 0,0:10:51.38,0:10:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tahu-tahu ditampar,\Njadinya kelepasan.
Dialogue: 0,0:10:54.76,0:10:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, masih mau berlagak sok imut coba.
Dialogue: 0,0:10:57.01,0:11:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham betul soal Kak Kushida, lo.
Dialogue: 0,0:11:01.14,0:11:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cewek busuk yang yakin betul\Nkalau dirinya manis.
Dialogue: 0,0:11:06.35,0:11:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba jual air mata ke pihak sekolah\Npura-pura jadi korban yang dianiaya?
Dialogue: 0,0:11:10.44,0:11:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, bisa saja membuatku\Nterancam dikeluarkan sekolah.
Dialogue: 0,0:11:14.53,0:11:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, akan kuberi hadiah kenang-kenangan.
Dialogue: 0,0:11:17.61,0:11:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua rahasia kelam masa SMP yang coba\NKakak sembunyikan mati-matian
Dialogue: 0,0:11:21.37,0:11:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kubongkar untuk\Nmerampas tempatmu berada.
Dialogue: 0,0:11:24.62,0:11:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?!
Dialogue: 0,0:11:26.54,0:11:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kenapa bisa tahu rahasia itu?"
Dialogue: 0,0:11:28.83,0:11:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tanya ke Kak Ayanokoji, ya?!"
Dialogue: 0,0:11:31.67,0:11:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa terbaca dari mukamu.
Dialogue: 0,0:11:33.55,0:11:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu salah.
Dialogue: 0,0:11:35.17,0:11:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah sosok spesial.
Dialogue: 0,0:11:38.01,0:11:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi segalanya sudah kuketahui.
Dialogue: 0,0:11:40.68,0:11:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?!
Dialogue: 0,0:11:42.39,0:11:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini sebenarnya apa?!
Dialogue: 0,0:11:44.93,0:11:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini hanya...
Dialogue: 0,0:11:48.15,0:11:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang untuk menyelamatkan Kak Ayanokoji.
Dialogue: 0,0:11:51.36,0:11:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:11:52.44,0:11:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu siapa yang meminta,\Ntapi Kak Kushida ini sudah dimanfaatkan.
Dialogue: 0,0:11:57.95,0:12:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin Kak Ayanokoji tidak sadar\Nkalau dibuntuti amatiran sepertimu.
Dialogue: 0,0:12:04.04,0:12:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hubungannya denganmu, kan?!
Dialogue: 0,0:12:06.20,0:12:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya ada, banyak lagi.
Dialogue: 0,0:12:08.42,0:12:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bagiku, Kak Ayanokoji\Nadalah orang yang spesial.
Dialogue: 0,0:12:13.71,0:12:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:12:15.13,0:12:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu? Kau suka padanya?
Dialogue: 0,0:12:17.84,0:12:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan disamakan dengan perasaan\Nrendahan begitu, dong.
Dialogue: 0,0:12:21.51,0:12:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan suka, tapi lebih ke cinta?
Dialogue: 0,0:12:24.26,0:12:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jauh lebih tinggi dari itu rasanya.
Dialogue: 0,0:12:29.44,0:12:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah perasaan yang melebihi cinta!
Dialogue: 0,0:12:33.23,0:12:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih begitu.
Dialogue: 0,0:12:35.23,0:12:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut saja dan putar balik turun dari gunung.
Dialogue: 0,0:12:39.86,0:12:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda.
Dialogue: 0,0:12:42.78,0:12:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan apa pun demi memegang\Nkelemahan Ayanokoji dan mengeluarkannya!
Dialogue: 0,0:12:46.66,0:12:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya aku tidak akan membiarkan\Norang luar sepertimu melakukan itu.
Dialogue: 0,0:12:52.63,0:12:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan!
Dialogue: 0,0:12:53.96,0:12:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kulepas...
Dialogue: 0,0:12:55.75,0:12:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini jelas bukan orang biasa!
Dialogue: 0,0:12:59.51,0:13:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu lebih manis dari siapa pun.
Dialogue: 0,0:13:02.30,0:13:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu lebih unggul dari siapa pun.
Dialogue: 0,0:13:04.93,0:13:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kushida ini pokoknya suka sekali\Nsama diri Kakak sendiri, ya.
Dialogue: 0,0:13:10.77,0:13:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin mengungguli orang lain, jadinya\Nmati-matian mau memegang rahasianya.
Dialogue: 0,0:13:16.36,0:13:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dirinya sendiri benci\Nkalau direndahkan seperti itu.
Dialogue: 0,0:13:20.53,0:13:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan memaafkan orang\Nyang tahu rahasiamu.
Dialogue: 0,0:13:24.37,0:13:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak benci sifatmu yang sinting itu.
Dialogue: 0,0:13:28.50,0:13:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti tidak akan kalah!
Dialogue: 0,0:13:31.41,0:13:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi,\Ntidak akan menyerah sampai akhir!
Dialogue: 0,0:13:35.00,0:13:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang sedang kujadikan mainan, tuh.
Dialogue: 0,0:13:38.88,0:13:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak perlu panik.
Dialogue: 0,0:13:41.26,0:13:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup singkirkan sekalian dirimu.
Dialogue: 0,0:13:43.64,0:13:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kusingkirkan semua yang mengganggu.
Dialogue: 0,0:13:46.18,0:13:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah cukup begitu saja.
Dialogue: 0,0:13:48.39,0:13:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih dari perkiraanku.
Dialogue: 0,0:13:50.77,0:13:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kushida ini memang cewek busuk,\Ntapi aku kagum dengan kekuatan mentalmu.
Dialogue: 0,0:13:56.94,0:14:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada ketakutan padaku,\Njustru kebencian yang meluap-luap.
Dialogue: 0,0:14:01.57,0:14:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya ditujukan padaku.
Dialogue: 0,0:14:03.99,0:14:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi juga pada orang yang\Nmemberi tahu rahasiamu.
Dialogue: 0,0:14:07.74,0:14:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan saja.
Dialogue: 0,0:14:08.99,0:14:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berdiri terbalik pun\Ntidak akan bisa mengalahkanku.
Dialogue: 0,0:14:12.66,0:14:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah.
Dialogue: 0,0:14:18.34,0:14:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu tidak akan cocok untukku, lo.
Dialogue: 0,0:14:21.05,0:14:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya rahasia yang bakal\Nbikin resah kalau dipegang.
Dialogue: 0,0:14:24.59,0:14:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mungkin harus kubilang\Nitu Kak Ayanokoji.
Dialogue: 0,0:14:28.10,0:14:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya untuk berurusan dengan dia,
Dialogue: 0,0:14:30.35,0:14:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama susahnya dengan\Nmengalahkanku, iya, kan?
Dialogue: 0,0:14:36.02,0:14:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, ya.
Dialogue: 0,0:14:37.36,0:14:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus ketemu sama Kak Ayanokoji.
Dialogue: 0,0:14:39.98,0:14:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau memberi tahu soalku?
Dialogue: 0,0:14:42.03,0:14:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan.
Dialogue: 0,0:14:44.61,0:14:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mungkin saja,
Dialogue: 0,0:14:47.03,0:14:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kelanjutan yang diinginkan\NKak Kushida sedang menunggu.
Dialogue: 0,0:14:51.12,0:14:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji bisa saja akan\Ndikeluarkan dari sekolah.
Dialogue: 0,0:14:55.82,0:14:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau benar, selanjutnya kau\Nyang akan kubuat hancur.
Dialogue: 0,0:14:59.42,0:15:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menghancurkanmu.
Dialogue: 0,0:15:02.63,0:15:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kushida ini, hasil pertarungannya\Nsudah bisa ditebak sejak awal.
Dialogue: 0,0:15:13.48,0:15:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku ini, sedang apa...
Dialogue: 0,0:15:26.86,0:15:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang rusak, ya?
Dialogue: 0,0:15:28.99,0:15:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:30.03,0:15:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa saat jatuh dan kena batu tadi.
Dialogue: 0,0:15:33.08,0:15:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kembali minta ganti sendirian\Napa enggak bahaya?
Dialogue: 0,0:15:37.00,0:15:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuacanya juga lagi jelek.
Dialogue: 0,0:15:39.21,0:15:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham kalau bahaya.
Dialogue: 0,0:15:41.13,0:15:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untuk mengejar posisi atas,\Nkurasa tidak boleh menyia-nyiakan satu poin pun.
Dialogue: 0,0:15:46.34,0:15:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita baru bergabung\Ndan menambah batas anggota grup.
Dialogue: 0,0:15:50.76,0:15:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:15:51.97,0:15:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau jamnya tidak berfungsi\Njelas tidak ada pilihan lain.
Dialogue: 0,0:15:55.35,0:15:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan memaksakan diri, ya.
Dialogue: 0,0:15:57.35,0:16:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tidak lucu kalau sampai terluka\Nlalu gugur.
Dialogue: 0,0:16:03.36,0:16:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa aku ini?
Dialogue: 0,0:16:06.90,0:16:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang dilakukan\Nrasanya selalu keliru.
Dialogue: 0,0:16:09.91,0:16:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada pergerakan dari\Npihak pengajar yang mengawasi kita.
Dialogue: 0,0:16:14.12,0:16:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama kewaspadaan Mashima\Nrasanya begitu tinggi.
Dialogue: 0,0:16:17.46,0:16:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Yayasan Sementara dan Pak Shiba?
Dialogue: 0,0:16:20.21,0:16:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu wali dari Kelas 2-D, Bu Chabashira,\Nmemeriksa seluruh riwayat yang ada.
Dialogue: 0,0:16:25.46,0:16:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik Bu Chabashira atau Pak Mashima,
Dialogue: 0,0:16:29.26,0:16:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak salah lagi rasanya kalau\Ndianggap punya koneksi ke Ayanokoji.
Dialogue: 0,0:16:33.72,0:16:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Riwayat yang ada sudah kami ubah,\Njadi seharusnya tidak akan terlacak.
Dialogue: 0,0:16:38.85,0:16:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:16:40.69,0:16:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, karena sudah ada kemungkinan\Nmendapat suatu petunjuk,
Dialogue: 0,0:16:45.98,0:16:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau tidak mau kita harus\Nbenar-benar memojokkannya.
Dialogue: 0,0:16:49.49,0:16:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, apa bisa semudah itu\Ndikeluarkan dari sekolah?
Dialogue: 0,0:16:53.78,0:16:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawannya dari White Room...
Dialogue: 0,0:16:54.99,0:16:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang memang mudah terkecoh oleh status.
Dialogue: 0,0:16:58.62,0:17:00.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}White Room?
Dialogue: 0,0:17:00.37,0:17:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila dia bisa bertahan hingga hari terakhir,
Dialogue: 0,0:17:03.29,0:17:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari kita habisi di area I2 seperti rencana.
Dialogue: 0,0:17:19.23,0:17:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, kau adalah\NIchinose Honami dari Kelas 2-C, ya.
Dialogue: 0,0:17:25.73,0:17:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya bukan kau sudah\Ndengar sampai mana.
Dialogue: 0,0:17:30.24,0:17:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya harus segera disingkirkan.
Dialogue: 0,0:17:34.87,0:17:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak sedikit terburu-buru, Pak Shiba.
Dialogue: 0,0:17:38.95,0:17:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mohon maaf.
Dialogue: 0,0:17:41.50,0:17:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Saya tidak dengar apa-apa.
Dialogue: 0,0:17:44.79,0:17:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang dewasa harus selalu bertindak\Ndengan pertimbangan yang terburuk.
Dialogue: 0,0:17:50.34,0:17:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus melanjutkan segalanya
Dialogue: 0,0:17:52.80,0:17:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan asumsi bahwa dirimu\Nsudah mendengar semuanya.
Dialogue: 0,0:17:58.56,0:18:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bahasan tadi sampai bocor ke luar,
Dialogue: 0,0:18:01.02,0:18:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka kami akan berada dalam\Nmasalah yang sangat besar.
Dialogue: 0,0:18:05.52,0:18:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu dibuat gugur dengan disiksa\Nhingga ingatanmu hilang?
Dialogue: 0,0:18:13.49,0:18:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti itu.
Dialogue: 0,0:18:14.95,0:18:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pihak yang melindungi sekolah,\Nmana bisa mengatakannya.
Dialogue: 0,0:18:20.12,0:18:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri juga tidak ingin\Nambil tindakan yang kasar.
Dialogue: 0,0:18:25.54,0:18:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situlah kuberi usulan.
Dialogue: 0,0:18:27.84,0:18:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membocorkan ini pada seseorang,\Nsatu grup yang terdiri dari siswa Kelas 2-C
Dialogue: 0,0:18:34.18,0:18:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan dibuat terdiskualifikasi.
Dialogue: 0,0:18:37.93,0:18:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu dipilih orang-orang yang tidak punya\Ncukup poin pribadi untuk penyelamatan.
Dialogue: 0,0:18:45.06,0:18:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelabuhan tinggal terus maju ke sana.
Dialogue: 0,0:18:48.27,0:18:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana pergi.
Dialogue: 0,0:18:58.78,0:19:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa kalau yang harus kau lindungi\Nadalah teman-teman sekelasmu.
Dialogue: 0,0:19:08.25,0:19:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa beri tahu alasanmu mengincarku?
Dialogue: 0,0:19:12.88,0:19:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya, ingin membalas dendam Matsuo Eiichiro.
Dialogue: 0,0:19:17.80,0:19:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu masuk ke sekolah ini.
Dialogue: 0,0:19:21.06,0:19:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari TK hingga lulus SMP.
Dialogue: 0,0:19:23.89,0:19:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya selalu bersama Eiichiro\Nyang satu tahun lebih tua.
Dialogue: 0,0:19:30.06,0:19:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang selalu lebih mahir dari saya\Ndalam melakukan segala hal,
Dialogue: 0,0:19:33.74,0:19:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah panutan yang selalu saya kagumi.
Dialogue: 0,0:19:36.20,0:19:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ayahnya...
Dialogue: 0,0:19:39.24,0:19:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah membantu proses\NKak Ayanokoji lari dari White Room,
Dialogue: 0,0:19:43.70,0:19:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penghidupan mereka pun dirampas.
Dialogue: 0,0:19:48.17,0:19:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski itu menutup jalannya\Nmelanjutkan sekolah...
Dialogue: 0,0:19:51.04,0:19:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski membuatnya kehilangan ayah...
Dialogue: 0,0:19:53.09,0:19:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Eiichiro tetap melihat ke depan\Ndan tersenyum pantang menyerah.
Dialogue: 0,0:19:59.64,0:20:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah tidak bisa bertemu,\Ntidak akan bisa menyampaikan perasaan lagi.
Dialogue: 0,0:20:04.02,0:20:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu kau bilang begitu, ya.
Dialogue: 0,0:20:05.85,0:20:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu beliau muncul di hadapan saya\Nyang seperti itu.
Dialogue: 0,0:20:10.10,0:20:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukishiro, ya.
Dialogue: 0,0:20:12.48,0:20:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya diberi tahu penyebab\Nhidupnya jadi berantakan
Dialogue: 0,0:20:16.19,0:20:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diurus untuk masuk sekolah kemari.
Dialogue: 0,0:20:19.61,0:20:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil mengeluarkan\NKak Ayanokoji dari sekolah,
Dialogue: 0,0:20:22.83,0:20:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya dijanjikan untuk dipertemukan\Ndengan ayah Kakak.
Dialogue: 0,0:20:26.83,0:20:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang salah bukanlah Kakak.
Dialogue: 0,0:20:29.25,0:20:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, amarah yang tidak tersalurkan ini.
Dialogue: 0,0:20:32.88,0:20:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekecewaan ini rasanya ingin\Ndilampiaskan pada seseorang.
Dialogue: 0,0:20:38.01,0:20:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya yang tidak bisa menjalankan\Nperintah Kepala Yayasan Sementara,
Dialogue: 0,0:20:42.10,0:20:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah tidak punya alasan\Nuntuk tetap di sini.
Dialogue: 0,0:20:45.10,0:20:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau keluar dari sekolah, begitu?
Dialogue: 0,0:20:47.73,0:20:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu yang bisa saya lakukan\Nuntuk menebus kesalahan.
Dialogue: 0,0:20:55.07,0:20:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu merasa malu.
Dialogue: 0,0:20:57.44,0:21:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah melakukan segalanya\Nuntuk mencoba membalas dendam.
Dialogue: 0,0:21:03.37,0:21:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi aku juga punya alasan\Nuntuk tidak boleh kalah.
Dialogue: 0,0:21:06.54,0:21:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku terus tinggal di sekolah ini,
Dialogue: 0,0:21:09.87,0:21:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa itulah satu-satunya\Nbentuk perlawanan pada pria itu.
Dialogue: 0,0:21:15.88,0:21:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh meminta sesuatu padamu,
Dialogue: 0,0:21:18.51,0:21:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong bantu aku dan\Njangan pergi dari sekolah ini.
Dialogue: 0,0:21:21.38,0:21:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai dikeluarkan oleh Tsukishiro,
Dialogue: 0,0:21:24.30,0:21:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu juga berarti mengkhianati perasaan Matsuo\Nyang membantuku melarikan diri.
Dialogue: 0,0:21:29.39,0:21:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi apa yang harus saya lakukan\Nadalah sebaliknya, begitu?
Dialogue: 0,0:21:37.28,0:21:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kau membantuku?
Dialogue: 0,0:21:39.90,0:21:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya akan berjanji.
Dialogue: 0,0:21:44.03,0:21:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifat asliku dan pria itu sama.
Dialogue: 0,0:21:47.49,0:21:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada juga bagian yang berbeda.
Dialogue: 0,0:21:50.54,0:21:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu tidak akan pernah mengulurkan tangan\Npada pecundang yang tidak berguna.
Dialogue: 0,0:21:56.04,0:21:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar berguna atau tidak\Nitu tidak ada hubungannya.
Dialogue: 0,0:21:59.71,0:22:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski nantinya dibuang setelah digunakan,
Dialogue: 0,0:22:02.80,0:22:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terpenting adalah memanfaatkannya\Nsebaik mungkin agar berguna.
