Dialogue: 0,0:02:53.96,0:02:54.63,tanda,,0000,0000,0000,,#5 PRIA SEHARGA 20 JUTA
Dialogue: 0,0:00:02.86,0:00:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tenangkan dulu dirimu.
Dialogue: 0,0:00:05.40,0:00:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tenang.
Dialogue: 0,0:00:07.32,0:00:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tidak bisa terima,\Ndia dapat nilai sempurna yang mustahil itu.
Dialogue: 0,0:00:12.16,0:00:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang soalnya sesulit itu?
Dialogue: 0,0:00:14.79,0:00:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma sulit!
Dialogue: 0,0:00:17.04,0:00:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jauh melewati materi\Nyang dipelajari di SMA.
Dialogue: 0,0:00:20.46,0:00:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, itu seharusnya soal\Nyang tidak bisa dipecahkan.
Dialogue: 0,0:00:23.67,0:00:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma kepikiran saja, nih.
Dialogue: 0,0:00:25.38,0:00:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin Ayanokoji berbuat curang?
Dialogue: 0,0:00:28.34,0:00:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja itu!
Dialogue: 0,0:00:29.80,0:00:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbuat curang buat tahu\Njawabannya duluan misalnya.
Dialogue: 0,0:00:33.18,0:00:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:00:34.47,0:00:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada bukti apa pun kalau\NAyanokoji curang, kan?
Dialogue: 0,0:00:37.81,0:00:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan seenaknya memutuskan\Ndi belakang yang bersangkutan!
Dialogue: 0,0:00:40.19,0:00:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih, Ken?
Dialogue: 0,0:00:41.56,0:00:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau berpihak sama Ayanokoji?
Dialogue: 0,0:00:44.44,0:00:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:00:46.19,0:00:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir, kemungkinan dia dapat nilai sempurna\Ndari kemampuannya sendiri itu lebih tinggi.
Dialogue: 0,0:00:50.78,0:00:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuannya sendiri?
Dialogue: 0,0:00:51.99,0:00:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademik Ayanokoji di OAA\Nlebih rendah dariku, lo.
Dialogue: 0,0:00:55.08,0:00:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, bisa jadi itu karena\Ndia tidak serius seperti Koenji.
Dialogue: 0,0:00:59.71,0:01:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tenang dulu, teman-teman.
Dialogue: 0,0:01:01.83,0:01:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang masih banyak yang belum jelas.
Dialogue: 0,0:01:04.42,0:01:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, bukankah sudah mau\Nwaktunya ekskul buat Sudo?
Dialogue: 0,0:01:07.59,0:01:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya.
Dialogue: 0,0:01:09.05,0:01:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibilang benar juga.
Dialogue: 0,0:01:11.05,0:01:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pergi dulu.
Dialogue: 0,0:01:12.72,0:01:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kutitipkan Keisei pada kalian.
Dialogue: 0,0:01:14.76,0:01:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sampai nanti, Miyachi.
Dialogue: 0,0:01:29.53,0:01:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:39.35,0:02:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:50.86,0:02:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obrolan dengan Kepala Yayasan Sementara\Nsepertinya sudah selesai.
Dialogue: 0,0:02:54.64,0:02:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, begitulah.
Dialogue: 0,0:02:56.45,0:03:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini dirimu\Njadi sedikit terkenal.
Dialogue: 0,0:03:00.53,0:03:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak merasa senang.
Dialogue: 0,0:03:02.70,0:03:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma bisa saya anggap sebagai\Nlangkah yang perlu diambil.
Dialogue: 0,0:03:05.75,0:03:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mau bagaimana kamu menjelaskannya\Npada teman-teman sekelas?
Dialogue: 0,0:03:09.84,0:03:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru akan saya tangani sekarang.
Dialogue: 0,0:03:12.55,0:03:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah untuk dihujani pertanyaan.
Dialogue: 0,0:03:19.80,0:03:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, bagaimana bisa dapat\Nnilai sempurna di matematika?!
Dialogue: 0,0:03:24.98,0:03:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ichinose atau Sakayanagi saja\Ntidak dapat nilai sempurna.
Dialogue: 0,0:03:28.31,0:03:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kamu sendiri di angkatan kita.
Dialogue: 0,0:03:30.94,0:03:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai itu...
Dialogue: 0,0:03:33.19,0:03:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menjelaskan.
Dialogue: 0,0:03:35.28,0:03:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini tanya ke Kiyotaka.
Dialogue: 0,0:03:37.61,0:03:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:03:38.66,0:03:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang punya jawaban\Natas pertanyaanmu itu aku.
Dialogue: 0,0:03:43.12,0:03:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:03:44.37,0:03:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat setelah masuk sekolah,
Dialogue: 0,0:03:45.70,0:03:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tahu kalau tempat dudukku\Nbersebelahan dengan Ayanokoji, kan?
Dialogue: 0,0:03:49.79,0:03:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi bicara dengannya,
Dialogue: 0,0:03:51.71,0:03:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa sengaja aku tahu kalau\Nsebenarnya dia sangat jago belajar.
Dialogue: 0,0:03:55.05,0:03:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:03:56.17,0:04:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak masuk sekolah, bukankah nilai Kiyotaka\Nselalu saja sesuai rata-rata.
Dialogue: 0,0:04:00.89,0:04:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena aku yang memintanya\Nagar sengaja menahan diri.
Dialogue: 0,0:04:05.22,0:04:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa melakukan itu?
Dialogue: 0,0:04:06.98,0:04:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyimpan daya tempur\Nuntuk situasi tidak terduga.
Dialogue: 0,0:04:09.73,0:04:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin akan kusebut kartu as.
Dialogue: 0,0:04:12.11,0:04:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja sulit dipercaya.
Dialogue: 0,0:04:14.40,0:04:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sejak awal dia mendapat nilai tinggi,
Dialogue: 0,0:04:16.94,0:04:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah itu lebih menguntungkan kelas?
Dialogue: 0,0:04:19.36,0:04:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa berprestasi kelak akan\Ndianggap pengganggu oleh kelas lain.
Dialogue: 0,0:04:23.95,0:04:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak aneh jika ada yang bergerak\Nuntuk menyingkirkannya.
Dialogue: 0,0:04:27.12,0:04:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu dia nanti bisa saja diincar?
Dialogue: 0,0:04:29.46,0:04:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:30.71,0:04:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyatanya dalam pemungutan suara kelas,
Dialogue: 0,0:04:32.96,0:04:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji sempat terancam dikeluarkan\Nkarena strategi Sakayanagi.
Dialogue: 0,0:04:38.22,0:04:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kenapa malah\Nditunjukkan sekarang?
Dialogue: 0,0:04:41.80,0:04:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam satu tahun ini, kekompakan kita\Nsebagai Kelas 2-D meningkat pesat
Dialogue: 0,0:04:45.97,0:04:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga mulai bisa mengambil\Nkeputusan yang tepat.
Dialogue: 0,0:04:48.89,0:04:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sekarang ada\Nyang mengincar Ayanokoji,
Dialogue: 0,0:04:52.35,0:04:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa bekerja sama untuk melindunginya.
Dialogue: 0,0:04:55.27,0:04:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu kuputuskan untuk\Nmembuka kemampuannya
Dialogue: 0,0:04:58.40,0:05:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mulai meningkatkan\Nkemampuan kita secara keseluruhan.
Dialogue: 0,0:05:01.11,0:05:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengerti strategi Horikita.
Dialogue: 0,0:05:03.62,0:05:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kiyotaka cuma sangat jago di matematika?
Dialogue: 0,0:05:07.49,0:05:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu belum bisa kujawab di tahap ini.
Dialogue: 0,0:05:11.04,0:05:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga,\Ndengan menutupi kebenarannya
Dialogue: 0,0:05:14.04,0:05:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia akan terus jadi\Npengganggu bagi kelas lain.
Dialogue: 0,0:05:17.30,0:05:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:05:18.63,0:05:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham apa yang ingin\Ndisampaikan Horikita.
Dialogue: 0,0:05:21.72,0:05:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, lawan yang status detailnya\Ntidak terlihat akan terasa menakutkan.
Dialogue: 0,0:05:26.47,0:05:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi kita sebagai teman sekelasnya\Njuga tidak tahu.
Dialogue: 0,0:05:29.48,0:05:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ditelusuri informasinya pun\Ntidak akan berguna.
Dialogue: 0,0:05:32.27,0:05:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:33.31,0:05:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik membuat lawan menganggap\Ndia sebagai sosok tidak diketahui.
Dialogue: 0,0:05:37.40,0:05:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas lain saat ini pasti sangat kaget.
Dialogue: 0,0:05:41.36,0:05:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah rahasia di balik nilai sempurna\NAyanokoji pada mata pelajaran matematika.
Dialogue: 0,0:05:45.62,0:05:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuat kalian kaget.
Dialogue: 0,0:05:50.37,0:05:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pulang tanpa bilang apa-apa?
Dialogue: 0,0:05:53.37,0:05:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kejadian hari ini\Ntidak pernah kau ceritakan?
Dialogue: 0,0:05:56.25,0:06:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa artinya kami juga tidak bisa dipercaya?
Dialogue: 0,0:06:00.01,0:06:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat paham kenapa\NKeisei merasa murka.
Dialogue: 0,0:06:03.13,0:06:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamulah yang paling peduli
Dialogue: 0,0:06:05.80,0:06:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan mengajakku masuk grup\Ndan mengajariku.
Dialogue: 0,0:06:08.85,0:06:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf.
Dialogue: 0,0:06:10.93,0:06:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku masih marah.
Dialogue: 0,0:06:13.64,0:06:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada yang bisa kumengerti karena\Nkita sudah lama di grup yang sama.
Dialogue: 0,0:06:19.40,0:06:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kiyotaka itu bukan orang jahat.
Dialogue: 0,0:06:23.07,0:06:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Keisei.
Dialogue: 0,0:06:25.66,0:06:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana kalau kalian\Nbersalaman sebagai tanda baikan?
Dialogue: 0,0:06:30.74,0:06:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga itu salaman!
Dialogue: 0,0:06:35.04,0:06:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah baikan, ya.
Dialogue: 0,0:06:37.38,0:06:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk merayakan kalian berbaikan.
Dialogue: 0,0:06:39.67,0:06:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ekskul Miyachi selesai,\Nbagaimana kalau kumpul di Mal Keyaki?
Dialogue: 0,0:06:45.34,0:06:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Ayanokoji!
Dialogue: 0,0:06:48.10,0:06:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang menunggu seseorang?
Dialogue: 0,0:06:50.01,0:06:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ini ada acara makan\Nbersama teman-teman.
Dialogue: 0,0:06:52.77,0:06:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya, aku lihat, lo.
Dialogue: 0,0:06:54.73,0:06:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil tesmu hebat sekali.
Dialogue: 0,0:06:57.06,0:06:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melihat OAA tahun lalu,
Dialogue: 0,0:06:59.65,0:07:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak punya kemampuan\Nuntuk dapat nilai sempurna.
Dialogue: 0,0:07:02.40,0:07:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merahasiakan kalau aku bisa matematika
Dialogue: 0,0:07:05.40,0:07:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah hasil berunding dengan teman-teman.
Dialogue: 0,0:07:08.16,0:07:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi selama ini hanya disembunyikan, ya?
Dialogue: 0,0:07:12.12,0:07:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu lawan yang\Nlebih sulit dari bayangan.
Dialogue: 0,0:07:15.00,0:07:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanzaki.
Dialogue: 0,0:07:16.46,0:07:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kurang baik kalau disebut begitu.
Dialogue: 0,0:07:19.33,0:07:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar kalau tiap kelas punya\Nstrateginya masing-masing.
Dialogue: 0,0:07:23.80,0:07:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji bukanlah musuh.
Dialogue: 0,0:07:26.55,0:07:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aliansi kita sudah bubar.
Dialogue: 0,0:07:29.05,0:07:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi kalau Kelas 2-D\Nadalah musuh kita.
Dialogue: 0,0:07:32.81,0:07:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan diteruskan lagi, Kanzaki.
Dialogue: 0,0:07:36.48,0:07:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, sepertinya aku memang\Nsedikit hilang kontrol.
Dialogue: 0,0:07:40.40,0:07:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku duluan.
Dialogue: 0,0:07:42.52,0:07:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:07:44.15,0:07:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi kami memang tidak baik,\Njadi Kanzaki tidak bisa santai.
Dialogue: 0,0:07:48.82,0:07:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kami jadi kelas C, kan?
Dialogue: 0,0:07:52.45,0:07:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalau harus membuang sifat naif.
Dialogue: 0,0:07:55.66,0:07:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:07:57.08,0:08:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih ingat apa yang dulu kukatakan?
Dialogue: 0,0:08:00.08,0:08:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:01.21,0:08:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Teruslah maju bersama teman sekelasmu."
Dialogue: 0,0:08:04.84,0:08:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke depannya, bisa jadi akan muncul\Nsiswa yang tidak puas padamu
Dialogue: 0,0:08:08.51,0:08:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau bahkan akan berkhianat pada kelas.
Dialogue: 0,0:08:13.60,0:08:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi,\Npercayalah pada temanmu
Dialogue: 0,0:08:16.60,0:08:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan teruslah bertarung dengan\Nprioritas melindungi mereka.
Dialogue: 0,0:08:20.23,0:08:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:08:21.69,0:08:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan melindungi teman sekelasku.
Dialogue: 0,0:08:24.86,0:08:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau misalkan tiba saatnya untuk\Nseseorang harus keluar dari kelas.
Dialogue: 0,0:08:30.03,0:08:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, akulah yang harus\Npertama kali keluar.
Dialogue: 0,0:08:33.83,0:08:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tenang mendengarnya, tapi ada satu\Nyang tidak bisa kuterima.
Dialogue: 0,0:08:38.46,0:08:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terima?
Dialogue: 0,0:08:40.12,0:08:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membiarkanmu dikeluarkan.
Dialogue: 0,0:08:44.63,0:08:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu...
Dialogue: 0,0:08:46.67,0:08:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, aku pasti akan bertahan.
Dialogue: 0,0:08:51.13,0:08:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku pergi dulu, ya!
Dialogue: 0,0:08:53.51,0:08:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:59.14,0:09:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin kelihatannya repot sekali.
Dialogue: 0,0:09:01.98,0:09:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu menyembunyikan kalau\Njago belajar karena idenya Suzune?
Dialogue: 0,0:09:06.19,0:09:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:07.69,0:09:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengar dari Yosuke.\NKatanya kamu membelaku, ya?
Dialogue: 0,0:09:12.66,0:09:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada membela, aku cuma memberi fakta.
Dialogue: 0,0:09:16.62,0:09:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa jago berkelahi\Njuga salah satu rahasiamu?
Dialogue: 0,0:09:20.87,0:09:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak paham maksudnya.
Dialogue: 0,0:09:23.29,0:09:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pura-pura bodoh!
Dialogue: 0,0:09:25.04,0:09:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mampu menahan Hosen dengan\Nkekuatan setara atau bahkan lebih besar darinya!
Dialogue: 0,0:09:28.42,0:09:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberapa hebat dirimu yang sebenarnya?
Dialogue: 0,0:09:31.93,0:09:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberapa, ya?
Dialogue: 0,0:09:34.43,0:09:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tadi itu lupakan saja.
Dialogue: 0,0:09:37.18,0:09:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada artinya kalau tidak\Nkubuktikan dengan mataku sendiri.
Dialogue: 0,0:09:41.35,0:09:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak marah karena sudah kurahasiakan?
Dialogue: 0,0:09:44.10,0:09:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku memang berpikir,\N"Apa-apaan itu?!"
Dialogue: 0,0:09:48.11,0:09:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku akan berkembang\Ndengan caraku sendiri.
Dialogue: 0,0:09:52.11,0:09:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana orang lain\Nitu tidak ada hubungannya, kan?
Dialogue: 0,0:09:56.07,0:09:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya.
Dialogue: 0,0:09:57.45,0:09:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubunganmu sama Suzune...
Dialogue: 0,0:09:58.99,0:10:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pacaran, ya.
Dialogue: 0,0:10:01.50,0:10:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh...
Dialogue: 0,0:10:03.21,0:10:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau begitu.
Dialogue: 0,0:10:04.96,0:10:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, ayo buruan!
Dialogue: 0,0:10:08.84,0:10:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide cerdikmu menyelamatkanku.
Dialogue: 0,0:10:11.59,0:10:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku berterima kasih sekali lagi.
Dialogue: 0,0:10:14.13,0:10:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuanggap sebagai utang.
Dialogue: 0,0:10:16.18,0:10:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, soal hadiah 20 juta poin\Njika berhasil membuatmu dikeluarkan.
Dialogue: 0,0:10:22.14,0:10:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sekolah benar-benar mengizinkan\Nujian khusus yang di luar nalar begini?
Dialogue: 0,0:10:27.81,0:10:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi ada yang secara personal\Nmenawarkan imbalan atas kepalaku
Dialogue: 0,0:10:31.32,0:10:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membuat anak kelas satu terpancing.
Dialogue: 0,0:10:34.20,0:10:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang dengan daya bayar sebesar itu\Ndan dipercaya oleh anak kelas satu.
Dialogue: 0,0:10:40.62,0:10:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua OSIS?
Dialogue: 0,0:10:43.25,0:10:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang Ketua Nagumo\Nterlibat dalam kejadian ini?
Dialogue: 0,0:10:46.17,0:10:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:10:47.67,0:10:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat dia sedendam itu padaku.
Dialogue: 0,0:10:50.17,0:10:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Nagumo tertarik pada kakakku.
Dialogue: 0,0:10:53.72,0:10:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi karena Kakak selalu\Nterpaku pada Ayanokoji.
Dialogue: 0,0:10:57.18,0:11:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak aneh jika dia punya\Nperasaan rumit seperti diriku.
Dialogue: 0,0:11:02.02,0:11:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan sebuah kebetulan.
Dialogue: 0,0:11:04.23,0:11:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setelah ini aku ingin\Nmenemui Ketua Nagumo
Dialogue: 0,0:11:06.69,0:11:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengajukan diri masuk ke OSIS.
Dialogue: 0,0:11:09.36,0:11:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:11:10.90,0:11:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang ingin memasukkanku ke OSIS\Nuntuk mengawasi Ketua Nagumo.
Dialogue: 0,0:11:16.86,0:11:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukan sekadar melihat saja, kan?
Dialogue: 0,0:11:20.16,0:11:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara pikir Nagumo berkebalikan dengan\Nkakakmu yang menghargai tradisi.
Dialogue: 0,0:11:25.75,0:11:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak menilai mana\Nyang benar dari keduanya.
Dialogue: 0,0:11:30.71,0:11:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa ingin melihat\Nreformasi milik Nagumo.
Dialogue: 0,0:11:33.80,0:11:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya ingin mengawasi,\Nkenapa malah memasukkanku ke OSIS?
Dialogue: 0,0:11:38.47,0:11:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Nagumo mengambil arah yang salah,
Dialogue: 0,0:11:42.22,0:11:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan butuh seseorang\Nuntuk menghentikannya, kan?
Dialogue: 0,0:11:45.23,0:11:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada bagian yang tidak kusuka,
Dialogue: 0,0:11:47.52,0:11:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kuanggap sebagai sebuah keuntungan.
Dialogue: 0,0:11:50.27,0:11:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apa aku bisa minta ditemani?
Dialogue: 0,0:11:53.61,0:11:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditemani?
Dialogue: 0,0:11:54.99,0:11:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:55.78,0:11:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau misalkan Ketua Nagumo terlibat\Ndi kasus uang imbalan,
Dialogue: 0,0:11:59.32,0:12:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa saja kita melihat reaksinya.
Dialogue: 0,0:12:01.78,0:12:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:06.25,0:12:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin bicara apa denganku?
Dialogue: 0,0:12:08.62,0:12:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa ini waktu yang berharga,\Njadi langsung saja.
Dialogue: 0,0:12:12.54,0:12:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ingin bergabung dengan OSIS.
Dialogue: 0,0:12:15.71,0:12:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada angin apa lagi itu?
Dialogue: 0,0:12:18.80,0:12:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin menyetujuinya begitu saja.
Dialogue: 0,0:12:22.10,0:12:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah artinya saya tidak diterima?
Dialogue: 0,0:12:25.77,0:12:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini spesial, Horikita Suzune.
Dialogue: 0,0:12:29.77,0:12:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jawab kenapa ingin bergabung\Ndengan OSIS di saat seperti ini?
Dialogue: 0,0:12:35.44,0:12:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perselisihan di antara\Nsaya dengan kakak.
Dialogue: 0,0:12:39.03,0:12:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menghilangkannya,\Nsaya pun masuk ke sekolah ini.
Dialogue: 0,0:12:42.99,0:12:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sejak masuk bersekolah,
Dialogue: 0,0:12:45.66,0:12:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hubungan saya dengan kakak\Ntetap tidak berubah.
Dialogue: 0,0:12:49.37,0:12:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu tahun berlalu
Dialogue: 0,0:12:51.71,0:12:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa kami bisa leluasa mengobrol\Nhingga kakak lulus.
Dialogue: 0,0:12:55.17,0:12:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa kalian sudah berdamai?
Dialogue: 0,0:12:58.17,0:12:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:59.05,0:13:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski di saat-saat terakhir.
Dialogue: 0,0:13:01.26,0:13:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situlah untuk pertama kali,
Dialogue: 0,0:13:02.93,0:13:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya tertarik pada OSIS yang telah menjadi\Ndedikasi kakak saya selama bersekolah.
Dialogue: 0,0:13:08.35,0:13:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sudah berputar cukup jauh.
Dialogue: 0,0:13:11.10,0:13:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saya jadi ingin ikut\Nmenapaki jalan yang kakak lalui.
Dialogue: 0,0:13:15.32,0:13:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan yang kakakmu lalui, ya?
Dialogue: 0,0:13:17.98,0:13:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh kuanggap kamu punya tekad\Nuntuk kelak jadi ketua OSIS?
Dialogue: 0,0:13:23.99,0:13:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, saya berniat menjadi ketua OSIS.
Dialogue: 0,0:13:27.83,0:13:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:13:29.37,0:13:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Honami sudah bekerja keras\Nsebagai anggota OSIS selama satu tahun.
Dialogue: 0,0:13:35.17,0:13:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu paham kalau sudah\Ntertinggal satu putaran?
Dialogue: 0,0:13:38.80,0:13:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak menganggapnya sebagai jarak\Nyang tidak bisa dikejar.
Dialogue: 0,0:13:43.72,0:13:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sedikit rasa enggan\Nmemanggilmu Horikita.
Dialogue: 0,0:13:47.97,0:13:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku memanggilmu Suzune.
Dialogue: 0,0:13:50.52,0:13:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan saja sesuka Anda.
Dialogue: 0,0:13:52.73,0:13:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang kebingungan karena\Nanggota kelas dua cuma ada Honami.
Dialogue: 0,0:13:58.98,0:14:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat bergabung dengan OSIS.
Dialogue: 0,0:14:01.57,0:14:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini aku tidak akan sungkan\Nmemintamu bekerja, Suzune.
Dialogue: 0,0:14:05.99,0:14:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saya siap.
Dialogue: 0,0:14:08.12,0:14:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktikan kalau ucapanmu\Nbukan hanya di mulut saja.
Dialogue: 0,0:14:12.71,0:14:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kiriyama, sebagai wakil ketua OSIS.
Dialogue: 0,0:14:15.88,0:14:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya.
Dialogue: 0,0:14:18.00,0:14:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mau sekalian masuk ke OSIS, Ayanokoji?
Dialogue: 0,0:14:22.17,0:14:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tolak tawarannya.
Dialogue: 0,0:14:24.13,0:14:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}OSIS bukanlah gaya saya.
Dialogue: 0,0:14:27.26,0:14:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kukira akan begitu.
Dialogue: 0,0:14:29.39,0:14:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Ayanokoji,\Npekerjaan OSIS sudah mulai lengang.
Dialogue: 0,0:14:35.02,0:14:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat meluangkan waktu\Nuntuk adik-adik kelas saat musim panas.
Dialogue: 0,0:14:40.44,0:14:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bermain denganmu,\Njadi nantikan saja.
Dialogue: 0,0:14:46.66,0:14:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka Kei akan menyeduh kopi.
Dialogue: 0,0:14:49.49,0:14:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada angin apa ini?
Dialogue: 0,0:14:51.45,0:14:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan kirimu sedang terluka,\Njadi pasti sulit, kan?
Dialogue: 0,0:14:55.25,0:14:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:14:56.46,0:14:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah niat buat bilang kalau ketemu.
Dialogue: 0,0:14:59.25,0:15:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tanggung jawab Kiyotaka\Nitu besar, tahu.
Dialogue: 0,0:15:02.21,0:15:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini mendadak sekali?
Dialogue: 0,0:15:03.72,0:15:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara matematikamu\Ndapat nilai sempurna,
Dialogue: 0,0:15:06.22,0:15:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi makin susah bilang kalau kita pacaran.
Dialogue: 0,0:15:09.43,0:15:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:15:11.89,0:15:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak mau kalau dianggap\Npacaran cuma karena status.
Dialogue: 0,0:15:17.85,0:15:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya itu buruk, ya?
Dialogue: 0,0:15:20.86,0:15:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bilang sampai sana.
Dialogue: 0,0:15:23.78,0:15:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya, memacari gadis\Ndengan penampilan sangat manis
Dialogue: 0,0:15:27.78,0:15:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagi cowok itu status, kan?
Dialogue: 0,0:15:29.78,0:15:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah jahat kalau dilarang\Nuntuk menginginkan itu?
Dialogue: 0,0:15:34.04,0:15:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku ini manis?
Dialogue: 0,0:15:36.41,0:15:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir aku mau berpacaran\Nsama orang yang tidak manis?
Dialogue: 0,0:15:41.34,0:15:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga menganggap kalau\NKiyotaka itu sangat keren, kok.
Dialogue: 0,0:15:55.89,0:15:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh?
Dialogue: 0,0:15:58.44,0:15:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu sebentar.
Dialogue: 0,0:15:59.77,0:16:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:16:01.94,0:16:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!\NIni aku!
Dialogue: 0,0:16:07.90,0:16:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang karena khawatir sama\Nkondisi tanganmu yang terluka.
Dialogue: 0,0:16:14.49,0:16:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, boleh tidak kalau dilepas dulu?
Dialogue: 0,0:16:19.17,0:16:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah sore, apa tidak besok saja?
Dialogue: 0,0:16:23.04,0:16:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat berpasangan sama Kak Sudo,\NKakak masih belum lupa, kan?
Dialogue: 0,0:16:28.13,0:16:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, aku sedang kehabisan\Nbahan masakan.
Dialogue: 0,0:16:31.80,0:16:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, begitu rupanya?!
Dialogue: 0,0:16:35.18,0:16:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:16:40.23,0:16:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak tidak sedang sendirian, kan?
Dialogue: 0,0:16:43.31,0:16:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu pikir begitu?
Dialogue: 0,0:16:45.57,0:16:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sudah lihat,\Ndari Kak Karuizawa kembali ke asrama.
Dialogue: 0,0:16:50.57,0:16:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak tadi.
Dialogue: 0,0:16:53.16,0:16:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ketahuan sama aku,\Nbukannya tidak perlu bohong lagi?
Dialogue: 0,0:16:56.58,0:16:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berniat baik\Nuntuk merahasiakannya, lo.
Dialogue: 0,0:16:59.96,0:17:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kubocorkan saja, ya?
Dialogue: 0,0:17:04.46,0:17:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tidak sedang apa-apa.
Dialogue: 0,0:17:06.92,0:17:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tentu saja itu!
Dialogue: 0,0:17:09.08,0:17:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa datang tiba-tiba, sih?!
Dialogue: 0,0:17:11.68,0:17:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kalian melakukan hal terlarang.
Dialogue: 0,0:17:14.89,0:17:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kalian tinggal bersama.
Dialogue: 0,0:17:19.43,0:17:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dilarang aturan sekolah.
Dialogue: 0,0:17:22.06,0:17:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melanggar aturan sekolah\Nbukannya cuma formalitas?
Dialogue: 0,0:17:26.23,0:17:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi ke supermarket saja\Nbisa beli benda seperti ini.
Dialogue: 0,0:17:30.20,0:17:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah dariku...
Dialogue: 0,0:17:33.53,0:17:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, salah, mungkin permintaan maaf.
Dialogue: 0,0:17:37.45,0:17:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat kamu berbuat salah.
Dialogue: 0,0:17:39.70,0:17:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, masih saja.
Dialogue: 0,0:17:41.50,0:17:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka di tangan Kakak ada andilku juga, kan?
Dialogue: 0,0:17:45.21,0:17:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya sudah membantu Hosen.
Dialogue: 0,0:17:47.92,0:17:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?!
Dialogue: 0,0:17:49.80,0:17:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kalau Kak Ayanokoji\Nsalah paham padaku.
Dialogue: 0,0:17:55.43,0:17:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah paham?
Dialogue: 0,0:17:57.06,0:18:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukanlah musuh Kak Ayanokoji.
Dialogue: 0,0:18:00.56,0:18:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalimatmu itu sangat sulit dipercaya.
Dialogue: 0,0:18:03.27,0:18:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:18:04.60,0:18:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sudah memberi Hosen ide
Dialogue: 0,0:18:07.23,0:18:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam rencananya mengeluarkan\NKakak dari sekolah?
Dialogue: 0,0:18:10.61,0:18:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu dulu sebentar!
Dialogue: 0,0:18:12.53,0:18:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya mau mengeluarkan\NKiyotaka dari sekolah?!
Dialogue: 0,0:18:15.95,0:18:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, jadi tidak diceritakan ke pacarmu, ya.
Dialogue: 0,0:18:19.66,0:18:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti soal imbalan 20 juta juga?
Dialogue: 0,0:18:22.87,0:18:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang 20 juta?!
Dialogue: 0,0:18:25.38,0:18:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal detailnya mungkin lebih baik\Nditanyakan ke pacar Kakak saja.
Dialogue: 0,0:18:29.63,0:18:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Kak?
Dialogue: 0,0:18:33.97,0:18:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak menyadari rencananya\Nsaat pergi belanja denganku.
Dialogue: 0,0:18:38.47,0:18:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tidak ragu-ragu\Nsaat memilih pisau.
Dialogue: 0,0:18:42.10,0:18:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:18:43.60,0:18:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sengaja kau buat agar aku menyadarinya, ya.
Dialogue: 0,0:18:48.19,0:18:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik sekali rupanya.
Dialogue: 0,0:18:50.48,0:18:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendadak dijadikan target berhadiah\Njika berhasil dikeluarkan dari sekolah.
Dialogue: 0,0:18:55.49,0:18:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi merasa kasihan.
Dialogue: 0,0:18:57.99,0:19:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemikiran yang melebihi manusia biasa.
Dialogue: 0,0:19:00.95,0:19:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau disebut siswa White Room pun\Nakan masuk akal.
Dialogue: 0,0:19:04.16,0:19:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa untungnya\Ndia membeberkan identitasnya?
Dialogue: 0,0:19:09.54,0:19:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku sudah memberi ucapan maaf,\Njadi mungkin sekarang pulang saja.
Dialogue: 0,0:19:14.01,0:19:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan masakannya silakan dipakai saja.
Dialogue: 0,0:19:17.14,0:19:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?! Apa-apaan itu?!
Dialogue: 0,0:19:20.01,0:19:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa justru boleh berlama-lama di sini?
Dialogue: 0,0:19:23.52,0:19:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau itu...\NMemang maunya kamu pulang saja...
Dialogue: 0,0:19:27.77,0:19:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku pulang dulu...
Dialogue: 0,0:19:33.94,0:19:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semenjak ujian khusus di akhir April,\Nujian baru masih belum dimulai.
Dialogue: 0,0:19:39.66,0:19:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerak-gerik siswa White Room\Nyang seharusnya mengincarku
Dialogue: 0,0:19:43.41,0:19:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih belum bisa dipastikan.
Dialogue: 0,0:19:45.50,0:19:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Kak Ayanokoji.
Dialogue: 0,0:19:48.33,0:19:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, selamat pagi.
Dialogue: 0,0:19:51.38,0:19:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada sesuatu dengan langit?
Dialogue: 0,0:19:53.76,0:19:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:19:55.09,0:19:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma memandangi langit biru.
Dialogue: 0,0:19:57.72,0:20:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kita lama tidak bertemu.
Dialogue: 0,0:20:00.30,0:20:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sudah lama kita tidak bertemu.
Dialogue: 0,0:20:03.51,0:20:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya merasa sudah berbuat salah\Npada Kak Ayanokoji.
Dialogue: 0,0:20:08.23,0:20:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Kakak membenci saya?
Dialogue: 0,0:20:11.69,0:20:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada alasan buat membencimu.
Dialogue: 0,0:20:14.11,0:20:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ujian khusus untuk\Nmengeluarkanku dari sekolah, kan?
Dialogue: 0,0:20:17.70,0:20:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ujiannya sudah selesai?
Dialogue: 0,0:20:20.16,0:20:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum, masih berlanjut.
Dialogue: 0,0:20:22.70,0:20:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batasnya hingga semester dua dimulai.
Dialogue: 0,0:20:25.45,0:20:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kakak khawatir karena saya atau Hosen\Nmalah tidak melakukan kontak sama sekali?
Dialogue: 0,0:20:30.46,0:20:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong kalau aku bilang tidak kepikiran.
Dialogue: 0,0:20:33.63,0:20:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kejadian sebelumnya sudah dipastikan
Dialogue: 0,0:20:36.17,0:20:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau mengatur siasat di kegiatan sehari-hari\Ntidak akan mempan dengan mudah.
Dialogue: 0,0:20:40.09,0:20:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang menunggu ujian khusus\Nyang melibatkan angkatan lain, ya?
Dialogue: 0,0:20:46.93,0:20:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya anak kelas satu\Nada yang dikeluarkan dari ujian khusus.
Dialogue: 0,0:20:52.23,0:20:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:53.31,0:20:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang siswa laki-laki dari Kelas 1-C\Nsudah dikeluarkan.
Dialogue: 0,0:20:56.99,0:21:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekolah ini, teman yang kemarin\Nmasih tertawa bersama
Dialogue: 0,0:21:00.99,0:21:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa hilang tanpa belas kasih.
Dialogue: 0,0:21:03.62,0:21:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali diingatkan dengan keras\Nkalau kami harus
Dialogue: 0,0:21:06.49,0:21:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjalaninya tanpa membuat\Nmenyesal di lain waktu.
Dialogue: 0,0:21:09.29,0:21:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya berniat menjalani hidup bersekolah\Ntanpa ada penyesalan.
Dialogue: 0,0:21:15.67,0:21:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga Kak Ayanokoji juga bisa menjalani\Nhidup bersekolah tanpa penyesalan.
Dialogue: 0,0:21:25.22,0:21:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau kalian semua ada di sini.
Dialogue: 0,0:21:28.27,0:21:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujelaskan sedikit lebih awal\Nsoal liburan musim panas kalian.
Dialogue: 0,0:21:33.52,0:21:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama delapan hari tujuh malam,
Dialogue: 0,0:21:35.19,0:21:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian bisa sepuasnya menikmati\Nlibur musim panas di kapal pesiar mewah ini.
Dialogue: 0,0:21:39.86,0:21:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada ujian khusus\Nyang diadakan di atas kapal.
Dialogue: 0,0:21:44.57,0:21:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, demi menikmati perjalanan kapal ini.
Dialogue: 0,0:21:48.04,0:21:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus melewati\Nujian khusus berikutnya dengan selamat.
Dialogue: 0,0:21:52.04,0:21:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan ujian khususnya diadakan?
Dialogue: 0,0:21:55.46,0:21:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti biasa, harusnya akan\Ndimulai hari ini atau besok.
Dialogue: 0,0:21:59.17,0:22:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ujian khusus berikutnya akan diadakan\Nsaat libur musim panas.
Dialogue: 0,0:22:03.22,0:22:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan diminta bertahan hidup dan\Nbersaing di pulau tak berpenghuni.
