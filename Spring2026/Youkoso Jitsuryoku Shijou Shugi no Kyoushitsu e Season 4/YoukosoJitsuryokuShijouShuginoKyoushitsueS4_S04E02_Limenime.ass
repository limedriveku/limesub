Dialogue: 0,0:01:30.58,0:01:36.37,tanda,,0000,0000,0000,,CLASSROOM OF THE ELITE 4TH SEASON:\NSECOND YEAR, FIRST SEMESTER
Dialogue: 0,0:02:40.40,0:02:46.99,tanda,,0000,0000,0000,,CLASSROOM OF THE ELITE 4TH SEASON:\NSECOND YEAR, FIRST SEMESTER
Dialogue: 0,0:02:52.03,0:02:54.52,tanda,,0000,0000,0000,,#2 KONTRAK DAN BAYARAN
Dialogue: 0,0:15:45.63,0:15:48.13,tanda,,0000,0000,0000,,NANASE TSUBASA
Dialogue: 0,0:15:50.14,0:15:52.64,tanda,,0000,0000,0000,,NANASE TSUBASA\NKITA BISA BERTEMU BESOK SEPULANG SEKOLAH
Dialogue: 0,0:00:01.73,0:00:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:00:02.98,0:00:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa benar kamu Kak Kushida?
Dialogue: 0,0:00:05.61,0:00:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:07.32,0:00:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku, adik kelasmu dari SMP dulu.
Dialogue: 0,0:00:10.95,0:00:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yagami Takuya.
Dialogue: 0,0:00:12.70,0:00:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yagami?
Dialogue: 0,0:00:14.95,0:00:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yagami yang itu?!
Dialogue: 0,0:00:16.70,0:00:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:00:18.12,0:00:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu.
Dialogue: 0,0:00:19.71,0:00:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenalanmu?
Dialogue: 0,0:00:21.33,0:00:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:22.17,0:00:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski hampir tidak pernah interaksi,\Ntapi ingat karena dia sangat pintar.
Dialogue: 0,0:00:28.09,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga kenal Yagami?
Dialogue: 0,0:00:30.63,0:00:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian satu SMP, kan?
Dialogue: 0,0:00:33.39,0:00:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah, aku tidak tahu.
Dialogue: 0,0:00:35.72,0:00:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak seluang itu untuk memperhatikan\Norang yang tidak menarik buatku.
Dialogue: 0,0:00:39.69,0:00:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Yagami tahu soal masa lalu Kushida?
Dialogue: 0,0:00:44.57,0:00:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan aneh kalau dia tahu.
Dialogue: 0,0:00:49.49,0:00:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang mendadak, tapi aku\Ntidak masalah kalau sama Kakak.
Dialogue: 0,0:00:52.95,0:00:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah jadi partnerku untuk ujian khusus?
Dialogue: 0,0:00:56.58,0:00:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin mau sama aku?
Dialogue: 0,0:00:58.66,0:01:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik cari partner dengan\Norang yang lebih pintar...
Dialogue: 0,0:01:02.08,0:01:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:01:02.96,0:01:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih belum tahu apa-apa di sini.
Dialogue: 0,0:01:05.37,0:01:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ingin cari orang yang\Nbisa dipercaya sebagai partner.
Dialogue: 0,0:01:08.59,0:01:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bisa berikan aku sedikit waktu\Nuntuk memikirkannya dulu, tidak?
Dialogue: 0,0:01:13.34,0:01:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu boleh!
Dialogue: 0,0:01:15.18,0:01:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan berpartner dulu dengan\Nsiapa pun untuk menunggu jawabanmu.
Dialogue: 0,0:02:54.53,0:02:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren, ya.
Dialogue: 0,0:02:56.53,0:02:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lihat ini!\N- Bagus juga, tuh.
Dialogue: 0,0:02:59.91,0:03:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak kelas satu santai sekali, ya.
Dialogue: 0,0:03:02.75,0:03:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita lagi serius cari partner.
Dialogue: 0,0:03:06.29,0:03:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lupa sama dirimu setahun lalu?
Dialogue: 0,0:03:09.84,0:03:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukannya lupa!
Dialogue: 0,0:03:12.63,0:03:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah introspeksi diri.
Dialogue: 0,0:03:14.92,0:03:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita cari anak kelas satu yang\Nmungkin mau jadi partner Sudo, kan?
Dialogue: 0,0:03:19.85,0:03:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita coba dulu bicara ke mereka.
Dialogue: 0,0:03:25.98,0:03:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bicara sebentar?
Dialogue: 0,0:03:28.69,0:03:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang mencari partner\Nuntuk ujian khusus kali ini.
Dialogue: 0,0:03:33.28,0:03:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh bicara sebentar tidak?
Dialogue: 0,0:03:36.20,0:03:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja boleh.
Dialogue: 0,0:03:38.57,0:03:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:03:40.07,0:03:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kami belum berpartner\Ndengan siapa-siapa.
Dialogue: 0,0:03:44.08,0:03:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih kalau bahasannya jadi cepat.
Dialogue: 0,0:03:46.83,0:03:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, kami sedang\Nmencari pasangan untuk Sudo.
Dialogue: 0,0:03:51.34,0:03:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana kalau begini?
Dialogue: 0,0:03:55.09,0:03:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?!\NMau minta poin maksudnya?!
Dialogue: 0,0:03:57.68,0:04:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi kemahalan kalau 50.000!
Dialogue: 0,0:04:00.09,0:04:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak tidak perlu bercanda lagi, lo.
Dialogue: 0,0:04:03.89,0:04:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan 50.000, tapi 500.000.
Dialogue: 0,0:04:07.10,0:04:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh, 500.000?!
Dialogue: 0,0:04:09.10,0:04:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah dihubungi duluan\Noleh Kelas A dan C.
Dialogue: 0,0:04:14.65,0:04:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak mau jual murah.
Dialogue: 0,0:04:18.24,0:04:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kami pertimbangkan.
Dialogue: 0,0:04:20.99,0:04:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, sebenarnya ada permintaan lain.
Dialogue: 0,0:04:24.70,0:04:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kenalkan ke beberapa\Nanak lain dari Kelas D?
Dialogue: 0,0:04:29.12,0:04:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu, agak sulit.
Dialogue: 0,0:04:33.17,0:04:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:34.21,0:04:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertindak sembarangan,\Nnanti dimarahi Hosen.
Dialogue: 0,0:04:38.13,0:04:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:04:42.39,0:04:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, kelemahanku dimanfaatkan.
Dialogue: 0,0:04:45.64,0:04:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sembarangan, nanti dimarahi Hosen.
Dialogue: 0,0:04:50.10,0:04:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau begitu,\Nbukannya malah enggak laku?
Dialogue: 0,0:04:53.94,0:04:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang takut pada penalti saat\Ntidak dapat pasangan hanya kelas dua.
Dialogue: 0,0:04:57.65,0:05:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen berpikir menjadikannya senjata\Nuntuk meraup banyak poin.
Dialogue: 0,0:05:02.66,0:05:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap bertanya tanpa arah begini,\Nhasilnya akan sama saja.
Dialogue: 0,0:05:07.75,0:05:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau maju bagaimana?
Dialogue: 0,0:05:10.04,0:05:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini aku tidak ada niat ikut main uang.
Dialogue: 0,0:05:15.17,0:05:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalkan bisa jadi peringkat satu,\Npoin kelas yang didapat adalah 50.
Dialogue: 0,0:05:19.34,0:05:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditukar jadi poin pribadi,\Nhanya dua juta lebih sedikit.
Dialogue: 0,0:05:24.43,0:05:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, kalau beli satu orang\Ndengan 500.000 poin,
Dialogue: 0,0:05:28.22,0:05:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langsung rugi saat ambil lima orang.
Dialogue: 0,0:05:30.93,0:05:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya menurutku, sebaiknya jangan\Nmemaksa mengeluarkan poin di sini.
Dialogue: 0,0:05:36.44,0:05:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku langkah yang harus diambil\Nmemang bernegosiasi dengan Kelas 1-D.
Dialogue: 0,0:05:42.32,0:05:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, risikonya tinggi kalau\Nhanya berharap pada kelas Hosen.
Dialogue: 0,0:05:47.12,0:05:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar dapat partner yang bagus,\Nmemang harus tanya ke banyak orang...
Dialogue: 0,0:05:52.96,0:05:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:05:54.88,0:05:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mencari partner yang bagus,\Nada di sini, lo!
Dialogue: 0,0:06:03.09,0:06:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menguping obrolan kami, ya?
Dialogue: 0,0:06:05.93,0:06:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, Kakak ini.
Dialogue: 0,0:06:07.76,0:06:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma kebetulan dengar,\Nmakanya kupanggil.
Dialogue: 0,0:06:11.23,0:06:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Amasawa Ichika dari Kelas 1-A.
Dialogue: 0,0:06:14.69,0:06:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan akademikku dinilai A, lo.
Dialogue: 0,0:06:17.77,0:06:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, apa perlu kujadikan pasangan?
Dialogue: 0,0:06:19.98,0:06:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas tawarannya.
Dialogue: 0,0:06:22.19,0:06:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sayangnya bukan aku,\Nbisakah kamu jadi pasangan Sudo?
Dialogue: 0,0:06:28.78,0:06:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademik Kak Sudo E+, ya.
Dialogue: 0,0:06:32.25,0:06:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bukannya aku enggak mau bantu, sih.
Dialogue: 0,0:06:35.75,0:06:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?!
Dialogue: 0,0:06:37.58,0:06:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini memang suka sama cowok kuat.
Dialogue: 0,0:06:42.26,0:06:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kamu ini?
Dialogue: 0,0:06:44.09,0:06:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan secara mental,\Ntapi yang kuat secara fisik.
Dialogue: 0,0:06:49.72,0:06:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengumpulkan orang kuat\Nbuat disuruh kelahi.
Dialogue: 0,0:06:52.98,0:06:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencananya aku bakal berpasangan\Nsama yang paling kuat dari mereka.
Dialogue: 0,0:06:58.48,0:07:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bercanda?
Dialogue: 0,0:07:00.07,0:07:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin bisa seperti itu.
Dialogue: 0,0:07:02.48,0:07:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:07:03.99,0:07:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius, lo.
Dialogue: 0,0:07:05.82,0:07:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini suka sama cowok kuat.
Dialogue: 0,0:07:10.83,0:07:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cabut, Suzune.
Dialogue: 0,0:07:13.00,0:07:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dikerjai.
Dialogue: 0,0:07:15.25,0:07:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:07:20.50,0:07:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:07:21.67,0:07:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuberi kesempatan lain,\Njadi maafkan aku.
Dialogue: 0,0:07:25.59,0:07:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan?
Dialogue: 0,0:07:27.09,0:07:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain cowok yang kuat,\Naku juga suka cowok yang bisa masak.
Dialogue: 0,0:07:33.60,0:07:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa membuatkan masakan\Nyang kupesan dengan enak,
Dialogue: 0,0:07:36.89,0:07:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau jadi pasanganmu.
Dialogue: 0,0:07:38.02,0:07:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Masakan buatanku sendiri?!
Dialogue: 0,0:07:40.52,0:07:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah masak sejak lahir.
Dialogue: 0,0:07:43.61,0:07:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak boleh kalau aku yang buat\Nmenggantikan Sudo?
Dialogue: 0,0:07:47.53,0:07:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh kalau itu.
Dialogue: 0,0:07:49.24,0:07:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, kan, cowok yang bisa masak.
Dialogue: 0,0:07:54.12,0:07:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji.
Dialogue: 0,0:07:55.79,0:08:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah kamu pamer padaku\Nkalau jago masak, bukan?
Dialogue: 0,0:08:00.83,0:08:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:01.88,0:08:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang kalau memasak\Nsatu-satunya keahlianku.
Dialogue: 0,0:08:05.80,0:08:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana kalau Ayanokoji saja?
Dialogue: 0,0:08:09.30,0:08:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, sih.
Dialogue: 0,0:08:10.68,0:08:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa betulan jago?
Dialogue: 0,0:08:13.01,0:08:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penilaianku akan cukup ketat, lo.
Dialogue: 0,0:08:15.56,0:08:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak masalah.
Dialogue: 0,0:08:17.81,0:08:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:08:18.94,0:08:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, begitulah.
Dialogue: 0,0:08:21.06,0:08:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kita sepakat, ya.
Dialogue: 0,0:08:23.48,0:08:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sepulang sekolah besok gagal\Nmenyuguhiku masakan buatanmu yang enak,
Dialogue: 0,0:08:27.49,0:08:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perjanjian kali ini tidak jadi.
Dialogue: 0,0:08:30.57,0:08:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon padamu, Ayanokoji!
Dialogue: 0,0:08:32.53,0:08:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Carikan aku pasangan dengan\Nkemampuan memasakmu itu!
Dialogue: 0,0:08:37.58,0:08:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, sampai besok!
Dialogue: 0,0:08:39.66,0:08:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah!
Dialogue: 0,0:08:42.58,0:08:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikita, harusnya kamu tahu,\Nkemampuan memasakku...
Dialogue: 0,0:08:47.09,0:08:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang diamlah dulu.
Dialogue: 0,0:08:48.72,0:08:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang kupikirkan strateginya.
Dialogue: 0,0:08:52.47,0:08:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai tadi pagi sudah 56 pasangan.
Dialogue: 0,0:08:54.97,0:08:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari 30% sudah menentukan\Npartner secepat ini, ya.
Dialogue: 0,0:09:00.69,0:09:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus segera serius bergerak.
Dialogue: 0,0:09:04.57,0:09:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Kak Ayanokoji.
Dialogue: 0,0:09:07.99,0:09:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kalau kemarin Hosen\Nsudah bicara tidak sopan.
Dialogue: 0,0:09:12.24,0:09:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu minta maaf.
Dialogue: 0,0:09:14.53,0:09:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:09:15.58,0:09:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal saya ikut menemani untuk\Nmenghentikan Hosen bertindak seperti itu.
Dialogue: 0,0:09:19.66,0:09:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya jadi sadar kalau kurang mampu.
Dialogue: 0,0:09:22.58,0:09:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikapnya ramah,\Nsopan dan akademiknya juga tinggi.
Dialogue: 0,0:09:26.84,0:09:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah di Kelas D.
Dialogue: 0,0:09:29.88,0:09:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu yang menggangguku adalah
Dialogue: 0,0:09:32.59,0:09:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sorot matanya saat itu.
Dialogue: 0,0:09:35.97,0:09:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah menentukan partner?
Dialogue: 0,0:09:38.35,0:09:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya saya?
Dialogue: 0,0:09:39.89,0:09:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum.
Dialogue: 0,0:09:41.06,0:09:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sudah menawari beberapa orang,\Ntapi masih belum dapat.
Dialogue: 0,0:09:44.77,0:09:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, bagaimana kalau sebagai\Nsesama Kelas D saling bantu
Dialogue: 0,0:09:49.03,0:09:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari partner?
Dialogue: 0,0:09:51.28,0:09:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saling bantu sebagai sesama Kelas D?
Dialogue: 0,0:09:54.78,0:09:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:56.24,0:09:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya setuju dengan itu.
Dialogue: 0,0:09:58.58,0:10:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja ada satu masalah.
Dialogue: 0,0:10:01.20,0:10:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Hosen, ya?
Dialogue: 0,0:10:02.91,0:10:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:04.04,0:10:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak siswa yang sudah tunduk\Ndan mematuhi perintah Hosen.
Dialogue: 0,0:10:09.42,0:10:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa posisimu agak berbeda?
Dialogue: 0,0:10:13.26,0:10:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak merasa kalau kamu\Ntunduk pada Hosen.
Dialogue: 0,0:10:16.93,0:10:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena saya tidak akan pernah\Ntunduk pada kekerasan!
Dialogue: 0,0:10:22.10,0:10:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga, kalau yang\Nmenentukan haluan kelas adalah Hosen...
Dialogue: 0,0:10:26.61,0:10:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahasan tadi rasanya akan sulit terjadi.
Dialogue: 0,0:10:30.19,0:10:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, misalkan tidak masalah\Nkalau kondisinya begitu.
Dialogue: 0,0:10:33.45,0:10:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu saya coba mengatur\Nmedia kerja samanya?
Dialogue: 0,0:10:37.32,0:10:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul tidak apa-apa?
Dialogue: 0,0:10:39.28,0:10:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Horikita pasti akan senang.
Dialogue: 0,0:10:42.25,0:10:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kak Horikita pemimpin kelas Kakak?
Dialogue: 0,0:10:45.71,0:10:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:46.96,0:10:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menyampaikan itu padanya.
Dialogue: 0,0:10:49.50,0:10:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kita bertukar kontak?
Dialogue: 0,0:10:52.46,0:10:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.\NMohon kerja samanya, Kak Ayanokoji.
Dialogue: 0,0:10:58.72,0:11:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk ukuranmu,\Nini pendekatan yang lumayan berani.
Dialogue: 0,0:11:02.60,0:11:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah buruk?
Dialogue: 0,0:11:03.93,0:11:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru itu yang kuharapkan.
Dialogue: 0,0:11:07.23,0:11:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukankah, Hosen justru menginginkan\Nskema main uang yang mau kamu hindari?
Dialogue: 0,0:11:12.57,0:11:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang benar.
Dialogue: 0,0:11:14.15,0:11:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa benar dia hanya ingin poin?
Dialogue: 0,0:11:17.99,0:11:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti maksudmu,\Ntujuan Hosen adalah kita, Kelas D?
Dialogue: 0,0:11:22.74,0:11:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, bisa diperkirakan kalau\NHosen bukan lawan yang mudah dilawan.
Dialogue: 0,0:11:27.67,0:11:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk jaga-jaga, sedang kudiskusikan
Dialogue: 0,0:11:30.59,0:11:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa perlu menjalin kerja sama\Ndengan sebagian anak Kelas 1-B.
Dialogue: 0,0:11:34.01,0:11:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya Kelas 1-B itu Yagami yang katanya\Nsatu SMP denganmu dan Kushida, ya?
Dialogue: 0,0:11:40.26,0:11:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin, Kushida sudah\Nberpasangan dengan Yagami.
Dialogue: 0,0:11:44.18,0:11:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang minta tolong dia untuk\Nmelakukan negosiasi di balik layar.
Dialogue: 0,0:11:48.60,0:11:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu juga ikut bantu.
Dialogue: 0,0:11:51.27,0:11:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Amasawa, ya.
Dialogue: 0,0:11:53.44,0:11:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:55.11,0:11:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strateginya sudah jadi.
Dialogue: 0,0:12:02.08,0:12:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang pertama talenan, kan?
Dialogue: 0,0:12:04.37,0:12:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisau, kan?
Dialogue: 0,0:12:06.08,0:12:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus mangkuk wadah sama pengocok telur.
Dialogue: 0,0:12:08.96,0:12:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:12:10.50,0:12:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau alat masak, di kamarku juga ada.
Dialogue: 0,0:12:13.30,0:12:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, biar saja.
Dialogue: 0,0:12:14.80,0:12:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma minta dibelikan\Nkhusus dipakai buat aku.
Dialogue: 0,0:12:18.18,0:12:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu semuanya yang mahal.
Dialogue: 0,0:12:20.80,0:12:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, pisau kue juga enggak boleh ketinggalan.
Dialogue: 0,0:12:24.43,0:12:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya aku mau tanya, yang bayar...
Dialogue: 0,0:12:26.81,0:12:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas Kak Ayanokoji, dong.
Dialogue: 0,0:12:29.39,0:12:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, Kakak ini.
Dialogue: 0,0:12:30.81,0:12:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tahu, sih...
Dialogue: 0,0:12:33.82,0:12:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja nanti aku bisa pakai\Nalat-alat mahal buat ke depannya.
Dialogue: 0,0:12:38.07,0:12:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tadi sudah kubilang,\Nini khusus dipakai buat aku.
Dialogue: 0,0:12:41.82,0:12:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi jangan dipakai selain itu, ya.
Dialogue: 0,0:12:43.99,0:12:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelit sekali.
Dialogue: 0,0:12:46.91,0:12:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:12:49.79,0:12:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren, sudah dirapikan sampai bersih.
Dialogue: 0,0:12:54.17,0:12:57.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi kubuatkan, kamu rebahan saja.
Dialogue: 0,0:12:57.26,0:12:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kak.
Dialogue: 0,0:12:58.84,0:13:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kalau masak sambil lihat ponsel\Nitu pelanggaran, ya.
Dialogue: 0,0:13:03.09,0:13:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketat sekali.
Dialogue: 0,0:13:04.85,0:13:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak pede, nih?
Dialogue: 0,0:13:07.18,0:13:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya begitu.
Dialogue: 0,0:13:09.14,0:13:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponselku akan kutaruh di sini.
Dialogue: 0,0:13:11.69,0:13:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang harus kumasak?
Dialogue: 0,0:13:14.36,0:13:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuumumkan sekarang.
Dialogue: 0,0:13:16.40,0:13:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan yang harus dibuat Kakak adalah
Dialogue: 0,0:13:20.03,0:13:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tom yam udang.
Dialogue: 0,0:13:22.36,0:13:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tom yam udang, ya.
Dialogue: 0,0:13:25.62,0:13:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong dibuatkan, ya, Kak.
Dialogue: 0,0:13:29.58,0:13:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar bahasan kalian.
Dialogue: 0,0:13:31.46,0:13:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka minta tom yam udang.
Dialogue: 0,0:13:33.92,0:13:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri arahannya.
Dialogue: 0,0:13:36.09,0:13:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara pakai pisaunya\Nseperti yang kuajarkan kemarin.
Dialogue: 0,0:13:39.38,0:13:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usahakan waktu memasaknya\Ndari 15 sampai 30 menit, ya.
Dialogue: 0,0:13:43.84,0:13:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham?
Dialogue: 0,0:13:45.14,0:13:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, mari kita lihat bisa sejauh mana\Nhasil belajar singkat ini.
Dialogue: 0,0:13:53.74,0:13:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, keren, keren.
Dialogue: 0,0:13:55.52,0:13:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara tampilan sudah lulus.
Dialogue: 0,0:13:59.11,0:14:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, selamat makan.
Dialogue: 0,0:14:05.03,0:14:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun ketumbarnya boleh juga.
Dialogue: 0,0:14:08.45,0:14:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kelinci dari apel.
Dialogue: 0,0:14:13.67,0:14:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas hidangannya.
Dialogue: 0,0:14:16.21,0:14:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tom yam udang buatan Kakak...
Dialogue: 0,0:14:21.17,0:14:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, nilainya pas-pasan untuk lulus, lah.
Dialogue: 0,0:14:26.43,0:14:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sekarang biar kubereskan, ya.
Dialogue: 0,0:14:29.35,0:14:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja.
Dialogue: 0,0:14:30.47,0:14:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tidak apa-apa.
Dialogue: 0,0:14:31.93,0:14:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah minta yang tidak-tidak,\Njadi minimal ini biar aku saja.
Dialogue: 0,0:14:35.15,0:14:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:14:36.94,0:14:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, soal hasilnya...
Dialogue: 0,0:14:41.82,0:14:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya tidak bisa dibilang lulus.
Dialogue: 0,0:14:44.91,0:14:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sudah minta dibelikan\Nbanyak barang mahal.
Dialogue: 0,0:14:47.62,0:14:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menghargai usaha Kakak kali ini,\Naku akan berpasangan dengan Kak Sudo.
Dialogue: 0,0:14:52.45,0:14:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berterima kasih.
Dialogue: 0,0:14:54.08,0:14:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, boleh.
Dialogue: 0,0:14:55.71,0:14:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak boleh berterima kasih padaku\Nsebanyak-banyaknya.
Dialogue: 0,0:14:58.71,0:15:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, tidak enak kalau terlalu larut,\Naku pulang dulu.
Dialogue: 0,0:15:02.67,0:15:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:03.72,0:15:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, Kak Ayanokoji.
Dialogue: 0,0:15:06.34,0:15:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah.
Dialogue: 0,0:15:10.47,0:15:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas usahanya.
Dialogue: 0,0:15:12.14,0:15:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya berjalan lancar.
Dialogue: 0,0:15:14.18,0:15:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah Sudo sudah terselesaikan.
Dialogue: 0,0:15:16.77,0:15:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pencapaian yang sangat besar.
Dialogue: 0,0:15:18.90,0:15:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau ada kesan tertolong oleh\Nlonggarnya penilaian Amasawa.
Dialogue: 0,0:15:23.11,0:15:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti akan kukabari kalau\Nada kabar dari Nanase.
Dialogue: 0,0:15:26.11,0:15:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:27.57,0:15:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Amasawa adalah orang dari White Room,
Dialogue: 0,0:15:30.78,0:15:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak aneh kalau dia memasang sesuatu.
Dialogue: 0,0:15:34.25,0:15:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terpenting Amasawa bukan\Nberpasangan denganku, tapi Sudo.
Dialogue: 0,0:15:38.63,0:15:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak dipikir berlebihan...
Dialogue: 0,0:15:40.54,0:15:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan Amasawa adalah\Nsiswa dari White Room akan hilang.
Dialogue: 0,0:15:53.47,0:15:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada tawaran dari Kelas C lagi\Nke siswa yang sudah kita ajak bicara.
Dialogue: 0,0:15:59.44,0:16:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi katanya akan dihadiahi 10.000 poin\Nkalau menolak tawaran Kelas A.
Dialogue: 0,0:16:04.15,0:16:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh apa bagaimana?
Dialogue: 0,0:16:06.86,0:16:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Ryuen benar-benar ingin\Nmenantangku bertanding.
Dialogue: 0,0:16:12.95,0:16:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bagaimana?
Dialogue: 0,0:16:14.66,0:16:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampaikan pada anak kelas satu.
Dialogue: 0,0:16:17.41,0:16:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga menyiapkan harga\Nyang setara dengan Ryuen.
Dialogue: 0,0:16:21.92,0:16:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, jangan buat perjanjian\Nmeski anak kelas satu menerimanya.
Dialogue: 0,0:16:28.55,0:16:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha, apa itu?
Dialogue: 0,0:16:30.93,0:16:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku betulan tidak paham maksudnya.
Dialogue: 0,0:16:34.35,0:16:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryuen,\Nstrategimu justru menguntungkan buatku.
Dialogue: 0,0:16:40.48,0:16:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar enggak paham apa maksudmu.
Dialogue: 0,0:16:43.19,0:16:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saja enggak, sih?
Dialogue: 0,0:16:44.98,0:16:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Tuan Putri memang tidak butuh.
Dialogue: 0,0:16:47.94,0:16:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strategi pembelian besar-besaran Ryuen\Nbukanlah sesuatu yang buruk.
Dialogue: 0,0:16:54.45,0:16:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, jelas sebuah kesalahan kalau terus
Dialogue: 0,0:16:57.33,0:17:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersaing dengan kita yang mengincar\Nsiswa yang sama.
Dialogue: 0,0:17:00.96,0:17:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau berani beli orang\Nsampai sejauh itu,
Dialogue: 0,0:17:04.33,0:17:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti dia menimbun\Npoin pribadi sebanyak itu?
Dialogue: 0,0:17:07.71,0:17:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, entah kalau itu.
Dialogue: 0,0:17:10.51,0:17:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski melarat pun masih bisa\Nkalau sekadar mengajukan penawaran.
Dialogue: 0,0:17:14.59,0:17:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi cuma pura-pura punya uang?!
Dialogue: 0,0:17:17.02,0:17:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang apa untungnya Kelas C melakukan itu?
Dialogue: 0,0:17:20.52,0:17:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalkan tidak ada Ryuen.
Dialogue: 0,0:17:23.06,0:17:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya bermodal nama Kelas A, kita sudah bisa\Nmenarik banyak siswa teladan.
Dialogue: 0,0:17:28.69,0:17:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi dengan adanya Kelas C\Nyang mengajukan penawaran.
Dialogue: 0,0:17:32.53,0:17:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita jadi dipaksa ikut bermain uang.
Dialogue: 0,0:17:35.49,0:17:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang dilakukan selanjutnya\Nadalah menaikkan harga
Dialogue: 0,0:17:39.41,0:17:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sebisa mungkin membuat kita\Nkeluar uang sebanyak-banyaknya.
Dialogue: 0,0:17:43.75,0:17:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:17:45.50,0:17:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti poker.
Dialogue: 0,0:17:47.25,0:17:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia sudah salah perhitungan.
Dialogue: 0,0:17:49.92,0:17:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal kekuatan nama Kelas A yang kita punya.
Dialogue: 0,0:17:55.01,0:18:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kelas 1-B yang kita pancing seharga\N20.000 sepertinya minta ditahan dulu.
Dialogue: 0,0:18:00.27,0:18:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok, bisa?
Dialogue: 0,0:18:01.60,0:18:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua puluh ribu poin masih kurang?
Dialogue: 0,0:18:03.52,0:18:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu.
Dialogue: 0,0:18:05.02,0:18:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tahu semua yang mereka incar.
Dialogue: 0,0:18:08.02,0:18:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang kita kasih uang muka 10.000,\Nlalu setelah ujian kasih 20.000.
Dialogue: 0,0:18:12.32,0:18:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-Yakin itu?
Dialogue: 0,0:18:14.03,0:18:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling kebanyakan dari mereka\Njuga tidak akan memutuskan.
Dialogue: 0,0:18:18.03,0:18:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berharap Sakayanagi menaikkan tawarannya.
Dialogue: 0,0:18:21.54,0:18:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya nanti itu malah bikin\Nkita berakhir bangkrut?
Dialogue: 0,0:18:25.54,0:18:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalkan dikasih tawaran yang sama,\Nkita kalah pamor nama, kan?
Dialogue: 0,0:18:30.05,0:18:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamor nama Kelas A cuma\Npajangan buat sekarang.
Dialogue: 0,0:18:34.43,0:18:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, mau bagaimana\Nkalau harganya terus melambung naik?
Dialogue: 0,0:18:38.68,0:18:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu kita bayar.
Dialogue: 0,0:18:40.93,0:18:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:42.06,0:18:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang sedang ingin kulakukan adalah
Dialogue: 0,0:18:44.27,0:18:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihat seperti apa\Nanak-anak kelas satu tahun ini.
Dialogue: 0,0:18:48.86,0:18:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang termakan sama uang,\Nbisa kita jadikan kawan kapan saja.
Dialogue: 0,0:18:53.07,0:18:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan yang krusial justru\Nanak-anak selain mereka.
Dialogue: 0,0:18:57.07,0:19:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal, aku tidak berniat cari poin\Nkelas yang jadi uang jajan saja tidak cukup.
Dialogue: 0,0:19:02.58,0:19:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menghancurkan Kelas A
Dialogue: 0,0:19:05.21,0:19:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita hanya bisa menunggu saat\Npoin kelas naik turun dengan brutal.
Dialogue: 0,0:19:12.38,0:19:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:19:13.72,0:19:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pengunjung yang tidak biasa.
Dialogue: 0,0:19:16.30,0:19:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang, Shiina.
Dialogue: 0,0:19:18.34,0:19:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mau ada pembicaraan, jadi hari ini\Nmungkin akan sedikit ribut.
Dialogue: 0,0:19:23.14,0:19:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:19:24.56,0:19:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kurasa sebaiknya\Npakai kursi di belakang.
Dialogue: 0,0:19:28.10,0:19:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:29.61,0:19:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kelas C lancar?
Dialogue: 0,0:19:32.65,0:19:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sepertinya banyak yang sudah bergerak.
Dialogue: 0,0:19:37.61,0:19:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesampingkan soal Nanase,\Nmasalahnya bagaimana Hosen akan bergerak.
Dialogue: 0,0:19:42.29,0:19:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:43.58,0:19:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya akan banyak yang berubah kalau\Ndia muncul di sini atau tidak.
Dialogue: 0,0:19:47.67,0:19:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah menunggu, Kak.
Dialogue: 0,0:19:51.21,0:19:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan lagi, aku Horikita Suzune.
Dialogue: 0,0:19:53.92,0:19:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah meluangkan\Nwaktumu hari ini.
Dialogue: 0,0:19:56.47,0:19:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:19:57.63,0:19:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan.
Dialogue: 0,0:19:58.97,0:20:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama saya Nanase Tsubasa.
Dialogue: 0,0:20:01.80,0:20:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru saya yang harus berterima kasih.
Dialogue: 0,0:20:05.73,0:20:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung saja.
Dialogue: 0,0:20:07.39,0:20:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ingin kubahas hari ini,\Nbukan kontrak dengan bayaran poin.
Dialogue: 0,0:20:12.73,0:20:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mengerti.
Dialogue: 0,0:20:14.15,0:20:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan kerja sama untuk
Dialogue: 0,0:20:16.44,0:20:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saling membantu siswa dengan\Nakademik yang kurang.
Dialogue: 0,0:20:19.91,0:20:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:20.66,0:20:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu datang sadar akan hal itu,\Nberarti ada celah untuk negosiasi?
Dialogue: 0,0:20:25.75,0:20:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya harap memang ada.
Dialogue: 0,0:20:28.79,0:20:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ego yang begitu kuat di balik\Ncara pikir Hosen.
Dialogue: 0,0:20:34.38,0:20:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap begini,
Dialogue: 0,0:20:35.71,0:20:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siswa dengan akademik rendah\Ntidak akan dapat partner dan tertinggal.
Dialogue: 0,0:20:41.01,0:20:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, yang sebenarnya\Ntidak saya inginkan adalah
Dialogue: 0,0:20:43.64,0:20:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kelas jadi tidak bisa kompak jika\Nke depannya ego tersebut didahulukan.
Dialogue: 0,0:20:49.77,0:20:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:20:50.98,0:20:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semakin ego berada di depan,
Dialogue: 0,0:20:52.86,0:20:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semakin membuat kelasmu tidak siap\Njika nanti menghadapi ujian
Dialogue: 0,0:20:55.98,0:20:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mengharuskan persatuan kelas.
Dialogue: 0,0:20:58.36,0:20:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:59.28,0:21:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah secara terpisah saya\Nmengharapkan negosiasi ini demi kelas.
Dialogue: 0,0:21:06.29,0:21:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, akan kutanyakan sesuatu\Nyang lebih mendalam.
Dialogue: 0,0:21:09.46,0:21:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini ada berapa banyak siswa kelas 1-D\Nyang kesulitan mencari partner?
Dialogue: 0,0:21:15.71,0:21:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini sekitar 15 orang.
Dialogue: 0,0:21:19.09,0:21:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih banyak dari yang kupikirkan.
Dialogue: 0,0:21:21.97,0:21:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase, kalau misal diperbolehkan,
Dialogue: 0,0:21:24.76,0:21:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin menjalin kontrak besar\Ndengan kalian.
Dialogue: 0,0:21:27.43,0:21:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontrak besar, ya?
Dialogue: 0,0:21:30.64,0:21:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan dirimu, kita berdua akan\Nmenentukan 15 pasangan itu
Dialogue: 0,0:21:35.82,0:21:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ingin langsung\Nmendaftarkannya sekaligus.
Dialogue: 0,0:21:43.11,0:21:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa itu tawaran yang begitu bagus.
Dialogue: 0,0:21:46.37,0:21:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen pasti tidak akan setuju jika\Nmemberi bantuan tanpa imbalan.
Dialogue: 0,0:21:50.87,0:21:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:52.12,0:21:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya tidak ada ruginya untuk dia.
Dialogue: 0,0:21:54.63,0:21:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, saya rasa Hosen\Ntetap tidak akan setuju.
Dialogue: 0,0:21:59.63,0:22:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:22:00.80,0:22:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:22:04.14,0:22:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu hal\Nyang sekarang kutahu dari Hosen.
