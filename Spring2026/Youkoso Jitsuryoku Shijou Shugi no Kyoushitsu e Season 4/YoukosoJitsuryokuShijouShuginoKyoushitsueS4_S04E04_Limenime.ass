Dialogue: 0,0:01:54.60,0:02:00.39,tanda,,0000,0000,0000,,CLASSROOM OF THE ELITE 4TH SEASON:\NSECOND YEAR, FIRST SEMESTER
Dialogue: 0,0:03:04.42,0:03:11.01,tanda,,0000,0000,0000,,CLASSROOM OF THE ELITE 4TH SEASON:\NSECOND YEAR, FIRST SEMESTER
Dialogue: 0,0:03:15.17,0:03:18.72,tanda,,0000,0000,0000,,#4 KE MANA BILAH MENGARAH
Dialogue: 0,0:17:45.29,0:17:46.63,tanda,,0000,0000,0000,,PENGUMUMAN HASIL UJIAN KHUSUS\NMATEMATIKA
Dialogue: 0,0:17:46.63,0:17:47.80,tanda,,0000,0000,0000,,AYANOKOJI KIYOTAKA 100, HORIKITA SUZUNE 87\NYUKIMURA TERUHIKO 84, WANG MEIYU 80
Dialogue: 0,0:22:06.18,0:22:07.89,tanda,,0000,0000,0000,,PERINGKAT KESELURUHAN UJIAN KHUSUS\N1. KELAS 2-A, NILAI RATA-RATA 725
Dialogue: 0,0:22:07.89,0:22:09.89,tanda,,0000,0000,0000,,2. KELAS 2-C, NILAI RATA-RATA 673\N3. KELAS 2-D, NILAI RATA-RATA 640\N4. KELAS 2-B, NILAI RATA-RATA 621
Dialogue: 0,0:00:01.19,0:00:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus?
Dialogue: 0,0:00:02.77,0:00:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari cerita Nanase, katanya kalian\Nminta kerja sama dengan kelasku, ya?
Dialogue: 0,0:00:09.45,0:00:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit keliru.
Dialogue: 0,0:00:11.62,0:00:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bersedia kerja sama dengan kelasmu.
Dialogue: 0,0:00:15.70,0:00:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana tidak ada atas dan bawah,\Nhubungan kerja sama yang setara.
Dialogue: 0,0:00:20.42,0:00:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:00:22.54,0:00:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau bawa-bawa kalau\Nkalian kakak tingkat rupanya.
Dialogue: 0,0:00:27.17,0:00:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak main senioritas itu\Nkeputusan yang bijak.
Dialogue: 0,0:00:32.64,0:00:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalau di antara siswa kelas satu
Dialogue: 0,0:00:34.56,0:00:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada yang tidak peduli jika\Nteman sekelasnya mengalami kesulitan.
Dialogue: 0,0:00:39.94,0:00:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi,
Dialogue: 0,0:00:40.94,0:00:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke depannya pasti datang saat di mana\Nkekuatan pertemanan kelas akan dibutuhkan.
Dialogue: 0,0:00:45.48,0:00:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya bekerja sama biar\Ntidak dapat nilai merah.
Dialogue: 0,0:00:52.66,0:00:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tidak masalah kalau kau\Nkuanggap pemimpin Kelas 2-D?
Dialogue: 0,0:00:58.45,0:01:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan saja kalau mau dianggap begitu.
Dialogue: 0,0:01:01.21,0:01:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu biar kuberi\Nperingatan pada pemimpin itu.
Dialogue: 0,0:01:05.63,0:01:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali
Dialogue: 0,0:01:07.00,0:01:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak berniat bekerja sama yang\Ndikaburkan dengan kata "setara" begini.
Dialogue: 0,0:01:12.80,0:01:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini mengharap apa?
Dialogue: 0,0:01:15.26,0:01:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir aku akan\Nmengeluarkan poin pribadi?
Dialogue: 0,0:01:18.47,0:01:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti keluar.
Dialogue: 0,0:01:20.31,0:01:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan kau keluarkan.
Dialogue: 0,0:01:21.98,0:01:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pilihan lain\Nselain dikeluarkan, bukan?
Dialogue: 0,0:01:25.69,0:01:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuulangi lagi.
Dialogue: 0,0:01:27.69,0:01:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tawaran kali ini adalah setara.
Dialogue: 0,0:01:31.11,0:01:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada pihak yang\Nmemberi uang atau imbalan.
Dialogue: 0,0:01:36.08,0:01:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:01:38.66,0:01:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung pulang saja kalau begitu.
Dialogue: 0,0:03:18.72,0:03:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:03:20.55,0:03:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen, kurasa kita harus mendengar\Nbahasan Kak Horikita.
Dialogue: 0,0:03:26.10,0:03:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak perlu.
Dialogue: 0,0:03:28.81,0:03:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kita memang perlu.
Dialogue: 0,0:03:30.40,0:03:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap begini,\Nkelas kita tidak akan bisa bersatu.
Dialogue: 0,0:03:34.49,0:03:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini bodoh, ya?
Dialogue: 0,0:03:37.32,0:03:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada untungnya buat kita\Nmenuruti syarat mereka mentah-mentah.
Dialogue: 0,0:03:41.99,0:03:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strategi Hosen kurasa tidaklah buruk.
Dialogue: 0,0:03:46.25,0:03:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sengaja tidak bergerak dan\Nmengabaikan negosiasi di awal,
Dialogue: 0,0:03:49.50,0:03:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu agar tawarannya lebih menguntungkan.
Dialogue: 0,0:03:52.75,0:03:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba bilang apa untungnya kita\Nmembantu Horikita sekarang?
Dialogue: 0,0:03:57.34,0:03:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan saling percaya.
Dialogue: 0,0:03:59.76,0:04:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan saling percaya katamu?
Dialogue: 0,0:04:02.47,0:04:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata-kata manis yang enggak ada\Ngunanya sama sekali.
Dialogue: 0,0:04:06.93,0:04:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Hosen membuat kelas dua jadi musuh...
Dialogue: 0,0:04:10.19,0:04:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat diadakan ujian serupa di masa depan,
Dialogue: 0,0:04:13.23,0:04:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada kemungkinan situasi kita akan sulit\Ndapat partner meski sudah menyiapkan poin.
Dialogue: 0,0:04:19.02,0:04:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku akan takut\Ncuma karena bakal dapat penalti?
Dialogue: 0,0:04:23.78,0:04:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bagus kalau hanya begitu.
Dialogue: 0,0:04:26.45,0:04:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jadinya kalau partner yang didapat\Nsengaja tidak serius di ujian?
Dialogue: 0,0:04:30.12,0:04:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikeluarkan dari sekolah\Njadi tidak terhindari.
Dialogue: 0,0:04:33.67,0:04:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir ada yang berani\Nbunuh diri bersamaku?
Dialogue: 0,0:04:37.55,0:04:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sistem sekolah ini sepertinya punya\Nsesuatu yang disebut poin proteksi, ya?
Dialogue: 0,0:04:42.80,0:04:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:43.80,0:04:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa menganulir pengeluaran sekali.
Dialogue: 0,0:04:46.31,0:04:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah poin istimewa.
Dialogue: 0,0:04:48.35,0:04:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lawan yang jadi pasanganmu\Npunya poin proteksi.
Dialogue: 0,0:04:51.81,0:04:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya bunuh diri sama-sama,\Ntapi kamu bisa dikeluarkan secara sepihak.
Dialogue: 0,0:04:56.44,0:05:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah, bukankah sekarang perlu\Nuntuk membangun hubungan saling percaya?
Dialogue: 0,0:05:02.57,0:05:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:05:04.20,0:05:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bodoh, kalian sudah bersiap\Nuntuk memojokkanku, ya.
Dialogue: 0,0:05:08.41,0:05:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf saja walau kalian sudah\Nmemberiku masukan.
Dialogue: 0,0:05:12.29,0:05:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak berniat\Nbekerja sama dengan setara.
Dialogue: 0,0:05:15.79,0:05:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apa maumu?
Dialogue: 0,0:05:18.01,0:05:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak berniat untuk\Nberubah pikiran dari setara.
Dialogue: 0,0:05:21.80,0:05:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah paham betul itu.
Dialogue: 0,0:05:25.35,0:05:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mau bagaimanapun juga\Nitu rasanya tidak setara.
Dialogue: 0,0:05:31.31,0:05:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang sampai sejauh itu,
Dialogue: 0,0:05:33.15,0:05:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa katakan apa maumu\Nsebagai pertimbangan?
Dialogue: 0,0:05:36.82,0:05:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Poin pribadi sebanyak satu juta.
Dialogue: 0,0:05:40.07,0:05:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan padaku sebagai jaminan.
Dialogue: 0,0:05:43.32,0:05:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau nanti ada saatnya kami\Nbergantung pada kalian.
Dialogue: 0,0:05:46.83,0:05:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati akan kukembalikan semua.
Dialogue: 0,0:05:50.62,0:05:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau rasa percaya memang\Nsepenting yang kau bilang.
Dialogue: 0,0:05:54.58,0:05:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak ada apa-apanya, kan?
Dialogue: 0,0:05:58.05,0:06:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen mengajukan negosiasi dengan cerdas.
Dialogue: 0,0:06:02.05,0:06:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan sekadar berani kelahi.
Dialogue: 0,0:06:04.43,0:06:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti Ryuen, dia musuh tangguh\Nyang bisa memakai taktik licik.
Dialogue: 0,0:06:09.43,0:06:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang omonganmu bukannya tidak logis.
Dialogue: 0,0:06:13.14,0:06:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, syarat itu tidak bisa kami terima.
Dialogue: 0,0:06:16.27,0:06:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:06:18.02,0:06:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang kalau begitu.
Dialogue: 0,0:06:20.48,0:06:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah kuberi jalan keluar,\Ntapi negosiasinya kembali buntu.
Dialogue: 0,0:06:26.70,0:06:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:33.91,0:06:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:06:35.17,0:06:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti, Sudo!
Dialogue: 0,0:06:37.42,0:06:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bilang begitu pun...
Dialogue: 0,0:06:42.05,0:06:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kesal negosiasinya buntu,\Nbertindaklah dengan lebih bijak lagi.
Dialogue: 0,0:06:47.97,0:06:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:06:50.22,0:06:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin, nih?!
Dialogue: 0,0:06:55.06,0:06:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin, Hosen?
Dialogue: 0,0:07:04.36,0:07:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:07:06.70,0:07:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kamu terus minta yang tidak-tidak,
Dialogue: 0,0:07:10.16,0:07:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pemikiranku tidak akan berubah.
Dialogue: 0,0:07:12.58,0:07:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, baik.
Dialogue: 0,0:07:14.62,0:07:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuperintah anak kelas\Ndan kupasangkan dengan kalian.
Dialogue: 0,0:07:18.58,0:07:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya beri aku poin, sebanyak dua juta.
Dialogue: 0,0:07:22.80,0:07:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua juta?
Dialogue: 0,0:07:24.38,0:07:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar juga muka aslimu.
Dialogue: 0,0:07:26.59,0:07:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ini caranya untuk kalian\Nterhindar dari dikeluarkan.
Dialogue: 0,0:07:31.47,0:07:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya jadi pelit.
Dialogue: 0,0:07:34.35,0:07:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak bisa diterima.
Dialogue: 0,0:07:37.98,0:07:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:07:39.44,0:07:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupikirkan tawaran kalian tadi.
Dialogue: 0,0:07:42.44,0:07:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuanmu berubah pikiran sekarang?
Dialogue: 0,0:07:44.65,0:07:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengulur negosiasi sampai detik terakhir\Nbiar jadi untung itu hal wajar, bukan?
Dialogue: 0,0:07:50.03,0:07:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kamu akan setuju dengan\Nhubungan yang benar-benar setara, ya.
Dialogue: 0,0:07:54.50,0:07:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:55.70,0:07:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti pakai kekerasan\Ndan ganti dengan berunding.
Dialogue: 0,0:07:58.54,0:08:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di sini ada kemungkinan dilihat orang.
Dialogue: 0,0:08:01.63,0:08:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ganti tempat.
Dialogue: 0,0:08:03.46,0:08:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:08:04.84,0:08:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuberi waktu sepuluh menit.
Dialogue: 0,0:08:06.97,0:08:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:08.72,0:08:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuantar.
Dialogue: 0,0:08:12.97,0:08:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat dari kami sama seperti\Nyang kusebutkan tadi, oke?
Dialogue: 0,0:08:17.68,0:08:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:08:19.44,0:08:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga juta.
Dialogue: 0,0:08:21.94,0:08:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian membayarku segitu,\Nakan langsung kutolong anak-anak dungu itu.
Dialogue: 0,0:08:27.82,0:08:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda kau!
Dialogue: 0,0:08:29.82,0:08:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bercanda.
Dialogue: 0,0:08:32.03,0:08:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kuberi kesempatan\Nnegosiasi sekali lagi.
Dialogue: 0,0:08:37.53,0:08:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang salah sudah mencoba\Nuntuk mendengarkanmu.
Dialogue: 0,0:08:43.09,0:08:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzune!
Dialogue: 0,0:08:45.46,0:08:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang...
Dialogue: 0,0:08:56.47,0:09:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba tunjukkan sejauh mana\Nkau bisa meladeniku.
Dialogue: 0,0:09:01.44,0:09:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke kalau itu maumu.
Dialogue: 0,0:09:03.15,0:09:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berani menyerang Suzune.
Dialogue: 0,0:09:05.98,0:09:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kuberi ampun!
Dialogue: 0,0:09:12.11,0:09:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang...
Dialogue: 0,0:09:13.12,0:09:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau pikirkan?!
Dialogue: 0,0:09:15.12,0:09:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Horikita.
Dialogue: 0,0:09:17.16,0:09:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin situasi sekolah\Nsedikit berbeda dari sebelumnya.
Dialogue: 0,0:09:21.92,0:09:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami para siswa kelas satu lebih paham\Nsituasi saat ini dibanding kakak kelas.
Dialogue: 0,0:09:27.38,0:09:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?!
Dialogue: 0,0:09:28.88,0:09:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa perwakilan kami dari kelas satu
Dialogue: 0,0:09:32.47,0:09:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendapat penjelasan langsung\Ndari Ketua OSIS Nagumo.
Dialogue: 0,0:09:36.22,0:09:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai tahun ini sekolah akan\Nlebih menomorsatukan kemampuan.
Dialogue: 0,0:09:41.14,0:09:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:09:43.15,0:09:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi perkelahian juga diperbolehkan?!
Dialogue: 0,0:09:48.28,0:09:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sudo, coba lihat Horikita.
Dialogue: 0,0:09:52.15,0:09:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melihatmu dengan tatapan marah, lo.
Dialogue: 0,0:09:56.91,0:10:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan pengalaman bertarungnya\Nbukan bandingan untuk Sudo.
Dialogue: 0,0:10:01.54,0:10:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:10:02.87,0:10:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja Ryuen menghindarinya.
Dialogue: 0,0:10:14.72,0:10:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau adu otot, ya?
Dialogue: 0,0:10:16.72,0:10:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan ini tidak akan\Nmenguntungkan siapa-siapa!
Dialogue: 0,0:10:28.77,0:10:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Hosen betulan berpikir bisa mengubah\Narus dengan berkuasa lewat kekerasan?
Dialogue: 0,0:10:35.61,0:10:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kurasa dia tidak sebodoh itu\Nuntuk punya pemikiran begitu.
Dialogue: 0,0:10:40.95,0:10:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apa yang sesungguhnya\NHosen harapkan dari hasil perkelahian ini?
Dialogue: 0,0:10:48.38,0:10:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, pengawal yang bisa diandalkan\Nsekarang sudah lenyap!
Dialogue: 0,0:10:54.88,0:10:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir kami akan tunduk\Npada kekerasanmu?
Dialogue: 0,0:10:59.89,0:11:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhajar habis kalian di sini,
Dialogue: 0,0:11:02.81,0:11:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu kubuat menulis satu atau dua surat\Npermintaan maaf sambil berlinang air mata.
Dialogue: 0,0:11:07.02,0:11:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:11:08.52,0:11:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan menghentikanmu.
Dialogue: 0,0:11:10.77,0:11:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru menarik.
Dialogue: 0,0:11:13.11,0:11:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau berani maju,\Nakan kuterima dengan senang hati!
Dialogue: 0,0:11:25.46,0:11:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata gerakanmu...
Dialogue: 0,0:11:27.75,0:11:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}boleh juga!
Dialogue: 0,0:11:31.25,0:11:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Suzune!
Dialogue: 0,0:11:37.68,0:11:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Horikita, buatlah kontrak denganku.
Dialogue: 0,0:11:42.64,0:11:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima juta.
Dialogue: 0,0:11:44.98,0:11:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan itu semuanya\Nakan berakhir damai, kan?
Dialogue: 0,0:11:48.19,0:11:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan bercanda.
Dialogue: 0,0:11:51.23,0:11:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji, panggilkan guru!\NSiapa saja!
Dialogue: 0,0:11:54.82,0:11:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan.
Dialogue: 0,0:11:57.40,0:12:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau luka mereka akan lebih parah\Nberkali-kali lipat.
Dialogue: 0,0:12:04.33,0:12:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikita, kuberi kesempatan terakhir.
Dialogue: 0,0:12:07.29,0:12:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekarang mau tunduk\Ndan menyiapkan poin untukku,
Dialogue: 0,0:12:11.42,0:12:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji tidak akan kubunuh.
Dialogue: 0,0:12:15.51,0:12:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang mau kau...
Dialogue: 0,0:12:17.34,0:12:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bilang "no" pada kontrakku.
Dialogue: 0,0:12:20.84,0:12:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutusuk Ayanokoji dengan ini.
Dialogue: 0,0:12:24.10,0:12:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal demi poin, aku rela kalau cuma begini.
Dialogue: 0,0:12:28.73,0:12:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lebih dari ini!
Dialogue: 0,0:12:30.98,0:12:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya saya memang tidak bisa\Nmenyetujui caramu!
Dialogue: 0,0:12:34.48,0:12:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir, Nanase.
Dialogue: 0,0:12:36.69,0:12:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur.
Dialogue: 0,0:12:38.53,0:12:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kak Horikita.
Dialogue: 0,0:12:41.03,0:12:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal memang mustahil\Nuntuk bekerja sama dengan Hosen.
Dialogue: 0,0:12:44.28,0:12:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:45.37,0:12:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkataan Hosen membuat Kak Horikita\Nterpikir untuk hubungan kerja sama kali ini.
Dialogue: 0,0:12:51.25,0:12:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu semua sejak awal adalah\Nlangkah untuk membuat situasi ini.
Dialogue: 0,0:12:55.71,0:12:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi berisik sekali mulutmu.
Dialogue: 0,0:12:58.55,0:13:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melibas Ayanokoji,\Nkelas kita akan dapat uang yang melimpah.
Dialogue: 0,0:13:03.68,0:13:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas sekali kalau itu sangat menguntungkan.
Dialogue: 0,0:13:06.93,0:13:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:13:09.27,0:13:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saya masih belum bisa menilai
Dialogue: 0,0:13:11.06,0:13:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah Kak Ayanokoji memanglah\Nsiswa yang harus diincar atau tidak.
Dialogue: 0,0:13:16.78,0:13:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak ada hubungannya denganku.
Dialogue: 0,0:13:19.78,0:13:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau menghalangi.
Dialogue: 0,0:13:24.28,0:13:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku akan maju.
Dialogue: 0,0:13:26.62,0:13:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji!
Dialogue: 0,0:13:41.63,0:13:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek kau, Ayanokoji.
Dialogue: 0,0:13:45.05,0:13:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisau ini
Dialogue: 0,0:13:46.68,0:13:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau lebih tepatnya pisau dapur,\Nadalah barang yang kubeli.
Dialogue: 0,0:13:51.77,0:13:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?!
Dialogue: 0,0:13:54.06,0:13:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggiring ke tempat ini dan\Nmemicu perkelahian secara paksa.
Dialogue: 0,0:13:59.44,0:14:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang marah karena\Nteman-temanku disakiti
Dialogue: 0,0:14:02.74,0:14:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menusukmu dengan pisau yang\Nkusembunyikan untuk berjaga-jaga.
Dialogue: 0,0:14:07.03,0:14:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti itu, kan, rencanamu?
Dialogue: 0,0:14:10.29,0:14:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas sekali kalau melihat cara pegangmu\Nyang bukan untuk menusuk orang.
Dialogue: 0,0:14:14.88,0:14:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilahnya dihadapkan ke atas\Nagar terlihat kalau kau yang ditusuk.
Dialogue: 0,0:14:20.63,0:14:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah tahu soal itu...
Dialogue: 0,0:14:23.13,0:14:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah sengaja buat ditusuk,\Nkepalamu sudah gila, ya?
Dialogue: 0,0:14:26.60,0:14:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini cara terbaik\Nuntuk menggagalkannya.
Dialogue: 0,0:14:30.27,0:14:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak beda denganmu, kan?
Dialogue: 0,0:14:32.68,0:14:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri merencanakan ini\Nsudah siap untuk terluka parah.
Dialogue: 0,0:14:36.40,0:14:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya ada suatu ujian khusus\Nyang berjalan dan hanya diberikan
Dialogue: 0,0:14:41.69,0:14:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada sebagian kecil siswa kelas satu.
Dialogue: 0,0:14:46.78,0:14:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu isinya adalah membuat\Ndiriku dikeluarkan dari sekolah.
Dialogue: 0,0:14:53.12,0:14:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa tahu kalau ini pisaumu?
Dialogue: 0,0:14:57.42,0:15:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah sedikit menyelidiki.
Dialogue: 0,0:15:00.42,0:15:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kemarin,\Nhanya aku yang membeli pisau ini.
Dialogue: 0,0:15:04.88,0:15:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kau ini?
Dialogue: 0,0:15:06.84,0:15:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini apa sebenarnya?!
Dialogue: 0,0:15:08.47,0:15:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang mau bagaimana?
Dialogue: 0,0:15:10.35,0:15:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski pemiliknya aku,\Ntapi kau yang menusuk.
Dialogue: 0,0:15:14.64,0:15:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bisa mengelak,\Nkau akan dikeluarkan, Hosen.
Dialogue: 0,0:15:19.77,0:15:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tindakanmu itu karena\Nsudah membaca sampai sana.
Dialogue: 0,0:15:25.15,0:15:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji!
Dialogue: 0,0:15:26.66,0:15:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu tidak apa-apa?!
Dialogue: 0,0:15:28.87,0:15:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah khawatir.
Dialogue: 0,0:15:30.41,0:15:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau, sudah tahu sampai mana?!
Dialogue: 0,0:15:34.04,0:15:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang pertama kali membuatku curiga
Dialogue: 0,0:15:36.79,0:15:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Amasawa yang mengajakku\Nbelanja di pusat perbelanjaan.
Dialogue: 0,0:15:40.42,0:15:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amasawa?!
Dialogue: 0,0:15:41.96,0:15:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu dia terlibat di kejadian ini?!
Dialogue: 0,0:15:45.01,0:15:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:46.13,0:15:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegawai toko melihat dia menghentikan\NHosen untuk membeli pisau.
Dialogue: 0,0:15:52.85,0:15:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang merencanakan ini adalah dirimu.
Dialogue: 0,0:15:55.68,0:15:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang membuatnya lebih sempurna\Nadalah Amasawa.
Dialogue: 0,0:15:59.31,0:16:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan lebih meyakinkan kalau pisau\Nyang dijadikan senjata itu kubeli sendiri.
Dialogue: 0,0:16:04.57,0:16:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkara dia mencari karet rambut,
Dialogue: 0,0:16:07.03,0:16:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma karangan untuk bisa\Nmembawa pisaunya pergi.
Dialogue: 0,0:16:10.82,0:16:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu memberikannya pada Hosen\Ntanpa meninggalkan sidik jari.
Dialogue: 0,0:16:16.04,0:16:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengajak kerja sama cewek yang tidak\Nkukenal baik ternyata pilihan buruk.
Dialogue: 0,0:16:20.71,0:16:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:16:22.25,0:16:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Amasawa, strategi ini bisa terwujud.
Dialogue: 0,0:16:26.34,0:16:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan gagal kalau kau cuma sendiri.
Dialogue: 0,0:16:29.76,0:16:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen, kejadian ini bisa saja\Nkita tutupi di sini.
Dialogue: 0,0:16:35.52,0:16:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maumu?
Dialogue: 0,0:16:37.85,0:16:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebagai gantinya,\Naku punya dua syarat.
Dialogue: 0,0:16:43.11,0:16:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, menjalin hubungan kerja sama\Nyang setara antar sesama Kelas D.
Dialogue: 0,0:16:48.65,0:16:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kedua.
Dialogue: 0,0:16:50.11,0:16:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai partner untuk ujian khusus kali ini,
Dialogue: 0,0:16:53.45,0:16:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus berpasangan denganku.
Dialogue: 0,0:16:57.16,0:17:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen adalah kandidat partner\Nyang paling cocok.
Dialogue: 0,0:17:01.37,0:17:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia dari White Room,
Dialogue: 0,0:17:03.17,0:17:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sulit dibayangkan kalau akan\Nmengambil langkah semencolok itu.
Dialogue: 0,0:17:08.47,0:17:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, bagus, Kak Ayanokoji.
Dialogue: 0,0:17:12.47,0:17:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini ada lawan yang\Nmembuat hatiku berdebar.
Dialogue: 0,0:17:15.97,0:17:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu tidak akan seru kalau\Nbisa kalah hanya dengan tangan.
Dialogue: 0,0:17:20.52,0:17:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh habis dirimu,\Njadi nantikan saja.
Dialogue: 0,0:17:27.90,0:17:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari Senin besoknya,
Dialogue: 0,0:17:32.32,0:17:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hubungan kerja sama yang setara\Nterjalin dan seluruh pasangan terbentuk.
Dialogue: 0,0:17:37.24,0:17:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian khusus pun selesai tanpa masalah,
Dialogue: 0,0:17:39.95,0:17:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tibalah hari pengumuman\Nhasil ujian di tanggal 1 Mei.
Dialogue: 0,0:17:48.38,0:17:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan berdalih.
Dialogue: 0,0:17:50.55,0:17:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun kesal.
Dialogue: 0,0:17:52.34,0:17:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjadi dua hal beruntun yang membuatku\Nmau tidak mau harus mengakui dirimu.
Dialogue: 0,0:17:58.39,0:18:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang kalah di pertandingan kita.
Dialogue: 0,0:18:00.81,0:18:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang lebih penting, ini soal Nanase.
Dialogue: 0,0:18:05.31,0:18:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sikap ramahnya mendekati kita,\Nsemua adalah sandiwara?
Dialogue: 0,0:18:10.49,0:18:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya memang berpikir untuk\Nbekerja sama dengan Kak Horikita.
Dialogue: 0,0:18:14.91,0:18:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja.
Dialogue: 0,0:18:16.45,0:18:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strategi untuk mengincar Kak Ayanokoji\Nadalah prioritas utama.
Dialogue: 0,0:18:21.62,0:18:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa begitu?
Dialogue: 0,0:18:24.50,0:18:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji Kiyotaka dari Kelas 2-D.
Dialogue: 0,0:18:27.84,0:18:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun siswa yang bisa\Nmengeluarkannya dari sekolah,
Dialogue: 0,0:18:31.05,0:18:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan diberi 20 juta poin pribadi.
Dialogue: 0,0:18:34.26,0:18:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami diberikan ujian khusus seperti itu.
Dialogue: 0,0:18:39.35,0:18:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?!
Dialogue: 0,0:18:41.85,0:18:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang menentukan\Nujian tidak masuk akal seperti itu?!
Dialogue: 0,0:18:48.86,0:18:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sudah menyampaikan\Napa yang perlu disampaikan.
Dialogue: 0,0:18:52.53,0:18:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini bukankah Kak Ayanokoji\Nakan sangat waspada terhadap
Dialogue: 0,0:18:57.24,0:19:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seluruh kelas satu selain kelas kami?
Dialogue: 0,0:19:01.37,0:19:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin kami puas dengan jawaban itu!
Dialogue: 0,0:19:04.58,0:19:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji sudah...
Dialogue: 0,0:19:05.87,0:19:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:19:07.50,0:19:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengetahui situasi itu saja\Nsudah sangat disyukuri.
Dialogue: 0,0:19:11.88,0:19:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, alasan saya membantu Hosen\Nbukan hanya itu saja.
Dialogue: 0,0:19:17.80,0:19:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku merasa Kak Ayanokoji\Nbukanlah orang yang pantas di sekolah ini.
Dialogue: 0,0:19:25.10,0:19:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bahasannya benar.
Dialogue: 0,0:19:27.40,0:19:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di sini rupanya.
Dialogue: 0,0:19:29.65,0:19:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji.
Dialogue: 0,0:19:32.44,0:19:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku akan pulang saja.
Dialogue: 0,0:19:34.40,0:19:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal janji saat ujian,\Nkita bicarakan saja lagi besok.
Dialogue: 0,0:19:39.16,0:19:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa denganku?
Dialogue: 0,0:19:41.53,0:19:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Yayasan Sementara\NTsukishiro memanggilmu.
Dialogue: 0,0:19:45.66,0:19:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan April sudah berakhir.
Dialogue: 0,0:19:49.54,0:19:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu sudah tahu siapa\Nsiswa yang kukirim?
Dialogue: 0,0:19:54.55,0:19:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:19:56.05,0:19:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung kamu jawab begitu saja.
Dialogue: 0,0:19:59.34,0:20:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak yakin, tidak akan saya katakan.
Dialogue: 0,0:20:03.01,0:20:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:20:05.06,0:20:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti anak itu berhasil\Nmembaur dengan baik.
Dialogue: 0,0:20:10.06,0:20:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura khas siswa White Room\Nsama sekali tidak kurasakan.
Dialogue: 0,0:20:15.24,0:20:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintar sekali dia menutupi baunya.
Dialogue: 0,0:20:17.95,0:20:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam beberapa bulan ini.
Dialogue: 0,0:20:20.16,0:20:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah menjalani kurikulum untuk\Nberperan jadi siswa SMA.
Dialogue: 0,0:20:25.75,0:20:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang,\NAyanokoji tidak bisa menebaknya.
Dialogue: 0,0:20:30.42,0:20:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa memastikan itu anggap saja sudah bagus.
Dialogue: 0,0:20:34.42,0:20:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa kalau kamu undur diri.
Dialogue: 0,0:20:37.01,0:20:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi masalah di luar dugaan?
Dialogue: 0,0:20:40.72,0:20:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu punya dasarnya?
Dialogue: 0,0:20:45.06,0:20:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertentangan dengan rencana\NKepala Yayasan Sementara Tsukishiro,
Dialogue: 0,0:20:48.73,0:20:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siswa White Room malah\Ntidak mengikuti perintah.
Dialogue: 0,0:20:52.48,0:20:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya masuk akal\Nkalau dipikir seperti itu.
Dialogue: 0,0:20:55.53,0:21:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini memang bisa saja\Nmengeluarkan pemikiran yang menarik.
Dialogue: 0,0:21:00.49,0:21:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kuakui.
Dialogue: 0,0:21:04.45,0:21:09.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini anak itu memang mengabaikan\Nrencana yang kubuat.
Dialogue: 0,0:21:09.71,0:21:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, Ayanokoji.
Dialogue: 0,0:21:12.54,0:21:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, yang menentukan\Nsiswa White Room yang dikirim...
Dialogue: 0,0:21:16.92,0:21:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah diriku.
Dialogue: 0,0:21:19.51,0:21:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kemungkinan para atasan punya\Nsuatu rencana yang mencurigakan.
Dialogue: 0,0:21:26.26,0:21:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Tsukishiro dan siswa White Room\Nbukanlah satu kubu, ya.
Dialogue: 0,0:21:31.81,0:21:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin.
Dialogue: 0,0:21:33.40,0:21:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga tipuan untuk membingungkanku.
Dialogue: 0,0:21:36.27,0:21:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika misalkan anak itu
Dialogue: 0,0:21:38.40,0:21:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan mengabaikan kehendak ayahandamu...
Dialogue: 0,0:21:43.03,0:21:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi memilih untuk dikeluarkan\Nakan lebih bahagia.
Dialogue: 0,0:21:48.75,0:21:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena rasa iri dan benci yang ditujukan\Npadamu sebagai ciptaan terbaik White Room
Dialogue: 0,0:21:54.08,0:21:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangatlah tak terukur.
Dialogue: 0,0:21:57.67,0:22:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caramu untuk\Nmembuat anak itu bisa terima?
Dialogue: 0,0:22:02.09,0:22:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memikirkannya saja sudah membuat takut.
