Dialogue: 0,0:03:27.82,0:03:34.37,tanda-5,signs,0,0,0,,{\fad(660,480)\fs75\bord0\shad3\pos(960,896)}#7  Manuver Rahasia
Dialogue: 0,0:00:02.36,0:00:04.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya baru Yagami, ya.
Dialogue: 0,0:00:04.78,0:00:06.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Halo, Utomiya.
Dialogue: 0,0:00:06.74,0:00:10.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Entah kenapa aku sudah merasa\Nkalau perwakilan Kelas C itu kamu.
Dialogue: 0,0:00:10.99,0:00:13.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal jadi pemimpin bukan gayaku.
Dialogue: 0,0:00:13.45,0:00:17.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin karena tahu kalau kamu\Nsiswa yang cukup bisa diandalkan.
Dialogue: 0,0:00:17.58,0:00:19.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami sudah kehilangan seorang teman.
Dialogue: 0,0:00:19.79,0:00:23.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dan kurasa itu kehilangan yang cukup besar.
Dialogue: 0,0:00:23.13,0:00:26.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga tidak mengira Hatano\Nakan dikeluarkan dari sekolah.
Dialogue: 0,0:00:26.55,0:00:28.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sangat disayangkan, ya.
Dialogue: 0,0:00:28.51,0:00:29.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:30.43,0:00:32.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menurutmu apa Hosen akan datang?
Dialogue: 0,0:00:32.60,0:00:35.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin setengah iya setengah tidak.
Dialogue: 0,0:00:35.10,0:00:37.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tebakanku dia tidak akan datang.
Dialogue: 0,0:00:37.14,0:00:41.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelas D pasti akan terus menuntut poin\Nkalau mau diajak gabung kerja sama.
Dialogue: 0,0:00:41.10,0:00:42.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Justru karena itu!
Dialogue: 0,0:00:42.61,0:00:47.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak muncul di sini, bisa dipastikan\Ngrup akan dibentuk tanpa Kelas D.
Dialogue: 0,0:00:47.74,0:00:52.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, mereka bakal tertinggal\Nkarena sudah jual mahal.
Dialogue: 0,0:00:52.95,0:00:54.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, Riku sama Takuya!
Dialogue: 0,0:00:54.99,0:00:56.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata memang kalian.
Dialogue: 0,0:00:56.74,0:01:00.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Osamu dipaksa mengurus\Nmasalah merepotkan lagi, ya.
Dialogue: 0,0:01:00.71,0:01:04.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pemimpin kami memang malas\Nkalau harus repot.
Dialogue: 0,0:01:04.17,0:01:06.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sudah begini jadi jatahku.
Dialogue: 0,0:01:06.00,0:01:08.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisanya tinggal Kazuomi, ya?
Dialogue: 0,0:01:08.38,0:01:11.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa langsung saja grupnya dibentuk\Ndari kelas kita bertiga?
Dialogue: 0,0:01:11.72,0:01:15.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ujian pulau tak berpenghuni katanya juga\Nmenuntut kemampuan selain akademik.
Dialogue: 0,0:01:16.18,0:01:20.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelas D mungkin terbawah, tapi fisik mereka\Nbeda tipis dengan peringkat satu.
Dialogue: 0,0:01:20.43,0:01:24.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seharusnya akan memegang peran penting\Ndalam membentuk grup.
Dialogue: 0,0:01:24.52,0:01:26.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku paham yang mau Riku sampaikan.
Dialogue: 0,0:01:26.77,0:01:30.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelas A kami juga kesal dengan sikap Kazuomi\Nyang meminta poin
Dialogue: 0,0:01:30.65,0:01:32.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}agar mau diajak gabung kerja sama.
Dialogue: 0,0:01:32.95,0:01:36.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, bukankah terlalu dini\Nuntuk mengabaikannya?
Dialogue: 0,0:01:36.03,0:01:39.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuakui kalau Kelas D punya daya tempur.
Dialogue: 0,0:01:39.41,0:01:43.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi bukan yang sampai harus\Nmengambil hati Hosen dulu.
Dialogue: 0,0:01:43.54,0:01:47.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kurasa tidak akan semudah itu, Riku.
Dialogue: 0,0:03:20.76,0:03:23.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah mau kasih poin sekarang?
Dialogue: 0,0:03:23.22,0:03:25.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bercandamu itu tidak lucu.
Dialogue: 0,0:03:25.10,0:03:27.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tak ada sepeser pun poin\Nyang akan diberikan padamu.
Dialogue: 0,0:03:28.34,0:03:30.11,Default Above,,0,0,0,,{\blur3}{\fad(00,40)}Sudah, tenang dulu.
Dialogue: 0,0:03:30.11,0:03:33.98,Default Above,,0,0,0,,{\blur3}{\fad(00,40)}Mana bisa berdiskusi kalau\Ndari awal sudah siap berkelahi.
Dialogue: 0,0:03:33.98,0:03:37.24,Default Above,,0,0,0,,{\blur3}{\fad(00,40)}Karena semua sudah kumpul,\Nayo kita mulai saja.
Dialogue: 0,0:03:37.74,0:03:40.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan seenaknya dimulai sendiri, woi!
Dialogue: 0,0:03:41.24,0:03:45.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hosen, bisa berhenti\Nbawa-bawa kekerasan ke sini?
Dialogue: 0,0:03:45.12,0:03:48.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hah?\NCeritanya mau menghalangiku, nih?
Dialogue: 0,0:03:48.12,0:03:50.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kulakukan kalau dibutuhkan.
Dialogue: 0,0:03:50.21,0:03:51.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Heh, menarik.
Dialogue: 0,0:03:51.88,0:03:54.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coba tunjukkan kalau begitu.
Dialogue: 0,0:03:55.97,0:03:57.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar konyol.
Dialogue: 0,0:03:57.47,0:04:01.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kalau itu maumu,\Nbisa saja kubuktikan di sini.
Dialogue: 0,0:04:01.30,0:04:02.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya saja,
Dialogue: 0,0:04:02.97,0:04:07.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}itu kalau kau mau janji tidak akan\Nmengganggu teman sekelasku lagi.
Dialogue: 0,0:04:07.35,0:04:10.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Woi, woi, apa maksudmu itu?
Dialogue: 0,0:04:10.65,0:04:14.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menebak ada yang sudah\Nmembuat Hatano dikeluarkan.
Dialogue: 0,0:04:14.11,0:04:15.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terus itu aku?
Dialogue: 0,0:04:15.44,0:04:17.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang siapa lagi kalau bukan dirimu?
Dialogue: 0,0:04:17.39,0:04:19.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian berdua tenang dulu!
Dialogue: 0,0:04:19.52,0:04:23.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang kita harus fokus pada\Nbertahan hidup di pulau tak berpenghuni.
Dialogue: 0,0:04:23.45,0:04:26.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa yang bilang bakal ikut diskusinya?
Dialogue: 0,0:04:26.41,0:04:30.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu alasanmu datang ke sini\Napa sekadar mengisi waktu luang?
Dialogue: 0,0:04:30.21,0:04:31.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kubilang iya?
Dialogue: 0,0:04:32.46,0:04:34.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak akan percaya.
Dialogue: 0,0:04:34.38,0:04:36.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena kamu tidak sebodoh itu.
Dialogue: 0,0:04:36.80,0:04:41.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik kelas dua dan tiga, masing-masing\Nsudah pernah menjalaninya satu kali.
Dialogue: 0,0:04:41.55,0:04:45.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kita harus menghadapinya dengan\Nkondisi sangat tidak menguntungkan.
Dialogue: 0,0:04:45.22,0:04:49.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak bisa berkoordinasi,\Nbisa jadi malah dimangsa secara sepihak.
Dialogue: 0,0:04:49.60,0:04:52.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ocehanmu lembek sekali, Yagami.
Dialogue: 0,0:04:52.35,0:04:56.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau kelas dua atau tiga,\Naku yakin bisa mengalahkan mereka.
Dialogue: 0,0:04:56.57,0:05:00.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak semua orang bisa beruntung\Nseperti dirimu.
Dialogue: 0,0:05:00.20,0:05:04.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa disembunyikan kalau nyatanya\Nkelas satu kalah di keseluruhan kemampuan.
Dialogue: 0,0:05:04.58,0:05:09.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk itu, kelas satu harus kerja sama\Nmembuat grup kuat berisi empat orang
Dialogue: 0,0:05:09.46,0:05:12.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan menurutku minimal kita harus bikin satu.
Dialogue: 0,0:05:12.71,0:05:14.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti kata Hosen tadi.
Dialogue: 0,0:05:14.92,0:05:19.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita kumpulkan siswa yang tidak akan kalah\Nmeski lawannya adalah kakak kelas.
Dialogue: 0,0:05:19.63,0:05:25.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berarti kita tidak akan berebut poin kelas\Ndi ujian khusus ini, begitu maksudmu?
Dialogue: 0,0:05:25.14,0:05:26.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:26.18,0:05:29.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berbeda dari kakak kelas yang\Ntinggal punya sedikit waktu hingga lulus.
Dialogue: 0,0:05:29.81,0:05:32.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita masih punya banyak sisa waktu.
Dialogue: 0,0:05:32.48,0:05:36.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena itulah, justru sekarang saatnya\Nmengabaikan poin kelas.
Dialogue: 0,0:05:36.40,0:05:39.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untungnya begitu tipis untuk sampai\Nbekerja sama dengan kelas lain.
Dialogue: 0,0:05:39.90,0:05:43.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu tidak seberapa dibanding\Njadi mangsa kakak kelas.
Dialogue: 0,0:05:43.74,0:05:46.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, tunggu sebentar, Takuya.
Dialogue: 0,0:05:46.28,0:05:47.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa cuma satu?
Dialogue: 0,0:05:47.91,0:05:51.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mempertimbangkan bisa\Nmenggabung grup di saat ujian,
Dialogue: 0,0:05:51.08,0:05:54.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}bukankah lebih baik membuat\Nbanyak grup kuat?
Dialogue: 0,0:05:54.83,0:05:56.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu itu benar sekali.
Dialogue: 0,0:05:56.92,0:06:01.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kalau mau begitu dari awal,\Ndaya tempur akan terpecah-pecah.
Dialogue: 0,0:06:01.30,0:06:03.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, membuat grup terkuat\Ndengan empat orang
Dialogue: 0,0:06:03.38,0:06:06.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}demi mengamankan peringkat satu\Njadi lebih utama.
Dialogue: 0,0:06:06.35,0:06:10.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena kakak kelas hanya bisa bekerja sama\Ndi grup berisi 3 orang dari 3 kelas.
Dialogue: 0,0:06:10.93,0:06:15.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Asal dapat peringkat satu,\Nsisanya diabaikan juga tidak masalah, ya.
Dialogue: 0,0:06:15.98,0:06:19.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau melepas Hosen dan\Nbekerja sama dengan tiga kelas.
Dialogue: 0,0:06:19.07,0:06:21.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadinya akan sama saja dengan angkatan lain.
Dialogue: 0,0:06:21.61,0:06:24.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hak istimewa membuat\Ngrup kecil berisi 4 orang
Dialogue: 0,0:06:24.28,0:06:27.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}yang hanya diberikan pada kita\Nanak kelas satu.
Dialogue: 0,0:06:27.20,0:06:30.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sayang rasanya kalau hal ini\Nkita abaikan begitu saja.
Dialogue: 0,0:06:30.45,0:06:32.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi aku minta bantuanmu.
Dialogue: 0,0:06:34.29,0:06:37.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oke, biar kubantu.
Dialogue: 0,0:06:37.46,0:06:39.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa maumu, Hosen?
Dialogue: 0,0:06:39.59,0:06:41.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa mauku?
Dialogue: 0,0:06:41.96,0:06:46.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah aku cuma mengiyakan\Npermintaan manisnya untuk kerja sama.
Dialogue: 0,0:06:46.34,0:06:48.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa beri tahu syaratnya?
Dialogue: 0,0:06:48.43,0:06:54.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dua posisi kosong di grup besar nanti,\Nharus diisi anak Kelas D.
Dialogue: 0,0:06:54.18,0:06:56.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini syarat wajibnya.
Dialogue: 0,0:06:56.35,0:06:57.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:57.52,0:07:01.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kita masih belum tahu apakah bisa\Nbebas membuat grup besar atau tidak.
Dialogue: 0,0:07:01.73,0:07:05.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kubilang, kan, ini syarat wajib.
Dialogue: 0,0:07:05.74,0:07:07.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:07:07.07,0:07:09.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak bisa memasukkan\Ndua anak Kelas D,
Dialogue: 0,0:07:09.58,0:07:11.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}harus kita selesaikan\Ndengan empat orang, ya.
Dialogue: 0,0:07:11.99,0:07:13.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan bercanda, dong, Hosen!
Dialogue: 0,0:07:13.95,0:07:15.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bercanda!
Dialogue: 0,0:07:15.08,0:07:17.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak suka, kau saja yang cabut.
Dialogue: 0,0:07:17.75,0:07:19.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berengsek.
Dialogue: 0,0:07:19.13,0:07:21.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tenangkan dirimu, Utomiya.
Dialogue: 0,0:07:21.55,0:07:24.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sendiri tidak masalah dengan syarat itu.
Dialogue: 0,0:07:24.30,0:07:28.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang harus diprioritaskan adalah\Nkita berempat bisa bersatu.
Dialogue: 0,0:07:28.34,0:07:31.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sudah diberi hati,\Nnanti dia minta jantung.
Dialogue: 0,0:07:31.68,0:07:36.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, apa ada yang akan berubah\Njika Kelas D kita buang di sini?
Dialogue: 0,0:07:36.31,0:07:37.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau itu...
Dialogue: 0,0:07:37.98,0:07:42.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Membuat kelas satu menang\Nadalah yang terpenting dari ujian ini.
Dialogue: 0,0:07:42.11,0:07:44.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu tidak akan\Nmemberi kerugian apa pun.
Dialogue: 0,0:07:44.40,0:07:46.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga setuju, Riku.
Dialogue: 0,0:07:46.49,0:07:50.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku paham perasaanmu,\Ntapi kelas satu harus bisa kerja sama dulu.
Dialogue: 0,0:07:50.20,0:07:53.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi tidak boleh minta lebih dari itu.
Dialogue: 0,0:07:53.45,0:07:54.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Paham, Hosen?!
Dialogue: 0,0:07:56.08,0:07:57.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sesukamu saja.
Dialogue: 0,0:08:07.09,0:08:09.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana kalau kita ke kamar Yukimu?
Dialogue: 0,0:08:09.97,0:08:13.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak masalah, tapi kita ini\Nmau belajar kelompok, bukannya main.
Dialogue: 0,0:08:13.51,0:08:15.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu, kok.
Dialogue: 0,0:08:15.14,0:08:18.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayanokoji, bisa minta waktu sebentar?
Dialogue: 0,0:08:18.60,0:08:19.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:08:19.69,0:08:24.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya ada anak kelas satu\Nyang ingin ketemu Ayanokoji.
Dialogue: 0,0:08:24.27,0:08:26.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang kayaknya tidak bisa, ya?
Dialogue: 0,0:08:26.57,0:08:27.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa, nih?
Dialogue: 0,0:08:27.90,0:08:31.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan-jangan Kiyopon mau\Nditembak sama adik kelas?
Dialogue: 0,0:08:31.45,0:08:32.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:08:32.45,0:08:34.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:08:34.58,0:08:38.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau iya, mau tidak mau\Nharus kita beri izin, kan?
Dialogue: 0,0:08:38.87,0:08:40.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memangnya begitu?
Dialogue: 0,0:08:41.03,0:08:46.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, begini, yang mau ketemu itu\Nsayangnya cowok.
Dialogue: 0,0:08:46.46,0:08:47.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:08:47.92,0:08:49.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukannya tidak masalah.
Dialogue: 0,0:08:49.42,0:08:52.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Toh, bersosialisasi\Ndengan kelas satu itu baik.
Dialogue: 0,0:08:52.80,0:08:54.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:08:54.26,0:08:58.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apalagi grup kita kurang jago\Nsoal hubungan sosial.
Dialogue: 0,0:08:58.52,0:08:59.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:08:59.85,0:09:03.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau memang begitu,\Nkurasa tidak apa-apa dibiarkan ikut.
Dialogue: 0,0:09:03.98,0:09:06.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:09:07.48,0:09:10.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya dia sudah jalan ke sini.
Dialogue: 0,0:09:10.28,0:09:11.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita tunggu di sini saja, yuk.
Dialogue: 0,0:09:11.86,0:09:16.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski begitu, kamu sudah akrab\Ndengan anak kelas satu, ya.
Dialogue: 0,0:09:16.70,0:09:19.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, ini sudah bulan Juli, lo.
Dialogue: 0,0:09:19.41,0:09:22.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kurasa sudah banyak waktu\Nyang tersedia buat itu.
Dialogue: 0,0:09:22.08,0:09:26.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayanokoji sendiri sudah punya teman\Ndari anak kelas satu, kan?
Dialogue: 0,0:09:26.88,0:09:29.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masih belum ada yang bisa kusebut teman.
Dialogue: 0,0:09:29.84,0:09:31.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Be-Begitu ternyata.
Dialogue: 0,0:09:32.30,0:09:35.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, tidak perlu buru-buru juga.
Dialogue: 0,0:09:35.14,0:09:36.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baru mulai dari sekarang.
Dialogue: 0,0:09:36.85,0:09:38.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kak Kushida!
Dialogue: 0,0:09:38.68,0:09:42.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia anak yang bilang mau ketemu Ayanokoji,\Nnamanya Yagami.
Dialogue: 0,0:09:42.48,0:09:44.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Salam kenal, Kak Ayanokoji.
Dialogue: 0,0:09:45.52,0:09:48.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih sudah mau meluangkan waktu.
Dialogue: 0,0:09:48.94,0:09:52.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak salah, dari Kelas 1-B, ya.
Dialogue: 0,0:09:52.20,0:09:52.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:53.24,0:09:55.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namaku Yagami Takuya.
Dialogue: 0,0:09:56.83,0:10:01.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya ada yang ingin\Nkusampaikan ke Kak Ayanokoji.
Dialogue: 0,0:10:02.16,0:10:06.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kakak sudah tahu soal ujian khusus\Nyang diberitahukan dengan
Dialogue: 0,0:10:06.25,0:10:09.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}sangat terbatas pada anak kelas satu, bukan?
Dialogue: 0,0:10:09.76,0:10:15.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anu, aku sama sekali tidak tahu\Nsoal apa itu.
Dialogue: 0,0:10:15.05,0:10:17.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa tidak masalah kalau kuceritakan?
Dialogue: 0,0:10:17.22,0:10:19.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, aku tidak punya hak menghentikanmu.
Dialogue: 0,0:10:20.02,0:10:22.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua bermula tidak lama\Nsetelah masuk sekolah
Dialogue: 0,0:10:22.98,0:10:25.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}dari pemberitahuan Ketua OSIS Nagumo.
Dialogue: 0,0:10:25.73,0:10:28.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa saja, dengan cara apa pun,\Njika bisa mengeluarkan
Dialogue: 0,0:10:28.98,0:10:31.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kak Ayanokoji dari sekolah\Nsebelum semester dua,
Dialogue: 0,0:10:31.61,0:10:33.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}akan diberi bayaran 20 juta poin.
Dialogue: 0,0:10:33.99,0:10:37.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, membuat Ayanokoji dikeluarkan?!
Dialogue: 0,0:10:37.07,0:10:40.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah begitu 20 juta poin itu\Nuang yang sangat besar.
Dialogue: 0,0:10:40.04,0:10:42.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memangnya itu diizinkan?
Dialogue: 0,0:10:42.04,0:10:44.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang kami pun tahu.
Dialogue: 0,0:10:44.41,0:10:47.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau ini ujian khusus yang tidak biasa.
Dialogue: 0,0:10:47.25,0:10:53.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena tidak tertarik pada imbalan yang\Npada akhirnya harus menjatuhkan seseorang,
Dialogue: 0,0:10:53.09,0:10:55.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}jadi aku tidak berniat\Nikut serta sama sekali.
Dialogue: 0,0:10:55.68,0:10:59.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, kenapa harus Ayanokoji?
Dialogue: 0,0:10:59.30,0:11:03.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ketua OSIS bilang kalau dipilih\Nsecara acak dari siswa kelas dua.
Dialogue: 0,0:11:03.02,0:11:08.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, bukankah ujian khusus yang tidak\Ndiakui sekolah itu rasanya janggal?
Dialogue: 0,0:11:08.44,0:11:11.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat diberi tahu Ketua OSIS.
Dialogue: 0,0:11:11.02,0:11:15.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada Kepala Yayasan Sementara Tsukishiro\Nyang hadir sebagai saksi.
Dialogue: 0,0:11:15.86,0:11:20.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau situasinya begitu, rasanya wajar\Njika menerimanya sebagai ujian khusus.
Dialogue: 0,0:11:20.08,0:11:22.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau Kepala Yayasan Sementara yang bilang.
Dialogue: 0,0:11:22.62,0:11:25.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, rasanya benar juga.
Dialogue: 0,0:11:25.58,0:11:28.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siswa kelas satu yang ada di sana,
Dialogue: 0,0:11:28.25,0:11:31.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}mulai dari kelas A adalah\NTakahashi Osamu dan Ishigami Kyo.
Dialogue: 0,0:11:31.13,0:11:35.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari kelas B ada aku,\Nkelas C ada Utomiya Riku.
Dialogue: 0,0:11:35.34,0:11:41.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu dari kelas D ada Hosen Kazuomi\Ndan Nanase Tsubasa, totalnya enam orang.
Dialogue: 0,0:11:41.22,0:11:44.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa kepikiran untuk\Nmenceritakannya padaku?
Dialogue: 0,0:11:44.06,0:11:48.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena dengar kalau Hosen sudah\Nbertindak duluan dan gagal.
Dialogue: 0,0:11:48.98,0:11:52.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dan sepertinya itu\Nlangkah yang sangat kejam.
Dialogue: 0,0:11:52.44,0:11:54.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, tidak bisa kusangkal.
Dialogue: 0,0:11:54.86,0:11:56.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu ada satu lagi.
Dialogue: 0,0:11:56.99,0:11:59.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dibiarkan begini,\Nbukan cuma Kak Ayanokoji.
Dialogue: 0,0:11:59.95,0:12:06.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tergantung situasinya, bisa saja Kak Kushida\Njuga kena dampaknya sebagai teman sekelas.
Dialogue: 0,0:12:06.08,0:12:07.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih atas ceritamu.
Dialogue: 0,0:12:07.91,0:12:11.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi mungkin saja berbahaya kalau\Nmenceritakannya padaku.
Dialogue: 0,0:12:11.42,0:12:13.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yagami tidak apa-apa?
Dialogue: 0,0:12:13.80,0:12:15.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau misalnya ketahuan...
Dialogue: 0,0:12:15.38,0:12:17.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak apa-apa, Kak Kushida.
Dialogue: 0,0:12:17.59,0:12:20.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Toh, tidak diberi tahu\Nada penalti khusus atau apa.
Dialogue: 0,0:12:20.51,0:12:24.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu aku sudah siap kalau misalkan\Ndibenci di kalangan kelas satu.
Dialogue: 0,0:12:24.51,0:12:27.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejak awal juga sudah ditakdirkan\Nuntuk beradu dengan kelas lain.
Dialogue: 0,0:12:28.56,0:12:31.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong hati-hati, Kak Ayanokoji.
Dialogue: 0,0:12:31.61,0:12:32.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:32.56,0:12:36.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi menurut Yagami,\Nsiapa yang harus diwaspadai?
Dialogue: 0,0:12:37.40,0:12:41.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga, normalnya akan berpikir Hosen.
Dialogue: 0,0:12:41.45,0:12:44.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kalau kalau harus menunjuk satu nama.
Dialogue: 0,0:12:44.16,0:12:46.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, tidak, tidak jadi kuteruskan saja.
Dialogue: 0,0:12:46.37,0:12:48.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, kenapa?
Dialogue: 0,0:12:48.16,0:12:50.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku jadi penasaran.
Dialogue: 0,0:12:50.29,0:12:52.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau menyebut satu nama di sini,
Dialogue: 0,0:12:52.50,0:12:55.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}tentu kakak sekalian\Nakan mewaspadainya, kan?
Dialogue: 0,0:12:55.25,0:12:58.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebagai sesama anak kelas satu,\Nkurasa itu tidak adil.
Dialogue: 0,0:12:58.97,0:13:01.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu juga masih belum yakin.
Dialogue: 0,0:13:01.26,0:13:05.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setidaknya di ujian pulau tak berpenghuni,\Naku berniat untuk menyelidiki
Dialogue: 0,0:13:05.31,0:13:07.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}apa dia benar orang berbahaya atau tidak.
Dialogue: 0,0:13:07.77,0:13:10.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yagami sendiri juga hati-hati, ya.
Dialogue: 0,0:13:10.52,0:13:12.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:12.56,0:13:14.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:13:14.65,0:13:19.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anu, setelah ujian pulau tak berpenghuni\Nsudah selesai saja tidak masalah.
Dialogue: 0,0:13:19.03,0:13:21.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi ada yang ingin kubicarakan\Nke Kak Kushida.
Dialogue: 0,0:13:21.78,0:13:24.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, iya, baiklah.
Dialogue: 0,0:13:24.49,0:13:26.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kira-kira apa, ya?
Dialogue: 0,0:13:27.12,0:13:29.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau punya adik kelas yang baik, ya.
Dialogue: 0,0:13:29.29,0:13:30.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:13:30.29,0:13:32.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sampai rasanya mubazir buatku.
Dialogue: 0,0:13:32.96,0:13:36.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, ini bukan alur yang kuharapkan.
Dialogue: 0,0:13:36.80,0:13:41.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yagami tahu soal masa laluku.
Dialogue: 0,0:13:41.01,0:13:42.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu berarti?
Dialogue: 0,0:13:42.93,0:13:46.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Harus disingkirkan dalam waktu dekat.
Dialogue: 0,0:13:46.68,0:13:48.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lebih susah menyingkirkan adik kelas
Dialogue: 0,0:13:48.62,0:13:51.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}daripada menyingkirkan\Naku atau Horikita, lo.
Dialogue: 0,0:13:51.31,0:13:54.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah itu tergantung cara mainnya?
Dialogue: 0,0:13:54.35,0:14:00.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semakin seseorang menganggap dirinya hebat,\Nbiasanya malah mengecewakan.
Dialogue: 0,0:14:00.07,0:14:04.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak terkecuali kamu dan Horikita.
Dialogue: 0,0:14:04.07,0:14:07.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukannya dirimu sedang\Ngencatan senjata denganku?
Dialogue: 0,0:14:07.83,0:14:10.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buat sekarang aku memang diam saja.
Dialogue: 0,0:14:10.33,0:14:14.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sampai nanti, Ayanokoji.
Dialogue: 0,0:14:21.84,0:14:26.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anu, kami mau bicara sebentar.
Dialogue: 0,0:14:26.60,0:14:29.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf kalau kami mengajak bicara\Ndengan seperti ini.
Dialogue: 0,0:14:29.97,0:14:32.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau membicarakan apa memangnya?
Dialogue: 0,0:14:32.23,0:14:34.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini mengenai Hosen Kazuomi.
Dialogue: 0,0:14:34.56,0:14:38.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kakak sudah tahu sikapnya\Nyang tidak kooperatif itu, kan?
Dialogue: 0,0:14:38.11,0:14:40.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami ingin memberinya\Nsedikit pelajaran saat
Dialogue: 0,0:14:40.09,0:14:42.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}bertahan hidup di pulau tak berpenghuni.
Dialogue: 0,0:14:42.82,0:14:46.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat ini dia tidak punya\Nbanyak poin pribadi.
Dialogue: 0,0:14:46.28,0:14:50.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berarti kalau harus menyerah di awal-awal,\Ntidak akan bisa membayar penaltinya.
Dialogue: 0,0:14:50.95,0:14:54.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi ingin membuat Hosen\Ndikeluarkan dari sekolah, ya?
Dialogue: 0,0:14:54.25,0:14:56.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:14:56.25,0:14:58.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar begitu.
Dialogue: 0,0:14:58.29,0:15:00.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setidaknya akan kudengar alasannya.
Dialogue: 0,0:15:00.50,0:15:05.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari Kelas 1-C ada siswa bernama Hatano\Nyang sudah dikeluarkan.
Dialogue: 0,0:15:05.22,0:15:08.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menebak Hosen terlibat soal ini.
Dialogue: 0,0:15:08.39,0:15:10.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi mau membalasnya, begitu?
Dialogue: 0,0:15:10.64,0:15:14.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu akan bohong kalau\Nbilang tidak punya dendam.
Dialogue: 0,0:15:14.02,0:15:18.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi yang penting adalah jangan ada\Nyang dikeluarkan lebih dari ini.
Dialogue: 0,0:15:18.02,0:15:19.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar itu.
Dialogue: 0,0:15:19.65,0:15:22.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadinya poin kelas kami minus seratus.
Dialogue: 0,0:15:22.28,0:15:26.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, apa hubungannya perkara itu\Ndengan diriku?
Dialogue: 0,0:15:26.07,0:15:29.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hosen tidak akan bekerja sama\Ndengan orang luar.
Dialogue: 0,0:15:29.16,0:15:32.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi berpasangan dengan Kak Ayanokoji\Ndi ujian akhir April.
Dialogue: 0,0:15:33.20,0:15:37.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi mengira ada celah\Nyang bisa dipakai di sana?
Dialogue: 0,0:15:37.17,0:15:38.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong bantu kami.
Dialogue: 0,0:15:38.67,0:15:41.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di kondisi masih belum tahu\Napa isi ujiannya nanti,
Dialogue: 0,0:15:41.75,0:15:43.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku rasanya belum bisa bilang setuju.
Dialogue: 0,0:15:43.96,0:15:47.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, bisa tidak mempertimbangkan\Nuntuk membantu kami?
Dialogue: 0,0:15:47.51,0:15:51.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau bisa menyingkirkan dan membuat\NHosen dikeluarkan di awal,
Dialogue: 0,0:15:51.26,0:15:53.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}akan kami bayar yang setimpal.
Dialogue: 0,0:15:53.10,0:15:57.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak memikirkan kemungkinan\Nkalau aku adalah sekutu Hosen?
Dialogue: 0,0:15:57.35,0:15:58.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau itu...
Dialogue: 0,0:16:00.86,0:16:03.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Luka di tangan kiri itu,
Dialogue: 0,0:16:03.11,0:16:07.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}bukankah hasil perkelahian dengan Hosen?
Dialogue: 0,0:16:07.99,0:16:09.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa berpikiran begitu?
Dialogue: 0,0:16:09.61,0:16:13.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena kami juga mengincar\Nimbalan 20 juta poinnya.
Dialogue: 0,0:16:13.95,0:16:15.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:16:15.25,0:16:19.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makanya dulu kalian mendekatiku\Ndengan pura-pura cari partner.
Dialogue: 0,0:16:19.25,0:16:21.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:16:21.00,0:16:25.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski kita bekerja sama, bukankah tidak ada\Ncara untuk hanya mengeluarkan diriku?
Dialogue: 0,0:16:25.76,0:16:28.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau itu tidak bisa dijawab.
Dialogue: 0,0:16:28.38,0:16:30.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf soal itu.
Dialogue: 0,0:16:30.34,0:16:32.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetapi kami sudah mundur dari hal itu.
Dialogue: 0,0:16:32.85,0:16:34.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:34.01,0:16:37.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meskipun berhasil membuat Kak Ayanokoji\Ndikeluarkan dari sekolah,
Dialogue: 0,0:16:37.48,0:16:40.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}itu akan segera tersebar ke seluruh sekolah.
Dialogue: 0,0:16:40.65,0:16:44.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu akan membuat Kelas 2-D jadi musuh kami.
Dialogue: 0,0:16:44.15,0:16:48.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah mengeluarkan Hosen\Njuga akan sama saja hasilnya?
Dialogue: 0,0:16:48.40,0:16:50.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana mungkin itu.
Dialogue: 0,0:16:50.32,0:16:54.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kurasa justru lebih banyak teman sekelasnya\Nyang senang dia sudah tidak ada.
Dialogue: 0,0:16:54.87,0:16:56.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pokoknya tolong diingat.
Dialogue: 0,0:16:56.79,0:17:00.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kami hanya ingin mengalahkan Hosen.
Dialogue: 0,0:17:01.71,0:17:03.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tik, tok.
Dialogue: 0,0:17:03.38,0:17:07.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mengganggu sekali makanya\Naku benci sama jammu itu.
Dialogue: 0,0:17:07.55,0:17:09.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bawel amat, lah.
Dialogue: 0,0:17:09.47,0:17:12.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang kau tahu nilai jam ini?
Dialogue: 0,0:17:12.64,0:17:15.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak segabut itu untuk tahu\Nnilai sesuatu yang kubenci.
Dialogue: 0,0:17:15.93,0:17:18.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi apa urusanmu?
Dialogue: 0,0:17:18.09,0:17:20.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perkara ujian pulau tak berpenghuni.
Dialogue: 0,0:17:20.52,0:17:22.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bergabunglah denganku, Amasawa.
Dialogue: 0,0:17:22.40,0:17:24.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi mau kerja sama denganku, nih?
Dialogue: 0,0:17:24.94,0:17:27.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah begitu di pulau tak berpenghuni.
Dialogue: 0,0:17:27.28,0:17:29.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mikir hal-hal ngeres, ya?
Dialogue: 0,0:17:29.32,0:17:30.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:30.57,0:17:32.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau lihat celana dalamku?
Dialogue: 0,0:17:32.41,0:17:34.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mau mengintip boleh, kok.
Dialogue: 0,0:17:34.37,0:17:38.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau pikir aku tidak akan\Nmain tangan sama cewek?
Dialogue: 0,0:17:38.20,0:17:41.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Justru tenang karena kurasa tipe\Nyang bakal santai saja main tangan.
Dialogue: 0,0:17:41.87,0:17:45.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu jangan asal ngomong.
Dialogue: 0,0:17:45.00,0:17:49.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu biar kudengar rencanamu.
Dialogue: 0,0:17:49.92,0:17:52.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa malah mengajakku?
Dialogue: 0,0:17:52.13,0:17:57.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena kau punya nyali untuk tidak ragu\Nmengeluarkan Ayanokoji dari sekolah.
Dialogue: 0,0:17:57.89,0:18:02.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau ada imbalan 20 juta,\Nnormalnya bakal habis-habisan berambisi?
Dialogue: 0,0:18:02.89,0:18:04.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terus, imbalannya?
Dialogue: 0,0:18:05.27,0:18:07.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita seharusnya setara.
Dialogue: 0,0:18:07.90,0:18:10.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah dulu sudah kita bicarakan?
Dialogue: 0,0:18:10.65,0:18:12.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:18:12.20,0:18:16.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ditambah Nanase, kita bertigalah\Ngrup yang direncanakan Hosen.
Dialogue: 0,0:18:16.66,0:18:18.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi sisa satunya?
Dialogue: 0,0:18:18.62,0:18:20.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak butuh.
Dialogue: 0,0:18:20.25,0:18:24.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang memenangkan ujian pulau tak\Nberpenghuni kali ini adalah kita bertiga.
Dialogue: 0,0:18:24.17,0:18:26.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berani sekali.
Dialogue: 0,0:18:26.38,0:18:29.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah rencananya kita para kelas satu
Dialogue: 0,0:18:29.80,0:18:33.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}adalah bekerja sama membuat\Ngrup terkuat dari empat kelas?
Dialogue: 0,0:18:33.51,0:18:38.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sedangkan yang kupikir akan dipilih\Ndari Kelas D adalah dua orang di depanku ini.
Dialogue: 0,0:18:38.89,0:18:42.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akulah yang memutuskan itu\Nsebagai yang memerintah Kelas D.
Dialogue: 0,0:18:42.93,0:18:44.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Paham artinya, kan?
Dialogue: 0,0:18:44.98,0:18:48.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau mengirim keroco sebagai perwakilan, ya?
Dialogue: 0,0:18:48.57,0:18:51.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cari ribut ke semua arah, nih.
Dialogue: 0,0:18:51.78,0:18:55.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika mengajukan anak dengan kemampuan\Nakademik dan fisik yang tinggi,
Dialogue: 0,0:18:55.28,0:18:57.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}tidak akan membuat masalah besar.
Dialogue: 0,0:18:57.28,0:18:58.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terlebih lagi...
Dialogue: 0,0:18:58.53,0:19:03.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetap akan muncul masalah jika\NHosen masuk grup terkuat.
Dialogue: 0,0:19:03.08,0:19:07.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, memang kelihatan tidak bisa\Nmain kerja sama, sih.
Dialogue: 0,0:19:07.29,0:19:10.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kembali ke topik utama, bisa kasih berapa?
Dialogue: 0,0:19:10.71,0:19:12.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada poin yang bisa diberikan.
Dialogue: 0,0:19:12.88,0:19:16.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya mengulangi saja,\Ntapi hubungan kita ini setara.
Dialogue: 0,0:19:16.63,0:19:21.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, bukankah tingkat kontribusinya\Ntidak bisa setara?
Dialogue: 0,0:19:21.89,0:19:26.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku yakin bisa berkontribusi baik itu\Ndi pulau tak berpenghuni atau bukan.
Dialogue: 0,0:19:26.64,0:19:28.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang kelihatan lumayan punya stamina.
Dialogue: 0,0:19:28.81,0:19:32.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi apa Nanase yang\Nbegitu manis ini bisa mengikuti?
Dialogue: 0,0:19:32.82,0:19:34.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa mau dicoba?
Dialogue: 0,0:19:35.11,0:19:38.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terang-terangan sekali, ya.
Dialogue: 0,0:19:38.03,0:19:39.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oalah.
Dialogue: 0,0:19:39.37,0:19:41.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lumayan bisa di bagian itu, nih?
Dialogue: 0,0:19:41.99,0:19:45.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku suka sekali sama cewek yang kuat.
Dialogue: 0,0:19:45.16,0:19:49.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu sendiri yang bilang begitu,\Nitu juga tidak normal.
Dialogue: 0,0:19:49.33,0:19:51.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:19:53.76,0:19:58.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku, Nanase dan dirimu bertiga\Nakan jadi satu grup.
Dialogue: 0,0:19:58.89,0:20:00.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oke, ya.
Dialogue: 0,0:20:00.09,0:20:03.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku paham kalau Nanase\Nlumayan bisa diandalkan.
Dialogue: 0,0:20:03.77,0:20:07.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi untuk kerja sama\Nrasanya harus minta tambah.
Dialogue: 0,0:20:07.94,0:20:10.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Arogan sekali sikapmu.
Dialogue: 0,0:20:11.02,0:20:12.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oke, biar kudengar.
Dialogue: 0,0:20:12.44,0:20:15.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau minta apa selain imbalan grupnya?
Dialogue: 0,0:20:15.44,0:20:19.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Poin yang didapat saat berhasil\Nmengeluarkan Kak Ayanokoji dari sekolah,
Dialogue: 0,0:20:19.66,0:20:21.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}semuanya jadi milikku.
Dialogue: 0,0:20:21.70,0:20:23.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu syaratku bergabung.
Dialogue: 0,0:20:24.29,0:20:27.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Besar juga yang kau minta itu.
Dialogue: 0,0:20:27.08,0:20:29.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana bisa kuiyakan semudah itu.
Dialogue: 0,0:20:29.54,0:20:32.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu apa kutolak saja, ya?
Dialogue: 0,0:20:32.29,0:20:35.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi apa jadinya kalau sampai kutolak?
Dialogue: 0,0:20:35.09,0:20:37.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah cari ribut ke semua arah.
Dialogue: 0,0:20:37.34,0:20:42.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah akan susah karena tidak ada\Nyang bisa dipercaya selain Nanase?
Dialogue: 0,0:20:42.05,0:20:47.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, akan kuserahkan semua reputasi\Nmengeluarkan Kak Ayanokoji padamu.
Dialogue: 0,0:20:47.35,0:20:49.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sudah cukup, kan?
Dialogue: 0,0:20:49.10,0:20:51.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu mengikuti kemauannya!
Dialogue: 0,0:20:51.23,0:20:54.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau memikirkan apa yang akan terjadi\Njika 20 juta poin masuk ke Kelas A...
Dialogue: 0,0:20:54.82,0:20:56.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Diam saja sana.
Dialogue: 0,0:20:56.86,0:21:00.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Amasawa, uangnya akan kuserahkan padamu.
Dialogue: 0,0:21:00.74,0:21:02.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makasih.
Dialogue: 0,0:21:02.16,0:21:06.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cowok yang tidak pelit itu\Nmenurutku cukup memesona, lo.
Dialogue: 0,0:21:06.49,0:21:09.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya sudah, tolong bantuannya saat ujian.
Dialogue: 0,0:21:10.67,0:21:12.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benarkah tidak apa-apa?
Dialogue: 0,0:21:12.96,0:21:15.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasanya dia tipe yang akan\Ndengan mudah berkhianat.
Dialogue: 0,0:21:15.92,0:21:20.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejak awal aku tidak percaya\Npadamu atau Amasawa.
Dialogue: 0,0:21:20.01,0:21:22.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu kenapa mau satu grup dengan dia?
Dialogue: 0,0:21:23.34,0:21:25.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena beda dari cecunguk yang ada.
Dialogue: 0,0:21:25.81,0:21:29.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sama seperti dirimu,\Nada sisi kalian yang tidak kutahu.
Dialogue: 0,0:21:29.60,0:21:31.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin memang benar begitu.
Dialogue: 0,0:21:31.52,0:21:35.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski begitu, 20 juta poin tetaplah\Nsyarat yang luar biasa besar.
Dialogue: 0,0:21:36.52,0:21:39.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Janji di mulut itu bisa sesuka hati.
Dialogue: 0,0:21:39.61,0:21:44.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau aku yang berhasil mengeluarkannya,\Ntentu imbalannya akan dikirim padaku.
Dialogue: 0,0:21:44.87,0:21:48.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti dia mengemis merengek pun\Ntidak ada hubungannya.
Dialogue: 0,0:21:48.29,0:21:50.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sungguh orang yang jahat.
Dialogue: 0,0:21:50.16,0:21:54.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau Ayanokoji, Ryuen atau\Nkeroco-keroco lain yang ada.
Dialogue: 0,0:21:54.46,0:21:58.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kuhancurkan semua\Nyang berani menantangku.
Dialogue: 0,0:21:58.05,0:22:02.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serasa mau tenggelam\Noleh aturan gila sekolah ini.
Dialogue: 0,0:22:02.80,0:22:05.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ketagihan maksimal!
