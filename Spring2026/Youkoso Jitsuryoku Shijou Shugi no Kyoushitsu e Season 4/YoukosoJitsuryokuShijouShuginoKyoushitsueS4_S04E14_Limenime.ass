Dialogue: 0,0:00:17.83,0:00:21.67,sign,,0000,0000,0000,,"DAFTAR GRUP PERINGKAT ATAS"
Dialogue: 0,0:02:38.01,0:02:40.42,sign,,0000,0000,0000,,"#14 GENIUS PENYENDIRI"
Dialogue: 0,0:03:00.53,0:03:05.08,sign,,0000,0000,0000,,HARI KESEBELAS
Dialogue: 0,0:11:26.71,0:11:27.82,sign,,0000,0000,0000,,HARI KESEMBILAN
Dialogue: 0,0:16:43.94,0:16:44.65,sign,,0000,0000,0000,,HARI KEDUA BELAS
Dialogue: 0,0:17:56.35,0:17:58.85,sign,,0000,0000,0000,,HARI KETIGA BELAS
Dialogue: 0,0:00:07.28,0:00:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiriyama, rasanya Nagumo\Nterlalu menunda bereaksi, ya?
Dialogue: 0,0:00:12.37,0:00:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah setelah paruh akhir dimulai,\Nharusnya sudah memimpin jauh di depan?
Dialogue: 0,0:00:17.83,0:00:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara menunda mengurus Koenji,
Dialogue: 0,0:00:21.67,0:00:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selisih poinnya jadi hampir setara.
Dialogue: 0,0:00:23.88,0:00:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koenji mengeluarkan mode seriusnya\Ndi ujian kali ini.
Dialogue: 0,0:00:27.47,0:00:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya, dia berubah dari\Nyang bukan ancaman menjadi musuh terkuat.
Dialogue: 0,0:00:32.97,0:00:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, bagaimana menyingkirkannya?
Dialogue: 0,0:00:35.47,0:00:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukerahkan semua grup\Nyang dititipkan Nagumo padaku.
Dialogue: 0,0:00:38.89,0:00:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau serius bilang begitu?!
Dialogue: 0,0:00:40.48,0:00:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan kita cuma satu orang, lo!
Dialogue: 0,0:00:41.85,0:00:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jadi ancaman cuma Koenji.
Dialogue: 0,0:00:44.23,0:00:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri yang akan memimpin\Nuntuk menghentikan Koenji.
Dialogue: 0,0:00:47.82,0:00:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau?!
Dialogue: 0,0:00:49.15,0:00:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja!
Dialogue: 0,0:00:50.57,0:00:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus menaikkan\Npenilaian Nagumo padaku.
Dialogue: 0,0:00:53.70,0:00:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:00:54.58,0:00:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:00:55.33,0:00:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bisa menghentikan Koenji\Nselain aku dan Nagumo.
Dialogue: 0,0:00:59.58,0:01:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggaplah lawan kita adalah musuh terbesar.
Dialogue: 0,0:01:13.51,0:01:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:23.33,0:02:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:36.26,0:02:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana situasinya?
Dialogue: 0,0:02:38.01,0:02:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia malah tidur santai.
Dialogue: 0,0:02:40.43,0:02:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bagaimana kalau kita kepung saja\Nsebelum dia keluar dari tenda?
Dialogue: 0,0:02:44.44,0:02:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kau beri dalih apa\Nkalau ada pihak lain yang melihat?
Dialogue: 0,0:02:47.52,0:02:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa, pencarian GPS itu\Njuga tidak selalu akurat.
Dialogue: 0,0:02:52.65,0:02:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti rencana semula,\Nkita maju saat Koenji mulai bergerak.
Dialogue: 0,0:02:58.03,0:02:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:03:06.33,0:03:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa dengan diriku?
Dialogue: 0,0:03:09.42,0:03:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin agar hari ini\Nkau tidak bergerak dari sini.
Dialogue: 0,0:03:13.67,0:03:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu kau siapa,
Dialogue: 0,0:03:16.01,0:03:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kurasa kau seharusnya tahu\Nkalau itu usulan yang mustahil.
Dialogue: 0,0:03:19.68,0:03:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau patuh, tidak akan kami sakiti.
Dialogue: 0,0:03:23.02,0:03:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berpihak pada Nagumo\Nyang merupakan ketua OSIS,
Dialogue: 0,0:03:26.31,0:03:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehidupan sekolahmu akan lebih terjamin.
Dialogue: 0,0:03:30.48,0:03:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang buru-buru, jadi akan pamit dulu!
Dialogue: 0,0:03:34.78,0:03:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-Yang benar saja?!
Dialogue: 0,0:03:36.57,0:03:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panik, Mikitani.
Dialogue: 0,0:03:38.32,0:03:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan saatnya buat santai!\NKita melepaskannya, lo!
Dialogue: 0,0:03:41.24,0:03:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia memilih\Nuntuk terus lari ke sana-kemari,
Dialogue: 0,0:03:44.58,0:03:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan bisa lagi\Nmengikuti tugas dengan santai.
Dialogue: 0,0:03:47.75,0:03:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya,
Dialogue: 0,0:03:48.71,0:03:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau terang-terangan mengerjakan tugas,\Ntinggal kita kejar saja ke sana.
Dialogue: 0,0:04:01.22,0:04:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lari tapi malah tidur siang.
Dialogue: 0,0:04:03.64,0:04:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tetap bisa kelelahan rupanya.
Dialogue: 0,0:04:05.98,0:04:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah jelas.
Dialogue: 0,0:04:07.69,0:04:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga manusia seperti kalian.
Dialogue: 0,0:04:10.98,0:04:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu hari ini kau istirahat saja.
Dialogue: 0,0:04:13.98,0:04:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya dengarkan\Npendapat kakak kelasmu ini.
Dialogue: 0,0:04:17.36,0:04:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat?
Dialogue: 0,0:04:18.89,0:04:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkataanmu lucu juga.
Dialogue: 0,0:04:24.12,0:04:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan samakan aku\Ndengan orang biasa.
Dialogue: 0,0:04:27.50,0:04:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena staminaku sekarang\Nsudah pulih sepenuhnya.
Dialogue: 0,0:04:32.88,0:04:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari sepuluh hari ini kau sudah\Nberusaha keras lebih dari siapa pun.
Dialogue: 0,0:04:37.13,0:04:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski punya stamina di luar manusia biasa,\Npasti sudah lama mencapai batas.
Dialogue: 0,0:04:41.30,0:04:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sayangnya aku ini sangat short sleeper.
Dialogue: 0,0:04:46.06,0:04:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:04:47.02,0:04:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Short sleeper.
Dialogue: 0,0:04:48.93,0:04:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu benar, berarti masalah besar.
Dialogue: 0,0:04:51.94,0:04:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya, Kiriyama?
Dialogue: 0,0:04:54.15,0:04:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu merujuk pada orang yang tetap bugar\Nmeski hanya tidur sebentar.
Dialogue: 0,0:04:59.95,0:05:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, dia cukup istirahat sebentar saja
Dialogue: 0,0:05:03.24,0:05:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk langsung mereset kelelahan\Nyang diterima.
Dialogue: 0,0:05:06.16,0:05:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang izinkan aku menuju area\Nyang sudah ditunjuk selanjutnya.
Dialogue: 0,0:05:10.54,0:05:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?!
Dialogue: 0,0:05:11.33,0:05:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu!
Dialogue: 0,0:05:13.58,0:05:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat, kita ganti strategi.
Dialogue: 0,0:05:16.17,0:05:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bergerak bersama Koenji\Nuntuk mencegahnya ikut tugas.
Dialogue: 0,0:05:20.01,0:05:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang pegang komando di sini,\Njangan buat kekacauan.
Dialogue: 0,0:05:23.68,0:05:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:05:37.69,0:05:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koenji, jangan berlagak kuat kau!
Dialogue: 0,0:05:40.69,0:05:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh, berisik sekali.
Dialogue: 0,0:05:43.61,0:05:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana kalau sedikit\Nkunaikkan lajuku?
Dialogue: 0,0:05:48.20,0:05:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja?!
Dialogue: 0,0:05:49.70,0:05:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, kejar!
Dialogue: 0,0:05:51.33,0:05:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan bergerak seenaknya.
Dialogue: 0,0:05:53.33,0:05:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:05:54.38,0:05:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan dia lepas dua kali!
Dialogue: 0,0:05:57.50,0:05:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:06:01.80,0:06:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usaha kalian ternyata keras juga.
Dialogue: 0,0:06:04.59,0:06:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah tidak punya pilihan lagi!
Dialogue: 0,0:06:08.10,0:06:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini peringatan terakhir.
Dialogue: 0,0:06:10.27,0:06:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehari penuh besok saja sudah cukup,\Ndiamlah jangan melakukan apa-apa.
Dialogue: 0,0:06:14.23,0:06:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Nagumo bilang untuk setidaknya\Nmenahan dia dua hari.
Dialogue: 0,0:06:17.27,0:06:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memaksa Koenji sejauh itu\Nbukanlah langkah baik.
Dialogue: 0,0:06:20.36,0:06:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lusa sudah H-1 hari terakhir.
Dialogue: 0,0:06:22.95,0:06:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus fokus menambah poin perolehan.
Dialogue: 0,0:06:26.07,0:06:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tinggal beri penjaga\Nyang minimal bisa menahannya dua hari!
Dialogue: 0,0:06:30.29,0:06:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir Koenji akan diam saja?
Dialogue: 0,0:06:32.04,0:06:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tergantung eksekusinya, kan?!
Dialogue: 0,0:06:34.37,0:06:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kau bisa melakukannya?
Dialogue: 0,0:06:38.04,0:06:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa!
Dialogue: 0,0:06:39.38,0:06:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil kubuktikan,\Nsiapkan tiket ke Kelas A untukku!
Dialogue: 0,0:06:45.05,0:06:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah dengar, kan?!
Dialogue: 0,0:06:47.01,0:06:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat kau diam\Ndi sini sampai besok lusa!
Dialogue: 0,0:06:51.31,0:06:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permintaan yang tidak bisa kuturuti,\Napa jadinya kalau kutolak?
Dialogue: 0,0:06:55.19,0:06:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Opsi terburuknya adalah mengeluarkanmu\Ndari sekolah.
Dialogue: 0,0:06:59.02,0:07:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan patuh pada siapa pun.
Dialogue: 0,0:07:01.69,0:07:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti harus dibuat agar mau patuh.
Dialogue: 0,0:07:05.32,0:07:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh, ini tidak bisa disebut\Nsituasi yang enak dipandang.
Dialogue: 0,0:07:10.03,0:07:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus mau bagaimana?
Dialogue: 0,0:07:11.79,0:07:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berani coba-coba menerobos,\Nakan kuanggap sebagai deklarasi perang.
Dialogue: 0,0:07:17.42,0:07:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:07:25.38,0:07:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku pamit dulu.
Dialogue: 0,0:07:33.72,0:07:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:07:34.85,0:07:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lenganku! Lenganku kayaknya patah!
Dialogue: 0,0:07:36.98,0:07:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parah juga tindakanmu, Koenji.
Dialogue: 0,0:07:39.77,0:07:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morooka sampai terluka, tuh.
Dialogue: 0,0:07:42.44,0:07:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti tukang tabrak palsu saja.
Dialogue: 0,0:07:44.78,0:07:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bilang apa pun,\Nnyatanya kau tetap sudah mendorong Morooka.
Dialogue: 0,0:07:49.82,0:07:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berniat untuk memberi ampun\Nke orang yang ingin menghentikan jalanku.
Dialogue: 0,0:07:55.33,0:07:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jadinya kalau kami melapor\Nke pihak sekolah?
Dialogue: 0,0:07:59.33,0:08:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu hanya akan mengotori\Nnama kalian yang sudah beramai-ramai
Dialogue: 0,0:08:03.13,0:08:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin menjatuhkan adik kelas?
Dialogue: 0,0:08:09.47,0:08:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah boleh pergi sekarang?
Dialogue: 0,0:08:11.72,0:08:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara meladeni kalian,
Dialogue: 0,0:08:14.26,0:08:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}batas waktu hadiah kedatanganku\Nhampir habis.
Dialogue: 0,0:08:17.48,0:08:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf saja,\Ntapi kau tidak akan kami biarkan pergi.
Dialogue: 0,0:08:20.60,0:08:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti ingin menantangku, ya?
Dialogue: 0,0:08:25.11,0:08:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu adalah uang!
Dialogue: 0,0:08:27.19,0:08:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat maju sini.
Dialogue: 0,0:08:29.36,0:08:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti boleh digas, Mikitani?
Dialogue: 0,0:08:31.49,0:08:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betulan kita hajar dia.
Dialogue: 0,0:08:33.37,0:08:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:34.62,0:08:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terpaksa, tinggal dekap Koenji\Ndan seret terjun sama-sama.
Dialogue: 0,0:08:38.62,0:08:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo maju!
Dialogue: 0,0:09:02.23,0:09:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan...
Dialogue: 0,0:09:07.78,0:09:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:09:09.07,0:09:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kau ini?!
Dialogue: 0,0:09:11.36,0:09:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, bukankah lari dari kami itu\Njauh lebih mudah?!
Dialogue: 0,0:09:16.95,0:09:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya akan repot\Nkalau kalian terus mengikutiku.
Dialogue: 0,0:09:20.87,0:09:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:09:22.25,0:09:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunjukkan perbedaan kekuatan yang besar\Nuntuk mematahkan semangat mereka.
Dialogue: 0,0:09:26.88,0:09:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku pamit dulu.
Dialogue: 0,0:09:29.30,0:09:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, apa-apaan dia?!
Dialogue: 0,0:09:32.05,0:09:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin dia anak SMA?!
Dialogue: 0,0:09:34.39,0:09:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan yang tidak bisa diprediksi\Nmemang akan selalu ada.
Dialogue: 0,0:09:39.14,0:09:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti Nagumo.
Dialogue: 0,0:09:41.23,0:09:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kau mau lapor ke Nagumo\Nsoal kegagalanku ini, ya?!
Dialogue: 0,0:09:45.23,0:09:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir, sejak awal sudah\Ndiduga kalau Koenji itu di luar nalar.
Dialogue: 0,0:09:50.40,0:09:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, lawan seperti apa pun\Npasti punya kelemahan.
Dialogue: 0,0:09:54.45,0:10:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, Koenji pasti jadi menganggap\Nanak kelas tiga itu tidak seberapa.
Dialogue: 0,0:10:00.29,0:10:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah incaran sebenarnya.
Dialogue: 0,0:10:07.67,0:10:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ternyata Ayanokoji.
Dialogue: 0,0:10:11.38,0:10:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lebih segar daripada yang kubayangkan.
Dialogue: 0,0:10:13.93,0:10:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oke, sepakat, ya.\N- Karena mereka semua sudah bekerja keras.
Dialogue: 0,0:10:16.76,0:10:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji sendiri apakah sehat-sehat saja?
Dialogue: 0,0:10:20.64,0:10:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kurang lebih untuk sekarang.
Dialogue: 0,0:10:23.56,0:10:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, ya.
Dialogue: 0,0:10:25.48,0:10:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah luka saja bisa membuatmu gugur.
Dialogue: 0,0:10:30.53,0:10:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal tiga hari, ya.
Dialogue: 0,0:10:32.36,0:10:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:33.82,0:10:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:10:35.78,0:10:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Ayanokoji, toh.
Dialogue: 0,0:10:37.53,0:10:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf anak kelas lain sepertiku mengganggu.
Dialogue: 0,0:10:40.41,0:10:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali enggak, kok.
Dialogue: 0,0:10:42.29,0:10:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi cowok sendiri rasanya tidak enak.
Dialogue: 0,0:10:45.04,0:10:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, hari ini sudah tidak ada ujian,\Nayo kemah bareng kami, sini.
Dialogue: 0,0:10:49.92,0:10:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide yang sangat bagus.
Dialogue: 0,0:10:51.92,0:10:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:10:53.26,0:10:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi Ayanokoji\Ntidak kelihatan bahaya sama sekali.
Dialogue: 0,0:10:56.05,0:10:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:11:07.52,0:11:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak.
Dialogue: 0,0:11:08.86,0:11:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji.
Dialogue: 0,0:11:11.57,0:11:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini saya, Nanase.
Dialogue: 0,0:11:15.24,0:11:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa di jam segini?
Dialogue: 0,0:11:17.45,0:11:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin segera saya sampaikan.
Dialogue: 0,0:11:20.95,0:11:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini soal rencana besar\Nuntuk membuat Kak Ayanokoji gugur.
Dialogue: 0,0:11:27.83,0:11:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya kau menikmati sekali\Nwaktumu bersama Ayanokoji.
Dialogue: 0,0:11:32.38,0:11:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya bagaimana?
Dialogue: 0,0:11:33.63,0:11:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:11:34.92,0:11:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukanlah lawan\Nyang bisa saja kukalahkan.
Dialogue: 0,0:11:38.51,0:11:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kau tantang mentah-mentah\Ntanpa memanfaatkan senjata wanita.
Dialogue: 0,0:11:42.97,0:11:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata wanita?
Dialogue: 0,0:11:46.02,0:11:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sudahlah.
Dialogue: 0,0:11:47.85,0:11:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu, Hosen!
Dialogue: 0,0:11:50.52,0:11:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:11:51.65,0:11:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku Katagiri dari Kelas C.
Dialogue: 0,0:11:55.11,0:11:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak kenal.
Dialogue: 0,0:11:56.90,0:11:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:58.49,0:12:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, aku membawa sesuatu\Nyang harus diserahkan ke Hosen.
Dialogue: 0,0:12:02.78,0:12:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak menarik\Nbakal kuhajar kau sampai mental.
Dialogue: 0,0:12:05.79,0:12:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini untuk bicara dengan Utomiya!
Dialogue: 0,0:12:11.17,0:12:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?\NMinta ditemani main?
Dialogue: 0,0:12:14.88,0:12:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sebenarnya tidak ingin menghubungimu.
Dialogue: 0,0:12:17.42,0:12:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak bisa dihindari\Nuntuk menjalankan rencananya.
Dialogue: 0,0:12:20.89,0:12:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana katamu?
Dialogue: 0,0:12:22.64,0:12:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya itu?
Dialogue: 0,0:12:24.31,0:12:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi kami akan menjalankan\Nrencana menyelamatkan anak kelas satu.
Dialogue: 0,0:12:29.23,0:12:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyelamatkan katamu?
Dialogue: 0,0:12:30.90,0:12:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, ada empat grup kelas satu\Nyang berada di peringkat 10 terbawah.
Dialogue: 0,0:12:36.23,0:12:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada dua grup dari Kelas 1-D kita.
Dialogue: 0,0:12:40.41,0:12:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak peduli kalau sampah\Nseperti mereka tersingkir.
Dialogue: 0,0:12:44.20,0:12:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kau ingin aku membantu?
Dialogue: 0,0:12:46.87,0:12:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolak saja kalau tidak mau.
Dialogue: 0,0:12:48.79,0:12:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya kusampaikan karena perintah,
Dialogue: 0,0:12:51.75,0:12:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak awal kurasa bisa\Ndijalankan tanpa dirimu.
Dialogue: 0,0:12:54.38,0:12:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kita selesai di sini, akan kututup.
Dialogue: 0,0:12:57.63,0:13:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau tidak akan membantu.\NBegitu, ya.
Dialogue: 0,0:13:01.26,0:13:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar,\Ntidak ada yang bilang kalau tidak mau bantu.
Dialogue: 0,0:13:05.26,0:13:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:13:06.52,0:13:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berani sujud dan memohon padaku,\Naku tidak masalah membantu kalian.
Dialogue: 0,0:13:12.27,0:13:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:13:13.94,0:13:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang mau bersujud padamu?!
Dialogue: 0,0:13:15.57,0:13:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti lupakan obrolan ini.
Dialogue: 0,0:13:18.03,0:13:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah, kan, Tsubaki?
Dialogue: 0,0:13:23.62,0:13:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya memang tidak bisa\Nkuserahkan ke Utomiya seorang.
Dialogue: 0,0:13:27.62,0:13:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa maksudmu\Nmau menyelamatkan kelas satu?
Dialogue: 0,0:13:31.50,0:13:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang mau menyelamatkan\Nmereka semua yang di peringkat bawah?
Dialogue: 0,0:13:36.21,0:13:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum kujawab, ingin kupastikan dulu.
Dialogue: 0,0:13:38.46,0:13:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase tidak masalah kalau\Nkuanggap rekan kita, kan?
Dialogue: 0,0:13:41.63,0:13:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya iya.
Dialogue: 0,0:13:43.13,0:13:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:13:44.22,0:13:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu aku tidak akan ragu\Nmelanjutkan bahasan kita.
Dialogue: 0,0:13:47.14,0:13:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:13:48.47,0:13:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kuselamatkan semuanya.
Dialogue: 0,0:13:50.68,0:13:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bersatu satu angkatan\Nseperti kakak kelas.
Dialogue: 0,0:13:54.69,0:13:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup peringkat bawah digabung\Nke grup yang mumpuni agar naik.
Dialogue: 0,0:13:59.65,0:14:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang bukan ide yang buruk,\Ntapi tidak ada jaminan bisa menang, kan?
Dialogue: 0,0:14:04.41,0:14:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:14:05.45,0:14:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya sebelum hari terakhir selesai,
Dialogue: 0,0:14:07.91,0:14:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tinggal buat grup kakak kelas gugur.
Dialogue: 0,0:14:10.79,0:14:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:12.21,0:14:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masih ada beberapa orang\Nyang bergerak seorang diri.
Dialogue: 0,0:14:16.42,0:14:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup jatuhkan saja mereka.
Dialogue: 0,0:14:18.96,0:14:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:20.92,0:14:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal ada lima grup yang gugur,\Nsemuanya bisa diselamatkan.
Dialogue: 0,0:14:25.34,0:14:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, coba sebutkan secara detail\Nbantuan apa yang kau minta dariku?
Dialogue: 0,0:14:29.56,0:14:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berniat menjatuhkan Kak Ayanokoji, kan?
Dialogue: 0,0:14:34.10,0:14:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak dapat kesempatan\Nkarena dia selalu bergerak.
Dialogue: 0,0:14:38.52,0:14:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi beda cerita kalau punya\Njaring luas untuk mengepungnya.
Dialogue: 0,0:14:41.61,0:14:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan menyiapkan pengepungan Ayanokoji\Nmakanya ingin aku membantu, ya.
Dialogue: 0,0:14:47.74,0:14:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:48.49,0:14:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cara yang kubenci,\Ntapi pihak sekolah juga tidak sebodoh itu.
Dialogue: 0,0:14:52.75,0:14:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu terjadi,\Nkedua pihak sama-sama bersalah.
Dialogue: 0,0:14:55.42,0:14:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai dalangnya, aku yang akan\Nbertanggung jawab dan keluar dari sekolah.
Dialogue: 0,0:14:59.88,0:15:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:15:01.13,0:15:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya aku tidak punya rasa terikat\Nke sekolah ini, sih.
Dialogue: 0,0:15:05.38,0:15:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi rasanya aku ingin segera keluar.
Dialogue: 0,0:15:11.81,0:15:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang tidak takut\Npasang badan memang seram.
Dialogue: 0,0:15:15.52,0:15:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penilaianku berubah.
Dialogue: 0,0:15:17.23,0:15:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kupastikan.
Dialogue: 0,0:15:19.11,0:15:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana memakai kekerasan untuk\Nmengeluarkan Ayanokoji dari sekolah,
Dialogue: 0,0:15:22.90,0:15:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau sendiri yang merencanakannya, Tsubaki.
Dialogue: 0,0:15:26.61,0:15:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:15:28.49,0:15:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku yang akan tanggung\Njawab di situasi terburuk.
Dialogue: 0,0:15:32.12,0:15:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kapan mau dijalankan?
Dialogue: 0,0:15:34.62,0:15:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum bisa kukatakan.
Dialogue: 0,0:15:36.75,0:15:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasi eksekusinya\Ntidak boleh semudah itu disebarkan.
Dialogue: 0,0:15:40.13,0:15:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah saja kalau mau main rahasia,\Ntapi aku jadi tidak bisa bantu apa-apa, lo.
Dialogue: 0,0:15:44.88,0:15:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itulah radio panggil di tanganmu.
Dialogue: 0,0:15:48.39,0:15:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kuhubungi lagi, tolong bantuannya, ya.
Dialogue: 0,0:15:51.22,0:15:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya dia wanita yang licik.
Dialogue: 0,0:15:53.93,0:15:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana sekarang?
Dialogue: 0,0:15:55.52,0:15:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimanapun juga,\Ntidak ada ruginya kita ikuti.
Dialogue: 0,0:15:59.65,0:16:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa mengamuk sesuka hati,\Ntapi semua tanggung jawab ada di Tsubaki.
Dialogue: 0,0:16:04.86,0:16:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi yang sangat menggiurkan.
Dialogue: 0,0:16:08.32,0:16:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah memberitahuku.
Dialogue: 0,0:16:10.41,0:16:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan lama-lama di sini.
Dialogue: 0,0:16:13.12,0:16:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:14.08,0:16:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan saya kabari kalau ada pergerakan lagi.
Dialogue: 0,0:16:17.04,0:16:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sudah cukup.
Dialogue: 0,0:16:19.67,0:16:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selebihnya lakukan saja tugasmu\Nsebagai anggota grup Hosen dan Amasawa.
Dialogue: 0,0:16:25.96,0:16:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kehilangan kepercayaan Nanase di sini,\Nnilai kegunaannya akan turun.
Dialogue: 0,0:16:30.64,0:16:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kak Ayanokoji bilang begitu...
Dialogue: 0,0:16:33.76,0:16:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:16:36.02,0:16:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan anak kelas satu\Ntidaklah mengagetkan.
Dialogue: 0,0:16:39.69,0:16:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perubahan dalam rencanaku juga tidak ada.
Dialogue: 0,0:16:44.65,0:16:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu enggak apa-apa?\N- Pagi-pagi sudah harus menanjak di sini.
Dialogue: 0,0:16:47.61,0:16:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin capek.
Dialogue: 0,0:16:48.36,0:16:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Napasmu habis begitu, lo.\N- Tidak ada pilihan lain, kan?
Dialogue: 0,0:16:51.45,0:16:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji.
Dialogue: 0,0:16:53.07,0:16:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendirian terus selama ujian,\Napa tidak merasa kesepian?
Dialogue: 0,0:16:57.87,0:17:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru lebih terasa kalau santai.
Dialogue: 0,0:17:01.67,0:17:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku, sepertinya tetap\Nakan merasa kesepian atau takut.
Dialogue: 0,0:17:07.58,0:17:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membayangkan\Ndirimu ketakutan.
Dialogue: 0,0:17:11.58,0:17:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kelihatannya begini,\Nsebenarnya aku cukup penakut.
Dialogue: 0,0:17:16.34,0:17:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang gadis beraktivitas sendiri di pulau\Ntak berpenghuni seperti Horikita atau Ibuki
Dialogue: 0,0:17:21.77,0:17:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya mustahil buatku.
Dialogue: 0,0:17:23.73,0:17:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nkalian berdua ini memang akrab sekali, ya.
Dialogue: 0,0:17:27.35,0:17:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacaran saja, sana.
Dialogue: 0,0:17:29.40,0:17:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus pindah ke kelas kami, ya.
Dialogue: 0,0:17:32.57,0:17:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini terlalu ikut campur, tahu!
Dialogue: 0,0:17:36.91,0:17:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ishizaki memang lucu sekali.
Dialogue: 0,0:17:43.50,0:17:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ke arah sana,\Njadi kita cuma sampai di sini.
Dialogue: 0,0:17:47.09,0:17:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:48.17,0:17:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujiannya juga sebentar lagi selesai,\Nteruslah berjuang tanpa lengah.
Dialogue: 0,0:17:52.34,0:17:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji juga hati-hati.
Dialogue: 0,0:18:01.31,0:18:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang kau pikirkan, Tsubaki?
Dialogue: 0,0:18:04.06,0:18:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma melakukan simulasi\Nterakhir di dalam kepala.
Dialogue: 0,0:18:07.90,0:18:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada butuh apa?
Dialogue: 0,0:18:09.78,0:18:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa cuma obrolan denganku\Nyang tidak kau lakukan lewat radio panggil?
Dialogue: 0,0:18:14.74,0:18:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena cuma Utomiya yang bisa kupercaya.
Dialogue: 0,0:18:18.83,0:18:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya ingin langsung menyampaikan\Napa yang kupikirkan dengan tatap muka.
Dialogue: 0,0:18:25.96,0:18:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsubaki, ada sesuatu\Nyang sangat ingin kusampaikan padamu.
Dialogue: 0,0:18:30.21,0:18:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu,
Dialogue: 0,0:18:31.80,0:18:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yagami, kemarin kau tiba-tiba menghilang.
Dialogue: 0,0:18:35.34,0:18:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi ke mana kau?
Dialogue: 0,0:18:36.51,0:18:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf, jam tanganku rusak,\Njadinya aku kembali ke titik start.
Dialogue: 0,0:18:42.23,0:18:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah rusak dua kali.
Dialogue: 0,0:18:44.56,0:18:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rencanakan?
Dialogue: 0,0:18:46.60,0:18:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, sedih sekali.
Dialogue: 0,0:18:48.48,0:18:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah beberapa hari yang lalu,\Npunya Utomiya juga rusak.
Dialogue: 0,0:18:52.53,0:18:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punyaku cuma rusak biasa.
Dialogue: 0,0:18:54.74,0:18:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama, kok.
Dialogue: 0,0:18:57.12,0:19:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bisa jangan ribut di saat seperti ini?
Dialogue: 0,0:19:00.95,0:19:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, apa yang ingin kau bicarakan?
Dialogue: 0,0:19:03.25,0:19:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyiapkan\Nsebuah hadiah untuk Tsubaki.
Dialogue: 0,0:19:07.46,0:19:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini apa?
Dialogue: 0,0:19:08.71,0:19:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kupinjam dari grup anak kelas B\Ntempatku berada.
Dialogue: 0,0:19:11.88,0:19:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemilik tablet ini ada di tabel\Nyang sama dengan Kak Ayanokoji.
Dialogue: 0,0:19:16.47,0:19:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya,
Dialogue: 0,0:19:17.89,0:19:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa tahu pergerakan Kak Ayanokoji\Ntanpa jeda waktu asal ada itu, begitu?
Dialogue: 0,0:19:23.35,0:19:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa yakin kalau satu tabel?
Dialogue: 0,0:19:26.19,0:19:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berulang kali dicari lewat GPS\Nuntuk memastikan tabelnya, ya.
Dialogue: 0,0:19:31.73,0:19:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali.
Dialogue: 0,0:19:33.53,0:19:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tindakanku ini tidak perlu, ya?
Dialogue: 0,0:19:35.57,0:19:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku berterima kasih, kok.
Dialogue: 0,0:19:38.03,0:19:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, yakin boleh buatku?
Dialogue: 0,0:19:39.62,0:19:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berada di pihak yang sama.
Dialogue: 0,0:19:42.20,0:19:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi,\Nkalau usulan ini tidak diterima,
Dialogue: 0,0:19:45.60,0:19:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi tidak bisa menyiapkan antisipasi.
Dialogue: 0,0:19:48.46,0:19:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antisipasi?
Dialogue: 0,0:19:49.88,0:19:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prioritasnya adalah menyerang Kak Ayanokoji\Nuntuk membuatnya gugur.
Dialogue: 0,0:19:54.92,0:19:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau sialnya berakhir\Ndengan kegagalan...
Dialogue: 0,0:19:58.38,0:20:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganti rencana ke membuat dia melewatkan\Nsemua penunjukan area dan merebut poinnya.
Dialogue: 0,0:20:03.89,0:20:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghalangi pergerakannya
Dialogue: 0,0:20:05.81,0:20:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar kena penalti karena beruntun\Nmelewatkan area yang ditunjuk, ya.
Dialogue: 0,0:20:09.06,0:20:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil membuat Kak Ayanokoji\Ngugur lewat rencana cadangan ini...
Dialogue: 0,0:20:13.15,0:20:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh tidak, kalau lima juta\Ndari total hadiah 20 juta poin jadi milikku?
Dialogue: 0,0:20:19.74,0:20:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide yang tidak buruk.
Dialogue: 0,0:20:21.62,0:20:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah begitu, Tsubaki?
Dialogue: 0,0:20:23.74,0:20:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tidak ada salahnya dicoba.
Dialogue: 0,0:20:26.29,0:20:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja...
Dialogue: 0,0:20:28.08,0:20:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu apa?
Dialogue: 0,0:20:29.08,0:20:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tablet dengan tabel yang sama\Ndengan Kak Ayanokoji.
Dialogue: 0,0:20:32.92,0:20:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:20:34.09,0:20:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sejak kapan?
Dialogue: 0,0:20:35.42,0:20:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsubaki ternyata melebihi bayanganku.
Dialogue: 0,0:20:38.80,0:20:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga memikirkan rencana cadangan ini, ya.
Dialogue: 0,0:20:42.47,0:20:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa tidak bilang dari tadi?
Dialogue: 0,0:20:45.81,0:20:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya aku sedikit kesal.
Dialogue: 0,0:20:48.35,0:20:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kepikiran hal\Nyang sama dengan Yagami.
Dialogue: 0,0:20:52.31,0:20:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu ceritanya,\Nberarti aku tidak boleh meminta hadiahnya.
Dialogue: 0,0:20:58.44,0:21:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:02.41,0:21:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsubaki, kau serius berniat\Nmenanggung semuanya sendiri?
Dialogue: 0,0:21:06.58,0:21:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal yang bilang ingin\Nmengeluarkan Kak Ayanokoji itu aku, kan?
Dialogue: 0,0:21:12.38,0:21:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Utomiya cuma ikut menemani saja.
Dialogue: 0,0:21:15.92,0:21:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang benar.
Dialogue: 0,0:21:18.38,0:21:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukankah sebaiknya aku juga ikut?
Dialogue: 0,0:21:20.68,0:21:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin bisa menang\Nsatu lawan satu dengan Ayanokoji.
Dialogue: 0,0:21:24.64,0:21:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak boleh.
Dialogue: 0,0:21:26.35,0:21:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utomiya itu orang yang dibutuhkan Kelas C.
Dialogue: 0,0:21:31.14,0:21:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:21:32.56,0:21:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengawasi pertarunganmu dari dekat.
Dialogue: 0,0:21:38.36,0:21:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemberitahuan ke semua grup.
Dialogue: 0,0:21:40.74,0:21:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penunjukan area yang dituju musuh adalah C3.
Dialogue: 0,0:21:43.57,0:21:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup yang berada D4 tolong bersiaga.
Dialogue: 0,0:21:46.62,0:21:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup di E6 mulai bergerak ke utara\Nuntuk mengepung.
Dialogue: 0,0:21:52.83,0:21:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utomiya, Tsubaki dan Yagami,\Nketiganya saling berdekatan.
Dialogue: 0,0:21:57.88,0:22:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu cukup banyak grup anak kelas satu\Nmengepungku di D4 dan E6.
Dialogue: 0,0:22:05.43,0:22:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya bergerak, ya.
