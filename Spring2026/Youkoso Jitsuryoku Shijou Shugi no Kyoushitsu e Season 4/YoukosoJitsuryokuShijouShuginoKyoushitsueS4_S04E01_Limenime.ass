Dialogue: 0,0:01:28.48,0:01:31.74,tanda,,0000,0000,0000,,"#1 ASASIN DARI WHITE ROOM"
Dialogue: 0,0:03:15.72,0:03:17.47,tanda,,0000,0000,0000,,OAA?
Dialogue: 0,0:08:48.59,0:08:49.30,tanda,,0000,0000,0000,,RINGKASAN_UJIAN_KHUSUS_KEMAMPUAN_AKADEMIK.PDF
Dialogue: 0,0:10:49.88,0:10:50.39,tanda,,0000,0000,0000,,ICHINOSE HONAMI
Dialogue: 0,0:10:50.40,0:10:51.37,tanda,,0000,0000,0000,,AKU DAPAT IZIN MENGADAKAN ACARA KUMPUL ANTARA\NKELAS 1 DAN 2 DI GEDUNG OLAHRAGA PUKUL 4 NANTI.
Dialogue: 0,0:22:19.53,0:22:25.32,tanda,,0000,0000,0000,,CLASSROOM OF THE ELITE 4TH SEASON:\NSECOND YEAR, FIRST SEMESTER
Dialogue: 0,0:23:29.35,0:23:35.94,tanda,,0000,0000,0000,,CLASSROOM OF THE ELITE 4TH SEASON:\NSECOND YEAR, FIRST SEMESTER
Dialogue: 0,0:00:01.65,0:00:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tadi data mendetail\Ndari Ayanokoji Kiyotaka
Dialogue: 0,0:00:05.36,0:00:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta 156 siswa kelas dua.
Dialogue: 0,0:00:09.57,0:00:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah masuk ke kepalamu, kan?
Dialogue: 0,0:00:12.53,0:00:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasmu adalah membuat Ayanokoji\Ndikeluarkan di bulan April
Dialogue: 0,0:00:17.58,0:00:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membawanya kembali ke White Room.
Dialogue: 0,0:00:20.50,0:00:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jalankanlah dengan rapi.
Dialogue: 0,0:00:24.09,0:00:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sampai diketahui publik, maka namanya,
Dialogue: 0,0:00:27.21,0:00:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nama beliau ditakutkan bisa tercoreng.
Dialogue: 0,0:00:32.85,0:00:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mukamu terlihat belum bisa terima.
Dialogue: 0,0:00:37.56,0:00:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak suka kalau dia disebut-sebut\Nsebagai ciptaan terbaik, ya?
Dialogue: 0,0:00:42.94,0:00:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggungnya sudah disiapkan.
Dialogue: 0,0:00:45.90,0:00:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya aku ingin dirimu\Nmenunjukkan seluruh kemampuanmu.
Dialogue: 0,0:00:49.45,0:00:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika punya kemampuan sebesar ini,\Ntentu mengeluarkan dia bukan hal sulit.
Dialogue: 0,0:00:56.04,0:00:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa memastikan satu hal.
Dialogue: 0,0:00:59.71,0:01:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu tidak berbuat sesuatu\Ndi belakangku, kan?
Dialogue: 0,0:01:09.84,0:01:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan antarsiswa White Room.
Dialogue: 0,0:01:13.47,0:01:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memburu atau diburu.
Dialogue: 0,0:01:16.39,0:01:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya permainan antar anak kecil,
Dialogue: 0,0:01:19.98,0:01:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kelihatannya akan menarik.
Dialogue: 0,0:01:28.48,0:01:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, eh, papan tulisnya sekarang jadi monitor.
Dialogue: 0,0:01:31.74,0:01:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok, keren?
Dialogue: 0,0:01:32.57,0:01:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ayanokoji.
Dialogue: 0,0:01:34.45,0:01:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyake.
Dialogue: 0,0:01:36.45,0:01:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama libur musim semi,\Nkamu jarang setor muka sama grup.
Dialogue: 0,0:01:40.50,0:01:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku sedikit khawatir.
Dialogue: 0,0:01:42.50,0:01:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku agak sibuk.
Dialogue: 0,0:01:45.29,0:01:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, tidak usah dipaksa\Nbuat ikut kumpul.
Dialogue: 0,0:01:48.21,0:01:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi si Haruka juga sama.
Dialogue: 0,0:01:49.84,0:01:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi Airi kelihatannya sangat\Nkepikiran sama kamu.
Dialogue: 0,0:01:55.05,0:01:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:01:56.43,0:01:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencananya aku bakal\Nsekali-kali setor muka.
Dialogue: 0,0:01:59.27,0:02:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau begitu.
Dialogue: 0,0:02:00.89,0:02:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bakal kesepian\Nkalau enggak ada dirimu.
Dialogue: 0,0:02:03.77,0:02:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian obrolin apa?
Dialogue: 0,0:02:05.52,0:02:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:02:07.40,0:02:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Miyachi pelit.\N- Su-Suzune?!
Dialogue: 0,0:02:09.40,0:02:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini!\NRambutmu kenapa?!
Dialogue: 0,0:02:11.86,0:02:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikita, perubahan gayamu drastis sekali.
Dialogue: 0,0:02:14.91,0:02:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma potong rambut memangnya seaneh itu?
Dialogue: 0,0:02:18.16,0:02:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukannya aneh, sih,\Ncuma bikin kaget saja.
Dialogue: 0,0:02:22.50,0:02:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut pendekmu ternyata cocok juga.
Dialogue: 0,0:02:25.79,0:02:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, kan, Kushida?
Dialogue: 0,0:02:27.42,0:02:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ya.
Dialogue: 0,0:02:29.09,0:02:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa terjadi sesuatu?
Dialogue: 0,0:02:31.30,0:02:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau harus bilang,\Nini menunjukkan tekadku.
Dialogue: 0,0:02:34.26,0:02:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tahun ini setelah kita naik kelas,
Dialogue: 0,0:02:36.14,0:02:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan bertarung untuk\Nmenaikkan peringkat kelas D.
Dialogue: 0,0:02:39.05,0:02:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi itu, aku ingin melakukan\Napa yang kubisa.
Dialogue: 0,0:02:42.68,0:02:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:02:44.35,0:02:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mungkin sebaliknya\Naku mau coba memanjangkan rambut.
Dialogue: 0,0:02:48.44,0:02:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ribut sekali kalian ini.
Dialogue: 0,0:02:50.82,0:02:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat duduk.
Dialogue: 0,0:02:53.69,0:02:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung saja, kalian sekarang
Dialogue: 0,0:02:55.78,0:03:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus melakukan prosedur penting\Nmenjalani kehidupan sekolah ke depannya.
Dialogue: 0,0:03:00.70,0:03:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukalah situs sekolah.
Dialogue: 0,0:03:03.25,0:03:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, instal sebuah aplikasi baru.
Dialogue: 0,0:03:07.08,0:03:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama resmi aplikasinya adalah\NOver All Ability.
Dialogue: 0,0:03:13.01,0:03:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disingkat OAA.
Dialogue: 0,0:03:17.47,0:03:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aplikasi yang didistribusikan\Nke seluruh angkatan ini
Dialogue: 0,0:03:20.47,0:03:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke depannya akan memberi banyak\Nkegunaan di kehidupan sekolah.
Dialogue: 0,0:03:25.02,0:03:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, berisi data pribadi\Ndari seluruh siswa.
Dialogue: 0,0:03:29.61,0:03:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat data kalian sendiri.
Dialogue: 0,0:03:31.61,0:03:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bu Guru, kok, prestasi akademikku\Njadi kayak angka-angka di gim?
Dialogue: 0,0:03:37.36,0:03:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:38.66,0:03:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah nilai individu yang\Ndibuat pihak sekolah
Dialogue: 0,0:03:41.74,0:03:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berdasar prestasi di akhir tahun pertama.
Dialogue: 0,0:03:45.04,0:03:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prestasi seluruh angkatan dapat\Ndilihat tanpa memandang kelas.
Dialogue: 0,0:03:50.13,0:03:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai akademikku dianggap E, nih?
Dialogue: 0,0:03:53.38,0:03:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai akan diperbarui di awal bulan.
Dialogue: 0,0:03:56.30,0:03:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudo, meski sekarang nilaimu E,
Dialogue: 0,0:03:59.18,0:04:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau dapat nilai sempurna\Ndi ujian tulis selanjutnya,
Dialogue: 0,0:04:01.93,0:04:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti akan diberi nilai A+.
Dialogue: 0,0:04:05.64,0:04:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, nilai jelek akan tetap\Njadi catatan buruk, ya.
Dialogue: 0,0:04:10.06,0:04:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu,\Nbisa dilihat seluruh sekolah, kan?
Dialogue: 0,0:04:13.15,0:04:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai kalian di tahun pertama\Nhanyalah masa lalu.
Dialogue: 0,0:04:16.77,0:04:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan berpengaruh pada\Npenilaian kalian ke depannya.
Dialogue: 0,0:04:20.16,0:04:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,
Dialogue: 0,0:04:21.12,0:04:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengingatkan kembali mereka\Nyang memiliki prestasi buruk,
Dialogue: 0,0:04:25.16,0:04:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan harapan mendorong\Nperkembangan kalian.
Dialogue: 0,0:04:27.66,0:04:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat praktis untuk mengecek prestasi.
Dialogue: 0,0:04:30.67,0:04:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:04:31.58,0:04:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin cuma itu.
Dialogue: 0,0:04:33.29,0:04:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah aplikasi yang adil.
Dialogue: 0,0:04:35.46,0:04:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan dinilai dengan setara
Dialogue: 0,0:04:37.63,0:04:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan akan berperan sebagai sarana menjalin\Ninteraksi tanpa memandang angkatan.
Dialogue: 0,0:04:42.72,0:04:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, kurasa tidak akan\Nhanya berhenti di situ.
Dialogue: 0,0:04:47.60,0:04:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini spekulasi belaka.
Dialogue: 0,0:04:50.10,0:04:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi selama setahun ke depan,
Dialogue: 0,0:04:51.69,0:04:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siswa yang nilai kumulatifnya\Ntidak mencapai standar tertentu,
Dialogue: 0,0:04:55.11,0:04:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin akan diberi suatu penalti.
Dialogue: 0,0:04:58.53,0:05:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penalti?
Dialogue: 0,0:05:00.36,0:05:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, dikeluarkan?
Dialogue: 0,0:05:02.53,0:05:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-Yang benar, nih?!
Dialogue: 0,0:05:04.83,0:05:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada yang tidak terima\Ndengan nilai kalian sendiri.
Dialogue: 0,0:05:07.95,0:05:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi inilah penilaian yang\Ndiberikan pada kalian saat ini.
Dialogue: 0,0:05:10.96,0:05:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada keberatan,
Dialogue: 0,0:05:12.62,0:05:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tunjukkan kemampuan kalian selama\Nsetahun ini agar pihak sekolah mengerti.
Dialogue: 0,0:05:17.38,0:05:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah seperti pertandingan individu.
Dialogue: 0,0:05:19.84,0:05:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penerapan aplikasi yang seolah mematahkan
Dialogue: 0,0:05:22.72,0:05:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}alur pertarungan sebagai kelas\Nyang ada selama ini.
Dialogue: 0,0:05:25.97,0:05:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak heran kalau ada yang bingung\Ndan tidak puas.
Dialogue: 0,0:05:28.60,0:05:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu diingat, sistem ini diterapkan
Dialogue: 0,0:05:31.98,0:05:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas usulan Nagumo Miyabi\Nselaku ketua OSIS aktif.
Dialogue: 0,0:05:35.36,0:05:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat sistem yang menilai\Nkemampuan asli individu.
Dialogue: 0,0:05:38.78,0:05:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi yang dikatakan Nagumo itu\Nkini sudah terealisasi, ya?
Dialogue: 0,0:05:43.11,0:05:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, ujian khusus pertama kalian\Nsetelah naik ke kelas dua kali ini
Dialogue: 0,0:05:48.99,0:05:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lagi-lagi memiliki aspek baru yang\Nbelum pernah ada sebelumnya.
Dialogue: 0,0:05:53.29,0:05:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah ujian tulis di mana
Dialogue: 0,0:05:56.84,0:06:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian sebagai kelas dua akan\Nberpartner dengan anak baru kelas satu.
Dialogue: 0,0:06:01.84,0:06:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpartner sama kelas satu?
Dialogue: 0,0:06:04.89,0:06:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini sekolah belum pernah
Dialogue: 0,0:06:06.35,0:06:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengadakan interaksi antar angkatan\Nsecara mendalam.
Dialogue: 0,0:06:09.72,0:06:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah kemampuan komunikasi kalian\Ndinilai kurang berkembang.
Dialogue: 0,0:06:14.48,0:06:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi, kami bersaing dengan\Nsesama angkatan, kan?
Dialogue: 0,0:06:18.90,0:06:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya ada yang aneh.
Dialogue: 0,0:06:21.74,0:06:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kalian pikirkan.
Dialogue: 0,0:06:23.24,0:06:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang akan kalian temui\Nsaat masuk ke masyarakat nanti,
Dialogue: 0,0:06:26.37,0:06:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan hanya sesama lulusan baru saja.
Dialogue: 0,0:06:28.99,0:06:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu ke depannya,
Dialogue: 0,0:06:30.41,0:06:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa jadi ada situasi saat kalian harus\Nbersaing dengan kelas satu atau tiga.
Dialogue: 0,0:06:34.25,0:06:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bebas mau berpasangan\Ndengan anak kelas satu mana pun.
Dialogue: 0,0:06:38.25,0:06:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujiannya diadakan akhir bulan\Ndua pekan lagi.
Dialogue: 0,0:06:40.71,0:06:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah disiapkan banyak waktu\Nuntuk memilih partner.
Dialogue: 0,0:06:45.26,0:06:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjalin kepercayaan dengan adik kelas\Nyang belum begitu dekat itu sulit.
Dialogue: 0,0:06:51.01,0:06:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itulah disiapkan aplikasi OAA, ya.
Dialogue: 0,0:06:54.27,0:06:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lima mapel yang diujikan,\Ntotal nilai penuhnya adalah 500.
Dialogue: 0,0:06:58.19,0:07:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu yang penting dari aturannya adalah...
Dialogue: 0,0:07:00.69,0:07:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini disiapkan menang-kalah\Nuntuk kelas dan individu.
Dialogue: 0,0:07:07.28,0:07:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi betulan ada penalti\Ndikeluarkan dari sekolah, nih?!
Dialogue: 0,0:07:10.28,0:07:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasangan dibentuk atas kesepakatan bersama.
Dialogue: 0,0:07:13.00,0:07:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dibentuk, tidak akan bisa\Ndibatalkan dengan alasan apa pun.
Dialogue: 0,0:07:16.87,0:07:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah paham, kan?
Dialogue: 0,0:07:18.54,0:07:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam ujian ini,
Dialogue: 0,0:07:20.00,0:07:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siswa dengan akademik tinggi\Nakan terpilih lebih dulu.
Dialogue: 0,0:07:23.80,0:07:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Bu.
Dialogue: 0,0:07:25.09,0:07:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jadinya kalau ada siswa yang\Ntidak dapat partner sebelum ujian?
Dialogue: 0,0:07:29.55,0:07:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak terpilih, pasangannya akan\Ndipilih secara acak di hari ujian.
Dialogue: 0,0:07:33.77,0:07:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau begitu,
Dialogue: 0,0:07:35.43,0:07:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan ada penalti pengurangan nilai\Nsebesar lima persen.
Dialogue: 0,0:07:38.81,0:07:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujung-ujungnya bakal susah\Nkalau enggak dapat pasangan, dong.
Dialogue: 0,0:07:46.07,0:07:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana ini, Hirata?!
Dialogue: 0,0:07:48.41,0:07:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana adik kelas yang mau berpasangan\Nsama aku yang akademiknya E!
Dialogue: 0,0:07:52.49,0:07:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak yakin.
Dialogue: 0,0:07:54.70,0:07:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang tenang dulu.
Dialogue: 0,0:07:56.33,0:07:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru tentukan arah kita.
Dialogue: 0,0:07:58.37,0:07:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:59.17,0:08:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak perlu panik.
Dialogue: 0,0:08:01.54,0:08:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat prediksi nilai\Nberdasar peringkat akademik
Dialogue: 0,0:08:04.67,0:08:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dikirim bersama\Nringkasan ujian di aplikasi.
Dialogue: 0,0:08:07.84,0:08:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batas nilai total kelulusannya adalah 500.
Dialogue: 0,0:08:10.51,0:08:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, jika siswa dengan akademik E\Nberpasangan dengan peringkat B ke atas,
Dialogue: 0,0:08:15.10,0:08:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa dibilang akan aman di ujian ini.
Dialogue: 0,0:08:17.60,0:08:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar kata Horikita.
Dialogue: 0,0:08:19.77,0:08:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal tekun mendalami materi seperti biasa,\Nkita semua pasti bisa melewatinya.
Dialogue: 0,0:08:24.36,0:08:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting adalah,\Njangan enteng memilih pasangan.
Dialogue: 0,0:08:28.15,0:08:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada apa-apa, pastikan untuk\Nmendiskusikannya denganku atau Hirata.
Dialogue: 0,0:08:34.12,0:08:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa yang dianggap sengaja\Nmendapat nilai rendah,
Dialogue: 0,0:08:38.00,0:08:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan dikeluarkan tanpa\Nmemandang angkatannya.
Dialogue: 0,0:08:41.28,0:08:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Normalnya, ini sudah cukup\Nuntuk mencegah itu terjadi.
Dialogue: 0,0:08:44.16,0:08:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ceritanya akan berbeda\Nkalau itu anak dari White Room.
Dialogue: 0,0:08:49.31,0:08:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika berhasil berpasangan denganku.
Dialogue: 0,0:08:51.89,0:08:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti tidak akan takut dapat nilai nol\Nuntuk menyeretku keluar.
Dialogue: 0,0:08:55.89,0:09:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, kalau aku sampai memilih\Npasangan dari White Room,
Dialogue: 0,0:09:00.69,0:09:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu sudah akan tamat.
Dialogue: 0,0:09:02.85,0:09:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Yayasan Sementara Tsukishiro.
Dialogue: 0,0:09:05.27,0:09:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi ini aturan buatan pria itu.
Dialogue: 0,0:09:14.12,0:09:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa?
Dialogue: 0,0:09:15.99,0:09:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih ingat janji\Nsaat libur musim dingin
Dialogue: 0,0:09:19.61,0:09:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk bertanding denganku, kan?
Dialogue: 0,0:09:21.37,0:09:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian khusus kali ini\Nsangat pas buat itu, ya?
Dialogue: 0,0:09:25.09,0:09:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:26.09,0:09:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu menang, aku akan masuk OSIS.
Dialogue: 0,0:09:29.01,0:09:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku yang menang, ke depannya
Dialogue: 0,0:09:31.09,0:09:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu harus mengerahkan kemampuan asli\Nyang kau sembunyikan demi kelas.
Dialogue: 0,0:09:35.10,0:09:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan.
Dialogue: 0,0:09:37.10,0:09:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:09:38.72,0:09:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, langsung saja\Nke topik selanjutnya.
Dialogue: 0,0:09:42.27,0:09:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memeriksa anak kelas satu\Ndengan peringkat akademik B ke atas.
Dialogue: 0,0:09:46.48,0:09:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kelas A ada 17 orang,\Nkelas B dan C masing-masing 13 orang.
Dialogue: 0,0:09:51.11,0:09:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kelas D ada 11 orang.
Dialogue: 0,0:09:53.86,0:09:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Total 54 orang.
Dialogue: 0,0:09:56.74,0:10:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kelas kita yang peringkat\Nakademiknya E hanya ada empat.
Dialogue: 0,0:10:00.33,0:10:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah peringkat D sekalipun\Ntotal 12 orang.
Dialogue: 0,0:10:03.08,0:10:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kelas satu sudah punya\Ndaya tempur yang cukup.
Dialogue: 0,0:10:07.13,0:10:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jadi masalah adalah seberapa banyak
Dialogue: 0,0:10:09.42,0:10:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa memasangkan anak teladan itu\Ndengan mereka yang berakademik D dan E.
Dialogue: 0,0:10:13.59,0:10:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:14.47,0:10:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menurutku harus diurus\Nlebih dulu adalah Sudo.
Dialogue: 0,0:10:18.85,0:10:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya nilai akademik Sudo\Nsekarang sudah cukup membaik?
Dialogue: 0,0:10:23.35,0:10:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademiknya iya.
Dialogue: 0,0:10:25.15,0:10:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau kamu adalah anak kelas satu\Nyang tidak tahu apa-apa.
Dialogue: 0,0:10:28.52,0:10:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang lebih mudah diajak berpasangan\Nantara Sudo dan Ike?
Dialogue: 0,0:10:31.61,0:10:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:10:32.57,0:10:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perawakan yang mengintimidasi,\Nmulut super kasar.
Dialogue: 0,0:10:35.28,0:10:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimanapun Sudo kesannya seram.
Dialogue: 0,0:10:38.37,0:10:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:39.33,0:10:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak hati-hati, mencarikannya\Npasangan itu sendiri akan sulit.
Dialogue: 0,0:10:43.21,0:10:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku ingin segera bergerak,\Nkamu bisa bantu?
Dialogue: 0,0:10:51.38,0:10:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ichinose memang cekatan.
Dialogue: 0,0:10:53.38,0:10:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya kelas B,
Dialogue: 0,0:10:55.26,0:10:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mengambil langkah dengan\Nmemikirkan keseluruhannya.
Dialogue: 0,0:10:58.39,0:11:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas A dan C pasti juga akan\Nmenjalankan langkah yang lain.
Dialogue: 0,0:11:03.18,0:11:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih belum tahu langkah apa\Nyang akan diambil Ryuen atau Sakayanagi.
Dialogue: 0,0:11:06.60,0:11:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi menurutku, salah satu yang\Njadi kuncinya adalah poin pribadi.
Dialogue: 0,0:11:12.03,0:11:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu strategi jual beli\Ndengan uang tunai, ya.
Dialogue: 0,0:11:15.20,0:11:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:15.95,0:11:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi kelas satu, poin adalah\Nnilai yang paling mudah dimengerti.
Dialogue: 0,0:11:19.74,0:11:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita seharusnya juga mengeluarkan uang\Nuntuk mengamankan beberapa orang.
Dialogue: 0,0:11:25.21,0:11:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita yang pendapatan poinnya sulit,\Nakan berat untuk ikut main uang.
Dialogue: 0,0:11:30.00,0:11:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita awasi dulu acara kumpulnya.
Dialogue: 0,0:11:32.46,0:11:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:11:33.63,0:11:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutemani.
Dialogue: 0,0:11:34.92,0:11:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu betulan akan membantu?
Dialogue: 0,0:11:38.18,0:11:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin melihat cara bertarung\Nseperti apa yang akan kau pakai.
Dialogue: 0,0:11:43.18,0:11:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:44.52,0:11:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya masih terlalu cepat\Nuntuk memakai istilah "kerja sama".
Dialogue: 0,0:11:52.44,0:11:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama-tama harus membangun\Nrasa saling percaya.
Dialogue: 0,0:11:56.15,0:11:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langkah yang khas dari Ichinose.
Dialogue: 0,0:11:58.70,0:12:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, nih, yakin mau santai begini?
Dialogue: 0,0:12:01.74,0:12:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kepalanya encer bakal diembat\Nkelas B semua, lo.
Dialogue: 0,0:12:04.66,0:12:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, kita bisa mengalahkan\Ngrup Ichinose soal bersosialisasi di sini?
Dialogue: 0,0:12:10.71,0:12:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak terpikir.
Dialogue: 0,0:12:12.46,0:12:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi.
Dialogue: 0,0:12:15.21,0:12:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin, nih, Suzune?
Dialogue: 0,0:12:18.05,0:12:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari setengah siswa yang ada\Ntidak hadir di acara kumpul ini.
Dialogue: 0,0:12:22.10,0:12:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bernegosiasi\Ndengan mereka yang tidak hadir.
Dialogue: 0,0:12:26.93,0:12:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian sadar?
Dialogue: 0,0:12:28.35,0:12:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ketimpangan dari siswa-siswa\Nyang datang di acara kumpul ini.
Dialogue: 0,0:12:32.36,0:12:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketimpangan?
Dialogue: 0,0:12:33.86,0:12:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa kelas 1-D sama sekali\Ntidak ada yang datang.
Dialogue: 0,0:12:38.36,0:12:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang itu artinya apa?
Dialogue: 0,0:12:40.61,0:12:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kelas itu ada 40 siswa, lo.
Dialogue: 0,0:12:43.33,0:12:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sama sekali tidak ada yang datang,\Nberarti itu jelas keputusan bersama kelas.
Dialogue: 0,0:12:48.87,0:12:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya sudah ada pemimpin di kelas 1-D
Dialogue: 0,0:12:52.08,0:12:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia menolak acara kumpul ini, ya.
Dialogue: 0,0:12:55.13,0:12:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:56.00,0:12:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa nego langsung dengan pemimpinnya,
Dialogue: 0,0:12:58.63,0:13:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak perlu lagi bertaruh secara individu.
Dialogue: 0,0:13:06.18,0:13:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, Ichinose masih seperti biasa, ya.
Dialogue: 0,0:13:10.14,0:13:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia mengutamakan untuk\Nmenyelamatkan kelasnya dan kelas satu.
Dialogue: 0,0:13:14.40,0:13:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia paham ruginya menarik\Norang bodoh tidak, sih?
Dialogue: 0,0:13:17.86,0:13:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama saja mengalah dari pertarungan.
Dialogue: 0,0:13:20.15,0:13:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kalian dari kelas A,
Dialogue: 0,0:13:22.11,0:13:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakayanagi sudah memprediksi\Nsituasi ini, ya.
Dialogue: 0,0:13:25.62,0:13:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya tidak hadir di acara.
Dialogue: 0,0:13:27.54,0:13:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, pasti begitu.
Dialogue: 0,0:13:30.04,0:13:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana caranya kalian akan\Nmenarik para siswa teladan?
Dialogue: 0,0:13:33.79,0:13:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tergantung pemikiran Tuan Putri.
Dialogue: 0,0:13:36.92,0:13:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma menuruti perintah.
Dialogue: 0,0:13:41.80,0:13:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bergegas.
Dialogue: 0,0:13:43.13,0:13:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jam segini seharusnya masih ada\Nanak kelas D yang di kelas.
Dialogue: 0,0:13:52.23,0:13:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datangmu lama juga, Suzune.
Dialogue: 0,0:13:56.40,0:13:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryuen.
Dialogue: 0,0:13:57.73,0:14:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga tidak ikut acara kumpul\Nuntuk menengok anak kelas satu?
Dialogue: 0,0:14:01.49,0:14:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kumpul di gedung olahraga,\Nisinya anak bego semua, kan?
Dialogue: 0,0:14:06.28,0:14:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak butuh dilihat.
Dialogue: 0,0:14:07.49,0:14:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah ke kelas D?!
Dialogue: 0,0:14:10.00,0:14:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, aku masih belum\Nmenarik siapa-siapa.
Dialogue: 0,0:14:14.00,0:14:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikapmu itu, yang ada anak kelas satu\Nhanya akan takut padamu.
Dialogue: 0,0:14:17.29,0:14:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuancam sedikit saja, kurasa mereka\Nakan langsung membantuku.
Dialogue: 0,0:14:22.01,0:14:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda.
Dialogue: 0,0:14:23.38,0:14:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa menurutmu cara itu diizinkan?
Dialogue: 0,0:14:25.76,0:14:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan urusan diizinkan atau tidak.
Dialogue: 0,0:14:28.47,0:14:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada aturan yang melarang\Ncari partner dengan mengancam orang.
Dialogue: 0,0:14:33.02,0:14:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak perlu ditulis dalam aturan.
Dialogue: 0,0:14:35.60,0:14:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jadi masalah,\Nyang akan repot itu kamu.
Dialogue: 0,0:14:38.36,0:14:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu buat saja jadi masalah.
Dialogue: 0,0:14:41.11,0:14:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku tidak akan bertindak bodoh\Nsampai membuatku ketahuan.
Dialogue: 0,0:14:45.86,0:14:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuberi tahu satu hal menarik.
Dialogue: 0,0:14:48.41,0:14:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal anak kelas satu\Nmasih belum lama masuk,
Dialogue: 0,0:14:51.54,0:14:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mereka tenang sekali.
Dialogue: 0,0:14:53.37,0:14:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini mau bilang apa?
Dialogue: 0,0:14:55.37,0:14:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, besar kemungkinan\Norang dari pihak sekolah
Dialogue: 0,0:14:58.21,0:15:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah menjelaskan sistem sekolah\Nke anak baru sampai batas tertentu.
Dialogue: 0,0:15:05.63,0:15:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, berjuanglah sekuat tenaga\Nagar tidak tertinggal.
Dialogue: 0,0:15:10.01,0:15:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin anak-anak kelas satu
Dialogue: 0,0:15:12.64,0:15:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menolak kita lebih keras\Ndari yang kuduga.
Dialogue: 0,0:15:15.85,0:15:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo segera\Nnegosiasi dengan mereka.
Dialogue: 0,0:15:22.28,0:15:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?!
Dialogue: 0,0:15:24.28,0:15:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kelas ini lebih merepotkan\Ndari dugaanku.
Dialogue: 0,0:15:31.91,0:15:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, sudah dapat pasangan?\N- Sudah 22 pasangan yang terbentuk, ya.
Dialogue: 0,0:15:34.50,0:15:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut pemberitahuan,
Dialogue: 0,0:15:36.04,0:15:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tadi pagi sudah dipastikan ada 22 pasangan.
Dialogue: 0,0:15:39.67,0:15:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan langsung dikeluarkan kalau\Ndapat pasangan anak White Room.
Dialogue: 0,0:15:43.92,0:15:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya aku sudah menghafal\Nmuka dan nama seluruh anak kelas satu.
Dialogue: 0,0:15:48.30,0:15:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oi!
Dialogue: 0,0:15:50.35,0:15:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada anak kelas satu yang ke sini!
Dialogue: 0,0:16:08.78,0:16:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya Nanase Tsubasa dari kelas 1-D.
Dialogue: 0,0:16:12.95,0:16:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan dia juga dari kelas yang sama.
Dialogue: 0,0:16:15.04,0:16:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Hosen.
Dialogue: 0,0:16:17.04,0:16:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai datang ke lantai kakak kelas.
Dialogue: 0,0:16:19.96,0:16:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tindakan kalian cukup berani\Nuntuk ukuran anak baru.
Dialogue: 0,0:16:23.63,0:16:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuakui nyalimu.
Dialogue: 0,0:16:25.76,0:16:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:16:27.05,0:16:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang mengakui nyaliku?
Dialogue: 0,0:16:28.97,0:16:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlagak sekali kau.
Dialogue: 0,0:16:30.26,0:16:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok keras kau bocah kelas satu!
Dialogue: 0,0:16:33.76,0:16:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:16:35.02,0:16:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan akademiknya E+.
Dialogue: 0,0:16:37.02,0:16:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh banget kayak mukanya.
Dialogue: 0,0:16:39.81,0:16:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?!
Dialogue: 0,0:16:41.10,0:16:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas sekali.
Dialogue: 0,0:16:42.36,0:16:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, yang datang ke sini\Npaling cuma kelas D.
Dialogue: 0,0:16:46.15,0:16:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan menguntungkan.
Dialogue: 0,0:16:47.36,0:16:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu itu?
Dialogue: 0,0:16:49.45,0:16:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kelas D adalah kumpulan anak gagal.
Dialogue: 0,0:16:52.53,0:16:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak kami tunjuk,\Nmana bisa dapat pasangan yang bagus.
Dialogue: 0,0:16:57.29,0:17:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya akan kubantu kalian yang bodoh\Ndan tidak becus ini.
Dialogue: 0,0:17:01.21,0:17:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya paham, kan?
Dialogue: 0,0:17:03.04,0:17:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu artinya kalian ingin\Nberpasangan dengan kami?
Dialogue: 0,0:17:06.58,0:17:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah minta dengan arogan begitu.
Dialogue: 0,0:17:08.80,0:17:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha? Yang harusnya minta\Nitu kalian, tahu?
Dialogue: 0,0:17:11.83,0:17:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat menunduk dan bilang,\N"Izinkan kami berpasangan dengan kalian".
Dialogue: 0,0:17:15.81,0:17:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:17:17.59,0:17:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya ada salah paham di sini.
Dialogue: 0,0:17:19.84,0:17:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita di posisi yang setara\Nsebagai sesama kelas D.
Dialogue: 0,0:17:23.56,0:17:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setara?
Dialogue: 0,0:17:25.44,0:17:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak paham, ya?
Dialogue: 0,0:17:27.31,0:17:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, kami bisa melakukan apa saja.
Dialogue: 0,0:17:30.78,0:17:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti enggak mau ribet, kan?
Dialogue: 0,0:17:33.16,0:17:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia sadar senjata khusus\Nyang hanya dimiliki kelas satu.
Dialogue: 0,0:17:38.54,0:17:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kamu mau pakai cara apa?
Dialogue: 0,0:17:41.25,0:17:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu, kan, kalau kami punya cara\Nuntuk menurunkan nilai secara paksa?
Dialogue: 0,0:17:46.75,0:17:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, kau ini bercanda, ya?!
Dialogue: 0,0:17:49.38,0:17:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak serius di ujian, bakal dikeluarkan!
Dialogue: 0,0:17:51.59,0:17:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kalau tidak serius\Nbakal dikeluarkan.
Dialogue: 0,0:17:53.93,0:17:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ya.
Dialogue: 0,0:17:54.84,0:17:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penalti dari gagal dapat pasangan\Nsebelum waktu habis beda cerita.
Dialogue: 0,0:18:00.77,0:18:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bakal kena repot itu kalian,\Nkelas dua yang bisa saja dikeluarkan.
Dialogue: 0,0:18:05.52,0:18:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak dikeluarkan, kalian berniat\Nkehilangan poin pribadi, ya?
Dialogue: 0,0:18:10.28,0:18:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan kalian,\Nbukan kerugian yang berarti.
Dialogue: 0,0:18:13.95,0:18:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kan?
Dialogue: 0,0:18:14.61,0:18:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:15.45,0:18:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak akan mendapat\Npoin pribadi selama tiga bulan.
Dialogue: 0,0:18:19.41,0:18:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksimal 240 ribu poin.
Dialogue: 0,0:18:21.62,0:18:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami rasa itu bukan masalah yang fatal.
Dialogue: 0,0:18:25.75,0:18:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang paham situasinya?
Dialogue: 0,0:18:29.00,0:18:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok berlagu begitu!
Dialogue: 0,0:18:31.67,0:18:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan hilang kesabaran, Sudo.
Dialogue: 0,0:18:34.18,0:18:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu seharusnya sangat tahu\Nsoal sekolah ini, kan?
Dialogue: 0,0:18:37.68,0:18:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku tahu.
Dialogue: 0,0:18:41.98,0:18:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang gede badannya doang, nih?
Dialogue: 0,0:18:44.19,0:18:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kupegang sedikit, lo.
Dialogue: 0,0:18:46.27,0:18:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:18:47.19,0:18:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kau ini?!
Dialogue: 0,0:18:49.36,0:18:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ishizaki?!
Dialogue: 0,0:18:50.86,0:18:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncul terus satu per satu kayak kecoak.
Dialogue: 0,0:18:54.74,0:18:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tahu batas sedikit\Nkalau mengejek kelas dua!
Dialogue: 0,0:18:58.24,0:19:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan kalau kau tidak mau mati, Ishizaki.
Dialogue: 0,0:19:01.16,0:19:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa malah dihentikan?!
Dialogue: 0,0:19:03.91,0:19:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham betul siapa dirimu.
Dialogue: 0,0:19:06.50,0:19:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen memang agak terkenal\Ndi tempat asalku.
Dialogue: 0,0:19:11.42,0:19:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu siapa dia, Ryuen?
Dialogue: 0,0:19:14.34,0:19:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak kusangka ternyata\Nmukanya bisa sebodoh ini.
Dialogue: 0,0:19:18.64,0:19:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertemuan yang tidak terduga.
Dialogue: 0,0:19:21.22,0:19:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai muak dengar gosip tentangmu.
Dialogue: 0,0:19:24.39,0:19:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak kusangka Ryuen yang jadi\Nbuah bibir itu badannya selembek ini.
Dialogue: 0,0:19:30.19,0:19:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri sampai kelihatan berotak otot.
Dialogue: 0,0:19:33.94,0:19:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berniat membunuhmu\Nbeberapa kali saat perjalanan.
Dialogue: 0,0:19:37.61,0:19:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau takut padaku dan sembunyi, kan?
Dialogue: 0,0:19:40.91,0:19:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruntung sekali dirimu.
Dialogue: 0,0:19:42.83,0:19:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertemu denganku,
Dialogue: 0,0:19:44.33,0:19:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mungkin sekarang kau\Nbisa bersikap angkuh begitu.
Dialogue: 0,0:19:47.96,0:19:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja kalau mau\Nselesaikan semuanya di sini.
Dialogue: 0,0:19:53.17,0:19:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah saja.
Dialogue: 0,0:19:54.96,0:19:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau baku hantam dengan gorila\Ntanpa imbalan apa-apa.
Dialogue: 0,0:19:58.72,0:20:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin mau tetap diremehkan\Nanak kelas satu begini?
Dialogue: 0,0:20:02.81,0:20:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusannya bisa diselesaikan kapan saja.
Dialogue: 0,0:20:05.73,0:20:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, ayo main dulu, Ryuen.
Dialogue: 0,0:20:08.48,0:20:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang tidak mau.
Dialogue: 0,0:20:10.48,0:20:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:20:16.28,0:20:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo coba kabur.
Dialogue: 0,0:20:17.86,0:20:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat sini, kalian boleh saja\Nkalau mau maju semua!
Dialogue: 0,0:20:21.12,0:20:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah gila, ya?!
Dialogue: 0,0:20:22.45,0:20:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:20:23.95,0:20:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, Hosen!
Dialogue: 0,0:20:25.83,0:20:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:20:27.33,0:20:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak tadi para kakak kelas\Nsudah khawatir dengan kamera pengawas.
Dialogue: 0,0:20:30.96,0:20:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menilai tidak ada untungnya\Njika mengamuk di sini.
Dialogue: 0,0:20:34.42,0:20:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah paham itu\Nmakanya main-main di sini.
Dialogue: 0,0:20:37.59,0:20:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap melakukan hal tidak berguna,\Naku punya rencanaku sendiri.
Dialogue: 0,0:20:41.72,0:20:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupertimbangkan untuk\Nmembeberkan "itu" di sini.
Dialogue: 0,0:20:50.73,0:20:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani juga kau mengancamku, Nanase.
Dialogue: 0,0:20:54.36,0:20:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak akan ragu-ragu\Nkalau kau mengkhianati harapanku.
Dialogue: 0,0:20:58.36,0:21:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghadapinya saat itu terjadi.
Dialogue: 0,0:21:00.86,0:21:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kamu, Hosen?
Dialogue: 0,0:21:03.37,0:21:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:21:04.62,0:21:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkelahi itu tidak seharusnya\Ndi tempat umum.
Dialogue: 0,0:21:07.62,0:21:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang begini namanya bukan perkelahian.
Dialogue: 0,0:21:10.42,0:21:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo balik, Nanase.
Dialogue: 0,0:21:12.08,0:21:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pilihan bijak.
Dialogue: 0,0:21:18.92,0:21:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau sujud, aku akan berpasangan\Ndenganmu, Abang Ryuen.
Dialogue: 0,0:21:23.76,0:21:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, aku tidak ada niat\Nberpasangan dengan gorila liar.
Dialogue: 0,0:21:27.93,0:21:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sangat disayangkan.
Dialogue: 0,0:21:30.60,0:21:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, Horikita.
Dialogue: 0,0:21:35.06,0:21:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah membuat ribut.
Dialogue: 0,0:21:49.58,0:21:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorot matanya yang seolah\Nsedang mengamati itu.
