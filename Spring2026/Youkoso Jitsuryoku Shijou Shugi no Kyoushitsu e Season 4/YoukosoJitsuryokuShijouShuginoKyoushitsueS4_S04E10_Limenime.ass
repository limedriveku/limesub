Dialogue: 0,0:00:53.62,0:00:54.62,tanda,,0000,0000,0000,,TOPIK: ANIME SECARA UMUM
Dialogue: 0,0:00:56.62,0:00:57.46,tanda,,0000,0000,0000,,PERTANYAAN PERTAMA: BERIKUT MANAKAH YANG\NMERUPAKAN JUDUL EPISODE 13 ROBOT PETARUNG BUNDAM?
Dialogue: 0,0:02:43.93,0:02:46.77,tanda,,0000,0000,0000,,"#10 PERASAAN TAK SAMPAI"
Dialogue: 0,0:09:28.05,0:09:31.05,tanda,,0000,0000,0000,,HARI KE-3
Dialogue: 0,0:17:16.89,0:17:18.77,tanda,,0000,0000,0000,,"TOPIK: SEJARAH"
Dialogue: 0,0:17:18.77,0:17:20.77,tanda,,0000,0000,0000,,PERTANYAAN PERTAMA: SIAPAKAH SHOGUN TERLAMA\NDALAM SEJARAH DAN DIKENAL "PUNYA BANYAK ANAK"?
Dialogue: 0,0:21:23.34,0:21:26.85,tanda,,0000,0000,0000,,HARI KE-4
Dialogue: 0,0:00:04.23,0:00:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:00:06.49,0:00:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ayanokoji.
Dialogue: 0,0:00:08.32,0:00:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau juga ikut tugas kuis rupanya?
Dialogue: 0,0:00:10.99,0:00:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:12.07,0:00:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kondisi grupmu sendiri lancar?
Dialogue: 0,0:00:14.79,0:00:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lancar jaya, dapat poin.
Dialogue: 0,0:00:17.08,0:00:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja si Kanji agak kurang semangat.
Dialogue: 0,0:00:22.67,0:00:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sudah agak aneh sejak sebelum ujian.
Dialogue: 0,0:00:25.46,0:00:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tutupi bilang tidak ada apa-apa.
Dialogue: 0,0:00:28.72,0:00:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang jadi khawatir,\Ntapi tugas tetaplah tugas.
Dialogue: 0,0:00:31.80,0:00:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian bertiga bekerja sama,
Dialogue: 0,0:00:34.04,0:00:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masuk ke peringkat atas\Nbukanlah hal yang sulit.
Dialogue: 0,0:00:36.06,0:00:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:37.10,0:00:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kau cuma sendiri, kan?
Dialogue: 0,0:00:39.85,0:00:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin bisa?
Dialogue: 0,0:00:41.10,0:00:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tergantung dapat topik\Nyang kukuasai atau tidak.
Dialogue: 0,0:00:45.23,0:00:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, sampai nanti.
Dialogue: 0,0:00:47.53,0:00:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti katamu, tugas tetaplah tugas.
Dialogue: 0,0:00:49.78,0:00:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kami kerjakan sekuat tenaga.
Dialogue: 0,0:00:51.61,0:00:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai.
Dialogue: 0,0:00:55.28,0:00:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anime?
Dialogue: 0,0:00:57.50,0:00:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:00:59.62,0:01:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar, nih?!\NGampang banget, dong!
Dialogue: 0,0:01:01.96,0:01:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula...
Dialogue: 0,0:01:04.20,0:01:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bundam itu apa?
Dialogue: 0,0:01:17.52,0:01:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:27.33,0:02:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:38.76,0:02:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap, dapat peringkat satu!
Dialogue: 0,0:02:40.89,0:02:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat kali!
Dialogue: 0,0:02:42.27,0:02:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanji!
Dialogue: 0,0:02:43.93,0:02:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah? Oh!
Dialogue: 0,0:02:46.77,0:02:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaannya sulit-sulit, ya.
Dialogue: 0,0:02:49.27,0:02:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:02:52.03,0:02:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada sesuatu yang mengganggu Kakak\Ndari grup Kak Sudo?
Dialogue: 0,0:02:56.11,0:02:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Nanase lihat bagaimana?
Dialogue: 0,0:02:58.03,0:03:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak kelas yang sedang duduk\Nterlihat tidak semangat.
Dialogue: 0,0:03:01.79,0:03:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tubuhnya sedang tidak enak?
Dialogue: 0,0:03:04.12,0:03:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada masalah dari badannya.
Dialogue: 0,0:03:06.54,0:03:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti Kakak khawatir kalau ada masalah\Ndari sisi mentalnya?
Dialogue: 0,0:03:10.42,0:03:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang kepikiran, tapi tidak bisa\Nterus-terusan mengkhawatirkan orang lain.
Dialogue: 0,0:03:16.05,0:03:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini waktu lokasi tujuan keempat diumumkan.
Dialogue: 0,0:03:19.35,0:03:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berangkat sekarang?
Dialogue: 0,0:03:20.85,0:03:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, Nanase...
Dialogue: 0,0:03:22.81,0:03:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tunjukkan tabletmu.
Dialogue: 0,0:03:25.52,0:03:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:03:27.06,0:03:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum tentu kalau kita\Nada di tabel yang sama.
Dialogue: 0,0:03:30.27,0:03:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira akan menunjukkan\Nsuatu reaksi perlawanan.
Dialogue: 0,0:03:34.65,0:03:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya saya memang berada\Ndi tabel yang sama dengan Kakak.
Dialogue: 0,0:03:38.16,0:03:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:03:39.28,0:03:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ingin ambil rute terpendek?
Dialogue: 0,0:03:41.28,0:03:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kali ini tidak akan memaksakan diri.
Dialogue: 0,0:03:44.16,0:03:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga muncul tugas di G8 dan G9.
Dialogue: 0,0:03:48.04,0:03:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyelesaikan hari ini\Ndengan mengitari kedua lokasi itu.
Dialogue: 0,0:03:52.04,0:03:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mau di mana\Nlokasi kemah hari ini?
Dialogue: 0,0:03:54.76,0:03:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:03:56.59,0:04:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menyelesaikan tugas,\Nrencanaku jalan ke H9 dan kemah di sana.
Dialogue: 0,0:04:01.39,0:04:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Ayanokoji, tadi kau bilang\Nmau kemah di H9, ya?
Dialogue: 0,0:04:05.77,0:04:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa memangnya?
Dialogue: 0,0:04:07.73,0:04:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lokasi selanjutnya\Nyang ditunjuk untuk kami.
Dialogue: 0,0:04:10.56,0:04:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, nanti mau gabung tidak?
Dialogue: 0,0:04:13.40,0:04:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih meriah kalau ada temannya.
Dialogue: 0,0:04:15.82,0:04:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau minta masukan.
Dialogue: 0,0:04:17.99,0:04:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:04:19.27,0:04:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak masalah dengan itu, Nanase?
Dialogue: 0,0:04:21.52,0:04:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah.
Dialogue: 0,0:04:23.03,0:04:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru saya rasa ini kesempatan bagus\Nuntuk saling berbincang.
Dialogue: 0,0:04:30.25,0:04:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Nanase itu Kelas D?!
Dialogue: 0,0:04:32.92,0:04:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak kelihatan.
Dialogue: 0,0:04:35.63,0:04:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, saya bukanlah orang\Nyang begitu cakap.
Dialogue: 0,0:04:39.17,0:04:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa masuk akal mulai di Kelas D.
Dialogue: 0,0:04:41.64,0:04:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, enggak kelihatan begitu, kok.
Dialogue: 0,0:04:44.31,0:04:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, orang yang tidak cakap itu kami.
Dialogue: 0,0:04:48.85,0:04:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanji sama Ken kenapa, sih?
Dialogue: 0,0:04:51.69,0:04:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada apa-apa, kok.
Dialogue: 0,0:04:53.69,0:04:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, Ryotaro...\NBerhentilah memercayai Nanase.
Dialogue: 0,0:04:58.03,0:05:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha? Apa-apaan itu?
Dialogue: 0,0:05:00.07,0:05:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mengatakan kenyataan.
Dialogue: 0,0:05:02.11,0:05:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku paham.
Dialogue: 0,0:05:03.74,0:05:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Kak Hondo.
Dialogue: 0,0:05:05.78,0:05:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya saya sudah mengatakan\Nhal yang tidak sopan pada Kak Sudo.
Dialogue: 0,0:05:10.16,0:05:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sopan?
Dialogue: 0,0:05:11.75,0:05:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan sesuatu yang perlu dibahas terus.
Dialogue: 0,0:05:14.17,0:05:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aslinya enggak masalah.
Dialogue: 0,0:05:16.46,0:05:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Kanji sendiri\Nkelihatan enggak semangat.
Dialogue: 0,0:05:19.17,0:05:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku enggak apa-apa...\NBiasa saja, kok...
Dialogue: 0,0:05:23.18,0:05:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa dari mananya coba?
Dialogue: 0,0:05:25.22,0:05:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak sebelum ujian\Nkau sudah kelihatan aneh, lo.
Dialogue: 0,0:05:28.10,0:05:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih, kalian berdua ini?
Dialogue: 0,0:05:30.14,0:05:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Enggak ada apa-apa...
Dialogue: 0,0:05:33.44,0:05:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari saya juga terlihat\Nkalau tidak bersemangat.
Dialogue: 0,0:05:37.23,0:05:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, kan?
Dialogue: 0,0:05:38.40,0:05:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada masalah yang sedang dipikirkan?
Dialogue: 0,0:05:42.61,0:05:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, bagaimana, ya?
Dialogue: 0,0:05:45.70,0:05:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?\NKalau ada, buruan bilang, dong.
Dialogue: 0,0:05:48.79,0:05:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling juga cuma sepele.
Dialogue: 0,0:05:53.37,0:05:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada apa-apa...
Dialogue: 0,0:05:55.67,0:05:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bisa kita tunggu sebentar?
Dialogue: 0,0:05:58.00,0:05:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:06:01.88,0:06:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu kita tunggu, Nanase.
Dialogue: 0,0:06:05.18,0:06:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ayo kita tunggu, Ryotaro.
Dialogue: 0,0:06:08.06,0:06:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:08.76,0:06:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke.
Dialogue: 0,0:06:10.43,0:06:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, boleh saja.
Dialogue: 0,0:06:14.06,0:06:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, nih...
Dialogue: 0,0:06:17.86,0:06:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sebenarnya sudah lama\Ntertarik pada seseorang.
Dialogue: 0,0:06:24.07,0:06:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kusuka...
Dialogue: 0,0:06:26.41,0:06:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang kusuka...
Dialogue: 0,0:06:30.04,0:06:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, Shi...
Dialogue: 0,0:06:33.41,0:06:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinohara Satsuki...
Dialogue: 0,0:06:36.79,0:06:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku benci dia.
Dialogue: 0,0:06:39.59,0:06:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak tahu bagaimana,\Nentah sejak kapan aku jadi tertarik padanya.
Dialogue: 0,0:06:44.80,0:06:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, karena tidak mau mengakuinya,
Dialogue: 0,0:06:46.89,0:06:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa aku jadi pura-pura\Ntidak suka padanya.
Dialogue: 0,0:06:49.93,0:06:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, kalau memang suka,\Ntinggal segera kau tembak saja, kan?
Dialogue: 0,0:06:53.43,0:06:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya tidak mendukung, ih!
Dialogue: 0,0:06:56.31,0:06:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ada sesuatu, ya.
Dialogue: 0,0:06:58.52,0:07:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di grup Shinohara saat ini ada Komiya.
Dialogue: 0,0:07:03.03,0:07:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia, kemungkinan...
Dialogue: 0,0:07:06.11,0:07:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka pada Shinohara...
Dialogue: 0,0:07:09.99,0:07:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah Shinohara sendiri kelihatannya\Npunya perlakuan spesial pada Komiya.
Dialogue: 0,0:07:16.87,0:07:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebenarnya aku ingin langsung\Nsatu grup dengannya di pulau tak berpenghuni.
Dialogue: 0,0:07:21.38,0:07:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, malah tidak bisa jujur\Ndan jadi bertengkar seperti biasa.
Dialogue: 0,0:07:27.51,0:07:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyedihkan sekali...
Dialogue: 0,0:07:30.22,0:07:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin sudah salah paham\Nentah sejak kapan.
Dialogue: 0,0:07:33.85,0:07:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Shinohara pasti bisa suka padaku\Nmeski kami bertengkar.
Dialogue: 0,0:07:40.15,0:07:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cupu banget.
Dialogue: 0,0:07:42.73,0:07:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang pun aku tidak tahu\Nharus bagaimana.
Dialogue: 0,0:07:46.57,0:07:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ike itu tidak bisa jujur\Npada Kak Shinohara, kan?
Dialogue: 0,0:07:52.83,0:07:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa itu bukanlah hal yang buruk.
Dialogue: 0,0:07:56.62,0:07:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Shinohara malah beregu sama Komiya!
Dialogue: 0,0:07:59.83,0:08:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berarti tidak ada kesempatan, bukan?!
Dialogue: 0,0:08:02.04,0:08:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu saya tidak tahu.
Dialogue: 0,0:08:04.17,0:08:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak tahu, tapi...
Dialogue: 0,0:08:06.55,0:08:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Kak Shinohara\Nmengharapkan adanya batasan.
Dialogue: 0,0:08:11.05,0:08:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adanya batasan?
Dialogue: 0,0:08:12.64,0:08:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mengerti kalau Kak Ike\Nselalu ceria pada siapa pun
Dialogue: 0,0:08:16.18,0:08:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bisa mengutarakan apa yang dipikirkan.
Dialogue: 0,0:08:20.02,0:08:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa Kak Shinohara juga\Nmenilai Kak Ike seperti itu.
Dialogue: 0,0:08:24.98,0:08:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mungkin dia pasti berharap kalau\Ndirinya jadi orang yang spesial.
Dialogue: 0,0:08:33.12,0:08:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ingin agar rasa suka itu\Ndisampaikan dengan lebih terbuka.
Dialogue: 0,0:08:40.03,0:08:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah menyembunyikan rasa malu,
Dialogue: 0,0:08:42.50,0:08:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang penting perasaan itu harus sampai\Nke orang yang disukai.
Dialogue: 0,0:08:45.30,0:08:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya paham perasaan Kakak\Ningin mengejar Kak Shinohara.
Dialogue: 0,0:08:49.05,0:08:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bertarung dan bertahan hidup dulu\Nadalah prioritas utama.
Dialogue: 0,0:08:52.89,0:08:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai tidak bisa bertemu lagi...
Dialogue: 0,0:08:55.97,0:08:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai tidak bisa\Nbertemu orang yang disuka lagi...
Dialogue: 0,0:09:00.23,0:09:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti tidak akan bisa lagi untuk\Nmenyampaikan perasaan suka itu.
Dialogue: 0,0:09:07.15,0:09:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sekarang bukan waktunya\Nuntuk merisaukan itu, Kak Ike?
Dialogue: 0,0:09:11.74,0:09:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:09:13.28,0:09:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jelas tidak ada artinya kalau tidak bisa\Nmelewati dan selamat dari ujian khusus ini.
Dialogue: 0,0:09:17.83,0:09:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak begitu,\Nsemuanya akan jadi sia-sia.
Dialogue: 0,0:09:20.54,0:09:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, betul itu, Kanji!
Dialogue: 0,0:09:32.05,0:09:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kak Ayanokoji,\Napa Kakak sudah bangun?
Dialogue: 0,0:09:36.60,0:09:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, aku akan keluar.
Dialogue: 0,0:09:40.60,0:09:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya khawatir kelewatan bicara\Nsoal Kak Ike kemarin.
Dialogue: 0,0:09:46.36,0:09:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ike bisa bangkit lagi berkat Nanase.
Dialogue: 0,0:09:49.23,0:09:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa dia akan berterima kasih.
Dialogue: 0,0:09:51.40,0:09:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak rasa begitu?
Dialogue: 0,0:09:53.70,0:09:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa Kak Ike entah bagaimana\Nagak membahayakan.
Dialogue: 0,0:09:58.49,0:10:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obrolan semalam malah membawa petaka
Dialogue: 0,0:10:01.37,0:10:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuatnya memaksakan diri.
Dialogue: 0,0:10:03.92,0:10:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu saya khawatir\Nkalau harus berpisah di sini.
Dialogue: 0,0:10:07.59,0:10:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukannya tidak paham perasaanmu.
Dialogue: 0,0:10:10.67,0:10:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, memang tidak bisa, ya.
Dialogue: 0,0:10:14.38,0:10:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, masih bisa asal menentukan\Ntempat kumpulnya nanti.
Dialogue: 0,0:10:19.14,0:10:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tergantung area yang ditunjuk,
Dialogue: 0,0:10:21.39,0:10:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi akan kusampaikan\Nsebelum pisah dengan grup Sudo.
Dialogue: 0,0:10:24.02,0:10:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima kasih banyak.
Dialogue: 0,0:10:39.66,0:10:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas di sini...
Dialogue: 0,0:10:41.91,0:10:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berebut bendera, ya.
Dialogue: 0,0:10:44.33,0:10:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ingin mendaftar.
Dialogue: 0,0:10:45.92,0:10:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:10:52.26,0:10:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masih bisa mendaftar?
Dialogue: 0,0:10:54.42,0:10:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali jumlah pesertanya\Nbaru saja terpenuhi.
Dialogue: 0,0:10:58.26,0:10:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:59.76,0:11:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau divisi putri masih kosong satu.
Dialogue: 0,0:11:02.93,0:11:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kak Ayanokoji tidak bisa ikut,\Nakan saya lewati juga.
Dialogue: 0,0:11:07.23,0:11:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah, kebetulan aku\Ningin istirahat sebentar.
Dialogue: 0,0:11:10.44,0:11:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase sebaiknya ikut saja.
Dialogue: 0,0:11:12.44,0:11:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:11:13.82,0:11:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mengalah padaku\Nuntuk hadiah pencapaian area,
Dialogue: 0,0:11:17.74,0:11:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka selisih poin kita juga makin lebar.
Dialogue: 0,0:11:20.37,0:11:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:11:22.33,0:11:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu akan saya terima tawaran Kakak.
Dialogue: 0,0:11:24.96,0:11:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain Nanase,\Nyang lain semuanya anak kelas tiga.
Dialogue: 0,0:11:28.21,0:11:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap grup hanya boleh satu orang\Nyang ikut serta.
Dialogue: 0,0:11:31.46,0:11:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah ini tidak wajar.
Dialogue: 0,0:11:33.96,0:11:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berkumpul karena ada\Nsuatu maksud tertentu, ya?
Dialogue: 0,0:11:39.72,0:11:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, bagaimana bilangnya?
Dialogue: 0,0:11:42.47,0:11:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang yang kau pilih imut, ya.
Dialogue: 0,0:11:45.14,0:11:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:11:46.39,0:11:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berebut bendera yang saya tonton di TV\Npakai baju renang seperti ini.
Dialogue: 0,0:11:50.90,0:11:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa saya salah?
Dialogue: 0,0:11:53.73,0:11:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:11:54.94,0:11:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai kemampuan fisiknya di OAA itu B+.
Dialogue: 0,0:11:58.74,0:12:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi melihat kemampuan aslinya selama ini,
Dialogue: 0,0:12:01.49,0:12:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya tidak akan aneh jika nilainya A.
Dialogue: 0,0:12:05.58,0:12:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf, Kak Ayanokoji.
Dialogue: 0,0:12:08.75,0:12:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditatap tajam dari dekat,\Nrasanya jadi tidak bisa tenang.
Dialogue: 0,0:12:13.30,0:12:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga.\NMaaf.
Dialogue: 0,0:12:17.13,0:12:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya pergi dulu.
Dialogue: 0,0:12:21.26,0:12:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:12:24.77,0:12:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulempar, ya!
Dialogue: 0,0:12:30.15,0:12:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya kau tidak berhasil ikut tugas.
Dialogue: 0,0:12:34.19,0:12:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Kakak juga sama.
Dialogue: 0,0:12:36.53,0:12:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau datang ke sini hanya\Nkarena penunjukan area?
Dialogue: 0,0:12:40.74,0:12:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang tahu.
Dialogue: 0,0:12:43.03,0:12:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau juga renang sana?
Dialogue: 0,0:12:45.04,0:12:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya santai sekali.
Dialogue: 0,0:12:47.50,0:12:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira Kakak-kakak sekalian\Nmengumpulkan poin sampai berdarah-darah.
Dialogue: 0,0:12:51.92,0:12:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh melepas penat juga, kan?
Dialogue: 0,0:12:54.04,0:12:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, acara utamanya baru besok.
Dialogue: 0,0:12:57.55,0:12:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai besok, babak pertengahan pun dimulai.
Dialogue: 0,0:12:59.80,0:13:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari di mana posisi 10 teratas dan terbawah\Ndari seluruh grup diumumkan.
Dialogue: 0,0:13:04.35,0:13:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai ada grup di luar kelas tiga\Nyang masuk ke tiga besar.
Dialogue: 0,0:13:08.52,0:13:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itulah aku bergerak.
Dialogue: 0,0:13:10.35,0:13:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas satu atau dua mustahil\Nnaik podium, ingat itu.
Dialogue: 0,0:13:14.19,0:13:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terkecuali dirimu.
Dialogue: 0,0:13:15.94,0:13:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas peringatannya.
Dialogue: 0,0:13:19.11,0:13:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi
Dialogue: 0,0:13:20.24,0:13:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku sendirian,
Dialogue: 0,0:13:21.93,0:13:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangankan peringkat atas,\Nmungkin malah di peringkat bawah.
Dialogue: 0,0:13:24.95,0:13:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, selagi sempat\Nsegeralah buat grup dengan seseorang.
Dialogue: 0,0:13:29.62,0:13:32.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai salah langkah\Ndan dikeluarkan dari sekolah,
Dialogue: 0,0:13:32.87,0:13:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nanti Kak Horikita pasti kecewa.
Dialogue: 0,0:13:36.84,0:13:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagumo, bisa ke sini sebentar?
Dialogue: 0,0:13:42.13,0:13:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada strategi yang bisa diambil justru\Nkarena dia adalah Nagumo Miyabi.
Dialogue: 0,0:13:46.47,0:13:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai itu dijalankan...
Dialogue: 0,0:13:50.14,0:13:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan dipaksa menghadapi\Npertarungan yang berat.
Dialogue: 0,0:13:59.03,0:14:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menang telak, ya.
Dialogue: 0,0:14:00.90,0:14:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:14:02.49,0:14:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya berhasil menang.
Dialogue: 0,0:14:04.03,0:14:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase, berapa air yang kau punya?
Dialogue: 0,0:14:06.53,0:14:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain satu botol hadiah yang saya\Nterima tadi, hampir tidak tersisa.
Dialogue: 0,0:14:10.79,0:14:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tinggal satu botol.
Dialogue: 0,0:14:13.00,0:14:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekurangan air akan menjadi\Nrintangan pertama.
Dialogue: 0,0:14:15.79,0:14:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita perlu cari cara untuk mendapat air.
Dialogue: 0,0:14:19.92,0:14:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku sendiri, sembari menuju area\Nyang ditunjuk dan menyelesaikan tugas,
Dialogue: 0,0:14:24.13,0:14:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tinggal bolak-balik ke titik start\Nuntuk menyuplai air.
Dialogue: 0,0:14:28.18,0:14:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Nanase pasti mustahil diajak begitu.
Dialogue: 0,0:14:31.39,0:14:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji.
Dialogue: 0,0:14:33.31,0:14:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Kakak memutuskan untuk\Nbertarung sendirian?
Dialogue: 0,0:14:36.69,0:14:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau tahu?
Dialogue: 0,0:14:38.44,0:14:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah bergerak sendiri lebih banyak\Nruginya daripada untungnya?
Dialogue: 0,0:14:43.07,0:14:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kerugiannya banyak,\Ntapi bukan berarti tidak bisa menang.
Dialogue: 0,0:14:47.95,0:14:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau masuk ke grup yang kekurangan poin,
Dialogue: 0,0:14:51.58,0:14:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa jadi akan muncul sinergi\Nyang tidak terduga.
Dialogue: 0,0:14:54.83,0:14:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itu Kakak bertarung sendiri?
Dialogue: 0,0:14:57.83,0:14:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, siapa yang tahu.
Dialogue: 0,0:14:59.71,0:15:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi Nanase hanya salah menilai
Dialogue: 0,0:15:02.10,0:15:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sebenarnya aku memang gagal\Nmendapat grup.
Dialogue: 0,0:15:05.55,0:15:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:15:07.05,0:15:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji memang punya sisi\Nyang kurang pandai bicara.
Dialogue: 0,0:15:11.85,0:15:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa memang dari dulu sudah begitu?
Dialogue: 0,0:15:14.14,0:15:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sifat seperti ini\Numumnya akan selalu sama?
Dialogue: 0,0:15:20.48,0:15:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, seseorang bisa berubah\Nkarena suatu hal.
Dialogue: 0,0:15:25.24,0:15:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ada yang seperti itu?
Dialogue: 0,0:15:29.28,0:15:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Nanase sudah berubah sejak masa SMP?
Dialogue: 0,0:15:33.75,0:15:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:15:35.25,0:15:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi sedikit berubah.
Dialogue: 0,0:15:39.04,0:15:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa?
Dialogue: 0,0:15:40.71,0:15:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, rasanya saya lebih sering tersenyum.
Dialogue: 0,0:15:45.09,0:15:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga soal mengobrol dan main\Ndengan orang lain,
Dialogue: 0,0:15:48.39,0:15:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya rasa sudah berkurang dari semasa SMP.
Dialogue: 0,0:15:52.85,0:15:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diri saya sudah berubah.
Dialogue: 0,0:15:56.27,0:15:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada suatu kejadian\Nyang membuat saya merasa demikian.
Dialogue: 0,0:16:05.74,0:16:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jalan?
Dialogue: 0,0:16:07.07,0:16:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bisa.
Dialogue: 0,0:16:09.16,0:16:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat tanpa memaksakan diri\Nitu juga perlu.
Dialogue: 0,0:16:12.37,0:16:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:16:14.29,0:16:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai memaksakan diri di sini\Ndan tidak bisa mengikutiku,
Dialogue: 0,0:16:17.62,0:16:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah itu justru\Nlebih memberatkan Nanase?
Dialogue: 0,0:16:20.29,0:16:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya benar begitu.
Dialogue: 0,0:16:23.38,0:16:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau lihat tugas di dekat sini.
Dialogue: 0,0:16:29.01,0:16:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bisa mendaftar?
Dialogue: 0,0:16:30.89,0:16:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa.
Dialogue: 0,0:16:31.97,0:16:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi regu ketujuh, ya.
Dialogue: 0,0:16:34.14,0:16:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa daftar?!
Dialogue: 0,0:16:35.35,0:16:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grupmu jadi yang terakhir.
Dialogue: 0,0:16:40.06,0:16:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya, kita baru ini bertemu selama ujian.
Dialogue: 0,0:16:42.90,0:16:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji.
Dialogue: 0,0:16:44.65,0:16:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani juga dirimu ikut ujian seorang diri.
Dialogue: 0,0:16:47.65,0:16:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah lumayan dapat poin?
Dialogue: 0,0:16:50.74,0:16:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, tidak aneh kalau\Nmasuk 10 grup terbawah.
Dialogue: 0,0:16:54.87,0:16:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda.
Dialogue: 0,0:16:56.66,0:17:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin memilih maju sendiri\Nkalau tidak pede bisa.
Dialogue: 0,0:17:01.04,0:17:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu saat berhasil masuk\Nperingkat 10 grup teratas... iya, kan?
Dialogue: 0,0:17:05.67,0:17:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, untung saja buat sekarang\Ntugasnya bukan matematika.
Dialogue: 0,0:17:09.63,0:17:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin bisa menang\Nmelawan genius matematika.
Dialogue: 0,0:17:12.47,0:17:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang tugas mapel sejarah akan dimulai.
Dialogue: 0,0:17:15.93,0:17:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh,
Dialogue: 0,0:17:16.89,0:17:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}obrolan santainya selesai, ya.
Dialogue: 0,0:17:22.31,0:17:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, angkat tangan, deh.
Dialogue: 0,0:17:25.02,0:17:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau juga jago soal sejarah.
Dialogue: 0,0:17:28.03,0:17:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma terbantu hoki dari empat pilihan.
Dialogue: 0,0:17:30.32,0:17:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoki?
Dialogue: 0,0:17:31.28,0:17:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya mustahil,\Ntapi tetap tidak bisa dipercaya.
Dialogue: 0,0:17:34.16,0:17:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku sedang buru-buru.
Dialogue: 0,0:17:37.04,0:17:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau incar yang mana\Nuntuk tugas selanjutnya?
Dialogue: 0,0:17:40.75,0:17:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat pergi ke tugas kimia.
Dialogue: 0,0:17:43.92,0:17:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali kalau begitu.
Dialogue: 0,0:17:46.21,0:17:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa lagi, Ayanokoji.
Dialogue: 0,0:17:52.93,0:17:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanase, staminamu bagaimana?
Dialogue: 0,0:17:55.39,0:17:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pulih berkat istirahat.
Dialogue: 0,0:17:57.56,0:17:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu ayo berangkat.
Dialogue: 0,0:17:59.68,0:18:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa saya boleh memastikan sesuatu?
Dialogue: 0,0:18:03.94,0:18:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:05.15,0:18:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau penilaian saya tidak salah,
Dialogue: 0,0:18:07.57,0:18:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji harusnya bisa\Nmengincar posisi lebih tinggi.
Dialogue: 0,0:18:10.69,0:18:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik untuk area yang ditunjuk ataupun tugas.
Dialogue: 0,0:18:14.11,0:18:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasarnya aku tidak berniat\Nuntuk tancap gas di awal.
Dialogue: 0,0:18:17.20,0:18:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, poin yang bisa didapat\Ndalam sehari ada batasnya.
Dialogue: 0,0:18:21.75,0:18:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus begini,\Nsaya rasa Kakak akan tertinggal jauh...
Dialogue: 0,0:18:26.42,0:18:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubilang kalau ini\Njuga salah satu bentuk strategi.
Dialogue: 0,0:18:30.96,0:18:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strategi?
Dialogue: 0,0:18:34.51,0:18:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berangkat dulu.
Dialogue: 0,0:18:36.01,0:18:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, baik!
Dialogue: 0,0:18:41.31,0:18:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Regu Sudo seharusnya ada di sekitar sini.
Dialogue: 0,0:18:44.19,0:18:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ya.
Dialogue: 0,0:18:45.44,0:18:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ayanokoji!
Dialogue: 0,0:18:49.11,0:18:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau cepat juga.
Dialogue: 0,0:18:51.61,0:18:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kita bisa kemah sama-sama lagi.
Dialogue: 0,0:18:54.36,0:18:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali.
Dialogue: 0,0:18:55.95,0:18:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ikan tangkapan kakak bertiga?
Dialogue: 0,0:18:59.20,0:19:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kami tangkap saat ke laut.
Dialogue: 0,0:19:01.87,0:19:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok, ada bau yang enak?
Dialogue: 0,0:19:05.75,0:19:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:19:06.67,0:19:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Karuizawa?
Dialogue: 0,0:19:08.50,0:19:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ah, enggak.
Dialogue: 0,0:19:10.42,0:19:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya, anu...
Dialogue: 0,0:19:12.88,0:19:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kepikiran, "Wah, pada bakar ikan."
Dialogue: 0,0:19:16.01,0:19:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kita juga kemah di sini, yuk.
Dialogue: 0,0:19:19.55,0:19:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya Ike bakal menjamu kita.
Dialogue: 0,0:19:22.06,0:19:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!\NKenapa harus aku?!
Dialogue: 0,0:19:24.14,0:19:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salahnya?\NEnggak bakal berkurang juga, kan?
Dialogue: 0,0:19:26.94,0:19:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dimakan, ya, bakal berkurang!\NAku enggak mau!
Dialogue: 0,0:19:29.48,0:19:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja, bagaimana?
Dialogue: 0,0:19:31.48,0:19:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu bisa tahu sesuatu soal Shinohara.
Dialogue: 0,0:19:35.49,0:19:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa boleh buat!
Dialogue: 0,0:19:37.99,0:19:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, biar kubakarkan ikan lagi!
Dialogue: 0,0:19:41.41,0:19:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?!
Dialogue: 0,0:19:42.58,0:19:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoki!
Dialogue: 0,0:19:43.62,0:19:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang harus dicoba.
Dialogue: 0,0:19:49.63,0:19:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya lancar.
Dialogue: 0,0:19:51.34,0:19:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku cuma dibantu terus.
Dialogue: 0,0:19:55.67,0:19:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang aneh beberapa hari ini?
Dialogue: 0,0:19:58.84,0:20:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal yang Kiyotaka bilang itu, kan?
Dialogue: 0,0:20:02.06,0:20:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, sepertinya tidak ada apa-apa.
Dialogue: 0,0:20:05.60,0:20:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi siapa saja yang melakukan kontak\Nsudah kucatat di tablet.
Dialogue: 0,0:20:09.69,0:20:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong diteruskan.
Dialogue: 0,0:20:11.65,0:20:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:20:14.19,0:20:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong!
Dialogue: 0,0:20:18.03,0:20:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si anak kelas satu itu,\Nkudengar dia ikut sama kamu.
Dialogue: 0,0:20:23.41,0:20:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cemas?
Dialogue: 0,0:20:27.62,0:20:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas cemas, dong.
Dialogue: 0,0:20:30.17,0:20:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami terpaksa gerak bersama\Nagar bisa menjalani ujian dengan baik.
Dialogue: 0,0:20:35.30,0:20:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:20:36.80,0:20:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada perasaan lain lebih dari itu.
Dialogue: 0,0:20:39.72,0:20:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya, sih.
Dialogue: 0,0:20:41.89,0:20:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tetap saja kalau dengar\Nkamu sama cewek.
Dialogue: 0,0:20:46.81,0:20:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka.
Dialogue: 0,0:20:49.02,0:20:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kei.
Dialogue: 0,0:21:06.74,0:21:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:21:08.50,0:21:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ci-Ciuman?
Dialogue: 0,0:21:11.50,0:21:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menunggu dan percaya padaku?
Dialogue: 0,0:21:13.58,0:21:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya...
Dialogue: 0,0:21:35.57,0:21:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin ini alarm darurat?
Dialogue: 0,0:21:38.03,0:21:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinannya sangat besar.
Dialogue: 0,0:21:40.86,0:21:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada tanda-tanda akan berhenti.
Dialogue: 0,0:21:43.61,0:21:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, setelah lima menit.
Dialogue: 0,0:21:46.12,0:21:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}GPS di jam tangan\Nakan memberi lokasi terkini
Dialogue: 0,0:21:49.91,0:21:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan penyelamat harusnya akan datang.
Dialogue: 0,0:21:52.79,0:21:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita bisa lebih dulu menemukannya\Nsebelum pihak sekolah tiba?
Dialogue: 0,0:21:57.25,0:22:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau bergerak,\Nlebih baik kalau beramai-ramai.
Dialogue: 0,0:22:00.76,0:22:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bangunkan Sudo dan yang lainnya.
Dialogue: 0,0:22:04.01,0:22:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
