Dialogue: 0,0:00:02.66,0:00:03.69,sign,,0000,0000,0000,,#16 DEMI SUATU MASA DEPAN
Dialogue: 0,0:01:26.73,0:01:27.41,sign,,0000,0000,0000,,TENGAH HARI, K.A, DIKELUARKAN, I2
Dialogue: 0,0:21:37.19,0:21:38.44,sign,,0000,0000,0000,,"KELAS A 1.206 POIN, KELAS B 578 POIN"
Dialogue: 0,0:21:38.44,0:21:41.28,sign,,0000,0000,0000,,"KELAS C 571 POIN, KELAS D 551 POIN"
Dialogue: 0,0:23:40.52,0:23:49.99,sign,,0000,0000,0000,,TENGAH DIPRODUKSI
Dialogue: 0,0:00:03.73,0:00:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya Anda mengambil langkah\Nyang cukup memaksa, ya.
Dialogue: 0,0:00:07.74,0:00:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kepala Yayasan Sementara.
Dialogue: 0,0:00:09.45,0:00:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, karena segala sesuatunya\Nselalu saja tidak berjalan lancar.
Dialogue: 0,0:00:14.62,0:00:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin melukai dirimu\Nyang merupakan produk berharga.
Dialogue: 0,0:00:19.37,0:00:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa,\Naku ingin dirimu menurut saja untuk ikut.
Dialogue: 0,0:00:23.88,0:00:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya menemukan apa yang harus\Ndan ingin kulakukan di sekolah ini.
Dialogue: 0,0:00:29.63,0:00:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan di dalam White Room dirimu\Nadalah contoh sukses yang istimewa.
Dialogue: 0,0:00:34.64,0:00:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersaing di sekolah selevel ini\Nbukankah terasa seperti pilihan bodoh?
Dialogue: 0,0:00:40.39,0:00:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini juga banyak orang berprestasi.
Dialogue: 0,0:00:43.77,0:00:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa akan cukup menghiburku hingga lulus.
Dialogue: 0,0:00:47.40,0:00:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pilihan lagi.
Dialogue: 0,0:00:49.53,0:00:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:00:51.11,0:00:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutaklukkan dirimu\Ndengan kepalan tanganku ini.
Dialogue: 0,0:00:55.53,0:00:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu kamu\Ntidak akan menyebutnya curang, kan?
Dialogue: 0,0:00:58.75,0:01:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena setidaknya dirimu\Nadalah karya terbaik White Room.
Dialogue: 0,0:01:05.25,0:01:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila tidak kurebut sendiri di sini,
Dialogue: 0,0:01:08.84,0:01:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan ada masa depan yang terbuka.
Dialogue: 0,0:01:27.44,0:01:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu sederhana\Nuntuk disebut pesan rahasia.
Dialogue: 0,0:01:32.24,0:01:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siang hari ini di area I2,\NAyanokoji akan dikeluarkan dari sekolah.
Dialogue: 0,0:01:37.87,0:01:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, akhirnya terkejar juga!
Dialogue: 0,0:01:40.62,0:01:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu di sini?
Dialogue: 0,0:01:42.75,0:01:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah poin!
Dialogue: 0,0:01:44.00,0:01:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan jumlah poinmu!
Dialogue: 0,0:01:45.71,0:01:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa kamu ini?
Dialogue: 0,0:01:48.13,0:01:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, kan?\NAku tidak akan kalah darimu di ujian ini.
Dialogue: 0,0:01:52.01,0:01:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, beri tahu jumlah poinmu.
Dialogue: 0,0:01:54.30,0:01:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Poinku 131.
Dialogue: 0,0:01:56.39,0:01:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sama-sama anak kelas dua,\Nkita adalah musuh.
Dialogue: 0,0:01:59.39,0:02:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin ambil risiko\Nmembeberkan informasi.
Dialogue: 0,0:02:02.48,0:02:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi takut setelah tahu jumlah poinku, ya.
Dialogue: 0,0:02:05.40,0:02:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kalah, kan?
Dialogue: 0,0:02:07.27,0:02:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku sedang buru-buru.
Dialogue: 0,0:02:09.32,0:02:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kabur, nih?
Dialogue: 0,0:02:10.82,0:02:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, baiklah.
Dialogue: 0,0:02:12.65,0:02:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah puas melihatnya,\Ntolong berhenti mengikuti lebih dari ini.
Dialogue: 0,0:02:16.74,0:02:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:02:19.16,0:02:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Kak Horikita.
Dialogue: 0,0:02:22.04,0:02:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:02:23.21,0:02:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Amasawa Ichika dari Kelas 1-A.
Dialogue: 0,0:02:26.63,0:02:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini ganggu, tahu.
Dialogue: 0,0:02:28.84,0:02:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku duluan yang di sini.
Dialogue: 0,0:02:30.55,0:02:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duluan?
Dialogue: 0,0:02:32.34,0:02:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Kak Ibuki seenaknya\Nmengejar tanpa diundang?
Dialogue: 0,0:02:36.26,0:02:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah!?
Dialogue: 0,0:02:37.05,0:02:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu ada maksud sesuatu, Amasawa?
Dialogue: 0,0:02:40.35,0:02:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Horikita sedang ingin ke mana?
Dialogue: 0,0:02:43.77,0:02:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal area yang ditunjuk bukan ke sini.
Dialogue: 0,0:02:47.19,0:02:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:02:48.52,0:02:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan mau ke I2, kan?
Dialogue: 0,0:02:51.53,0:02:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu sudah tahu banyak, ya.
Dialogue: 0,0:02:53.90,0:02:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski memakai pencarian GPS,\Nseharusnya sulit untuk mendahului.
Dialogue: 0,0:02:58.20,0:02:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti...
Dialogue: 0,0:02:59.70,0:03:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, mau sampai kapan bicara santai begitu?!
Dialogue: 0,0:03:02.87,0:03:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki.
Dialogue: 0,0:03:04.87,0:03:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}145 poin.
Dialogue: 0,0:03:06.42,0:03:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:03:07.29,0:03:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?!
Dialogue: 0,0:03:08.25,0:03:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parah.
Dialogue: 0,0:03:09.50,0:03:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah puas, kembalilah ke ujian.
Dialogue: 0,0:03:12.38,0:03:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada kesempatan membalik keadaan.
Dialogue: 0,0:03:14.80,0:03:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang benar.
Dialogue: 0,0:03:16.84,0:03:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa maksudmu mau\Nmengabaikan penunjukan area begitu?
Dialogue: 0,0:03:20.51,0:03:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu yang membuatku\Nharus pergi dari sini.
Dialogue: 0,0:03:24.73,0:03:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatanmu, Ibuki.
Dialogue: 0,0:03:26.64,0:03:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, sih.
Dialogue: 0,0:03:28.52,0:03:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu aku tidak akan sungkan\Nuntuk membalik keadaan.
Dialogue: 0,0:03:33.23,0:03:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa mau ke I2?
Dialogue: 0,0:03:37.03,0:03:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah justru dirimu\Nyang paling tahu soal itu?
Dialogue: 0,0:03:40.57,0:03:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:03:42.16,0:03:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berlagak bodoh.
Dialogue: 0,0:03:43.41,0:03:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah meninggalkan kertas ini di tendaku.
Dialogue: 0,0:03:46.29,0:03:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuanmu?
Dialogue: 0,0:03:50.58,0:03:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:03:51.96,0:03:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sejauh apa main-main seperti itu?
Dialogue: 0,0:03:54.92,0:03:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main?
Dialogue: 0,0:03:56.09,0:03:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ingin kamu lakukan\Ndengan melibatkanku dan Ayanokoji?
Dialogue: 0,0:03:59.93,0:04:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu sayangnya tidak tahu.
Dialogue: 0,0:04:02.76,0:04:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sepertinya juga salah satu peserta\Nsama seperti Kakak.
Dialogue: 0,0:04:08.06,0:04:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menemani permainan kata-katamu\Nlebih jauh hanya membuang waktu.
Dialogue: 0,0:04:11.56,0:04:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tidak tahu apa-apa\Nsoal Kak Ayanokoji,
Dialogue: 0,0:04:14.98,0:04:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa bisa pura-pura seolah\Njadi temannya begitu, pikirku.
Dialogue: 0,0:04:18.57,0:04:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa dirimu lebih mengerti\Ntentang dia daripada aku?
Dialogue: 0,0:04:23.33,0:04:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:04:25.08,0:04:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu betul, lo.
Dialogue: 0,0:04:27.54,0:04:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa sekeren dan secerdas itu
Dialogue: 0,0:04:30.83,0:04:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan lebih kuat dari siapa pun.
Dialogue: 0,0:04:34.21,0:04:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, memangnya apa yang Kak Horikita tahu?
Dialogue: 0,0:04:37.84,0:04:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu apa?
Dialogue: 0,0:04:39.47,0:04:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia...
Dialogue: 0,0:04:40.80,0:04:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji adalah temanku\Nyang pertama di sekolah ini.
Dialogue: 0,0:04:45.93,0:04:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski awalnya kukira siswa biasa.
Dialogue: 0,0:04:49.44,0:04:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ternyata punya kemampuan\Nmelebihi bayanganku.
Dialogue: 0,0:04:53.02,0:04:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga diakui oleh Kakak.
Dialogue: 0,0:04:55.73,0:04:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia menyembunyikan dirinya\Nyang seperti itu.
Dialogue: 0,0:04:59.40,0:05:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang yang ingin menjalani\Nhidup sekolah dengan tenang.
Dialogue: 0,0:05:03.95,0:05:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:05.24,0:05:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin tidak tahu apa-apa soal dirinya.
Dialogue: 0,0:05:09.62,0:05:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi.
Dialogue: 0,0:05:10.75,0:05:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai dari sini, hingga saat kelulusan.
Dialogue: 0,0:05:14.17,0:05:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa untuk terus\Ningin tahu soal dirinya.
Dialogue: 0,0:05:17.30,0:05:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai teman sekelas, sebagai sahabat,
Dialogue: 0,0:05:20.30,0:05:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauh melebihi dirimu yang sekarang.
Dialogue: 0,0:05:22.80,0:05:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merasa bisa berguna, ya?
Dialogue: 0,0:05:25.60,0:05:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal cuma seorang Kak Horikita?
Dialogue: 0,0:05:28.31,0:05:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sekarang kemampuanku memang kurang.
Dialogue: 0,0:05:31.52,0:05:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:05:32.69,0:05:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat dia kesusahan, aku berniat untuk\Njadi seseorang yang bisa menolongnya.
Dialogue: 0,0:05:38.19,0:05:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buat tertawa, dong.
Dialogue: 0,0:05:40.53,0:05:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin Kak Ayanokoji minta bantuan\Npada orang seperti Kak Horikita.
Dialogue: 0,0:05:46.45,0:05:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya sekarang memang benar.
Dialogue: 0,0:05:48.58,0:05:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya di masa depan akan berbeda?
Dialogue: 0,0:05:51.25,0:05:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkatmu aku jadi mengerti.
Dialogue: 0,0:05:53.58,0:05:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang akan terjadi sesuatu di I2, ya.
Dialogue: 0,0:05:57.04,0:05:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir bisa ke sana?
Dialogue: 0,0:05:58.71,0:06:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:00.21,0:06:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa bisa ke sana.
Dialogue: 0,0:06:02.97,0:06:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang ingin ketemu Kak Ayanokoji
Dialogue: 0,0:06:07.30,0:06:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar kuajak main sedikit!
Dialogue: 0,0:06:14.23,0:06:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat satu!
Dialogue: 0,0:06:21.19,0:06:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, akan kutunggu, tenang saja.
Dialogue: 0,0:06:24.20,0:06:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau istirahat 5 menit,\Natau 10 menit juga boleh.
Dialogue: 0,0:06:27.24,0:06:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini sekali lagi.
Dialogue: 0,0:06:36.21,0:06:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir ini judo?
Dialogue: 0,0:06:38.50,0:06:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cetek sekali pikiranmu.
Dialogue: 0,0:06:43.38,0:06:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya kamu ini?
Dialogue: 0,0:06:46.55,0:06:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?\NRasanya kakak sangat mengecewakan.
Dialogue: 0,0:06:50.31,0:06:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Horikita itu tidak sehebat\Nyang Kakak pikir, lo.
Dialogue: 0,0:06:54.98,0:06:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya Kak Ayanokoji\Ntidak pernah minta diskusi apa-apa.
Dialogue: 0,0:06:59.69,0:07:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang mau menolong, padahal aslinya\Nmau tahu dirimu itu dianggap apa, kan?
Dialogue: 0,0:07:06.41,0:07:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin benar begitu.
Dialogue: 0,0:07:09.20,0:07:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, akan kuminta dia mengatakan\Ndengan mulutnya sendiri.
Dialogue: 0,0:07:15.41,0:07:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibicarakan hanya akan membuat kesal.
Dialogue: 0,0:07:18.42,0:07:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kusudahi saja, ya.
Dialogue: 0,0:07:22.42,0:07:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah!
Dialogue: 0,0:07:27.22,0:07:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:07:28.34,0:07:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinju apa-apaan itu?
Dialogue: 0,0:07:30.39,0:07:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tangkapan yang bagus.
Dialogue: 0,0:07:32.06,0:07:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai kaget.
Dialogue: 0,0:07:34.64,0:07:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu?!
Dialogue: 0,0:07:36.39,0:07:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang akan mengalahkanmu itu aku.
Dialogue: 0,0:07:38.69,0:07:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau lihat dirimu kalah\Ndari anak kelas satu begini.
Dialogue: 0,0:07:42.15,0:07:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku si manis Amasawa Ichika, lo.
Dialogue: 0,0:07:44.94,0:07:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ingat namaku, ya, Kak Ibuki.
Dialogue: 0,0:07:50.66,0:07:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang main sama dia,\Nkamu pergi saja sana.
Dialogue: 0,0:07:54.58,0:07:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa kamu?
Dialogue: 0,0:07:56.21,0:07:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dirimu berjuang di ujian ini\Nuntuk menang dariku?
Dialogue: 0,0:07:59.29,0:08:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri mau mengabaikan\Npenunjukan area, kan?
Dialogue: 0,0:08:02.38,0:08:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membalik keadaan seperti itu\Ntidak ada artinya.
Dialogue: 0,0:08:05.76,0:08:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertarunganku!
Dialogue: 0,0:08:07.67,0:08:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah hampir kalah,\Nyakin mau bilang begitu?!
Dialogue: 0,0:08:11.35,0:08:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan bisa menang dari dia!
Dialogue: 0,0:08:13.60,0:08:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan anggap seenaknya!
Dialogue: 0,0:08:15.06,0:08:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubuktikan di depan mata...
Dialogue: 0,0:08:17.23,0:08:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Ntunjukkan tekad yang sepadan untuk itu.
Dialogue: 0,0:08:20.94,0:08:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuklah jadi satu grup denganku.
Dialogue: 0,0:08:24.27,0:08:26.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di antara kita tidak bisa bangkit,
Dialogue: 0,0:08:26.74,0:08:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sisanya harus lari agar grup tidak gugur.
Dialogue: 0,0:08:29.15,0:08:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bercanda?
Dialogue: 0,0:08:30.57,0:08:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus sama kamu?!
Dialogue: 0,0:08:31.95,0:08:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur masuk\Nke pertarungan ini tanpa tekad.
Dialogue: 0,0:08:36.45,0:08:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka itu.
Dialogue: 0,0:08:38.00,0:08:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak suka pun tidak apa-apa.
Dialogue: 0,0:08:40.28,0:08:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ingin kuandalkan kalau\Nkau memang ingin ikut terlibat.
Dialogue: 0,0:08:44.09,0:08:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumpah bikin kesal.
Dialogue: 0,0:08:46.34,0:08:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau dirimu gugur dari ujian ini\Nkarena anak kelas satu,
Dialogue: 0,0:08:50.88,0:08:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu tidak lucu.
Dialogue: 0,0:08:55.68,0:08:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang bukan rencana yang buruk.
Dialogue: 0,0:08:58.18,0:09:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sama-sama bergerak sendiri, itu bisa\Nmencegah langsung gugur sebelum ujian berakhir.
Dialogue: 0,0:09:03.36,0:09:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada satu yang salah diperhitungkan.
Dialogue: 0,0:09:06.15,0:09:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah kalau ada satu yang gugur...
Dialogue: 0,0:09:09.57,0:09:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu artinya salah satu boleh kuhancurkan.
Dialogue: 0,0:09:13.20,0:09:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya kuhancurkan yang mana dulu, ya?!
Dialogue: 0,0:09:15.95,0:09:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju sini!
Dialogue: 0,0:09:18.45,0:09:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke kiri!
Dialogue: 0,0:09:19.08,0:09:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memerintahku!
Dialogue: 0,0:09:31.38,0:09:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, setop dulu.
Dialogue: 0,0:09:33.84,0:09:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan anak kelas satu ini?!
Dialogue: 0,0:09:36.35,0:09:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:09:38.47,0:09:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo mulai lagi.
Dialogue: 0,0:09:41.10,0:09:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak langsung menaklukkan kami?
Dialogue: 0,0:09:43.48,0:09:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal perbedaannya jelas sekali.
Dialogue: 0,0:09:45.61,0:09:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang?
Dialogue: 0,0:09:46.98,0:09:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuberi paham kalau merasa remeh...
Dialogue: 0,0:09:49.74,0:09:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus menuruti perintah\Nkalau sudah jadi teman.
Dialogue: 0,0:09:52.45,0:09:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?! Jangan harap aku mau!
Dialogue: 0,0:09:54.91,0:09:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki!
Dialogue: 0,0:09:56.37,0:09:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan bela dirimu tidak kalah dariku.
Dialogue: 0,0:09:59.58,0:10:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru sedikit mengungguliku.
Dialogue: 0,0:10:02.21,0:10:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba begini?
Dialogue: 0,0:10:03.75,0:10:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu saja.
Dialogue: 0,0:10:05.21,0:10:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pandai belajar,\Ntidak bisa kerja sama dengan siapa saja.
Dialogue: 0,0:10:08.34,0:10:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti itu tapi mengaku sebagai rivalku,\Nsombong sekali dirimu.
Dialogue: 0,0:10:12.59,0:10:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:10:13.76,0:10:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan sudah waktunya dirimu\Nuntuk keluar dari cangkangmu?
Dialogue: 0,0:10:18.10,0:10:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuki Mio.
Dialogue: 0,0:10:19.56,0:10:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya itu?
Dialogue: 0,0:10:21.27,0:10:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap menyendiri seperti ini,
Dialogue: 0,0:10:23.69,0:10:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti akan terancam dikeluarkan dari sekolah.
Dialogue: 0,0:10:26.19,0:10:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak masalah kalau jadi begitu.
Dialogue: 0,0:10:28.77,0:10:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu artinya akan kalah telak dariku.
Dialogue: 0,0:10:31.74,0:10:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah?
Dialogue: 0,0:10:32.86,0:10:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:33.65,0:10:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerah dengan tanggung\Nbegitu tidak bisa disebut rival.
Dialogue: 0,0:10:37.91,0:10:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah sampai akhir lalu berkembang\Nsampai bisa memberi ancaman padaku.
Dialogue: 0,0:10:43.96,0:10:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itu sekarang
Dialogue: 0,0:10:46.42,0:10:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pinjamkan kekuatanmu padaku.
Dialogue: 0,0:10:49.92,0:10:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, paham.
Dialogue: 0,0:10:51.84,0:10:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah paham,\Njadi di sini aku akan menurutimu.
Dialogue: 0,0:10:55.01,0:10:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cukup, kan?
Dialogue: 0,0:10:56.51,0:10:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bagus.
Dialogue: 0,0:10:57.93,0:10:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:10:59.43,0:11:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus apa?
Dialogue: 0,0:11:04.77,0:11:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyusun strateginya sudah selesai?
Dialogue: 0,0:11:22.54,0:11:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:11:33.46,0:11:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu terasa sekali.
Dialogue: 0,0:11:36.51,0:11:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sampai sini.
Dialogue: 0,0:11:37.93,0:11:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu sudah tidak punya stamina\Nsampai titik yang parah, ya.
Dialogue: 0,0:11:42.06,0:11:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan?
Dialogue: 0,0:11:44.89,0:11:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka apa itu?
Dialogue: 0,0:11:47.52,0:11:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah main-main dulu satu ronde\Nsebelum menghadapi kakak berdua.
Dialogue: 0,0:11:53.28,0:11:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu bertarung di kondisi begitu?!
Dialogue: 0,0:11:56.11,0:11:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tahu aku dihajar siapa?
Dialogue: 0,0:11:58.82,0:12:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak bakal kujawab, sih.
Dialogue: 0,0:12:00.99,0:12:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang memang jadi agak seru.
Dialogue: 0,0:12:03.99,0:12:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sepertinya waktu habis.
Dialogue: 0,0:12:05.95,0:12:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau lewat silakan saja.
Dialogue: 0,0:12:10.17,0:12:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, walau kurasa sudah tidak perlu\Nuntuk mengejar Kak Ayanokoji lagi.
Dialogue: 0,0:12:16.38,0:12:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:17.63,0:12:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena semuanya sudah selesai.
Dialogue: 0,0:12:20.51,0:12:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji bagaimana?
Dialogue: 0,0:12:22.01,0:12:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan saja sendiri sana.
Dialogue: 0,0:12:24.77,0:12:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mungkin cuma akan menyesal.
Dialogue: 0,0:12:27.73,0:12:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bagaimana?
Dialogue: 0,0:12:29.48,0:12:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengejar Ayanokoji.
Dialogue: 0,0:12:31.98,0:12:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu aku ikut.
Dialogue: 0,0:12:33.94,0:12:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutertawai dari dekat\Nkalau Ayanokoji sedang terpojok.
Dialogue: 0,0:12:37.74,0:12:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatimu itu memang buruk, ya.
Dialogue: 0,0:12:58.26,0:13:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamat sudah kalau sampai tertangkap.
Dialogue: 0,0:13:01.38,0:13:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghindari dikepung dua arah\Nmemang benar secara teori.
Dialogue: 0,0:13:05.89,0:13:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apakah itu jawaban yang tepat?
Dialogue: 0,0:13:09.14,0:13:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tidak boleh lengah melawan Anda,\NPak Kepala Yayasan Sementara Tsukishiro.
Dialogue: 0,0:13:14.02,0:13:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berinisiatif mengerjakan tugas\Nyang dibenci orang adalah tugasku.
Dialogue: 0,0:13:20.15,0:13:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya akan buruk kalau tidak kubuat jadi\Nsatu lawan satu sebelum staminaku dikuras, ya.
Dialogue: 0,0:13:26.79,0:13:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kepala Yayasan Sementara.
Dialogue: 0,0:13:30.33,0:13:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tempat sepi seperti ini
Dialogue: 0,0:13:33.04,0:13:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedang apa para guru ini\Nmelawan seorang murid?
Dialogue: 0,0:13:38.34,0:13:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya sudah kuamati\Nsejak beberapa waktu lalu
Dialogue: 0,0:13:41.76,0:13:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak tahan melihat dua lawan satu.
Dialogue: 0,0:13:45.35,0:13:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya tidak ada reaksi\Ndari pencarian GPS.
Dialogue: 0,0:13:49.31,0:13:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin, ini penyebabnya?
Dialogue: 0,0:13:53.35,0:13:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh.
Dialogue: 0,0:13:54.94,0:13:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerusakan jam tangan di ujian ini\Nmemang tidak ada habisnya.
Dialogue: 0,0:13:58.57,0:14:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kakak mau membantuku?
Dialogue: 0,0:14:00.94,0:14:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu situasimu, tapi bukankah\Nwajar kakak kelas melindungi adik kelasnya?
Dialogue: 0,0:14:06.07,0:14:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa bisa ada di sini?
Dialogue: 0,0:14:08.29,0:14:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran dengan pergerakanmu\Nyang terus lari dari anak kelas satu.
Dialogue: 0,0:14:12.58,0:14:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya jadi bertemu\Ndengan situasi yang begitu menarik.
Dialogue: 0,0:14:17.09,0:14:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak tahu sejauh apa aku bisa berguna,
Dialogue: 0,0:14:20.26,0:14:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kurasa tidak akan selama itu.
Dialogue: 0,0:14:22.97,0:14:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu atau dua detik saja\Naku sudah sangat senang.
Dialogue: 0,0:14:26.05,0:14:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga bicaramu.
Dialogue: 0,0:14:27.85,0:14:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Shiba, kuserahkan pada Anda\Nuntuk mengurus siswi itu.
Dialogue: 0,0:14:32.35,0:14:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Ayanokoji, bisa tidak kau bergaya\Nyang lebih meyakinkan begitu?
Dialogue: 0,0:14:37.19,0:14:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:14:38.23,0:14:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasang kuda-kuda\Nseolah situasinya mendesak, dong.
Dialogue: 0,0:14:42.99,0:14:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya pengalaman memukul orang?
Dialogue: 0,0:14:45.32,0:14:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini wanita anggun, mana mungkin pernah.
Dialogue: 0,0:14:49.12,0:14:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja?
Dialogue: 0,0:14:50.62,0:14:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:14:52.45,0:14:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan aku memang sudah lama\Ningin mencoba memukul.
Dialogue: 0,0:14:57.38,0:15:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari selesaikan ini,\NPak Kepala Yayasan Sementara.
Dialogue: 0,0:15:00.88,0:15:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dirimu menilai bisa menang\Nkalau melawan aku sendiri, ya.
Dialogue: 0,0:15:05.76,0:15:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Ncoba tunjukkan kemampuanmu yang sesungguhnya.
Dialogue: 0,0:15:51.47,0:15:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sejak kapan, ya?
Dialogue: 0,0:15:54.35,0:16:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuakui, kalau dirimu tidak salah lagi\Nadalah karya terbaik.
Dialogue: 0,0:16:00.81,0:16:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak begitu suka cara yang kasar.
Dialogue: 0,0:16:04.36,0:16:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saking serunya,\Njadi tidak ada pilihan lagi.
Dialogue: 0,0:16:17.00,0:16:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa tahu?!
Dialogue: 0,0:16:19.67,0:16:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa ada yang janggal.
Dialogue: 0,0:16:21.92,0:16:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada arah pandangan serta\Nsengaja menunjukkan celah.
Dialogue: 0,0:16:27.97,0:16:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mau bagaimana sekarang?
Dialogue: 0,0:16:35.43,0:16:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali waktunya sudah habis,\NPak Kepala Yayasan Sementara.
Dialogue: 0,0:16:40.85,0:16:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa memanggil kapal kemari?
Dialogue: 0,0:16:43.82,0:16:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah mempersiapkannya di belakang?
Dialogue: 0,0:16:46.82,0:16:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melaporkan kalau ada anak Kelas 2-A dan D\Npingsan di sini.
Dialogue: 0,0:16:53.07,0:16:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kupastikan saat kejadian sebelumnya\Nkalau wali kelas sudah berangkat menolong.
Dialogue: 0,0:16:58.08,0:17:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal sudah mengincar ini, ya.
Dialogue: 0,0:17:01.42,0:17:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah kesalahan adalah\Nmengancam Ichinose secara tanggung.
Dialogue: 0,0:17:05.33,0:17:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau ditangani,\Nseharusnya sampai tuntas.
Dialogue: 0,0:17:08.01,0:17:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begini\Naku juga orang yang terhormat, lo.
Dialogue: 0,0:17:11.26,0:17:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melakukan\Nhal berbahaya seperti itu.
Dialogue: 0,0:17:15.09,0:17:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir, izinkan aku bertanya sesuatu.
Dialogue: 0,0:17:17.81,0:17:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Bapak benar-benar ingin\Nmengeluarkanku dari sekolah?
Dialogue: 0,0:17:21.77,0:17:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ada banyak cara yang lebih pasti?
Dialogue: 0,0:17:25.27,0:17:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu berlebihan.
Dialogue: 0,0:17:27.98,0:17:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sekuat tenaga ingin\Nmengeluarkanmu dari sekolah
Dialogue: 0,0:17:31.49,0:17:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan itu tidak tercapai.
Dialogue: 0,0:17:34.53,0:17:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa minta tolong sampaikan\Nsebuah pesan pada Amasawa?
Dialogue: 0,0:17:38.45,0:17:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kudengar.
Dialogue: 0,0:17:40.25,0:17:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dirimu akan dicap gagal\Nkarena terus melanggar perintah."
Dialogue: 0,0:17:45.75,0:17:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kamu bebas mau tetap tinggal\Natau pergi dari sekolah ini", begitu.
Dialogue: 0,0:17:51.63,0:17:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja berjuang sampai akhir kalau bisa.
Dialogue: 0,0:17:57.01,0:17:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengesankan sekali, Ayanokoji.
Dialogue: 0,0:17:59.81,0:18:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak juga.
Dialogue: 0,0:18:01.39,0:18:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja,\Nini tidak akan kukatakan ke siapa pun.
Dialogue: 0,0:18:05.36,0:18:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku jadi ingin mendengar\Npenjelasan akan banyak hal.
Dialogue: 0,0:18:09.36,0:18:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya masalah keluarga yang agak rumit.
Dialogue: 0,0:18:12.40,0:18:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:18:13.95,0:18:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya itu bukan sesuatu\Nyang boleh kumasuki seenaknya.
Dialogue: 0,0:18:17.78,0:18:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji!
Dialogue: 0,0:18:45.94,0:18:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pengganggu yang datang,\Ntapi jangan lupakan janjimu padaku.
Dialogue: 0,0:18:51.03,0:18:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:18:52.61,0:18:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakanlah kapan saja saat waktunya tiba.
Dialogue: 0,0:18:59.62,0:19:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji?
Dialogue: 0,0:19:00.99,0:19:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai imbalan bertarung\Njadi tentara bayaran,
Dialogue: 0,0:19:03.87,0:19:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berjanji untuk mengabulkan\Nsatu permintaan Ryuen.
Dialogue: 0,0:19:08.25,0:19:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa kamu janji semudah itu?
Dialogue: 0,0:19:10.88,0:19:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:11.92,0:19:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena keinginan itu justru akan\Nmenjerat dirinya sendiri dalam waktu dekat.
Dialogue: 0,0:19:17.89,0:19:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pasti akan membayar utangku.
Dialogue: 0,0:19:21.31,0:19:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginanku cuma satu.
Dialogue: 0,0:19:23.89,0:19:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertanding serius melawan Ayanokoji\Ntanpa ada yang mengganggu.
Dialogue: 0,0:19:29.27,0:19:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usulan yang lumayan sulit.
Dialogue: 0,0:19:31.98,0:19:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tidak perlu terburu-buru?
Dialogue: 0,0:19:34.40,0:19:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita masih punya kehidupan sekolah\Nselama satu tahun setengah yang tersisa.
Dialogue: 0,0:19:40.04,0:19:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kelar juga!
Dialogue: 0,0:19:41.70,0:19:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa makan sampai kenyang!
Dialogue: 0,0:19:43.04,0:19:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini juga susah...
Dialogue: 0,0:19:45.04,0:19:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar banget.
Dialogue: 0,0:19:46.29,0:19:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira bakal jadi apa.
Dialogue: 0,0:19:47.79,0:19:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untung bisa selamat sampai selesai.
Dialogue: 0,0:19:50.04,0:19:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asli.
Dialogue: 0,0:19:52.59,0:19:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:19:53.80,0:19:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan apa-apa.
Dialogue: 0,0:19:59.30,0:20:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi pengumuman hasilnya.
Dialogue: 0,0:20:05.81,0:20:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas usaha keras\Nsepanjang ujian pulau tak berpenghuni.
Dialogue: 0,0:20:09.56,0:20:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung saja.
Dialogue: 0,0:20:11.11,0:20:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama akan kuumumkan nama perwakilan
Dialogue: 0,0:20:13.44,0:20:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lima grup terbawah yang akan\Ndikeluarkan dari sekolah sebagai penalti.
Dialogue: 0,0:20:16.69,0:20:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muto dari Kelas 3-D.
Dialogue: 0,0:20:19.32,0:20:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawakami dari Kelas 3-D.
Dialogue: 0,0:20:21.66,0:20:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katsumata dari Kelas 3-C.
Dialogue: 0,0:20:24.41,0:20:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinonome dari Kelas 3-C.
Dialogue: 0,0:20:27.21,0:20:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mikitani dari Kelas 3-B.
Dialogue: 0,0:20:30.00,0:20:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak ada langkah penyelamatan,
Dialogue: 0,0:20:32.63,0:20:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka 15 siswa tadi akan\Ndikeluarkan dari sekolah.
Dialogue: 0,0:20:38.72,0:20:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira Nagumo akan menyelamatkan mereka.
Dialogue: 0,0:20:42.05,0:20:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu sekarang akan kuumumkan\Ntiga grup di peringkat teratas.
Dialogue: 0,0:20:47.10,0:20:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkat ketiga, grup Sakayanagi Arisu\Ndari Kelas 2-A dengan 261 poin.
Dialogue: 0,0:20:54.73,0:20:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkat kedua.
Dialogue: 0,0:20:56.32,0:21:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup Nagumo Miyabi dari Kelas 3-A\Ndengan 325 poin.
Dialogue: 0,0:21:03.49,0:21:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkat pertama.
Dialogue: 0,0:21:05.33,0:21:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koenji Rokusuke dari Kelas 2-D
Dialogue: 0,0:21:10.08,0:21:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan 327 poin.
Dialogue: 0,0:21:12.67,0:21:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:21:14.04,0:21:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita jadi Kelas C!
Dialogue: 0,0:21:15.55,0:21:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar lega!
Dialogue: 0,0:21:17.46,0:21:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata si Koenji benar-benar berhasil.
Dialogue: 0,0:21:20.80,0:21:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar berhasil melakukannya.
Dialogue: 0,0:21:23.55,0:21:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian pengumumannya selesai.
Dialogue: 0,0:21:25.81,0:21:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian boleh menikmati hidangan\Ndan beristirahat yang cukup.
Dialogue: 0,0:21:27.43,0:21:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aku tidak bisa begitu saja\Nmenerima ini dengan senang.
Dialogue: 0,0:21:30.73,0:21:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sekarang tidak masalah untuk senang?
Dialogue: 0,0:21:33.23,0:21:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita berhasil keluar\Ndari Kelas D untuk kedua kalinya.
Dialogue: 0,0:21:37.19,0:21:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:21:38.44,0:21:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini kita langsung mendekat ke atas.
Dialogue: 0,0:21:41.28,0:21:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Kelas B pun sudah masuk jangkauan.
Dialogue: 0,0:21:43.70,0:21:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Poin pribadi juga meningkat pesat.
Dialogue: 0,0:21:46.95,0:21:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat kelas pasti juga naik.
Dialogue: 0,0:21:49.70,0:21:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin benar seperti katamu.
Dialogue: 0,0:21:52.46,0:21:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya juga\Ntidak terjadi apa-apa pada dirimu.
Dialogue: 0,0:21:55.75,0:21:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga,\Nmungkin aku bisa merasa senang dengan tenang.
Dialogue: 0,0:21:59.46,0:22:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bagus.
Dialogue: 0,0:22:01.17,0:22:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun tidak berubah, tetap seperti biasa.
Dialogue: 0,0:22:04.84,0:22:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada satu pun.
Dialogue: 0,0:23:40.52,0:23:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 5th Season
