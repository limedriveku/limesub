Dialogue: 0,0:00:00.00,0:00:03.73,sign,,0000,0000,0000,,HARI KETIGA BELAS
Dialogue: 0,0:02:31.01,0:02:32.26,sign,,0000,0000,0000,,#15 KEKUATAN DAN TEKAD
Dialogue: 0,0:04:06.98,0:04:08.48,sign,,0000,0000,0000,,HARI KETIGA BELAS
Dialogue: 0,0:04:08.48,0:04:09.60,sign,,0000,0000,0000,,HARI KESEPULUH
Dialogue: 0,0:05:25.97,0:05:27.77,sign,,0000,0000,0000,,HARI KESEPULUH
Dialogue: 0,0:05:27.77,0:05:30.98,sign,,0000,0000,0000,,HARI KETIGA BELAS
Dialogue: 0,0:08:12.14,0:08:13.64,sign,,0000,0000,0000,,PERINGATAN
Dialogue: 0,0:13:28.58,0:13:30.79,sign,,0000,0000,0000,,"KITO HAYATO - UTOMIYA RIKU"
Dialogue: 0,0:14:36.10,0:14:38.94,sign,,0000,0000,0000,,HARI KEEMPAT BELAS, HARI TERAKHIR UJIAN
Dialogue: 0,0:00:03.73,0:00:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup anak kelas satu mengejar\Ndengan jumlah melebihi perkiraanku.
Dialogue: 0,0:00:08.61,0:00:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya menghindari pertempuran\Nmeski harus mengabaikan penunjukan area.
Dialogue: 0,0:00:15.16,0:00:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kak Ayanokoji terus memutar\Nuntuk menghindari anak kelas satu,
Dialogue: 0,0:00:20.79,0:00:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini bisa dimenangkan tanpa perlu ada kontak.
Dialogue: 0,0:00:24.67,0:00:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Ayanokoji ganti rute.
Dialogue: 0,0:00:26.84,0:00:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup di C4 bergeraklah ke utara.
Dialogue: 0,0:00:29.47,0:00:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:00:35.18,0:00:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:00:37.35,0:00:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Tsubaki?
Dialogue: 0,0:00:39.23,0:00:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup di C4 yang seharusnya pergi ke utara\Nmalah tidak bergerak.
Dialogue: 0,0:00:43.27,0:00:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi grup di area B5 juga...
Dialogue: 0,0:00:47.99,0:00:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:00:49.36,0:00:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:00:52.11,0:00:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa saja tolong jawab.
Dialogue: 0,0:01:09.59,0:01:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:19.41,0:02:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CLASSROOM OF THE ELITE 4th Season:\NSecond Year, First Semester
Dialogue: 0,0:02:32.30,0:02:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima grup anak kelas satu yang kukerahkan\Nberhenti bergerak.
Dialogue: 0,0:02:36.68,0:02:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada grup anak kelas dua\Nyang menempel lekat ke mereka semua.
Dialogue: 0,0:02:41.39,0:02:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, kelihatan seperti\Nsedang dihalangi anak kelas dua.
Dialogue: 0,0:02:45.52,0:02:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma itu,
Dialogue: 0,0:02:46.65,0:02:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada yang timpang, semua terbagi rata\Ndari anak Kelas A sampai Kelas D.
Dialogue: 0,0:02:51.28,0:02:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, ada yang memimpin mereka\Ndari belakang seperti Tsubaki?
Dialogue: 0,0:02:56.82,0:03:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini sudah siap bersiaga,\Nsekarang mari dimulai.
Dialogue: 0,0:03:01.41,0:03:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh-boleh saja, sih.
Dialogue: 0,0:03:03.50,0:03:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tahu dari mana akan ketemu grup\Nanak kelas satu yang menuju area yang sama?
Dialogue: 0,0:03:11.63,0:03:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama 12 hari ini,
Dialogue: 0,0:03:14.42,0:03:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski secara perlahan,\Ntelah terjadi perubahan medan
Dialogue: 0,0:03:17.38,0:03:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dalam pulau tak berpenghuni.
Dialogue: 0,0:03:20.47,0:03:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamu tahu itu apa?
Dialogue: 0,0:03:22.85,0:03:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perubahan medan?
Dialogue: 0,0:03:25.89,0:03:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya bekas dilewati manusia, ya?
Dialogue: 0,0:03:30.06,0:03:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:31.57,0:03:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tiap hari para siswa dan guru\Nsudah bergerak ke sana-kemari.
Dialogue: 0,0:03:35.61,0:03:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau titik tujuannya sudah ketahuan,
Dialogue: 0,0:03:38.61,0:03:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memprediksi rutenya tidaklah susah.
Dialogue: 0,0:03:41.95,0:03:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tidak melihat langsung,\Ntapi seolah bisa melihat jalannya.
Dialogue: 0,0:03:46.46,0:03:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang,
Dialogue: 0,0:03:47.79,0:03:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang-orang yang sama sekali\Ntidak bergerak padahal sekarang
Dialogue: 0,0:03:51.34,0:03:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktu menuju area yang ditunjuk dan tugas
Dialogue: 0,0:03:54.21,0:03:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Yagami Takuya, Utomiya Riku\Ndan Tsubaki Sakurako.
Dialogue: 0,0:03:59.59,0:04:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapakah di antara mereka\Nyang merupakan lawanku?
Dialogue: 0,0:04:03.47,0:04:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau justru malah ketiganya.
Dialogue: 0,0:04:09.65,0:04:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam, Ayanokoji.
Dialogue: 0,0:04:11.98,0:04:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa denganku?
Dialogue: 0,0:04:14.23,0:04:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin minta tolong sesuatu padamu.
Dialogue: 0,0:04:17.74,0:04:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan saja, tidak perlu sungkan.
Dialogue: 0,0:04:20.45,0:04:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubayar utang budi karena kau sudah\Nmenyelamatkan teman sekelas kami.
Dialogue: 0,0:04:23.87,0:04:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mengenai White Room.
Dialogue: 0,0:04:26.37,0:04:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya itu akan jadi topik\Nyang begitu menarik.
Dialogue: 0,0:04:33.92,0:04:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:04:35.75,0:04:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cukup menghabisi Amasawa Ichika, ya?
Dialogue: 0,0:04:40.18,0:04:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan dia.
Dialogue: 0,0:04:41.84,0:04:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, grup anak kelas satu.
Dialogue: 0,0:04:44.22,0:04:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin dirimu yang mengurus mereka.
Dialogue: 0,0:04:46.52,0:04:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, sesama siswa White Room\Nmungkin saja mampu.
Dialogue: 0,0:04:50.69,0:04:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau orang lain, kurasa tidak akan bisa\Nmemojokkan Ayanokoji.
Dialogue: 0,0:04:55.90,0:04:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan anak kelas satu\Nakan memakai cara paksa.
Dialogue: 0,0:04:58.90,0:05:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencoba menghalangi tugas atau\Npergerakan menuju area yang ditunjuk.
Dialogue: 0,0:05:02.41,0:05:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya sudah cukup kupahami.
Dialogue: 0,0:05:05.41,0:05:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti bisa kuanggap kau akan membantuku?
Dialogue: 0,0:05:08.12,0:05:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, ini tetap saja terlalu besar\Nuntuk utang menolong Takemoto.
Dialogue: 0,0:05:13.21,0:05:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti ini akan menjadi "utang" baru, lo.
Dialogue: 0,0:05:17.67,0:05:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyakitkan sekali kalau didengar.
Dialogue: 0,0:05:19.97,0:05:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau memang ada hasilnya,\Nakan kuterima "utang" itu.
Dialogue: 0,0:05:23.72,0:05:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepakat, ya.
Dialogue: 0,0:05:30.98,0:05:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, dengan ini pergerakan lima grup\Nyang mencurigakan sudah dihentikan.
Dialogue: 0,0:05:36.48,0:05:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita cari tahu siapa yang sudah\Nmerencanakan penyerangan ini.
Dialogue: 0,0:05:43.49,0:05:44.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kito.
Dialogue: 0,0:05:45.74,0:05:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Tsubaki.
Dialogue: 0,0:05:47.53,0:05:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memberi perintah yang detail ke lima grup\Nagar bisa lari dari anak kelas dua
Dialogue: 0,0:05:51.50,0:05:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah tidak sesulit itu?
Dialogue: 0,0:05:54.25,0:05:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, akan kuberi tahu kalau sudah selesai.
Dialogue: 0,0:05:57.42,0:06:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenyataannya justru terbalik.
Dialogue: 0,0:06:00.17,0:06:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan grupku yang tertangkap,\Ntapi aku yang menangkap grup lawan.
Dialogue: 0,0:06:06.26,0:06:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}H-Hm?
Dialogue: 0,0:06:08.39,0:06:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kelima grup itu berhasil\Nmemojokkan Kak Ayanokoji sekalipun.
Dialogue: 0,0:06:12.48,0:06:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada perbedaan kemampuan fisik,\Ntetap bisa ditinggal kabur, kan?
Dialogue: 0,0:06:15.90,0:06:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak menang dari Kak Ayanokoji,\Nrencana ini tidak ada gunanya, dong?
Dialogue: 0,0:06:20.90,0:06:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ada kegunaan yang lebih penting?
Dialogue: 0,0:06:23.90,0:06:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini bisa memancing grup\Nyang mencoba melindungi Kak Ayanokoji.
Dialogue: 0,0:06:29.20,0:06:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu siapa yang memegang komando,
Dialogue: 0,0:06:32.45,0:06:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi akan kuberi tahu kalau apa yang\Nterlihat oleh mata bukanlah segalanya.
Dialogue: 0,0:06:38.42,0:06:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini musuh yang menghalangi\Nsudah hilang.
Dialogue: 0,0:06:41.46,0:06:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang situasinya bisa seperti\Nyang kau harapkan.
Dialogue: 0,0:06:44.43,0:06:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen.
Dialogue: 0,0:06:46.43,0:06:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu kau, Kak Ayanokoji!
Dialogue: 0,0:06:54.39,0:06:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hosen, ya.
Dialogue: 0,0:06:55.64,0:06:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar tidak ada yang menghalangi,
Dialogue: 0,0:06:57.65,0:07:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sengaja memberi tahu\Nhari penyerangan ke Nanase
Dialogue: 0,0:07:00.77,0:07:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar kami punya waktu untuk bersiap, ya.
Dialogue: 0,0:07:03.74,0:07:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu ini sudah lama kutunggu-tunggu...
Dialogue: 0,0:07:07.99,0:07:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu permintaan yang mustahil, Hosen.
Dialogue: 0,0:07:12.24,0:07:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:07:13.25,0:07:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji, cepat menyingkir.
Dialogue: 0,0:07:16.75,0:07:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan mengganggu.
Dialogue: 0,0:07:21.34,0:07:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau bisa ada di sini, Ryuen?
Dialogue: 0,0:07:25.88,0:07:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kalimatku, Hosen.
Dialogue: 0,0:07:28.80,0:07:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seharusnya tidak punya urusan di sini.
Dialogue: 0,0:07:31.76,0:07:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:07:33.22,0:07:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya rencana yang kami pikirkan\Nsudah terbaca, ya?
Dialogue: 0,0:07:38.52,0:07:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau bertindak seperti apa\Ntidak ada hubungannya denganmu, kan?!
Dialogue: 0,0:07:43.19,0:07:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, ada hubungannya.
Dialogue: 0,0:07:46.53,0:07:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusan dompetku sedang seret soalnya.
Dialogue: 0,0:07:49.78,0:07:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja meniru tentara bayaran.
Dialogue: 0,0:07:52.16,0:07:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, urusan uang, ya.
Dialogue: 0,0:07:54.75,0:07:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, memangnya kau pikir
Dialogue: 0,0:07:58.92,0:08:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa menghentikanku?
Dialogue: 0,0:08:01.04,0:08:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:02.13,0:08:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kau pikir
Dialogue: 0,0:08:03.55,0:08:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak bisa?!
Dialogue: 0,0:08:07.72,0:08:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, dasar keras kepala kayak batu.
Dialogue: 0,0:08:13.64,0:08:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum sepuluh detik, lo.
Dialogue: 0,0:08:17.39,0:08:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bikin ketawa!
Dialogue: 0,0:08:30.82,0:08:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sudah kuduga kau tidak ada apa-apanya.
Dialogue: 0,0:08:35.08,0:08:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa tidak akan ada lawan\Nyang bisa membuatmu puas.
Dialogue: 0,0:08:40.08,0:08:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, tuh.
Dialogue: 0,0:08:41.78,0:08:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Ayanokoji yang sekarang\Nlagi jalan santai di belakangmu.
Dialogue: 0,0:08:48.55,0:08:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alah, kau juga sok tahu rupanya.
Dialogue: 0,0:08:52.34,0:08:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena selama ini aku belum pernah melihat\Nada yang bisa menahan tinjuku dengan santai.
Dialogue: 0,0:08:58.56,0:09:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, orang yang bisa bermuka datar\Ntanpa kesakitan saat tertusuk pisau
Dialogue: 0,0:09:03.61,0:09:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}enggak bakal pernah bisa kulihat lagi.
Dialogue: 0,0:09:06.86,0:09:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sudah seru-seruan\Ntanpa mengajakku.
Dialogue: 0,0:09:11.49,0:09:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau juga tertarik\Nsama Ayanokoji rupanya?!
Dialogue: 0,0:09:17.74,0:09:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat seperti dugaanku, Ryuen!
Dialogue: 0,0:09:20.54,0:09:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau itu memang cuma segitu!
Dialogue: 0,0:09:28.26,0:09:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah puas bisa membalas cuma begitu?
Dialogue: 0,0:09:31.26,0:09:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini biar kubunuh kau!
Dialogue: 0,0:09:38.47,0:09:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badan tidak bisa bohong, kan?
Dialogue: 0,0:09:41.69,0:09:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, terima saja situasimu\Nyang menyedihkan itu.
Dialogue: 0,0:09:48.23,0:09:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah, Ryuen.
Dialogue: 0,0:09:50.44,0:09:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau bukanlah orang\Nyang bisa menghiburku.
Dialogue: 0,0:09:54.32,0:09:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:09:56.03,0:09:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:09:57.49,0:10:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa seenaknya merasa menang begitu?
Dialogue: 0,0:10:02.04,0:10:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungannya masih belum selesai.
Dialogue: 0,0:10:09.50,0:10:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kau ini?
Dialogue: 0,0:10:12.30,0:10:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal berdiri saja setengah mati.
Dialogue: 0,0:10:14.76,0:10:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa bertahan sejauh itu?
Dialogue: 0,0:10:19.77,0:10:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:10:20.77,0:10:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian ini?!
Dialogue: 0,0:10:27.15,0:10:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?!
Dialogue: 0,0:10:29.02,0:10:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang mau main keroyok\Ntiga lawan satu, hah?!
Dialogue: 0,0:10:32.99,0:10:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menggonggong keras begitu, gorila.
Dialogue: 0,0:10:37.70,0:10:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya meremehkanku!
Dialogue: 0,0:10:39.62,0:10:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar keroco yang duel sendiri saja\Ntidak becus!
Dialogue: 0,0:10:43.79,0:10:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bikin ketawa.
Dialogue: 0,0:10:45.92,0:10:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sebodoh itu untuk\Nmenantang gorila berduel!
Dialogue: 0,0:11:08.81,0:11:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keras amat.
Dialogue: 0,0:11:10.77,0:11:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku yang ini ikut sakit jadinya.
Dialogue: 0,0:11:14.24,0:11:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan anggap dengan ini\Nkau bisa menang, Ryuen!
Dialogue: 0,0:11:19.49,0:11:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, bagaimana caranya itu tidak penting.
Dialogue: 0,0:11:23.16,0:11:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang masih berdiri di akhir\Nadalah pemenangnya.
Dialogue: 0,0:11:26.71,0:11:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ketemu lagi bakal langsung\Nkubunuh kau!
Dialogue: 0,0:11:31.38,0:11:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berniat meladeni\Ntanding ulangmu itu.
Dialogue: 0,0:11:34.80,0:11:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bisa memukulku hingga terpental\Ndan berakhir dikeluarkan dari sekolah.
Dialogue: 0,0:11:40.18,0:11:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu adalah kekalahanmu.
Dialogue: 0,0:11:43.52,0:11:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengoceh apa kau...!
Dialogue: 0,0:11:51.11,0:11:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar baku hantam yang melelahkan.
Dialogue: 0,0:11:54.53,0:11:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja dia ini mengerikan.
Dialogue: 0,0:11:57.32,0:12:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kukira monster betulan.
Dialogue: 0,0:12:00.53,0:12:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti lelah.
Dialogue: 0,0:12:02.91,0:12:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi sebelum para guru datang.
Dialogue: 0,0:12:07.16,0:12:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Ryuen sendiri...
Dialogue: 0,0:12:09.71,0:12:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal menyerah dan gugur bareng Hosen.
Dialogue: 0,0:12:13.67,0:12:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tidak masalah?
Dialogue: 0,0:12:17.55,0:12:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang dibutuhkan\Nsudah kuserahkan ke Katsuragi.
Dialogue: 0,0:12:21.68,0:12:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski masuk peringkat tiga besar\Njadi susah sekarang.
Dialogue: 0,0:12:25.43,0:12:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, sayang sekali, ya.
Dialogue: 0,0:12:29.77,0:12:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebenarnya tidak juga.
Dialogue: 0,0:12:35.36,0:12:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih laporannya.
Dialogue: 0,0:12:37.07,0:12:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah boleh kembali ke ujian.
Dialogue: 0,0:12:39.40,0:12:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya kurang memuaskan, ya?
Dialogue: 0,0:12:41.78,0:12:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya berhadapan sama anak kelas dua\Nbernama Ryuen dan keduanya luka parah.
Dialogue: 0,0:12:46.29,0:12:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usaha memojokkan Kak Ayanokoji\Ntidak selesai di sini, kan?
Dialogue: 0,0:12:50.67,0:12:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menantang bahaya lebih dari ini\Ntidak akan ada untungnya.
Dialogue: 0,0:12:55.92,0:12:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, akan mundur di sini, begitu?
Dialogue: 0,0:12:59.30,0:13:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa kesal rasanya.
Dialogue: 0,0:13:02.05,0:13:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal hadiah uang juga sudah\Nmenyebar dengan sendirinya.
Dialogue: 0,0:13:06.43,0:13:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi, kalau tidak bisa memercayai\Nteman dari kelas satu begini.
Dialogue: 0,0:13:11.48,0:13:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya rencana ini terlalu nekat.
Dialogue: 0,0:13:14.65,0:13:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyesal sudah merasa\Nharus melakukannya sendiri.
Dialogue: 0,0:13:20.61,0:13:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utomiya mana?
Dialogue: 0,0:13:22.53,0:13:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sampai tadi kurasa\Nmasih di dekat sini.
Dialogue: 0,0:13:28.58,0:13:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa dia?
Dialogue: 0,0:13:31.87,0:13:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah Kito Hayato,\Nkakak kelas dari Kelas 2-A, ya.
Dialogue: 0,0:13:37.05,0:13:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf saja, tapi tidak akan kubiarkan\Nlewat dari sini.
Dialogue: 0,0:13:40.22,0:13:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maumu?
Dialogue: 0,0:13:43.97,0:13:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang memerintahkanmu kemari?!
Dialogue: 0,0:13:46.35,0:13:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kuberi ampun\Nmeski pada kakak kelas!
Dialogue: 0,0:13:56.44,0:13:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utomiya, sedang apa kamu?
Dialogue: 0,0:14:00.28,0:14:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:14:01.15,0:14:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu harusnya\Nmengikuti perintahku?
Dialogue: 0,0:14:06.28,0:14:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuanku sudah terpenuhi.
Dialogue: 0,0:14:09.79,0:14:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utomiya!
Dialogue: 0,0:14:12.00,0:14:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku.
Dialogue: 0,0:14:13.21,0:14:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:14:14.62,0:14:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kito bagaimana?
Dialogue: 0,0:14:16.04,0:14:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru saja pergi dari hadapanku.
Dialogue: 0,0:14:18.25,0:14:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu seenaknya begitu?
Dialogue: 0,0:14:20.59,0:14:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:14:21.72,0:14:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat mencegah dia\Nmendekat ke tempatmu.
Dialogue: 0,0:14:25.59,0:14:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kalau bisa jalan,\Nkembalilah ke sini.
Dialogue: 0,0:14:38.98,0:14:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Ayanokoji.
Dialogue: 0,0:14:41.61,0:14:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin banyak sekali yang membuat repot, ya.
Dialogue: 0,0:14:44.61,0:14:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertolong berkatmu, Sakayanagi.
Dialogue: 0,0:14:47.37,0:14:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa penaltimu tidak masalah?
Dialogue: 0,0:14:49.70,0:14:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya kamu dipaksa bergerak\Ncukup jauh di tengah malam.
Dialogue: 0,0:14:53.12,0:14:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area pertama yang ditunjuk ada di H3.
Dialogue: 0,0:14:56.12,0:14:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau sudah mepet,\Ntapi kurasa masih sempat.
Dialogue: 0,0:14:58.63,0:15:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}H3, ya.
Dialogue: 0,0:15:00.88,0:15:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya tadi pagi Ichinose\Nyang ada di grupku tiba-tiba menghilang.
Dialogue: 0,0:15:05.88,0:15:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada musibah?
Dialogue: 0,0:15:07.39,0:15:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kurasa keputusannya sendiri.
Dialogue: 0,0:15:10.14,0:15:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena beberapa hari ini\Ngerak-geriknya aneh.
Dialogue: 0,0:15:13.89,0:15:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa mengabariku?
Dialogue: 0,0:15:16.19,0:15:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tahu kalau dia ada di E3\Nsama seperti Ayanokoji.
Dialogue: 0,0:15:20.19,0:15:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja ada di sisi D3\Nyang di arah kebalikan darimu.
Dialogue: 0,0:15:23.40,0:15:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin, area mana yang terakhir\Nditunjuk untuk grup kalian?
Dialogue: 0,0:15:26.95,0:15:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area D5.
Dialogue: 0,0:15:28.74,0:15:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi pagi aku menyadari\Npoin grup kami berkurang satu.
Dialogue: 0,0:15:33.08,0:15:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Ichinose memakai pencarian GPS.
Dialogue: 0,0:15:37.08,0:15:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah wajar kalau beranggapan\Ndia pergi menemui seseorang.
Dialogue: 0,0:15:40.92,0:15:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma itu alasan yang masuk akal\Nuntuk pergi di pagi buta.
Dialogue: 0,0:15:44.67,0:15:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berpikir apa mungkin\Ndia ingin bertemu Ayanokoji.
Dialogue: 0,0:15:49.18,0:15:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku tidak punya\Npetunjuk untuk itu.
Dialogue: 0,0:15:51.51,0:15:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bagaimana?
Dialogue: 0,0:15:52.72,0:15:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau berarti membuang hadiah kedatangan,\Nmau tidak mau harus mengabaikannya.
Dialogue: 0,0:15:57.94,0:16:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kemungkinan terburuknya dia gugur,
Dialogue: 0,0:16:00.65,0:16:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan memberi dampak buruk\Nyang berarti di hari terakhir seperti ini.
Dialogue: 0,0:16:04.82,0:16:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski mengherankan untuk Ichinose\Nyang sangat peduli pada temannya.
Dialogue: 0,0:16:08.99,0:16:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berat juga untukmu.
Dialogue: 0,0:16:10.82,0:16:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Insiden memang tidak terhindarkan.
Dialogue: 0,0:16:13.66,0:16:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa bertemu dengan dia,\Ntolong tanyakan alasannya.
Dialogue: 0,0:16:17.21,0:16:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:16:21.75,0:16:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal patroli untuk menjemput para siswa\Nsetelah ujian selesai, ya.
Dialogue: 0,0:16:28.22,0:16:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, malah dapat titik I2\Nyang ada di ujung timur laut.
Dialogue: 0,0:16:33.10,0:16:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di detik-detik terakhir sebelum ujian\Nberakhir di pukul tiga sore,
Dialogue: 0,0:16:37.27,0:16:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah menunjuk area yang tidak kira-kira.
Dialogue: 0,0:16:40.27,0:16:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji!
Dialogue: 0,0:16:43.11,0:16:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ichinose?
Dialogue: 0,0:16:44.82,0:16:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu datang sampai ke sini?
Dialogue: 0,0:16:47.24,0:16:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:16:48.57,0:16:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... ke sini...\Nuntuk menemui Ayanokoji...
Dialogue: 0,0:16:53.45,0:16:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal ke sana sekarang!
Dialogue: 0,0:16:58.37,0:17:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, terkejar juga.
Dialogue: 0,0:17:01.17,0:17:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya ada apa, Ichinose?
Dialogue: 0,0:17:04.17,0:17:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada yang harus kusampaikan ke Ayanokoji.
Dialogue: 0,0:17:10.80,0:17:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disampaikan padaku?
Dialogue: 0,0:17:12.80,0:17:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jam tanganku rusak,\Njadi kembali ke titik start.
Dialogue: 0,0:17:17.97,0:17:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tengah jalan ada Kepala Yayasan Sementara\NTsukishiro dan Pak Shiba.
Dialogue: 0,0:17:22.77,0:17:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai hari terakhir\NAyanokoji masih bertahan,
Dialogue: 0,0:17:25.81,0:17:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya mau dipanggil dan dihabisi di I2.
Dialogue: 0,0:17:28.94,0:17:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini kukatakan ke Ayanokoji,
Dialogue: 0,0:17:32.24,0:17:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya teman sekelasku\Nakan dikeluarkan dari sekolah.
Dialogue: 0,0:17:35.28,0:17:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi rasanya aku tidak bisa\Nmembiarkanmu begitu saja.
Dialogue: 0,0:17:39.75,0:17:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya jangan dipedulikan dan diam saja.
Dialogue: 0,0:17:41.79,0:17:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku ini musuhmu.
Dialogue: 0,0:17:44.42,0:17:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil!
Dialogue: 0,0:17:45.92,0:17:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji bukanlah musuhku!
Dialogue: 0,0:17:48.71,0:17:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini!
Dialogue: 0,0:17:50.13,0:17:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayanokoji, aku ini...
Dialogue: 0,0:17:52.97,0:17:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyukaimu!
Dialogue: 0,0:17:55.97,0:17:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan!
Dialogue: 0,0:17:58.01,0:17:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu...
Dialogue: 0,0:18:00.23,0:18:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku...
Dialogue: 0,0:18:02.81,0:18:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Ichinose.
Dialogue: 0,0:18:04.85,0:18:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak kau peringati,\Nentah bagaimana nasibku nanti.
Dialogue: 0,0:18:09.48,0:18:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sayangnya, aku berniat pergi ke I2.
Dialogue: 0,0:18:12.99,0:18:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan! Itu bahaya!
Dialogue: 0,0:18:15.24,0:18:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak begitu, nanti Ichinose tidak bisa\Nmelindungi teman sekelasmu yang berharga.
Dialogue: 0,0:18:22.00,0:18:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perkataanmu tadi sungguhan?
Dialogue: 0,0:18:25.25,0:18:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, bantahlah sekarang juga.
Dialogue: 0,0:18:27.71,0:18:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa salah paham.
Dialogue: 0,0:18:29.30,0:18:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, itu bukan salah paham...
Dialogue: 0,0:18:33.68,0:18:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, menyukaimu.
Dialogue: 0,0:18:37.18,0:18:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku baru saja\Nmenyadari perasaan itu.
Dialogue: 0,0:18:41.64,0:18:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya,
Dialogue: 0,0:18:43.14,0:18:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sedikit terkejut karena tidak menyangka\NIchinose punya perasaan seperti itu padaku.
Dialogue: 0,0:18:48.77,0:18:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, ya.
Dialogue: 0,0:18:50.90,0:18:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak suka, ya.
Dialogue: 0,0:18:52.90,0:18:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:18:54.78,0:18:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, masih tersisa beberapa hal\Nyang harus diselesaikan.
Dialogue: 0,0:18:59.62,0:19:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa tidak boleh menjawab\Niya atau tidak di situasi seperti itu.
Dialogue: 0,0:19:04.66,0:19:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah jawaban terbaik\Nyang bisa kuberikan sekarang.
Dialogue: 0,0:19:08.96,0:19:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, baiklah.
Dialogue: 0,0:19:14.01,0:19:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ayanokoji.
Dialogue: 0,0:19:16.59,0:19:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali.
Dialogue: 0,0:19:18.18,0:19:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Ketua OSIS Nagumo\Nada di tempat seperti ini?
Dialogue: 0,0:19:21.76,0:19:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri kenapa datang ke tempat\Nyang tidak ditunjuk dan tanpa tugas?
Dialogue: 0,0:19:26.73,0:19:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemuan sama Honami, ya?
Dialogue: 0,0:19:28.69,0:19:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau iya, apakah ada masalah?
Dialogue: 0,0:19:30.98,0:19:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:32.32,0:19:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kau sedang sendiri\Npasti karena ada tujuan lain.
Dialogue: 0,0:19:37.32,0:19:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin mengobrol denganmu\Nsetidaknya sekali.
Dialogue: 0,0:19:41.83,0:19:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah uang sebanyak 20 juta poin\Nbila berhasil mengeluarkanku dari sekolah.
Dialogue: 0,0:19:46.96,0:19:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya Anda tahu kalau\Nanak kelas satu menyerangku.
Dialogue: 0,0:19:52.13,0:19:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan diambil hati, lo.\NItu bukan ideku.
Dialogue: 0,0:19:55.88,0:19:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti Kepala Yayasan Sementara Tsukishiro, ya.
Dialogue: 0,0:19:59.09,0:20:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau targetnya adalah siswa lain,\Npasti tidak akan kuterima.
Dialogue: 0,0:20:04.02,0:20:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adalah satu-satunya pria\Nyang dinilai tinggi Kak Horikita.
Dialogue: 0,0:20:08.48,0:20:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertandinglah denganku dan tunjukkan\Nbagaimana mode seriusmu.
Dialogue: 0,0:20:13.11,0:20:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan bisa bertanding apa-apa.
Dialogue: 0,0:20:15.69,0:20:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan pikiran jujurmu.
Dialogue: 0,0:20:18.11,0:20:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ada di peringkat 11.
Dialogue: 0,0:20:20.99,0:20:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, pasti ada di peringkat 15\Natau 16, kan?
Dialogue: 0,0:20:25.25,0:20:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:20:27.00,0:20:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau betulan punya kemampuan\Nyang disembunyikan,
Dialogue: 0,0:20:30.12,0:20:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin pasti akan ambil peringkat yang\Ntidak mencolok dan bisa naik ke atas kapan saja.
Dialogue: 0,0:20:35.88,0:20:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku meragukan apa dirimu punya\Nkemampuan yang diharapkan Kak Horikita,
Dialogue: 0,0:20:41.64,0:20:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dengan ini jadi jelas.
Dialogue: 0,0:20:44.60,0:20:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah mendapat hak untuk\Ndihancurleburkan olehku.
Dialogue: 0,0:20:48.77,0:20:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahagialah.
Dialogue: 0,0:20:50.40,0:20:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku sedang buru-buru.
Dialogue: 0,0:20:54.02,0:20:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong urusan ini dilanjutkan saja lain waktu.
Dialogue: 0,0:20:56.82,0:20:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa memangnya di depan I2 sana?
Dialogue: 0,0:20:59.65,0:21:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan minggir\Nsampai kau mau menghadapiku.
Dialogue: 0,0:21:04.28,0:21:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mau menghadapiku...
Dialogue: 0,0:21:07.20,0:21:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua OSIS Nagumo, begini-begini\Naku berniat menilai tinggi dirimu.
Dialogue: 0,0:21:13.25,0:21:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu punya kemampuan yang\Nberbeda dengan Ketua OSIS Horikita
Dialogue: 0,0:21:16.75,0:21:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berhasil berdiri di puncak sekolah ini.
Dialogue: 0,0:21:20.09,0:21:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, ada area yang\Ntidak seharusnya Anda injak.
Dialogue: 0,0:21:24.80,0:21:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong pergi dari sini.
Dialogue: 0,0:21:26.72,0:21:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha, kau mau memerintahku?!
Dialogue: 0,0:21:30.14,0:21:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir siapa dirimu...?!
Dialogue: 0,0:21:32.81,0:21:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham tidak kalau kusuruh pergi?
Dialogue: 0,0:21:37.61,0:21:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjalan lancar, Nagumo!
Dialogue: 0,0:21:39.74,0:21:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri arahan selanjutnya\Nuntuk mengatasi Koenji.
Dialogue: 0,0:21:43.24,0:21:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Nagumo.
Dialogue: 0,0:21:44.78,0:21:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin tidak mau dijawab?
Dialogue: 0,0:21:50.25,0:21:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhajar dirimu hingga hancur lebur!
Dialogue: 0,0:21:52.92,0:21:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tugas terakhirku sebagai ketua OSIS!
Dialogue: 0,0:21:56.63,0:21:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:21:59.80,0:22:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A... yano... ko...
