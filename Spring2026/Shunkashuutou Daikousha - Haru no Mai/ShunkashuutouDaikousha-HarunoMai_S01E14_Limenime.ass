Dialogue: 0,0:00:51.07,0:00:51.74,sign,,0000,0000,0000,,EPISODE EMPAT BELAS:
Dialogue: 0,0:00:51.74,0:00:53.57,sign,,0000,0000,0000,,BUNGA MUSIM SEMI YANG MEKAR DI MUSIM DINGIN
Dialogue: 0,0:04:55.02,0:04:56.03,sign,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:23:42.07,0:23:45.07,sign,,0000,0000,0000,,KISAH PUN KEMBALI DIMULAI DARI SINI
Dialogue: 0,0:00:06.03,0:00:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda, kumohon jangan\Ntinggalkan aku sendiri!
Dialogue: 0,0:00:10.66,0:00:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi anak baik,\Njangan ditinggal sendiri!
Dialogue: 0,0:00:14.95,0:00:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mimpi.
Dialogue: 0,0:00:18.32,0:00:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:00:20.21,0:00:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ikut ke sini.
Dialogue: 0,0:00:24.21,0:00:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah, Ibunda?
Dialogue: 0,0:00:27.92,0:00:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah jadi anak yang sangat baik, lo!
Dialogue: 0,0:00:31.72,0:00:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berjuang keras!
Dialogue: 0,0:00:33.55,0:00:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berjuang hidup!
Dialogue: 0,0:00:35.18,0:00:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi anak itu.
Dialogue: 0,0:00:38.06,0:00:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Hinagiku. Ibunda tahu karena\Nselalu mengawasimu.
Dialogue: 0,0:00:45.32,0:00:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan kenyataan.
Dialogue: 0,0:00:48.65,0:00:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanyalah mimpi
Dialogue: 0,0:00:51.74,0:00:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk anak itu.
Dialogue: 0,0:01:00.92,0:01:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah disiapkan untuk bertempur.
Dialogue: 0,0:01:03.71,0:01:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya Tuhan!
Dialogue: 0,0:01:05.63,0:01:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah begitu kusayangi.
Dialogue: 0,0:01:08.21,0:01:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tahu kita akan datang.
Dialogue: 0,0:01:11.97,0:01:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, mana mungkin\Nberbuat seperti ini.
Dialogue: 0,0:01:16.97,0:01:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirim regu pengintai.
Dialogue: 0,0:01:28.86,0:01:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:01:30.99,0:01:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku!
Dialogue: 0,0:01:33.07,0:01:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga Penyamun sama seperti kalian!
Dialogue: 0,0:01:35.33,0:01:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mata-mata, tapi identitasku ketahuan\Nmakanya jadi begini!
Dialogue: 0,0:01:41.79,0:01:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana akting hebatku?
Dialogue: 0,0:01:46.38,0:01:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memakai dia sebagai umpan\Nternyata lumayan juga.
Dialogue: 0,0:01:48.96,0:01:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka...
Dialogue: 0,0:01:51.13,0:01:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Regu pengintai dikirim sesuai perkiraan.
Dialogue: 0,0:01:53.80,0:01:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau rekan mereka tidak kembali,\Npasti akan mengirim pengintai lagi.
Dialogue: 0,0:01:57.47,0:01:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lihat ini.
Dialogue: 0,0:02:01.68,0:02:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang ini sudah diutak-atik?
Dialogue: 0,0:02:03.73,0:02:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya mari kita manfaatkan itu.
Dialogue: 0,0:02:06.77,0:02:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua lari saja\Ndengan meninggalkan perangkat di sini.
Dialogue: 0,0:02:10.40,0:02:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti biar kami yang urus.
Dialogue: 0,0:02:12.61,0:02:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi masih banyak orang yang ter—
Dialogue: 0,0:02:14.70,0:02:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya tugas seorang pengawal\Nadalah melindungi tuannya.
Dialogue: 0,0:02:19.33,0:02:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadikan hatimu sekejam iblis.
Dialogue: 0,0:02:21.62,0:02:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi!
Dialogue: 0,0:02:22.08,0:02:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong putuskan sekarang!
Dialogue: 0,0:02:23.96,0:02:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu untuk ragu.
Dialogue: 0,0:02:26.96,0:02:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:02:28.54,0:02:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajar kalau ingin mengutamakan\Nnyawa Nona Hinagiku.
Dialogue: 0,0:02:32.97,0:02:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ragu.
Dialogue: 0,0:02:34.18,0:02:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu menolong orang lain sampai\Nmembahayakan nyawa Nona Hinagiku...
Dialogue: 0,0:02:40.22,0:02:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ragu, janganlah ragu!
Dialogue: 0,0:02:43.06,0:02:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau meninggalkan mereka semua?
Dialogue: 0,0:02:46.94,0:02:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh begitu.
Dialogue: 0,0:02:49.48,0:02:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bom.
Dialogue: 0,0:02:52.24,0:02:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua harus dibawa keluar.
Dialogue: 0,0:02:55.78,0:02:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, butuh waktu\Nuntuk mengeluarkan semuanya.
Dialogue: 0,0:02:58.87,0:03:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga harus lari lewat tangga darurat\Nuntuk menghindari Kasai.
Dialogue: 0,0:03:02.25,0:03:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, karena itu...
Dialogue: 0,0:03:05.25,0:03:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawalah itu.
Dialogue: 0,0:03:07.21,0:03:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ke atas bersama Sakura.
Dialogue: 0,0:03:11.75,0:03:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah targetnya Misuzu.
Dialogue: 0,0:03:15.81,0:03:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku tetap di sini,
Dialogue: 0,0:03:18.34,0:03:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bom akan dibiarkan tidak meledak.
Dialogue: 0,0:03:21.56,0:03:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi itu, kalian semua bisa lari.
Dialogue: 0,0:03:25.48,0:03:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin mengorbankan diri\Nmelindungi orang lain lagi?
Dialogue: 0,0:03:29.86,0:03:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kok, Sakura.
Dialogue: 0,0:03:33.23,0:03:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bilang masih mampu\Nkalau cuma mengulur waktu.
Dialogue: 0,0:03:40.49,0:03:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertarung.
Dialogue: 0,0:03:42.70,0:03:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan bertarung.
Dialogue: 0,0:03:45.33,0:03:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan mengorbankan diri lagi.
Dialogue: 0,0:03:50.47,0:03:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bukan yang dulu.
Dialogue: 0,0:03:55.13,0:03:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu berbahaya!
Dialogue: 0,0:03:56.34,0:03:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua saja yang lari!\NItu yang paling aman!
Dialogue: 0,0:03:59.59,0:04:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Sakura.
Dialogue: 0,0:04:02.22,0:04:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya akan bilang ini sekarang.
Dialogue: 0,0:04:08.27,0:04:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah pertarungan kita.
Dialogue: 0,0:04:11.81,0:04:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar para rakyat bisa lari dari penyamun.
Dialogue: 0,0:04:15.11,0:04:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini perintah tertinggi.
Dialogue: 0,0:04:18.39,0:04:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perintah selaku Utusan Musim Semi.
Dialogue: 0,0:04:24.54,0:04:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja sama juga dari kalian semua.
Dialogue: 0,0:04:30.04,0:04:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan bisa kalau sendiri.
Dialogue: 0,0:04:33.46,0:04:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa melindungi lebih banyak nyawa\Nsekecil apa pun itu.
Dialogue: 0,0:04:37.97,0:04:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri bantuan untuk itu.
Dialogue: 0,0:04:43.30,0:04:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon dengan sangat.
Dialogue: 0,0:04:52.77,0:04:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terima perintahnya.
Dialogue: 0,0:04:56.94,0:05:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Regu satu dan dua tidak bisa dihubungi.
Dialogue: 0,0:05:00.15,0:05:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, ayo pergi.
Dialogue: 0,0:05:02.62,0:05:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:05:03.49,0:05:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jebakan seperti ini cuma tipuan anak kecil.
Dialogue: 0,0:05:06.87,0:05:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita ikuti saja pancingannya.
Dialogue: 0,0:05:10.62,0:05:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku ingin segera bertemu anak itu.
Dialogue: 0,0:05:14.17,0:05:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, maaf, ya.
Dialogue: 0,0:05:17.05,0:05:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti takut.
Dialogue: 0,0:05:18.63,0:05:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti juga takut.
Dialogue: 0,0:05:22.77,0:05:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:23.89,0:05:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:05:25.39,0:05:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai semuanya bisa lari.
Dialogue: 0,0:05:29.14,0:05:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal ada kamu, aku bisa jadi kuat.
Dialogue: 0,0:05:35.15,0:05:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus jadi kuat.
Dialogue: 0,0:05:38.40,0:05:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, tolong.
Dialogue: 0,0:05:40.74,0:05:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bertarung sama-sama.
Dialogue: 0,0:05:44.82,0:05:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat kapan pun dan seperti apa pun,\Naku akan melindungimu.
Dialogue: 0,0:05:48.87,0:05:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kita berdua akan hidup.
Dialogue: 0,0:05:52.96,0:05:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, asalkan kita berdua.
Dialogue: 0,0:05:57.25,0:05:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:02.17,0:06:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tambah tinggi, ya.
Dialogue: 0,0:06:04.55,0:06:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu senang kamu sudah kelihatan dewasa.
Dialogue: 0,0:06:08.56,0:06:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau baju itu bukan seleraku.
Dialogue: 0,0:06:12.98,0:06:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju ini yang paling aku sukai.
Dialogue: 0,0:06:17.40,0:06:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Sakura sudah\Nsusah payah memilihkannya.
Dialogue: 0,0:06:22.82,0:06:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dulu, baju yang dipakaikan olehmu,
Dialogue: 0,0:06:27.33,0:06:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku membencinya!
Dialogue: 0,0:06:30.33,0:06:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu bisa menggunakan\Nkekuatanmu sepuasnya di sini?
Dialogue: 0,0:06:33.71,0:06:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi malah tidak menyerang.
Dialogue: 0,0:06:39.05,0:06:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi kamu tahu,\Nkalau ada bom.
Dialogue: 0,0:06:44.55,0:06:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tahu sampai rencana bomnya juga.
Dialogue: 0,0:06:47.18,0:06:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa coba yang membocorkannya,\Nbikin kesal saja.
Dialogue: 0,0:06:50.56,0:06:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, malah justru menguntungkan!
Dialogue: 0,0:07:02.57,0:07:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu cuma tes.
Dialogue: 0,0:07:05.07,0:07:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bom yang sama sudah dipasang\Ndi seluruh gedung.
Dialogue: 0,0:07:08.70,0:07:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau semuanya diledakkan,\Nkira-kira akan bagaimana?
Dialogue: 0,0:07:14.08,0:07:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mau merusak ini juga percuma.
Dialogue: 0,0:07:16.37,0:07:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa langsung meledak.
Dialogue: 0,0:07:18.75,0:07:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma aku yang bisa melepas bomnya,\Nkalau aku dibunuh, semuanya tamat.
Dialogue: 0,0:07:24.34,0:07:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya!
Dialogue: 0,0:07:26.34,0:07:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut saja dengan omonganku!
Dialogue: 0,0:07:29.35,0:07:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:07:30.60,0:07:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:07:31.68,0:07:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama jangan ada yang bantu, ya.
Dialogue: 0,0:07:34.85,0:07:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo mengobrol, Hinagiku.
Dialogue: 0,0:07:38.73,0:07:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:40.27,0:07:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kamu tusuk pakai pohon sakura?
Dialogue: 0,0:07:42.19,0:07:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak bisa, kan?
Dialogue: 0,0:07:45.32,0:07:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, akan banyak orang\Nyang mati karena salahmu.
Dialogue: 0,0:07:52.62,0:07:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang sini,\Nnanti kulepaskan bomnya.
Dialogue: 0,0:07:57.08,0:07:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:07:59.58,0:08:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu begitu
Dialogue: 0,0:08:03.80,0:08:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terobsesi padaku?
Dialogue: 0,0:08:07.26,0:08:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha? Kamu tanya kenapa?
Dialogue: 0,0:08:13.31,0:08:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginginkannya,\Nwujudmu yang melindungi orang lain.
Dialogue: 0,0:08:19.98,0:08:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu di sisiku.
Dialogue: 0,0:08:24.07,0:08:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin rasanya di dalam hidupku
Dialogue: 0,0:08:27.57,0:08:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada sosok seperti ini.
Dialogue: 0,0:08:32.37,0:08:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah, kamu putriku?\NItu alasannya.
Dialogue: 0,0:08:36.87,0:08:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang menggantikan,
Dialogue: 0,0:08:39.83,0:08:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memangnya akan menyelesaikan\Nsuatu masalahmu?
Dialogue: 0,0:08:45.57,0:08:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ditumpangtindihkan seenaknya.
Dialogue: 0,0:08:48.30,0:08:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukanlah putrimu!
Dialogue: 0,0:08:52.97,0:08:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu aku lagi!
Dialogue: 0,0:08:56.18,0:08:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bunuh siapa pun lagi!
Dialogue: 0,0:09:00.14,0:09:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Meski itu demi dirimu sekalipun!\N- Kenapa melakukan itu?
Dialogue: 0,0:09:05.94,0:09:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Meski itu demi dirimu sekalipun!\N- Kenapa kamu melakukan itu?
Dialogue: 0,0:09:08.82,0:09:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa melakukan itu?
Dialogue: 0,0:09:13.40,0:09:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini...
Dialogue: 0,0:09:14.87,0:09:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubah pendirian karena sudah teriak\Nsampai seperti itu tapi dunia
Dialogue: 0,0:09:18.37,0:09:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama sekali tidak bersikap baik padaku.
Dialogue: 0,0:09:20.29,0:09:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sudah orang perbuat padaku,\Nkuperbuat balik ke orang lain.
Dialogue: 0,0:09:25.17,0:09:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang apa salahnya itu?
Dialogue: 0,0:09:26.92,0:09:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada seorang pun yang menolongku!
Dialogue: 0,0:09:29.55,0:09:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa pun sama sekali tidak berguna!
Dialogue: 0,0:09:32.68,0:09:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi lemah.
Dialogue: 0,0:09:34.85,0:09:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang kukira.
Dialogue: 0,0:09:36.43,0:09:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila membuang kebencian,\Ntidak akan bisa jadi bilah pedang.
Dialogue: 0,0:09:39.85,0:09:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membutuhkannya!
Dialogue: 0,0:09:42.98,0:09:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa melindungi\Njika tidak jadi bilah.
Dialogue: 0,0:09:45.15,0:09:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi!
Dialogue: 0,0:09:46.90,0:09:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan bertarung.
Dialogue: 0,0:09:51.78,0:09:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewaku sudah memutuskan\Nuntuk melangkah ke depan!
Dialogue: 0,0:09:57.49,0:09:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu!
Dialogue: 0,0:09:59.25,0:10:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu akan kubuat dunia\Nyang lebih baik!
Dialogue: 0,0:10:02.75,0:10:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan utusan itu harus digunakan\Nuntuk orang yang lebih membutuhkan!
Dialogue: 0,0:10:06.88,0:10:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa diabaikan padahal ada orang-orang\Nyang meminta tolong?
Dialogue: 0,0:10:11.01,0:10:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkataanmu itu cuma rengekan anak kecil!
Dialogue: 0,0:10:13.09,0:10:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Doa remeh seperti itu tidak akan\Nbisa menyentuh hatiku!
Dialogue: 0,0:10:17.14,0:10:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di sana sebentar lagi akan selesai.
Dialogue: 0,0:10:19.89,0:10:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin dia tetap hidup,\Nkalau temanmu itu berharga!
Dialogue: 0,0:10:25.52,0:10:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan omonganku, Hinagiku!
Dialogue: 0,0:10:30.61,0:10:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tidak bisa disebut sebagai rencana,
Dialogue: 0,0:10:33.53,0:10:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi yang harus kita lakukan cuma satu.
Dialogue: 0,0:10:37.12,0:10:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bertahan menunggu saatnya bertarung.
Dialogue: 0,0:10:40.83,0:10:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:42.75,0:10:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sekarang begitu menyakitkan.
Dialogue: 0,0:10:45.29,0:10:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila tetap hidup, kelak suatu saat...
Dialogue: 0,0:10:49.92,0:10:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, temanmu makin babak belur, lo.
Dialogue: 0,0:10:53.63,0:10:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo diam dan menurut saja.
Dialogue: 0,0:11:03.39,0:11:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah tersenyum?
Dialogue: 0,0:11:05.06,0:11:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mengejekku?
Dialogue: 0,0:11:06.44,0:11:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang terasa dingin, ya?
Dialogue: 0,0:11:10.35,0:11:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:11.53,0:11:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka dengan musim dingin.
Dialogue: 0,0:11:16.53,0:11:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Komat-kamit apa kamu ini?\N- Aku sudah menunggu.
Dialogue: 0,0:11:22.49,0:11:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin?
Dialogue: 0,0:11:24.37,0:11:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita percaya, Nona Hinagiku.
Dialogue: 0,0:11:28.25,0:11:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti akan datang.
Dialogue: 0,0:11:31.00,0:11:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mikami, dia datang!
Dialogue: 0,0:11:33.26,0:11:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:11:34.51,0:11:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:11:44.48,0:11:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Dingin?
Dialogue: 0,0:11:46.77,0:11:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amankan!
Dialogue: 0,0:11:56.11,0:11:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri!
Dialogue: 0,0:12:08.79,0:12:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:12:12.80,0:12:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dibunuh!
Dialogue: 0,0:12:18.76,0:12:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misuzu, aku dan teman-teman yang menang.
Dialogue: 0,0:12:24.81,0:12:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan bomnya.
Dialogue: 0,0:12:35.07,0:12:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa.
Dialogue: 0,0:12:37.07,0:12:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada cara melepaskannya.
Dialogue: 0,0:12:40.70,0:12:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu lupa
Dialogue: 0,0:12:43.78,0:12:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ini siapa?
Dialogue: 0,0:13:09.77,0:13:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku...
Dialogue: 0,0:13:13.94,0:13:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung sempat.
Dialogue: 0,0:13:17.23,0:13:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan anggap aku tetap anak yang tidak berdaya\Nseperti sepuluh tahun lalu.
Dialogue: 0,0:13:27.62,0:13:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri!
Dialogue: 0,0:13:28.54,0:13:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, berengsek!
Dialogue: 0,0:13:36.13,0:13:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri!
Dialogue: 0,0:13:54.73,0:13:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri...
Dialogue: 0,0:13:58.90,0:14:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misuzu...
Dialogue: 0,0:14:14.63,0:14:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:14:29.01,0:14:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:14:34.52,0:14:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berjuang keras, ya.
Dialogue: 0,0:14:39.90,0:14:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan, sih?
Dialogue: 0,0:14:41.40,0:14:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lama sekali datangnya!
Dialogue: 0,0:14:54.04,0:14:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar Sakura, kan?
Dialogue: 0,0:14:57.54,0:14:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:15:00.46,0:15:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah besar, ya.
Dialogue: 0,0:15:06.01,0:15:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara seolah aku kerabatmu!
Dialogue: 0,0:15:34.16,0:15:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku.
Dialogue: 0,0:15:36.67,0:15:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, aku bukanlah musuh.
Dialogue: 0,0:15:40.04,0:15:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku utusan musim dingin,\NKantsubaki Rosei.
Dialogue: 0,0:15:44.45,0:15:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar keadaan soal hatimu
Dialogue: 0,0:15:47.63,0:15:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang berbeda, kan?
Dialogue: 0,0:15:49.55,0:15:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kudengar masih punya ingatan.
Dialogue: 0,0:15:55.56,0:15:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembang es.
Dialogue: 0,0:15:57.60,0:15:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat tidak?
Dialogue: 0,0:15:58.94,0:16:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita banyak main bersama.
Dialogue: 0,0:16:01.56,0:16:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kamu selamatkan, aku...
Dialogue: 0,0:16:06.20,0:16:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...sekarang jadi dewasa.
Dialogue: 0,0:16:16.29,0:16:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:16:19.33,0:16:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang melindungi bukanlah aku.
Dialogue: 0,0:16:23.92,0:16:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi anak yang sekarang sudah mati...
Dialogue: 0,0:16:29.93,0:16:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kamu bisa hidup.
Dialogue: 0,0:16:33.85,0:16:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi rasa senang ini
Dialogue: 0,0:16:37.60,0:16:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan milikku.
Dialogue: 0,0:16:40.65,0:16:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesungguhnya milik anak itu.
Dialogue: 0,0:16:46.40,0:16:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku yang sebelumnya.
Dialogue: 0,0:16:50.82,0:16:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang suka
Dialogue: 0,0:16:55.29,0:16:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padamu, Tuan Rosei.
Dialogue: 0,0:17:01.46,0:17:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak bisa mengembalikan anak itu.
Dialogue: 0,0:17:06.38,0:17:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf, ya.
Dialogue: 0,0:17:08.76,0:17:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah menunggu saat bertarung.
Dialogue: 0,0:17:11.93,0:17:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini milik anak itu.
Dialogue: 0,0:17:14.39,0:17:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:17:17.52,0:17:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miliknya.
Dialogue: 0,0:17:19.39,0:17:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah jadi anak yang sangat baik!
Dialogue: 0,0:17:23.15,0:17:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berjuang!
Dialogue: 0,0:17:25.02,0:17:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berjuang hidup!
Dialogue: 0,0:17:26.56,0:17:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milik anak itu.
Dialogue: 0,0:17:29.53,0:17:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Hinagiku. Ibunda tahu karena\Nselalu mengawasimu.
Dialogue: 0,0:17:36.78,0:17:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi ini, kalimat ini, semuanya\Nmilik anak itu.
Dialogue: 0,0:17:44.04,0:17:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa
Dialogue: 0,0:17:47.55,0:17:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengembalikan anak itu.
Dialogue: 0,0:17:51.55,0:17:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bahagia karena\Ndirimu sudah kembali.
Dialogue: 0,0:18:00.06,0:18:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyampaikannya.
Dialogue: 0,0:18:03.27,0:18:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku juga sangat menyukainya.
Dialogue: 0,0:18:08.40,0:18:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kamu sudah\Nmenyampaikan jawabannya.
Dialogue: 0,0:18:12.82,0:18:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, janganlah menangis.
Dialogue: 0,0:18:17.45,0:18:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang menolongmu.
Dialogue: 0,0:18:20.00,0:18:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah tidak apa-apa.
Dialogue: 0,0:18:22.83,0:18:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku bukanlah...
Dialogue: 0,0:18:27.13,0:18:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku tahu.
Dialogue: 0,0:18:30.09,0:18:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukankah dirimu yang mengawasi
Dialogue: 0,0:18:33.76,0:18:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melindungi gadis yang kusuka\Nhingga saat terakhirnya.
Dialogue: 0,0:18:38.60,0:18:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kita berdua sama,\Npunya kenangan darinya.
Dialogue: 0,0:18:44.69,0:18:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selama ini menyukainya.
Dialogue: 0,0:18:47.94,0:18:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukan berarti membuatku tidak senang\Ndengan kepulanganmu.
Dialogue: 0,0:18:53.15,0:18:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah kembali.
Dialogue: 0,0:18:57.32,0:18:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih karena
Dialogue: 0,0:18:59.45,0:19:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah hidup.
Dialogue: 0,0:19:04.87,0:19:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku ingin bertemu dirimu.
Dialogue: 0,0:19:09.25,0:19:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu adalah musim semiku.
Dialogue: 0,0:19:12.09,0:19:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan dirimu direbut\Ndan dilukai siapa pun lagi.
Dialogue: 0,0:19:19.43,0:19:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang,
Dialogue: 0,0:19:21.68,0:19:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku.
Dialogue: 0,0:19:40.87,0:19:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya boleh kuserahkan padamu?
Dialogue: 0,0:19:48.33,0:19:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku.
Dialogue: 0,0:19:50.92,0:19:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah memberi tugas yang berat.
Dialogue: 0,0:19:54.13,0:19:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa berjuang sedikit lebih lama lagi?
Dialogue: 0,0:19:59.14,0:20:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mimpi.
Dialogue: 0,0:20:02.72,0:20:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya, Hinagiku.
Dialogue: 0,0:20:06.69,0:20:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini bukan kenyataan.
Dialogue: 0,0:20:12.11,0:20:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:15.65,0:20:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku akan berjuang!
Dialogue: 0,0:20:28.25,0:20:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini Rapat Empat Musim\Ntahun ke-20 Reimei
Dialogue: 0,0:20:31.96,0:20:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kunyatakan selesai!
Dialogue: 0,0:20:35.71,0:20:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir, keempat musim pun berganti.
Dialogue: 0,0:20:41.09,0:20:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kemakmuran dan kedamaian\Nmeliputi bumi.
Dialogue: 0,0:20:46.85,0:20:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua puluh empat siklus matahari,
Dialogue: 0,0:20:49.35,0:20:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari bersorak!
Dialogue: 0,0:20:51.86,0:20:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarianku salah satu gerakan...
Dialogue: 0,0:20:54.65,0:20:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kemarin kuajak latihan\Nlebih banyak sebelum tidur.
Dialogue: 0,0:20:58.74,0:21:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kalau saja kemarin aku hentikan.
Dialogue: 0,0:21:01.87,0:21:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang salah.
Dialogue: 0,0:21:03.91,0:21:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang pertama kali bilang\Nuntuk main kartu sama-sama.
Dialogue: 0,0:21:08.62,0:21:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya aku tidak akan kalah!
Dialogue: 0,0:21:10.71,0:21:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:21:11.63,0:21:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hina, hati-hati melangkah.\N- Selanjutnya ayo main
Dialogue: 0,0:21:12.97,0:21:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hina, hati-hati melangkah.\N- yang bisa dimenangkan olehmu, Nona Ruri.
Dialogue: 0,0:21:14.63,0:21:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku dikasihani anak kecil?\N- Iya, Tuan Rosei.
Dialogue: 0,0:21:19.47,0:21:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang "Hina"?
Dialogue: 0,0:21:21.38,0:21:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil Nona Hinagiku\Ndengan panggilanmu sendiri!
Dialogue: 0,0:21:24.05,0:21:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sengaja mau meledekku, ya?
Dialogue: 0,0:21:26.14,0:21:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa berbeda dengan\Ndiri yang sebelumnya.
Dialogue: 0,0:21:30.77,0:21:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Tuan Rosei bilang\Nmau memanggil "Hina" saja.
Dialogue: 0,0:21:36.53,0:21:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya, Hina.
Dialogue: 0,0:21:38.19,0:21:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tetap kesal padahal tahu semuanya.
Dialogue: 0,0:21:41.91,0:21:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula ada aku pengawalnya di sini,\Nkenapa kamu yang mengawal?
Dialogue: 0,0:21:45.03,0:21:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir dirimu siapa?
Dialogue: 0,0:21:46.66,0:21:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya aku sudah minta izin, kan?
Dialogue: 0,0:21:49.45,0:21:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini betulan galak padaku, ya,\Npadahal lembut sama Itecho.
Dialogue: 0,0:21:55.17,0:21:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bersikap lembut padaku, ya?\NJadi tersanjung.
Dialogue: 0,0:21:58.80,0:21:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma—
Dialogue: 0,0:22:00.38,0:22:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana kutahu!
Dialogue: 0,0:22:03.26,0:22:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mau jalan-jalan sebentar!
Dialogue: 0,0:22:19.19,0:22:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Rosei blakblakan sekali.
Dialogue: 0,0:22:23.20,0:22:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia jatuh hati padamu.
Dialogue: 0,0:22:25.45,0:22:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak disembunyikan sama sekali.
Dialogue: 0,0:22:27.24,0:22:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau membalas perasannya?
Dialogue: 0,0:22:29.16,0:22:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:22:33.33,0:22:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka,\Ntapi tidak akan menentang.
Dialogue: 0,0:22:38.55,0:22:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:22:40.67,0:22:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka pada Tuan Rosei.
Dialogue: 0,0:22:49.93,0:22:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ya.
Dialogue: 0,0:22:52.18,0:22:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada laki-laki\Nyang begitu disuka sekalipun.
Dialogue: 0,0:22:58.19,0:23:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis yang paling aku sayang di dunia
Dialogue: 0,0:23:04.32,0:23:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah pasti kamu orangnya, Sakura.
Dialogue: 0,0:23:10.58,0:23:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku.
Dialogue: 0,0:23:12.70,0:23:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menyukaimu, Sakura.
Dialogue: 0,0:23:22.42,0:23:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik tahun depan dan yang akan datang,\Nmari kita datangkan musim semi.
Dialogue: 0,0:23:27.59,0:23:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdua kita pasti bisa.
Dialogue: 0,0:23:30.22,0:23:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:23:32.14,0:23:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenangkanlah dirimu.
Dialogue: 0,0:23:35.19,0:23:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita wujudkan musim semi yang indah.
