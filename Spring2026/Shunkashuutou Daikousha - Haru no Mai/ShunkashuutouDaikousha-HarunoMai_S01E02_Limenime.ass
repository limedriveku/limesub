Dialogue: 0,0:00:21.88,0:00:24.88,tanda,,0000,0000,0000,,EPISODE DUA: SALJU YANG TERSISA
Dialogue: 0,0:00:41.48,0:00:43.31,tanda,,0000,0000,0000,,BIRO EMPAT MUSIM
Dialogue: 0,0:01:49.38,0:01:50.55,tanda,,0000,0000,0000,,MUSIM SEMI DI RYUGU SETELAH SEPULUH TAHUN
Dialogue: 0,0:02:56.82,0:03:05.58,tanda,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:04:24.83,0:04:26.04,tanda,,0000,0000,0000,,BIRO EMPAT MUSIM YAMATO
Dialogue: 0,0:05:05.24,0:05:07.79,tanda,,0000,0000,0000,,BERLANJUT DARI RYUGU,
Dialogue: 0,0:05:07.79,0:05:09.96,tanda,,0000,0000,0000,,MUSIM SEMI PUN TIBA
Dialogue: 0,0:05:21.59,0:05:22.89,tanda,,0000,0000,0000,,ORANG YANG BERBEDA DARI 10 TAHUN SILAM
Dialogue: 0,0:23:39.98,0:23:44.99,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA: BAYANGAN SAMAR
Dialogue: 0,0:00:06.67,0:00:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang menolong.
Dialogue: 0,0:00:09.49,0:00:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua sudah aman.
Dialogue: 0,0:00:11.97,0:00:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalimat itulah yang ingin kuucapkan.
Dialogue: 0,0:00:15.54,0:00:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak pernah terucap.
Dialogue: 0,0:00:18.29,0:00:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya,
Dialogue: 0,0:00:21.33,0:00:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktu itu aku yang mati.
Dialogue: 0,0:00:30.75,0:00:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, ya.
Dialogue: 0,0:00:33.26,0:00:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga dia tumbuh sehat.
Dialogue: 0,0:00:36.77,0:00:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:00:44.10,0:00:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biro Empat Musim...
Dialogue: 0,0:00:46.03,0:00:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ketahuan.
Dialogue: 0,0:00:47.69,0:00:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kabur?
Dialogue: 0,0:00:49.22,0:00:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlanjur memanggil musim semi.
Dialogue: 0,0:00:52.03,0:00:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kasihan, ayo serahkan diri saja.
Dialogue: 0,0:00:57.70,0:01:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan menyesal?
Dialogue: 0,0:01:01.87,0:01:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh tahun lalu, kamu diculik\Ndan musim semi lenyap dari negeri ini.
Dialogue: 0,0:01:06.88,0:01:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu baru kembali sekarang.
Dialogue: 0,0:01:08.92,0:01:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tidak mau akan jadi sorotan
Dialogue: 0,0:01:11.13,0:01:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan orang yang tidak tahu apa-apa\Nakan menghujat seenaknya.
Dialogue: 0,0:01:15.08,0:01:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti lebih terluka dari saat ini.
Dialogue: 0,0:01:18.73,0:01:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin bisa menahannya?
Dialogue: 0,0:01:21.94,0:01:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bersedia menahannya?
Dialogue: 0,0:01:23.56,0:01:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bisa, kok.
Dialogue: 0,0:01:26.65,0:01:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah orang mau bilang apa.
Dialogue: 0,0:01:30.82,0:01:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:01:32.36,0:01:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok menjawabnya cepat sekali?
Dialogue: 0,0:01:34.99,0:01:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:01:36.95,0:01:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, kamu pasti melindungiku.
Dialogue: 0,0:01:42.67,0:01:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak akan berpisah lagi.
Dialogue: 0,0:01:45.46,0:01:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Nona Hinagiku.
Dialogue: 0,0:01:50.55,0:01:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei.
Dialogue: 0,0:01:52.26,0:01:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tanya Biro Empat Musim.
Dialogue: 0,0:01:54.81,0:01:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalinya musim semi di Ryugu
Dialogue: 0,0:01:58.01,0:02:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan karena munculnya utusan baru.
Dialogue: 0,0:02:01.23,0:02:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawalnya adalah Sakura.
Dialogue: 0,0:02:03.19,0:02:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang melakukan perwujudan
Dialogue: 0,0:02:04.98,0:02:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipastikan adalah Nona Kayo Hinagiku\Nyang menghilang.
Dialogue: 0,0:03:45.25,0:03:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini aku ditugaskan\NBadan Keamanan Biro Empat Musim
Dialogue: 0,0:03:48.25,0:03:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masuk ke Divisi Musim Dingin,\Nnamaku Ishihara.
Dialogue: 0,0:03:50.79,0:03:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Dingin,\NTuan Kantsubaki Rosei.
Dialogue: 0,0:03:54.01,0:03:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta Pengawal Utusan,\NTuan Kangetsu Itecho.
Dialogue: 0,0:03:58.05,0:04:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bertugas sepenuh hati,\Nmohon arahan dan bimbi—
Dialogue: 0,0:04:02.26,0:04:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup salamnya.
Dialogue: 0,0:04:03.18,0:04:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:04:03.97,0:04:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:04.64,0:04:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kamu juga harus ikut.
Dialogue: 0,0:04:06.73,0:04:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, ke mana?
Dialogue: 0,0:04:10.23,0:04:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat bunga.
Dialogue: 0,0:04:11.19,0:04:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh!\N- Pemeriksaan!
Dialogue: 0,0:04:12.82,0:04:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan memastikan keberhasilan
Dialogue: 0,0:04:14.86,0:04:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perwujudan musim semi setelah 10 tahun.
Dialogue: 0,0:04:17.39,0:04:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kamu baru sampai,
Dialogue: 0,0:04:19.61,0:04:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini memang tugas staf\Npendamping Utusan Musim Dingin.
Dialogue: 0,0:04:24.83,0:04:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:04:26.04,0:04:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berulang kali kubilang,\Ndiam saja di Istana Musim Dingin—
Dialogue: 0,0:04:29.08,0:04:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:04:30.33,0:04:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau semi atau dingin,\Npara utusan itu selalu seenaknya!
Dialogue: 0,0:04:34.25,0:04:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengurusi kalian itu biayanya besar, tahu!
Dialogue: 0,0:04:37.97,0:04:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demikianlah ucapan selamat\Ndari berbagai negara
Dialogue: 0,0:04:41.22,0:04:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas musim semi yang akhirnya tiba\Ndi Negeri Yamato setelah sepuluh tahun.
Dialogue: 0,0:04:45.43,0:04:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}SETELAH 10 TAHUN DI RYUGU—\NMeski begitu, utusan musim semi negeri kami
Dialogue: 0,0:04:48.60,0:04:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pergi ke mana saja selama ini?
Dialogue: 0,0:04:51.65,0:04:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Biro Empat Musim?
Dialogue: 0,0:04:53.02,0:04:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, kita dilarang pergi seenaknya.
Dialogue: 0,0:04:56.23,0:05:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini musim semi setelah sepuluh tahun,\Nmana bisa diam saja di Tanah Enishi.
Dialogue: 0,0:05:01.99,0:05:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau sulit untuk bertemu Nona Hinagiku.
Dialogue: 0,0:05:05.24,0:05:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada surat balasan,
Dialogue: 0,0:05:07.79,0:05:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti mereka tidak mau bertemu.
Dialogue: 0,0:05:09.96,0:05:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:05:11.25,0:05:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal bisa melihat musim semi\Npemberian Hinagiku, aku puas.
Dialogue: 0,0:05:15.54,0:05:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi, karena syok setelah diculik,\Ndia pasti...
Dialogue: 0,0:05:18.30,0:05:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dugaan dari laporan pengawal yang dikirim.
Dialogue: 0,0:05:21.59,0:05:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum bisa dipastikan.
Dialogue: 0,0:05:24.47,0:05:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya salahku.
Dialogue: 0,0:05:26.72,0:05:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku dan Sakura pasti membenciku.
Dialogue: 0,0:05:30.98,0:05:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja aku tidak pernah dilahirkan.
Dialogue: 0,0:05:33.69,0:05:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei.
Dialogue: 0,0:05:37.48,0:05:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu!
Dialogue: 0,0:05:39.53,0:05:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan pakai mulut!
Dialogue: 0,0:05:40.57,0:05:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulut saja tidak cukup bikin kamu paham,\Njadi harus pakai kepala.
Dialogue: 0,0:05:44.37,0:05:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan pakai kepala benaran!
Dialogue: 0,0:05:46.81,0:05:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:05:48.61,0:05:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesawat akan melakukan pendaratan.
Dialogue: 0,0:05:56.13,0:05:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu musim semi.
Dialogue: 0,0:06:03.88,0:06:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hangat sekali.
Dialogue: 0,0:06:06.60,0:06:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar musim semi.
Dialogue: 0,0:06:11.35,0:06:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia...
Dialogue: 0,0:06:13.69,0:06:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei!
Dialogue: 0,0:06:24.20,0:06:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, waspadalah pada sekitarmu.
Dialogue: 0,0:06:27.33,0:06:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:06:30.12,0:06:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya juga begini, kan?
Dialogue: 0,0:06:34.12,0:06:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!
Dialogue: 0,0:06:40.55,0:06:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubu reformasi?\NSepertinya bukan.
Dialogue: 0,0:06:43.38,0:06:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubu pemberantas, ya?
Dialogue: 0,0:06:44.47,0:06:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun?
Dialogue: 0,0:06:45.64,0:06:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:46.97,0:06:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubu musim dingin paling sering diserang\Ndi antara keempat musim.
Dialogue: 0,0:06:50.72,0:06:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapkan dirimu.
Dialogue: 0,0:06:52.62,0:06:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya dendam pada musim tertentu\Ndan mengincar kekuatan milik utusannya.
Dialogue: 0,0:06:57.27,0:06:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan mereka beragam.
Dialogue: 0,0:06:58.73,0:06:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:06:59.73,0:07:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja mencoba memahami\Ngerombolan yang isi kepalanya hanya membunuh
Dialogue: 0,0:07:04.45,0:07:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau memanfaatkan kita.
Dialogue: 0,0:07:06.66,0:07:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:07:07.57,0:07:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:16.04,0:07:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kami bantu!
Dialogue: 0,0:07:17.08,0:07:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah.
Dialogue: 0,0:07:17.67,0:07:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua sudah cukup.
Dialogue: 0,0:07:35.84,0:07:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelompok teroris yang khusus\Nmengincar utusan, itulah Penyamun.
Dialogue: 0,0:07:40.15,0:07:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lebih dan tidak kurang dari itu.
Dialogue: 0,0:07:42.90,0:07:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang seperti mereka ada di penjuru dunia
Dialogue: 0,0:07:46.15,0:07:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan para utusan akan selalu diserang.
Dialogue: 0,0:07:48.82,0:07:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sangat tidak masuk akal.
Dialogue: 0,0:07:50.91,0:07:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itulah kenyataan bagi kami.
Dialogue: 0,0:07:54.75,0:07:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ishihara, kamu juga akan\Nberhadapan dengan bahaya.
Dialogue: 0,0:07:59.54,0:08:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:08:02.59,0:08:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu dari mana kalau kami akan datang?
Dialogue: 0,0:08:05.97,0:08:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyahlah!
Dialogue: 0,0:08:15.78,0:08:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah diringkus.
Dialogue: 0,0:08:17.56,0:08:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bakal diperiksa\NBadan Keamanan Negara.
Dialogue: 0,0:08:21.02,0:08:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru tiba di Tsukushi langsung ditahan, deh.
Dialogue: 0,0:08:24.15,0:08:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Desa Musim Dingin\Ndan Biro Empat Musim marah besar kali ini.
Dialogue: 0,0:08:28.40,0:08:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi bersabarlah.
Dialogue: 0,0:08:30.49,0:08:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan seperti ini\Nsudah makanan tiap hari, kan?
Dialogue: 0,0:08:34.03,0:08:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi sendiri saja.
Dialogue: 0,0:08:36.00,0:08:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tetaplah di sini.
Dialogue: 0,0:08:37.65,0:08:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei.
Dialogue: 0,0:08:38.62,0:08:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu tidak akan ada yang terlibat.
Dialogue: 0,0:08:41.16,0:08:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerugiannya dapat ditekan.
Dialogue: 0,0:08:42.84,0:08:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan—
Dialogue: 0,0:08:43.75,0:08:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melantur!
Dialogue: 0,0:08:45.25,0:08:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memaksakan hanya akan\Nmemperburuk posisimu.
Dialogue: 0,0:08:49.26,0:08:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tergesa-gesa, Rosei.
Dialogue: 0,0:08:51.61,0:08:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang berkali-kali,
Dialogue: 0,0:08:53.85,0:08:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu itu berharga bagiku.
Dialogue: 0,0:09:00.14,0:09:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggelikan.
Dialogue: 0,0:09:02.35,0:09:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dipuja sebagai jelmaan dewa,
Dialogue: 0,0:09:05.23,0:09:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami diincar Penyamun dan dikekang negara.
Dialogue: 0,0:09:09.72,0:09:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat bunga saja sulit.
Dialogue: 0,0:09:12.53,0:09:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah kembali,\Naku ingin merasakan musim seminya.
Dialogue: 0,0:09:17.41,0:09:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal,
Dialogue: 0,0:09:19.41,0:09:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sesimpel itu.
Dialogue: 0,0:09:22.42,0:09:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu, Hinagiku menghilang karena salahku.
Dialogue: 0,0:09:26.46,0:09:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!\NKepung mereka!
Dialogue: 0,0:09:28.38,0:09:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh Utusan Musim Dingin!
Dialogue: 0,0:09:35.72,0:09:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:09:41.35,0:09:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho, kuperintahkan padamu.
Dialogue: 0,0:09:44.81,0:09:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa pergi Hinagiku dan Sakura.
Dialogue: 0,0:09:49.82,0:09:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mati di sini.
Dialogue: 0,0:09:52.32,0:09:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu mereka akan puas!
Dialogue: 0,0:09:55.49,0:09:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:10:02.37,0:10:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hinagiku!\N- Nona Hinagiku!
Dialogue: 0,0:10:17.27,0:10:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sakiti siapa-siapa lagi.
Dialogue: 0,0:10:21.48,0:10:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, biar aku...
Dialogue: 0,0:10:24.06,0:10:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!
Dialogue: 0,0:10:29.36,0:10:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, terima kasih.
Dialogue: 0,0:10:34.36,0:10:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah memberiku kembang es.
Dialogue: 0,0:10:38.87,0:10:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mati
Dialogue: 0,0:10:42.25,0:10:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tetaplah hidup, ya?
Dialogue: 0,0:10:44.92,0:10:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh tahun lalu,
Dialogue: 0,0:10:47.84,0:10:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya aku yang mati.
Dialogue: 0,0:10:54.05,0:10:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho, apa Tuan Rosei\Ndekat dengan Utusan Musim Semi?
Dialogue: 0,0:11:01.01,0:11:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang dekat,
Dialogue: 0,0:11:02.64,0:11:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah bisa bertemu\Nlangsung tanpa perlu dalih
Dialogue: 0,0:11:05.39,0:11:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memeriksa lokasi musim semi terwujud?
Dialogue: 0,0:11:08.94,0:11:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ishihara, perkaranya tidak semudah itu.
Dialogue: 0,0:11:14.11,0:11:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak tahu perasaan Nona Hinagiku.
Dialogue: 0,0:11:16.66,0:11:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi paling tidak, pelayannya...
Dialogue: 0,0:11:19.91,0:11:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himedaka Sakura
Dialogue: 0,0:11:22.83,0:11:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan memaafkan kami.
Dialogue: 0,0:11:25.71,0:11:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:11:32.88,0:11:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua itu salahku.
Dialogue: 0,0:11:39.85,0:11:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Insiden penculikan Utusan Musim Semi,\NKayo Hinagiku yang terjadi sepuluh tahun lalu.
Dialogue: 0,0:11:45.95,0:11:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Semi yang saat itu\Nsedang tinggal di Desa Musim Dingin
Dialogue: 0,0:11:49.19,0:11:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diculik dalam serangan Penyamun\Ndan kemudian menghilang.
Dialogue: 0,0:11:53.15,0:11:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pencarian gabungan\Ndilakukan Badan Keamanan Negara,
Dialogue: 0,0:11:56.89,0:11:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biro Empat Musim, Desa Musim Semi,\Ndan Desa Musim Dingin.
Dialogue: 0,0:11:59.87,0:12:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:12:02.74,0:12:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dalam tiga bulan,\NDesa Musim Semi mundur dari pencarian?
Dialogue: 0,0:12:07.62,0:12:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:10.00,0:12:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!
Dialogue: 0,0:12:11.88,0:12:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buang kami!
Dialogue: 0,0:12:13.42,0:12:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka pintunya! Kumohon!
Dialogue: 0,0:12:15.63,0:12:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:12:19.34,0:12:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho.
Dialogue: 0,0:12:21.80,0:12:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Musim Semi menghentikan pencarian.
Dialogue: 0,0:12:27.06,0:12:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku
Dialogue: 0,0:12:29.67,0:12:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan dibebastugaskan.
Dialogue: 0,0:12:32.06,0:12:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:33.44,0:12:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah pelayan.
Dialogue: 0,0:12:35.82,0:12:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus melindungi Nona Hinagiku\Nmeski nyawa taruhannya.
Dialogue: 0,0:12:40.41,0:12:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:12:42.87,0:12:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah hidup!
Dialogue: 0,0:12:44.54,0:12:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu! Tidak!
Dialogue: 0,0:12:46.91,0:12:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan salahmu!
Dialogue: 0,0:12:48.75,0:12:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, dengar!
Dialogue: 0,0:12:50.29,0:12:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim Dinginlah yang bersalah\Nkarena membiarkan Penyamun masuk!
Dialogue: 0,0:12:53.79,0:12:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahku!
Dialogue: 0,0:12:56.21,0:12:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap dihukum.
Dialogue: 0,0:12:58.67,0:13:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saat ini,
Dialogue: 0,0:13:00.72,0:13:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus mencari Nona Hinagiku.
Dialogue: 0,0:13:07.22,0:13:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:13:08.35,0:13:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datanglah ke Desa Musim Dingin.
Dialogue: 0,0:13:12.73,0:13:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cari Nona Hinagiku bersama kami!
Dialogue: 0,0:13:22.70,0:13:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:13:24.32,0:13:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima tahun kemudian, Desa Musim Dingin\Nmenghentikan pencariannya juga.
Dialogue: 0,0:13:29.83,0:13:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, Utusan Musim Semi...
Dialogue: 0,0:13:34.33,0:13:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditelantarkan?
Dialogue: 0,0:13:36.30,0:13:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak ditelantarkan, bukan?
Dialogue: 0,0:13:38.84,0:13:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bohong, kan, Tuan Itecho?
Dialogue: 0,0:13:43.34,0:13:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik Nona Hinagiku...\NAtaupun aku...
Dialogue: 0,0:13:46.47,0:13:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:13:51.04,0:13:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu bilang
Dialogue: 0,0:13:54.02,0:13:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau menolong?
Dialogue: 0,0:14:07.99,0:14:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita cari, Itecho!
Dialogue: 0,0:14:11.89,0:14:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tanpa bantuan desa!
Dialogue: 0,0:14:15.63,0:14:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski hanya kita berdua!
Dialogue: 0,0:14:18.70,0:14:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian Pengawal Musim Semi,\NHimedaka Sakura hilang tanpa jejak.
Dialogue: 0,0:14:24.09,0:14:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan dengan\Nkubu musim dingin pun terputus.
Dialogue: 0,0:14:29.10,0:14:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, seharusnya aku melindungi\NNona Hinagiku meski nyawa taruhannya.
Dialogue: 0,0:14:34.14,0:14:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, baik Rosei...
Dialogue: 0,0:14:37.21,0:14:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maupun Sakura...
Dialogue: 0,0:14:40.03,0:14:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:14:43.43,0:14:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gagal melindunginya.
Dialogue: 0,0:14:46.91,0:14:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:14:50.41,0:14:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu masih membenciku?
Dialogue: 0,0:15:03.47,0:15:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei!
Dialogue: 0,0:15:09.93,0:15:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biro Empat Musim dan desa berhasil dibujuk.
Dialogue: 0,0:15:12.31,0:15:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski makan waktu,\Nini berkat bantuan mereka.
Dialogue: 0,0:15:16.81,0:15:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka adalah penyintas\Ndari serangan sepuluh tahun lalu.
Dialogue: 0,0:15:21.36,0:15:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, mereka diselamatkan\Noleh Nona Hinagiku seperti kita.
Dialogue: 0,0:15:25.74,0:15:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma kamu yang gembira\Natas kembalinya musim semi.
Dialogue: 0,0:15:29.74,0:15:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ingin melihat musim semi bersamamu.
Dialogue: 0,0:15:34.13,0:15:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Rosei.
Dialogue: 0,0:15:36.29,0:15:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu maumu,\Naku akan membawamu ke mana pun.
Dialogue: 0,0:15:50.40,0:15:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat lupa pemandangan ini.
Dialogue: 0,0:15:53.97,0:15:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir kali ada musim semi,\Nusiaku masih belasan.
Dialogue: 0,0:15:59.27,0:16:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menakjubkan.
Dialogue: 0,0:16:15.54,0:16:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang menolong.
Dialogue: 0,0:16:17.77,0:16:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua sudah aman.
Dialogue: 0,0:16:25.26,0:16:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah kembali.
Dialogue: 0,0:16:28.88,0:16:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:16:33.39,0:16:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:16:36.93,0:16:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa saja ini penyerangan.
Dialogue: 0,0:16:39.19,0:16:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua bersiaga sampai ada kepastian.
Dialogue: 0,0:16:41.31,0:16:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siap!
Dialogue: 0,0:16:43.82,0:16:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parah sekali.
Dialogue: 0,0:16:55.12,0:16:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalamnya ada anak-anak.
Dialogue: 0,0:17:01.88,0:17:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagarnya tidak akan bertahan lama.
Dialogue: 0,0:17:09.26,0:17:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dipastikan.
Dialogue: 0,0:17:10.97,0:17:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada potensi serangan,\Nini murni kecelakaan.
Dialogue: 0,0:17:14.84,0:17:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ada sejumlah laporan.
Dialogue: 0,0:17:16.56,0:17:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan ditangani Badan Keamanan Negara\Ndan tim penyelamat.
Dialogue: 0,0:17:19.52,0:17:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:17:20.34,0:17:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, tunggu!
Dialogue: 0,0:17:25.35,0:17:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei!
Dialogue: 0,0:17:26.98,0:17:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan.
Dialogue: 0,0:17:28.19,0:17:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ilahi seorang utusan itu\Nuntuk mendatangkan musim.
Dialogue: 0,0:17:31.78,0:17:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Regulasi Empat Musim tidak mengizinkan\Npenggunaan pribadi kecuali pertahanan diri.
Dialogue: 0,0:17:35.91,0:17:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu itu, kan?
Dialogue: 0,0:17:37.37,0:17:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa kutolong.
Dialogue: 0,0:17:38.50,0:17:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukan pahlawan,\Ntapi utusan empat musim.
Dialogue: 0,0:17:41.62,0:17:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya kalau identitasmu terungkap\Nsetelah pakai kekuatan di depan umum.
Dialogue: 0,0:17:46.25,0:17:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma tambah memancing bahaya!
Dialogue: 0,0:17:48.80,0:17:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tindakanmu juga akan makin dibatasi!
Dialogue: 0,0:17:52.05,0:17:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:17:52.97,0:17:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei!
Dialogue: 0,0:17:53.64,0:17:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho!
Dialogue: 0,0:17:57.56,0:18:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di depan mataku,\Nada nyawa yang bisa ditolong.
Dialogue: 0,0:18:02.71,0:18:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa diselamatkan.
Dialogue: 0,0:18:05.73,0:18:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengerti maksudku, kan?
Dialogue: 0,0:18:19.78,0:18:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu lagi.
Dialogue: 0,0:18:21.71,0:18:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya boleh senandung.
Dialogue: 0,0:18:23.29,0:18:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, kan?
Dialogue: 0,0:18:24.42,0:18:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:18:32.01,0:18:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ingin kuucapkan padanya.
Dialogue: 0,0:18:43.02,0:18:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku datang menolong, semua sudah aman."
Dialogue: 0,0:18:48.07,0:18:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kutolong dengan kedua tangan ini.
Dialogue: 0,0:18:52.82,0:18:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:54.07,0:18:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan Utusan Musim Dingin\Nadalah Pembeku Hayat.
Dialogue: 0,0:18:58.58,0:19:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bisa sampai seperti itu.
Dialogue: 0,0:19:01.58,0:19:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, sok jagoan.
Dialogue: 0,0:19:07.92,0:19:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:19:10.46,0:19:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah kembali.
Dialogue: 0,0:19:14.76,0:19:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bersikap dengan pantas\Nuntuk musim semi.
Dialogue: 0,0:19:20.51,0:19:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ingin kuucapkan padanya.
Dialogue: 0,0:19:27.27,0:19:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku selalu berharap\Nbisa mengucapkannya.
Dialogue: 0,0:19:52.71,0:19:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang menolong.
Dialogue: 0,0:19:55.76,0:19:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua sudah aman.
Dialogue: 0,0:20:04.52,0:20:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Rosei.
Dialogue: 0,0:20:07.23,0:20:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkara ribetnya, biar aku yang urus.
Dialogue: 0,0:20:11.44,0:20:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:20:12.94,0:20:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan minta maaf.
Dialogue: 0,0:20:14.36,0:20:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, kan?
Dialogue: 0,0:20:15.78,0:20:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu maumu,\Naku akan membawamu ke mana pun.
Dialogue: 0,0:20:18.86,0:20:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup demi dirimu.
Dialogue: 0,0:20:22.16,0:20:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkali-kali dibilang.
Dialogue: 0,0:20:24.41,0:20:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei, kamu orang paling berharga bagiku.
Dialogue: 0,0:20:29.67,0:20:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakanlah itu ke Sakura.
Dialogue: 0,0:20:33.96,0:20:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang bisa, sudah dari dulu.
Dialogue: 0,0:20:52.27,0:20:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Rosei.
Dialogue: 0,0:20:54.73,0:20:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelak, masalah Nona Hinagiku\Npasti bisa diatasi.
Dialogue: 0,0:21:00.41,0:21:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan asal bicara\Nkalau tidak sanggup bertanggung jawab.
Dialogue: 0,0:21:03.74,0:21:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bertanggung jawab.
Dialogue: 0,0:21:05.20,0:21:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungimu seumur hidup.
Dialogue: 0,0:21:07.45,0:21:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, katakan itu ke Sakura.
Dialogue: 0,0:21:15.67,0:21:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, tadi itu menakjubkan.
Dialogue: 0,0:21:20.30,0:21:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu buat seperti itu agar tidak menodai\Nmusim semi Nona Hinagiku, kan?
Dialogue: 0,0:21:33.15,0:21:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan musim semi yang indah.
Dialogue: 0,0:21:51.12,0:21:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku.
Dialogue: 0,0:21:53.58,0:21:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ada di mana-mana, ya?
Dialogue: 0,0:21:56.80,0:22:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking rindunya aku,\Nkamu jadi muncul di mana-mana.
