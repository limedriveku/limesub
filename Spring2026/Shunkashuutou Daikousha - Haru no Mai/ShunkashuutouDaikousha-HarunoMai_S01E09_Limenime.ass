Dialogue: 0,0:02:03.69,0:02:12.45,sign,,0000,0000,0000,,(Utusan Empat Musim: Tarian Musim Semi)
Dialogue: 0,0:03:13.30,0:03:17.47,sign,,0000,0000,0000,,(Para Tuan dan Pelayan[4])
Dialogue: 0,0:22:29.46,0:22:33.13,sign,,0000,0000,0000,,(Episode Tujuh: Senja)
Dialogue: 0,0:23:34.94,0:23:39.94,sign,,0000,0000,0000,,(Selanjutnya: Hujan Sakura)
Dialogue: 0,0:00:10.20,0:00:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo! Rindo!
Dialogue: 0,0:00:22.76,0:00:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:00:26.47,0:00:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, ya...
Dialogue: 0,0:00:28.01,0:00:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski cuma sedikit,\Naku ingin melihatnya lebih dekat.
Dialogue: 0,0:00:30.89,0:00:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini musim semi pertamaku.
Dialogue: 0,0:00:34.19,0:00:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berapa pun itu akan kukabulkan.\NNadeshiko, kalau itu keinginanmu,
Dialogue: 0,0:00:38.69,0:00:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo adalah pangeranku.
Dialogue: 0,0:00:42.78,0:00:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pangeranmu?
Dialogue: 0,0:00:44.53,0:00:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih tepat kalau kesatriamu.\NAku seorang pengawal, jadi mungkin
Dialogue: 0,0:00:48.24,0:00:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri.
Dialogue: 0,0:00:49.91,0:00:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tuan putri?
Dialogue: 0,0:00:53.16,0:00:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Nadeshiko.
Dialogue: 0,0:00:55.87,0:00:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu adalah tuan putri\Npaling berharga di dunia.
Dialogue: 0,0:00:59.34,0:01:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga tuan tercinta yang harus dilindungi.
Dialogue: 0,0:01:02.00,0:01:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga satu-satunya utusan musim gugur
Dialogue: 0,0:01:05.34,0:01:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Negeri Yamato ini.
Dialogue: 0,0:01:10.97,0:01:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim gugurku.
Dialogue: 0,0:01:18.69,0:01:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih...♪
Dialogue: 0,0:01:19.73,0:01:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat hembusan angin yang lewat♪
Dialogue: 0,0:01:22.78,0:01:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali menusuk kulit di pagi hari♪
Dialogue: 0,0:01:28.24,0:01:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menembus gelap di balik kelopak mata♪
Dialogue: 0,0:01:30.78,0:01:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mencair seperti salju♪
Dialogue: 0,0:01:34.95,0:01:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini♪
Dialogue: 0,0:01:36.50,0:01:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dapat kau lihat?♪
Dialogue: 0,0:01:39.04,0:01:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang sempat bergema♪
Dialogue: 0,0:01:41.84,0:01:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak pernah kutemukan jawabnya♪
Dialogue: 0,0:01:44.55,0:01:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam ingatan♪
Dialogue: 0,0:01:47.42,0:01:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tersenyum♪
Dialogue: 0,0:01:50.18,0:01:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari itu, kamu tetap sama♪
Dialogue: 0,0:01:54.01,0:01:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ini tak tahu ke mana harus pergi♪
Dialogue: 0,0:01:57.98,0:02:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya terbang ringan, mengikuti angin♪
Dialogue: 0,0:02:03.02,0:02:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kelopak bunga♪
Dialogue: 0,0:02:05.23,0:02:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}“Kini saatnya.."♪
Dialogue: 0,0:02:06.32,0:02:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi pun bermekaran♪
Dialogue: 0,0:02:09.11,0:02:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlambat rasanya kini♪
Dialogue: 0,0:02:13.62,0:02:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meratapi kesedihan♪
Dialogue: 0,0:02:16.33,0:02:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebab duka itu♪
Dialogue: 0,0:02:18.04,0:02:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah lama padam♪
Dialogue: 0,0:02:23.59,0:02:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika semua telah berlalu♪
Dialogue: 0,0:02:25.92,0:02:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim pun kembali berputar♪
Dialogue: 0,0:02:28.67,0:02:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh di sana, langit telah cerah♪
Dialogue: 0,0:02:31.30,0:02:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan di antara semuanya♪
Dialogue: 0,0:02:34.22,0:02:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kenangan itu♪
Dialogue: 0,0:02:37.02,0:02:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap tak memudar♪
Dialogue: 0,0:02:39.64,0:02:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara itu♪
Dialogue: 0,0:02:42.44,0:02:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi penanda datangnya musim semi♪
Dialogue: 0,0:02:48.82,0:02:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi mulai menyelimuti Negeri Yamato!
Dialogue: 0,0:02:52.03,0:02:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya musim semi tiba di seluruh Teishu.
Dialogue: 0,0:02:54.58,0:02:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishi yang dilanda musim dingin panjang,\Nkini akhirnya cuaca hangat—
Dialogue: 0,0:02:59.21,0:03:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, coba lihat, Sakura.
Dialogue: 0,0:03:02.67,0:03:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka yang mana?
Dialogue: 0,0:03:05.46,0:03:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku...
Dialogue: 0,0:03:08.01,0:03:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah memikirkan Sakura,\Nsilakan pilih saja yang Anda suka.
Dialogue: 0,0:03:13.55,0:03:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mewujudkan musim semi di Teishu!\NTerima kasih sudah
Dialogue: 0,0:03:17.47,0:03:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah sejak kejadian itu,\Nsemuanya terlihat lancar.
Dialogue: 0,0:03:22.44,0:03:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}(Syukurlah sejak kejadian itu,\Nsemuanya terlihat lancar.)
Dialogue: 0,0:03:22.69,0:03:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:03:25.56,0:03:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habis ini mau ke Enishi, kan?
Dialogue: 0,0:03:30.86,0:03:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mampir ke Desa Musim Dingin,\Nbukannya bisa ketemu Tuan Rosei tercinta?
Dialogue: 0,0:03:38.20,0:03:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak tahu tercinta atau tidak...
Dialogue: 0,0:03:43.37,0:03:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, senang rasanya kalau bisa ketemu...
Dialogue: 0,0:03:47.59,0:03:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibelikan oleh-oleh dulu, ah...
Dialogue: 0,0:03:53.43,0:03:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mewujudkan musim di Teishu tanpa masalah.\NNona Hinagiku sepertinya sudah selesai
Dialogue: 0,0:03:58.39,0:04:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal tanah Enishi ini saja, ya.
Dialogue: 0,0:04:02.81,0:04:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuputuskan, Itecho.
Dialogue: 0,0:04:05.52,0:04:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan ada Rapat Empat Musim\Nsaat musim panas.
Dialogue: 0,0:04:08.02,0:04:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, tidak bisa kutunggu selama itu.
Dialogue: 0,0:04:12.28,0:04:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah keduanya selesai\Nmelakukan perwujudan,
Dialogue: 0,0:04:14.70,0:04:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kuajukan permohonan resmi untuk bertemu.
Dialogue: 0,0:04:17.91,0:04:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berbagai situasinya.\NAku jadi yakin setelah tahu
Dialogue: 0,0:04:20.54,0:04:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biro Empat Musim juga sama.\NDesa Musim Semi tidak bisa dipercaya,
Dialogue: 0,0:04:24.92,0:04:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai leluhur dari semua musim\NDiriku, musim dingin,
Dialogue: 0,0:04:28.84,0:04:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang akan jadi pelindung Hinagiku dan Sakura.
Dialogue: 0,0:04:32.63,0:04:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keputusan yang bagus.
Dialogue: 0,0:04:34.43,0:04:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari kita lihat saat yang tepat.
Dialogue: 0,0:04:37.72,0:04:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:04:38.64,0:04:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben enteng sekali reaksimu.
Dialogue: 0,0:04:40.64,0:04:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku juga memikirkan\Nhal yang sama.
Dialogue: 0,0:04:43.89,0:04:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah berniat menyarankannya.\NKalau kau tidak bilang duluan,
Dialogue: 0,0:04:49.86,0:04:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi, ada yang menggangguku.
Dialogue: 0,0:04:56.95,0:04:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:04:59.16,0:05:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunga sakura, ya?
Dialogue: 0,0:05:00.95,0:05:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambarmu bagus sekali.
Dialogue: 0,0:05:05.37,0:05:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah nama pelayan musim semi.
Dialogue: 0,0:05:09.13,0:05:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka Sakura?
Dialogue: 0,0:05:11.59,0:05:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku! Nadeshiko itu nama\Nbunga musim gugur, kan?
Dialogue: 0,0:05:16.51,0:05:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Rindo juga begitu.
Dialogue: 0,0:05:19.39,0:05:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Sang Utusan Musim Semi?!
Dialogue: 0,0:05:21.97,0:05:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Nona Kayo Hinagiku.
Dialogue: 0,0:05:24.43,0:05:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga!\NSenang sekali!
Dialogue: 0,0:05:27.31,0:05:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai nama bunga!\NSama-sama!
Dialogue: 0,0:05:29.90,0:05:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini ada yang sama.
Dialogue: 0,0:05:31.82,0:05:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang membuatmu senang?
Dialogue: 0,0:05:34.32,0:05:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah bunga.\NHabisnya nama Utusan Musim Panas
Dialogue: 0,0:05:38.66,0:05:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Dingin juga sama.
Dialogue: 0,0:05:41.74,0:05:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Semi dan pelayannya
Dialogue: 0,0:05:46.54,0:05:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi ingin bertemu mereka.
Dialogue: 0,0:05:49.71,0:05:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami, Divisi Keamanan memanggil.
Dialogue: 0,0:05:52.21,0:05:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo mau pergi?
Dialogue: 0,0:05:56.38,0:05:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera kembali.\NMaaf, Nadeshiko.
Dialogue: 0,0:05:59.76,0:06:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kue tar apel!\NAkan kusisakan camilan untuk Rindo,
Dialogue: 0,0:06:04.39,0:06:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:06:06.81,0:06:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupakan diriku\Nbarang sedetik pun, ya.
Dialogue: 0,0:06:11.31,0:06:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dirimulah yang selalu\Nkupikirkan tiap detik.
Dialogue: 0,0:06:30.46,0:06:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemberitahuan ke Divisi Keamanan.
Dialogue: 0,0:06:33.00,0:06:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjauh dari Fairy.
Dialogue: 0,0:06:42.59,0:06:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bau apa ini?!
Dialogue: 0,0:06:45.31,0:06:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udon kari.
Dialogue: 0,0:06:46.77,0:06:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan makan di tempat begini, Nagatsuki!
Dialogue: 0,0:06:49.27,0:06:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?! Ini dari restoran terkenal\Nyang kupesan dari Iyo, lo!
Dialogue: 0,0:06:53.56,0:06:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu juga mau?
Dialogue: 0,0:06:55.69,0:06:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuahnya jangan sampai keciprat!
Dialogue: 0,0:07:04.07,0:07:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerjanya, Tuan Pangeran.
Dialogue: 0,0:07:07.29,0:07:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf.
Dialogue: 0,0:07:09.08,0:07:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepat kalau Kesatria, ya?
Dialogue: 0,0:07:11.71,0:07:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi kau mengintip, ya.
Dialogue: 0,0:07:13.71,0:07:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh kamu ini,\Naku cuma kerja, kok.
Dialogue: 0,0:07:22.68,0:07:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja Istana Musim Panas\Ntidak diserang.
Dialogue: 0,0:07:26.26,0:07:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pergi melihat bunga.\NPasti sekarang Dik Fairy bisa diajak
Dialogue: 0,0:07:30.64,0:07:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumpah, deh.
Dialogue: 0,0:07:32.39,0:07:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaca antipeluru di seluruh sisi memang mahal.
Dialogue: 0,0:07:34.98,0:07:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya pilihan tepat.\NTapi membangun ruang berjemur
Dialogue: 0,0:07:38.23,0:07:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah fasilitasnya lengkap,\Nmemang tidak akan makan biaya lagi.
Dialogue: 0,0:07:43.53,0:07:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena musim gugur jarang diserang penyamun,\Nanggarannya jadi terbatas.
Dialogue: 0,0:07:47.99,0:07:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi harus dilindungi secara efektif.
Dialogue: 0,0:07:51.12,0:07:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beli generator listrik sendiri juga tepat.
Dialogue: 0,0:07:54.37,0:07:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Listrik Istana Musim Panas saja kemarin padam\Nkarena tempat pembangkitnya diledakkan.
Dialogue: 0,0:08:02.22,0:08:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belakangan ini menggangguku.\NPergerakan Penyamun
Dialogue: 0,0:08:05.09,0:08:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal penyerangan Istana Musim Panas?
Dialogue: 0,0:08:07.14,0:08:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk kejadian di Tsukushi.
Dialogue: 0,0:08:09.10,0:08:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukushi?
Dialogue: 0,0:08:10.56,0:08:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar itu ulah organisasi kecil setempat.
Dialogue: 0,0:08:14.02,0:08:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang mencurigakan?
Dialogue: 0,0:08:17.11,0:08:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya adalah
Dialogue: 0,0:08:18.52,0:08:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana penyamun kecil seperti mereka\Ntahu kita datang ke Tsukushi.
Dialogue: 0,0:08:23.61,0:08:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu bukanlah pemeriksaan biasa\Ndan diputuskan tiba-tiba.
Dialogue: 0,0:08:27.53,0:08:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agendanya juga baru ditetapkan\Nsebelum kejadian.
Dialogue: 0,0:08:30.62,0:08:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu cekatan untuk bisa\Nmenyergap di bandara, ya.
Dialogue: 0,0:08:34.83,0:08:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga ada rumor soal rute baru\Npenyelundupan senjata dan sebagainya.
Dialogue: 0,0:08:39.34,0:08:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk kasus Istana Musim Panas.
Dialogue: 0,0:08:41.55,0:08:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak salah lagi kalau dari rute yang berbeda.\NMelihat skala dan maksud penyerangannya,
Dialogue: 0,0:08:46.55,0:08:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun yang ditangkap katanya\Ntidak mau buka mulut sama sekali.
Dialogue: 0,0:08:49.81,0:08:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangankan itu.
Dialogue: 0,0:08:51.56,0:08:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada yang dilarikan ke rumah sakit\Nkarena coba menghabisi diri.
Dialogue: 0,0:08:54.52,0:08:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai kewalahan.\NBadan Keamanan Negara katanya
Dialogue: 0,0:08:58.31,0:09:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal frekuensi serangan, memang berkurang\Ndibanding tahun-tahun lalu.
Dialogue: 0,0:09:01.98,0:09:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin hanya pikiranku yang berlebihan.
Dialogue: 0,0:09:06.49,0:09:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho.
Dialogue: 0,0:09:08.32,0:09:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahkan pengawal rombongan Hinagiku\Nbersamaan dengan mereka masuk Enishi.
Dialogue: 0,0:09:12.74,0:09:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi secara rahasia.
Dialogue: 0,0:09:14.83,0:09:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:09:16.96,0:09:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu disampaikan pada Nona Himedaka\Nbila ada gerak-gerik mencurigakan?
Dialogue: 0,0:09:21.67,0:09:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, ini sekadar kecurigaan,\Nbelum ada bukti yang pasti.
Dialogue: 0,0:09:25.17,0:09:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi.
Dialogue: 0,0:09:26.63,0:09:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin dia istirahat dengan benar,\Ntapi ini soal Sakura.
Dialogue: 0,0:09:30.30,0:09:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sendiri pasti sudah waspada.
Dialogue: 0,0:09:32.81,0:09:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau membuatnya\Nlebih cemas lagi.
Dialogue: 0,0:09:36.10,0:09:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebisa mungkin aku ingin perkara ini\Nkalian simpan sendiri.
Dialogue: 0,0:09:45.69,0:09:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Semi, ya?\NOh iya, Dik Fairy bilang ingin ketemu
Dialogue: 0,0:09:50.95,0:09:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi setelah satu dekade.
Dialogue: 0,0:09:54.20,0:09:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar langsung berselisih\Ndengan Biro Empat Musim
Dialogue: 0,0:09:56.75,0:09:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi perwujudannya terlambat dimulai.
Dialogue: 0,0:09:59.79,0:10:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di depan kerumunan itu, ya.\NOh, yang lari dari rencana upacara perwujudan
Dialogue: 0,0:10:06.47,0:10:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memang bodoh.\NDivisi Musim Semi Biro Empat Musim\NPengawal Utusan Musim Semi
Dialogue: 0,0:10:09.97,0:10:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?\N- Huh?
Dialogue: 0,0:10:11.64,0:10:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari mana pun,\Nyang bodoh itu pelayan musim semi.
Dialogue: 0,0:10:15.06,0:10:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan adalah tokoh publik yang\Nmendatangkan musim ke dunia.
Dialogue: 0,0:10:19.85,0:10:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jadinya kalau pengawal tidak bisa\Nmemegang kendali agar mereka patuh?
Dialogue: 0,0:10:24.27,0:10:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh...
Dialogue: 0,0:10:25.53,0:10:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang bukan main memanjakan Fairy\Nyakin bilang begitu?
Dialogue: 0,0:10:28.99,0:10:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu termasuk pekerjaan.
Dialogue: 0,0:10:33.41,0:10:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga anak kecil.
Dialogue: 0,0:10:35.12,0:10:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal dijemur matahari dan diberi makan kue
Dialogue: 0,0:10:38.08,0:10:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diajak main-main agar terhibur\Nnanti juga senang.
Dialogue: 0,0:10:40.62,0:10:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!\NMode pangeran Azami Rindo!
Dialogue: 0,0:10:45.50,0:10:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kondisi fisik dan baik tidaknya suasana hati.\NKualitas kekuatan ilahi sangat terpengaruh
Dialogue: 0,0:10:50.59,0:10:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini demi dia bisa berfungsi di kondisi prima.
Dialogue: 0,0:10:52.97,0:10:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, itu!
Dialogue: 0,0:10:54.35,0:10:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berefek pada kekuatan ilahi!\NNyatanya sudah ada data kalau fluktuasi emosi
Dialogue: 0,0:10:59.10,0:11:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tergantung suasana hatinya!\NJadi kekuatan seorang utusan itu
Dialogue: 0,0:11:02.40,0:11:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah disuruh menyanyi dan menari\NTapi utusan yang sudah enggan
Dialogue: 0,0:11:06.15,0:11:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di depan banyak penonton seperti idola.
Dialogue: 0,0:11:08.36,0:11:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas efek sebaliknya akan parah.
Dialogue: 0,0:11:10.53,0:11:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu dia korban penculikan, lo!
Dialogue: 0,0:11:13.74,0:11:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas Biro Empat Musim yang bodoh.
Dialogue: 0,0:11:16.62,0:11:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi kalau dibalik.
Dialogue: 0,0:11:18.58,0:11:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika emosinya memuncak, bisa saja\Nmengeluarkan kekuatan yang luar biasa.
Dialogue: 0,0:11:23.71,0:11:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membahas utusan musim semi,\NNona Kayo Hinagiku yang jadi buah bibir itu...
Dialogue: 0,0:11:27.59,0:11:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kasus penculikan sepuluh tahun lalu itu, ya.
Dialogue: 0,0:11:30.51,0:11:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, benar yang itu!
Dialogue: 0,0:11:32.47,0:11:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum pernah menurunkan musim\NSaat masih anak baru dan
Dialogue: 0,0:11:35.14,0:11:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia membuat pohon sakura raksasa
Dialogue: 0,0:11:37.18,0:11:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melindungi pelayannya sendiri\Ndan tuan-pelayan musim dingin!
Dialogue: 0,0:11:40.81,0:11:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu terjadi saat usianya\Ntidak beda jauh dengan Fairy kita!
Dialogue: 0,0:11:45.56,0:11:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti memakai Nadeshiko\Nsebagai perbandingan!
Dialogue: 0,0:11:48.23,0:11:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}merendahkan Dik Fairy.\NTidak, tidak, aku tidak bermaksud
Dialogue: 0,0:11:52.61,0:11:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja Nona Hinagiku itu beda level.
Dialogue: 0,0:11:55.87,0:11:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi.
Dialogue: 0,0:11:57.03,0:12:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi cuma bahasan kita di sini.\NIni tidak ada di catatan resmi,
Dialogue: 0,0:12:00.87,0:12:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}markas penyamun yang menculik dirinya.\NJuga ada rumor dia kabur menghancurkan
Dialogue: 0,0:12:06.75,0:12:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaget dia.
Dialogue: 0,0:12:08.88,0:12:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kaget.
Dialogue: 0,0:12:09.88,0:12:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang hebat, ya.
Dialogue: 0,0:12:13.72,0:12:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya bisa kabur lebih cepat\Nkalau punya kekuatan seperti itu?
Dialogue: 0,0:12:23.60,0:12:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa-apaan—
Dialogue: 0,0:12:24.64,0:12:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini pasti!
Dialogue: 0,0:12:26.35,0:12:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe yang bilang, "Harusnya bisa melawan"\Nke korban pelecehan seksual!
Dialogue: 0,0:12:31.53,0:12:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin begitu!
Dialogue: 0,0:12:33.11,0:12:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, jangan dekat-dekat, dong...
Dialogue: 0,0:12:35.45,0:12:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar berengsek tanpa hati nurani!
Dialogue: 0,0:12:38.62,0:12:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat, itu gadis berumur enam tahun, lo.
Dialogue: 0,0:12:41.75,0:12:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diancam penyamun\Ntentu akan menurut.
Dialogue: 0,0:12:44.62,0:12:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kalau tidak menurut, teman-temanku\Nakan kami serang lagi," misalnya.
Dialogue: 0,0:12:48.38,0:12:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:12:49.80,0:12:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus lebih belajar lagi.
Dialogue: 0,0:12:52.51,0:12:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diculik dan disekap.\NKondisi psikis dalam kondisi tertentu.
Dialogue: 0,0:12:56.43,0:12:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuci otak, trauma.
Dialogue: 0,0:12:58.60,0:13:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuat luka mendalam di hati.\NAda kalanya syok dari kejadian
Dialogue: 0,0:13:03.98,0:13:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan orang-orang di sekitar juga.
Dialogue: 0,0:13:06.31,0:13:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei dan Kakanda Itecho.
Dialogue: 0,0:13:10.94,0:13:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan yang seperti apa?\NMenurutmu akan senang
Dialogue: 0,0:13:16.86,0:13:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk musim dingin.\NTidak perlu memberi oleh-oleh
Dialogue: 0,0:13:19.28,0:13:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertemu mereka sama sekali.\NTidak ada agenda untuk
Dialogue: 0,0:13:26.21,0:13:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku tahu kalau bisa bertemu\Nsaat Rapat Empat Musim.
Dialogue: 0,0:13:31.46,0:13:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:13:32.63,0:13:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk saat Rapat Empat Musim.
Dialogue: 0,0:13:34.92,0:13:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura tidak bisa memaafkan mereka.
Dialogue: 0,0:13:37.38,0:13:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak ingin mempertemukan mereka\Ndengan Nona Hinagiku!
Dialogue: 0,0:13:39.85,0:13:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apalagi mengajak bicara.\NTidak saya biarkan mendekati Nona Hinagiku,
Dialogue: 0,0:13:49.23,0:13:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Sakura memang...
Dialogue: 0,0:13:53.57,0:13:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mau bertemu?
Dialogue: 0,0:13:59.66,0:14:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari bergegas.
Dialogue: 0,0:14:01.24,0:14:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti ketinggalan pesawat.
Dialogue: 0,0:14:10.13,0:14:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih banyak.
Dialogue: 0,0:14:12.75,0:14:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih kawalannya!
Dialogue: 0,0:14:14.50,0:14:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih dari itu.\NTapi tidak perlu ikut campur
Dialogue: 0,0:14:17.38,0:14:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bilang begitu, beri tahu saja\Nbila ada yang bisa kami bantu.
Dialogue: 0,0:14:22.39,0:14:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho sendiri mengkhawatirkan itu.
Dialogue: 0,0:14:25.18,0:14:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:14:26.14,0:14:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, bukan!
Dialogue: 0,0:14:27.68,0:14:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlalu keras berusaha.\NKhawatir kalau Nona Himedaka
Dialogue: 0,0:14:30.35,0:14:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa jangan memaksakan diri begitu.
Dialogue: 0,0:14:36.03,0:14:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:14:38.28,0:14:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakanda Itecho pasti juga ingin bertemu.
Dialogue: 0,0:14:45.91,0:14:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku tahu kalau sudah banyak\Nyang terjadi pada Hinagiku.
Dialogue: 0,0:14:54.17,0:14:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau bertemu, pasti...
Dialogue: 0,0:14:59.05,0:15:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut.
Dialogue: 0,0:15:01.47,0:15:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan jadi bagaimana jika bertemu.
Dialogue: 0,0:15:05.76,0:15:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti diriku.
Dialogue: 0,0:15:11.69,0:15:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho.
Dialogue: 0,0:15:14.94,0:15:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:15:16.15,0:15:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana pengamanan Rapat Empat Musim.
Dialogue: 0,0:15:18.23,0:15:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal konfirmasi darimu.
Dialogue: 0,0:15:21.11,0:15:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski acara itu sudah jadi tradisi,
Dialogue: 0,0:15:23.53,0:15:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi apa mengumpulkan\Nsemua utusan itu ada gunanya?
Dialogue: 0,0:15:27.29,0:15:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memanjatkan doa ke dewa-dewa musim\Nkenapa tidak di tempat masing-masing saja.
Dialogue: 0,0:15:31.87,0:15:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, yang jadi masalah adalah\Nperwujudan musim gugur tahun ini.
Dialogue: 0,0:15:36.09,0:15:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena Nadeshiko demam.\NTahun kemarin cukup merepotkan
Dialogue: 0,0:15:41.34,0:15:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibiarkan saja nanti juga sehat lagi.
Dialogue: 0,0:15:43.80,0:15:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hal yang biasa.
Dialogue: 0,0:15:47.22,0:15:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko.
Dialogue: 0,0:15:50.48,0:15:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:15:52.02,0:15:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya minum dulu sedikit.
Dialogue: 0,0:15:54.60,0:15:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa makan es?
Dialogue: 0,0:15:56.73,0:15:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mau sesuatu?
Dialogue: 0,0:16:05.45,0:16:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah di dekatku.
Dialogue: 0,0:16:12.08,0:16:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:16:16.84,0:16:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada di dekatmu.
Dialogue: 0,0:16:23.80,0:16:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo masih lama tidak, ya?
Dialogue: 0,0:16:27.05,0:16:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin cepat-cepat makan bersama dia.
Dialogue: 0,0:16:30.93,0:16:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang...
Dialogue: 0,0:16:32.43,0:16:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus kembali mengasuh anak kecil lagi.
Dialogue: 0,0:16:33.39,0:16:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih...
Dialogue: 0,0:16:35.44,0:16:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengajari dia, lalu makan malam...\NSetelah ini ada les privat,
Dialogue: 0,0:16:40.86,0:16:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga dimandikan.
Dialogue: 0,0:16:42.86,0:16:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}utusan dan pengawal mudah untuk\NPadahal di makalah juga tertulis kalau
Dialogue: 0,0:16:46.70,0:16:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hubungan tuan dan pelayan mereka.\Nsaling ketergantungan saat menjalin
Dialogue: 0,0:16:52.25,0:16:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia tidak sadar, ya?
Dialogue: 0,0:17:00.84,0:17:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akhirnya sampai di Enishi.
Dialogue: 0,0:17:05.84,0:17:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memanggil musim semi,\NTuan Rosei tentu akan sadar
Dialogue: 0,0:17:10.22,0:17:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau Hinagiku datang.
Dialogue: 0,0:17:20.40,0:17:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi soal pertemuan atau jadi pelindung.
Dialogue: 0,0:17:24.24,0:17:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku itu hanya dalih semata.
Dialogue: 0,0:17:27.28,0:17:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau sendiri aslinya\Nhanya ingin bertemu Sakura?
Dialogue: 0,0:17:32.99,0:17:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang ingin membantu mereka.
Dialogue: 0,0:17:35.66,0:17:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, apa pun yang terjadi\Nakulah yang akan melindungi.
Dialogue: 0,0:17:39.88,0:17:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau sekadar itu, cukup mengawasi saja\Ndari jauh seperti selama ini.
Dialogue: 0,0:17:45.92,0:17:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya lebih baik kalau dibiarkan saja.\NSaat memikirkan rombongan Hinagiku,
Dialogue: 0,0:17:51.05,0:17:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu hanya egoku semata.\NRepot-repot mengadakan pertemuan
Dialogue: 0,0:17:57.06,0:17:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi.
Dialogue: 0,0:17:58.90,0:18:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Sakura.
Dialogue: 0,0:18:02.19,0:18:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepuluh tahun,\Naku terus menunggu dan terus mencari.
Dialogue: 0,0:18:06.82,0:18:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ingin bertemu\Nterus saja semakin besar.
Dialogue: 0,0:18:13.74,0:18:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalau itu salahku.
Dialogue: 0,0:18:16.45,0:18:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga tahu kalau tidak boleh bertemu\Natau tidak akan pernah bisa dimaafkan.
Dialogue: 0,0:18:21.50,0:18:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu.
Dialogue: 0,0:18:23.88,0:18:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini rasanya jadi penuh.
Dialogue: 0,0:18:28.13,0:18:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang jadi terasa sesak.
Dialogue: 0,0:18:36.18,0:18:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ingin bertemu, rasanya.\N- Aku ingin bertemu dengannya.
Dialogue: 0,0:18:42.94,0:18:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu ke penjaga ruang berjemur.
Dialogue: 0,0:18:44.98,0:18:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kembali ke sana.
Dialogue: 0,0:19:41.33,0:19:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:19:43.88,0:19:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu utusan.
Dialogue: 0,0:19:48.25,0:19:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mati, ya?
Dialogue: 0,0:20:16.62,0:20:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bawa pulang dia, Mikami.
Dialogue: 0,0:20:19.20,0:20:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:20:20.79,0:20:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka anak ini.
Dialogue: 0,0:20:29.00,0:20:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:20:30.76,0:20:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya mau dibunuh?
Dialogue: 0,0:20:32.51,0:20:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bawa pulang.
Dialogue: 0,0:20:34.51,0:20:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda ingin digigit anjing piaraan lagi?
Dialogue: 0,0:20:38.43,0:20:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejadian itu cukup sekali saja terjadi.
Dialogue: 0,0:20:40.93,0:20:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu rencananya...
Dialogue: 0,0:20:45.31,0:20:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti anak itu saja.
Dialogue: 0,0:20:48.36,0:20:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kayo! Nona Himedaka!
Dialogue: 0,0:20:55.36,0:20:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istana Musim Gugur?!
Dialogue: 0,0:20:58.87,0:21:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo! Rindo!
Dialogue: 0,0:21:04.25,0:21:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupakan diriku\Nbarang sedetik pun, ya.
Dialogue: 0,0:21:11.38,0:21:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kusisakan camilan untuk Rindo,\Nkue tar apel!
Dialogue: 0,0:21:22.64,0:21:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo adalah pangeranku.
Dialogue: 0,0:21:26.64,0:21:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawal utusan musim gugur,\NAzami Rindo.
Dialogue: 0,0:21:32.07,0:21:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan ke depan.
Dialogue: 0,0:21:38.61,0:21:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan raga ini dan bersumpah\Nakan melindungimu.
Dialogue: 0,0:21:47.00,0:21:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melindungi dari apa?
Dialogue: 0,0:21:55.97,0:21:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Na...
Dialogue: 0,0:22:02.43,0:22:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari segala-galanya.
Dialogue: 0,0:22:06.27,0:22:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua kedipan mata♪
Dialogue: 0,0:22:08.85,0:22:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko...
Dialogue: 0,0:22:09.44,0:22:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tetap tak pernah bisa menjadi dirimu♪
Dialogue: 0,0:22:10.81,0:22:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:22:12.61,0:22:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terus hidup, terus berjumpa♪
Dialogue: 0,0:22:12.73,0:22:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko...
Dialogue: 0,0:22:14.40,0:22:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo.
Dialogue: 0,0:22:14.57,0:22:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga cahaya musim semi♪
Dialogue: 0,0:22:16.32,0:22:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko...
Dialogue: 0,0:22:18.28,0:22:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:22:18.61,0:22:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyinari air mata ini♪
Dialogue: 0,0:22:20.03,0:22:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko!
Dialogue: 0,0:22:20.82,0:22:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}“Apa kamu sudah lelah?"♪
Dialogue: 0,0:22:21.41,0:22:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo...
Dialogue: 0,0:22:22.91,0:22:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih begitu banyak hal yang belum kutahu♪
Dialogue: 0,0:22:26.50,0:22:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu banyak untuk sekadar menunggu♪
Dialogue: 0,0:22:28.12,0:22:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaulah...
Dialogue: 0,0:22:30.00,0:22:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musim gugurku.
Dialogue: 0,0:22:30.58,0:22:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari esok♪
Dialogue: 0,0:22:33.13,0:22:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak pernah datang sesuai yang diharapkan♪
Dialogue: 0,0:22:37.22,0:22:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin, kita hanya saling menyambung napas♪
Dialogue: 0,0:22:41.80,0:22:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di seberang sana♪
Dialogue: 0,0:22:44.14,0:22:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang akan ku ketahui♪
Dialogue: 0,0:22:46.81,0:22:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mempermasalahkannya♪
Dialogue: 0,0:22:49.10,0:22:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku tetap menggenggammu♪
Dialogue: 0,0:22:51.06,0:22:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti hari itu♪
Dialogue: 0,0:23:06.58,0:23:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim yang terus berputar♪
Dialogue: 0,0:23:09.21,0:23:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa tau di mana akhirnya♪
Dialogue: 0,0:23:13.13,0:23:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari musim yang terus berputar♪
Dialogue: 0,0:23:17.84,0:23:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di seberang sana♪
Dialogue: 0,0:23:20.09,0:23:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang akan kuketahui♪
Dialogue: 0,0:23:22.89,0:23:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mempermasalahkannya♪
Dialogue: 0,0:23:25.18,0:23:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku tetap menggenggammu♪
Dialogue: 0,0:23:27.10,0:23:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti hari itu♪
