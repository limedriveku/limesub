Dialogue: 0,0:00:51.70,0:01:00.46,tanda,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:09:01.37,0:09:02.87,tanda,,0000,0000,0000,,EPISODE EMPAT: TENANGNYA PAGI
Dialogue: 0,0:10:52.76,0:10:53.94,tanda,,0000,0000,0000,,BADAN KEAMANAN NASIONAL CABANG IYO
Dialogue: 0,0:23:39.94,0:23:44.94,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA: HANYA BERDUA
Dialogue: 0,0:01:38.66,0:01:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, tolong menjauh!
Dialogue: 0,0:01:50.26,0:01:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:01:51.34,0:01:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri.
Dialogue: 0,0:01:53.34,0:01:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan keluar dari kamar.
Dialogue: 0,0:02:03.39,0:02:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tolong bantu juga, ya.
Dialogue: 0,0:02:16.04,0:02:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang dalam!
Dialogue: 0,0:02:30.46,0:02:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam juga ada pelindung?
Dialogue: 0,0:02:40.68,0:02:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ragu!
Dialogue: 0,0:02:41.39,0:02:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau akan jadi lemah.
Dialogue: 0,0:02:46.19,0:02:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:02:47.61,0:02:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahankan amarah!
Dialogue: 0,0:02:48.69,0:02:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau tidak akan menjadi bilah!
Dialogue: 0,0:02:53.57,0:02:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisi dia!
Dialogue: 0,0:02:54.20,0:02:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak punya kebencian...
Dialogue: 0,0:02:55.95,0:02:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak!
Dialogue: 0,0:03:02.33,0:03:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:03:03.70,0:03:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dilindungi!
Dialogue: 0,0:03:39.73,0:03:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih Ruri—
Dialogue: 0,0:03:50.51,0:03:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat...
Dialogue: 0,0:03:51.42,0:03:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berhenti, berhenti!
Dialogue: 0,0:03:53.80,0:03:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:04:03.26,0:04:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berani kemari kalau tidak mau mati.
Dialogue: 0,0:04:08.77,0:04:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kemari kalau tidak mau mati!
Dialogue: 0,0:04:12.63,0:04:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:04:16.94,0:04:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?
Dialogue: 0,0:04:18.11,0:04:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:04:19.07,0:04:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:04:25.15,0:04:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak apa-apa.
Dialogue: 0,0:04:26.75,0:04:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:04:28.75,0:04:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah.
Dialogue: 0,0:04:30.61,0:04:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ini.
Dialogue: 0,0:04:32.34,0:04:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No-Nona Hinagiku?
Dialogue: 0,0:04:33.67,0:04:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:04:35.59,0:04:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau kamu terluka.
Dialogue: 0,0:04:39.47,0:04:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, semua hanya cipratan darah.
Dialogue: 0,0:04:43.93,0:04:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu gemetar...
Dialogue: 0,0:04:51.23,0:04:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Sakura.
Dialogue: 0,0:04:54.59,0:04:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi aku...
Dialogue: 0,0:04:58.15,0:05:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, aku sudah berbeda\Ndari sepuluh tahun lalu.
Dialogue: 0,0:05:05.33,0:05:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku akan berusaha\Nagar bisa melindungimu.
Dialogue: 0,0:05:09.21,0:05:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kumohon katakan,\N"Kerja bagus sudah melindungiku."
Dialogue: 0,0:05:14.54,0:05:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu usahaku akan terbayar.
Dialogue: 0,0:05:22.51,0:05:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:24.99,0:05:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat hebat.
Dialogue: 0,0:05:29.11,0:05:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah melindungiku.
Dialogue: 0,0:05:35.01,0:05:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Nona Hinagiku.
Dialogue: 0,0:05:38.29,0:05:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kayo! Nona Himedaka!
Dialogue: 0,0:05:40.99,0:05:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baik-baik saja?
Dialogue: 0,0:05:43.70,0:05:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegawai musim semi biro empat musim.
Dialogue: 0,0:05:46.08,0:05:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalur belakang bagaimana?
Dialogue: 0,0:05:47.16,0:05:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bersiaga, kami membalas\Nserangan Penyamun.
Dialogue: 0,0:05:49.62,0:05:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa gagal dihabisi\Ndan berhasil masuk ke Istana Musim Panas.
Dialogue: 0,0:05:53.58,0:05:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mohon maaf.
Dialogue: 0,0:05:55.29,0:05:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup alasannya.
Dialogue: 0,0:05:56.62,0:05:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri laporannya.
Dialogue: 0,0:05:57.75,0:05:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada korban jiwa atau luka.
Dialogue: 0,0:05:59.71,0:06:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Listrik di sekitar sedang padam,\Nsinyal juga tidak terhubung.
Dialogue: 0,0:06:03.63,0:06:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, kami bekerja sama dengan\Npengawal Desa Musim Dingin
Dialogue: 0,0:06:07.26,0:06:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memahami situasi\Ndan mengambil tindakan.
Dialogue: 0,0:06:10.98,0:06:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Musim Dingin?
Dialogue: 0,0:06:13.81,0:06:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:06:15.44,0:06:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat penyerangan, mereka datang membantu.
Dialogue: 0,0:06:18.61,0:06:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta mendapat perintah dari tuannya
Dialogue: 0,0:06:21.03,0:06:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melindungi kalian diam-diam.
Dialogue: 0,0:06:26.03,0:06:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya aku sendiri tidak cukup?
Dialogue: 0,0:06:28.24,0:06:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mau menebus dosa?
Dialogue: 0,0:06:31.12,0:06:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho!
Dialogue: 0,0:06:34.79,0:06:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih!
Dialogue: 0,0:06:36.39,0:06:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manfaatkan saja apa yang tersedia.
Dialogue: 0,0:06:38.82,0:06:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya biar kami yang urus,\Nsilakan tunggu di dalam.
Dialogue: 0,0:06:47.59,0:06:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tidak apa-apa.
Dialogue: 0,0:06:55.56,0:06:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang jangan maju!
Dialogue: 0,0:06:59.27,0:07:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, jangan-jangan itu...
Dialogue: 0,0:07:03.83,0:07:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:07:06.50,0:07:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Utusan Musim Panas?
Dialogue: 0,0:07:12.35,0:07:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil aku sangat menyayangi Ayame.
Dialogue: 0,0:07:16.04,0:07:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame! Ayame!
Dialogue: 0,0:07:19.00,0:07:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ruri?\N- Ayame! Ayame, ayo bangun!
Dialogue: 0,0:07:20.75,0:07:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berhenti membangunkanku seperti itu.\N- Ayame! Ayame, ayo bangun!
Dialogue: 0,0:07:25.07,0:07:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kakakku yang tercinta.
Dialogue: 0,0:07:30.25,0:07:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kembaran sama aku!
Dialogue: 0,0:07:32.06,0:07:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kembaran sama kamu!
Dialogue: 0,0:07:33.83,0:07:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi?
Dialogue: 0,0:07:36.47,0:07:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:07:37.94,0:07:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada keluarga yang bahagia.
Dialogue: 0,0:07:40.44,0:07:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira wajar kalau itu terus berlanjut.
Dialogue: 0,0:07:44.43,0:07:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:07:47.86,0:07:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:07:49.24,0:07:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit! Sakit!
Dialogue: 0,0:07:51.16,0:07:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali, Ayame!
Dialogue: 0,0:07:55.43,0:07:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu...
Dialogue: 0,0:07:57.00,0:07:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari saat dipilih oleh sang dewa.
Dialogue: 0,0:07:59.58,0:08:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya pun berubah.
Dialogue: 0,0:08:04.72,0:08:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa... harus aku?
Dialogue: 0,0:08:09.39,0:08:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau jadi dewa!
Dialogue: 0,0:08:12.35,0:08:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri, biar aku yang jadi pengawalmu.
Dialogue: 0,0:08:20.57,0:08:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau begitu, kamu nanti...
Dialogue: 0,0:08:23.15,0:08:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri, tidak apa-apa.
Dialogue: 0,0:08:25.57,0:08:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang ingin begitu.
Dialogue: 0,0:08:28.82,0:08:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Maaf!
Dialogue: 0,0:08:32.99,0:08:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu punya kehidupan sendiri.
Dialogue: 0,0:08:37.13,0:08:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan ada kehidupan\Nyang lebih indah lagi.
Dialogue: 0,0:08:41.03,0:08:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu... aku sungguh...
Dialogue: 0,0:08:44.42,0:08:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh minta maaf!
Dialogue: 0,0:08:47.88,0:08:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku yang tercinta.
Dialogue: 0,0:08:50.13,0:08:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang paling mengerti diriku.
Dialogue: 0,0:08:54.93,0:08:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga yang paling mengerti tentangnya.
Dialogue: 0,0:08:59.39,0:09:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal...
Dialogue: 0,0:09:01.37,0:09:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kukira begitu.
Dialogue: 0,0:09:03.40,0:09:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ulangi.
Dialogue: 0,0:09:04.73,0:09:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru saja terjadi ledakan yang mengakibatkan\Nkebakaran di Pembangkit Listrik Yaga.
Dialogue: 0,0:09:08.74,0:09:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyebabnya tidak diketahui.
Dialogue: 0,0:09:10.24,0:09:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan butuh waktu
Dialogue: 0,0:09:11.66,0:09:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- hingga aliran listrik pulih kembali.\N- Pergi dari sini
Dialogue: 0,0:09:13.53,0:09:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau bertahan sampai pagi.
Dialogue: 0,0:09:15.70,0:09:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kita putuskan antara itu.
Dialogue: 0,0:09:17.43,0:09:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri, situasi sekitar bagaimana?
Dialogue: 0,0:09:19.33,0:09:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berjuang, ya.
Dialogue: 0,0:09:20.29,0:09:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu, kan?\NAyo jawab!
Dialogue: 0,0:09:24.29,0:09:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan merajuk di saat begini,\Nayo cepat jawab!
Dialogue: 0,0:09:26.80,0:09:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak merajuk, kok!
Dialogue: 0,0:09:28.01,0:09:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah merajuk terus\Nselama tiga bulan ini!
Dialogue: 0,0:09:32.65,0:09:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya...
Dialogue: 0,0:09:34.68,0:09:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak diberi tahu.
Dialogue: 0,0:09:36.90,0:09:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:37.93,0:09:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak diberi tahu kalau kamu punya pacar!
Dialogue: 0,0:09:40.43,0:09:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:09:41.19,0:09:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He?
Dialogue: 0,0:09:47.03,0:09:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, itu apa harus sek—
Dialogue: 0,0:09:49.13,0:09:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buatku itu masalah besar!
Dialogue: 0,0:09:51.45,0:09:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas marah, dong,\Nkalau tiba-tiba bilang mau menikah!
Dialogue: 0,0:09:54.28,0:09:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan ketemunya?
Dialogue: 0,0:09:55.41,0:09:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa disembunyikan?
Dialogue: 0,0:09:56.83,0:09:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ada rahasia sama saudara kembar!
Dialogue: 0,0:09:58.62,0:10:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku selalu kasih laporan!
Dialogue: 0,0:10:00.91,0:10:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu—
Dialogue: 0,0:10:02.16,0:10:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, soal itu jelas-jelas\Nbukan buat dibahas sekarang!
Dialogue: 0,0:10:05.13,0:10:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terus mau kapan?\N- Ja-Jangan bertengkar!
Dialogue: 0,0:10:06.92,0:10:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yang jelas bukan sekarang!\N- Ja-Jangan bertengkar!
Dialogue: 0,0:10:08.46,0:10:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terus kapan?\N- Semua harus rukun...
Dialogue: 0,0:10:09.80,0:10:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Paham situasi, dong!\N- Semua harus rukun...
Dialogue: 0,0:10:10.92,0:10:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mau kapan?\N- Semua harus rukun...
Dialogue: 0,0:10:13.09,0:10:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu situasinya.
Dialogue: 0,0:10:18.51,0:10:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini.
Dialogue: 0,0:10:28.01,0:10:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak terlihat ada Penyamun lain,
Dialogue: 0,0:10:30.07,0:10:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada mobil hitam terparkir dalam radius\Nseratus meter sejak sejam lalu.
Dialogue: 0,0:10:35.10,0:10:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waspadalah.
Dialogue: 0,0:10:36.57,0:10:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja sekarang banyak kecelakaan\Nlalu lintas di jalan karena listrik padam.
Dialogue: 0,0:10:40.91,0:10:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan keluar sembarangan.
Dialogue: 0,0:10:42.58,0:10:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu kemampuan utusan musim panas?
Dialogue: 0,0:10:46.08,0:10:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengendali Hayat.
Dialogue: 0,0:10:47.88,0:10:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, mereka akan memberi tahu.
Dialogue: 0,0:10:50.60,0:10:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka temanku.
Dialogue: 0,0:10:53.94,0:10:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada laporan kalau tidak ada\Npergerakan aneh di sekitar sini.
Dialogue: 0,0:10:57.51,0:11:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil hitamnya juga sudah pergi.
Dialogue: 0,0:11:03.39,0:11:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk jaga-jaga, sudah dikejar\Ndengan kemampuan Ruri.
Dialogue: 0,0:11:06.65,0:11:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjagaan juga akan diteruskan.
Dialogue: 0,0:11:08.59,0:11:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa tidak jadi masalah\Nberangkat setelah fajar.
Dialogue: 0,0:11:11.80,0:11:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:11:14.19,0:11:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku permisi.
Dialogue: 0,0:11:14.91,0:11:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf...
Dialogue: 0,0:11:16.53,0:11:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pertunanganmu\Ndirahasiakan dari Nona Ruri?
Dialogue: 0,0:11:21.62,0:11:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa bilang.
Dialogue: 0,0:11:23.19,0:11:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena jelas akan marah kalau diberi tahu.
Dialogue: 0,0:11:25.61,0:11:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paling tahu dia dibanding siapa pun.
Dialogue: 0,0:11:28.46,0:11:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Nona Ruri juga merasa begitu?
Dialogue: 0,0:11:33.84,0:11:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa tidak kedinginan?
Dialogue: 0,0:11:37.51,0:11:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku ini utusan musim panas.
Dialogue: 0,0:11:40.30,0:11:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, apa kamu tidak kedinginan?
Dialogue: 0,0:11:43.29,0:11:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini perlu kutaruh di pangkuanmu?
Dialogue: 0,0:11:47.00,0:11:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Nona Himedaka.
Dialogue: 0,0:11:49.32,0:11:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:11:52.91,0:11:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa, ya?
Dialogue: 0,0:11:56.09,0:12:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku ini pertama kalinya\Naku bertemu denganmu.
Dialogue: 0,0:12:01.13,0:12:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang kutemui di dapur itu\Nbukan Nona Ayame tapi kamu, kan?
Dialogue: 0,0:12:06.59,0:12:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:12:07.92,0:12:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak berniat membohongimu.
Dialogue: 0,0:12:10.83,0:12:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku penasaran\Npelayan musim semi itu seperti apa.
Dialogue: 0,0:12:13.68,0:12:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:12:14.60,0:12:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip sama Ayame, kan?
Dialogue: 0,0:12:16.17,0:12:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang disebut bakat terlatih!
Dialogue: 0,0:12:18.43,0:12:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang seperti itu tidak boleh dijadikan bakat.
Dialogue: 0,0:12:20.93,0:12:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya kalau tidak begitu,\Nmana bisa menikmati hiburan!
Dialogue: 0,0:12:24.81,0:12:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan itu mau apa-apa pasti diawasi, lo!
Dialogue: 0,0:12:28.02,0:12:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sedang umurnya!
Dialogue: 0,0:12:29.56,0:12:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sedang membahas apa?
Dialogue: 0,0:12:32.31,0:12:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pura-pura jadi Ayame\Nuntuk mengerjai Nona Himedaka.
Dialogue: 0,0:12:35.89,0:12:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengerjai Sakura?
Dialogue: 0,0:12:37.24,0:12:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pura-pura jadi Ayame karena penasaran\Npelayan musim semi orangnya bagaimana.
Dialogue: 0,0:12:42.69,0:12:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyebalkan, niatnya mau kujaili.
Dialogue: 0,0:12:45.65,0:12:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura anak baik, kok!
Dialogue: 0,0:12:48.58,0:12:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No-Nona Hinagiku!
Dialogue: 0,0:12:50.21,0:12:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi anak baik khusus untukmu,\Ndengan orang lain tidak begitu—
Dialogue: 0,0:12:55.33,0:12:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi senang rasanya.
Dialogue: 0,0:12:56.59,0:13:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, menurutku dia\Nmemang pelayan yang baik.
Dialogue: 0,0:13:01.65,0:13:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iri rasanya.
Dialogue: 0,0:13:03.19,0:13:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia kesatria bagimu.
Dialogue: 0,0:13:07.14,0:13:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti sangat sedih
Dialogue: 0,0:13:12.65,0:13:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena tidak diberi tahu\Nsoal pernikahan Kak Ayame, ya.
Dialogue: 0,0:13:19.78,0:13:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena selalu terlihat kesepian\Nsaat menatap Kak Ayame.
Dialogue: 0,0:13:26.93,0:13:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menganggap\Ndiriku nomor satu di hati Kakak.
Dialogue: 0,0:13:31.08,0:13:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bagiku, Kakak adalah nomor satu!
Dialogue: 0,0:13:34.21,0:13:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ruri...
Dialogue: 0,0:13:35.25,0:13:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah menurut kalian itu jahat?
Dialogue: 0,0:13:37.47,0:13:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah mengatakan\Nsemuanya soal tunangan.
Dialogue: 0,0:13:42.28,0:13:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, jadi kamu sudah punya tunangan?
Dialogue: 0,0:13:45.89,0:13:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-Ya begitulah.
Dialogue: 0,0:13:48.33,0:13:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kesan pertamanya parah banget.
Dialogue: 0,0:13:51.10,0:13:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang Kakak lemah,\Njadi kutendang pakai rusa!
Dialogue: 0,0:13:54.61,0:13:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya bisa mati\Nkalau ditendang sembarangan?
Dialogue: 0,0:13:56.86,0:14:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya dia mengatai Kakak,\Nmana mungkin kubiarkan.
Dialogue: 0,0:14:01.86,0:14:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Utusan Musim Panas.
Dialogue: 0,0:14:04.47,0:14:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat menyayangi Kak Ayame, ya?
Dialogue: 0,0:14:10.38,0:14:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:13.00,0:14:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tetap tidak mau\Nberbaikan dengan Kak Ayame?
Dialogue: 0,0:14:19.51,0:14:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pernah mengurung diri di kamar.
Dialogue: 0,0:14:25.40,0:14:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedikit dengar dari Nona Himedaka.
Dialogue: 0,0:14:28.26,0:14:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan yang lain adalah utusan,\Ntapi tetap saja manusia.
Dialogue: 0,0:14:34.00,0:14:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang menyakitkan,\Ntentu ingin lari.
Dialogue: 0,0:14:37.81,0:14:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:38.54,0:14:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, lari dan menolak itu berbeda.
Dialogue: 0,0:14:43.89,0:14:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, akan terjadi\Nhal yang tidak baik.
Dialogue: 0,0:14:48.45,0:14:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi khawatir padamu.
Dialogue: 0,0:14:54.67,0:14:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku.
Dialogue: 0,0:15:00.11,0:15:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah diserang Penyamun\Ndan tidak ditolong oleh desa.
Dialogue: 0,0:15:09.39,0:15:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibuang.\NItu begitu berat rasanya.
Dialogue: 0,0:15:14.25,0:15:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian mengabaikannya sebagai balasan.
Dialogue: 0,0:15:17.56,0:15:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tidak mau memberi musim semi.
Dialogue: 0,0:15:21.01,0:15:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajar, aku juga akan begitu.
Dialogue: 0,0:15:25.36,0:15:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu tidak boleh.
Dialogue: 0,0:15:28.74,0:15:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada musim,\Nrakyat akan kesusahan.
Dialogue: 0,0:15:33.00,0:15:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bumi, sawah, dan ladang\Ntidak bisa tumbuh.
Dialogue: 0,0:15:36.71,0:15:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, karena aku tidak menurut.
Dialogue: 0,0:15:41.00,0:15:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku, malah Sakura yang terluka.
Dialogue: 0,0:15:45.63,0:15:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:47.13,0:15:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Sakura sudah setia\Ntidak meninggalkanku.
Dialogue: 0,0:15:54.57,0:15:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena aku terlalu lama berkeras hati,
Dialogue: 0,0:15:59.02,0:16:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura jadi dianggap kurang becus.
Dialogue: 0,0:16:03.73,0:16:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tidak mau memanggil musim semi.
Dialogue: 0,0:16:08.11,0:16:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sakura jadi diusir dari desa.\N- Sakura!
Dialogue: 0,0:16:10.31,0:16:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sakura jadi diusir dari desa.\N- Jangan, Sakura!
Dialogue: 0,0:16:12.87,0:16:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:16:15.33,0:16:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja dia.
Dialogue: 0,0:16:16.86,0:16:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak diperlukan lagi\Nkalau tidak bisa membantu perwujudan.
Dialogue: 0,0:16:20.04,0:16:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah disiapkan pelayan pengganti untukmu.
Dialogue: 0,0:16:23.46,0:16:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:16:25.05,0:16:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bersama Sakura!
Dialogue: 0,0:16:28.34,0:16:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, anak itu sudah...
Dialogue: 0,0:16:31.09,0:16:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak diperlukan lagi.
Dialogue: 0,0:16:32.85,0:16:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:16:33.56,0:16:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:16:34.68,0:16:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa saja hentikan dia!
Dialogue: 0,0:16:37.77,0:16:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Sakura!
Dialogue: 0,0:16:39.77,0:16:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah jahat!
Dialogue: 0,0:16:45.78,0:16:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka! Buka!
Dialogue: 0,0:16:49.90,0:16:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, aku tidak butuh apa-apa,\Nasal bisa di samping Nona Hinagiku.
Dialogue: 0,0:16:56.20,0:16:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di malam kabut rembulan...
Dialogue: 0,0:16:59.33,0:17:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersembunyi tajam bilah pedang...
Dialogue: 0,0:17:07.49,0:17:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam gulita perlahan...
Dialogue: 0,0:17:10.68,0:17:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- berkabut dan menghilang...\N- Nona Hinagiku?
Dialogue: 0,0:17:14.30,0:17:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?
Dialogue: 0,0:17:15.43,0:17:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini!
Dialogue: 0,0:17:16.56,0:17:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku ada di sini!\N- Tahanlah rindu...
Dialogue: 0,0:17:18.18,0:17:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nona Hinagiku!\N- Tahanlah rindu...
Dialogue: 0,0:17:23.44,0:17:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pesta musim semi begitu semarak...\N- Perwujudan musim semi...
Dialogue: 0,0:17:29.44,0:17:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:17:34.50,0:17:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena terjadi hal seperti itu.
Dialogue: 0,0:17:38.62,0:17:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun berubah.
Dialogue: 0,0:17:42.37,0:17:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah berubah, sekarang jadi\Nlebih dekat dengan Sakura.
Dialogue: 0,0:17:50.38,0:17:54.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bagimu
Dialogue: 0,0:17:54.43,0:18:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gadis yang paling disayangi di dunia\Nadalah kakakmu.
Dialogue: 0,0:18:00.14,0:18:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak boleh berbuat jahat.
Dialogue: 0,0:18:05.27,0:18:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia ini, ada perpisahan\Nyang benar-benar abadi.
Dialogue: 0,0:18:11.27,0:18:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar tidak menyesal belakangan,
Dialogue: 0,0:18:14.74,0:18:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perlakukan orang yang kamu cintai\Ndengan kasih sayang.
Dialogue: 0,0:18:24.89,0:18:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa pakai ponsel.
Dialogue: 0,0:18:27.63,0:18:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh?
Dialogue: 0,0:18:28.38,0:18:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang mempelajarinya.
Dialogue: 0,0:18:30.80,0:18:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nminta kontak Sakura saja dulu.
Dialogue: 0,0:18:33.68,0:18:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan ponselnya.
Dialogue: 0,0:18:34.93,0:18:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, baik!
Dialogue: 0,0:18:36.83,0:18:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:18:37.68,0:18:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ketemu Tuan Utusan Musim Dingin?
Dialogue: 0,0:18:40.02,0:18:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu, tidak ada kabar dari Tuan Rosei.
Dialogue: 0,0:18:45.23,0:18:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya hanya bisa bertemu\Ndi rapat empat musim.
Dialogue: 0,0:18:48.90,0:18:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh?
Dialogue: 0,0:18:50.11,0:18:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat sekali padahal sepuluh tahun lalu\Npernah ditolong.
Dialogue: 0,0:18:52.86,0:18:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, selama Utusan Musim Dingin\Ntidak menunjukkan iktikad baik,
Dialogue: 0,0:18:58.74,0:19:00.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ingin kupertemukan.
Dialogue: 0,0:19:01.37,0:19:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sedang memperhatikan\Nagar tidak mengganggu perwujudan musim?
Dialogue: 0,0:19:05.25,0:19:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku utusan musim dingin,
Dialogue: 0,0:19:07.71,0:19:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti segera mengirim telegram, tapi akan\Nmelihat waktu dulu untuk bertemu.
Dialogue: 0,0:19:13.83,0:19:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang ada surat.
Dialogue: 0,0:19:15.93,0:19:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukan kata-kata dia sendiri,\Nsekadar ucapan salam.
Dialogue: 0,0:19:19.64,0:19:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:19:21.39,0:19:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bukan benci sama\NUtusan Musim Dingin ternyata.
Dialogue: 0,0:19:24.77,0:19:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin ketemu?
Dialogue: 0,0:19:25.35,0:19:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ingin bertemu!\NSangat ingin!
Dialogue: 0,0:19:29.57,0:19:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku sangat ingin menemuinya.
Dialogue: 0,0:19:34.07,0:19:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin, nih, Nona Sakura?
Dialogue: 0,0:19:36.28,0:19:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis semanis ini dibiarkan sama
Dialogue: 0,0:19:37.65,0:19:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- "Cowok Badai Salju Suram" itu?\N- Suram—
Dialogue: 0,0:19:40.12,0:19:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya Rosei?
Dialogue: 0,0:19:41.37,0:19:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih saja bahas itu!
Dialogue: 0,0:19:47.75,0:19:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa lagi!
Dialogue: 0,0:19:55.34,0:19:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku akhirnya punya teman\Nyang tidak menjauhiku.
Dialogue: 0,0:19:59.85,0:20:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kamu sangat benci denganku?
Dialogue: 0,0:20:03.01,0:20:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalimat yang terucap\Nsaat bertengkar tidak dihitung.
Dialogue: 0,0:20:06.27,0:20:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?
Dialogue: 0,0:20:07.39,0:20:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilang dengan serius, lo.
Dialogue: 0,0:20:09.56,0:20:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin diberkahi.
Dialogue: 0,0:20:15.19,0:20:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, ya, aku senang kalau\Nkamu membutuhkanku.
Dialogue: 0,0:20:18.95,0:20:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku merasa membantumu\Nsudah seperti tugasku.
Dialogue: 0,0:20:24.47,0:20:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak boleh tetap seperti sekarang.
Dialogue: 0,0:20:28.07,0:20:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai seorang insan,\Nkamu harus bisa mandiri tanpa diriku.
Dialogue: 0,0:20:34.11,0:20:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mana mengerti\Nkalau diberi tahu hal sesulit itu.
Dialogue: 0,0:20:38.22,0:20:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih anak kecil.
Dialogue: 0,0:20:40.39,0:20:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga masih belum ingin menikah\Nwalau dengan orang yang kusuka.
Dialogue: 0,0:20:44.22,0:20:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih ingin punya teman.
Dialogue: 0,0:20:46.87,0:20:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu...
Dialogue: 0,0:20:48.23,0:20:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, aku ingin selalu bersamamu!
Dialogue: 0,0:20:53.29,0:20:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa bodoh sama musim panas!
Dialogue: 0,0:20:55.44,0:21:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma melakukannya karena kamu bilang\Nsuka melihat bunga musim panas!
Dialogue: 0,0:21:01.43,0:21:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan melakukannya demi dunia.
Dialogue: 0,0:21:04.99,0:21:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena kamu meminta\Nditunjukkan musim panas.
Dialogue: 0,0:21:10.51,0:21:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:21:11.84,0:21:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini selalu begitu!
Dialogue: 0,0:21:13.54,0:21:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu yang bisa memberiku semangat!
Dialogue: 0,0:21:16.71,0:21:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau punya pacar bukan masalah,\Nmenikah pun bukan masalah!
Dialogue: 0,0:21:20.59,0:21:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetaplah di dekatku.
Dialogue: 0,0:21:23.09,0:21:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesepian, Ayame.
Dialogue: 0,0:21:26.47,0:21:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Dewa Empat Musim,\Nkenapa malah memilih adikku?
Dialogue: 0,0:21:32.44,0:21:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus berubah?
Dialogue: 0,0:21:34.40,0:21:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal selama ini kamu milikku sendiri!
Dialogue: 0,0:21:37.86,0:21:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia begitu manja
Dialogue: 0,0:21:40.34,0:21:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hanya seorang anak kecil\Nyang mencintai kakaknya.
Dialogue: 0,0:21:43.11,0:21:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau berusaha, tapi...
Dialogue: 0,0:21:46.28,0:21:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kalau tidak terpilih,\Npasti bisa hidup lebih bebas dan damai.
Dialogue: 0,0:21:50.79,0:21:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada kamu,\Ntidak ada gunanya aku berusaha!
Dialogue: 0,0:21:55.73,0:21:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Ruri.
Dialogue: 0,0:21:57.92,0:22:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak memilih jalan menjadi pelayan,\Naku sudah menahan diri dari banyak hal.
Dialogue: 0,0:22:03.10,0:22:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga mendedikasikan masa mudaku pada Ruri.
Dialogue: 0,0:22:06.18,0:22:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertahan sedikit lagi.
Dialogue: 0,0:22:08.93,0:22:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan terbebas dari Dewa Musim Panas ini.
Dialogue: 0,0:22:19.44,0:22:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah berjuang lagi.
Dialogue: 0,0:22:22.18,0:22:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupku sendiri akan dimulai.
Dialogue: 0,0:22:24.82,0:22:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh merasa senang.
Dialogue: 0,0:22:26.85,0:22:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah merasa sungkan\Nkarena keluarga lagi.
Dialogue: 0,0:22:30.45,0:22:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:22:33.21,0:22:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kebebasan akhirnya tiba.
Dialogue: 0,0:22:36.63,0:22:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:22:38.21,0:22:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun ini yang terakhir,\Nsudah keputusan desa.
Dialogue: 0,0:22:41.78,0:22:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai tahun depan, jangan mengirim\Nmusim panas untukku lagi.
Dialogue: 0,0:22:44.88,0:22:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus jadi kuat.
Dialogue: 0,0:22:46.45,0:22:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus begini?
Dialogue: 0,0:22:49.39,0:22:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, seandainya bukan kamu\Npasti lebih baik, ya.
Dialogue: 0,0:22:53.52,0:22:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin terlepas dari dewa ini.
Dialogue: 0,0:22:55.90,0:22:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai aku bisa menggantikanmu, ya.
Dialogue: 0,0:22:58.65,0:23:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyukai adikku.
Dialogue: 0,0:23:00.53,0:23:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seandainya bukan kamu.
Dialogue: 0,0:23:02.49,0:23:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membenci adikku.
Dialogue: 0,0:23:04.78,0:23:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin...
Dialogue: 0,0:23:10.54,0:23:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bisa jadi kakak yang lebih baik!
Dialogue: 0,0:23:15.71,0:23:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku menyayangi adikku.
Dialogue: 0,0:23:21.26,0:23:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri.
Dialogue: 0,0:23:23.74,0:23:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:23:25.70,0:23:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja, aku bisa menggantikanmu.
