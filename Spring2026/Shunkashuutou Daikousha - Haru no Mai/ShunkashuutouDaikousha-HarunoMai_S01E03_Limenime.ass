Dialogue: 0,0:01:53.68,0:02:02.44,tanda,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:05:33.40,0:05:36.40,tanda,,0000,0000,0000,,EPISODE TIGA: BAYANGAN SAMAR
Dialogue: 0,0:21:43.41,0:21:45.41,tanda,,0000,0000,0000,,TIDAK ADA KONEKSI INTERNET
Dialogue: 0,0:23:40.02,0:23:45.03,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA: TENANGNYA PAGI
Dialogue: 0,0:00:06.25,0:00:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanan mendatangkan musim semi\Nke Negeri Yamato.
Dialogue: 0,0:00:09.45,0:00:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bisa sampai di sini dengan selamat.
Dialogue: 0,0:00:12.95,0:00:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak ada salahnya waspada.
Dialogue: 0,0:00:15.70,0:00:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan tinggal di istana milik\Nutusan musim panas saat berada di Tanah Iyo.
Dialogue: 0,0:00:22.17,0:00:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan musim panas?
Dialogue: 0,0:00:23.96,0:00:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sesama utusan\Nyang hanya ada empat di negeri ini,
Dialogue: 0,0:00:26.97,0:00:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin banyak yang bisa diobrolkan.
Dialogue: 0,0:00:29.35,0:00:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita nantikan.
Dialogue: 0,0:00:31.39,0:00:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:00:33.72,0:00:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawasan Biro Empat Musim\Nakan sedikit melonggar
Dialogue: 0,0:00:36.06,0:00:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau berada\Ndi bawah pengawasan musim lain.
Dialogue: 0,0:00:39.39,0:00:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauhkan segala sesuatu yang bisa\Nmengacaukan hati Nona Hinagiku.
Dialogue: 0,0:00:42.94,0:00:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik orang-orang desa,\Natau serangan Penyamun.
Dialogue: 0,0:00:47.03,0:00:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar tidak kehilangan Nona Hinagiku lagi.
Dialogue: 0,0:00:50.70,0:00:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mengambil kembali waktu kami!
Dialogue: 0,0:00:56.42,0:00:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Utusan Musim Panas.
Dialogue: 0,0:01:00.38,0:01:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku bisa berteman dengannya?
Dialogue: 0,0:02:38.38,0:02:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekolah, bisa main sama teman.
Dialogue: 0,0:02:41.46,0:02:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya keluarga yang bahagia,\Nserta kakak yang kucinta.
Dialogue: 0,0:02:47.09,0:02:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira wajar kalau itu terus berlanjut.
Dialogue: 0,0:02:50.90,0:02:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya telah berubah.
Dialogue: 0,0:02:54.78,0:02:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus aku?
Dialogue: 0,0:02:59.93,0:03:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, ada kelinci!
Dialogue: 0,0:03:03.70,0:03:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Nona Hinagiku, ada kelinci.
Dialogue: 0,0:03:05.71,0:03:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada anak anjing dan anak kucing juga!
Dialogue: 0,0:03:08.88,0:03:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kombinasi yang terlalu imut.
Dialogue: 0,0:03:10.67,0:03:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada burung, dan juga tupai.
Dialogue: 0,0:03:12.84,0:03:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah surga, Nona Hinagiku.
Dialogue: 0,0:03:15.43,0:03:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti mari kita ambil foto,\Nsebagai penyejuk hatiku.
Dialogue: 0,0:03:18.81,0:03:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalian menyukai binatang.
Dialogue: 0,0:03:22.62,0:03:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan, aku Hazakura Ayame,\Nselaku pengawal musim panas.
Dialogue: 0,0:03:29.67,0:03:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berkenan, apa perlu disiapkan kamar\Nuntuk pengawal musim semi yang lain?
Dialogue: 0,0:03:34.07,0:03:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:03:35.82,0:03:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menemani dengan menjaga jarak.
Dialogue: 0,0:03:39.74,0:03:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti lelah, silakan bersantai.
Dialogue: 0,0:03:44.54,0:03:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, ini kamar yang bagus, ya.
Dialogue: 0,0:03:48.46,0:03:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalian menyukainya.
Dialogue: 0,0:03:50.79,0:03:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kebaikanmu.
Dialogue: 0,0:03:52.67,0:03:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Hazakura.
Dialogue: 0,0:03:56.92,0:04:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kayo, tolong panggil aku "Ayame" saja.
Dialogue: 0,0:04:02.03,0:04:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Panas juga menggunakan\Nnama Hazakura, jadinya nanti rancu.
Dialogue: 0,0:04:07.89,0:04:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku belum menjelaskannya.
Dialogue: 0,0:04:11.65,0:04:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ayame dan Nona Utusan Musim Panas\Nadalah sepasang saudari.
Dialogue: 0,0:04:16.02,0:04:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saudari sekaligus tuan dan pelayan?
Dialogue: 0,0:04:21.66,0:04:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Sakura bukanlah saudari.
Dialogue: 0,0:04:25.75,0:04:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita seperti sepasang saudari.
Dialogue: 0,0:04:28.66,0:04:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita juga sama?
Dialogue: 0,0:04:30.25,0:04:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pantas bila disebut saudarimu.
Dialogue: 0,0:04:33.79,0:04:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua sangat dekat,\Njadi kupikir itu baik...
Dialogue: 0,0:04:38.89,0:04:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak suka, ya...
Dialogue: 0,0:04:41.29,0:04:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:04:42.76,0:04:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NMana mungkin aku tidak suka!
Dialogue: 0,0:04:45.10,0:04:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang sebagai sahabat!
Dialogue: 0,0:04:46.60,0:04:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai saudari!
Dialogue: 0,0:04:47.60,0:04:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai katana pelindungmu!
Dialogue: 0,0:04:49.23,0:04:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu menemanimu\Nmelewati suka dan duka!
Dialogue: 0,0:04:52.23,0:04:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:04:54.23,0:04:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar!
Dialogue: 0,0:04:56.98,0:04:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar rumornya.
Dialogue: 0,0:04:59.11,0:05:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kalian sungguh dekat, ya.
Dialogue: 0,0:05:03.94,0:05:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak...
Dialogue: 0,0:05:04.99,0:05:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku adalah adik yang egois,\Nsedikit iri rasanya.
Dialogue: 0,0:05:10.12,0:05:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Egois?
Dialogue: 0,0:05:11.94,0:05:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:13.58,0:05:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan dia sungguh egois.
Dialogue: 0,0:05:16.05,0:05:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diperbolehkan, kami ingin\Nmemberi salam pada Utusan Musim Panas.
Dialogue: 0,0:05:22.21,0:05:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang beristirahat,\Nkita lihat lain waktu.
Dialogue: 0,0:05:46.53,0:05:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sangat jinak pada manusia.
Dialogue: 0,0:05:48.66,0:05:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dipeluk kalau mereka mendekat.
Dialogue: 0,0:05:51.75,0:05:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak hewan.
Dialogue: 0,0:05:54.25,0:05:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kenapa?
Dialogue: 0,0:05:57.29,0:06:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Panas diberi kemampuan bicara\Ndan membuat tunduk makhluk hidup
Dialogue: 0,0:06:00.95,0:06:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang disebut Pengendali Hayat.
Dialogue: 0,0:06:03.97,0:06:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja aku\Njadi utusan musim panas...
Dialogue: 0,0:06:08.60,0:06:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara dengan hewan memang menyenangkan,\Ntapi jadi musim panas tetap repot, lo.
Dialogue: 0,0:06:13.31,0:06:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biaya pakan dan pemeliharaannya besar,\Npadahal anggaran kami minim.
Dialogue: 0,0:06:17.61,0:06:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Masih mau difoto?\N- Sebisa mungkin,
Dialogue: 0,0:06:19.15,0:06:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anggaran inginnya dipakai\Nuntuk pakaian utusan, ya.
Dialogue: 0,0:06:22.32,0:06:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:06:23.78,0:06:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Busana utusan adalah\Nbagian pelayan unjuk gigi!
Dialogue: 0,0:06:27.91,0:06:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah baju tradisional Jepang\Nitu merepotkan?
Dialogue: 0,0:06:30.20,0:06:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju tradisional memang mengerikan.
Dialogue: 0,0:06:32.91,0:06:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:06:34.42,0:06:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah betapa menggemaskannya beliau!
Dialogue: 0,0:06:36.71,0:06:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja kerasnya sepadan bila demi ini!
Dialogue: 0,0:06:38.79,0:06:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh mengesankan!
Dialogue: 0,0:06:40.30,0:06:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin seperti itu,\Ntapi utusan kami menyukai pakaian Barat.
Dialogue: 0,0:06:45.09,0:06:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, anggaran memang jadi bisa ditekan.
Dialogue: 0,0:06:48.43,0:06:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, anu, aku tidak harus kimono,\Npakai setelan jas—
Dialogue: 0,0:06:53.52,0:06:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa kamu ini, Nona Hinagiku?
Dialogue: 0,0:06:55.52,0:06:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rasa Nona Kayo juga\Ncocok dengan pakaian Barat!
Dialogue: 0,0:06:58.36,0:07:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi! Pasti lebih cocok pakaian Jepang!
Dialogue: 0,0:07:00.61,0:07:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:07:02.23,0:07:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pasti itu!
Dialogue: 0,0:07:42.33,0:07:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak atas\Nperwujudan musimnya di Iyo.
Dialogue: 0,0:07:45.19,0:07:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti lelah melaksanakan upacara tanpa henti.
Dialogue: 0,0:07:47.45,0:07:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kusiapkan camilan minum teh dulu.
Dialogue: 0,0:07:50.07,0:07:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku bantu.
Dialogue: 0,0:07:51.66,0:07:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, bisa tolong menunggu di kamar?
Dialogue: 0,0:07:55.22,0:07:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:57.13,0:08:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Nona Kayo.\NKami permisi.
Dialogue: 0,0:08:17.15,0:08:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kelinci?
Dialogue: 0,0:08:20.27,0:08:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kelinci, halo...
Dialogue: 0,0:08:53.49,0:08:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan, Kayo Hinagiku.
Dialogue: 0,0:08:58.02,0:09:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kamu utusan musim panas?
Dialogue: 0,0:09:02.98,0:09:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa butuh sesuatu denganku?
Dialogue: 0,0:09:11.99,0:09:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena cara bicaraku aneh?
Dialogue: 0,0:09:17.87,0:09:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku, Ruri.
Dialogue: 0,0:09:20.21,0:09:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri sang Utusan Musim Panas.
Dialogue: 0,0:09:23.02,0:09:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, panggil saja aku "Hinagiku".
Dialogue: 0,0:09:28.21,0:09:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kakak bilang sesuatu soal diriku?
Dialogue: 0,0:09:31.26,0:09:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayame?
Dialogue: 0,0:09:33.89,0:09:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang sedang istirahat karena\Ntidak enak badan.
Dialogue: 0,0:09:39.43,0:09:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma itu?
Dialogue: 0,0:09:40.85,0:09:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak bilang yang lain?
Dialogue: 0,0:09:43.77,0:09:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:09:44.73,0:09:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Kakak memang\Nsudah tidak peduli padaku!
Dialogue: 0,0:09:48.69,0:09:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Rasanya tidak—
Dialogue: 0,0:09:51.15,0:09:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pergi menjemput Utusan Musim Semi\Ntanpa bilang apa-apa padaku.
Dialogue: 0,0:09:55.95,0:09:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kondisi badan...
Dialogue: 0,0:09:57.66,0:09:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak apa-apa!
Dialogue: 0,0:09:59.27,0:10:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehat.
Dialogue: 0,0:10:00.54,0:10:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku kesal makanya tidak keluar.
Dialogue: 0,0:10:03.62,0:10:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau keluar supaya dia kesusahan.
Dialogue: 0,0:10:06.79,0:10:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal, akulah yang menderita...
Dialogue: 0,0:10:13.55,0:10:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Nona Utusan Musim Panas.
Dialogue: 0,0:10:18.12,0:10:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan bermaksud jahat.
Dialogue: 0,0:10:22.29,0:10:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku juga—
Dialogue: 0,0:10:23.39,0:10:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri?
Dialogue: 0,0:10:25.02,0:10:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?\NAku mencarimu ke mana-mana!
Dialogue: 0,0:10:27.48,0:10:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:10:29.65,0:10:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!\NCepat keluar dan minta maaf!
Dialogue: 0,0:10:33.74,0:10:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, tidak apa-apa, kok.
Dialogue: 0,0:10:36.49,0:10:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat keluar!
Dialogue: 0,0:10:38.12,0:10:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti lari saat kamu terpojok!
Dialogue: 0,0:10:40.33,0:10:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame, kami hanya bertukar salam.
Dialogue: 0,0:10:46.04,0:10:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:48.21,0:10:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ayame, tuanku tidak terluka,\Njadi tidak apa-apa.
Dialogue: 0,0:10:59.66,0:11:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah lepas kendali seperti tadi.
Dialogue: 0,0:11:02.60,0:11:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku marah karena tingkahnya\Nyang begitu seenaknya.
Dialogue: 0,0:11:05.98,0:11:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah dipikirkan.
Dialogue: 0,0:11:09.27,0:11:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin memang tidak kusampaikan.
Dialogue: 0,0:11:11.48,0:11:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Ruri sudah mengurung diri di kamar\Ntidak mau keluar selama tiga bulan.
Dialogue: 0,0:11:16.49,0:11:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain sedang mogok kerja.
Dialogue: 0,0:11:19.10,0:11:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mogok kerja?
Dialogue: 0,0:11:21.45,0:11:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi aku akan menikah\Ndan berhenti jadi pelayan.
Dialogue: 0,0:11:24.92,0:11:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikku pun merajuk karena hal itu.
Dialogue: 0,0:11:34.39,0:11:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura ada rencana menikah?
Dialogue: 0,0:11:38.14,0:11:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:38.84,0:11:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak ada!
Dialogue: 0,0:11:40.18,0:11:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginanku adalah terus berada\Ndi sisimu seumur hidup!
Dialogue: 0,0:11:43.60,0:11:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada rencana atau keinginan ke sana!
Dialogue: 0,0:11:46.85,0:11:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Meski Kakanda Itecho yang melamarmu?
Dialogue: 0,0:11:52.11,0:11:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:53.11,0:11:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah orang itu yang kamu sebut?
Dialogue: 0,0:11:55.24,0:11:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Sakura seram...
Dialogue: 0,0:11:58.61,0:12:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, bukankah saat kecil\Nkamu menyukai Kakanda Itecho—
Dialogue: 0,0:12:05.04,0:12:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu perasaan sepuluh tahun lalu!
Dialogue: 0,0:12:07.37,0:12:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibuang ke tempat sampah,\Nmasuk tempat pembuangan, dan sudah dibakar.
Dialogue: 0,0:12:12.67,0:12:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah itu?
Dialogue: 0,0:12:14.88,0:12:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:16.38,0:12:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, padahal...
Dialogue: 0,0:12:24.50,0:12:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?
Dialogue: 0,0:12:26.25,0:12:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?
Dialogue: 0,0:12:32.43,0:12:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Sakura.
Dialogue: 0,0:12:35.90,0:12:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah tidak ada yang parah.
Dialogue: 0,0:12:41.39,0:12:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisi Nona Kayo?
Dialogue: 0,0:12:44.59,0:12:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang sedikit demam.
Dialogue: 0,0:12:46.54,0:12:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti lelah melakukan perwujudan\Nmusim semi berturut-turut.
Dialogue: 0,0:12:49.75,0:12:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat bisa dimengerti.
Dialogue: 0,0:12:51.92,0:12:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya di sini dilalui aliran energi roh\Nyang dapat meningkatkan kekuatan ilahi.
Dialogue: 0,0:12:56.88,0:13:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan beristirahat saja hingga kalian\Nberangkat ke Teishu.
Dialogue: 0,0:13:00.88,0:13:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:13:02.47,0:13:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, selain itu.
Dialogue: 0,0:13:06.35,0:13:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diizinkan memakai dapur,\Njadi akan kubuatkan bubur.
Dialogue: 0,0:13:11.06,0:13:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu istirahat saja.
Dialogue: 0,0:13:14.36,0:13:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah aku egois kalau bilang\Ningin bubur dengan telur?
Dialogue: 0,0:13:23.82,0:13:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sedang demam atau tidak,\Nsilakan meminta hal "egois" padaku.
Dialogue: 0,0:13:29.50,0:13:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan sangat senang.
Dialogue: 0,0:13:34.19,0:13:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka.
Dialogue: 0,0:13:36.53,0:13:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ayame?
Dialogue: 0,0:13:37.80,0:13:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf aku berpakaian seperti ini.
Dialogue: 0,0:13:41.26,0:13:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak perlu sungkan.
Dialogue: 0,0:13:45.66,0:13:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ada apa, ya?
Dialogue: 0,0:13:47.35,0:13:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:13:48.06,0:13:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya merasa\Nkalau kamu pintar memasak.
Dialogue: 0,0:13:51.69,0:13:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma bubur,\Nsiapa saja juga bisa membuatnya.
Dialogue: 0,0:13:54.40,0:13:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sangat memalukan,\Ntapi aku belum pernah membuat bubur.
Dialogue: 0,0:14:00.40,0:14:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini semuanya dikerjakan\Norang-orang sekitar.
Dialogue: 0,0:14:04.25,0:14:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak baik, ya.\NPadahal aku akan menikah.
Dialogue: 0,0:14:07.12,0:14:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat suamiku nanti sakit,\Nsetidaknya harus membuatkan bubur, kan?
Dialogue: 0,0:14:13.27,0:14:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba membuatnya bersama?
Dialogue: 0,0:14:22.37,0:14:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal menunggu jadi.
Dialogue: 0,0:14:24.22,0:14:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena permintaan Nona Hinagiku,\Nakan diberi telur di akhir nanti.
Dialogue: 0,0:14:29.87,0:14:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi maaf, apa aku boleh bertanya\Nmengenai Utusan Musim Panas?
Dialogue: 0,0:14:34.81,0:14:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betapa memalukannya tuan kami\Nsampai mogok kerja.
Dialogue: 0,0:14:39.32,0:14:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:14:41.19,0:14:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil, adikku menganggapku\Nsebagai barang pribadinya.
Dialogue: 0,0:14:48.20,0:14:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menganggap aku menikah\Nlalu berhenti jadi pelayan,
Dialogue: 0,0:14:50.74,0:14:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seolah karena telah direbut orang lain.
Dialogue: 0,0:14:54.00,0:14:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Padahal kamu adalah milikku," begitu.
Dialogue: 0,0:14:57.33,0:15:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, aku tidak menyangka\NDesa bisa memberi izin.
Dialogue: 0,0:15:02.17,0:15:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Musim Panas punya tradisi unik.
Dialogue: 0,0:15:05.75,0:15:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kecil, utusan akan\Ndipasrahkan pada keluarga.
Dialogue: 0,0:15:08.64,0:15:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dewasa, pasangannyalah\Nyang akan mendukung penuh.
Dialogue: 0,0:15:13.00,0:15:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa aku menikah pun.
Dialogue: 0,0:15:14.94,0:15:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawal Ruri kelak pasti dilanjutkan\Nsiapa pun yang menjadi suaminya.
Dialogue: 0,0:15:19.69,0:15:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti Utusan Musim Panas\Njuga akan menikah?
Dialogue: 0,0:15:22.94,0:15:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah melewati perjodohan\Ndan telah bertunangan.
Dialogue: 0,0:15:25.95,0:15:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasangannya memang orang\Nyang Ruri sayangi.
Dialogue: 0,0:15:31.85,0:15:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri sebenarnya juga mengerti.
Dialogue: 0,0:15:34.96,0:15:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahwa pernikahan kami adalah\Ndemi kebahagiaan masing-masing.
Dialogue: 0,0:15:39.21,0:15:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu sudah tidak bisa diapa-apakan lagi.
Dialogue: 0,0:15:42.69,0:15:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah tahu, tidak bisa merelakannya.
Dialogue: 0,0:15:46.39,0:15:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, malah bicara yang tidak perlu.
Dialogue: 0,0:15:49.34,0:15:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang musim semi\Ntentu tidak punya masalah seperti ini.
Dialogue: 0,0:15:53.94,0:15:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga pernah menghadapi mogok kerja.
Dialogue: 0,0:15:57.10,0:15:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:58.41,0:16:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak penculikannya, Nona Hinagiku\Nterus mengurung diri di kamar.
Dialogue: 0,0:16:04.07,0:16:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan butuh dua tahun hingga\Npulih seperti sekarang.
Dialogue: 0,0:16:08.73,0:16:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia diculik Penyamun dan terus disekap, kan?
Dialogue: 0,0:16:12.74,0:16:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya wajar kalau hatinya terluka.
Dialogue: 0,0:16:16.50,0:16:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Musim Semi langsung\Nmenghentikan pencarian
Dialogue: 0,0:16:19.96,0:16:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menunggu kematian Nona Hinagiku!
Dialogue: 0,0:16:23.91,0:16:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat seorang utusan mati,
Dialogue: 0,0:16:26.12,0:16:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan terpilih salah satu dari kami,\Nsuku empat musim sebagai penggantinya.
Dialogue: 0,0:16:29.76,0:16:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas kehendak para dewa.
Dialogue: 0,0:16:32.05,0:16:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang?
Dialogue: 0,0:16:33.14,0:16:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:35.55,0:16:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Nona Hinagiku mati,\Nakan muncul utusan baru.
Dialogue: 0,0:16:41.90,0:16:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah dibuang.
Dialogue: 0,0:16:43.81,0:16:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena lebih mudah menunggu mati\Ndaripada sibuk mencari!
Dialogue: 0,0:16:48.40,0:16:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibalik dan tidak kunjung ada\Nutusan baru yang terpilih,
Dialogue: 0,0:16:53.37,0:16:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu bukti Nona Hinagiku masih hidup.
Dialogue: 0,0:16:56.58,0:16:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, orang-orang desa...
Dialogue: 0,0:17:03.21,0:17:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku mengetahui itu semua.
Dialogue: 0,0:17:06.39,0:17:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bertemu kembali denganku.
Dialogue: 0,0:17:08.47,0:17:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangankan melakukan perwujudan musim,\Nmeneruskan hidup saja beliau menolak.
Dialogue: 0,0:17:13.89,0:17:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang menginginkan diriku\Nuntuk mati saja, kan?
Dialogue: 0,0:17:20.76,0:17:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kubilang, biar aku mati saja.
Dialogue: 0,0:17:28.11,0:17:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu sangat masuk akal.
Dialogue: 0,0:17:30.90,0:17:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipuja-puji bagai dewa atau apa,\Nlalu dipekerjakan seenaknya.
Dialogue: 0,0:17:34.12,0:17:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau menurut\Ndisebut produk cacat.
Dialogue: 0,0:17:37.45,0:17:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah tidak dibutuhkan akan dibunuh,\Ndibuang lalu diganti.
Dialogue: 0,0:17:40.25,0:17:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu semua!
Dialogue: 0,0:17:41.92,0:17:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diperlakukan seperti roda gigi\Nuntuk menggulirkan musim di dunia.
Dialogue: 0,0:17:50.18,0:17:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada utusan yang menyebut diri mereka\Nsebagai "hewan ternak".
Dialogue: 0,0:17:55.26,0:17:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dipiara, tanpa punya kebebasan.
Dialogue: 0,0:18:00.21,0:18:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku bisa mengerti.
Dialogue: 0,0:18:03.65,0:18:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal menjadi utusan empat musim\Nbukan karena keinginan individu.
Dialogue: 0,0:18:09.65,0:18:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh sekolah,\Njuga berteman atau bermain.
Dialogue: 0,0:18:14.66,0:18:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa melakukan hal normal.
Dialogue: 0,0:18:17.91,0:18:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya diputuskan seenaknya,\Nbilang "tidak" saja tidak boleh.
Dialogue: 0,0:18:22.58,0:18:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Napas serasa sesak.
Dialogue: 0,0:18:24.62,0:18:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap dilakukan,\Ntetap berjuang sekuat tenaga.
Dialogue: 0,0:18:28.00,0:18:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:29.17,0:18:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikucilkan, dibenci.
Dialogue: 0,0:18:31.38,0:18:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diprotes dan harus lebih begini begitu.
Dialogue: 0,0:18:34.05,0:18:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sampai hampir terbunuh.
Dialogue: 0,0:18:37.93,0:18:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perwujudan musim bukannya\Ndilakukan karena keinginan!
Dialogue: 0,0:18:41.18,0:18:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya tidak penting!
Dialogue: 0,0:18:43.19,0:18:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memanggil musim panas\Nhanya demi Ayame!
Dialogue: 0,0:18:47.23,0:18:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, adikku sering bilang begitu.
Dialogue: 0,0:18:54.07,0:19:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ayame, apakah Utusan Musim Panas\Nsekadar sedang merajuk?
Dialogue: 0,0:19:01.36,0:19:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu maksudnya bagaimana?
Dialogue: 0,0:19:05.71,0:19:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan kamu bilang, kan?
Dialogue: 0,0:19:08.40,0:19:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ruri memanggil musim panas\Ndemi Nona Ayame.
Dialogue: 0,0:19:11.59,0:19:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu demi dirimu.
Dialogue: 0,0:19:13.95,0:19:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang utusan mewujudkan musim\Ndengan hatinya.
Dialogue: 0,0:19:18.10,0:19:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa bagi Utusan Musim Panas,\Nkamu adalah
Dialogue: 0,0:19:21.43,0:19:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penyangga hatinya yang tidak terganti.
Dialogue: 0,0:19:26.97,0:19:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membawa dan menggilirkan musim\Ndi dunia yang kejam ini.
Dialogue: 0,0:19:32.54,0:19:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga memungkinkan\Nuntuk mewujudkan keajaiban seperti itu.
Dialogue: 0,0:19:36.93,0:19:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, meski ada orang lain yang disuka.
Dialogue: 0,0:19:40.45,0:19:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehilanganmu itu begitu menyakitkan,\Nbegitu tidak tertahankan.
Dialogue: 0,0:19:46.12,0:19:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kepedihan itu sekadar\Ndianggap egois.
Dialogue: 0,0:19:51.39,0:19:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah hingga kapan pun\Ntidak akan terselesaikan?
Dialogue: 0,0:19:56.71,0:19:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:20:01.10,0:20:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu ada yang bisa memahami\Nseorang utusan sepertimu...
Dialogue: 0,0:20:07.06,0:20:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya jadi sedikit lega.
Dialogue: 0,0:20:09.19,0:20:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak, maaf!
Dialogue: 0,0:20:10.73,0:20:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku belum bertemu langsung\Ndengan Utusan Musim Panas.
Dialogue: 0,0:20:14.07,0:20:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah bicara seolah paham segalanya.
Dialogue: 0,0:20:16.57,0:20:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tadi itu kalimat yang kubutuhkan.
Dialogue: 0,0:20:20.38,0:20:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku ingin mendengar itu sejak lama.
Dialogue: 0,0:20:24.58,0:20:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:20:26.58,0:20:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan musim panasmu.
Dialogue: 0,0:20:28.82,0:20:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun segalanya tidak bisa diubah lagi.
Dialogue: 0,0:20:32.84,0:20:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihat musim panasmu.
Dialogue: 0,0:20:34.92,0:20:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin diizinkan menyayanginya.
Dialogue: 0,0:20:38.47,0:20:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka musim panas yang kamu berikan.
Dialogue: 0,0:20:41.74,0:20:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sangat menyayanginya.
Dialogue: 0,0:20:50.26,0:20:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:20:51.86,0:20:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:20:54.15,0:20:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:21:14.87,0:21:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demammu sudah turun.
Dialogue: 0,0:21:34.93,0:21:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun?
Dialogue: 0,0:21:37.90,0:21:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak ada pemberitahuan\Ndari Biro Empat Musim.
Dialogue: 0,0:21:40.36,0:21:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:21:47.82,0:21:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Nona Hinagiku.
Dialogue: 0,0:21:50.62,0:21:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti melindungimu.
Dialogue: 0,0:21:53.46,0:21:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari turun dan bergabung dengan lainnya.
Dialogue: 0,0:21:59.19,0:22:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ditemukan, akan kami amankan.
Dialogue: 0,0:22:05.47,0:22:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
