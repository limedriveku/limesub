Dialogue: 0,0:01:18.98,0:01:21.98,tanda,,0000,0000,0000,,AYO PULANG, BIAR KUANTAR
Dialogue: 0,0:02:08.69,0:02:17.53,tanda,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:04:55.82,0:04:57.82,tanda,,0000,0000,0000,,TAHUN 10 REIMEI
Dialogue: 0,0:05:23.59,0:05:25.60,tanda,,0000,0000,0000,,TAHUN 15 REIMEI
Dialogue: 0,0:06:20.94,0:06:23.45,tanda,,0000,0000,0000,,TAHUN 18 REIMEI
Dialogue: 0,0:11:07.63,0:11:09.98,tanda,,0000,0000,0000,,EPISODE ENAM: TEMPAT PULANG
Dialogue: 0,0:12:07.25,0:12:08.04,tanda,,0000,0000,0000,,TAHUN 18 REIMEI
Dialogue: 0,0:18:08.86,0:18:10.92,tanda,,0000,0000,0000,,SEDANG MENCARI GADIS HILANG
Dialogue: 0,0:19:02.66,0:19:05.54,tanda,,0000,0000,0000,,TAHUN 19 REIMEI
Dialogue: 0,0:23:39.98,0:23:44.94,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA: SENJA
Dialogue: 0,0:00:07.33,0:00:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahagia rasanya dapat putri yang manis.
Dialogue: 0,0:00:11.45,0:00:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cukup menurut saja\Npada perkataanku.
Dialogue: 0,0:00:17.54,0:00:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu bahagia sekali\Nhari ini akhirnya tiba.
Dialogue: 0,0:00:22.09,0:00:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukanlah...
Dialogue: 0,0:00:31.09,0:00:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang mencoba melindungimu...
Dialogue: 0,0:00:34.72,0:00:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua akan kubunuh.
Dialogue: 0,0:00:39.25,0:00:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan...
Dialogue: 0,0:00:40.73,0:00:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, jangan...
Dialogue: 0,0:00:44.73,0:00:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda...
Dialogue: 0,0:00:49.70,0:00:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh...
Dialogue: 0,0:00:55.56,0:00:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak kuat.
Dialogue: 0,0:00:57.75,0:01:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa berjuang lagi, kok.
Dialogue: 0,0:01:01.42,0:01:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak kuat berjuang.
Dialogue: 0,0:01:04.04,0:01:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mati?
Dialogue: 0,0:01:06.38,0:01:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:01:07.83,0:01:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin mati saja.
Dialogue: 0,0:01:15.10,0:01:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah...
Dialogue: 0,0:02:52.62,0:02:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:02:54.70,0:02:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dibuang?
Dialogue: 0,0:03:02.89,0:03:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tiada bunga yang mekar abadi ♪
Dialogue: 0,0:03:08.75,0:03:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menyedihkan namun dirindukan ♪
Dialogue: 0,0:03:14.76,0:03:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dirimu sang musim dingin bagaikan rembulan ♪
Dialogue: 0,0:03:16.74,0:03:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara akan merdu\Njika menyanyikan lagu cinta.
Dialogue: 0,0:03:20.76,0:03:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kejarlah jejaknya selamanya ♪
Dialogue: 0,0:03:30.27,0:03:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti lelah melakukan\Nperwujudan berturut-turut.
Dialogue: 0,0:03:36.90,0:03:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan duduk di sini.
Dialogue: 0,0:03:39.30,0:03:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga duduk, yuk.
Dialogue: 0,0:03:41.78,0:03:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kursinya hanya ada satu.
Dialogue: 0,0:03:44.29,0:03:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu.
Dialogue: 0,0:03:45.87,0:03:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau duduk di pangkuanmu saja.
Dialogue: 0,0:03:57.01,0:03:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saljunya...
Dialogue: 0,0:03:59.34,0:04:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah, ya.
Dialogue: 0,0:04:02.56,0:04:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Tuan Rosei sehat-sehat saja?
Dialogue: 0,0:04:06.60,0:04:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gunanya memikirkan dia?
Dialogue: 0,0:04:08.94,0:04:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu mengkhawatirkannya.
Dialogue: 0,0:04:11.98,0:04:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang seperti itu.
Dialogue: 0,0:04:15.99,0:04:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia orang yang disukai anak itu,
Dialogue: 0,0:04:19.99,0:04:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}disukai oleh diriku yang sebelumnya.
Dialogue: 0,0:04:23.68,0:04:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah, sekarang pun\Ntetap saja memikirkannya.
Dialogue: 0,0:04:30.37,0:04:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bukan kehendakmu sendiri?
Dialogue: 0,0:04:33.62,0:04:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:04:35.96,0:04:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang sekarang,
Dialogue: 0,0:04:39.66,0:04:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti tinggal tanpa izin di rumah\Norang yang tidak dikenal.
Dialogue: 0,0:04:47.10,0:04:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rumahmu sendiri.
Dialogue: 0,0:04:50.10,0:04:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tetap saja berbeda.
Dialogue: 0,0:04:55.82,0:04:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghentikan pencarian?
Dialogue: 0,0:04:58.25,0:05:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dalam tiga bulan?
Dialogue: 0,0:05:01.66,0:05:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Nona Hinagiku masih hidup?
Dialogue: 0,0:05:04.58,0:05:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin dibiarkan mati begitu saja?
Dialogue: 0,0:05:09.41,0:05:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong cari Nona Hinagiku!\NAku mohon!
Dialogue: 0,0:05:13.54,0:05:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dibuang!
Dialogue: 0,0:05:15.21,0:05:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong dibuka! Aku mohon!
Dialogue: 0,0:05:17.55,0:05:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:05:21.09,0:05:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho...
Dialogue: 0,0:05:25.60,0:05:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:05:27.47,0:05:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pencarian skala besar resmi dihentikan.
Dialogue: 0,0:05:31.52,0:05:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak bisa menghentikannya...
Dialogue: 0,0:05:36.07,0:05:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengkhianat.
Dialogue: 0,0:05:39.18,0:05:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bohong, kan, Tuan Itecho?
Dialogue: 0,0:05:43.16,0:05:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik Nona Hinagiku... atau aku...
Dialogue: 0,0:05:46.87,0:05:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:05:48.91,0:05:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya mau menolong kami?
Dialogue: 0,0:05:55.96,0:06:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau desa, Rosei, atau pun Itecho.
Dialogue: 0,0:06:01.13,0:06:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, mereka semua...
Dialogue: 0,0:06:04.26,0:06:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:06.30,0:06:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:08.51,0:06:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa membuang kami?
Dialogue: 0,0:06:20.94,0:06:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa lagi?
Dialogue: 0,0:06:26.95,0:06:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak berniat mencari Nona Hinagiku,
Dialogue: 0,0:06:29.83,0:06:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan memanggilku!
Dialogue: 0,0:06:31.20,0:06:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah kembali.
Dialogue: 0,0:06:35.04,0:06:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:06:36.71,0:06:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku Sang Utusan sudah kembali.
Dialogue: 0,0:06:40.34,0:06:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ditemukan setengah tahun lalu.
Dialogue: 0,0:06:51.10,0:06:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:06:52.31,0:06:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:06:56.65,0:06:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kembali!
Dialogue: 0,0:06:58.31,0:07:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pulang!
Dialogue: 0,0:07:00.73,0:07:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis paling berharga di dunia\Nyang pernah menyelamatkanku!
Dialogue: 0,0:07:08.07,0:07:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:07:18.08,0:07:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?
Dialogue: 0,0:07:20.38,0:07:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku!\NHimedaka Sakura!
Dialogue: 0,0:07:24.42,0:07:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura?
Dialogue: 0,0:07:26.63,0:07:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura milikmu!
Dialogue: 0,0:07:29.22,0:07:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona... Hinagiku...
Dialogue: 0,0:07:36.94,0:07:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku...
Dialogue: 0,0:07:41.33,0:07:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf telah gagal melindungimu!
Dialogue: 0,0:07:46.86,0:07:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini, aku...
Dialogue: 0,0:07:54.50,0:07:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:08:00.13,0:08:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sungguh Sakura?
Dialogue: 0,0:08:05.42,0:08:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:08:07.30,0:08:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutmu kenapa?
Dialogue: 0,0:08:10.80,0:08:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dulu hitam dan indah.
Dialogue: 0,0:08:14.27,0:08:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertemu denganmu!
Dialogue: 0,0:08:16.35,0:08:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku terus mencarimu.
Dialogue: 0,0:08:19.85,0:08:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terus mencari?
Dialogue: 0,0:08:22.36,0:08:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap hari aku cari tanpa henti!
Dialogue: 0,0:08:25.18,0:08:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:08:26.65,0:08:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu mencari Hinagiku.
Dialogue: 0,0:08:30.53,0:08:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:08:32.53,0:08:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf sebesar-besarnya\Ntelah gagal melindungimu sebagai pelayan.
Dialogue: 0,0:08:38.28,0:08:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, itu tidak benar.
Dialogue: 0,0:08:41.63,0:08:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku itu...
Dialogue: 0,0:08:44.16,0:08:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah mati.
Dialogue: 0,0:08:51.39,0:08:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf?
Dialogue: 0,0:08:54.02,0:08:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya mati?
Dialogue: 0,0:08:56.83,0:09:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku yang dulu sudah mati.
Dialogue: 0,0:09:02.11,0:09:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku yang sekarang\Nadalah orang lain.
Dialogue: 0,0:09:08.07,0:09:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang lain?
Dialogue: 0,0:09:10.23,0:09:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku yang dulu tidak kuat bertahan.
Dialogue: 0,0:09:15.83,0:09:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu menghilang.
Dialogue: 0,0:09:18.15,0:09:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku yang sekarang bukanlah\NHinagiku yang kamu cari.
Dialogue: 0,0:09:24.21,0:09:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya pengganti.
Dialogue: 0,0:09:26.05,0:09:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara bicaramu memang berbeda.
Dialogue: 0,0:09:29.63,0:09:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:09:31.18,0:09:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:09:34.01,0:09:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan Hinagiku yang dulu.
Dialogue: 0,0:09:37.13,0:09:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah bilang ke semua orang.
Dialogue: 0,0:09:40.94,0:09:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Sakura.
Dialogue: 0,0:09:44.00,0:09:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu boleh pulang saja.
Dialogue: 0,0:09:47.44,0:09:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?
Dialogue: 0,0:09:49.57,0:09:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang menunggu\Nkematian anak itu, kan?
Dialogue: 0,0:09:56.11,0:09:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, biar aku kabulkan.
Dialogue: 0,0:09:59.54,0:10:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi itu, Hinagiku yang sekarang\Njuga akan mati.
Dialogue: 0,0:10:05.55,0:10:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi biarkan saja.
Dialogue: 0,0:10:08.42,0:10:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pulang saja.
Dialogue: 0,0:10:12.26,0:10:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:10:15.18,0:10:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kamu bahagia, Sakura.
Dialogue: 0,0:10:21.81,0:10:24.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup dengan melupakan Nona Hinagiku?
Dialogue: 0,0:10:25.94,0:10:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi dari sini mencari kebahagiaan\Nseperti yang beliau bilang?
Dialogue: 0,0:10:30.86,0:10:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan...
Dialogue: 0,0:10:32.03,0:10:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:10:34.65,0:10:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh hidup seperti itu.
Dialogue: 0,0:10:39.24,0:10:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh apa pun selain\Nhak berada di sampingnya!
Dialogue: 0,0:10:44.08,0:10:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Nona Hinagiku.
Dialogue: 0,0:10:46.83,0:10:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat aku pulang hanya satu.
Dialogue: 0,0:10:51.71,0:10:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi, akulah pelayanmu.
Dialogue: 0,0:10:56.34,0:10:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan akan selalu kembali ke hadapanmu.
Dialogue: 0,0:10:59.14,0:11:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan ketidakhadiranku selama ini.
Dialogue: 0,0:11:02.52,0:11:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himedaka Sakura,\Nsaat ini telah kembali ke hadapanmu!
Dialogue: 0,0:11:19.87,0:11:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada laporan dari Todo dan regunya.
Dialogue: 0,0:11:22.54,0:11:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini Nona Hinagiku juga sudah selesai\Nmewujudkan musim semi dengan lancar.
Dialogue: 0,0:11:27.83,0:11:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:11:30.34,0:11:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini didapat dari menekan para atasan.
Dialogue: 0,0:11:33.34,0:11:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku berhasil kabur dari Penyamun\Ndan kembali sejak dua tahun lalu.
Dialogue: 0,0:11:38.34,0:11:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, Desa Musim Semi\Ndan Biro Empat Musim.
Dialogue: 0,0:11:41.55,0:11:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menutup rapat hal itu hingga perwujudan\Nmusim semi tahun ini berhasil dengan lancar.
Dialogue: 0,0:11:46.75,0:11:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena Hinagiku yang kembali...
Dialogue: 0,0:11:50.06,0:11:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hatinya telah hancur\Ndan berganti dengan kepribadian lain.
Dialogue: 0,0:11:53.98,0:11:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura yang menghilang\Nkemudian dibawa pulang,
Dialogue: 0,0:11:57.20,0:11:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya bertujuan memulihkan hal tersebut.
Dialogue: 0,0:12:01.08,0:12:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sudah berbeda\Ndengan yang saat itu.
Dialogue: 0,0:12:05.83,0:12:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:12:08.04,0:12:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku.
Dialogue: 0,0:12:11.54,0:12:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak makan, nanti jatuh sakit.
Dialogue: 0,0:12:14.30,0:12:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah.
Dialogue: 0,0:12:15.63,0:12:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku sakit dan mati saja.
Dialogue: 0,0:12:19.80,0:12:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:12:21.30,0:12:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, setidaknya satu suap saja.
Dialogue: 0,0:12:28.56,0:12:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku.
Dialogue: 0,0:12:30.65,0:12:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah aku sampaikan berulang kali.
Dialogue: 0,0:12:32.65,0:12:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap menolak mewujudkan musim,\Nnyawamu akan dalam bahaya.
Dialogue: 0,0:12:37.65,0:12:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kamu tidak melaksanakan perwujudan,
Dialogue: 0,0:12:40.74,0:12:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musim semi tidak akan tiba ke Yamato.
Dialogue: 0,0:12:43.08,0:12:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi memanggil musim semi,
Dialogue: 0,0:12:44.58,0:12:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau tidak mau harus membunuhmu\Nuntuk melahirkan utusan baru.
Dialogue: 0,0:12:49.27,0:12:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar kalau ada\Nyang punya pemikiran seperti itu.
Dialogue: 0,0:12:53.18,0:12:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya sudah dibilang\Nbiarkan aku mati saja.
Dialogue: 0,0:12:58.77,0:13:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang berharga buatmu bukanlah aku,
Dialogue: 0,0:13:03.84,0:13:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi anak itu, kan?
Dialogue: 0,0:13:07.85,0:13:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun aku mati,
Dialogue: 0,0:13:11.73,0:13:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak perlu bersedih.
Dialogue: 0,0:13:20.30,0:13:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, ini Sakura.
Dialogue: 0,0:13:22.49,0:13:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izin permisi.
Dialogue: 0,0:13:30.46,0:13:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?
Dialogue: 0,0:13:40.26,0:13:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:13:42.72,0:13:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan...
Dialogue: 0,0:13:46.39,0:13:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit, lo!
Dialogue: 0,0:14:00.36,0:14:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, saat bertemu denganmu,
Dialogue: 0,0:14:04.11,0:14:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ketahuan saat menyelinap ke wastu\Nlalu sempat dipisahkan darimu.
Dialogue: 0,0:14:09.16,0:14:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu kamu mengurung diri di kamar.
Dialogue: 0,0:14:12.62,0:14:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya tidak akan menjalankan tugas kalau\NHimedaka Sakura tidak dibawa menghadap.
Dialogue: 0,0:14:16.59,0:14:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang desa pun kalang kabut.
Dialogue: 0,0:14:21.80,0:14:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf, aku kelepasan.
Dialogue: 0,0:14:24.64,0:14:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tentu tidak ingat, ya.
Dialogue: 0,0:14:28.85,0:14:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu.
Dialogue: 0,0:14:36.73,0:14:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena di dalam diriku
Dialogue: 0,0:14:40.19,0:14:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih tersisa ingatan anak itu.
Dialogue: 0,0:14:50.54,0:14:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Sakura.
Dialogue: 0,0:14:54.33,0:14:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:14:56.54,0:15:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan anak itu,
Dialogue: 0,0:15:00.92,0:15:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kamu tidak perlu melindungiku lagi.
Dialogue: 0,0:15:06.76,0:15:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa mengembalikan anak itu.
Dialogue: 0,0:15:12.72,0:15:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:15:18.98,0:15:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:15:26.70,0:15:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku milikku sudah pulang.
Dialogue: 0,0:15:30.91,0:15:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah kamu yang sekarang hidup\Ndengan sepenuh hati.
Dialogue: 0,0:15:35.41,0:15:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bersamamu.
Dialogue: 0,0:15:46.22,0:15:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa kali pun akan kuucapkan.
Dialogue: 0,0:15:49.22,0:15:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bersamamu.
Dialogue: 0,0:15:52.64,0:15:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kamu tidak mengakui diri sendiri,\Naku bisa tahu.
Dialogue: 0,0:15:57.64,0:16:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu adalah Nona Kayo Hinagiku.
Dialogue: 0,0:16:01.94,0:16:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, kalau begitu.
Dialogue: 0,0:16:05.53,0:16:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh memikirkan Tuan Rosei?
Dialogue: 0,0:16:12.45,0:16:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu kenapa.
Dialogue: 0,0:16:15.50,0:16:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku itu orang lain,\Nperasaan suka pada Tuan Rosei
Dialogue: 0,0:16:24.00,0:16:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya belum mati.
Dialogue: 0,0:16:27.80,0:16:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:16:30.13,0:16:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin mempertemukan anak itu\Ndengan Tuan Rosei.
Dialogue: 0,0:16:40.81,0:16:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:42.90,0:16:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dibuang?
Dialogue: 0,0:16:45.42,0:16:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu diculik gara-gara musim dingin.
Dialogue: 0,0:16:48.96,0:16:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:16:50.61,0:16:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang berdosa adalah para Penyamun.
Dialogue: 0,0:16:54.91,0:16:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi orang-orang musim dingin\Nsudah membuang kita.
Dialogue: 0,0:16:58.29,0:17:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada sekutu yang bisa kita percaya.
Dialogue: 0,0:17:01.46,0:17:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak begitu, kok.
Dialogue: 0,0:17:03.96,0:17:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, memang begitu!
Dialogue: 0,0:17:05.83,0:17:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menjadikan Tuan Rosei\Ndan Kakanda Itecho sebagai orang jahat,
Dialogue: 0,0:17:12.97,0:17:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu bisa lega?
Dialogue: 0,0:17:16.18,0:17:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei! Itecho!
Dialogue: 0,0:17:19.29,0:17:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:17:21.14,0:17:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu sekadar dirimu\Nyang menjadikan mereka orang jahat.
Dialogue: 0,0:17:28.56,0:17:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kamu tahu, kan?
Dialogue: 0,0:17:32.32,0:17:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka sudah berusaha melindungi.
Dialogue: 0,0:17:37.49,0:17:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadikan seseorang sebagai penjahat\Nitu rasanya sakit, lo.
Dialogue: 0,0:17:42.40,0:17:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan terus merasa sakit.
Dialogue: 0,0:17:47.00,0:17:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kebencian ini...
Dialogue: 0,0:17:48.12,0:17:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kamu tidak bisa berubah,
Dialogue: 0,0:17:50.09,0:17:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tetap menyukaimu.
Dialogue: 0,0:17:54.37,0:17:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...sampai kubuang...
Dialogue: 0,0:17:56.43,0:18:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jangan sampai menderita.
Dialogue: 0,0:18:00.31,0:18:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...akan jadi lemah.
Dialogue: 0,0:18:02.14,0:18:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bertahun-tahun mencarimu.
Dialogue: 0,0:18:04.60,0:18:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lemah, tidak akan bisa menjadi bilah.
Dialogue: 0,0:18:06.86,0:18:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski musim semi,
Dialogue: 0,0:18:08.86,0:18:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan musim dingin membuang kita, tetap kucari.
Dialogue: 0,0:18:11.61,0:18:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa melindungi\Njika tidak jadi bilah.
Dialogue: 0,0:18:14.32,0:18:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membutuhkan amarah.
Dialogue: 0,0:18:17.83,0:18:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh kebencian.
Dialogue: 0,0:18:21.79,0:18:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis yang kucinta, tuanku sendiri,\Ntidak akan bisa kulindungi.
Dialogue: 0,0:18:27.04,0:18:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku pasti tidak tahu.
Dialogue: 0,0:18:30.77,0:18:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada manusia yang tidak bisa hidup\Ntanpa kebencian.
Dialogue: 0,0:18:36.30,0:18:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak dilindungi.
Dialogue: 0,0:18:38.18,0:18:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik Nona Hinagiku atau diriku akan mati.
Dialogue: 0,0:18:42.89,0:18:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku.
Dialogue: 0,0:18:45.15,0:18:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:46.55,0:18:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha memenuhi ucapanmu.
Dialogue: 0,0:18:50.28,0:18:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:18:52.40,0:18:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tolong sekali lagi\Nbilang "suka" padaku?
Dialogue: 0,0:18:57.41,0:19:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh tenaga untuk berusaha.
Dialogue: 0,0:19:00.91,0:19:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan musim seminya bisa tiba?
Dialogue: 0,0:19:02.66,0:19:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah tidak dibutuhkan lagi!
Dialogue: 0,0:19:05.54,0:19:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah memakan waktu setahun pun\Nutusannya masih belum bekerja.
Dialogue: 0,0:19:10.80,0:19:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, bukan?
Dialogue: 0,0:19:12.92,0:19:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasmu berakhir.
Dialogue: 0,0:19:15.81,0:19:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal baru mau mulai dari sini...
Dialogue: 0,0:19:18.14,0:19:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal baru dipercaya...
Dialogue: 0,0:19:20.06,0:19:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kukira bisa membalas budi...
Dialogue: 0,0:19:23.27,0:19:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu apa mereka soal dia selain diriku?
Dialogue: 0,0:19:25.98,0:19:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sehancur apa pun Nona Hinagiku\Ntetaplah Nona Hinagiku.
Dialogue: 0,0:19:30.15,0:19:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah dewaku!
Dialogue: 0,0:19:34.15,0:19:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin di sisi Nona Hinagiku...
Dialogue: 0,0:19:44.87,0:19:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma... musim semi?
Dialogue: 0,0:19:48.54,0:19:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:19:51.38,0:19:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini!
Dialogue: 0,0:19:52.38,0:19:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada di sini!
Dialogue: 0,0:20:01.14,0:20:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:20:03.52,0:20:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah bersamaku!
Dialogue: 0,0:20:06.45,0:20:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lakukan segalanya!
Dialogue: 0,0:20:08.44,0:20:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku berada di sisimu,\Nakan kupersembahkan diriku.
Dialogue: 0,0:20:13.13,0:20:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum bisa\Nmemberikan apa-apa untukmu.
Dialogue: 0,0:20:17.82,0:20:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini menakutkan.
Dialogue: 0,0:20:21.12,0:20:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski takut, tetap hidup...
Dialogue: 0,0:20:23.74,0:20:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih harus terus hidup...
Dialogue: 0,0:20:27.08,0:20:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungimu!
Dialogue: 0,0:20:29.42,0:20:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari hal seseram apa pun,\Npasti akan kulindungi!
Dialogue: 0,0:20:34.96,0:20:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu maumu,\Nakan kuucap berapa kali pun.
Dialogue: 0,0:20:38.59,0:20:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski itu begitu bodoh, begitu hina.
Dialogue: 0,0:20:40.93,0:20:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sakura...\N- Aku tahu itu...
Dialogue: 0,0:20:43.31,0:20:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:20:45.10,0:20:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesal melihat orang yang tidak kusuka\Ndapat perhatian tuanku dengan mudah,
Dialogue: 0,0:20:50.60,0:20:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu aku minta hal yang sama.
Dialogue: 0,0:20:52.69,0:20:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka padamu.
Dialogue: 0,0:20:54.65,0:20:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu tetap ingin.
Dialogue: 0,0:20:56.36,0:21:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin agar cintamu\Nhanya memandang diriku.
Dialogue: 0,0:21:00.20,0:21:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik sisi yang lembut,\Natau yang pemarah.
Dialogue: 0,0:21:05.20,0:21:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harapanku untuk hidup hanyalah dirimu.
Dialogue: 0,0:21:08.46,0:21:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka.
Dialogue: 0,0:21:10.39,0:21:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat cinta padamu.
Dialogue: 0,0:21:13.46,0:21:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap kali dirimu mencintai diriku.
Dialogue: 0,0:21:16.56,0:21:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya ada sesuatu yang diampuni\Ndi dalam diriku.
Dialogue: 0,0:21:19.97,0:21:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak apa-apa, ya, Sakura.
Dialogue: 0,0:21:25.81,0:21:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, aku juga menyukaimu.
Dialogue: 0,0:21:29.98,0:21:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, maafkan aku...
Dialogue: 0,0:21:32.65,0:21:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai aku bisa menyukaimu\Ndengan lebih normal lagi.
Dialogue: 0,0:21:36.07,0:21:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin terus kudengar di sisimu.
Dialogue: 0,0:21:38.61,0:21:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari paling dekat, tanpa pernah menjauh.
Dialogue: 0,0:21:41.36,0:21:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak bisa berfungsi\Njika tidak seperti ini.
Dialogue: 0,0:21:45.20,0:21:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, berapa kali pun akan aku katakan.
Dialogue: 0,0:21:48.54,0:21:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu, Sakura.
Dialogue: 0,0:21:53.75,0:21:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupakan itu.
Dialogue: 0,0:21:56.33,0:21:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka padamu.
Dialogue: 0,0:21:57.93,0:22:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku juga menyukaimu.
Dialogue: 0,0:22:01.97,0:22:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, setidaknya untuk sekarang,\Naku butuh kebencian serta ketergantungan.
Dialogue: 0,0:22:06.47,0:22:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya tak bisa kulepaskan.
Dialogue: 0,0:22:07.97,0:22:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan kulindungi selamanya.
Dialogue: 0,0:22:14.48,0:22:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka padamu, Sakura.
Dialogue: 0,0:22:17.15,0:22:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat, sangat menyukaimu.
Dialogue: 0,0:22:19.40,0:22:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ada di antara kami berdua\Nbukanlah cinta.
Dialogue: 0,0:22:23.07,0:22:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu lebih keras cinta,\Njuga lebih murni kasih.
Dialogue: 0,0:22:27.78,0:22:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sedikit rusak,\Nitu perasaan yang normal.
