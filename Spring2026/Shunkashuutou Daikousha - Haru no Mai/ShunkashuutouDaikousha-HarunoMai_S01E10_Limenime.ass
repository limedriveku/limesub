Dialogue: 0,0:01:08.72,0:01:17.43,sign,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:12:32.98,0:12:35.99,sign,,0000,0000,0000,,EPISODE 10: SISA BAYANGAN
Dialogue: 0,0:23:39.98,0:23:44.99,sign,,0000,0000,0000,,SELANJUTNYA: GELISAH
Dialogue: 0,0:00:06.57,0:00:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahan, menunggu saatnya bertempur.
Dialogue: 0,0:00:11.24,0:00:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunggu saatnya bertarung.
Dialogue: 0,0:00:14.74,0:00:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dirimulah yang bisa hidup,
Dialogue: 0,0:00:19.58,0:00:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku.
Dialogue: 0,0:01:56.76,0:02:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang bertanggung jawab\Natas sistem keamanan Istana Musim Gugur.
Dialogue: 0,0:02:00.64,0:02:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Nagatsuki.
Dialogue: 0,0:02:02.14,0:02:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah kehormatan bisa bertemu denganmu .
Dialogue: 0,0:02:05.40,0:02:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azami, kamu juga!
Dialogue: 0,0:02:07.94,0:02:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu.
Dialogue: 0,0:02:10.40,0:02:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pengawal utusan musim gugur,\NAzami Rindo.
Dialogue: 0,0:02:14.99,0:02:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong angkat kepala kalian.
Dialogue: 0,0:02:19.70,0:02:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mendapat pemberitahuan,
Dialogue: 0,0:02:21.66,0:02:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami datang untuk membantu.
Dialogue: 0,0:02:28.96,0:02:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski meluangkan diri untuk memeriksanya,
Dialogue: 0,0:02:31.71,0:02:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa ini hanya akan memberatkan hatimu.
Dialogue: 0,0:02:34.01,0:02:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini data kamera pengawas yang beruntungnya
Dialogue: 0,0:02:36.84,0:02:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih tersisa dan berhasil dipulihkan.
Dialogue: 0,0:02:39.22,0:02:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun masih belum bisa diidentifikasi.
Dialogue: 0,0:02:43.29,0:02:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada yang ingin aku tanyakan.
Dialogue: 0,0:02:45.44,0:02:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sampai rela sejauh ini?
Dialogue: 0,0:02:47.94,0:02:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Azami—
Dialogue: 0,0:02:49.11,0:02:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menjual budi?\NAtau justru uang?
Dialogue: 0,0:02:52.19,0:02:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan saja kalau ingin sesuatu.
Dialogue: 0,0:02:55.04,0:02:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:02:56.32,0:02:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini hampir tidak ada\Nyang bisa kami berikan.
Dialogue: 0,0:02:59.75,0:03:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kehilangan sebagian besar anggota,\Nreputasi juga terjun bebas.
Dialogue: 0,0:03:03.33,0:03:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa kuberikan hanyalah nyawaku.
Dialogue: 0,0:03:06.21,0:03:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu bisa menyelamatkan Nadeshiko,
Dialogue: 0,0:03:09.29,0:03:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah siap mengorbankan diriku!
Dialogue: 0,0:03:13.42,0:03:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami, sebagai seorang pelayan,\Nnyalimu patut dipuji tinggi.
Dialogue: 0,0:03:18.30,0:03:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukainya.
Dialogue: 0,0:03:20.68,0:03:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperjelas di awal.
Dialogue: 0,0:03:22.77,0:03:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim Semi tidak mengharap imbalan\Ndari Musim Gugur dalam bantuan kali ini.
Dialogue: 0,0:03:28.19,0:03:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami turut serta dalam pertempuran ini\Nuntuk menebus kekalahan satu dekade lalu.
Dialogue: 0,0:03:33.94,0:03:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun yang harus membayar harganya.
Dialogue: 0,0:03:37.41,0:03:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa menaruh curiga itu bisa dimengerti.
Dialogue: 0,0:03:40.70,0:03:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan ucapkan yang barusan\Npada Musim Panas.
Dialogue: 0,0:03:44.33,0:03:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sepenuhnya datang dengan niat baik.
Dialogue: 0,0:03:47.03,0:03:49.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi terserah mau bilang apa\Npada Musim Dingin.
Dialogue: 0,0:03:49.46,0:03:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim Panas dan Dingin juga?
Dialogue: 0,0:03:51.13,0:03:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan dengan mereka sebatas\Nbertukar salam di ritual.
Dialogue: 0,0:03:54.17,0:03:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada kewajiban membantu kami.
Dialogue: 0,0:03:56.05,0:03:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah ragu?
Dialogue: 0,0:03:58.22,0:03:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Tuan Azami.
Dialogue: 0,0:03:59.72,0:04:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini saat yang penting!
Dialogue: 0,0:04:01.72,0:04:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak mau menyelamatkan\NMusim Gugurmu?
Dialogue: 0,0:04:03.51,0:04:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kuselamatkan!
Dialogue: 0,0:04:04.89,0:04:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:04:06.48,0:04:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulatkan tekadmu!
Dialogue: 0,0:04:08.27,0:04:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah manfaatkan kami\Nuntuk menyelamatkan tuanmu!
Dialogue: 0,0:04:11.31,0:04:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu pengawalnya!
Dialogue: 0,0:04:13.61,0:04:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau nyalimu saja sudah ciut,
Dialogue: 0,0:04:15.36,0:04:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}utusan akan dikendalikan oleh orang-orang\Nyang hanya melihat mereka sebagai alat!
Dialogue: 0,0:04:19.86,0:04:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan menyesal selamanya.
Dialogue: 0,0:04:22.62,0:04:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai sepuluh tahun lalu mendapat\Nbantuan dari musim-musim lain...
Dialogue: 0,0:04:26.95,0:04:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kami bukanlah anak kecil\Nyang tidak berdaya...
Dialogue: 0,0:04:30.63,0:04:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya bisa saja berbeda.
Dialogue: 0,0:04:34.39,0:04:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka!\NAku benar-benar tersentuh!
Dialogue: 0,0:04:38.22,0:04:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azami boleh ciut, tapi aku pasti\Nakan menemukan Dik Fairy!
Dialogue: 0,0:04:41.93,0:04:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Nagatsuki, aku bukannya ciut—
Dialogue: 0,0:04:45.89,0:04:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bertengkar?
Dialogue: 0,0:04:49.35,0:04:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak bertengkar, kok.
Dialogue: 0,0:04:52.19,0:04:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hasilnya?
Dialogue: 0,0:04:57.32,0:05:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu orang yang sama...
Dialogue: 0,0:05:05.20,0:05:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu obrolannya.
Dialogue: 0,0:05:07.41,0:05:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kabar dari resepsionis di lantai satu.
Dialogue: 0,0:05:10.41,0:05:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo!
Dialogue: 0,0:05:13.67,0:05:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya sebelum ke sini,\Nkami pergi ke Tsukushi.
Dialogue: 0,0:05:16.84,0:05:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertanya ke hewan-hewan\Ndi sekitar Istana Musim Gugur
Dialogue: 0,0:05:19.84,0:05:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencoba melacak jejak Penyamun,
Dialogue: 0,0:05:21.80,0:05:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya saja langkahnya terputus di bandara.
Dialogue: 0,0:05:24.97,0:05:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah naik pesawat,
Dialogue: 0,0:05:26.47,0:05:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan Pengendali Hayat sekalipun\Nakan sulit dikejar.
Dialogue: 0,0:05:30.56,0:05:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf tidak bisa memberi kontribusi.
Dialogue: 0,0:05:32.77,0:05:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak.
Dialogue: 0,0:05:34.15,0:05:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ucapkan terima kasih\Nyang tulus dari lubuk hati.
Dialogue: 0,0:05:39.01,0:05:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga kini belum ada klaim\Nserta negosiasi ke pemerintah,
Dialogue: 0,0:05:42.25,0:05:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}identitas penyamun pun belum teridentifikasi.
Dialogue: 0,0:05:45.03,0:05:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, setelah rekaman kamera pengawas\Ndikonfirmasi oleh Nona Utusan Musim Semi,
Dialogue: 0,0:05:50.50,0:05:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}identitas penyamun akhirnya terungkap.
Dialogue: 0,0:05:57.96,0:06:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misuzu Henderson, kepala dari Kasai,\Norganisasi penyamun kubu reformasi.
Dialogue: 0,0:06:03.34,0:06:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang memimpin organisasi\Nsetelah mewarisinya dari sang ayah.
Dialogue: 0,0:06:06.84,0:06:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunya orang luar negeri.
Dialogue: 0,0:06:08.39,0:06:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang keturunan pedagang senjata
Dialogue: 0,0:06:10.52,0:06:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan punya koneksi kuat ke jaringan\Npenyelundup senjata luar negeri.
Dialogue: 0,0:06:14.40,0:06:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersamaan dengan peralihan generasi\Nke tangannya sepuluh tahun lalu,
Dialogue: 0,0:06:18.44,0:06:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasai memperluas pergerakan.
Dialogue: 0,0:06:20.90,0:06:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu bekerja sama\Ndengan organisasi pemberantas lain,
Dialogue: 0,0:06:24.24,0:06:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}merencanakan penyerangan besar\Nyang belum ada sebelumnya.
Dialogue: 0,0:06:27.36,0:06:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:06:28.87,0:06:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubu pemberantas adalah penyamun\Nyang membenci musim tertentu,
Dialogue: 0,0:06:32.16,0:06:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedangkan kubu reformasi adalah\Npenyamun yang ingin
Dialogue: 0,0:06:34.37,0:06:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatan utusan dipakai untuk hal lain\Nseperti penyelamatan dan perang, kan?
Dialogue: 0,0:06:38.29,0:06:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya bisa kerja sama?
Dialogue: 0,0:06:40.00,0:06:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya tidak mungkin.
Dialogue: 0,0:06:41.34,0:06:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski pandangan dan prinsipnya berbeda,
Dialogue: 0,0:06:43.51,0:06:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}asal tujuan mereka\Nuntuk membunuh utusan itu sama.
Dialogue: 0,0:06:46.72,0:06:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat mungkin terjadi.
Dialogue: 0,0:06:48.10,0:06:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa yang kayak begitu\Njangan sampai sama, dong.
Dialogue: 0,0:06:52.14,0:06:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah memotong pembicaraannya.
Dialogue: 0,0:06:54.60,0:06:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyerangan seperti apa yang disiapkan Kasai\Ndengan bekerja sama dengan penyamun lain?
Dialogue: 0,0:06:59.36,0:07:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hubungannya sama penculikan kali ini?
Dialogue: 0,0:07:02.90,0:07:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyerangan itulah
Dialogue: 0,0:07:05.49,0:07:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}insiden penyerangan Desa Musim Dingin\Npada sepuluh tahun lalu.
Dialogue: 0,0:07:08.91,0:07:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun kali ini adalah\Npenyamun yang sama
Dialogue: 0,0:07:13.45,0:07:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang pernah menculik Nona Hinagiku.
Dialogue: 0,0:07:20.13,0:07:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua tahun lalu, Nona Hinagiku kabur dengan\Nmeluluhlantakkan markas Kasai saat itu.
Dialogue: 0,0:07:25.88,0:07:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pun menyebabkan Kasai bubar.
Dialogue: 0,0:07:28.87,0:07:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:07:30.35,0:07:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misuzu Henderson yang menghilang\Ndiperkirakan membangunnya kembali.
Dialogue: 0,0:07:36.23,0:07:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai meledakkan\NIstana Musim Gugur,
Dialogue: 0,0:07:38.38,0:07:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sulit dibayangkan kalau dari awal\Nniatnya memang menculik.
Dialogue: 0,0:07:41.98,0:07:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun mempertanyakan itu.
Dialogue: 0,0:07:43.94,0:07:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi kemungkinan ini penyebabnya.
Dialogue: 0,0:07:47.45,0:07:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembusuk Hayat.
Dialogue: 0,0:07:49.74,0:07:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:50.66,0:07:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan mengendalikan hidup dan mati.
Dialogue: 0,0:07:53.24,0:07:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merasa dirinya dalam bahaya kematian,
Dialogue: 0,0:07:56.37,0:07:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu diperkirakan\Nmengaktifkannya tanpa sadar.
Dialogue: 0,0:07:59.33,0:08:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan yang luar biasa.
Dialogue: 0,0:08:01.59,0:08:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kepikiran kalau bisa dimanfaatkan.
Dialogue: 0,0:08:04.00,0:08:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diculik sekalian, musim gugur negeri ini\Nbisa dijadikan sandera.
Dialogue: 0,0:08:08.63,0:08:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga bisa, tapi...
Dialogue: 0,0:08:12.47,0:08:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan sebenarnya, kemungkinan...
Dialogue: 0,0:08:16.77,0:08:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin menjadikan Nona Utusan Musim Gugur\Nsebagai anaknya sendiri.
Dialogue: 0,0:08:23.52,0:08:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:24.65,0:08:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misuzu bilang kalau dulu\Ndia kehilangan anaknya.
Dialogue: 0,0:08:31.16,0:08:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya terasa pedih.
Dialogue: 0,0:08:34.65,0:08:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Utusan Musim Gugur\Nberusia tujuh tahun, kan?
Dialogue: 0,0:08:42.21,0:08:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usia yang "sangat pas"\Nuntuk disayang Misuzu.
Dialogue: 0,0:08:49.68,0:08:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin... do...
Dialogue: 0,0:08:53.93,0:08:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo?
Dialogue: 0,0:08:55.64,0:08:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:09:04.03,0:09:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak apa-apa?
Dialogue: 0,0:09:06.90,0:09:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidurmu lama sekali, lo.
Dialogue: 0,0:09:09.61,0:09:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:09:11.57,0:09:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:09:13.16,0:09:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah ibu di rumah ini.
Dialogue: 0,0:09:16.62,0:09:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini juga akan jadi ibumu.
Dialogue: 0,0:09:20.08,0:09:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ibundaku sedang bekerja\Ndengan Ayahanda di ibu kota.
Dialogue: 0,0:09:25.13,0:09:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang aku yang jadi ibu.
Dialogue: 0,0:09:27.51,0:09:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya.
Dialogue: 0,0:09:28.59,0:09:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kubilang aku ibunya,\Nya, aku ibunya.
Dialogue: 0,0:09:30.97,0:09:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa?
Dialogue: 0,0:09:34.60,0:09:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah kuputuskan begitu.
Dialogue: 0,0:09:36.81,0:09:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang bukan dewa sepertimu.
Dialogue: 0,0:09:39.23,0:09:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di sini akulah dewanya.
Dialogue: 0,0:09:42.73,0:09:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Nadeshiko.
Dialogue: 0,0:09:45.01,0:09:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara para penyamun, ada orang-orang\Nyang ingin memanfaatkan seorang utusan.
Dialogue: 0,0:09:49.19,0:09:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut mereka, punya kekuatan luar biasa\Njangan cuma untuk menggulirkan musim.
Dialogue: 0,0:09:53.70,0:09:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi juga harus digunakan\Nuntuk dunia atau semua orang.
Dialogue: 0,0:09:57.70,0:10:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, itu hanyalah dalih\Nuntuk melakukan tindak terorisme.
Dialogue: 0,0:10:03.54,0:10:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pernah kamu percaya.
Dialogue: 0,0:10:06.00,0:10:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong berjanjilah, padaku.
Dialogue: 0,0:10:11.73,0:10:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, coba panggil aku "Ibu".
Dialogue: 0,0:10:16.14,0:10:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukanlah ibundaku\Ndan mungkin penyamun,
Dialogue: 0,0:10:20.81,0:10:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi tidak akan kupanggil begitu!
Dialogue: 0,0:10:24.41,0:10:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak nakal.
Dialogue: 0,0:10:26.15,0:10:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo menurut sama perkataanku.
Dialogue: 0,0:10:27.86,0:10:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo mana?
Dialogue: 0,0:10:28.82,0:10:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana orang-orang istana?
Dialogue: 0,0:10:31.65,0:10:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pulangkan aku ke tempat Rindo!\N- Aku ini penyelamat nyawamu, lo.
Dialogue: 0,0:10:33.53,0:10:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mereka pasti khawatir!\N- Aku ini penyelamat nyawamu, lo.
Dialogue: 0,0:10:35.20,0:10:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu bisa bilang,"Terima kasih, Ibu," kan?\N- Rindo selalu seperti itu!
Dialogue: 0,0:10:39.16,0:10:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak suka kalau aku\Ntidak di tempat yang bisa dia lihat!
Dialogue: 0,0:10:42.41,0:10:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak mau ikut main petak umpet!
Dialogue: 0,0:10:44.92,0:10:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Nadeshiko!
Dialogue: 0,0:10:46.33,0:10:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Nadeshiko akan baik-baik saja?
Dialogue: 0,0:10:47.71,0:10:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama menurut pada perkataan Misuzu,\Nseharusnya tidak apa-apa.
Dialogue: 0,0:10:54.88,0:10:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau melawan...
Dialogue: 0,0:11:00.68,0:11:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuberi tahu.
Dialogue: 0,0:11:02.81,0:11:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini sudah dibuang.
Dialogue: 0,0:11:05.69,0:11:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada yang datang menyelamatkan.
Dialogue: 0,0:11:08.77,0:11:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kamu hilang,\Nsemua orang sekarang pasti lega.
Dialogue: 0,0:11:12.03,0:11:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu anak yang tidak diinginkan!
Dialogue: 0,0:11:13.65,0:11:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan sekali!
Dialogue: 0,0:11:18.25,0:11:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku yang akan jadi ibumu.
Dialogue: 0,0:11:22.12,0:11:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sekarang cuma punya aku.
Dialogue: 0,0:11:24.62,0:11:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang harus menurut sama\Napa yang kukatakan, ya.
Dialogue: 0,0:11:28.92,0:11:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham?
Dialogue: 0,0:11:40.35,0:11:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo...
Dialogue: 0,0:11:42.56,0:11:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong...
Dialogue: 0,0:11:44.31,0:11:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang yang bisa\Nmelawan Misuzu di Kasai.
Dialogue: 0,0:11:50.56,0:11:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggota Higan-Nishi yang bekerja sama\Ndengan mereka sepuluh tahun lalu,
Dialogue: 0,0:11:54.57,0:11:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya sebagian besar sudah dibunuh.
Dialogue: 0,0:11:56.90,0:12:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Kasai menyebar teror\Ndan kediktatoran Misuzu Henderson, begitu?
Dialogue: 0,0:12:03.29,0:12:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak bisa melawan
Dialogue: 0,0:12:06.54,0:12:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tiap hari dipaksa menggunakan\NPercepatan Hayat...
Dialogue: 0,0:12:13.30,0:12:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih spesifiknya?
Dialogue: 0,0:12:15.17,0:12:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku dipaksa oleh Penyamun
Dialogue: 0,0:12:18.13,0:12:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membudidayakan tanaman\Nyang jadi bahan obat terlarang.
Dialogue: 0,0:12:23.24,0:12:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan itu pada utusan yang terhormat...
Dialogue: 0,0:12:30.01,0:12:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko!
Dialogue: 0,0:12:32.98,0:12:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:12:36.94,0:12:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh tahun lalu,
Dialogue: 0,0:12:38.70,0:12:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasai menjadikan nyawa Nona Hinagiku\Nsebagai tameng
Dialogue: 0,0:12:41.16,0:12:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengajukan tuntutan\Ntidak masuk akal.
Dialogue: 0,0:12:43.24,0:12:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan kali ini juga.
Dialogue: 0,0:12:46.00,0:12:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti akan ada kontak, begitu?
Dialogue: 0,0:12:48.04,0:12:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti itu giliran kita!
Dialogue: 0,0:12:50.29,0:12:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tugas kita sekarang menunggu.
Dialogue: 0,0:12:53.29,0:12:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf.
Dialogue: 0,0:12:56.13,0:12:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku yang seharusnya\Npaling tegar di sini.
Dialogue: 0,0:13:05.26,0:13:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang sekarang paling menderita\Nadalah Tuan Azami.
Dialogue: 0,0:13:12.65,0:13:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon andalkan kami untuk apa pun.
Dialogue: 0,0:13:15.90,0:13:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tolong jangan patah semangat.
Dialogue: 0,0:13:21.57,0:13:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berusaha mencari sekeras ini.
Dialogue: 0,0:13:28.50,0:13:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi Utusan Musim Gugur, itu akan menjadi\Nharapan yang paling besar.
Dialogue: 0,0:13:36.96,0:13:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan adalah cahaya bagi utusannya.
Dialogue: 0,0:13:43.18,0:13:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nadeshiko pasti sedang menunggu.
Dialogue: 0,0:13:47.10,0:13:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan patah semangat.
Dialogue: 0,0:13:48.85,0:13:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita rebut kembali bersama-sama.
Dialogue: 0,0:13:54.61,0:13:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih...
Dialogue: 0,0:13:56.02,0:13:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:14:01.03,0:14:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah datang tiba-tiba.
Dialogue: 0,0:14:05.78,0:14:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menyelamatkan Utusan Musim Gugur,
Dialogue: 0,0:14:07.99,0:14:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami akan membentuk\NKoalisi Juang Empat Musim.
Dialogue: 0,0:14:10.50,0:14:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang menyampaikan itu.
Dialogue: 0,0:14:12.96,0:14:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kami dari Musim Semi\Nharus menolong Musim Gugur?
Dialogue: 0,0:14:17.75,0:14:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski utusan yang sekarang tidak kembali,
Dialogue: 0,0:14:20.21,0:14:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kelak utusan gugur selanjutnya\Npasti akan lahir.
Dialogue: 0,0:14:22.59,0:14:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koalisi Juang adalah hal yang sia-sia.
Dialogue: 0,0:14:29.64,0:14:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang bukan untuk berdiskusi\Nataupun meminta izin.
Dialogue: 0,0:14:33.60,0:14:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berani ganggu kami.
Dialogue: 0,0:14:36.65,0:14:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengerti?
Dialogue: 0,0:14:38.86,0:14:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu lagi.
Dialogue: 0,0:14:40.32,0:14:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang perlakukanlah Hinagiku\Ndan Sakura lebih baik lagi.
Dialogue: 0,0:14:45.11,0:14:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terjadi sesuatu pada mereka berdua...
Dialogue: 0,0:14:48.62,0:14:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Musim Semi ini pasti akan membeku.
Dialogue: 0,0:14:55.87,0:14:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek yang bikin susah saja.
Dialogue: 0,0:14:58.13,0:15:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau telah melindungi\NDesa Musim Semi begitu lama.
Dialogue: 0,0:15:02.05,0:15:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukanlah orang biasa.
Dialogue: 0,0:15:03.84,0:15:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja seperti siluman.
Dialogue: 0,0:15:09.30,0:15:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Pengawal Musim Gugur.
Dialogue: 0,0:15:12.52,0:15:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:15:14.60,0:15:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah berbagi informasi.
Dialogue: 0,0:15:17.35,0:15:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka penyamun yang sama\Ndengan sepuluh tahun lalu.
Dialogue: 0,0:15:20.57,0:15:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kantsubaki, semuanya kesalahanku.
Dialogue: 0,0:15:25.61,0:15:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai aku bisa melindungi Nadeshiko.
Dialogue: 0,0:15:29.53,0:15:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya tersadar setelah jadi begini.
Dialogue: 0,0:15:32.70,0:15:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku begitu menyayangi\Nmusim gugurku dari lubuk hati.
Dialogue: 0,0:15:37.37,0:15:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini tidak sadar, ya?
Dialogue: 0,0:15:39.75,0:15:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, jangan terlalu disesali.
Dialogue: 0,0:15:42.09,0:15:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini peringatan dari yang pernah mengalaminya.
Dialogue: 0,0:15:44.26,0:15:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyesalan akan menggerogoti jiwa raga.
Dialogue: 0,0:15:47.01,0:15:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti tidak bisa membuat keputusan\Nyang tenang di saat darurat.
Dialogue: 0,0:15:50.14,0:15:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang pikirkan saja cara\Nmenyelamatkan musim gugurmu.
Dialogue: 0,0:15:53.72,0:15:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:54.52,0:15:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utang ini pasti akan kubalas!
Dialogue: 0,0:15:56.85,0:15:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipikir seberat itu.
Dialogue: 0,0:15:58.65,0:16:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bilang begitu, akan kubayar\Ndengan mengerahkan segalanya.
Dialogue: 0,0:16:02.19,0:16:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, berat sekali.
Dialogue: 0,0:16:06.28,0:16:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong...
Dialogue: 0,0:16:08.34,0:16:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Utusan Musim Semi baik-baik saja?
Dialogue: 0,0:16:11.24,0:16:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku mendapat kalimat penyemangat\Ndari Nona Kayo.
Dialogue: 0,0:16:16.40,0:16:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengingat musuh dalam kejadian ini\Npasti membuat hatinya campur aduk,
Dialogue: 0,0:16:20.42,0:16:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sikapnya begitu tegar.
Dialogue: 0,0:16:23.05,0:16:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau sangat baik hati, ya.
Dialogue: 0,0:16:25.80,0:16:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa butuh sesuatu dengan Nona Kayo?
Dialogue: 0,0:16:28.01,0:16:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya sedikit teringat masa lalu.
Dialogue: 0,0:16:38.19,0:16:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan makan waktu, ya.
Dialogue: 0,0:16:39.85,0:16:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti gara-gara memungut utusan\Nyang seharusnya dibunuh.
Dialogue: 0,0:16:43.44,0:16:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga sudah cepat.
Dialogue: 0,0:16:46.49,0:16:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa anak itu sehat-sehat saja, ya?
Dialogue: 0,0:16:50.41,0:16:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mentalnya sudah hancur.
Dialogue: 0,0:16:52.95,0:16:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aneh bisa kembali pulih.
Dialogue: 0,0:16:58.08,0:17:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, anak itu sekarang adalah\Ndirinya yang telah hancur, ya?
Dialogue: 0,0:17:03.34,0:17:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:17:05.06,0:17:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang menghancurkannya.
Dialogue: 0,0:17:06.83,0:17:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti sama denganku, dong.\NSerasi sekali.
Dialogue: 0,0:17:12.33,0:17:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya memang anak itu\Nyang cocok jadi putriku.
Dialogue: 0,0:17:18.06,0:17:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mikami...
Dialogue: 0,0:17:20.73,0:17:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku, ya.
Dialogue: 0,0:17:23.06,0:17:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditanya kenapa?\NAku tidak bisa menolaknya.
Dialogue: 0,0:17:44.08,0:17:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ayo bantu aku.
Dialogue: 0,0:17:56.18,0:17:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang aneh.
Dialogue: 0,0:17:57.81,0:18:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang minta dibantu itu kamu.
Dialogue: 0,0:18:01.52,0:18:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:03.02,0:18:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berutang banyak pada ayahmu.
Dialogue: 0,0:18:06.36,0:18:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja.
Dialogue: 0,0:18:08.32,0:18:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Tuan Putri sendiri melakukan ini\Nkarena tidak punya pilihan?
Dialogue: 0,0:18:14.28,0:18:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih
Dialogue: 0,0:18:17.72,0:18:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah mau menolongku.
Dialogue: 0,0:18:26.29,0:18:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini seperti pahlawan, ya.
Dialogue: 0,0:18:33.51,0:18:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak saat itu,\Nanehnya malah lengket padaku.
Dialogue: 0,0:18:37.97,0:18:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mikami, dunia ini sudah keliru.
Dialogue: 0,0:18:41.98,0:18:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski orang-orang lemah meminta tolong,
Dialogue: 0,0:18:44.98,0:18:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak semuanya\Nakan menolong seperti dirimu.
Dialogue: 0,0:18:47.94,0:18:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu harus kuubah sendiri.
Dialogue: 0,0:18:50.90,0:18:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku tidak boleh lemah.
Dialogue: 0,0:18:53.57,0:18:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi untuk permulaan,\Nsang dewa harus...
Dialogue: 0,0:19:00.04,0:19:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan empat musim itu mahaguna.
Dialogue: 0,0:19:03.37,0:19:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau dibunuh, katanya akan lahir yang baru.
Dialogue: 0,0:19:07.58,0:19:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan terus, terus, dan terus kita bunuh
Dialogue: 0,0:19:12.88,0:19:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu ayo ancam pemerintah,\Nuntuk mengubah dunia.
Dialogue: 0,0:19:18.30,0:19:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin berdebar saja, ya, Mikami.
Dialogue: 0,0:19:22.77,0:19:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bunuh para dewa bersama-sama.
Dialogue: 0,0:19:28.61,0:19:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan masuk dari Penyamun!
Dialogue: 0,0:19:30.19,0:19:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun menuntut uang tebusan yang besar\Ndan perubahan hukum empat musim.
Dialogue: 0,0:19:34.53,0:19:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utamanya menuntut perluasan
Dialogue: 0,0:19:36.78,0:19:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penggunaan kekuatan utusan\Ndemi rakyat dan wilayah Yamato.
Dialogue: 0,0:19:41.28,0:19:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu juga pembebasan\Nrekan-rekan yang ditahan.
Dialogue: 0,0:19:44.20,0:19:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, itu jelas mustahil!
Dialogue: 0,0:19:46.25,0:19:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biro Empat Musim berniat menolak semuanya\Nselain uang tebusan.
Dialogue: 0,0:19:49.73,0:19:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi sambungannya diputus\Ntanpa memberi celah negosiasi.
Dialogue: 0,0:19:53.84,0:19:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi lokasi sumbernya\Nberhasil diidentifikasi.
Dialogue: 0,0:19:57.72,0:20:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski para penyamun telah melarikan diri,
Dialogue: 0,0:20:00.35,0:20:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa mungkin melacak jejak mereka dengan\Nkekuatan Nona Utusan Musim Panas?
Dialogue: 0,0:20:03.97,0:20:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya!
Dialogue: 0,0:20:05.43,0:20:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua tolong tinggal di sini.
Dialogue: 0,0:20:07.56,0:20:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:20:08.15,0:20:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi akan ada tuntutan\Natau pergerakan lagi dari penyamun.
Dialogue: 0,0:20:12.15,0:20:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Nona Kayo yang paling mengerti\Nsoal penyamun kali ini.
Dialogue: 0,0:20:16.74,0:20:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, sebentar lagi\NUtusan Musim Dingin juga akan tiba!
Dialogue: 0,0:20:20.20,0:20:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada kamu, dia pasti senang, lo!
Dialogue: 0,0:20:23.08,0:20:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:20:25.08,0:20:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya tolong urus yang di sini, ya.
Dialogue: 0,0:20:27.50,0:20:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kayo, Nona Himedaka.
Dialogue: 0,0:20:30.63,0:20:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku berterima kasih lagi.
Dialogue: 0,0:20:32.34,0:20:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapan kalian telah menyelamatkanku.
Dialogue: 0,0:20:35.05,0:20:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko pasti akan kuselamatkan!
Dialogue: 0,0:20:43.22,0:20:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami begitu hebat, ya.
Dialogue: 0,0:20:46.68,0:20:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia yang paling menderita saat ini.
Dialogue: 0,0:20:50.06,0:20:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:20:52.56,0:20:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku anak yang tidak dibutuhkan.
Dialogue: 0,0:20:58.95,0:21:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak kembali sekalipun,
Dialogue: 0,0:21:01.66,0:21:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}utusan penggantinya pasti segera terlahir.
Dialogue: 0,0:21:05.95,0:21:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang juga tidak peduli\Nkalau misalkan bukan aku.
Dialogue: 0,0:21:13.17,0:21:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku pikir lebih baik\Nkalau cepat mati saja.
Dialogue: 0,0:21:21.22,0:21:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, akhirnya memilih untuk hidup.
Dialogue: 0,0:21:27.43,0:21:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu orang yang membutuhkanku...
Dialogue: 0,0:21:34.40,0:21:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang menungguku,\Nternyata sungguhan ada.
Dialogue: 0,0:21:40.40,0:21:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada hal lain yang bisa kulakukan\Nselain hidup sebagai
Dialogue: 0,0:21:47.37,0:21:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}utusan musim semi.
Dialogue: 0,0:21:49.58,0:21:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak diinginkan oleh semua orang,
Dialogue: 0,0:21:54.77,0:21:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku masih bisa berguna.
Dialogue: 0,0:21:59.59,0:22:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi aku kembali pulang untuk ini.
