Dialogue: 0,0:01:55.68,0:02:04.44,sign,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:19:58.01,0:19:58.80,sign,,0000,0000,0000,,EPISODE TIGA BELAS: MEREBUT KEMBALI
Dialogue: 0,0:23:01.23,0:23:02.99,sign,,0000,0000,0000,,KANTSUBAKI ROSEI - TELEPON SELESAI
Dialogue: 0,0:23:40.02,0:23:45.03,sign,,0000,0000,0000,,SELANJUTNYA: BUNGA MUSIM SEMI\NYANG MEKAR DI MUSIM DINGIN
Dialogue: 0,0:00:08.24,0:00:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo.
Dialogue: 0,0:00:10.78,0:00:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:00:13.20,0:00:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:00:17.00,0:00:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badan Keamanan Negara ada urusan apa?
Dialogue: 0,0:00:19.54,0:00:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan kami memeriksa ke dalam.
Dialogue: 0,0:00:21.83,0:00:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami punya surat perintah.
Dialogue: 0,0:00:23.04,0:00:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:00:23.88,0:00:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maumu seenaknya begitu?
Dialogue: 0,0:00:25.71,0:00:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi dimulai,\Nkalian berdua tolong sesuai rencana.
Dialogue: 0,0:00:30.34,0:00:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serbu!
Dialogue: 0,0:00:33.47,0:00:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dimulai.
Dialogue: 0,0:00:34.68,0:00:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu.
Dialogue: 0,0:00:35.93,0:00:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan yang di sini pada kami, Tuan Azami!
Dialogue: 0,0:00:38.35,0:00:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Nadeshiko pasti bisa kita rebut kembali!
Dialogue: 0,0:00:42.61,0:00:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, sekarang
Dialogue: 0,0:00:45.32,0:00:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktunya kita juga berjuang!
Dialogue: 0,0:00:50.15,0:00:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:55.16,0:00:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan.
Dialogue: 0,0:01:00.62,0:01:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan...
Dialogue: 0,0:01:03.67,0:01:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko.
Dialogue: 0,0:01:06.21,0:01:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim gugurku!
Dialogue: 0,0:02:45.93,0:02:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa!
Dialogue: 0,0:02:47.11,0:02:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kita adalah merebut kembali\NNona Utusan Musim Gugur!
Dialogue: 0,0:02:50.98,0:02:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi kalau sedang\Ndisekap di gedung ini!
Dialogue: 0,0:02:54.74,0:02:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan untuk menemukannya!
Dialogue: 0,0:02:57.37,0:03:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami dan Badan Keamanan Negara\Nakan menyisir bagian dalam bangunan.
Dialogue: 0,0:03:02.25,0:03:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mempertimbangkan cerita Nona Kayo,
Dialogue: 0,0:03:04.66,0:03:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehendak Misuzu Henderson sebagai pemimpin\Nadalah keputusan mutlak bagi Kasai.
Dialogue: 0,0:03:09.13,0:03:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sengaja menculik Nona Nadeshiko\Ndan ingin memanfaatkan beliau,
Dialogue: 0,0:03:14.09,0:03:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemungkinannya dibunuh akan nihil.
Dialogue: 0,0:03:16.76,0:03:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehilangan Nona Nadeshiko justru\Nakan jadi masalah bagi musuh.
Dialogue: 0,0:03:21.31,0:03:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:03:29.90,0:03:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinyal dari Nona Ruri?
Dialogue: 0,0:03:31.40,0:03:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti!
Dialogue: 0,0:03:32.73,0:03:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami!
Dialogue: 0,0:03:34.36,0:03:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun yang di dalam\Nbiar kami tahan!
Dialogue: 0,0:03:37.07,0:03:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan pergi saja!
Dialogue: 0,0:03:42.99,0:03:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang banget, ya.
Dialogue: 0,0:03:44.54,0:03:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat kabur.
Dialogue: 0,0:03:50.00,0:03:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai tidak lari,
Dialogue: 0,0:03:51.46,0:03:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti di dalamnya ada sesuatu\Nyang begitu berharga, ya?
Dialogue: 0,0:03:55.05,0:03:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini bilang,\Nada aroma Nona Nadeshiko dari koper itu.
Dialogue: 0,0:03:59.80,0:04:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taruh itu perlahan ke tanah\Ndan tunjukkan isinya.
Dialogue: 0,0:04:04.29,0:04:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:04:09.90,0:04:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja mereka tidak mungkin sendirian.
Dialogue: 0,0:04:14.98,0:04:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuperintahkan!
Dialogue: 0,0:04:16.52,0:04:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lindungilah Nona Nadeshiko!
Dialogue: 0,0:04:19.45,0:04:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak apa-apa.
Dialogue: 0,0:04:21.91,0:04:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lindungilah Utusan Musim Gugur!
Dialogue: 0,0:04:25.08,0:04:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perintah kuterima!
Dialogue: 0,0:04:27.04,0:04:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi!
Dialogue: 0,0:04:28.21,0:04:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tahu!
Dialogue: 0,0:04:36.59,0:04:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya, Kak.
Dialogue: 0,0:04:38.97,0:04:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:04:43.05,0:04:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun membuatku benar-benar kesal.
Dialogue: 0,0:04:46.18,0:04:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, sebagai ganti Kakak,\Ntolong aku, ya.
Dialogue: 0,0:04:58.86,0:05:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lindungilah diriku!
Dialogue: 0,0:05:08.33,0:05:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya!
Dialogue: 0,0:05:11.33,0:05:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya!
Dialogue: 0,0:05:12.71,0:05:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya!
Dialogue: 0,0:05:18.34,0:05:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya!
Dialogue: 0,0:05:21.26,0:05:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada habisnya!
Dialogue: 0,0:05:23.01,0:05:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau datang lebih banyak lagi,\Nmereka tidak akan kuat!
Dialogue: 0,0:05:27.85,0:05:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:05:39.24,0:05:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf terlambat!
Dialogue: 0,0:05:40.74,0:05:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku urus sisanya!
Dialogue: 0,0:05:43.32,0:05:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rindo!
Dialogue: 0,0:05:46.41,0:05:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamatkanlah Nona Nadeshiko!
Dialogue: 0,0:05:52.92,0:05:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:05:54.13,0:05:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:05:54.92,0:05:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami!
Dialogue: 0,0:05:56.29,0:05:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orangnya!
Dialogue: 0,0:05:57.67,0:06:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejar pria besar itu!
Dialogue: 0,0:06:00.67,0:06:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nadeshiko ada di dalamnya!
Dialogue: 0,0:06:03.30,0:06:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habis kita kalau dia sampai kabur!
Dialogue: 0,0:06:04.80,0:06:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, masih banyak Penyamun—
Dialogue: 0,0:06:06.18,0:06:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak apa-apa!
Dialogue: 0,0:06:08.14,0:06:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi saja!
Dialogue: 0,0:06:10.89,0:06:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:06:16.44,0:06:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, kita tinggal perlu menahan mereka.
Dialogue: 0,0:06:20.36,0:06:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri! Bahaya, kamu mundur saja!
Dialogue: 0,0:06:23.45,0:06:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bakal ikut bertarung sama-sama!
Dialogue: 0,0:06:27.70,0:06:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang jadi pengawal.
Dialogue: 0,0:06:30.45,0:06:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau begitu, kamu nanti...
Dialogue: 0,0:06:33.91,0:06:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri, tidak apa-apa.
Dialogue: 0,0:06:37.46,0:06:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang ingin begitu.
Dialogue: 0,0:06:41.46,0:06:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua, lindungilah Kakak.
Dialogue: 0,0:06:45.34,0:06:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, asal aku dan Kakak\Nmenyatukan kekuatan
Dialogue: 0,0:06:50.10,0:06:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti akan menang!
Dialogue: 0,0:07:03.03,0:07:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:07:15.29,0:07:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nade— Shiko...
Dialogue: 0,0:07:19.17,0:07:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nade... shiko...
Dialogue: 0,0:07:46.36,0:07:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh.
Dialogue: 0,0:07:49.20,0:07:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi pembunuh sekalipun aku tidak peduli.
Dialogue: 0,0:07:52.99,0:07:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku peduli.
Dialogue: 0,0:07:56.66,0:07:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim gugurku...
Dialogue: 0,0:07:59.92,0:08:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko milikku...
Dialogue: 0,0:08:14.60,0:08:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko...
Dialogue: 0,0:08:18.60,0:08:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko!
Dialogue: 0,0:08:23.61,0:08:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, celaka.
Dialogue: 0,0:08:30.07,0:08:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kukira bisa membantu Kakak.
Dialogue: 0,0:08:35.28,0:08:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah tidak berguna.
Dialogue: 0,0:08:37.50,0:08:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Kak.
Dialogue: 0,0:08:42.59,0:08:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:48.51,0:08:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri?
Dialogue: 0,0:08:57.89,0:09:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, Ruri, sedang apa kamu—
Dialogue: 0,0:09:13.57,0:09:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong.
Dialogue: 0,0:09:15.08,0:09:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bohong.
Dialogue: 0,0:09:16.91,0:09:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri.
Dialogue: 0,0:09:18.37,0:09:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyusahkan saja.
Dialogue: 0,0:09:21.67,0:09:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:09:23.08,0:09:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame.
Dialogue: 0,0:09:30.59,0:09:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame.
Dialogue: 0,0:09:33.51,0:09:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:09:39.48,0:09:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame.
Dialogue: 0,0:09:41.10,0:09:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:09:42.44,0:09:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame.
Dialogue: 0,0:09:43.81,0:09:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayame...\N- Sakit!
Dialogue: 0,0:09:45.77,0:09:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame...
Dialogue: 0,0:09:53.16,0:09:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan leluconmu itu...
Dialogue: 0,0:09:57.03,0:09:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame.
Dialogue: 0,0:09:58.41,0:09:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayame...\N- Hei...
Dialogue: 0,0:10:00.41,0:10:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bilang kalau ini bohong!
Dialogue: 0,0:10:02.41,0:10:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame.
Dialogue: 0,0:10:09.59,0:10:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:10:11.34,0:10:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat seorang utusan mati.
Dialogue: 0,0:10:13.22,0:10:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Dewa...
Dialogue: 0,0:10:14.55,0:10:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari anggota suku keempat musim...
Dialogue: 0,0:10:16.26,0:10:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Dewa!
Dialogue: 0,0:10:17.47,0:10:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...akan dipilih penggantinya oleh para dewa.
Dialogue: 0,0:10:25.10,0:10:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:10:29.65,0:10:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko! Nadeshiko!
Dialogue: 0,0:10:31.57,0:10:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, ayo bangun!
Dialogue: 0,0:10:34.49,0:10:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil lagi namaku dengan suaramu itu!
Dialogue: 0,0:10:39.54,0:10:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin... do...
Dialogue: 0,0:10:43.75,0:10:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo?
Dialogue: 0,0:10:45.29,0:10:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko?
Dialogue: 0,0:10:47.04,0:10:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku!\NBisa mengerti?
Dialogue: 0,0:10:49.63,0:10:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:50.80,0:10:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria sekaligus pangeranku, Azami Rindo.
Dialogue: 0,0:10:58.18,0:11:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar-benar keren.
Dialogue: 0,0:11:33.42,0:11:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Dewa Musim Panas itu
Dialogue: 0,0:11:36.84,0:11:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}begitu bodoh?
Dialogue: 0,0:11:38.93,0:11:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur!
Dialogue: 0,0:11:45.85,0:11:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kami saudari kembar?
Dialogue: 0,0:11:49.52,0:11:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar bikin muak.
Dialogue: 0,0:11:52.42,0:11:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senandung Ruri sudah melekat di kepalaku.
Dialogue: 0,0:11:55.19,0:11:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku selalu di sisinya?
Dialogue: 0,0:11:57.66,0:12:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu di sisinya.
Dialogue: 0,0:12:30.98,0:12:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri.
Dialogue: 0,0:12:33.61,0:12:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak malah jadi utusan musim panas.
Dialogue: 0,0:12:39.36,0:12:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jadi masalah dari kita berdua\Nitu jahat sekali, ya.
Dialogue: 0,0:12:44.37,0:12:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau siapa saja tidak jadi masalah.
Dialogue: 0,0:12:47.87,0:12:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik aku mati saja.
Dialogue: 0,0:12:54.34,0:13:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri, ayo kita sama-sama\Nprotes ke sang Dewa.
Dialogue: 0,0:13:11.56,0:13:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang...
Dialogue: 0,0:13:13.23,0:13:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang kamu lakukan?
Dialogue: 0,0:13:16.44,0:13:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami...
Dialogue: 0,0:13:19.86,0:13:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hazakura Ayame...
Dialogue: 0,0:13:24.87,0:13:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Iwaizuki?
Dialogue: 0,0:13:30.08,0:13:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri... Ruri sudah...
Dialogue: 0,0:13:35.63,0:13:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:13:38.13,0:13:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gagal melindunginya...
Dialogue: 0,0:13:41.30,0:13:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikku...
Dialogue: 0,0:13:55.23,0:13:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo.
Dialogue: 0,0:13:58.23,0:14:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih hangat.
Dialogue: 0,0:14:05.99,0:14:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau mencobanya?
Dialogue: 0,0:14:08.04,0:14:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:09.29,0:14:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada aliran energi roh dari gunung ini.
Dialogue: 0,0:14:12.79,0:14:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga ambil sedikit dari\Norang-orang yang masih sehat.
Dialogue: 0,0:14:16.59,0:14:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan mengambil nyawanya, kok.
Dialogue: 0,0:14:22.01,0:14:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ayame.
Dialogue: 0,0:14:23.34,0:14:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu kalau aku punya\Nkekuatan Pembusuk Hayat, bukan?
Dialogue: 0,0:14:29.56,0:14:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Nona Ayame.
Dialogue: 0,0:14:35.15,0:14:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti tidak apa-apa.
Dialogue: 0,0:14:37.82,0:14:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Nadeshiko,\Ntolonglah Nona Ruri.
Dialogue: 0,0:14:42.90,0:14:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal hidup dan mati adalah ranahku.
Dialogue: 0,0:14:47.66,0:14:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku!
Dialogue: 0,0:14:57.71,0:14:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:15:00.42,0:15:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ayame, jangan khawatir.
Dialogue: 0,0:15:06.18,0:15:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila ada Rindo, diriku
Dialogue: 0,0:15:09.18,0:15:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa melakukan apa saja.
Dialogue: 0,0:15:15.69,0:15:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:15:18.86,0:15:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, selalu merepotkanmu.
Dialogue: 0,0:15:23.78,0:15:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku jadi adik\Nyang lebih baik lagi.
Dialogue: 0,0:15:28.28,0:15:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dengan begini.
Dialogue: 0,0:15:31.20,0:15:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kakak jadi bisa hidup\Ndengan tenang, ya?
Dialogue: 0,0:15:35.66,0:15:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, maaf, ya.
Dialogue: 0,0:15:41.21,0:15:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:15:45.17,0:15:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:15:49.51,0:15:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:15:52.93,0:15:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:15:55.14,0:15:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:15:57.06,0:15:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:15:59.06,0:16:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:16:01.32,0:16:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:16:03.48,0:16:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri!
Dialogue: 0,0:16:21.29,0:16:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri...
Dialogue: 0,0:16:23.46,0:16:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri?
Dialogue: 0,0:16:26.38,0:16:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri hidup.
Dialogue: 0,0:16:28.05,0:16:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hidup.
Dialogue: 0,0:16:31.39,0:16:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:33.31,0:16:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:16:38.02,0:16:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:16:39.27,0:16:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru aku yang harus berterima kasih.
Dialogue: 0,0:16:42.48,0:16:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah diselamatkan.
Dialogue: 0,0:16:44.90,0:16:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku diselamatkan.
Dialogue: 0,0:16:47.61,0:16:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko, kamu pintar.
Dialogue: 0,0:16:51.20,0:16:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar pintar.
Dialogue: 0,0:16:53.49,0:16:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk kamu juga!\NTerima kasih.
Dialogue: 0,0:16:56.12,0:16:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya...
Dialogue: 0,0:16:58.54,0:17:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menangis?
Dialogue: 0,0:17:00.12,0:17:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, biar kuelus-elus dirimu.
Dialogue: 0,0:17:02.83,0:17:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak usah.
Dialogue: 0,0:17:05.88,0:17:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu biar kuelus Nona Ayame.
Dialogue: 0,0:17:09.01,0:17:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ayame.
Dialogue: 0,0:17:10.43,0:17:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuelus, elus.
Dialogue: 0,0:17:12.08,0:17:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No-Nona Iwaizuki...
Dialogue: 0,0:17:19.94,0:17:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah nangis lagi?
Dialogue: 0,0:17:29.19,0:17:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:31.45,0:17:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:32.45,0:17:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong segera siapkan helikopter medis\Nuntuk Nona Ruri dan Ayame juga.
Dialogue: 0,0:17:40.46,0:17:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Rindo.
Dialogue: 0,0:17:42.83,0:17:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, saat aku sedang ditangkap,\Naku bermimpi tentangmu.
Dialogue: 0,0:17:49.30,0:17:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:17:51.17,0:17:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ingat saat kamu membuatkan\Nkarangan bunga dari daun ginkgo?
Dialogue: 0,0:17:58.10,0:17:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:59.31,0:18:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat senang.
Dialogue: 0,0:18:01.18,0:18:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku selalu memikirkan saat itu,\Nmemikirkan tentangmu.
Dialogue: 0,0:18:07.19,0:18:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski takut, aku jadi bisa berjuang.
Dialogue: 0,0:18:12.15,0:18:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan lagi berapa kali pun,\Nakan kulakukan tiap tahun!
Dialogue: 0,0:18:15.53,0:18:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:16.91,0:18:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko, maaf aku tidak bisa melindungimu.
Dialogue: 0,0:18:20.16,0:18:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu yang begitu manis\Nsekarang terluka sebanyak ini.
Dialogue: 0,0:18:25.46,0:18:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf.
Dialogue: 0,0:18:27.46,0:18:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang akan kutebus seumur hidupku,\Nakan kulayani dirimu sampai mati.
Dialogue: 0,0:18:32.01,0:18:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menebusnya, Nadeshiko.
Dialogue: 0,0:18:35.72,0:18:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ih, Rindo.
Dialogue: 0,0:18:38.97,0:18:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu merasa sikapmu berubah?
Dialogue: 0,0:18:42.39,0:18:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:43.02,0:18:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang sekarang juga tetap menawan.
Dialogue: 0,0:18:46.98,0:18:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini Rindo yang sebenarnya, ya.
Dialogue: 0,0:18:55.20,0:18:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo, darahnya...
Dialogue: 0,0:18:58.24,0:18:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu luka?
Dialogue: 0,0:18:59.95,0:19:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak...
Dialogue: 0,0:19:02.54,0:19:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menyentuhmu dengan tangan kotor ini.
Dialogue: 0,0:19:05.29,0:19:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kotor, kok.
Dialogue: 0,0:19:09.25,0:19:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang seperti apa pun,\Naku pasti
Dialogue: 0,0:19:14.26,0:19:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti tetap menyukaimu!
Dialogue: 0,0:19:24.52,0:19:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa pun kamu, bagiku tetaplah\Npangeran yang menawan.
Dialogue: 0,0:19:31.23,0:19:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus dan akan terus begitu.
Dialogue: 0,0:19:33.90,0:19:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan berubah.
Dialogue: 0,0:19:37.11,0:19:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menyukaimu, Rindo!
Dialogue: 0,0:19:44.96,0:19:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:46.83,0:19:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan apa pun\Nbila itu demi dirimu.
Dialogue: 0,0:19:50.00,0:19:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuserahkan segala yang kumiliki.
Dialogue: 0,0:19:53.09,0:19:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila demi tuan putriku,\Nberapa kali pun aku akan
Dialogue: 0,0:19:58.80,0:20:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi seorang pangeran.
Dialogue: 0,0:21:34.56,0:21:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:21:37.03,0:21:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:21:39.40,0:21:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku.
Dialogue: 0,0:21:43.45,0:21:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:21:45.70,0:21:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terluka tidak?
Dialogue: 0,0:21:48.95,0:21:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:51.46,0:21:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal begitu...\Npadahal sudah begitu kubenci.
Dialogue: 0,0:21:57.38,0:21:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma dengar suaranya.
Dialogue: 0,0:22:01.93,0:22:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa begitu...
Dialogue: 0,0:22:05.18,0:22:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggulah sebentar lagi,\Naku sedang ke sana.
Dialogue: 0,0:22:12.39,0:22:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menangis, akan lebih menyakitkan\Ndari apa pun bila kamu menangis.
Dialogue: 0,0:22:16.56,0:22:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menangis!
Dialogue: 0,0:22:17.98,0:22:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong.
Dialogue: 0,0:22:19.44,0:22:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya mau bicara padaku\Nsetelah sekian lama.
Dialogue: 0,0:22:22.63,0:22:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:22:25.91,0:22:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:22:28.16,0:22:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu masih membenciku?
Dialogue: 0,0:22:31.71,0:22:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak yang ingin kamu katakan, bukan?
Dialogue: 0,0:22:34.58,0:22:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kudengar semua,\Nmau kamu pukul pun tidak apa-apa.
Dialogue: 0,0:22:38.21,0:22:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itu, aku ingin menemuimu hidup-hidup.
Dialogue: 0,0:22:42.97,0:22:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti tidak percaya,\Ntapi aku ada di pihakmu.
Dialogue: 0,0:22:47.97,0:22:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pernah berubah.
Dialogue: 0,0:22:49.47,0:22:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka!
Dialogue: 0,0:22:50.72,0:22:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Karena itu jangan menangis.\N- Musuh akan tiba!
Dialogue: 0,0:22:52.10,0:22:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong waspada!
Dialogue: 0,0:22:53.77,0:22:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggulah di sana.
Dialogue: 0,0:22:57.94,0:22:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat ke sini!
Dialogue: 0,0:23:02.99,0:23:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat ke sini.
Dialogue: 0,0:23:06.45,0:23:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho.
Dialogue: 0,0:23:10.83,0:23:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bergegas, Itecho.
Dialogue: 0,0:23:13.75,0:23:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua sudah menunggu.
Dialogue: 0,0:23:18.08,0:23:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku.
Dialogue: 0,0:23:20.50,0:23:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:23:27.51,0:23:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:23:31.14,0:23:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku bersamamu!
Dialogue: 0,0:23:36.90,0:23:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pinjam kekuatannya.
