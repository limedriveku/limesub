Dialogue: 0,0:01:04.70,0:01:13.47,sign,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:14:38.07,0:14:39.07,sign,,0000,0000,0000,,HIMEDAKA SAKURA
Dialogue: 0,0:14:55.67,0:14:57.58,sign,,0000,0000,0000,,TIDAK TERJAWAB - HIMEDAKA SAKURA
Dialogue: 0,0:15:37.12,0:15:39.00,sign,,0000,0000,0000,,KANTSUBAKI ROSEI - MEMANGGIL
Dialogue: 0,0:22:05.93,0:22:07.88,sign,,0000,0000,0000,,EPISODE SEBELAS: GELISAH
Dialogue: 0,0:23:39.94,0:23:44.94,sign,,0000,0000,0000,,SELANJUTNYA: SERANGAN
Dialogue: 0,0:00:05.49,0:00:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membutuhkan amarah.
Dialogue: 0,0:00:08.99,0:00:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seakan tidak bisa hidup tanpa kebencian,
Dialogue: 0,0:00:11.99,0:00:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga tidak bisa melangkah maju.
Dialogue: 0,0:00:15.92,0:00:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:01:48.62,0:01:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:01:50.19,0:01:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:01:51.91,0:01:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:01:53.60,0:01:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, baik.
Dialogue: 0,0:01:55.55,0:01:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:01:57.17,0:02:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, habis telepon dengan siapa?
Dialogue: 0,0:02:01.36,0:02:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang dari Desa Musim Dingin.
Dialogue: 0,0:02:02.94,0:02:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membahas soal pekerjaan.
Dialogue: 0,0:02:05.29,0:02:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:02:06.48,0:02:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada masalah?
Dialogue: 0,0:02:08.40,0:02:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:02:09.83,0:02:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sakura.
Dialogue: 0,0:02:11.36,0:02:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rombongan Tuan Rosei akan tiba, kan?
Dialogue: 0,0:02:16.82,0:02:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:02:17.66,0:02:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agendanya sebentar lagi tiba.
Dialogue: 0,0:02:20.08,0:02:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menunggu di kafetaria lantai satu,
Dialogue: 0,0:02:23.59,0:02:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa bisa tahu kalau dia sudah tiba?
Dialogue: 0,0:02:28.38,0:02:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang itu yang kamu mau,\Nmari kita sambut kedatangannya.
Dialogue: 0,0:02:32.04,0:02:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kuberi tahu lebih dulu,
Dialogue: 0,0:02:34.03,0:02:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa\Nbersikap ramah pada mereka.
Dialogue: 0,0:02:36.43,0:02:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:02:37.76,0:02:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, rambutku aneh tidak?
Dialogue: 0,0:02:44.06,0:02:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih tetap cantik setara pusaka negara.
Dialogue: 0,0:02:47.31,0:02:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kimononya?\NAda yang aneh tidak?
Dialogue: 0,0:02:50.44,0:02:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu anggun bagai bidadari\Nyang turun dari surga.
Dialogue: 0,0:03:02.41,0:03:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila melakukan sesuatu\Nyang membuatmu bermuka sedih,
Dialogue: 0,0:03:05.50,0:03:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan langsung kutebas di tempat.
Dialogue: 0,0:03:07.58,0:03:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:03:09.38,0:03:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, akan kupukul.
Dialogue: 0,0:03:11.46,0:03:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga tidak boleh.
Dialogue: 0,0:03:13.34,0:03:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa apa-apa, dong.
Dialogue: 0,0:03:17.43,0:03:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awasi saja.
Dialogue: 0,0:03:20.11,0:03:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalkan Tuan Rosei tidak menerima\Naku yang sekarang,
Dialogue: 0,0:03:26.27,0:03:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya tidak bisa disalahkan.
Dialogue: 0,0:03:29.98,0:03:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau bisa jadi dekat,
Dialogue: 0,0:03:34.07,0:03:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya bisa membantu untuk\Nmengembalikan "diriku"
Dialogue: 0,0:03:38.95,0:03:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada semua orang.
Dialogue: 0,0:03:41.74,0:03:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku
Dialogue: 0,0:03:44.75,0:03:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin mengembalikan "diriku"\Npada kalian bertiga
Dialogue: 0,0:03:48.62,0:03:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ingin "diriku" lindungi.
Dialogue: 0,0:03:54.76,0:03:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mempertemukan\N"anak itu" pada Tuan Rosei.
Dialogue: 0,0:04:00.51,0:04:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak bisa.
Dialogue: 0,0:04:04.14,0:04:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku yang palsu ini
Dialogue: 0,0:04:08.64,0:04:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetap bisa melakukan sesuatu.
Dialogue: 0,0:04:11.40,0:04:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, bisa dekat lagi denganmu, kan?
Dialogue: 0,0:04:16.95,0:04:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karenanya, kalau bisa begitu juga\Ndengan Tuan Rosei dan yang lain.
Dialogue: 0,0:04:22.35,0:04:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah sama seperti yang dulu.
Dialogue: 0,0:04:27.01,0:04:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga tidak harus cinta.
Dialogue: 0,0:04:30.80,0:04:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, rasa sakit semua orang\Ndari sepuluh tahun lalu
Dialogue: 0,0:04:36.91,0:04:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin bisa berubah.
Dialogue: 0,0:04:40.43,0:04:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, aku sudah berubah.
Dialogue: 0,0:04:44.93,0:04:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bisa melangkah lagi.
Dialogue: 0,0:04:48.19,0:04:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu semua berkatmu.
Dialogue: 0,0:04:52.69,0:04:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena apa pun keadaannya,
Dialogue: 0,0:04:56.01,0:04:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu selalu ada di dekatku.
Dialogue: 0,0:05:00.20,0:05:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kali ini biar aku...
Dialogue: 0,0:05:05.55,0:05:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kamu sudah lelah membenci seorang.
Dialogue: 0,0:05:11.35,0:05:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menerimamu dengan lapang.
Dialogue: 0,0:05:16.97,0:05:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, ya, Sakura?
Dialogue: 0,0:05:21.09,0:05:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau bicara\Ndengan Kakanda Itecho?
Dialogue: 0,0:05:27.14,0:05:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:29.56,0:05:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:05:42.03,0:05:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebakaran.
Dialogue: 0,0:05:43.45,0:05:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah terjadi kebakaran.
Dialogue: 0,0:05:45.37,0:05:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebakaran?\NDi lantai berapa?
Dialogue: 0,0:05:46.74,0:05:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo turun dulu ke lantai satu\Nlalu ke luar!
Dialogue: 0,0:05:49.08,0:05:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pakai lift!\NLewat tangga saja!
Dialogue: 0,0:05:52.16,0:05:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Utusan juga tolong kemari!
Dialogue: 0,0:05:54.25,0:05:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sebelah sana ada tangga darurat.
Dialogue: 0,0:05:56.29,0:05:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, mari.
Dialogue: 0,0:05:57.42,0:05:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari turun sama-sama ke lobi.
Dialogue: 0,0:06:00.84,0:06:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura?
Dialogue: 0,0:06:02.68,0:06:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebakaran!
Dialogue: 0,0:06:04.22,0:06:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sini!
Dialogue: 0,0:06:05.05,0:06:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Minggir!\N- Cepat!
Dialogue: 0,0:06:14.48,0:06:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap tenang!
Dialogue: 0,0:06:15.86,0:06:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong maju perlahan!
Dialogue: 0,0:06:19.78,0:06:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:06:21.05,0:06:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pihak keamanan?
Dialogue: 0,0:06:30.62,0:06:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para utusan!
Dialogue: 0,0:06:32.79,0:06:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kebakaran!\NSegera turun ke bawah!
Dialogue: 0,0:06:35.00,0:06:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari, di sebelah sana!
Dialogue: 0,0:06:37.28,0:06:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura?
Dialogue: 0,0:06:40.55,0:06:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong cepat kemari!
Dialogue: 0,0:06:43.76,0:06:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagatsuki, izin bertanya sesuatu.
Dialogue: 0,0:06:46.39,0:06:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa memangnya?
Dialogue: 0,0:06:47.85,0:06:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ce—
Dialogue: 0,0:06:48.53,0:06:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mereka pakai di balik baju,\Nkelihatannya tebal sekali.
Dialogue: 0,0:06:52.89,0:06:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mengenakan rompi antipeluru?
Dialogue: 0,0:06:55.73,0:06:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa tiba-tiba tanya begitu?
Dialogue: 0,0:06:58.73,0:07:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ro-Rompi antipeluru?
Dialogue: 0,0:07:02.19,0:07:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin pakai seperti itu.
Dialogue: 0,0:07:11.83,0:07:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:07:56.16,0:07:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lagi yang mau jadi mangsa\Naliran Kangetsu?
Dialogue: 0,0:08:00.04,0:08:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tutup pintu tangga darurat!
Dialogue: 0,0:08:01.84,0:08:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi ada rekan mereka di bawah.
Dialogue: 0,0:08:03.96,0:08:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:08:16.64,0:08:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu pengkhianatnya?
Dialogue: 0,0:08:19.10,0:08:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau wanita divisi keamanan\Nadalah mata-mata Penyamun,
Dialogue: 0,0:08:21.77,0:08:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penyerangan Istana Musim Gugur\Njadi masuk akal!
Dialogue: 0,0:08:23.98,0:08:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:08:24.98,0:08:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melindungi Nona Musim Semi—
Dialogue: 0,0:08:27.70,0:08:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian datang kemari pastilah takdir!
Dialogue: 0,0:08:31.20,0:08:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah mewaspadai pergerakan Kasai,\Njadi menyiapkan situasi darurat!
Dialogue: 0,0:08:35.95,0:08:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Utusan Musim Semi,\Nmari kita pergi sama-sama.
Dialogue: 0,0:08:39.28,0:08:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong berikan musim semi abadi ke dunia!
Dialogue: 0,0:08:42.25,0:08:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, jangan melihatnya.
Dialogue: 0,0:08:44.38,0:08:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti matamu ternoda.
Dialogue: 0,0:08:46.53,0:08:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:08:48.44,0:08:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah Higan-Nishi\Nyang memuja Musim Semi.
Dialogue: 0,0:08:54.39,0:08:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higan-Nishi?
Dialogue: 0,0:09:23.96,0:09:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana.
Dialogue: 0,0:09:29.92,0:09:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:31.13,0:09:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerja kerasnya.
Dialogue: 0,0:09:32.53,0:09:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang bagus kalau penyamun itu\Nkembali ke markas mereka.
Dialogue: 0,0:09:38.52,0:09:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau tidak,\Nini betulan cuma buang waktu, kan?
Dialogue: 0,0:09:43.40,0:09:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau berhasil ditangkap,\Nbisa dipaksa membeberkan informasi.
Dialogue: 0,0:09:47.53,0:09:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah bisa?
Dialogue: 0,0:09:48.82,0:09:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun yang lebih dulu ditangkap\Ndi penyerangan Istana Musim Panas,
Dialogue: 0,0:09:51.99,0:09:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum mau buka mulut.
Dialogue: 0,0:09:53.95,0:09:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bikin kesal saja para penyamun itu!
Dialogue: 0,0:09:57.41,0:09:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampas banget.
Dialogue: 0,0:09:58.87,0:10:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main culik gadis sekecil dia—
Dialogue: 0,0:10:00.83,0:10:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatikan lagi kata-katamu!
Dialogue: 0,0:10:03.37,0:10:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, jadi utusan harus berurusan\Nsama hal begini melulu!
Dialogue: 0,0:10:08.00,0:10:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka betulan ingin kubuat babak belur!
Dialogue: 0,0:10:16.85,0:10:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa lama lagi?
Dialogue: 0,0:10:18.18,0:10:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi sampai.
Dialogue: 0,0:10:20.07,0:10:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terasa lebih jauh dari biasanya.
Dialogue: 0,0:10:27.90,0:10:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan musuh!
Dialogue: 0,0:10:41.37,0:10:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:10:42.71,0:10:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir, kamu berat.
Dialogue: 0,0:10:44.62,0:10:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, bikin kesal saja.
Dialogue: 0,0:10:46.96,0:10:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau informasi dari Azami benar,\Nberarti lawan kita Kasai.
Dialogue: 0,0:10:51.01,0:10:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat kita selesaikan.
Dialogue: 0,0:10:52.92,0:10:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertemu Hinagiku dan Sakura\Nsecepat mungkin.
Dialogue: 0,0:10:57.55,0:10:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:11:14.95,0:11:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada habisnya.
Dialogue: 0,0:11:16.70,0:11:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu kubantu?
Dialogue: 0,0:11:18.16,0:11:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak jago menembak, kan?
Dialogue: 0,0:11:20.28,0:11:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan urusanmu!
Dialogue: 0,0:11:26.83,0:11:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei!
Dialogue: 0,0:11:27.83,0:11:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banting setirnya!
Dialogue: 0,0:11:48.15,0:11:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ishihara, siapkan penyelamatan korban luka\Ndan mobil yang bisa dipakai!
Dialogue: 0,0:11:52.73,0:11:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:11:53.65,0:11:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bantu lindungi Utusan!
Dialogue: 0,0:11:55.90,0:11:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:05.12,0:12:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya mereka pikirkan?
Dialogue: 0,0:12:07.67,0:12:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka organisasi yang menculik utusan\Nuntuk dijadikan pengganti anaknya sendiri.
Dialogue: 0,0:12:11.88,0:12:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikirkan logikanya,\Naku saja mau muntah.
Dialogue: 0,0:12:15.59,0:12:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan itu.
Dialogue: 0,0:12:17.17,0:12:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang itu, berikan padaku.
Dialogue: 0,0:12:20.55,0:12:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhabisi sekaligus.
Dialogue: 0,0:12:22.35,0:12:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuberi mereka berkah pembekuan.
Dialogue: 0,0:12:28.10,0:12:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab, Nagatsuki.
Dialogue: 0,0:12:30.10,0:12:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higan-Nishi seharusnya sudah hancur\Nsetelah berselisih dengan Kasai.
Dialogue: 0,0:12:37.36,0:12:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh tahun lalu.
Dialogue: 0,0:12:38.99,0:12:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di insiden penyerangan Desa Musim Dingin,
Dialogue: 0,0:12:41.62,0:12:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku mengorbankan dirinya\Nuntuk melindungi utusan musim lain.
Dialogue: 0,0:12:45.45,0:12:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang begitu tersentuh\Nmelihat penampilan beliau.
Dialogue: 0,0:12:49.04,0:12:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melepaskan diri dari kubu pemberantas\Ndan mendirikan Higan-Nishi.
Dialogue: 0,0:12:54.03,0:12:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu menganut paham pemujaan Musim Semi.
Dialogue: 0,0:12:59.17,0:13:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masuk ke Biro Empat Musim,
Dialogue: 0,0:13:01.30,0:13:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga menyusup ke Musim Gugur\Nadalah perintah dari atasan.
Dialogue: 0,0:13:04.47,0:13:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua itu demi dunia\Nyang bisa memuja musim semi!
Dialogue: 0,0:13:08.64,0:13:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu sudah direncanakan\Nsejak sepuluh tahun lalu?
Dialogue: 0,0:13:11.94,0:13:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:13.02,0:13:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Gugur pun niatnya\Nkelak akan disingkirkan.
Dialogue: 0,0:13:19.07,0:13:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:13:21.32,0:13:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu lama berada di dekat Dik Fairy.
Dialogue: 0,0:13:25.83,0:13:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membunuhnya.
Dialogue: 0,0:13:28.83,0:13:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin berbuat sesuatu untuk melindunginya.
Dialogue: 0,0:13:33.40,0:13:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-temanku pun\Nmemantau pergerakan Kasai.
Dialogue: 0,0:13:36.21,0:13:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, tidak ada informasi\Nsoal penyerangan Istana Musim Gugur!
Dialogue: 0,0:13:39.76,0:13:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya terseret—
Dialogue: 0,0:13:44.43,0:13:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cepat selesaikan barikadenya!\N- Nona Himedaka!
Dialogue: 0,0:13:46.97,0:13:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari bekerja sama memprioritaskan
Dialogue: 0,0:13:49.64,0:13:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perlindungan Nona Hinagiku\Nsampai bisa lari dari sini!
Dialogue: 0,0:13:52.10,0:13:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah pemuja Nona Hinagiku.
Dialogue: 0,0:13:54.61,0:13:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon pergunakan layaknya kaki tanganmu.
Dialogue: 0,0:13:57.94,0:14:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hunuskan pedang salju,\Nwarna rembulan akan berlumur putih.
Dialogue: 0,0:14:01.53,0:14:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi keempat musim adalah pelipur mereka
Dialogue: 0,0:14:03.78,0:14:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- yang tidur abadi.\N- Sudah belum, Rosei?
Dialogue: 0,0:14:04.95,0:14:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bunuh musim gugur dan mati di musim semi.\N- Sudah belum, Rosei?
Dialogue: 0,0:14:06.58,0:14:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri kematian pada semua yang terkutuk.
Dialogue: 0,0:14:08.66,0:14:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kesedihan—
Dialogue: 0,0:14:09.83,0:14:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong angkat, tanganku sedang sibuk.
Dialogue: 0,0:14:13.58,0:14:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar semua kesedihan diliputi putih.
Dialogue: 0,0:14:15.42,0:14:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua jadi putih,\Nlarut dalam warna bunga salju.
Dialogue: 0,0:14:18.21,0:14:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hunuskan pedang salju,\Nwarna rembulan akan berlumur putih.
Dialogue: 0,0:14:21.42,0:14:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mimpi indah keempat musim...\N- Dari Sakura?
Dialogue: 0,0:14:25.39,0:14:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkat.
Dialogue: 0,0:14:26.26,0:14:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan kesal kalau kuangkat!
Dialogue: 0,0:14:28.10,0:14:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama saja kalau aku yang angkat.
Dialogue: 0,0:14:31.31,0:14:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dulu, kalian begitu akrab.
Dialogue: 0,0:14:34.10,0:14:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kesalahanku.
Dialogue: 0,0:14:36.27,0:14:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kesalahanku.
Dialogue: 0,0:14:39.07,0:14:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telepon balik.
Dialogue: 0,0:14:40.82,0:14:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia marah.
Dialogue: 0,0:14:42.36,0:14:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kukatakan seberapa keras kamu mencari,\Nseberapa keras kamu peduli!
Dialogue: 0,0:14:48.63,0:14:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei.
Dialogue: 0,0:14:49.91,0:14:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau fokus,\Njangan ajak bicara lagi.
Dialogue: 0,0:14:53.87,0:14:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hunuskan pedang salju,
Dialogue: 0,0:14:55.67,0:14:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}warna rembulan akan berlumur putih.
Dialogue: 0,0:14:58.25,0:15:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari markas pencarian.
Dialogue: 0,0:15:00.68,0:15:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:15:01.92,0:15:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami, bisa dengar suaraku?
Dialogue: 0,0:15:05.13,0:15:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka?
Dialogue: 0,0:15:07.55,0:15:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada—
Dialogue: 0,0:15:07.87,0:15:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biro Empat Musim sedang diserang\Noleh suatu pihak.
Dialogue: 0,0:15:10.68,0:15:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:15:11.31,0:15:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang berlindung di lantai atas.
Dialogue: 0,0:15:13.76,0:15:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, kami masih aman.
Dialogue: 0,0:15:17.15,0:15:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katanya?
Dialogue: 0,0:15:18.02,0:15:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badan Keamanan Negara bagaimana?
Dialogue: 0,0:15:19.44,0:15:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini masih belum tiba.
Dialogue: 0,0:15:22.48,0:15:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, kami akan segera kembali.
Dialogue: 0,0:15:24.90,0:15:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tolong tetap dilanjutkan.
Dialogue: 0,0:15:26.99,0:15:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang harus aku sampaikan.
Dialogue: 0,0:15:30.66,0:15:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagatsuki berkhianat.
Dialogue: 0,0:15:33.25,0:15:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He?
Dialogue: 0,0:15:40.00,0:15:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagatsuki dan yang lainnya sedang membantu\Nmemprioritaskan perlindungan Nona Hinagiku.
Dialogue: 0,0:15:45.30,0:15:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagatsuki berkhianat?
Dialogue: 0,0:15:47.51,0:15:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti yang dulu, kali ini sepertinya\Nhanya ikut terseret.
Dialogue: 0,0:15:50.93,0:15:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi katanya berniat membawa Nona Hinagiku\Nke markas mereka kalau ada kesempatan.
Dialogue: 0,0:15:56.60,0:15:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:15:59.06,0:16:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu aku angkat?
Dialogue: 0,0:16:02.61,0:16:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa jawab, kok.
Dialogue: 0,0:16:06.32,0:16:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:16:10.45,0:16:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi indah keempat musim adalah\Npelipur mereka yang tidur abadi.
Dialogue: 0,0:16:13.45,0:16:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sakura—\N- Halo, Tuan Rosei...
Dialogue: 0,0:16:20.00,0:16:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:16:21.47,0:16:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku?
Dialogue: 0,0:16:24.73,0:16:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku bukanlah lari\Nataupun dipermainkan masa lalu.
Dialogue: 0,0:16:30.27,0:16:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ingin menyelesaikan segalanya\Ndan memulai lembaran baru.
Dialogue: 0,0:16:35.35,0:16:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku terus memikirkan\Napa yang bisa dirinya lakukan.
Dialogue: 0,0:16:41.77,0:16:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku selalu saja\Nmemikirkan diriku sendiri.
Dialogue: 0,0:16:51.69,0:16:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku terasa begitu bodoh.
Dialogue: 0,0:16:56.62,0:16:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami.
Dialogue: 0,0:16:59.21,0:17:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:17:00.33,0:17:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memahami situasinya.
Dialogue: 0,0:17:02.46,0:17:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun kami mati di sini,\Nkamu tak boleh menyerah.
Dialogue: 0,0:17:06.58,0:17:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang seperti itu.
Dialogue: 0,0:17:08.33,0:17:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami, kamu sama sekali tidak boleh\Nmenyerah mencari Nona Nadeshiko.
Dialogue: 0,0:17:13.59,0:17:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan adalah cahaya bagi utusannya.
Dialogue: 0,0:17:16.23,0:17:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupakan kalimat Nona Hinagiku.
Dialogue: 0,0:17:20.14,0:17:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berjanji, tidak akan menyerah\Nmencari Nadeshiko.
Dialogue: 0,0:17:24.44,0:17:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakanda Itecho...
Dialogue: 0,0:17:27.60,0:17:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ini aku.
Dialogue: 0,0:17:29.57,0:17:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Sakura sedang ada telepon lain...
Dialogue: 0,0:17:35.03,0:17:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah, silakan dilanjut—
Dialogue: 0,0:17:37.37,0:17:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Kakanda Itecho.
Dialogue: 0,0:17:41.25,0:17:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tubuhmu tidak apa-apa?
Dialogue: 0,0:17:45.71,0:17:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dulu kena tembak\Nmasih sakit?
Dialogue: 0,0:17:53.51,0:17:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah tidak apa-apa.
Dialogue: 0,0:17:56.64,0:17:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak sakit lagi.
Dialogue: 0,0:17:59.20,0:18:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak,\Nkarena sudah menolong kami saat itu.
Dialogue: 0,0:18:05.52,0:18:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku ingin berterima kasih.
Dialogue: 0,0:18:11.33,0:18:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:18:13.15,0:18:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih telah menyelamatkan\Nnyawaku sepuluh tahun lalu.
Dialogue: 0,0:18:20.29,0:18:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakanda Itecho.
Dialogue: 0,0:18:23.91,0:18:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak berhak dipanggil\Ndengan sebutan itu.
Dialogue: 0,0:18:28.34,0:18:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan seperti itu.
Dialogue: 0,0:18:31.51,0:18:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga sama.
Dialogue: 0,0:18:35.09,0:18:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dengar soal aku?
Dialogue: 0,0:18:39.36,0:18:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, hanya sedikit.
Dialogue: 0,0:18:41.18,0:18:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berbeda.
Dialogue: 0,0:18:43.81,0:18:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalamnya sudah berbeda.
Dialogue: 0,0:18:47.25,0:18:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukanlah yang asli.
Dialogue: 0,0:18:49.69,0:18:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, ada juga yang sudah diwarisi.
Dialogue: 0,0:18:54.36,0:18:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang dulu memang sudah mati.
Dialogue: 0,0:18:59.40,0:19:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku yang sekarang\Nhidup mewarisinya.
Dialogue: 0,0:19:04.75,0:19:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mati?
Dialogue: 0,0:19:06.38,0:19:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku belum bisa memahaminya.
Dialogue: 0,0:19:09.09,0:19:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tidak apa-apa.
Dialogue: 0,0:19:11.55,0:19:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi begini.
Dialogue: 0,0:19:13.72,0:19:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seperti itulah aku yang ada sekarang.\N- Rosei!
Dialogue: 0,0:19:23.10,0:19:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:19:24.10,0:19:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:19:25.35,0:19:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahuku hanya kena tembak.
Dialogue: 0,0:19:27.56,0:19:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya ingin aku katakan\Njika bertemu langsung.
Dialogue: 0,0:19:33.19,0:19:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!\NAkan kuberikan pada Rosei!
Dialogue: 0,0:19:35.99,0:19:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei!
Dialogue: 0,0:19:41.62,0:19:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi situasinya jadi tidak tahu\Nbisa mengatakannya atau tidak.
Dialogue: 0,0:19:45.79,0:19:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi akan aku katakan sekarang.
Dialogue: 0,0:19:52.59,0:19:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka?
Dialogue: 0,0:19:53.92,0:19:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:19:55.72,0:19:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka!
Dialogue: 0,0:20:02.01,0:20:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakanda Itecho.
Dialogue: 0,0:20:07.23,0:20:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat, Rosei!
Dialogue: 0,0:20:08.44,0:20:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei.
Dialogue: 0,0:20:09.81,0:20:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hina—
Dialogue: 0,0:20:10.27,0:20:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku yang sepuluh tahun lalu.
Dialogue: 0,0:20:13.45,0:20:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa aku kembalikan\Ndalam keadaan hidup.
Dialogue: 0,0:20:18.66,0:20:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:20:22.25,0:20:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hina... giku...
Dialogue: 0,0:20:29.62,0:20:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, hei?\NAda apa memangnya?
Dialogue: 0,0:20:32.38,0:20:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Tuan Azami?
Dialogue: 0,0:20:33.67,0:20:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:20:36.13,0:20:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:20:37.89,0:20:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ledakan.
Dialogue: 0,0:20:41.39,0:20:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Rosei!\NAda apa?
Dialogue: 0,0:20:43.93,0:20:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku bagaimana?
Dialogue: 0,0:20:46.89,0:20:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku...
Dialogue: 0,0:21:04.20,0:21:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei!
Dialogue: 0,0:21:08.46,0:21:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuatkan dirimu!
Dialogue: 0,0:21:13.59,0:21:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:21:27.77,0:21:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi sama Nona Hinagiku\Ndan yang lainnya?
Dialogue: 0,0:21:30.89,0:21:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terdengar suara ledakan...
Dialogue: 0,0:21:35.07,0:21:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rombongan Hinagiku dalam bahaya!
Dialogue: 0,0:21:37.11,0:21:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho, kumohon!
Dialogue: 0,0:21:39.36,0:21:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyelamatkan teman\Ndan gadis yang kucinta!
Dialogue: 0,0:21:42.03,0:21:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temani aku!
Dialogue: 0,0:21:44.81,0:21:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:21:46.24,0:21:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita segera ke sana!
Dialogue: 0,0:21:48.29,0:21:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ishihara!
Dialogue: 0,0:21:57.13,0:22:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, Tuan Itecho.
Dialogue: 0,0:22:00.30,0:22:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi ke sana.
Dialogue: 0,0:22:02.84,0:22:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pergi ke Biro Empat Musim.
Dialogue: 0,0:22:05.93,0:22:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan mati.
