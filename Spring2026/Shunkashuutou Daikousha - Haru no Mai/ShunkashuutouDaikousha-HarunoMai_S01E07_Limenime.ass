Dialogue: 0,0:02:08.65,0:02:17.45,tanda,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:03:18.39,0:03:21.72,tanda,,0000,0000,0000,,PARA TUAN DAN PELAYAN [4]
Dialogue: 0,0:03:27.44,0:03:28.32,tanda,,0000,0000,0000,,SYUKURLAH SEJAK KEJADIAN ITU,
Dialogue: 0,0:03:28.32,0:03:29.06,tanda,,0000,0000,0000,,SEMUANYA TERLIHAT LANCAR.
Dialogue: 0,0:03:29.06,0:03:30.57,tanda,,0000,0000,0000,,TERIMA KASIH BANYAK
Dialogue: 0,0:03:30.57,0:03:33.44,tanda,,0000,0000,0000,,HABIS INI MAU KE ENISHI, KAN?
Dialogue: 0,0:22:35.00,0:22:36.29,tanda,,0000,0000,0000,,EPISODE TUJUH: SENJA
Dialogue: 0,0:23:39.94,0:23:44.94,tanda,,0000,0000,0000,,SELANJUTNYA: HUJAN SAKURA
Dialogue: 0,0:00:15.31,0:00:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo! Rindo!
Dialogue: 0,0:00:27.76,0:00:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:00:31.47,0:00:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, ya...
Dialogue: 0,0:00:33.15,0:00:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski cuma sebentar,\Naku ingin melihatnya lebih dekat.
Dialogue: 0,0:00:35.89,0:00:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini musim semi pertamaku.
Dialogue: 0,0:00:39.24,0:00:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko, kalau itu keinginanmu,\Nakan aku kabulkan.
Dialogue: 0,0:00:43.69,0:00:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu adalah pangeranku.
Dialogue: 0,0:00:47.78,0:00:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pangeranmu?
Dialogue: 0,0:00:49.28,0:00:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku seorang pengawal, jadi mungkin\Nlebih tepat kalau kesatriamu.
Dialogue: 0,0:00:53.24,0:00:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri.
Dialogue: 0,0:00:54.91,0:00:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tuan putri?
Dialogue: 0,0:00:58.04,0:01:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Nadeshiko.
Dialogue: 0,0:01:00.79,0:01:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu adalah tuan putri\Npaling berharga di dunia.
Dialogue: 0,0:01:04.34,0:01:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga tuan tercinta yang harus dilindungi.
Dialogue: 0,0:01:07.01,0:01:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga satu-satunya utusan musim gugur
Dialogue: 0,0:01:10.34,0:01:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Negeri Yamato ini.
Dialogue: 0,0:01:15.97,0:01:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim gugurku.
Dialogue: 0,0:02:53.82,0:02:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi mulai menyelimuti Negeri Yamato!
Dialogue: 0,0:02:57.03,0:02:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya musim semi tiba di seluruh Teishu.
Dialogue: 0,0:02:59.58,0:03:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishi yang dilanda musim dingin panjang,\Nkini akhirnya cuaca hangat—
Dialogue: 0,0:03:03.91,0:03:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, coba lihat, Sakura.
Dialogue: 0,0:03:07.67,0:03:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka yang mana?
Dialogue: 0,0:03:10.46,0:03:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku...
Dialogue: 0,0:03:12.71,0:03:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah memikirkanku,\Npilih saja yang kamu suka.
Dialogue: 0,0:03:18.39,0:03:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih
Dialogue: 0,0:03:19.60,0:03:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah mewujudkan musim semi di Teishu!
Dialogue: 0,0:03:22.47,0:03:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah sejak kejadian itu,\Nsemuanya terlihat lancar.
Dialogue: 0,0:03:27.44,0:03:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:03:30.57,0:03:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habis ini mau ke Enishi, kan?
Dialogue: 0,0:03:35.86,0:03:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mampir ke Desa Musim Dingin,\Nbukannya bisa ketemu Tuan Rosei tercinta?
Dialogue: 0,0:03:43.20,0:03:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak tahu tercinta atau tidak...
Dialogue: 0,0:03:48.48,0:03:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, senang rasanya kalau bisa ketemu...
Dialogue: 0,0:03:52.59,0:03:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beli oleh-oleh dulu, ah...
Dialogue: 0,0:03:58.43,0:04:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku sepertinya sudah selesai\Nmewujudkan musim di Teishu.
Dialogue: 0,0:04:03.53,0:04:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal tanah Enishi ini saja, ya.
Dialogue: 0,0:04:07.81,0:04:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuputuskan, Itecho.
Dialogue: 0,0:04:10.52,0:04:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan ada Rapat Empat Musim\Nsaat musim panas.
Dialogue: 0,0:04:13.02,0:04:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, tidak bisa kutunggu selama itu.
Dialogue: 0,0:04:17.27,0:04:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah keduanya selesai\Nmelakukan perwujudan,
Dialogue: 0,0:04:19.82,0:04:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kuajukan permohonan resmi\Nuntuk bertemu.
Dialogue: 0,0:04:22.70,0:04:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi yakin setelah tahu\Nberbagai situasinya.
Dialogue: 0,0:04:25.54,0:04:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Musim Semi tidak bisa dipercaya,\NBiro Empat Musim juga sama.
Dialogue: 0,0:04:29.92,0:04:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku, musim dingin,\Nsebagai leluhur dari semua musim
Dialogue: 0,0:04:33.84,0:04:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang akan jadi pelindung\NHinagiku dan Sakura.
Dialogue: 0,0:04:37.63,0:04:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keputusan yang bagus.
Dialogue: 0,0:04:39.43,0:04:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nmari kita lihat saat yang tepat.
Dialogue: 0,0:04:42.72,0:04:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:04:43.64,0:04:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben enteng sekali reaksimu.
Dialogue: 0,0:04:45.64,0:04:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku juga memikirkan\Nhal yang sama.
Dialogue: 0,0:04:48.89,0:04:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak bilang duluan,\Naku berniat menyarankannya.
Dialogue: 0,0:04:54.86,0:04:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi, ada yang menggangguku.
Dialogue: 0,0:05:01.95,0:05:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:05:04.16,0:05:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunga sakura, ya?
Dialogue: 0,0:05:05.95,0:05:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambarmu bagus sekali.
Dialogue: 0,0:05:10.37,0:05:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah nama pelayan musim semi.
Dialogue: 0,0:05:14.13,0:05:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Himedaka Sakura?
Dialogue: 0,0:05:16.59,0:05:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku! Nadeshiko itu nama\Nbunga musim gugur, kan?
Dialogue: 0,0:05:21.41,0:05:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Rindo juga begitu.
Dialogue: 0,0:05:24.39,0:05:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Sang Utusan Musim Semi?
Dialogue: 0,0:05:26.97,0:05:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Nona Kayo Hinagiku.
Dialogue: 0,0:05:29.43,0:05:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga!\NSenang sekali!
Dialogue: 0,0:05:32.31,0:05:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama!\NPakai nama bunga!
Dialogue: 0,0:05:34.90,0:05:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini ada yang sama.
Dialogue: 0,0:05:36.82,0:05:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang membuatmu senang?
Dialogue: 0,0:05:39.32,0:05:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya nama Utusan Musim Panas\Nbukanlah bunga.
Dialogue: 0,0:05:43.66,0:05:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Dingin juga sama.
Dialogue: 0,0:05:46.74,0:05:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Semi dan pelayannya
Dialogue: 0,0:05:51.54,0:05:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi ingin bertemu mereka.
Dialogue: 0,0:05:54.71,0:05:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami, Divisi Keamanan memanggil.
Dialogue: 0,0:05:57.21,0:06:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo, kamu mau pergi?
Dialogue: 0,0:06:01.38,0:06:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Nadeshiko.\NAku akan segera kembali.
Dialogue: 0,0:06:04.51,0:06:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kusisakan camilan untukmu,\Nkue tar apel!
Dialogue: 0,0:06:09.39,0:06:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:06:11.52,0:06:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupakan diriku\Nbarang sedetik pun, ya.
Dialogue: 0,0:06:16.31,0:06:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dirimulah yang selalu\Nkupikirkan tiap detik.
Dialogue: 0,0:06:35.21,0:06:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemberitahuan ke Divisi Keamanan.
Dialogue: 0,0:06:37.71,0:06:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjauh dari Fairy.
Dialogue: 0,0:06:47.60,0:06:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bau apa ini?
Dialogue: 0,0:06:50.31,0:06:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udon kari.
Dialogue: 0,0:06:51.77,0:06:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan makan di tempat begini, Nagatsuki!
Dialogue: 0,0:06:54.27,0:06:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ini dari restoran terkenal\Nyang kupesan dari Iyo, lo!
Dialogue: 0,0:06:58.56,0:07:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu juga mau?
Dialogue: 0,0:07:00.69,0:07:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuahnya jangan sampai keciprat!
Dialogue: 0,0:07:09.08,0:07:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerjanya, Tuan Pangeran.
Dialogue: 0,0:07:12.29,0:07:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf.
Dialogue: 0,0:07:14.08,0:07:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepat kalau Kesatria, ya?
Dialogue: 0,0:07:16.71,0:07:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi kamu mengintip, ya.
Dialogue: 0,0:07:18.71,0:07:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh kamu ini,\Naku cuma kerja, kok.
Dialogue: 0,0:07:27.68,0:07:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja Istana Musim Panas\Ntidak diserang.
Dialogue: 0,0:07:31.26,0:07:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sekarang Dik Fairy bisa diajak\Npergi melihat bunga.
Dialogue: 0,0:07:35.64,0:07:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumpah, deh.
Dialogue: 0,0:07:37.40,0:07:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaca antipeluru di seluruh sisi memang mahal.
Dialogue: 0,0:07:39.98,0:07:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi membangun ruang berjemur\Nsepertinya pilihan tepat.
Dialogue: 0,0:07:43.23,0:07:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah fasilitasnya lengkap,\Nmemang tidak akan makan biaya lagi.
Dialogue: 0,0:07:48.32,0:07:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena musim gugur jarang diserang penyamun,\Nanggarannya jadi terbatas.
Dialogue: 0,0:07:52.74,0:07:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi harus dilindungi secara efektif.
Dialogue: 0,0:07:56.12,0:07:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beli generator listrik sendiri juga tepat.
Dialogue: 0,0:07:59.38,0:08:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Listrik Istana Musim Panas saja kemarin padam\Nkarena tempat pembangkitnya diledakkan.
Dialogue: 0,0:08:07.22,0:08:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergerakan Penyamun\Nbelakangan ini menggangguku.
Dialogue: 0,0:08:10.09,0:08:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal penyerangan Istana Musim Panas?
Dialogue: 0,0:08:12.14,0:08:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk kejadian di Tsukushi.
Dialogue: 0,0:08:13.85,0:08:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukushi?
Dialogue: 0,0:08:15.56,0:08:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar itu ulah organisasi kecil setempat.
Dialogue: 0,0:08:19.02,0:08:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang mencurigakan?
Dialogue: 0,0:08:22.11,0:08:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya adalah
Dialogue: 0,0:08:23.52,0:08:28.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana penyamun kecil seperti mereka\Ntahu kita datang ke Tsukushi.
Dialogue: 0,0:08:28.61,0:08:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu bukanlah pemeriksaan biasa\Ndan diputuskan tiba-tiba.
Dialogue: 0,0:08:32.48,0:08:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agendanya juga baru ditetapkan\Nsebelum kejadian.
Dialogue: 0,0:08:35.62,0:08:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu cekatan untuk bisa\Nmenyergap di bandara, ya.
Dialogue: 0,0:08:40.03,0:08:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga ada rumor soal rute baru\Npenyelundupan senjata dan sebagainya.
Dialogue: 0,0:08:44.34,0:08:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk kasus Istana Musim Panas.
Dialogue: 0,0:08:46.55,0:08:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat skala dan tujuan serangannya,\Npasti datang dari rute yang berbeda.
Dialogue: 0,0:08:51.55,0:08:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamun yang ditangkap katanya\Ntidak mau buka mulut sama sekali.
Dialogue: 0,0:08:54.81,0:08:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangankan itu.
Dialogue: 0,0:08:56.56,0:08:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada yang dilarikan ke rumah sakit\Nkarena coba menghabisi diri.
Dialogue: 0,0:08:59.52,0:09:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badan Keamanan Negara katanya\Nsampai kewalahan.
Dialogue: 0,0:09:03.31,0:09:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal frekuensi serangan, memang berkurang\Ndibanding tahun-tahun lalu.
Dialogue: 0,0:09:06.98,0:09:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin hanya pikiranku yang berlebihan.
Dialogue: 0,0:09:11.49,0:09:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho.
Dialogue: 0,0:09:13.32,0:09:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahkan pengawal rombongan Hinagiku\Nbersamaan dengan mereka masuk Enishi.
Dialogue: 0,0:09:17.75,0:09:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi secara rahasia.
Dialogue: 0,0:09:19.83,0:09:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:09:21.96,0:09:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu disampaikan pada Nona Himedaka\Nbila ada gerak-gerik mencurigakan?
Dialogue: 0,0:09:26.67,0:09:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, ini sekadar kecurigaan,\Nbelum ada bukti pasti.
Dialogue: 0,0:09:30.17,0:09:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi.
Dialogue: 0,0:09:31.63,0:09:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin dia istirahat yang cukup,\Ntapi ini soal Sakura.
Dialogue: 0,0:09:35.30,0:09:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sendiri pasti sudah waspada.
Dialogue: 0,0:09:37.81,0:09:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau membuatnya\Nlebih cemas lagi.
Dialogue: 0,0:09:41.10,0:09:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebisa mungkin aku ingin perkara ini\Nkalian simpan sendiri.
Dialogue: 0,0:09:50.69,0:09:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Dik Fairy bilang ingin ketemu\NUtusan Musim Semi, ya?
Dialogue: 0,0:09:55.95,0:09:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi setelah satu dekade.
Dialogue: 0,0:09:59.20,0:10:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar langsung berselisih\Ndengan Biro Empat Musim
Dialogue: 0,0:10:01.75,0:10:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi perwujudannya terlambat dimulai.
Dialogue: 0,0:10:04.79,0:10:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, yang lari dari rencana ritual perwujudan\Ndi depan kerumunan itu, ya.
Dialogue: 0,0:10:11.22,0:10:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Divisi Musim Semi Biro Empat Musim\N- Pengawal Utusan Musim Semi
Dialogue: 0,0:10:12.97,0:10:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- memang bodoh.
Dialogue: 0,0:10:14.92,0:10:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Huh?\N- Hah?
Dialogue: 0,0:10:16.64,0:10:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari mana pun,\Nyang bodoh itu pelayan musim semi.
Dialogue: 0,0:10:20.06,0:10:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan adalah tokoh publik\Nyang mendatangkan musim ke dunia.
Dialogue: 0,0:10:24.85,0:10:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jadinya kalau pengawal tidak bisa\Nmemegang kendali agar mereka patuh?
Dialogue: 0,0:10:29.28,0:10:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh...
Dialogue: 0,0:10:30.53,0:10:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang bukan main memanjakan Fairy\Nyakin bilang begitu?
Dialogue: 0,0:10:33.99,0:10:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu termasuk pekerjaan.
Dialogue: 0,0:10:38.41,0:10:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga anak kecil.
Dialogue: 0,0:10:40.12,0:10:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal dijemur matahari dan diberi makan kue
Dialogue: 0,0:10:43.08,0:10:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diajak main-main agar terhibur\Nnanti juga senang.
Dialogue: 0,0:10:45.62,0:10:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!\NMode pangeran Azami Rindo!
Dialogue: 0,0:10:50.50,0:10:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kualitas kekuatan ilahi sangat terpengaruh\Nkondisi fisik dan baik tidaknya suasana hati.
Dialogue: 0,0:10:55.59,0:10:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini demi dia bisa berfungsi di kondisi prima.
Dialogue: 0,0:10:57.97,0:10:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, itu!
Dialogue: 0,0:10:59.35,0:11:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyatanya sudah ada data kalau fluktuasi emosi\Nberefek pada kekuatan ilahi!
Dialogue: 0,0:11:04.10,0:11:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kekuatan seorang utusan itu\Ntergantung suasana hatinya!
Dialogue: 0,0:11:07.40,0:11:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi utusan yang sudah enggan\Nmalah disuruh menyanyi dan menari
Dialogue: 0,0:11:11.15,0:11:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di depan banyak penonton seperti idola.
Dialogue: 0,0:11:13.36,0:11:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas efek sebaliknya akan parah.
Dialogue: 0,0:11:15.53,0:11:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu dia korban penculikan, lo!
Dialogue: 0,0:11:18.81,0:11:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas Biro Empat Musim yang bodoh.
Dialogue: 0,0:11:21.62,0:11:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi kalau dibalik.
Dialogue: 0,0:11:23.58,0:11:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika emosinya memuncak, bisa saja\Nmengeluarkan kekuatan yang luar biasa.
Dialogue: 0,0:11:28.71,0:11:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membahas utusan musim semi,\NNona Kayo Hinagiku yang jadi buah bibir itu...
Dialogue: 0,0:11:32.59,0:11:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kasus penculikan\Nsepuluh tahun lalu itu, ya.
Dialogue: 0,0:11:35.51,0:11:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, benar yang itu!
Dialogue: 0,0:11:37.18,0:11:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masih anak baru\Ndan belum pernah menurunkan musim
Dialogue: 0,0:11:40.14,0:11:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia membuat pohon sakura raksasa
Dialogue: 0,0:11:42.18,0:11:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melindungi pelayannya sendiri\Ndan tuan-pelayan musim dingin!
Dialogue: 0,0:11:45.81,0:11:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu terjadi saat usianya\Ntidak beda jauh dengan Fairy kita!
Dialogue: 0,0:11:50.31,0:11:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti memakai Nadeshiko\Nsebagai perbandingan!
Dialogue: 0,0:11:53.23,0:11:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak, aku tidak bermaksud\Nmerendahkan Dik Fairy.
Dialogue: 0,0:11:57.61,0:12:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja Nona Hinagiku itu beda level.
Dialogue: 0,0:12:00.87,0:12:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi...
Dialogue: 0,0:12:02.03,0:12:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak ada di catatan resmi,\Njadi cuma bahasan kita di sini.
Dialogue: 0,0:12:05.87,0:12:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga ada rumor dia kabur menghancurkan\Nmarkas penyamun yang menculik dirinya.
Dialogue: 0,0:12:11.75,0:12:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaget dia.
Dialogue: 0,0:12:13.88,0:12:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kaget.
Dialogue: 0,0:12:14.88,0:12:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang hebat, ya.
Dialogue: 0,0:12:18.72,0:12:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya bisa kabur lebih cepat\Nkalau punya kekuatan seperti itu?
Dialogue: 0,0:12:28.60,0:12:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa-apaan—
Dialogue: 0,0:12:29.65,0:12:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini pasti!
Dialogue: 0,0:12:31.36,0:12:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe yang bilang, "Harusnya bisa melawan"\Nke korban pelecehan seksual!
Dialogue: 0,0:12:36.53,0:12:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin begitu!
Dialogue: 0,0:12:38.11,0:12:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, jangan dekat-dekat, dong...
Dialogue: 0,0:12:40.45,0:12:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar berengsek tanpa hati nurani!
Dialogue: 0,0:12:43.37,0:12:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat, itu gadis berumur enam tahun, lo.
Dialogue: 0,0:12:46.75,0:12:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diancam penyamun\Ntentu akan menurut.
Dialogue: 0,0:12:49.62,0:12:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kalau tidak menurut, teman-temanku\Nakan kami serang lagi," misalnya.
Dialogue: 0,0:12:53.38,0:12:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:12:54.80,0:12:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus lebih belajar lagi.
Dialogue: 0,0:12:57.51,0:13:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diculik dan disekap.\NKondisi psikis dalam kondisi tertentu.
Dialogue: 0,0:13:01.43,0:13:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuci otak, trauma.
Dialogue: 0,0:13:03.60,0:13:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kalanya syok dari kejadian\Nmembuat luka mendalam di hati.
Dialogue: 0,0:13:08.98,0:13:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan orang-orang di sekitar juga.
Dialogue: 0,0:13:11.19,0:13:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei dan Kakanda Itecho.
Dialogue: 0,0:13:15.94,0:13:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu akan senang\Ndengan yang seperti apa?
Dialogue: 0,0:13:21.61,0:13:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu memberi oleh-oleh\Nuntuk musim dingin.
Dialogue: 0,0:13:24.28,0:13:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian tidak ada agenda bertemu mereka.
Dialogue: 0,0:13:31.21,0:13:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalau bisa bertemu\Nsaat Rapat Empat Musim.
Dialogue: 0,0:13:36.46,0:13:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:13:37.63,0:13:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk saat Rapat Empat Musim.
Dialogue: 0,0:13:39.92,0:13:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa memaafkan mereka.
Dialogue: 0,0:13:42.38,0:13:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin mempertemukan\Nmereka denganmu!
Dialogue: 0,0:13:44.85,0:13:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membiarkan\Nmereka mendekatimu,
Dialogue: 0,0:13:47.27,0:13:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apalagi mengajak bicara.
Dialogue: 0,0:13:54.23,0:13:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu memang...
Dialogue: 0,0:13:58.57,0:14:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mau bertemu?
Dialogue: 0,0:14:04.66,0:14:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari bergegas.
Dialogue: 0,0:14:06.24,0:14:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti ketinggalan pesawat.
Dialogue: 0,0:14:14.63,0:14:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih banyak.
Dialogue: 0,0:14:17.75,0:14:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih kawalannya!
Dialogue: 0,0:14:19.51,0:14:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak perlu ikut campur\Nlebih dari itu.
Dialogue: 0,0:14:22.38,0:14:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bilang begitu, beri tahu saja\Nbila ada yang bisa kami bantu.
Dialogue: 0,0:14:27.39,0:14:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho sendiri mengkhawatirkan itu.
Dialogue: 0,0:14:30.18,0:14:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:14:31.14,0:14:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, bukan!
Dialogue: 0,0:14:32.68,0:14:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khawatir kalau Nona Himedaka\Nterlalu keras berusaha.
Dialogue: 0,0:14:35.35,0:14:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa jangan memaksakan diri begitu.
Dialogue: 0,0:14:41.03,0:14:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:14:43.28,0:14:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakanda Itecho pasti juga ingin bertemu.
Dialogue: 0,0:14:50.91,0:14:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalau sudah banyak\Nyang terjadi pada Hinagiku.
Dialogue: 0,0:14:59.17,0:15:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau bertemu, pasti...
Dialogue: 0,0:15:04.05,0:15:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut.
Dialogue: 0,0:15:06.47,0:15:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan jadi bagaimana jika bertemu.
Dialogue: 0,0:15:10.76,0:15:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti diriku.
Dialogue: 0,0:15:16.69,0:15:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho.
Dialogue: 0,0:15:19.94,0:15:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:15:21.15,0:15:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana pengamanan Rapat Empat Musim.
Dialogue: 0,0:15:23.24,0:15:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal konfirmasi darimu.
Dialogue: 0,0:15:26.11,0:15:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Acara itu sudah jadi tradisi,
Dialogue: 0,0:15:28.53,0:15:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi apa mengumpulkan\Nsemua utusan itu ada gunanya?
Dialogue: 0,0:15:32.36,0:15:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak berdoa ke dewa musim\Ndi tempat masing-masing saja?
Dialogue: 0,0:15:36.87,0:15:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, yang jadi masalah adalah\Nperwujudan musim gugur tahun ini.
Dialogue: 0,0:15:41.09,0:15:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun kemarin cukup merepotkan\Nkarena Nadeshiko demam.
Dialogue: 0,0:15:46.34,0:15:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibiarkan saja nanti juga sehat lagi.
Dialogue: 0,0:15:48.80,0:15:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hal yang biasa.
Dialogue: 0,0:15:52.22,0:15:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko.
Dialogue: 0,0:15:55.48,0:15:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:15:57.02,0:15:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya minum dulu sedikit.
Dialogue: 0,0:15:59.61,0:16:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa makan es?
Dialogue: 0,0:16:01.85,0:16:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mau sesuatu?
Dialogue: 0,0:16:10.45,0:16:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah di dekatku.
Dialogue: 0,0:16:17.08,0:16:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:16:21.84,0:16:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada di dekatmu.
Dialogue: 0,0:16:28.59,0:16:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo masih lama tidak, ya?
Dialogue: 0,0:16:32.05,0:16:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin cepat-cepat makan bersama dia.
Dialogue: 0,0:16:35.93,0:16:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang...
Dialogue: 0,0:16:37.43,0:16:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- harus kembali mengasuh anak kecil lagi.\N- Makasih...
Dialogue: 0,0:16:40.44,0:16:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ini ada les privat,\Nmengajari dia, lalu makan malam...
Dialogue: 0,0:16:45.86,0:16:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga dimandikan.
Dialogue: 0,0:16:47.49,0:16:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal di makalah juga tertulis kalau\Nutusan dan pengawal mudah
Dialogue: 0,0:16:51.70,0:16:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saling ketergantungan saat menjalin\Nhubungan tuan dan pelayan mereka.
Dialogue: 0,0:16:57.04,0:16:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia tidak sadar, ya?
Dialogue: 0,0:17:05.83,0:17:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akhirnya sampai di Enishi.
Dialogue: 0,0:17:10.83,0:17:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memanggil musim semi,\NTuan Rosei tentu akan sadar
Dialogue: 0,0:17:14.89,0:17:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau aku sudah datang.
Dialogue: 0,0:17:25.40,0:17:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi soal pertemuan atau jadi pelindung.
Dialogue: 0,0:17:29.24,0:17:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku itu hanya dalih semata.
Dialogue: 0,0:17:32.28,0:17:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu sendiri aslinya\Nhanya ingin bertemu Sakura?
Dialogue: 0,0:17:38.00,0:17:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang ingin membantu mereka.
Dialogue: 0,0:17:40.66,0:17:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, apa pun yang terjadi\Nakulah yang akan melindungi.
Dialogue: 0,0:17:44.88,0:17:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau sekadar itu, cukup mengawasi saja\Ndari jauh seperti selama ini.
Dialogue: 0,0:17:50.92,0:17:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat memikirkan rombongan Hinagiku,\Nrasanya lebih baik kalau dibiarkan saja.
Dialogue: 0,0:17:56.05,0:18:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Repot-repot mengadakan pertemuan\Nitu hanya egoku semata.
Dialogue: 0,0:18:02.06,0:18:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:03.65,0:18:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Sakura.
Dialogue: 0,0:18:06.90,0:18:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepuluh tahun,\Naku terus menunggu dan terus mencari.
Dialogue: 0,0:18:11.82,0:18:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ingin bertemu\Nterus saja makin besar.
Dialogue: 0,0:18:18.74,0:18:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu salahku.
Dialogue: 0,0:18:21.46,0:18:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga tahu kalau tidak boleh bertemu\Natau tidak akan pernah dimaafkan.
Dialogue: 0,0:18:26.50,0:18:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:18:28.88,0:18:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini rasanya jadi penuh.
Dialogue: 0,0:18:33.13,0:18:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang jadi terasa sesak.
Dialogue: 0,0:18:41.18,0:18:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ingin bertemu, rasanya.\N- Aku ingin bertemu dengannya.
Dialogue: 0,0:18:47.94,0:18:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu ke penjaga ruang berjemur.
Dialogue: 0,0:18:49.69,0:18:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kembali ke sana.
Dialogue: 0,0:19:46.57,0:19:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:19:48.88,0:19:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu utusan.
Dialogue: 0,0:19:53.00,0:19:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mati, ya?
Dialogue: 0,0:20:21.62,0:20:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bawa pulang dia, Mikami.
Dialogue: 0,0:20:24.20,0:20:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:20:25.79,0:20:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka anak ini.
Dialogue: 0,0:20:34.00,0:20:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:20:35.76,0:20:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya mau dibunuh?
Dialogue: 0,0:20:37.51,0:20:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bawa pulang.
Dialogue: 0,0:20:39.51,0:20:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin digigit anjing piaraan lagi?
Dialogue: 0,0:20:43.43,0:20:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejadian itu cukup sekali saja.
Dialogue: 0,0:20:45.93,0:20:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu rencananya...
Dialogue: 0,0:20:50.31,0:20:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti anak itu saja.
Dialogue: 0,0:20:53.36,0:20:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kayo! Nona Himedaka!
Dialogue: 0,0:21:00.36,0:21:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istana Musim Gugur?
Dialogue: 0,0:21:03.87,0:21:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo! Rindo!
Dialogue: 0,0:21:09.25,0:21:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupakan diriku\Nbarang sedetik pun, ya.
Dialogue: 0,0:21:16.38,0:21:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kusisakan camilan untukmu,\Nkue tar apel!
Dialogue: 0,0:21:27.64,0:21:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu adalah pangeranku.
Dialogue: 0,0:21:31.65,0:21:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawal utusan musim gugur,\NAzami Rindo.
Dialogue: 0,0:21:37.07,0:21:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan ke depan.
Dialogue: 0,0:21:43.62,0:21:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan raga ini dan bersumpah\Nakan melindungimu.
Dialogue: 0,0:21:51.75,0:21:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melindungi dari apa?
Dialogue: 0,0:22:00.97,0:22:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Na...
Dialogue: 0,0:22:07.22,0:22:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari segala-galanya.
Dialogue: 0,0:22:13.85,0:22:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko...
Dialogue: 0,0:22:15.81,0:22:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:22:17.73,0:22:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko...
Dialogue: 0,0:22:19.40,0:22:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo.
Dialogue: 0,0:22:21.32,0:22:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko...
Dialogue: 0,0:22:23.28,0:22:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo!
Dialogue: 0,0:22:25.16,0:22:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nadeshiko!
Dialogue: 0,0:22:26.41,0:22:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo...
Dialogue: 0,0:22:33.12,0:22:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamulah...
Dialogue: 0,0:22:35.00,0:22:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musim gugurku.
