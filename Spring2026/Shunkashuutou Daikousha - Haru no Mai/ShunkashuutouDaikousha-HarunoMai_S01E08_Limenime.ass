Dialogue: 0,0:03:22.81,0:03:23.43,tanda,,0000,0000,0000,,MUSIM SEMIKU
Dialogue: 0,0:05:13.71,0:05:14.59,tanda,,0000,0000,0000,,SEDIH...
Dialogue: 0,0:05:32.40,0:05:34.40,tanda,,0000,0000,0000,,DEG, DUG
Dialogue: 0,0:05:46.45,0:05:47.08,tanda,,0000,0000,0000,,ADUH~
Dialogue: 0,0:05:47.08,0:05:47.66,tanda,,0000,0000,0000,,ADUH~ GEMASNYA~
Dialogue: 0,0:06:04.39,0:06:05.76,tanda,,0000,0000,0000,,BUNGA DAN BINTANG
Dialogue: 0,0:09:26.09,0:09:28.17,tanda,,0000,0000,0000,,MELOTOT
Dialogue: 0,0:23:32.02,0:23:35.02,tanda,,0000,0000,0000,,EPISODE DELAPAN: HUJAN SAKURA
Dialogue: 0,0:23:35.02,0:23:40.02,tanda,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:23:40.02,0:23:45.03,tanda,,0000,0000,0000,,SELANJUTNYA: EPISODE SEMBILAN
Dialogue: 0,0:00:05.82,0:00:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?\NTerima kasih laporannya.
Dialogue: 0,0:00:09.06,0:00:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, prioritaskan mereka berdua\Ndaripada Biro Empat Musim.
Dialogue: 0,0:00:14.42,0:00:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku bagaimana?\NDia baik-baik saja?
Dialogue: 0,0:00:18.04,0:00:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya beliau menangis.
Dialogue: 0,0:00:20.13,0:00:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin segera menemani di sisinya!
Dialogue: 0,0:00:22.25,0:00:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham perasaanmu.
Dialogue: 0,0:00:23.75,0:00:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita disuruh diam saja selama\Npergerakan Penyamun belum diketahui.
Dialogue: 0,0:00:28.26,0:00:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka.
Dialogue: 0,0:00:30.01,0:00:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istana Musim Gugur sampai diserang\Ndan Nadeshiko diculik.
Dialogue: 0,0:00:34.58,0:00:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini sepuluh tahun lalu\Nyang terulang kembali?
Dialogue: 0,0:00:41.73,0:00:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:00:43.15,0:00:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah kubilang agar hari ini\Nbangun cepat dan siap-siap.
Dialogue: 0,0:00:46.53,0:00:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peralihan Empat Musim itu cuma\Npertemuan para utusan, kan?
Dialogue: 0,0:00:50.53,0:00:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma itu.
Dialogue: 0,0:00:52.28,0:00:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan baru menghabiskan waktu bersama\Nmusim dingin sebagai leluhur keempat musim
Dialogue: 0,0:00:56.04,0:00:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mewujudkan legenda.
Dialogue: 0,0:00:57.79,0:01:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ritual penting penutup pelatihan setahun,
Dialogue: 0,0:01:00.16,0:01:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ketika seseorang resmi\Ndiakui telah mandiri.
Dialogue: 0,0:01:03.17,0:01:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melalui ritual ini,
Dialogue: 0,0:01:04.62,0:01:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- seluruh organisasi seperti Biro dan Desa,\N- Tumben sekali.
Dialogue: 0,0:01:06.88,0:01:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- serta Badan Keamanan Negara—\N- Hari ini cerah.
Dialogue: 0,0:01:09.13,0:01:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan musim semi sebelumnya\Nmeninggal di saat yang tepat.
Dialogue: 0,0:01:13.39,0:01:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mati setelah menyelesaikan perwujudan.
Dialogue: 0,0:01:16.64,0:01:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu tahun untuk latihan\Nhingga perwujudan selanjutnya.
Dialogue: 0,0:01:19.39,0:01:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa rumor itu benar?
Dialogue: 0,0:01:22.90,0:01:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah.
Dialogue: 0,0:01:24.02,0:01:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kali ini bisa hidup\Nlebih lama dari yang sebelumnya.
Dialogue: 0,0:01:27.65,0:01:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:01:28.03,0:01:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, jangan diteruskan.
Dialogue: 0,0:01:30.78,0:01:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, utusan musim semi itu\Nseorang gadis, kan?
Dialogue: 0,0:01:36.08,0:01:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa akur dengan dia tidak, ya?
Dialogue: 0,0:01:38.04,0:01:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei, coba bayangkan dirimu di posisinya.
Dialogue: 0,0:01:41.54,0:01:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia harus menghabiskan satu bulan\Ndi tempat yang tidak dikenal, lo.
Dialogue: 0,0:01:45.29,0:01:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersikaplah lembut padanya.
Dialogue: 0,0:01:47.05,0:01:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, siapa tahu dia akan jadi\Nteman seumur hidupmu.
Dialogue: 0,0:01:52.34,0:01:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku saja sejak lahir\Nbelum pernah punya teman.
Dialogue: 0,0:01:56.80,0:01:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya aku bukan, ya?
Dialogue: 0,0:01:58.47,0:02:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau kamu...\NPengasuh sekaligus pelayan...
Dialogue: 0,0:02:02.98,0:02:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Le-Lebih seperti kakak, kan?
Dialogue: 0,0:02:08.07,0:02:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibilang begitu, benar juga.
Dialogue: 0,0:02:10.49,0:02:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah.
Dialogue: 0,0:02:11.94,0:02:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa saling memahami rasa pedih\Ndan sakit sebagai sesama utusan,
Dialogue: 0,0:02:16.53,0:02:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di negeri ini hanya ada empat orang\Ntermasuk dirimu.
Dialogue: 0,0:02:19.24,0:02:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak punya teman.
Dialogue: 0,0:02:21.87,0:02:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini juga tidak punya...
Dialogue: 0,0:02:24.25,0:02:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku tidak akan memaksa.
Dialogue: 0,0:02:27.88,0:02:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, berhentilah pasang muka\Ncemberut begitu!
Dialogue: 0,0:02:31.34,0:02:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak sopan, tahu.
Dialogue: 0,0:02:32.67,0:02:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mukaku memang begini!
Dialogue: 0,0:02:35.17,0:02:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan musim semi, Nona Kayo Hinagiku!
Dialogue: 0,0:02:39.10,0:02:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta pelayannya, Nona Himedaka Sakura,\Ntelah tiba!
Dialogue: 0,0:03:06.42,0:03:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Utusan Musim Dingin.
Dialogue: 0,0:03:08.42,0:03:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang rasanya bisa bertemu denganmu.
Dialogue: 0,0:03:23.43,0:03:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semiku.
Dialogue: 0,0:03:27.77,0:03:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalau selain orang desa\Ndijadikan murid aliran Kangetsu,
Dialogue: 0,0:03:31.98,0:03:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa memang akan melanggar aturan?
Dialogue: 0,0:03:34.19,0:03:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada aturan seperti itu.
Dialogue: 0,0:03:37.39,0:03:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja rasanya bisa menyinggung\Nkubu Desa Musim Semi.
Dialogue: 0,0:03:41.83,0:03:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu teknik pembunuhnya cukup kejam.
Dialogue: 0,0:03:44.54,0:03:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi untuk seorang gadis...
Dialogue: 0,0:03:46.29,0:03:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini demi melindungi Nona Hinagiku,\Naneh kalau orang desa justru marah.
Dialogue: 0,0:03:51.04,0:03:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu anggapan tidak cocok\Nuntuk wanita itu sudah kuno.
Dialogue: 0,0:03:54.96,0:03:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, akan repot\Nkalau reputasimu jadi buruk.
Dialogue: 0,0:03:58.93,0:04:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak boleh secara rahasia?
Dialogue: 0,0:04:00.43,0:04:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulihat dan pelajari.
Dialogue: 0,0:04:01.68,0:04:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kalau itu...
Dialogue: 0,0:04:03.31,0:04:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih enak dijadikan murid\Nkalau mau diajari.
Dialogue: 0,0:04:06.14,0:04:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi—
Dialogue: 0,0:04:07.06,0:04:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho, obrolan kita\Nkembali ke awal lagi.
Dialogue: 0,0:04:25.87,0:04:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku juga ditemani, lo.
Dialogue: 0,0:04:40.09,0:04:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau dipinjamkan ke gadis,\Nminimal bersihkan debunya!
Dialogue: 0,0:04:43.18,0:04:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berisik, ih!
Dialogue: 0,0:04:45.14,0:04:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana, cepat pakai, nanti Itecho berisik.
Dialogue: 0,0:04:48.71,0:04:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik...
Dialogue: 0,0:04:50.27,0:04:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf.
Dialogue: 0,0:04:53.69,0:04:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kedinginan,\Nkenapa tidak kamu hangatkan saja?
Dialogue: 0,0:04:57.36,0:04:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kan utusan musim semi.
Dialogue: 0,0:04:59.20,0:05:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya itu tidak boleh selain saat latihan.
Dialogue: 0,0:05:02.45,0:05:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu latih saja, sana.
Dialogue: 0,0:05:04.91,0:05:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi, menjadikan sebagian tempat ini\Njadi musim semi itu sulit,
Dialogue: 0,0:05:10.33,0:05:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau dilakukan sebelum hari perwujudan...
Dialogue: 0,0:05:14.59,0:05:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf...
Dialogue: 0,0:05:16.00,0:05:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak usah minta maaf—
Dialogue: 0,0:05:18.51,0:05:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ki-Kita tidak perlu\Nkaku dan terus menonton, lo.
Dialogue: 0,0:05:22.51,0:05:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke tempat lain?
Dialogue: 0,0:05:24.43,0:05:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku ingin melihat Sakura\Nyang sedang berusaha keras.
Dialogue: 0,0:05:27.89,0:05:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kalau aku tidak mengganggu.
Dialogue: 0,0:05:32.40,0:05:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukannya mengganggu, kok!
Dialogue: 0,0:05:38.15,0:05:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pelayan, rasanya itu\Ntidak bisa dibiarkan begitu saja.
Dialogue: 0,0:05:41.86,0:05:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Sakura.
Dialogue: 0,0:05:43.28,0:05:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang ini pertama kalinya dia\Nbicara ke gadis seumuran,
Dialogue: 0,0:05:46.45,0:05:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi belum terbiasa.
Dialogue: 0,0:05:47.66,0:05:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Tuan Rosei.
Dialogue: 0,0:05:50.37,0:05:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah keahlian utusan musim dingin\Nbisa membuat apa saja?
Dialogue: 0,0:05:57.42,0:06:00.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pedang, panah atau tombak\Nbisa kubuat dengan singkat!
Dialogue: 0,0:06:00.38,0:06:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bunga...
Dialogue: 0,0:06:01.88,0:06:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau bintang apakah bisa dibuat?
Dialogue: 0,0:06:05.76,0:06:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bunga?
Dialogue: 0,0:06:07.39,0:06:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf sudah meminta\Nsesuatu yang konyol!
Dialogue: 0,0:06:10.85,0:06:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:06:14.22,0:06:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah buat.
Dialogue: 0,0:06:21.90,0:06:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum jadi, ya.
Dialogue: 0,0:06:23.07,0:06:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:06:35.04,0:06:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, sudah jadi.
Dialogue: 0,0:06:38.82,0:06:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatku ini bunga karin.
Dialogue: 0,0:06:41.05,0:06:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap tahun mekar di taman wastu.
Dialogue: 0,0:06:43.55,0:06:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu dingin, dan cantik.
Dialogue: 0,0:06:47.03,0:06:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:06:50.56,0:06:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, boleh kutunjukkan pada Sakura?
Dialogue: 0,0:07:00.11,0:07:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:07:12.08,0:07:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, bunga hinagiku.
Dialogue: 0,0:07:14.21,0:07:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunga yang jadi namaku.
Dialogue: 0,0:07:16.42,0:07:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berkenan...
Dialogue: 0,0:07:18.71,0:07:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat...
Dialogue: 0,0:07:20.13,0:07:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, hebat!
Dialogue: 0,0:07:21.67,0:07:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, kamu yang lebih hebat!
Dialogue: 0,0:07:25.38,0:07:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi bisa begini juga.
Dialogue: 0,0:07:29.14,0:07:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku cuma bisa membekukan,\Njadi ini baru pertama kalinya.
Dialogue: 0,0:07:33.64,0:07:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:35.48,0:07:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, terima kasih, ya!
Dialogue: 0,0:07:39.40,0:07:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama, Tuan Rosei.
Dialogue: 0,0:08:13.97,0:08:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ro-Rosei?\NMau apa kamu?
Dialogue: 0,0:08:17.18,0:08:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya selama ini kamu pernah\Nbersikap peka seperti itu?
Dialogue: 0,0:08:21.15,0:08:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lancang sekali kamu ini!
Dialogue: 0,0:08:23.15,0:08:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau bisa akrab\Ndengan Nona Hinagiku.
Dialogue: 0,0:08:26.65,0:08:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri juga dekat dengan Sakura.
Dialogue: 0,0:08:30.11,0:08:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, nih? Cemburu, ya?
Dialogue: 0,0:08:32.20,0:08:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin begitu!
Dialogue: 0,0:08:35.15,0:08:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang agak malu kalau dipanggil guru,
Dialogue: 0,0:08:38.08,0:08:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ayunan pedang Sakura sangat bagus.
Dialogue: 0,0:08:40.12,0:08:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sabar melihat ke depannya nanti.
Dialogue: 0,0:08:42.28,0:08:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, aku juga mau bantu!
Dialogue: 0,0:08:45.30,0:08:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan.\NMinyaknya bahaya.
Dialogue: 0,0:08:48.05,0:08:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:49.22,0:08:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bahaya, bahaya.\N- Mudah sekali ditebak.
Dialogue: 0,0:08:51.55,0:08:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo makan di sana, biar kusiapkan.
Dialogue: 0,0:08:54.14,0:08:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku juga mau ikut bantu...
Dialogue: 0,0:08:57.93,0:08:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu.
Dialogue: 0,0:08:59.56,0:09:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku,\Nbisa tolong bawakan minumannya?
Dialogue: 0,0:09:03.31,0:09:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya enak.
Dialogue: 0,0:09:05.48,0:09:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini apa?
Dialogue: 0,0:09:07.57,0:09:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya amazake.
Dialogue: 0,0:09:09.03,0:09:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya manis dan membuat hangat.
Dialogue: 0,0:09:11.03,0:09:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amazake.
Dialogue: 0,0:09:12.70,0:09:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama kali minum.
Dialogue: 0,0:09:14.28,0:09:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:09:16.79,0:09:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, sih, cinta pertama.
Dialogue: 0,0:09:18.87,0:09:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho!
Dialogue: 0,0:09:21.04,0:09:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lihat Nona Hinagiku?
Dialogue: 0,0:09:23.33,0:09:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, barusan sama Rosei.
Dialogue: 0,0:09:26.09,0:09:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hanya berdua?
Dialogue: 0,0:09:30.13,0:09:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini justru cemburu.
Dialogue: 0,0:09:41.44,0:09:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua menurutmu bagaimana?
Dialogue: 0,0:09:43.35,0:09:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana apanya?
Dialogue: 0,0:09:44.73,0:09:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pasang muka seseram itu.
Dialogue: 0,0:09:47.11,0:09:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah dengar\Nada pernikahan sesama utusan.
Dialogue: 0,0:09:50.15,0:09:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau ditelusuri hingga zaman dewa,\Nmungkin paling tidak akan ada satu.
Dialogue: 0,0:09:55.62,0:09:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, asal itu keinginan Nona Hinagiku...
Dialogue: 0,0:09:59.62,0:10:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:10:03.12,0:10:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:10:05.13,0:10:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:08.57,0:10:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri ada rencana menikah?
Dialogue: 0,0:10:12.34,0:10:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada rencana untuk itu.
Dialogue: 0,0:10:15.47,0:10:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:18.35,0:10:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah belum?
Dialogue: 0,0:10:20.98,0:10:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum!
Dialogue: 0,0:10:24.35,0:10:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah belum?
Dialogue: 0,0:10:27.19,0:10:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah!
Dialogue: 0,0:10:31.03,0:10:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah terbiasa?
Dialogue: 0,0:10:33.99,0:10:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:10:35.07,0:10:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:10:37.12,0:10:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja terasa ada kemiripannya.
Dialogue: 0,0:10:39.62,0:10:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Nona Hinagiku dan utusan terdahulu...
Dialogue: 0,0:10:43.62,0:10:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:44.75,0:10:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Kobai punya cinta terlarang\Ndengan Kepala Keluarga Kayo.
Dialogue: 0,0:10:48.46,0:10:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian mengandung Nona Hinagiku.
Dialogue: 0,0:10:53.22,0:10:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Nyonya Kobai meninggal\Nsetelah Nona Hinagiku diadopsi,
Dialogue: 0,0:10:57.97,0:11:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga di saat terakhir pun\Ntidak bisa bertemu.
Dialogue: 0,0:11:00.47,0:11:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di wasiat yang ditinggalkan,
Dialogue: 0,0:11:02.39,0:11:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau menyerahkan Nona Hinagiku\Npada Kepala Keluarga Kayo.
Dialogue: 0,0:11:04.98,0:11:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu nama marganya...
Dialogue: 0,0:11:07.48,0:11:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, maksudnya wasiat?
Dialogue: 0,0:11:09.98,0:11:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:11.48,0:11:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diduga menutup usianya sendiri.
Dialogue: 0,0:11:19.45,0:11:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku...
Dialogue: 0,0:11:22.58,0:11:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku ingin membuat\NHinagiku tidak merasa sedih lagi.
Dialogue: 0,0:11:28.63,0:11:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melindungi Hinagiku.
Dialogue: 0,0:11:35.13,0:11:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berpikir seperti itu.
Dialogue: 0,0:11:45.52,0:11:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Hinagiku, itu dia!
Dialogue: 0,0:11:55.57,0:11:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menunjukkan sesuatu\Nyang hanya bisa dilihat di Enishi.
Dialogue: 0,0:11:59.32,0:12:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:12:01.45,0:12:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut sekali!
Dialogue: 0,0:12:02.83,0:12:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Imut sekali!
Dialogue: 0,0:12:05.08,0:12:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kutunjukkan juga pada Sakura.
Dialogue: 0,0:12:07.29,0:12:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, lihat—
Dialogue: 0,0:12:20.89,0:12:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:12:21.72,0:12:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nona Hinagiku?\N- Panggil bala bantuan!
Dialogue: 0,0:12:22.76,0:12:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa—
Dialogue: 0,0:12:23.68,0:12:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa tidak bisa dihubungi!
Dialogue: 0,0:12:26.77,0:12:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}De-Desanya...
Dialogue: 0,0:12:40.11,0:12:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke sana!
Dialogue: 0,0:12:42.53,0:12:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei, Sakura!
Dialogue: 0,0:12:44.08,0:12:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah di sisi Nona Hinagiku!
Dialogue: 0,0:12:45.87,0:12:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham?
Dialogue: 0,0:12:46.70,0:12:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho!
Dialogue: 0,0:12:49.75,0:12:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, tolong kemari!
Dialogue: 0,0:13:05.47,0:13:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbaiki formasi!
Dialogue: 0,0:13:06.89,0:13:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan mereka\Nmendekati Rosei dan lainnya!
Dialogue: 0,0:13:16.44,0:13:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi sempat,\Nbawa Rosei dan Nona Hinagiku—
Dialogue: 0,0:13:32.15,0:13:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan...
Dialogue: 0,0:13:37.13,0:13:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho!
Dialogue: 0,0:13:38.46,0:13:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho, kamu terluka!
Dialogue: 0,0:13:40.63,0:13:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:13:42.13,0:13:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding itu, di sini bahaya.
Dialogue: 0,0:13:44.89,0:13:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bisa lari, kan?
Dialogue: 0,0:13:53.57,0:13:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:13:59.94,0:14:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei, lari!\NSekuat yang kamu bisa!
Dialogue: 0,0:14:04.24,0:14:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei!
Dialogue: 0,0:14:05.87,0:14:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat berputar!
Dialogue: 0,0:14:07.41,0:14:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahului mereka!
Dialogue: 0,0:14:08.83,0:14:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan Musim Dingin hanya bocah!
Dialogue: 0,0:14:10.58,0:14:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh dia!
Dialogue: 0,0:14:14.69,0:14:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahku.
Dialogue: 0,0:14:16.63,0:14:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena salahku, mereka jadi terlibat.
Dialogue: 0,0:14:19.89,0:14:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei!
Dialogue: 0,0:14:22.98,0:14:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:14:31.60,0:14:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bawa Nona Hinagiku...
Dialogue: 0,0:14:34.39,0:14:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi!
Dialogue: 0,0:14:35.85,0:14:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:14:40.61,0:14:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:14:42.78,0:14:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:14:45.57,0:14:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seandainya aku bukan utusan musim dingin...
Dialogue: 0,0:14:48.70,0:14:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seandainya aku tiada...
Dialogue: 0,0:14:51.41,0:14:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan jadi seperti ini.
Dialogue: 0,0:14:59.25,0:15:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, apa pun yang terjadi\NHinagiku akan kulindungi.
Dialogue: 0,0:15:05.01,0:15:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang pertama jadi temanku.
Dialogue: 0,0:15:07.51,0:15:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa sakitnya jadi kepedihan bagiku.
Dialogue: 0,0:15:11.37,0:15:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dalam hidupku, aku bisa sekali saja\Nmenyelamatkan seseorang...
Dialogue: 0,0:15:15.56,0:15:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku!
Dialogue: 0,0:15:16.81,0:15:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melindungimu.
Dialogue: 0,0:15:20.02,0:15:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau keinginan mereka terpenuhi,\Nbisa saja Hinagiku dan lainnya dibebaskan.
Dialogue: 0,0:15:26.03,0:15:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku mati, bisa jadi\Nmereka bertiga akan selamat.
Dialogue: 0,0:15:30.28,0:15:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihannya cuma mati.
Dialogue: 0,0:15:33.29,0:15:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma harus mati!
Dialogue: 0,0:15:40.10,0:15:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei!
Dialogue: 0,0:15:41.30,0:15:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho!
Dialogue: 0,0:15:44.01,0:15:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lindungilah Sakura!
Dialogue: 0,0:15:53.43,0:15:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, aku akan menggendong Sakura.
Dialogue: 0,0:15:56.44,0:15:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa lari sendiri?
Dialogue: 0,0:16:01.19,0:16:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pusatkan pikiranmu,\Npertahankan kekerasannya.
Dialogue: 0,0:16:04.57,0:16:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:16:05.90,0:16:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buatlah sesuatu yang bisa\Nmengakhirinya dalam sekejap.
Dialogue: 0,0:16:09.53,0:16:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dipegang kedua tangan\Ndan langsung menembus jantung.
Dialogue: 0,0:16:13.91,0:16:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang bisa mengakhiri\Nnyawaku sendiri dengan pasti!
Dialogue: 0,0:16:16.91,0:16:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei...
Dialogue: 0,0:16:18.17,0:16:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa kamu?
Dialogue: 0,0:16:19.33,0:16:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi!
Dialogue: 0,0:16:20.33,0:16:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kecil tidak mungkin menang!
Dialogue: 0,0:16:24.34,0:16:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei?
Dialogue: 0,0:16:26.09,0:16:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho, kuperintahkan dirimu.
Dialogue: 0,0:16:30.01,0:16:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah lari.
Dialogue: 0,0:16:32.51,0:16:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:16:34.09,0:16:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu...
Dialogue: 0,0:16:34.97,0:16:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei!
Dialogue: 0,0:16:36.64,0:16:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuakhiri dengan badai salju.
Dialogue: 0,0:16:38.81,0:16:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bekas darahnya\Ntidak bisa tertutupi semua.
Dialogue: 0,0:16:41.40,0:16:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kumohon berusahalah lari.
Dialogue: 0,0:16:44.78,0:16:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba meminta agar\Nkalian dibiarkan selamat.
Dialogue: 0,0:16:47.65,0:16:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ini—
Dialogue: 0,0:16:48.90,0:16:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara bodoh!
Dialogue: 0,0:16:50.41,0:16:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buat aku mengulanginya!
Dialogue: 0,0:16:52.99,0:16:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini perintah, bawa mereka berdua pergi.
Dialogue: 0,0:16:57.20,0:16:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, akan mati di sini.
Dialogue: 0,0:16:59.79,0:17:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:17:01.63,0:17:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya tidak boleh!
Dialogue: 0,0:17:03.34,0:17:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyerah, Tuan Rosei!
Dialogue: 0,0:17:06.55,0:17:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus lari dan terus hidup!
Dialogue: 0,0:17:12.95,0:17:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, tidak apa-apa.
Dialogue: 0,0:17:16.72,0:17:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan selamat.
Dialogue: 0,0:17:20.61,0:17:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, kamu...
Dialogue: 0,0:17:38.29,0:17:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh ada yang mati!
Dialogue: 0,0:17:40.83,0:17:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali tidak boleh!
Dialogue: 0,0:17:45.24,0:17:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu tidak ada hubungannya.
Dialogue: 0,0:17:47.59,0:17:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hubungannya!
Dialogue: 0,0:17:49.80,0:17:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu orang yang berharga buatku!
Dialogue: 0,0:17:54.30,0:17:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan main lagi bersamaku, kan?
Dialogue: 0,0:17:58.81,0:18:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, itu sudah mustahil.
Dialogue: 0,0:18:01.63,0:18:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berteman baiklah dengan\Nutusan musim dingin selanjutnya.
Dialogue: 0,0:18:04.81,0:18:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang semudah itu...
Dialogue: 0,0:18:08.32,0:18:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin bersamamu...
Dialogue: 0,0:18:11.32,0:18:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan kamu...
Dialogue: 0,0:18:14.49,0:18:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kamu pasti tidak tahu\Napa yang akan terjadi setelah mati.
Dialogue: 0,0:18:19.54,0:18:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang...
Dialogue: 0,0:18:20.83,0:18:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:18:22.96,0:18:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibundaku juga meninggal karena\Ningin berbuat sesuatu sepertimu.
Dialogue: 0,0:18:28.84,0:18:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, hentikan...
Dialogue: 0,0:18:31.09,0:18:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik hilang kalau mengganggu.
Dialogue: 0,0:18:34.09,0:18:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berharap dengan begitu hidup putrinya\Nakan jadi lebih baik.
Dialogue: 0,0:18:39.35,0:18:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membulatkan tekad.
Dialogue: 0,0:18:41.60,0:18:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak begitu!
Dialogue: 0,0:18:44.27,0:18:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski menuruti orang yang menyakiti kita,
Dialogue: 0,0:18:47.31,0:18:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah kamu mati,\Nmereka yang menyakiti kita
Dialogue: 0,0:18:50.36,0:18:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya akan tertawa sesuka hati.
Dialogue: 0,0:18:52.36,0:18:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu!
Dialogue: 0,0:18:54.61,0:18:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah memutuskan untuk mati.
Dialogue: 0,0:18:56.99,0:18:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan patahkan hatiku seperti itu.
Dialogue: 0,0:18:59.08,0:19:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada jalan!
Dialogue: 0,0:19:00.95,0:19:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lari sama-sama!
Dialogue: 0,0:19:02.54,0:19:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak ada pilihan lain\Nuntuk melindungi kalian dari Penyamun!
Dialogue: 0,0:19:08.88,0:19:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, kamu sebenarnya\Nbelum ingin mati, bukan?
Dialogue: 0,0:19:15.68,0:19:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, harus bagaimana?
Dialogue: 0,0:19:18.30,0:19:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?
Dialogue: 0,0:19:21.56,0:19:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri tidak mau mati!
Dialogue: 0,0:19:23.56,0:19:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, lebih tidak kuat kalau kalian yang mati!
Dialogue: 0,0:19:26.40,0:19:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada kalian yang mati,\Nlebih baik aku saja, kan?
Dialogue: 0,0:19:42.79,0:19:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, kalau begitu\Nayo kita semua lari sama-sama.
Dialogue: 0,0:19:46.83,0:19:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan kekalahan.
Dialogue: 0,0:19:49.29,0:19:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua...
Dialogue: 0,0:19:51.34,0:19:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan lari, lari, dan lari...
Dialogue: 0,0:19:56.75,0:20:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahan, menunggu saatnya bertarung.
Dialogue: 0,0:20:05.23,0:20:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku!
Dialogue: 0,0:20:06.48,0:20:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku...
Dialogue: 0,0:20:08.23,0:20:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:20:31.75,0:20:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, jangan bunuh Sakura!
Dialogue: 0,0:20:35.55,0:20:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bunuh Tuan Rosei!
Dialogue: 0,0:20:37.80,0:20:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tembak Kakanda Itecho lagi!
Dialogue: 0,0:20:41.55,0:20:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!\NTunggu, Hinagiku!
Dialogue: 0,0:20:44.51,0:20:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan! Jangan, Hinagiku!
Dialogue: 0,0:20:46.93,0:20:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:20:48.56,0:20:50.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hentikan.
Dialogue: 0,0:20:51.69,0:20:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku jadi sandera!
Dialogue: 0,0:20:54.57,0:20:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa kamu?
Dialogue: 0,0:20:55.90,0:20:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, Hinagiku!
Dialogue: 0,0:20:58.07,0:20:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya Tuhan...
Dialogue: 0,0:20:59.61,0:21:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona... Hinagiku...
Dialogue: 0,0:21:01.57,0:21:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku...
Dialogue: 0,0:21:02.82,0:21:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang gantikanmu, Nona Hinagiku!
Dialogue: 0,0:21:08.58,0:21:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski utusan musim dingin dibunuh,\Nakan muncul utusan penggantinya.
Dialogue: 0,0:21:13.59,0:21:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah cukup, kan?
Dialogue: 0,0:21:16.21,0:21:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, jangan lukai siapa pun lagi!
Dialogue: 0,0:21:21.09,0:21:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Hinagiku...\NHentikan!
Dialogue: 0,0:21:24.51,0:21:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Nona Hinagiku!
Dialogue: 0,0:21:27.47,0:21:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, kamu pasti akan selamat.
Dialogue: 0,0:21:30.64,0:21:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, aku yang akan melindungimu.
Dialogue: 0,0:21:33.48,0:21:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak mau!
Dialogue: 0,0:21:35.48,0:21:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang jadi sandera!
Dialogue: 0,0:21:37.94,0:21:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:21:39.28,0:21:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu pergi...
Dialogue: 0,0:21:41.86,0:21:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, larilah...
Dialogue: 0,0:21:45.33,0:21:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakanda Itecho, aku sudah sangat lelah.
Dialogue: 0,0:21:50.58,0:21:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah sekuat tenaga.
Dialogue: 0,0:21:53.08,0:21:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jaga Sakura, kumohon.
Dialogue: 0,0:21:57.25,0:22:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, kumohon!\NTunggu dulu!
Dialogue: 0,0:22:00.01,0:22:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang mati!
Dialogue: 0,0:22:01.68,0:22:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mati sekarang!\NTunggu dulu!
Dialogue: 0,0:22:03.89,0:22:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku kamu itu...
Dialogue: 0,0:22:07.35,0:22:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku itu suka padamu...
Dialogue: 0,0:22:13.35,0:22:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku...
Dialogue: 0,0:22:16.48,0:22:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei.
Dialogue: 0,0:22:18.23,0:22:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka padamu!
Dialogue: 0,0:22:20.32,0:22:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi!
Dialogue: 0,0:22:22.24,0:22:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat senang mendengarnya, Tuan Rosei.
Dialogue: 0,0:22:25.87,0:22:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, kumohon!
Dialogue: 0,0:22:27.99,0:22:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, terima kasih\Nsudah menemaniku bermain.
Dialogue: 0,0:22:31.87,0:22:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, Hinagiku!
Dialogue: 0,0:22:33.87,0:22:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah memberi kembang es.
Dialogue: 0,0:22:36.63,0:22:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang tunggu dulu!
Dialogue: 0,0:22:38.46,0:22:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah bersikap\Nbegitu lembut padaku, Tuan Rosei.
Dialogue: 0,0:22:42.84,0:22:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mati sekarang,\Ndengan begitu kau tidak perlu pergi!
Dialogue: 0,0:22:46.55,0:22:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pasti akan selamat.
Dialogue: 0,0:22:48.93,0:22:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Hinagiku!
Dialogue: 0,0:22:50.81,0:22:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, maukah bermain denganku lagi?
Dialogue: 0,0:22:57.48,0:22:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku—
Dialogue: 0,0:22:59.15,0:23:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Nona Hinagiku!
Dialogue: 0,0:23:01.36,0:23:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi, Nona Hinagiku!
Dialogue: 0,0:23:04.07,0:23:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:23:05.20,0:23:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi, Hinagiku!
Dialogue: 0,0:23:07.91,0:23:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan... Rosei...
Dialogue: 0,0:23:11.83,0:23:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku...
Dialogue: 0,0:23:12.75,0:23:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku!
Dialogue: 0,0:23:13.58,0:23:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei!\NKelak pasti akan kujawab!
Dialogue: 0,0:23:17.04,0:23:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, Tuan Rosei!
Dialogue: 0,0:23:20.00,0:23:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku!
Dialogue: 0,0:23:21.50,0:23:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mati,\Nmaukah kamu tetap hidup?
Dialogue: 0,0:23:26.76,0:23:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku?
Dialogue: 0,0:23:28.26,0:23:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku!
