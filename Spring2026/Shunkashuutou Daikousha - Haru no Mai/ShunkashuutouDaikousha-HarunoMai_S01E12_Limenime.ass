Dialogue: 0,0:04:19.70,0:04:28.46,sign,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:09:34.37,0:09:35.80,sign,,0000,0000,0000,,****.
Dialogue: 0,0:09:57.56,0:09:59.08,sign,,0000,0000,0000,,EPISODE DUA BELAS: SERANGAN
Dialogue: 0,0:12:25.43,0:12:26.43,sign,,0000,0000,0000,,PANGGILAN - KANTSUBAKI ROSEI
Dialogue: 0,0:14:15.08,0:14:16.84,sign,,0000,0000,0000,,****.
Dialogue: 0,0:14:58.17,0:15:00.13,sign,,0000,0000,0000,,****.
Dialogue: 0,0:17:01.96,0:17:03.21,sign,,0000,0000,0000,,****.
Dialogue: 0,0:21:48.62,0:21:53.21,sign,,0000,0000,0000,,AYO PULANG, BIAR KUANTAR PULANG
Dialogue: 0,0:23:40.11,0:23:45.11,sign,,0000,0000,0000,,SELANJUTNYA: MEREBUT KEMBALI
Dialogue: 0,0:00:07.99,0:00:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei, Tuan Itecho.
Dialogue: 0,0:00:10.87,0:00:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi ke sana.
Dialogue: 0,0:00:13.49,0:00:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pergi ke Biro Empat Musim,
Dialogue: 0,0:00:15.87,0:00:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian akan mati.
Dialogue: 0,0:00:19.33,0:00:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu, Nona Ishihara—
Dialogue: 0,0:00:29.34,0:00:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:00:29.80,0:00:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak!
Dialogue: 0,0:00:31.52,0:00:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ishihara.
Dialogue: 0,0:00:32.80,0:00:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan kalau kamu punya alasan.
Dialogue: 0,0:00:35.22,0:00:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlihat enggan melakukannya.
Dialogue: 0,0:00:37.93,0:00:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang belum lama,\Ntapi kamu sudah banyak membantu.
Dialogue: 0,0:00:42.44,0:00:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku juga akan membantumu.
Dialogue: 0,0:00:44.77,0:00:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan alasanmu.
Dialogue: 0,0:00:48.57,0:00:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu diperintah seseorang?
Dialogue: 0,0:00:52.87,0:00:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua orang tua...
Dialogue: 0,0:00:55.41,0:00:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan ibuku\Nada di jajaran petinggi Kasai.
Dialogue: 0,0:00:59.37,0:01:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:01:00.58,0:01:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukankah yang menyerang tadi\Nadalah Kasai.
Dialogue: 0,0:01:03.73,0:01:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah diperintah untuk siap mati.
Dialogue: 0,0:01:05.88,0:01:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dijadikan tumbal, ya?
Dialogue: 0,0:01:07.63,0:01:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak lari?
Dialogue: 0,0:01:08.67,0:01:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melakukannya nanti dibunuh!
Dialogue: 0,0:01:11.34,0:01:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berulang kali mencoba lari,\Ntapi tetap diseret paksa kembali.
Dialogue: 0,0:01:15.76,0:01:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak pun mati karena dihukum Kasai!
Dialogue: 0,0:01:19.77,0:01:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah menipumu selama ini.
Dialogue: 0,0:01:23.90,0:01:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah memperlakukanku\Nlayaknya manusia.
Dialogue: 0,0:01:27.44,0:01:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan jauh lebih baik\Ndibanding orang tuaku.
Dialogue: 0,0:01:30.40,0:01:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu ingin kutolong!
Dialogue: 0,0:01:32.16,0:01:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang masih bisa lari!
Dialogue: 0,0:01:33.57,0:01:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lari!
Dialogue: 0,0:01:35.74,0:01:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:01:38.41,0:01:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja...
Dialogue: 0,0:01:41.66,0:01:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus pergi menyelamatkan musim semiku.
Dialogue: 0,0:01:45.21,0:01:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski itu berarti menjemput ajalku sendiri.
Dialogue: 0,0:01:49.80,0:01:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutaruh dalam perlindunganku.
Dialogue: 0,0:01:51.76,0:01:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:01:53.05,0:01:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ungkapkanlah semua rahasia Kasai\Nyang kamu punya.
Dialogue: 0,0:01:56.47,0:01:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:01:58.31,0:02:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Na-Nanti aku dibunuh!
Dialogue: 0,0:02:00.60,0:02:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasai tidak mengampuni pengkhianat!
Dialogue: 0,0:02:02.56,0:02:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan dibunuh,\Nbiar kuselamatkan.
Dialogue: 0,0:02:05.98,0:02:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpihaklah padaku.
Dialogue: 0,0:02:08.15,0:02:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan menyesal.
Dialogue: 0,0:02:10.49,0:02:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah pada dewa-dewa empat musim\Nuntuk pasti membalas kesetiaanmu.
Dialogue: 0,0:02:25.79,0:02:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Gozen, atasan dari Kasai,\Nmengincar Biro Empat Musim.
Dialogue: 0,0:02:31.59,0:02:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mengeluarkan banyak uang\Nuntuk mendapat orang dalam dan komplotan.
Dialogue: 0,0:02:38.10,0:02:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu mengerahkan pasukan sebagai umpan.
Dialogue: 0,0:02:41.10,0:02:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa masuk dari depan dengan menyamar\Njadi Badan Keamanan Negara.
Dialogue: 0,0:02:47.36,0:02:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian memasang bom di gedung biro
Dialogue: 0,0:02:51.65,0:02:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan meledakkannya.
Dialogue: 0,0:02:54.40,0:02:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, ada sebagian\Nyang berubah dari rencananya.
Dialogue: 0,0:03:00.99,0:03:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu terluka, Nona Hinagiku?
Dialogue: 0,0:03:03.87,0:03:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak apa-apa.
Dialogue: 0,0:03:07.04,0:03:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:08.17,0:03:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teleponnya terputus di tengah-tengah.
Dialogue: 0,0:03:11.67,0:03:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakanda Itecho bicara di telepon, lo.
Dialogue: 0,0:03:20.18,0:03:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Gozen begitu terpikat\Npada Nona Utusan Musim Semi.
Dialogue: 0,0:03:25.89,0:03:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum meledakkan Biro Empat Musim,\Nbeliau ingin merebutnya sendiri.
Dialogue: 0,0:05:05.28,0:05:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang dalam yang membocorkan\Nlokasi markas utama Kasai.
Dialogue: 0,0:05:09.21,0:05:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan karena\Nkekuatan utama musuh sedang keluar.
Dialogue: 0,0:05:12.42,0:05:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lanjut saja bergerak\Nmenyelamatkan Nadeshiko.
Dialogue: 0,0:05:15.59,0:05:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, Nona Kayo dan lainnya bagaimana?
Dialogue: 0,0:05:17.67,0:05:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum ada informasi,\Naku yang akan menyelamatkannya.
Dialogue: 0,0:05:20.38,0:05:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu dulu, Cowok Badai Salju Suram!
Dialogue: 0,0:05:23.51,0:05:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik perempuan Hazakura, ya.
Dialogue: 0,0:05:25.26,0:05:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku itu ingin bertemu dirimu.
Dialogue: 0,0:05:29.10,0:05:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka sama Nona Hinagiku, kan?
Dialogue: 0,0:05:34.11,0:05:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin, lo, ya,\Nkurasa perasaanmu terbalas.
Dialogue: 0,0:05:36.94,0:05:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, Ruri!
Dialogue: 0,0:05:38.36,0:05:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, jadi, itu artinya...
Dialogue: 0,0:05:41.45,0:05:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kalau berhasil ketemu dia,
Dialogue: 0,0:05:44.07,0:05:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katakan lagi ke Nona Hinagiku\Nkalau kamu suka padanya.
Dialogue: 0,0:05:49.58,0:05:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh tahun ini\Nkamu kelihatannya jaga hati
Dialogue: 0,0:05:52.42,0:05:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak mencoba dekat\Ndengan gadis lain, kan?
Dialogue: 0,0:05:55.08,0:05:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayame bilang kalau si Cowok Badai\Nbelum menyelesaikan cinta pertamanya,
Dialogue: 0,0:05:58.59,0:06:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan mau berteman dengan—
Dialogue: 0,0:06:03.01,0:06:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosei?
Dialogue: 0,0:06:10.85,0:06:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi sudah kucoba,\Ntapi tidak bisa menghubungi ke mana-mana.
Dialogue: 0,0:06:14.48,0:06:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin seperti pengakuan Nona Ishihara,
Dialogue: 0,0:06:16.73,0:06:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}komunikasi berbagai lembaga ibu kota\Nlumpuh karena sabotase Kasai.
Dialogue: 0,0:06:20.48,0:06:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pergi ke Biro Empat Musim,\Natau minta bantuan Badan Keamanan Negara.
Dialogue: 0,0:06:24.61,0:06:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya anggap semua informasi\Ndan transportasi sedang terputus.
Dialogue: 0,0:06:29.45,0:06:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:06:33.62,0:06:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan bisa melakukan ini kalau waras.
Dialogue: 0,0:06:36.71,0:06:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung saja bisa membeli ini\Ndari orang yang menonton.
Dialogue: 0,0:06:39.92,0:06:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lagi cuma seharga tiga juta.
Dialogue: 0,0:06:42.09,0:06:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Didikanmu sepertinya sudah keliru.
Dialogue: 0,0:06:44.93,0:06:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho, jangan jadi waras,\Nayo menggila.
Dialogue: 0,0:06:48.64,0:06:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Hinagiku dan Sakura menghilang,
Dialogue: 0,0:06:51.60,0:06:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keseharian kita selalu terasa gila.
Dialogue: 0,0:06:56.98,0:06:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berangkat.
Dialogue: 0,0:07:05.86,0:07:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak seberapa.
Dialogue: 0,0:07:15.62,0:07:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membuat ribuan,\Nhingga puluhan ribu kembang es.
Dialogue: 0,0:07:21.09,0:07:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar suatu saat bisa memberinya bunga lagi.
Dialogue: 0,0:07:25.05,0:07:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ambil rute terpendek.
Dialogue: 0,0:07:27.84,0:07:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menyelamatkan mereka berdua!
Dialogue: 0,0:07:29.76,0:07:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti!
Dialogue: 0,0:07:37.14,0:07:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa melakukan itu?
Dialogue: 0,0:07:42.11,0:07:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini bilang aku yang sudah memancing.
Dialogue: 0,0:07:45.28,0:07:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara rok yang pendek.
Dialogue: 0,0:07:47.74,0:07:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya tidak apa-apa kalau main pegang.
Dialogue: 0,0:07:51.91,0:07:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pria keberapa yang seperti ini?
Dialogue: 0,0:07:54.83,0:07:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak paham.
Dialogue: 0,0:07:57.50,0:08:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya coba kulakukan hal yang sama.
Dialogue: 0,0:08:01.75,0:08:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini mukanya seperti hama.
Dialogue: 0,0:08:04.34,0:08:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya tidak apa-apa kalau dibasmi.
Dialogue: 0,0:08:06.55,0:08:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar begitu, kan?
Dialogue: 0,0:08:14.35,0:08:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aneh sekali.
Dialogue: 0,0:08:17.77,0:08:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini malah kaget.
Dialogue: 0,0:08:20.27,0:08:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa mengira kalau dirinya\Ntidak akan mendapat kekerasan?
Dialogue: 0,0:08:24.90,0:08:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara dirinya lebih kuat?\NLebih berkuasa?
Dialogue: 0,0:08:28.57,0:08:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya boleh menyakitiku, begitu?
Dialogue: 0,0:08:32.78,0:08:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak salah!
Dialogue: 0,0:08:36.25,0:08:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau jadi kuat,\Nlalu menolong orang yang lemah.
Dialogue: 0,0:08:49.59,0:08:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukannya cinta atau apa.
Dialogue: 0,0:08:51.97,0:08:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah satu tahun,\Nakan langsung kugugat cerai.
Dialogue: 0,0:08:54.76,0:08:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pilihan lain\Nuntuk keluar dari rumah ini.
Dialogue: 0,0:09:06.15,0:09:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti bisa jadi seperti itu.
Dialogue: 0,0:09:08.99,0:09:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah tidak akan\Nkehilangan apa pun lagi.
Dialogue: 0,0:09:13.07,0:09:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mikami!\NBantu aku!
Dialogue: 0,0:09:23.58,0:09:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayi... Bayiku...
Dialogue: 0,0:09:28.38,0:09:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayi...
Dialogue: 0,0:09:31.43,0:09:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayiku...
Dialogue: 0,0:09:36.26,0:09:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bisa.
Dialogue: 0,0:09:37.52,0:09:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tahu rasanya sakit.
Dialogue: 0,0:09:41.75,0:09:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku, ya, Mikami.
Dialogue: 0,0:09:45.15,0:09:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bunuh para dewa, ancam pemerintah,\Nlalu ubah dunia.
Dialogue: 0,0:09:52.70,0:09:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:09:55.03,0:09:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kepikiran sesuatu yang menarik.
Dialogue: 0,0:10:03.04,0:10:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-teman kalian, ya?
Dialogue: 0,0:10:04.67,0:10:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, cuma ini rekan-rekan\NHigan-Nishi yang ada.
Dialogue: 0,0:10:07.92,0:10:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kami berniat menyebar\Nkehebatan Nona Hinagiku,
Dialogue: 0,0:10:10.88,0:10:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menambah jumlah pengikut!
Dialogue: 0,0:10:13.51,0:10:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap dinantikan!
Dialogue: 0,0:10:14.55,0:10:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nona Himedaka! Apa kamu dengar?\N- Tidak butuh! Jangan ditambah!
Dialogue: 0,0:10:16.43,0:10:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mohon, tolong dibuka!\N- Sakura, suara ini...
Dialogue: 0,0:10:20.68,0:10:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kayo! Nona Himedaka!\NApa kalian di dalam?
Dialogue: 0,0:10:24.40,0:10:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawal Desa Musim Dingin, ya.
Dialogue: 0,0:10:26.77,0:10:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubuka sekarang!\NLepas persenjataan kalian dan masuklah!
Dialogue: 0,0:10:32.90,0:10:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalian berdua tidak apa-apa.
Dialogue: 0,0:10:35.36,0:10:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah menjauh dari sisi kalian.
Dialogue: 0,0:10:38.20,0:10:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding itu, apa luka kalian\Ndari para penyamun?
Dialogue: 0,0:10:41.95,0:10:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, oleh pengawal divisi Musim Semi.
Dialogue: 0,0:10:45.67,0:10:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua sudah dihabisi, tapi kemungkinan\Nmasih ada pengkhianat yang tersisa.
Dialogue: 0,0:10:50.59,0:10:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut informasi teman kami.
Dialogue: 0,0:10:52.92,0:10:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasai sudah keluar uang ke sana-kemari\Nuntuk membuat komplotan, lo.
Dialogue: 0,0:10:58.26,0:10:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mereka?
Dialogue: 0,0:10:59.72,0:11:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan damkar saja belum datang\Npadahal sudah sericuh ini...
Dialogue: 0,0:11:03.64,0:11:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}artinya seperti itu, kan?
Dialogue: 0,0:11:07.10,0:11:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tutup gerbang depan!
Dialogue: 0,0:11:09.44,0:11:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada pegawai yang tertinggal\Ndi tiap lantai.
Dialogue: 0,0:11:12.57,0:11:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus dievakuasi.
Dialogue: 0,0:11:13.74,0:11:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami saja.
Dialogue: 0,0:11:20.91,0:11:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higan-Nishi?
Dialogue: 0,0:11:22.29,0:11:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sebaiknya diringkus?
Dialogue: 0,0:11:24.58,0:11:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manfaatkan saja kalau bisa digunakan.
Dialogue: 0,0:11:27.33,0:11:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjatanya juga sudah disita.
Dialogue: 0,0:11:28.67,0:11:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada masalah\Nkalau kamu memercayai kami!
Dialogue: 0,0:11:32.21,0:11:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:11:33.17,0:11:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aspek tidak pasti bukankah\Nsebaiknya disingkirkan?
Dialogue: 0,0:11:37.84,0:11:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kami!
Dialogue: 0,0:11:39.22,0:11:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakinya terluka.
Dialogue: 0,0:11:46.73,0:11:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin tidak perlu dibunuh?
Dialogue: 0,0:11:48.73,0:11:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga akan mati.
Dialogue: 0,0:11:50.94,0:11:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasang bom adalah prioritas.
Dialogue: 0,0:11:54.61,0:11:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langkah apa yang terbaik?
Dialogue: 0,0:11:56.40,0:11:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aspek tidak pasti sebaiknya disingkirkan.
Dialogue: 0,0:11:58.16,0:11:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang boleh kupercaya?
Dialogue: 0,0:11:59.66,0:12:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada masalah\Nkalau kamu memercayai kami!
Dialogue: 0,0:12:02.91,0:12:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang musuh...
Dialogue: 0,0:12:04.91,0:12:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang sekutu?
Dialogue: 0,0:12:08.17,0:12:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, tenang.
Dialogue: 0,0:12:09.50,0:12:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang yang harus kulindungi.
Dialogue: 0,0:12:13.42,0:12:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:12:16.88,0:12:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, aku juga akan membantu.
Dialogue: 0,0:12:23.47,0:12:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku...
Dialogue: 0,0:12:34.32,0:12:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berhenti!
Dialogue: 0,0:12:35.69,0:12:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:12:36.32,0:12:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, cepat!
Dialogue: 0,0:12:43.41,0:12:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura, kamu tidak apa-apa?
Dialogue: 0,0:12:45.83,0:12:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Nona Hinagiku juga baik-baik saja.
Dialogue: 0,0:12:48.37,0:12:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ada yang sedang menyerang gedung.
Dialogue: 0,0:12:51.50,0:12:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan menyerang balik—
Dialogue: 0,0:12:52.75,0:12:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu regu penyerang Kasai!
Dialogue: 0,0:12:54.88,0:12:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kabur dari sana!
Dialogue: 0,0:13:02.09,0:13:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, kesempatannya sudah lewat.
Dialogue: 0,0:13:04.68,0:13:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga jangan ke sini, bahaya.
Dialogue: 0,0:13:06.81,0:13:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku juga mengha—
Dialogue: 0,0:13:08.18,0:13:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mau meledakkan\Ngedung Biro Empat Musim!
Dialogue: 0,0:13:10.73,0:13:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi, atasan Kasai\Nsedang mengincar Hinagiku!
Dialogue: 0,0:13:16.86,0:13:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misuzu...
Dialogue: 0,0:13:19.40,0:13:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan datang?
Dialogue: 0,0:13:25.87,0:13:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, salahmu, ya.
Dialogue: 0,0:13:31.00,0:13:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang Higan-Nishi\Nkatanya menginginkanmu.
Dialogue: 0,0:13:35.96,0:13:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau dijadikan dewa mereka sendiri.
Dialogue: 0,0:13:39.13,0:13:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok, bisa bilang seperti itu, ya.
Dialogue: 0,0:13:43.64,0:13:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dirimu itu punyaku.
Dialogue: 0,0:13:47.14,0:13:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dirimulah yang pantas jadi putriku!
Dialogue: 0,0:13:59.11,0:14:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak apa-apa.
Dialogue: 0,0:14:02.07,0:14:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu akhirnya kembali.
Dialogue: 0,0:14:08.58,0:14:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ingin bertemu denganmu.
Dialogue: 0,0:14:11.04,0:14:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kamu pulang...
Dialogue: 0,0:14:16.84,0:14:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama delapan tahun sejak itu.
Dialogue: 0,0:14:19.80,0:14:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipaksa hidup sebagai putri orang ini.
Dialogue: 0,0:14:25.26,0:14:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku penuh harap.
Dialogue: 0,0:14:28.93,0:14:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:14:30.93,0:14:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan ada yang menyelamatkanku.
Dialogue: 0,0:14:35.98,0:14:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A... ku...
Dialogue: 0,0:14:39.19,0:14:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, setelah dikurung bertahun-tahun...
Dialogue: 0,0:14:45.16,0:14:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku tidak percaya apa pun lagi.
Dialogue: 0,0:14:50.29,0:14:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku...
Dialogue: 0,0:14:53.79,0:14:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak ada seorang pun yang menolong.
Dialogue: 0,0:15:00.59,0:15:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:15:03.76,0:15:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah ****.
Dialogue: 0,0:15:10.56,0:15:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu itu ****!\N- Mungkin saja.
Dialogue: 0,0:15:13.52,0:15:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku yang dipanggil dengan nama lain\Nadalah yang sesungguhnya
Dialogue: 0,0:15:18.06,0:15:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan semua kenangan masa lalu\Nadalah kesalahan.
Dialogue: 0,0:15:22.32,0:15:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dunia luar itu ada?
Dialogue: 0,0:15:24.74,0:15:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa diriku yang ini benar?
Dialogue: 0,0:15:27.99,0:15:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kalau sudah tidak ada\Nyang mencari lagi.
Dialogue: 0,0:15:33.33,0:15:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ****.
Dialogue: 0,0:15:36.29,0:15:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kepikiran sesuatu yang menarik.
Dialogue: 0,0:15:39.96,0:15:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan dari empat musim itu
Dialogue: 0,0:15:42.09,0:15:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya terpilih dari keturunan utusan, ya.
Dialogue: 0,0:15:46.88,0:15:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:15:48.89,0:15:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu berkeluarga,\Nakan terlahir utusan empat musim dari sini.
Dialogue: 0,0:15:55.10,0:15:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasai akan menjadi desa utusan.
Dialogue: 0,0:15:59.02,0:15:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:15:59.90,0:16:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali, bukan?
Dialogue: 0,0:16:01.44,0:16:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke... luar... ga?
Dialogue: 0,0:16:04.69,0:16:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk.
Dialogue: 0,0:16:07.53,0:16:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang asli desa.
Dialogue: 0,0:16:09.82,0:16:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, ya.
Dialogue: 0,0:16:11.49,0:16:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin Mikami yang jadi pasangan\Ndari dirimu yang manis ini.
Dialogue: 0,0:16:16.37,0:16:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau anak dari dirimu dan Mikami,\Nrasanya sangat bisa kusayang.
Dialogue: 0,0:16:21.84,0:16:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Mikami itu milikku,\Njadi sepertinya tidak bisa kukasih.
Dialogue: 0,0:16:27.13,0:16:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:16:31.05,0:16:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gozen, yakin mau dilakukan?
Dialogue: 0,0:16:33.68,0:16:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:16:35.02,0:16:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lama ini sudah menstruasi.
Dialogue: 0,0:16:36.93,0:16:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapkan obatnya.
Dialogue: 0,0:16:38.75,0:16:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudnya.
Dialogue: 0,0:16:40.73,0:16:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pohon uang yang akhirnya didapat\Nbisa hancur, lo.
Dialogue: 0,0:16:43.32,0:16:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:16:44.57,0:16:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pernah dipakai seperti itu.
Dialogue: 0,0:17:00.08,0:17:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:17:04.92,0:17:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan keras kepala.
Dialogue: 0,0:17:07.76,0:17:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia ini ada banyak hal\Nyang lebih menyakitkan.
Dialogue: 0,0:17:10.47,0:17:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bertahan menjalaninya.
Dialogue: 0,0:17:12.89,0:17:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kamu juga harus begitu.
Dialogue: 0,0:17:16.97,0:17:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:17:19.06,0:17:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak...
Dialogue: 0,0:17:21.31,0:17:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau...
Dialogue: 0,0:17:22.73,0:17:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:17:24.15,0:17:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, tolong!
Dialogue: 0,0:17:26.15,0:17:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa saja!
Dialogue: 0,0:17:29.65,0:17:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:17:31.24,0:17:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura... Sakura...\NSakura!
Dialogue: 0,0:17:35.70,0:17:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei... Tuan Rosei...\NTuan Rosei!
Dialogue: 0,0:17:40.58,0:17:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa saja... tolong aku!
Dialogue: 0,0:17:44.71,0:17:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong...
Dialogue: 0,0:17:48.34,0:17:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada yang mau menolong.
Dialogue: 0,0:17:51.72,0:17:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, ayo menurut pada perkataanku.
Dialogue: 0,0:17:56.10,0:17:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau orang-orang yang coba kamu lindungi
Dialogue: 0,0:17:59.18,0:18:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua akan kubunuh!
Dialogue: 0,0:18:09.94,0:18:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu...
Dialogue: 0,0:18:13.95,0:18:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyerah!
Dialogue: 0,0:18:17.83,0:18:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak kuat.
Dialogue: 0,0:18:20.37,0:18:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti tertolong!
Dialogue: 0,0:18:21.96,0:18:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, berjuanglah...
Dialogue: 0,0:18:26.17,0:18:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa berjuang.
Dialogue: 0,0:18:27.79,0:18:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa berusaha, kok.
Dialogue: 0,0:18:31.30,0:18:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak bisa berusaha.
Dialogue: 0,0:18:34.01,0:18:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Tuan Rosei?
Dialogue: 0,0:18:38.64,0:18:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuserahkan padamu.
Dialogue: 0,0:18:41.39,0:18:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku bukan...
Dialogue: 0,0:18:43.89,0:18:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan "diriku", kan?
Dialogue: 0,0:18:47.81,0:18:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon.
Dialogue: 0,0:18:50.69,0:18:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau mati?
Dialogue: 0,0:19:00.16,0:19:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:12.05,0:19:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah boleh.
Dialogue: 0,0:19:33.94,0:19:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda!
Dialogue: 0,0:19:46.12,0:19:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendadak dia jadi diam.
Dialogue: 0,0:19:51.67,0:19:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini apa tidak rusak?
Dialogue: 0,0:19:54.26,0:19:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disiram air juga akan kembali semula.
Dialogue: 0,0:19:58.34,0:20:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah untung sekarang,\Nternyata tidak butuh obat.
Dialogue: 0,0:20:05.10,0:20:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gozen...
Dialogue: 0,0:20:10.90,0:20:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:16.95,0:20:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, Hinagiku dibunuh?
Dialogue: 0,0:20:25.54,0:20:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:33.92,0:20:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri!
Dialogue: 0,0:21:25.06,0:21:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura... Kakanda Itecho...
Dialogue: 0,0:21:32.85,0:21:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rosei...
Dialogue: 0,0:21:37.28,0:21:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian di mana?
Dialogue: 0,0:21:41.36,0:21:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:21:44.45,0:21:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di sini...
Dialogue: 0,0:21:54.04,0:21:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mengerti?\NKasai akan ke sana!
Dialogue: 0,0:21:56.38,0:22:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjinak bom sudah dipanggil,\Ntapi entah kapan akan tiba di situasi begini!
Dialogue: 0,0:22:00.51,0:22:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantuan pemerintah juga\Ntidak bisa diharapkan!
Dialogue: 0,0:22:04.39,0:22:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kami akan ke sana!
Dialogue: 0,0:22:06.22,0:22:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larilah kalau bisa!
Dialogue: 0,0:22:08.39,0:22:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sakura!\NSakura?
Dialogue: 0,0:22:11.39,0:22:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:22:14.35,0:22:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kulindungi...
Dialogue: 0,0:22:15.86,0:22:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bagaimana?
Dialogue: 0,0:22:17.61,0:22:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kulindungi!
Dialogue: 0,0:22:19.11,0:22:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa saja...
Dialogue: 0,0:22:21.11,0:22:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku...
Dialogue: 0,0:22:22.61,0:22:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, kumohon...
Dialogue: 0,0:22:24.74,0:22:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang harus melindunginya!
Dialogue: 0,0:22:27.24,0:22:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itecho!
Dialogue: 0,0:22:29.62,0:22:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:22:37.79,0:22:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:22:40.01,0:22:41.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku.
Dialogue: 0,0:22:44.38,0:22:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:23:25.55,0:23:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Azami.
Dialogue: 0,0:23:27.34,0:23:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu.
Dialogue: 0,0:23:31.56,0:23:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu markas Kasai?
Dialogue: 0,0:23:35.60,0:23:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, Nadeshiko!
