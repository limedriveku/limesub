Dialogue: 0,0:00:36.47,0:00:39.47,tanda,,0000,0000,0000,,EPISODE SATU: TARIAN MUSIM SEMI
Dialogue: 0,0:01:54.01,0:01:56.22,tanda,,0000,0000,0000,,SELAMAT DATANG DI RYUGU\NRYUGU
Dialogue: 0,0:01:56.22,0:01:58.68,tanda,,0000,0000,0000,,RYUGU
Dialogue: 0,0:03:57.59,0:03:59.59,tanda,,0000,0000,0000,,DILARANG MASUK
Dialogue: 0,0:04:34.12,0:04:36.79,tanda,,0000,0000,0000,,HIYAK, HOYAK
Dialogue: 0,0:04:40.38,0:04:41.01,tanda,,0000,0000,0000,,FUAH
Dialogue: 0,0:22:43.22,0:22:46.47,tanda,,0000,0000,0000,,BERITA TERKINI: MUSIM SEMI TIBA
Dialogue: 0,0:23:12.57,0:23:17.79,tanda,,0000,0000,0000,,MUSIM SEMI TIBA DI RYUGU
Dialogue: 0,0:23:36.03,0:23:39.98,tanda,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:23:39.98,0:23:44.98,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA: SALJU YANG TERSISA
Dialogue: 0,0:00:05.72,0:00:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, pasti banyak\Nkesedihan yang terjadi.
Dialogue: 0,0:00:14.76,0:00:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari bukan berarti kalah.
Dialogue: 0,0:00:17.13,0:00:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah hidup.
Dialogue: 0,0:00:18.58,0:00:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:00:19.79,0:00:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura?
Dialogue: 0,0:00:21.08,0:00:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kelak, waktu mekar akan kembali tiba.
Dialogue: 0,0:00:24.67,0:00:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bawa Nona Hinagiku!
Dialogue: 0,0:00:27.75,0:00:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura...
Dialogue: 0,0:00:28.88,0:00:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:00:35.54,0:00:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah, tunggu saat yang tepat!
Dialogue: 0,0:00:45.02,0:00:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:00:47.98,0:00:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:00:49.24,0:00:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Sakura.
Dialogue: 0,0:00:54.28,0:00:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah, ya.
Dialogue: 0,0:00:55.91,0:00:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka musim dingin.
Dialogue: 0,0:00:59.66,0:01:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:01:01.66,0:01:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benci musim dingin, ya?
Dialogue: 0,0:01:04.66,0:01:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat benci!
Dialogue: 0,0:01:06.44,0:01:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini aku kembali bertugas.
Dialogue: 0,0:01:08.59,0:01:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan aku harus pergi minta maaf
Dialogue: 0,0:01:11.48,0:01:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke Tuan Rosei sang utusan musim dingin?
Dialogue: 0,0:01:14.51,0:01:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Nona harus ke sana?
Dialogue: 0,0:01:16.38,0:01:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru Musim Dingin\Nyang harus datang minta maaf!
Dialogue: 0,0:01:20.58,0:01:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, aku berbeda.
Dialogue: 0,0:01:25.10,0:01:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Tuan Rosei pasti kecewa.
Dialogue: 0,0:01:30.02,0:01:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:01:30.78,0:01:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah membahasnya, kan?
Dialogue: 0,0:01:32.91,0:01:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkali-kali dibilang, aku maunya kamu!
Dialogue: 0,0:01:36.59,0:01:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah di luar sana
Dialogue: 0,0:01:39.26,0:01:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada orang yang membutuhkanku?
Dialogue: 0,0:01:42.33,0:01:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:01:44.12,0:01:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu adalah Nona Kayo Hinagiku.
Dialogue: 0,0:01:47.13,0:01:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan musim semi negeri ini.
Dialogue: 0,0:02:06.18,0:02:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:02:07.98,0:02:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:02:09.57,0:02:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Himedaka Sakura.
Dialogue: 0,0:02:11.44,0:02:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawal dari Utusan Musim Semi.
Dialogue: 0,0:02:13.44,0:02:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf, Nona Himedaka.
Dialogue: 0,0:02:15.57,0:02:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Biro Empat Musim tidak mengabari
Dialogue: 0,0:02:19.41,0:02:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal datangnya utusan musim hari ini.
Dialogue: 0,0:02:22.68,0:02:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ritual pertama setelah tuanku,\NNona Kayo Hinagiku kembali bertugas.
Dialogue: 0,0:02:27.50,0:02:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebisa mungkin,\Nkami tidak mau menarik perhatian.
Dialogue: 0,0:02:30.58,0:02:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:02:31.75,0:02:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, ini tanpa dukungan Biro Empat Musim?
Dialogue: 0,0:02:35.38,0:02:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah,
Dialogue: 0,0:02:36.26,0:02:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beri izin ke Puncak Ryugu\Ndan kosongkan areanya.
Dialogue: 0,0:02:39.51,0:02:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringatan darurat untuk Puncak Ryugu.
Dialogue: 0,0:02:43.97,0:02:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang memasuki gunung.
Dialogue: 0,0:02:47.73,0:02:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pengunjung yang berada di Puncak Ryugu,\N- Itu Dewa Musim Semi, ya?
Dialogue: 0,0:02:50.40,0:02:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- harap segera turun dari gunung.\N- Itu Dewa Musim Semi, ya?
Dialogue: 0,0:02:51.23,0:02:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- harap segera turun dari gunung.\N- Tapi dia manusia, lo.
Dialogue: 0,0:02:52.52,0:02:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga jelmaan dewa—
Dialogue: 0,0:02:53.48,0:02:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berkerumun!
Dialogue: 0,0:03:01.16,0:03:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya,
Dialogue: 0,0:03:02.62,0:03:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryugu itu tempat yang hangat\Nseperti di negeri tropis, kan?
Dialogue: 0,0:03:08.54,0:03:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini keseimbangan\Nempat musim sedang rusak.
Dialogue: 0,0:03:12.05,0:03:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepuluh tahun tidak ada musim semi.
Dialogue: 0,0:03:16.72,0:03:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf.
Dialogue: 0,0:03:18.69,0:03:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipikirkan.
Dialogue: 0,0:03:20.72,0:03:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ritual hari ini sukses,\Nmasalahnya selesai.
Dialogue: 0,0:03:23.93,0:03:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itulah kita kemari.
Dialogue: 0,0:03:26.19,0:03:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa akan berhasil?
Dialogue: 0,0:03:28.79,0:03:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti berhasil.
Dialogue: 0,0:03:31.14,0:03:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berani jamin.
Dialogue: 0,0:03:32.69,0:03:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kan, aku yang melakukannya.
Dialogue: 0,0:03:37.57,0:03:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan melakukan apa pun\Nagar aku tidak pergi, kan?
Dialogue: 0,0:03:42.61,0:03:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janjimu, sih, begitu.
Dialogue: 0,0:03:44.49,0:03:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:03:45.54,0:03:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun akan kulakukan\Nagar kamu tidak pergi!
Dialogue: 0,0:03:51.04,0:03:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi akan kudatangkan.
Dialogue: 0,0:03:54.03,0:03:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salju pun akan kucairkan.
Dialogue: 0,0:03:59.96,0:04:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari, Nona Hinagiku.
Dialogue: 0,0:04:01.85,0:04:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masuk jalur pegunungan,\Nsini biar kugendong.
Dialogue: 0,0:04:05.94,0:04:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau jalan sendiri?
Dialogue: 0,0:04:07.93,0:04:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pakai penghangat, kok.
Dialogue: 0,0:04:10.22,0:04:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan soal dingin saja.
Dialogue: 0,0:04:12.48,0:04:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak boleh kelelahan sebelum ritual.
Dialogue: 0,0:04:15.35,0:04:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu akan melindungiku, kan?
Dialogue: 0,0:04:19.45,0:04:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja—
Dialogue: 0,0:04:21.65,0:04:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelindungku juga tidak boleh kelelahan.
Dialogue: 0,0:04:28.62,0:04:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu ada dewa yang datang,
Dialogue: 0,0:04:31.12,0:04:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang-orang pasti menggotongnya pakai tandu.
Dialogue: 0,0:04:34.12,0:04:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tandu?
Dialogue: 0,0:04:35.25,0:04:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu peninggalan masa lalu.
Dialogue: 0,0:04:36.80,0:04:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang pun tradisi itu\Nmasih ada di beberapa tempat.
Dialogue: 0,0:04:41.95,0:04:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku mau jalan saja.
Dialogue: 0,0:04:44.43,0:04:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau naik tandu, pasti malu.
Dialogue: 0,0:04:47.26,0:04:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking malunya, cara bicaramu jadi kuno.
Dialogue: 0,0:04:52.32,0:04:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, waktunya bekerja, Nona Hinagiku.
Dialogue: 0,0:04:56.98,0:04:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:04:58.53,0:04:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunaikan\Ntugas sebagai utusan musim semi!
Dialogue: 0,0:04:58.53,0:05:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunaikan\Ntugas sebagai utusan musim semi!
Dialogue: 0,0:05:02.57,0:05:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat yang bagus.
Dialogue: 0,0:05:04.32,0:05:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:05:07.49,0:05:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengantarmu\Nsampai tempat ritualnya.
Dialogue: 0,0:05:11.12,0:05:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:05:13.80,0:05:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya sampai di sini.
Dialogue: 0,0:05:17.69,0:05:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Biro Empat Musim
Dialogue: 0,0:05:20.50,0:05:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah mengundang 500 tamu penting,
Dialogue: 0,0:05:24.38,0:05:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku harus\Nmelakukan ritual di depan mereka?
Dialogue: 0,0:05:28.10,0:05:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu maksud kalian?
Dialogue: 0,0:05:31.90,0:05:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perwujudan Musim adalah ritual suci\Nyang harus dirahasiakan,
Dialogue: 0,0:05:35.39,0:05:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perwujudan Musim adalah ritual suci\Nyang harus dirahasiakan,\Nbukan pertunjukan!
Dialogue: 0,0:05:35.40,0:05:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan pertunjukan!
Dialogue: 0,0:05:38.25,0:05:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biro Empat Musim dan desa,\Npasti sedang mati-matian mencari kami.
Dialogue: 0,0:05:43.82,0:05:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peduli setan.
Dialogue: 0,0:05:45.32,0:05:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting, Nona Hinagiku bisa\Nmenjalankan ritual dengan percaya diri.
Dialogue: 0,0:05:50.45,0:05:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski harus mengorbankan diri,\Naku harus melindungi—
Dialogue: 0,0:05:53.91,0:05:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sakura.
Dialogue: 0,0:05:56.36,0:05:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ada apa?
Dialogue: 0,0:05:58.37,0:05:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau digendong?
Dialogue: 0,0:05:59.71,0:06:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:06:01.79,0:06:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu.
Dialogue: 0,0:06:08.72,0:06:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah ada sirene\Nlarangan masuk ke gunung.
Dialogue: 0,0:06:12.31,0:06:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:06:13.93,0:06:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia tersesat?
Dialogue: 0,0:06:16.62,0:06:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melindungi anak kecil.
Dialogue: 0,0:06:24.08,0:06:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu yang di sana!\NBerhenti!
Dialogue: 0,0:06:28.74,0:06:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tunggu!\NHei!
Dialogue: 0,0:06:36.22,0:06:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa kamu naik gunung, Dik Nazuna?
Dialogue: 0,0:06:43.42,0:06:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyapu salju.
Dialogue: 0,0:06:44.55,0:06:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:45.78,0:06:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, sih, di rumah juga bisa.
Dialogue: 0,0:06:48.43,0:06:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang sana.
Dialogue: 0,0:06:51.93,0:06:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan melakukan ritual\Ndi Puncak Ryugu.
Dialogue: 0,0:06:55.44,0:06:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salju akan mencair dan berpotensi longsor.
Dialogue: 0,0:06:59.55,0:07:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya kalau tetap di gunung.
Dialogue: 0,0:07:01.35,0:07:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ritual?
Dialogue: 0,0:07:02.44,0:07:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:04.15,0:07:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan memanggil musim semi.
Dialogue: 0,0:07:07.70,0:07:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi itu apa?
Dialogue: 0,0:07:11.66,0:07:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak tahu musim semi?
Dialogue: 0,0:07:14.49,0:07:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak.
Dialogue: 0,0:07:15.62,0:07:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umurmu berapa?
Dialogue: 0,0:07:17.38,0:07:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi dua belas.
Dialogue: 0,0:07:19.30,0:07:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti sepuluh tahun lalu—
Dialogue: 0,0:07:21.58,0:07:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja tidak ingat.
Dialogue: 0,0:07:24.13,0:07:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi itu salah satu dari empat musim.
Dialogue: 0,0:07:28.08,0:07:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini ada panas, gugur, dingin,\Nada tiga musim.
Dialogue: 0,0:07:33.19,0:07:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya ada empat.
Dialogue: 0,0:07:38.09,0:07:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Kakak akan memanggil musim semi?
Dialogue: 0,0:07:41.06,0:07:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:42.40,0:07:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Nona Kayo Hinagiku.
Dialogue: 0,0:07:45.48,0:07:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan musim semi negeri ini.
Dialogue: 0,0:07:48.20,0:07:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku tahu.
Dialogue: 0,0:07:50.19,0:07:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang musim dingin karena\NUtusan Musim Dingin yang memanggil, kan?
Dialogue: 0,0:07:54.57,0:07:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang musim dingin karena\NUtusan Musim Dingin yang memanggil, kan?\NBenar.
Dialogue: 0,0:07:54.58,0:07:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:55.29,0:07:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu banyak, ya.
Dialogue: 0,0:07:56.86,0:07:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diajari di kelas.
Dialogue: 0,0:07:58.24,0:07:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semi, panas, gugur, dingin.
Dialogue: 0,0:07:59.62,0:08:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan masing-masing musim\Nberkeliling untuk mendatangkan musim—
Dialogue: 0,0:08:03.55,0:08:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:08:04.96,0:08:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semi dari empat musim,\Nmaksudnya musim semi?
Dialogue: 0,0:08:04.97,0:08:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semi dari empat musim,\Nmaksudnya musim semi?
Dialogue: 0,0:08:08.21,0:08:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semi dari empat musim,\Nmaksudnya musim semi?\NKamu sudah ingat?
Dialogue: 0,0:08:08.22,0:08:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah ingat?
Dialogue: 0,0:08:10.42,0:08:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tapi kok mencurigakan.
Dialogue: 0,0:08:14.09,0:08:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang utusan asli,\Ntunjukkan bahwa kamu dewa.
Dialogue: 0,0:08:18.06,0:08:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya—
Dialogue: 0,0:08:18.81,0:08:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:20.56,0:08:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Dik Nazuna.
Dialogue: 0,0:08:23.07,0:08:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan aku tunjukkan.
Dialogue: 0,0:08:25.88,0:08:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sedikit koreksi.
Dialogue: 0,0:08:29.53,0:08:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukanlah dewa.
Dialogue: 0,0:08:35.27,0:08:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya seorang utusan
Dialogue: 0,0:08:38.16,0:08:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dipinjami kekuatan\Nuntuk mendatangkan musim.
Dialogue: 0,0:08:43.71,0:08:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan musim semi adalah Percepatan Hayat.
Dialogue: 0,0:08:48.63,0:08:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang punya kekuatan ajaib.
Dialogue: 0,0:08:51.96,0:08:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu hanya pinjaman.
Dialogue: 0,0:08:57.60,0:09:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain bisa melakukan ini.
Dialogue: 0,0:09:00.51,0:09:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama saja dengan orang biasa.
Dialogue: 0,0:09:04.95,0:09:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya seorang utusan.
Dialogue: 0,0:09:07.69,0:09:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan yang akan mengatur keempat musim.
Dialogue: 0,0:09:15.63,0:09:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah paham, kan?
Dialogue: 0,0:09:17.74,0:09:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi dari sini.
Dialogue: 0,0:09:20.52,0:09:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah.
Dialogue: 0,0:09:21.37,0:09:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa menyapu salju di gunung?
Dialogue: 0,0:09:23.92,0:09:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya salju, tahu.
Dialogue: 0,0:09:25.63,0:09:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu disuruh seseorang?
Dialogue: 0,0:09:28.46,0:09:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keinginanku sendiri.
Dialogue: 0,0:09:31.22,0:09:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong!
Dialogue: 0,0:09:32.38,0:09:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bohong.
Dialogue: 0,0:09:33.71,0:09:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya jangan!\NCepat mengungsi!
Dialogue: 0,0:09:35.76,0:09:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:09:36.43,0:09:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ogah! Pokoknya ogah!\N- Kayak udang saja!
Dialogue: 0,0:09:38.85,0:09:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melawan, bocil udang!
Dialogue: 0,0:09:40.26,0:09:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan!
Dialogue: 0,0:09:42.68,0:09:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak lucu!
Dialogue: 0,0:09:44.81,0:09:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tertawa.
Dialogue: 0,0:09:46.81,0:09:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, aku serius.
Dialogue: 0,0:09:49.11,0:09:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ritual harus dilakukan\Nsebelum matahari terbenam.
Dialogue: 0,0:09:53.24,0:09:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sakura.
Dialogue: 0,0:09:54.69,0:09:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tolong carikan keluarga Dik Nazuna?
Dialogue: 0,0:09:59.82,0:10:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Dik Nazuna akan menunggu di sini.
Dialogue: 0,0:10:04.83,0:10:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:10:06.04,0:10:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus tetap dikawal!
Dialogue: 0,0:10:08.21,0:10:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:10:10.17,0:10:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sebentar, kok.
Dialogue: 0,0:10:12.04,0:10:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu!
Dialogue: 0,0:10:15.46,0:10:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hal itu terjadi lagi...
Dialogue: 0,0:10:19.01,0:10:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan...
Dialogue: 0,0:10:21.72,0:10:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:10:24.16,0:10:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Sakura.
Dialogue: 0,0:10:27.14,0:10:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipikirkan lagi.
Dialogue: 0,0:10:30.87,0:10:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seumur hidup
Dialogue: 0,0:10:32.79,0:10:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kupikirkan.
Dialogue: 0,0:10:35.02,0:10:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa pergi ke masa lalu,\Ningin kubunuh diriku saat itu.
Dialogue: 0,0:10:39.62,0:10:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kubunuh, ingin kubunuh!
Dialogue: 0,0:10:42.52,0:10:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:10:44.53,0:10:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku bersamamu, kan?
Dialogue: 0,0:10:48.83,0:10:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:10:51.59,0:10:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tenang saja.
Dialogue: 0,0:10:57.40,0:11:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku kehilangan akal sejenak.
Dialogue: 0,0:11:02.74,0:11:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah katana pelindung Nona Hinagiku.
Dialogue: 0,0:11:05.68,0:11:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku wajib membantu apa pun\Nyang Nona mau lakukan.
Dialogue: 0,0:11:05.69,0:11:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku wajib membantu apa pun\Nyang Nona mau lakukan.
Dialogue: 0,0:11:09.84,0:11:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ini pengecualian,\Nmari kita temani bocil udang ini.
Dialogue: 0,0:11:13.69,0:11:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kemauanmu, kan?
Dialogue: 0,0:11:18.57,0:11:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Nazuna, topimu cantik, ya.
Dialogue: 0,0:11:25.74,0:11:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:11:26.87,0:11:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu yang memilihkannya!
Dialogue: 0,0:11:28.92,0:11:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesukaanku!
Dialogue: 0,0:11:32.67,0:11:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Bibi.
Dialogue: 0,0:11:34.79,0:11:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil aku bibi.
Dialogue: 0,0:11:36.67,0:11:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Himedaka Sakura,\Nmasih berumur 19 tahun.
Dialogue: 0,0:11:40.96,0:11:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah,\Nterima kasih, Sakura.
Dialogue: 0,0:11:48.99,0:11:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Hinagiku
Dialogue: 0,0:11:51.48,0:11:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}main petak umpet sampai sepuluh tahun?
Dialogue: 0,0:11:55.23,0:11:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang dewasa bilang,
Dialogue: 0,0:11:57.00,0:11:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musim dingin terus berlanjut\Nkarena disembunyikan dewa.
Dialogue: 0,0:11:57.01,0:12:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musim dingin terus berlanjut\Nkarena disembunyikan dewa.
Dialogue: 0,0:12:00.95,0:12:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disembunyikan dewa itu maksudnya\Npetak umpetnya para dewa, kan?
Dialogue: 0,0:12:04.96,0:12:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku tidak bersalah.
Dialogue: 0,0:12:06.53,0:12:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kecelakaan.
Dialogue: 0,0:12:08.16,0:12:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecelakaan?
Dialogue: 0,0:12:09.52,0:12:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu terluka dan masuk rumah sakit?
Dialogue: 0,0:12:11.71,0:12:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:12:12.86,0:12:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu tidak perlu tahu.
Dialogue: 0,0:12:15.29,0:12:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:16.29,0:12:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hubungannya, kan?
Dialogue: 0,0:12:17.54,0:12:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, lah!
Dialogue: 0,0:12:19.51,0:12:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku bekerja di tempat wisata!
Dialogue: 0,0:12:22.59,0:12:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryugu ada di pulau selatan,
Dialogue: 0,0:12:24.68,0:12:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kami kerepotan karena salju turun terus!
Dialogue: 0,0:12:28.68,0:12:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara itu, keluargaku\Ntidak punya banyak uang.
Dialogue: 0,0:12:33.07,0:12:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membeli barang yang kusuka!
Dialogue: 0,0:12:37.94,0:12:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak bermaksud jahat, lo.
Dialogue: 0,0:12:44.66,0:12:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:12:45.82,0:12:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuberi tahu, tapi rahasia, ya.
Dialogue: 0,0:12:49.74,0:12:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang menunggu waktu yang tepat.
Dialogue: 0,0:12:57.55,0:13:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hal yang dikatakan ibu dari kenalanku.
Dialogue: 0,0:13:06.30,0:13:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski saat ini kalah, jangan menyerah.
Dialogue: 0,0:13:11.02,0:13:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggulah hari saat bisa kembali berjuang.
Dialogue: 0,0:13:15.15,0:13:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ditimpa kesulitan, jadilah seperti\Npara hewan saat hibernasi.
Dialogue: 0,0:13:20.86,0:13:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahan, bertahan, dan bertahanlah.
Dialogue: 0,0:13:24.82,0:13:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal tidak menyerah dan tetap hidup.
Dialogue: 0,0:13:28.68,0:13:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kelak, musim semi akan tiba.
Dialogue: 0,0:13:34.69,0:13:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bertahan selama sepuluh tahun?
Dialogue: 0,0:13:37.64,0:13:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, bukan hanya itu.
Dialogue: 0,0:13:41.30,0:13:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertempur dengan caraku sendiri.
Dialogue: 0,0:13:45.91,0:13:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang paham,\Ntapi kamu juga kesusahan, ya.
Dialogue: 0,0:13:50.81,0:13:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja begitu.
Dialogue: 0,0:13:53.37,0:13:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, karena sudah merepotkan banyak orang,
Dialogue: 0,0:13:56.73,0:13:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan berjuang sangat keras.
Dialogue: 0,0:13:59.15,0:14:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, lihat aku, ya.
Dialogue: 0,0:14:03.44,0:14:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah puas, kan?
Dialogue: 0,0:14:05.28,0:14:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasannya sangat pelik.
Dialogue: 0,0:14:06.95,0:14:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buat Nona Hinagiku bicara lagi!
Dialogue: 0,0:14:09.03,0:14:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membentak!
Dialogue: 0,0:14:10.12,0:14:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa orang dewasa sukanya membentak, sih?
Dialogue: 0,0:14:13.79,0:14:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:14:16.24,0:14:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan jahat, dong.
Dialogue: 0,0:14:18.87,0:14:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci orang dewasa,\Nsoalnya mereka jahat.
Dialogue: 0,0:14:22.96,0:14:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci orang dewasa,\Nsoalnya mereka jahat.\NPara orang dewasa
Dialogue: 0,0:14:22.97,0:14:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para orang dewasa
Dialogue: 0,0:14:25.21,0:14:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersikap kasar ke Dik Nazuna?
Dialogue: 0,0:14:41.36,0:14:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah hampir di puncak.
Dialogue: 0,0:14:44.32,0:14:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana tujuan bocil itu?
Dialogue: 0,0:14:48.91,0:14:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sampai.
Dialogue: 0,0:15:00.29,0:15:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kamu mau apa?
Dialogue: 0,0:15:03.00,0:15:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyapu salju.
Dialogue: 0,0:15:05.78,0:15:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Nazuna.
Dialogue: 0,0:15:07.38,0:15:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini makam, lo?
Dialogue: 0,0:15:12.10,0:15:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, kok.
Dialogue: 0,0:15:13.60,0:15:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku tidur di bawah sini.
Dialogue: 0,0:15:16.89,0:15:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan kalau dia kedinginan.
Dialogue: 0,0:15:20.94,0:15:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini terlihat dari jendela rumahku.
Dialogue: 0,0:15:24.62,0:15:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap hari aku selalu melihatnya.
Dialogue: 0,0:15:29.28,0:15:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat bagus saat musim panas.
Dialogue: 0,0:15:31.47,0:15:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa sepi karena bunganya indah.
Dialogue: 0,0:15:34.29,0:15:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim gugur juga bagus.
Dialogue: 0,0:15:36.51,0:15:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena daun mapel yang gugur bisa jadi tikar.
Dialogue: 0,0:15:40.12,0:15:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau musim dingin.
Dialogue: 0,0:15:43.67,0:15:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut Ibu kedinginan.
Dialogue: 0,0:15:47.88,0:15:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun tidak, tetap akan kulakukan.
Dialogue: 0,0:15:50.47,0:15:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya itu tidak boleh?
Dialogue: 0,0:15:52.60,0:15:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, tapi—
Dialogue: 0,0:15:54.22,0:15:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bilang aku aneh, kan?
Dialogue: 0,0:15:57.39,0:15:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku benci orang dewasa!
Dialogue: 0,0:15:59.89,0:16:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah juga bilang begitu.
Dialogue: 0,0:16:02.37,0:16:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya Ibu sudah tidak ada lagi.
Dialogue: 0,0:16:04.94,0:16:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku disuruh berhenti karena sia-sia.
Dialogue: 0,0:16:07.90,0:16:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Ibu ada di sini!
Dialogue: 0,0:16:10.36,0:16:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak sia-sia!
Dialogue: 0,0:16:11.61,0:16:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak aneh!
Dialogue: 0,0:16:12.82,0:16:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masuk akal!
Dialogue: 0,0:16:21.12,0:16:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:16:23.31,0:16:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Dik Nazuna ingin bilang\N"cinta" pada ibunya, ya.
Dialogue: 0,0:16:29.91,0:16:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat mencintainya, itu saja.
Dialogue: 0,0:16:34.14,0:16:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:36.68,0:16:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:40.47,0:16:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, dia tidaklah tahu.
Dialogue: 0,0:16:43.73,0:16:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi kamu tiada selama sepuluh tahun,
Dialogue: 0,0:16:46.15,0:16:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nazuna hidup tanpa tahu musim semi.
Dialogue: 0,0:16:49.08,0:16:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dialah contoh...
Dialogue: 0,0:16:52.16,0:16:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rakyat yang membutuhkan peran dari kita.
Dialogue: 0,0:16:57.55,0:17:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata betulan ada.
Dialogue: 0,0:17:00.42,0:17:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang membutuhkanku.
Dialogue: 0,0:17:05.00,0:17:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang utusan dilarang\Nsembarangan memakai kekuatan.
Dialogue: 0,0:17:08.33,0:17:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sekadar mengadakan ritual di sini\Nuntuk melipur kesedihan rakyat yang masih belia.
Dialogue: 0,0:17:14.55,0:17:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keempat Musim pasti mengizinkannya.
Dialogue: 0,0:17:17.91,0:17:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang ada di sini adalah\NUtusan Musim Semi.
Dialogue: 0,0:17:21.48,0:17:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kayo Hinagiku.
Dialogue: 0,0:17:24.03,0:17:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Nona Hinagiku.\NDatangkan musim semi ke negeri ini.
Dialogue: 0,0:17:28.86,0:17:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari nikmati pemandangan bunga sakura.
Dialogue: 0,0:17:33.51,0:17:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:17:36.54,0:17:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan perwujudan\Nmusim semi yang indah.
Dialogue: 0,0:17:43.22,0:17:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Nazuna.
Dialogue: 0,0:17:47.46,0:17:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, sudah kuputuskan.
Dialogue: 0,0:17:52.34,0:17:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupanggil musim semi di sini.
Dialogue: 0,0:17:55.68,0:17:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau musim semi tiba, salju akan mencair.
Dialogue: 0,0:17:59.37,0:18:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu menyapu salju lagi.
Dialogue: 0,0:18:02.93,0:18:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibumu tidak akan kedinginan lagi.
Dialogue: 0,0:18:07.19,0:18:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:18:09.07,0:18:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:10.10,0:18:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, rahasia, ya.
Dialogue: 0,0:18:13.16,0:18:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ini tidak boleh ditunjukkan.
Dialogue: 0,0:18:51.53,0:19:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Di malam kabut rembulan,\Ntersembunyi tajam bilah pedang ♪
Dialogue: 0,0:19:03.79,0:19:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Malam gulita perlahan berkabut\Ndan menghilang ♪
Dialogue: 0,0:19:15.37,0:19:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tahanlah rindu ♪
Dialogue: 0,0:19:21.83,0:19:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Pesta musim semi begitu semarak ♪
Dialogue: 0,0:19:28.07,0:19:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lereng gunung\Ndihiasi bunga hujan lembayung ♪
Dialogue: 0,0:19:33.88,0:19:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Biarlah bumi diwarnai kanola ♪
Dialogue: 0,0:19:45.40,0:19:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tiada bunga yang mekar abadi ♪
Dialogue: 0,0:19:51.50,0:19:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menyedihkan namun dirindukan ♪
Dialogue: 0,0:19:54.79,0:19:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semi, panas, gugur, dingin.
Dialogue: 0,0:19:56.67,0:19:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan melantunkan "Senandung Musim"\Nyang diwarisi masing-masing.
Dialogue: 0,0:19:59.76,0:20:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta mempersembahkan tarian,\Ndapat menyalurkan kekuatan ke sekitar.
Dialogue: 0,0:20:04.02,0:20:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perwujudan musim semi yang sempurna.
Dialogue: 0,0:20:06.54,0:20:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nazuna, inilah...
Dialogue: 0,0:20:09.25,0:20:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah musim semi.
Dialogue: 0,0:20:10.77,0:20:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:20:12.15,0:20:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah, kan?
Dialogue: 0,0:20:15.52,0:20:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:20:17.15,0:20:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini.
Dialogue: 0,0:20:21.53,0:20:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah lihat musim semi.
Dialogue: 0,0:20:25.74,0:20:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikasih lihat pun, bayi mana paham?
Dialogue: 0,0:20:28.74,0:20:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saja.
Dialogue: 0,0:20:29.83,0:20:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting itu pengalamannya.
Dialogue: 0,0:20:32.12,0:20:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Nazuna?
Dialogue: 0,0:20:34.44,0:20:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:20:36.79,0:20:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini musim semi.
Dialogue: 0,0:20:40.05,0:20:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku bisa lupa, ya?
Dialogue: 0,0:20:43.59,0:20:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kenangan berharga,\Nkok aku malah tidak ingat?
Dialogue: 0,0:20:49.10,0:20:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kutunjukkan ke Ayah.
Dialogue: 0,0:20:52.56,0:20:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hangat sekali.
Dialogue: 0,0:20:55.01,0:20:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Sakura?
Dialogue: 0,0:20:57.65,0:20:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura?
Dialogue: 0,0:20:59.11,0:21:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi orang sepertimulah\NNona Hinagiku berjuang keras.
Dialogue: 0,0:21:03.76,0:21:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan dirinya sendiri, tapi demi orang lain.
Dialogue: 0,0:21:07.03,0:21:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sangat menderita, dia tetap berjuang.
Dialogue: 0,0:21:12.04,0:21:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang itu terbayar, musim semi tiba,\Ndirimu pun merasa senang.
Dialogue: 0,0:21:18.76,0:21:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahagia rasanya.
Dialogue: 0,0:21:21.13,0:21:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:22.68,0:21:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahagia.
Dialogue: 0,0:21:28.05,0:21:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nazuna, berbanggalah.
Dialogue: 0,0:21:31.43,0:21:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sekarang terasa sepi,
Dialogue: 0,0:21:34.64,0:21:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu dicintai dunia.
Dialogue: 0,0:21:39.15,0:21:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyaksikan.
Dialogue: 0,0:21:44.40,0:21:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi telah berhasil tiba di sini.
Dialogue: 0,0:21:55.04,0:21:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya ada musim dingin.
Dialogue: 0,0:21:57.47,0:22:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia hanya punya musim dingin.
Dialogue: 0,0:22:00.40,0:22:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kuat menahan kesepian,\Nmusim dingin membuat musim semi.
Dialogue: 0,0:22:04.09,0:22:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi dan musim dingin\Nsaling merindukan.
Dialogue: 0,0:22:08.28,0:22:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus berulang dalam harmoni.
Dialogue: 0,0:22:10.60,0:22:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian musim dingin\Nmenciptakan musim panas dan gugur.
Dialogue: 0,0:22:15.37,0:22:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi mengejar musim dingin,\Ndisusul musim panas dan gugur.
Dialogue: 0,0:22:19.29,0:22:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjadilah siklus musim semi,\Npanas, gugur, dan dingin.
Dialogue: 0,0:22:22.57,0:22:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi romansa musim semi\Ndan musim dingin telah tiada.
Dialogue: 0,0:22:26.77,0:22:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situ, musim panas\Ndan gugur memberi usulan.
Dialogue: 0,0:22:30.12,0:22:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bagaimana kalau menyerahkan tugas kita\Npada mereka yang tinggal di bumi?"
Dialogue: 0,0:22:35.16,0:22:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu keempat musim memberikan\Nsebagian kekuatannya pada manusia.
Dialogue: 0,0:22:38.83,0:22:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu keempat musim memberikan\Nsebagian kekuatannya pada manusia.\NAkhirnya musim dingin punya waktu\Nuntuk mencintai musim semi.
Dialogue: 0,0:22:38.84,0:22:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya musim dingin punya waktu\Nuntuk mencintai musim semi.
Dialogue: 0,0:22:43.22,0:22:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah cerita dalam legenda.
Dialogue: 0,0:22:46.46,0:22:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim menghamparkan bunga sakura.
Dialogue: 0,0:22:48.84,0:22:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim panas memberikan lautan hijau.
Dialogue: 0,0:22:50.97,0:22:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim gugur menggantung tirai gingko.
Dialogue: 0,0:22:53.35,0:22:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim dingin akan memberi buaian perak.
Dialogue: 0,0:22:55.72,0:22:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama setahun berkeliling mengitari bumi.
Dialogue: 0,0:22:58.60,0:23:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebar kasih sayang musim\Nke seisi alam semesta.
Dialogue: 0,0:23:01.74,0:23:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang diberi kuasa\Ndan mengemban tugas dari dewa.
Dialogue: 0,0:23:05.61,0:23:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disebut sebagai Utusan Empat Musim.
Dialogue: 0,0:23:09.65,0:23:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku...
Dialogue: 0,0:23:12.57,0:23:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kisah dari Utusan Empat Musim.
Dialogue: 0,0:23:16.08,0:23:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta lanjutan dari legenda.
Dialogue: 0,0:23:17.79,0:23:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah pembunuh.
Dialogue: 0,0:23:19.37,0:23:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta kisah penyelamatan.
Dialogue: 0,0:23:21.12,0:23:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah persahabatan.
Dialogue: 0,0:23:22.71,0:23:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta kisah cinta yang umum terjadi.
Dialogue: 0,0:23:25.31,0:23:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kisah kehidupan yang dijalin\Norang-orang.
Dialogue: 0,0:23:31.59,0:23:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari sinilah kisah itu bermula.
