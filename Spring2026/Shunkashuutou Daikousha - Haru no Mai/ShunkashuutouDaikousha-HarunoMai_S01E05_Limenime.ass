Dialogue: 0,0:01:38.75,0:01:47.50,tanda,,0000,0000,0000,,UTUSAN EMPAT MUSIM: TARIAN MUSIM SEMI
Dialogue: 0,0:22:16.06,0:22:21.82,tanda,,0000,0000,0000,,EPISODE LIMA: HANYA BERDUA
Dialogue: 0,0:23:39.98,0:23:44.99,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA: TEMPAT PULANG
Dialogue: 0,0:00:24.75,0:00:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:00:27.13,0:00:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini dekat dengan Desa Musim Semi?
Dialogue: 0,0:00:33.89,0:00:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:34.98,0:00:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang masih jauh di dalam gunung.
Dialogue: 0,0:00:37.17,0:00:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa merasakannya\Ndari pepohonan dan pegunungannya?
Dialogue: 0,0:00:40.14,0:00:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan aliran energi roh yang khas.
Dialogue: 0,0:00:44.62,0:00:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tersirat.
Dialogue: 0,0:00:47.71,0:00:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang "anak" itu ingat.
Dialogue: 0,0:02:25.23,0:02:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim Semi menolak penambahan pengawal?
Dialogue: 0,0:02:28.34,0:02:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Sakura tidak suka?
Dialogue: 0,0:02:30.55,0:02:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan begitu.
Dialogue: 0,0:02:32.42,0:02:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada oposisi dari Divisi Musim Semi\NBiro Empat Musim.
Dialogue: 0,0:02:35.26,0:02:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasarnya Musim Dingin disalahkan karena
Dialogue: 0,0:02:37.56,0:02:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seenaknya mengirim pengawal\Ntanpa memberi tahu Musim Semi.
Dialogue: 0,0:02:41.10,0:02:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada serangan dari Penyamun, lo.
Dialogue: 0,0:02:43.29,0:02:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan saatnya bicara santai begitu!
Dialogue: 0,0:02:45.52,0:02:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dianggap sekadar terseret dalam\Nserangan Istana Musim Panas,
Dialogue: 0,0:02:48.82,0:02:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan secara khusus mengincar\Ntuan dan pelayan Musim Semi.
Dialogue: 0,0:02:52.28,0:02:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dua orang yang dikirim\Nsudah dilepaskan?
Dialogue: 0,0:02:54.90,0:02:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung saja bisa dibuat menyetujuinya.
Dialogue: 0,0:02:57.41,0:02:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kesannya begitu enggan.
Dialogue: 0,0:03:01.79,0:03:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itecho.
Dialogue: 0,0:03:03.33,0:03:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Musim Semi sepuluh tahun lalu,\Natau Biro Empat Musim yang sekarang.
Dialogue: 0,0:03:07.42,0:03:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tidak merasa perlakuan\Npada Hinagiku dan Sakura sangat ganjil?
Dialogue: 0,0:03:12.84,0:03:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama Desa Musim Semi.
Dialogue: 0,0:03:15.01,0:03:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Utusan Musim Semi dikatakan\Nakan muncul penggantinya bila mati.
Dialogue: 0,0:03:23.47,0:03:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin ada hubungannya\Ndengan asal-usul Hinagiku?
Dialogue: 0,0:03:27.94,0:03:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengetahuinya?
Dialogue: 0,0:03:31.02,0:03:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu tidak sengaja dengar waktu\Ndirimu bicara dengan Sakura.
Dialogue: 0,0:03:36.34,0:03:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak sedetail itu.
Dialogue: 0,0:03:38.35,0:03:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diperlukan untuk melindunginya,\Nkurasa perlu untuk mengetahuinya.
Dialogue: 0,0:03:42.41,0:03:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, beri tahu aku.
Dialogue: 0,0:03:49.13,0:03:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf, Nona Hinagiku.
Dialogue: 0,0:03:51.71,0:03:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesalahan terbesar di hidupku.
Dialogue: 0,0:03:54.01,0:03:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa, Sakura?
Dialogue: 0,0:03:57.22,0:04:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa membawa camilan\Nyang disiapkan untuk dimakan di sini!
Dialogue: 0,0:04:02.01,0:04:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegagalan yang memalukan!
Dialogue: 0,0:04:03.31,0:04:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gagal sebagai pelayan!
Dialogue: 0,0:04:05.31,0:04:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak begitu, kok.
Dialogue: 0,0:04:07.64,0:04:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:04:09.06,0:04:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menu pengganjal perut tuanku\Ndemi mengisi energi sebelum ritual
Dialogue: 0,0:04:12.57,0:04:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sudah dipilih begitu teliti,\Ndaifuku stroberi!
Dialogue: 0,0:04:17.82,0:04:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu!
Dialogue: 0,0:04:19.20,0:04:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kenapa malah kulupakan!
Dialogue: 0,0:04:20.95,0:04:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh, bodoh, bodohnya aku!
Dialogue: 0,0:04:22.20,0:04:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang orang terbodoh di Yamato!
Dialogue: 0,0:04:25.04,0:04:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kok, Sakura.
Dialogue: 0,0:04:27.54,0:04:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula aku tidak lapar.
Dialogue: 0,0:04:36.88,0:04:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf!
Dialogue: 0,0:04:47.93,0:04:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sakura...
Dialogue: 0,0:04:50.48,0:04:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai ganti dari camilan yang kelupaan.
Dialogue: 0,0:04:53.69,0:04:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo makan ini sama-sama.
Dialogue: 0,0:05:00.61,0:05:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf, Nona Hinagiku.
Dialogue: 0,0:05:03.49,0:05:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, hari ini kamu dilarang meminta maaf!
Dialogue: 0,0:05:15.13,0:05:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak?
Dialogue: 0,0:05:18.46,0:05:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya enak, Nona Hinagiku.
Dialogue: 0,0:05:26.22,0:05:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejauh mana yang kamu tahu?
Dialogue: 0,0:05:28.55,0:05:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Hinagiku adalah anak tidak sah.
Dialogue: 0,0:05:33.02,0:05:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahanda Nona Hinagiku adalah
Dialogue: 0,0:05:35.61,0:05:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayo Shungetsu, kepala keluarga Kayo\Nyang ternama di Desa Musim Semi.
Dialogue: 0,0:05:40.32,0:05:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga dikatakan kelak akan\Nmenggantikan posisi kepala desa.
Dialogue: 0,0:05:43.57,0:05:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu ibundanya,\Nkamu pernah menemui beliau.
Dialogue: 0,0:05:48.11,0:05:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan musim semi sebelumnya,\NNyonya Yukiyanagi Kobai.
Dialogue: 0,0:05:52.37,0:05:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya memang bertunangan\Ndengan Tuan Shungetsu.
Dialogue: 0,0:05:55.46,0:05:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dulunya tunangan?
Dialogue: 0,0:05:57.38,0:05:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa jadi begitu?
Dialogue: 0,0:05:59.91,0:06:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu keluarga Shirafuji?
Dialogue: 0,0:06:01.93,0:06:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga terhormat yang sudah ada\Nsejak dulu dan punya kuasa
Dialogue: 0,0:06:04.97,0:06:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik di dalam atau luar desa, kan?
Dialogue: 0,0:06:06.72,0:06:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri dari Shirafuji telah jatuh hati\Npada Tuan Shungetsu.
Dialogue: 0,0:06:11.45,0:06:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding utusan yang hanya satu generasi.
Dialogue: 0,0:06:13.81,0:06:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih menguntungkan menikah dengannya.
Dialogue: 0,0:06:16.61,0:06:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu membatalkan pertunangan, ya?
Dialogue: 0,0:06:18.36,0:06:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:19.60,0:06:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu mendapat seorang putra\Ndari pernikahan sah dengan Nyonya Shirafuji.
Dialogue: 0,0:06:23.65,0:06:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, hubungan suami istri seperti itu\Ntentu tidak berjalan mulus.
Dialogue: 0,0:06:28.37,0:06:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku pun terlahir ke dunia ini.
Dialogue: 0,0:06:32.24,0:06:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta terlarang itu kemudian tersebar di desa.
Dialogue: 0,0:06:35.45,0:06:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu terjadi insiden istri sah menebas\NNyonya Kobai dan Nona Hinagiku yang baru lahir.
Dialogue: 0,0:06:42.38,0:06:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kejadian, sepertinya Nyonya Kobai\Ndan Nona Hinagiku tinggal di luar desa.
Dialogue: 0,0:06:48.22,0:06:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggantikan Nyonya Kobai yang sering pergi,\Nsang nenek merawat Nona Hinagiku.
Dialogue: 0,0:06:53.64,0:06:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, neneknya pun meninggal.
Dialogue: 0,0:06:56.73,0:06:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lama kemudian\NNyonya Kobai pun jatuh sakit.
Dialogue: 0,0:07:03.59,0:07:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, jadi teringat.
Dialogue: 0,0:07:07.45,0:07:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena dekat dengan Desa Musim Semi?
Dialogue: 0,0:07:11.29,0:07:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau...
Dialogue: 0,0:07:12.58,0:07:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu soal masa lalu?
Dialogue: 0,0:07:15.54,0:07:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:17.10,0:07:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:07:19.13,0:07:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan punyaku.
Dialogue: 0,0:07:23.71,0:07:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenangan dari "anak" itu.
Dialogue: 0,0:07:31.43,0:07:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini musim semi Ibunda!
Dialogue: 0,0:07:34.02,0:07:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibundaku itu utusan musim semi!
Dialogue: 0,0:07:37.45,0:07:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren tidak?
Dialogue: 0,0:07:38.77,0:07:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mau kusimpan untuk kenang-kenangan.
Dialogue: 0,0:07:41.97,0:07:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini musim semi pertama\Nbersama Ibunda!
Dialogue: 0,0:07:45.24,0:07:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, kembalikan itu.
Dialogue: 0,0:07:49.12,0:07:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau yang akan kita temui,\Ntidak menyukai anak yang melakukan itu.
Dialogue: 0,0:07:55.83,0:07:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:07:56.79,0:07:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu mohon, Hinagiku.
Dialogue: 0,0:07:59.65,0:08:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu ingin agar beliau menyukaimu.
Dialogue: 0,0:08:05.13,0:08:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:11.35,0:08:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:08:37.03,0:08:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kobai, akhirnya kamu tiba.
Dialogue: 0,0:08:39.69,0:08:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba bilang seperti latihan.
Dialogue: 0,0:08:42.59,0:08:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Yukiyanagi Hinagiku,\Ndatang dari Akebono.
Dialogue: 0,0:08:47.17,0:08:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri dari Yukiyanagi Kobai.
Dialogue: 0,0:08:49.72,0:08:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun ini berusia lima tahun.
Dialogue: 0,0:08:53.43,0:08:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayo Shungetsu.
Dialogue: 0,0:08:55.65,0:08:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisi tubuhmu bagaimana?
Dialogue: 0,0:08:57.18,0:08:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini baik.
Dialogue: 0,0:08:58.64,0:09:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah kalau cuma hari ini.
Dialogue: 0,0:09:00.85,0:09:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kusiapkan tempat\Nuntuk istirahat dengan tenang.
Dialogue: 0,0:09:03.40,0:09:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obatilah dirimu.
Dialogue: 0,0:09:04.71,0:09:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku titipkan Hinagiku padamu.
Dialogue: 0,0:09:07.23,0:09:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:09:08.40,0:09:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalau kamu mendengarkanku\Ndan datang lebih awal,
Dialogue: 0,0:09:11.78,0:09:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini tidak akan terjadi...
Dialogue: 0,0:09:14.12,0:09:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan jahati Ibunda!
Dialogue: 0,0:09:19.79,0:09:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinagiku, tidak apa-apa.
Dialogue: 0,0:09:23.02,0:09:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau ini ayahandamu.
Dialogue: 0,0:09:27.21,0:09:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahandaku?
Dialogue: 0,0:09:30.17,0:09:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:09:32.55,0:09:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:09:34.93,0:09:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan apa-apa.
Dialogue: 0,0:09:38.83,0:09:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau akan melindungimu\Ndi dunia setelah Ibu tiada.
Dialogue: 0,0:09:44.40,0:09:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda mau pergi\Nmewujudkan musim semi lagi?
Dialogue: 0,0:09:48.68,0:09:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sekarang sudah semi?
Dialogue: 0,0:09:50.32,0:09:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, badan Ibu tidak begitu sehat.
Dialogue: 0,0:09:53.20,0:09:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi harus pergi berobat.
Dialogue: 0,0:09:56.01,0:09:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan baik-baik saja tanpa Ibu.
Dialogue: 0,0:09:59.33,0:10:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada bedanya dari selama ini, kan?
Dialogue: 0,0:10:01.83,0:10:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sekarang sudah bersama.
Dialogue: 0,0:10:04.87,0:10:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu ini wanita yang jahat.
Dialogue: 0,0:10:07.34,0:10:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bersamamu,\Nnanti kamu juga ikut diperlakukan jahat.
Dialogue: 0,0:10:10.49,0:10:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bersama,\Nkamu bisa hidup lebih bahagia.
Dialogue: 0,0:10:13.47,0:10:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikatai jahat atau tidak bahagia pun\Nbukan masalah.
Dialogue: 0,0:10:17.72,0:10:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau bersama Ibunda!
Dialogue: 0,0:10:22.55,0:10:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Hinagiku.
Dialogue: 0,0:10:25.04,0:10:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, pasti akan banyak\Nkesedihan yang menanti.
Dialogue: 0,0:10:28.48,0:10:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Ibu mohon bertahanlah.
Dialogue: 0,0:10:32.51,0:10:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahan menunggu saatnya bertarung.
Dialogue: 0,0:10:36.20,0:10:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahan menunggu saatnya bertarung?
Dialogue: 0,0:10:39.57,0:10:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:40.75,0:10:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada masa sulit, tetaplah hidup.
Dialogue: 0,0:10:44.17,0:10:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa lari demi tetap hidup.
Dialogue: 0,0:10:46.36,0:10:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari bukan berarti kalah.
Dialogue: 0,0:10:49.06,0:10:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terpenting harus hidup.
Dialogue: 0,0:10:51.58,0:10:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tunggulah hari saat\Nbisa kembali bertarung.
Dialogue: 0,0:10:54.53,0:10:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan memegang katana di hati.
Dialogue: 0,0:10:57.43,0:11:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kelak, waktu mekar\Nakan kembali tiba.
Dialogue: 0,0:11:01.77,0:11:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau bertarung!
Dialogue: 0,0:11:03.23,0:11:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:04.60,0:11:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada kalanya harus bertarung.
Dialogue: 0,0:11:08.19,0:11:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu ingin melindungimu dari segalanya.
Dialogue: 0,0:11:11.35,0:11:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini adalah hidupmu.
Dialogue: 0,0:11:14.11,0:11:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dirimulah\Nyang bisa menjalaninya, Hinagiku.
Dialogue: 0,0:11:20.24,0:11:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mau waktunya.
Dialogue: 0,0:11:21.51,0:11:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:11:22.58,0:11:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mau!
Dialogue: 0,0:11:24.04,0:11:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda!
Dialogue: 0,0:11:25.46,0:11:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus jadi anak baik, ya!
Dialogue: 0,0:11:27.67,0:11:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda, aku harus jaga rumah lagi?
Dialogue: 0,0:11:31.50,0:11:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus sampai kapan jadi anak baik?
Dialogue: 0,0:11:34.50,0:11:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamanya harus jadi anak baik!
Dialogue: 0,0:11:36.47,0:11:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan jadi anak baik.
Dialogue: 0,0:11:38.14,0:11:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi anak baik!
Dialogue: 0,0:11:39.55,0:11:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa bisa ketemu saat musim panas?
Dialogue: 0,0:11:44.56,0:11:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau musim gugur?
Dialogue: 0,0:11:48.40,0:11:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau, kalau sudah musim dingin,\Napa bisa bertemu Ibunda?
Dialogue: 0,0:11:54.11,0:11:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda...
Dialogue: 0,0:11:55.15,0:11:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh lebih lama lagi!
Dialogue: 0,0:12:02.28,0:12:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo main petak umpet, Hinagiku.
Dialogue: 0,0:12:07.01,0:12:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai Ibunda bilang,\Nkamu tidak boleh mulai mencari.
Dialogue: 0,0:12:11.56,0:12:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelak saat dirimu merasa kantuk luar biasa\Nhingga tak kuat membuka mata.
Dialogue: 0,0:12:17.26,0:12:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda akan bilang, "Sekarang sudah boleh."
Dialogue: 0,0:12:19.97,0:12:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mau!
Dialogue: 0,0:12:21.76,0:12:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda, kumohon jangan tinggalkan aku sendiri!
Dialogue: 0,0:12:27.10,0:12:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi anak baik,\Njadi jangan tinggalkan aku sendiri.
Dialogue: 0,0:12:37.40,0:12:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tinggalkan aku sendiri.
Dialogue: 0,0:12:48.82,0:12:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda...
Dialogue: 0,0:12:53.13,0:12:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda...
Dialogue: 0,0:12:56.71,0:13:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit! Sakit!
Dialogue: 0,0:13:11.15,0:13:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan...
Dialogue: 0,0:13:13.22,0:13:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil namaku...
Dialogue: 0,0:13:17.82,0:13:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut...
Dialogue: 0,0:13:21.95,0:13:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putrinya malah jadi utusan selanjutnya.
Dialogue: 0,0:13:24.83,0:13:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini belum pernah terjadi.
Dialogue: 0,0:13:26.12,0:13:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar sial...\N- Terkutuk...
Dialogue: 0,0:13:27.45,0:13:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semoga bukan pertanda buruk...\N- Siapa sangka jadi begini...
Dialogue: 0,0:13:30.46,0:13:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkutuk.
Dialogue: 0,0:13:40.01,0:13:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini.
Dialogue: 0,0:13:41.63,0:13:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama saja kalau kamu yang membunuhnya.
Dialogue: 0,0:13:46.78,0:13:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu dan anak jadi utusan\Nselama dua generasi.
Dialogue: 0,0:13:49.85,0:13:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau belum pernah terjadi\Ndianggap "kesialan".
Dialogue: 0,0:13:52.02,0:13:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang akan dikatakan\Npara sesepuh desa.
Dialogue: 0,0:13:55.02,0:13:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya yang bisa dibilang tulus berpihak\Nke Nona Hinagiku di Desa Musim Semi
Dialogue: 0,0:13:59.74,0:14:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanyalah Sakura.
Dialogue: 0,0:14:01.45,0:14:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dialah yang terus\Nmendukung Nona Hinagiku.
Dialogue: 0,0:14:07.90,0:14:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama selamanya,\Nselalu di sisinya sepanjang hari.
Dialogue: 0,0:14:11.37,0:14:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira tidak akan terpisah barang sesaat.
Dialogue: 0,0:14:14.79,0:14:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei!
Dialogue: 0,0:14:16.29,0:14:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tahu rahasia wastu di pinggir desa?
Dialogue: 0,0:14:19.21,0:14:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya utusan musim semi yang baru\Nsedang latihan di sana?
Dialogue: 0,0:14:22.38,0:14:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Cermin Pelaju Waktu, kan?
Dialogue: 0,0:14:24.51,0:14:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kalau dilihat\Nbakal menua terus mati itu?
Dialogue: 0,0:14:26.76,0:14:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ular gedenya, kalau masuk ke sana\Nbakal dimakan!
Dialogue: 0,0:14:29.93,0:14:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bohongan.
Dialogue: 0,0:14:31.14,0:14:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kabar angin yang disebar\Nbiar tidak didekati maling.
Dialogue: 0,0:14:34.19,0:14:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, kenapa?
Dialogue: 0,0:14:35.85,0:14:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada buah persik emas di tamannya.
Dialogue: 0,0:14:37.98,0:14:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emas?
Dialogue: 0,0:14:41.36,0:14:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, yang benar?
Dialogue: 0,0:14:43.15,0:14:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kok!
Dialogue: 0,0:14:44.57,0:14:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak meyakinkan.
Dialogue: 0,0:14:45.82,0:14:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku yang bilang!
Dialogue: 0,0:14:47.91,0:14:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?
Dialogue: 0,0:14:48.99,0:14:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh main ke rumahmu, enggak?
Dialogue: 0,0:14:50.54,0:14:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kok!
Dialogue: 0,0:14:51.87,0:14:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo!
Dialogue: 0,0:15:05.51,0:15:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emas...
Dialogue: 0,0:15:12.10,0:15:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buah persik emas,\Nkalau dijual bisa jadi uang tidak, ya?
Dialogue: 0,0:15:43.63,0:15:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata cuma persik biasa.
Dialogue: 0,0:15:46.43,0:15:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persik itu masih keras.
Dialogue: 0,0:15:54.18,0:15:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu siapa?
Dialogue: 0,0:15:58.69,0:16:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku, Sakura.
Dialogue: 0,0:16:02.19,0:16:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:16:05.90,0:16:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:16:11.21,0:16:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku ditinggal ayah dan ibu.
Dialogue: 0,0:16:15.12,0:16:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang tinggal di panti.
Dialogue: 0,0:16:16.83,0:16:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panti?
Dialogue: 0,0:16:18.10,0:16:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat tinggal anak desa\Nyang tidak punya orang tua.
Dialogue: 0,0:16:21.38,0:16:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dibuang.
Dialogue: 0,0:16:23.96,0:16:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disebut mencoreng muka keluarga Himedaka
Dialogue: 0,0:16:26.92,0:16:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau aib bagi desa.
Dialogue: 0,0:16:29.05,0:16:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi teman-teman disuruh orang tuanya\Nagar tidak berteman denganku.
Dialogue: 0,0:16:34.07,0:16:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku selalu sendiri.
Dialogue: 0,0:16:38.37,0:16:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lahir di keluarga yang layak.
Dialogue: 0,0:16:41.94,0:16:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu ke depannya akan bagaimana.
Dialogue: 0,0:16:46.26,0:16:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut.
Dialogue: 0,0:16:52.21,0:16:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga selalu sendiri.
Dialogue: 0,0:16:56.49,0:16:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunda sudah meninggal.
Dialogue: 0,0:16:59.46,0:17:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahanda bilang itu salahku.
Dialogue: 0,0:17:02.58,0:17:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dikutuk karena aku jadi utusan.
Dialogue: 0,0:17:07.89,0:17:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak ingin\Njadi utusan musim semi.
Dialogue: 0,0:17:11.03,0:17:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihannya juga tidak mau.
Dialogue: 0,0:17:12.93,0:17:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin pulang ke rumah, tapi tidak bisa.
Dialogue: 0,0:17:18.77,0:17:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sepi.
Dialogue: 0,0:17:46.75,0:17:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan datang lagi.
Dialogue: 0,0:17:47.96,0:17:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:17:49.34,0:17:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau datang lagi?
Dialogue: 0,0:18:18.87,0:18:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:18:20.04,0:18:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira tidak akan datang lagi!
Dialogue: 0,0:19:08.50,0:19:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi!
Dialogue: 0,0:19:09.46,0:19:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini!
Dialogue: 0,0:19:10.67,0:19:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana masuknya anak aib desa ini?
Dialogue: 0,0:19:13.63,0:19:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:19:15.18,0:19:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan!
Dialogue: 0,0:19:17.01,0:19:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:19:22.18,0:19:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan tempat yang boleh kamu datangi!
Dialogue: 0,0:19:24.68,0:19:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ke sini lagi!
Dialogue: 0,0:19:41.95,0:19:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Himedaka Sakura dipisahkan dariku,\Naku tidak akan menjalankan tugas.
Dialogue: 0,0:19:46.92,0:19:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau menjalani latihan,\Ntidak akan diberi makan, lo!
Dialogue: 0,0:19:49.96,0:19:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak butuh.
Dialogue: 0,0:20:11.94,0:20:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, tolong makan!
Dialogue: 0,0:20:14.28,0:20:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa mati kelaparan!
Dialogue: 0,0:20:16.86,0:20:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan makan sampai\NSakura dibawa ke hadapanku.
Dialogue: 0,0:20:33.42,0:20:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku, sudah kami bawa\NHimedaka Sakura kemari.
Dialogue: 0,0:20:38.22,0:20:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan Sakura masuk ke sini.
Dialogue: 0,0:20:45.52,0:20:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku.
Dialogue: 0,0:20:47.18,0:20:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:20:54.90,0:20:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:20:56.40,0:20:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti lapar, kan?
Dialogue: 0,0:21:03.18,0:21:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka makan diam-diam, kok.
Dialogue: 0,0:21:12.33,0:21:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak Himedaka Sakura dibawa kembali,\Nkekuatan ilahinya meningkat pesat.
Dialogue: 0,0:21:17.26,0:21:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipisah kembali, akan sulit diatasi.
Dialogue: 0,0:21:21.80,0:21:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang utusan melakukan perwujudan\Ndengan hati mereka.
Dialogue: 0,0:21:28.06,0:21:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kedua orang tuanya tidak berguna.
Dialogue: 0,0:21:30.14,0:21:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himedaka adalah keluarga ternama\Nyang telah melahirkan banyak pengawal.
Dialogue: 0,0:21:37.07,0:21:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pengecualian.
Dialogue: 0,0:21:39.90,0:21:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himedaka Sakura akan kutugaskan\Nmenjadi pengawal utusan musim semi.
Dialogue: 0,0:21:44.91,0:21:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinagiku!
Dialogue: 0,0:21:46.87,0:21:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura!
Dialogue: 0,0:21:53.08,0:21:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,\Naku bisa di sisimu sepanjang hari.
Dialogue: 0,0:21:56.84,0:21:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:21:58.20,0:21:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:21:59.21,0:22:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berhenti sekolah, tinggal di sini,
Dialogue: 0,0:22:01.55,0:22:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melindungimu.
Dialogue: 0,0:22:03.84,0:22:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:22:05.35,0:22:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang\Nkita akan terus bersama selamanya.
Dialogue: 0,0:22:12.21,0:22:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu bersama.
Dialogue: 0,0:22:14.15,0:22:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepanjang hari di sisinya.
Dialogue: 0,0:22:16.06,0:22:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira tidak akan terpisah sepatah waktu pun.
Dialogue: 0,0:22:19.42,0:22:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira begitu.
