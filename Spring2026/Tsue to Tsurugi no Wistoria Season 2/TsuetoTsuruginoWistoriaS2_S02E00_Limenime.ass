Dialogue: 0,0:01:17.18,0:01:17.63,tanda,,0000,0000,0000,,WILL SERFORT
Dialogue: 0,0:02:15.95,0:02:19.45,tanda,,0000,0000,0000,,ELFARIA ALBIS SERFORT
Dialogue: 0,0:02:40.22,0:02:43.61,tanda,,0000,0000,0000,,"MAGIA VANDER"
Dialogue: 0,0:03:32.65,0:03:32.93,tanda,,0000,0000,0000,,WORKNER NORGRAM
Dialogue: 0,0:06:01.34,0:06:06.76,tanda,,0000,0000,0000,,"EDWARD SERFENCE"
Dialogue: 0,0:08:39.79,0:08:42.30,tanda,,0000,0000,0000,,"COLETTE LOIRE"
Dialogue: 0,0:08:54.46,0:08:56.77,tanda,,0000,0000,0000,,"ROSTY NOWMAN"
Dialogue: 0,0:09:27.56,0:09:28.80,tanda,,0000,0000,0000,,FESTIVAL SIHIR AGUNG
Dialogue: 0,0:09:51.36,0:09:52.49,tanda,,0000,0000,0000,,SION ULSTER
Dialogue: 0,0:10:34.02,0:10:37.38,tanda,,0000,0000,0000,,"JULIUS REINBERG"
Dialogue: 0,0:13:26.00,0:13:26.79,tanda,,0000,0000,0000,,PRAKSIS AKBAR
Dialogue: 0,0:16:31.58,0:16:34.47,tanda,,0000,0000,0000,,"ANCAMAN LEBIH BESAR"
Dialogue: 0,0:21:43.10,0:21:43.45,tanda,,0000,0000,0000,,CUPLIKAN PERDANA ADEGAN UTAMA\NDI MUSIM KEDUA!
Dialogue: 0,0:00:05.43,0:00:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah dunia di mana\Nsihir menentukan segalanya.
Dialogue: 0,0:00:11.08,0:00:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini, ada satu-satunya pemuda\Nyang bertarung menggunakan pedang.
Dialogue: 0,0:00:17.86,0:00:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak bisa menggunakan sihir\Ndan kerap dipanggil "anak gagal,"
Dialogue: 0,0:00:22.32,0:00:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tetap melangkah maju.
Dialogue: 0,0:00:25.50,0:00:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lihat kembali\Njejak perjuangan Will.
Dialogue: 0,0:00:31.12,0:00:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, pada paruh kedua
Dialogue: 0,0:00:33.51,0:00:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami akan menampilkan cuplikan perdana\Nadegan utama di musim kedua!
Dialogue: 0,0:00:40.10,0:00:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perayaan Penayangan Musim Kedua:
Dialogue: 0,0:00:42.02,0:00:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompilasi spesial animasi\NTongkat Sihir dan Pedang Wistoria!
Dialogue: 0,0:00:45.92,0:00:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pedangnya bisa mengubah dunia?
Dialogue: 0,0:00:53.04,0:00:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah Akademi Sihir\Nyang dipenuhi penyihir muda.
Dialogue: 0,0:00:57.18,0:01:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara mereka, ada seorang siswa\Nyang tidak bisa menggunakan sihir.
Dialogue: 0,0:01:03.18,0:01:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh api!
Dialogue: 0,0:01:05.72,0:01:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncullah!
Dialogue: 0,0:01:17.64,0:01:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya adalah Will Serfort.
Dialogue: 0,0:01:23.12,0:01:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir adalah segalanya di dunia ini!
Dialogue: 0,0:01:26.54,0:01:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir adalah otoritas!
Dialogue: 0,0:01:28.44,0:01:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi sihir adalah kekuatan!
Dialogue: 0,0:01:30.57,0:01:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir adalah pahlawan!
Dialogue: 0,0:01:33.24,0:01:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Talenta sihir sangat dihargai\Ndi Akademi Sihir.
Dialogue: 0,0:01:38.16,0:01:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa nol besar tanpa talenta sihir\Nyang hanya bermodal pengetahuan
Dialogue: 0,0:01:41.88,0:01:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak layak mengenyam pendidikan\Ndi tempat mahardika ini.
Dialogue: 0,0:01:46.00,0:01:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski selalu diejek\Ndan dipanggil "anak gagal,"
Dialogue: 0,0:01:49.09,0:01:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will punya satu alasan\Nuntuk bertahan di akademi ini.
Dialogue: 0,0:01:54.70,0:01:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:01:55.84,0:02:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada "bulan" dan "matahari"\Nyang mengambang di langit asli!
Dialogue: 0,0:02:00.06,0:02:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa sih, Elfaria?
Dialogue: 0,0:02:03.00,0:02:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita pergi ke puncak menara\Nyang paling dekat dengan langit...
Dialogue: 0,0:02:06.94,0:02:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita jadi Magia Vander,
Dialogue: 0,0:02:08.90,0:02:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin kita bisa melihat\Nmatahari terbenam.
Dialogue: 0,0:02:13.20,0:02:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kita lihat bersama!
Dialogue: 0,0:02:19.90,0:02:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Itu adalah janji kita!
Dialogue: 0,0:02:24.20,0:02:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanyalah janji semasa kecil.
Dialogue: 0,0:02:29.16,0:02:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dia adalah genius sejati.
Dialogue: 0,0:02:33.20,0:02:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jadi Magia Vander termuda\Nberkat talentanya yang luar biasa,
Dialogue: 0,0:02:37.39,0:02:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia pergi ke puncak menara.
Dialogue: 0,0:02:40.22,0:02:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi memenuhi janji kepada teman masa kecilnya
Dialogue: 0,0:02:43.62,0:02:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sudah jadi Magia Vander,
Dialogue: 0,0:02:46.46,0:02:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will bertekad memanjat menara\Nsetelah lulus dari akademi.
Dialogue: 0,0:02:51.78,0:02:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak bisa menggunakan sihir,\Nia masih berjuang dengan cara lain.
Dialogue: 0,0:03:00.48,0:03:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada jeritan orang?
Dialogue: 0,0:03:02.82,0:03:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada seseorang\Nyang diserang di strata ini?
Dialogue: 0,0:03:14.68,0:03:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Evil Sentinel?!
Dialogue: 0,0:03:17.26,0:03:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kreditnya sepuluh!
Dialogue: 0,0:03:18.80,0:03:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh dengan kredit di atas lima?!
Dialogue: 0,0:03:22.72,0:03:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan ke sini! Menjauhlah!
Dialogue: 0,0:03:30.76,0:03:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Workner!
Dialogue: 0,0:03:32.94,0:03:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Edward?
Dialogue: 0,0:03:34.76,0:03:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa malam-mala—
Dialogue: 0,0:03:36.13,0:03:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion masuk dungeon tanpa izin!
Dialogue: 0,0:03:38.74,0:03:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:03:40.28,0:03:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra bangsawan memang menyusahkan!
Dialogue: 0,0:03:42.25,0:03:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dungeon itu luas!\NSuruh piaraanmu untuk mencarinya!
Dialogue: 0,0:03:46.76,0:03:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda tahu strata yang dituju?
Dialogue: 0,0:03:48.56,0:03:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strata enam.
Dialogue: 0,0:03:54.60,0:03:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tidak usah khawatir.
Dialogue: 0,0:03:57.82,0:03:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:01.04,0:04:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will ada di sana.
Dialogue: 0,0:04:19.12,0:04:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?
Dialogue: 0,0:04:22.34,0:04:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia benar-benar Will si gagal?
Dialogue: 0,0:04:25.66,0:04:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Mustahil!
Dialogue: 0,0:04:28.44,0:04:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will memang sepeti kerikil\Nyang salah tempat.
Dialogue: 0,0:04:30.92,0:04:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia punya kekuatan super penyihir.
Dialogue: 0,0:04:35.52,0:04:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketangguhan dwarf.
Dialogue: 0,0:04:42.52,0:04:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kemampuan observasi super\Nyang bisa mengingat pola gerak lawan
Dialogue: 0,0:04:45.50,0:04:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekali lihat.
Dialogue: 0,0:04:51.06,0:04:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pola itu...
Dialogue: 0,0:04:54.07,0:04:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...sudah kulihat!
Dialogue: 0,0:05:02.06,0:05:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will memang tak bisa menggunakan sihir.
Dialogue: 0,0:05:09.42,0:05:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, di dunia penyihir ini,
Dialogue: 0,0:05:13.40,0:05:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia adalah satu-satunya pendekar!
Dialogue: 0,0:05:32.28,0:05:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebasan pedangnya
Dialogue: 0,0:05:35.98,0:05:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa menandingi kilat!
Dialogue: 0,0:05:43.48,0:05:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:05:45.12,0:05:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak mungkin terjadi!
Dialogue: 0,0:05:47.66,0:05:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seharusnya tidak ada yang bisa\N- Apa kamu terluka?
Dialogue: 0,0:05:49.64,0:05:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menandingi penyihir tanpa sihir!
Dialogue: 0,0:05:54.20,0:05:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu mengetahui kekuatan Will,
Dialogue: 0,0:05:57.08,0:05:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Edward pun menyiapkan\Nujian berat untuk Will.
Dialogue: 0,0:06:01.34,0:06:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menguji kapasitasmu secara sepihak.
Dialogue: 0,0:06:12.02,0:06:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasmu adalah mendaratkan\Nsatu serangan saat melawanku.
Dialogue: 0,0:06:16.48,0:06:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak boleh menolak.
Dialogue: 0,0:06:18.66,0:06:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau berhasil, aku akan\Nmemberimu lima kredit realisasi sihir.
Dialogue: 0,0:06:22.66,0:06:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika kau sampai gagal,\Nkau akan dikeluarkan dari akademi.
Dialogue: 0,0:06:27.64,0:06:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dikeluarkan?!
Dialogue: 0,0:06:42.60,0:06:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will tumbang saat menghadapi sihir Edward.
Dialogue: 0,0:06:47.22,0:06:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sangat jelas.
Dialogue: 0,0:06:49.00,0:06:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Magia Vander adalah puncaknya\Nsegala macam penyihir.
Dialogue: 0,0:06:53.94,0:06:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang takkan bisa\Nmenandingi tongkat sihir!
Dialogue: 0,0:06:56.27,0:06:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mutlak!
Dialogue: 0,0:06:58.88,0:07:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buanglah ambisi tolol itu!
Dialogue: 0,0:07:02.34,0:07:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja!
Dialogue: 0,0:07:04.56,0:07:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja!
Dialogue: 0,0:07:07.50,0:07:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ingin mencapai posisi Magia Vander!
Dialogue: 0,0:07:11.34,0:07:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal apa yang mendasari tekadmu?
Dialogue: 0,0:07:14.66,0:07:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan mulia seperti apa
Dialogue: 0,0:07:16.80,0:07:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menjadi sumber semangat juangmu?!
Dialogue: 0,0:07:25.26,0:07:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ingin bersama orang yang saya cintai!
Dialogue: 0,0:07:31.14,0:07:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:07:32.56,0:07:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ingin menepati janji pada Elfie!
Dialogue: 0,0:07:37.80,0:07:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tekad kuat itu,\NWill berani menghadapi Edward
Dialogue: 0,0:07:41.72,0:07:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dan dunia yang mengagungkan sihir ini.\N- Habislah kau!
Dialogue: 0,0:07:47.26,0:07:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:08:13.14,0:08:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort berhak mendapat lima kredit.
Dialogue: 0,0:08:17.44,0:08:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:08:21.54,0:08:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Akademi Sihir,
Dialogue: 0,0:08:23.12,0:08:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will punya teman-teman\Nyang selalu mendukungnya.
Dialogue: 0,0:08:28.28,0:08:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan itu!
Dialogue: 0,0:08:30.60,0:08:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will lebih baik darimu\Ndan lebih giat dari semua orang!
Dialogue: 0,0:08:33.62,0:08:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan hina sahabatku!
Dialogue: 0,0:08:36.72,0:08:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswi berprestasi\Nyang ahli menggunakan sihir tanah
Dialogue: 0,0:08:39.79,0:08:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sahabat baik Will, Colette Loire.
Dialogue: 0,0:08:42.32,0:08:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stia Viola!
Dialogue: 0,0:08:43.50,0:08:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pergi ke strata empat,\Njadi, aku butuh peranti magismu!
Dialogue: 0,0:08:50.44,0:08:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak pernah basa-basi, ya.
Dialogue: 0,0:08:54.46,0:08:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakar peranti magis
Dialogue: 0,0:08:56.77,0:08:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan teman sekamar Will, Rosty Nowman.\N- Selamat jalan!
Dialogue: 0,0:08:59.86,0:09:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia membantu Will mendapat kredit\Nsecara bertahap.
Dialogue: 0,0:09:07.92,0:09:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menjunjung kata-kata\Nleluhur agung kita, Mercedes,
Dialogue: 0,0:09:14.18,0:09:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku meresmikan\Npembukaan Festival Sihir Agung.
Dialogue: 0,0:09:21.64,0:09:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival Sihir Agung adalah acara besar
Dialogue: 0,0:09:23.68,0:09:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diikuti para siswa\Nuntuk beradu kemampuan.
Dialogue: 0,0:09:28.96,0:09:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di panggung ini, Will pun berbentrokan\Ndengan beberapa siswa hebat di akademi.
Dialogue: 0,0:09:35.10,0:09:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lawan aku, Anak Gagal!
Dialogue: 0,0:09:38.31,0:09:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin melawanku?\NSekarang?!
Dialogue: 0,0:09:41.27,0:09:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:09:45.42,0:09:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu siswa hebat\Nyang menguasai sihir api,
Dialogue: 0,0:09:49.49,0:09:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion Ulster.
Dialogue: 0,0:09:52.86,0:09:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah diselamatkan oleh Will\Nyang selalu ia anggap anak gagal,
Dialogue: 0,0:09:56.64,0:10:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ia pun mulai memperhitungkan Will.
Dialogue: 0,0:10:01.04,0:10:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbanglah, Halcon!
Dialogue: 0,0:10:02.67,0:10:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dragos Nowl!
Dialogue: 0,0:10:08.84,0:10:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel dengan Sion berakhir seri\Nkarena campur tangan Colette.
Dialogue: 0,0:10:13.66,0:10:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, masih ada penyihir lain\Nyang menghadang Will.
Dialogue: 0,0:10:20.18,0:10:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggumu, Anak Gagal.
Dialogue: 0,0:10:23.56,0:10:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku menang\Ntanpa membuatmu malu,
Dialogue: 0,0:10:28.08,0:10:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemenanganku akan terasa hambar.
Dialogue: 0,0:10:32.30,0:10:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa pengguna sihir es
Dialogue: 0,0:10:34.02,0:10:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang termasuk tiga besar dalam hal kemampuan,
Dialogue: 0,0:10:37.38,0:10:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius Reinberg.
Dialogue: 0,0:10:39.88,0:10:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi memamerkan kebolehan\Ndi Festival Sihir Agung,
Dialogue: 0,0:10:43.42,0:10:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ia menjalankan sebuah strategi rahasia.
Dialogue: 0,0:10:47.34,0:10:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, sihir itu...
Dialogue: 0,0:10:49.80,0:10:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir rahasia Elfaria si cemerlang!
Dialogue: 0,0:10:54.38,0:10:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Glace Frosse!
Dialogue: 0,0:10:57.06,0:11:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menggunakan salah satu\Ndari kedua belas sihir orisinal itu.
Dialogue: 0,0:11:01.46,0:11:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El One: Ars Weiss.
Dialogue: 0,0:11:04.38,0:11:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir klona tubuh yang dibuat dari es.
Dialogue: 0,0:11:09.20,0:11:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia menyerang Will dengan sihir\Nyang diciptakan Elfaria si cemerlang.
Dialogue: 0,0:11:30.84,0:11:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia bisa selamat?
Dialogue: 0,0:11:34.58,0:11:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, Ars Weiss-mu tidak sempurna.
Dialogue: 0,0:11:46.18,0:11:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengendalikan klonamu\Ndengan bantuan teman-temanmu
Dialogue: 0,0:11:50.00,0:11:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar bisa menggunakan sihir Elfie\Nsementara waktu.
Dialogue: 0,0:11:54.46,0:11:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih belum mencapai level Elfie!
Dialogue: 0,0:11:57.84,0:12:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will memahami trik di balik sihir itu.
Dialogue: 0,0:12:01.88,0:12:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sihir itu adalah sihir khusus\Nyang dipenuhi kenangan bersama Elfie,
Dialogue: 0,0:12:06.06,0:12:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang merupakan teman masa kecilnya.
Dialogue: 0,0:12:09.98,0:12:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hentikan dia!
Dialogue: 0,0:12:15.63,0:12:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius Reinberg.
Dialogue: 0,0:12:18.36,0:12:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:12:19.58,0:12:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kemampuannya sesuai info\Nyang tertulis di dokumen ini,
Dialogue: 0,0:12:22.58,0:12:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin dia punya peluang.
Dialogue: 0,0:12:25.26,0:12:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk jadi penerusku.
Dialogue: 0,0:12:29.16,0:12:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Sarissa.
Dialogue: 0,0:12:31.40,0:12:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menginginkan penerus.
Dialogue: 0,0:12:36.94,0:12:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginginkan pedang\Nyang bisa menemaniku.
Dialogue: 0,0:12:43.72,0:12:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah melihat aksimu di turnamen!
Dialogue: 0,0:12:46.21,0:12:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mau bergabung\Ndengan tim kami?
Dialogue: 0,0:12:48.28,0:12:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu!\NJangan cepat-cepat!
Dialogue: 0,0:12:51.60,0:12:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selepas pertarungan melawan Julius,
Dialogue: 0,0:12:53.94,0:12:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua orang di akademi\Nmengetahui kekuatan Will.
Dialogue: 0,0:12:58.66,0:13:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kemampuannya\Nmulai diperhitungkan,
Dialogue: 0,0:13:00.76,0:13:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada seseorang\Nyang menghampiri Will.
Dialogue: 0,0:13:04.16,0:13:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu Lihanna?
Dialogue: 0,0:13:08.52,0:13:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will menerima sebuah tawaran\Ndi tempat yang mereka tuju.
Dialogue: 0,0:13:19.98,0:13:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membentuk tim\Nberanggotakan kita berlima.
Dialogue: 0,0:13:23.86,0:13:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim penyerbuan dungeon.
Dialogue: 0,0:13:26.80,0:13:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah Praksis Akbar\Ndi tahun terakhir masa studi.
Dialogue: 0,0:13:29.68,0:13:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelompok Will membentuk tim\Ndan masuk ke dalam dungeon.
Dialogue: 0,0:13:38.56,0:13:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus meraih hasil memuaskan\Ndan menyusul Elfie!
Dialogue: 0,0:13:42.44,0:13:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wignall, tolong bantu.
Dialogue: 0,0:13:46.12,0:13:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mellvent.
Dialogue: 0,0:14:00.36,0:14:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita pergi.
Dialogue: 0,0:14:02.02,0:14:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu baik-baik saja?
Dialogue: 0,0:14:07.98,0:14:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu Crimson Ant?
Dialogue: 0,0:14:11.96,0:14:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali!\NIni terlalu mendadak!
Dialogue: 0,0:14:14.66,0:14:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir selalu dirugikan\Ndalam pertarungan jarak dekat!
Dialogue: 0,0:14:17.58,0:14:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus melindungi mereka di depan!
Dialogue: 0,0:14:19.40,0:14:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah!
Dialogue: 0,0:14:21.92,0:14:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihanna Owenzaus.
Dialogue: 0,0:14:24.30,0:14:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tahu sebutan\Nyang melekat pada keluarganya?
Dialogue: 0,0:14:32.70,0:14:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergemuruh, Roh Petir!\NSeraya misi yang kupikul!
Dialogue: 0,0:14:37.56,0:14:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Owen Sique:
Dialogue: 0,0:14:40.28,0:14:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lisolde Dua!
Dialogue: 0,0:14:43.12,0:14:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penguatan?
Dialogue: 0,0:14:45.06,0:14:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Owenzaus adalah keluarga kesatria.
Dialogue: 0,0:14:48.22,0:14:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihanna adalah spesialis\Nsihir pertarungan jarak dekat
Dialogue: 0,0:14:51.04,0:14:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terbilang jarang di antara penyihir.
Dialogue: 0,0:14:56.06,0:14:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswi peringkat teratas\Nyang berselimut sihir petir,
Dialogue: 0,0:14:59.80,0:15:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihanna Owenzaus.
Dialogue: 0,0:15:02.30,0:15:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan elf yang mahir\Nmenggunakan sihir fantasi,
Dialogue: 0,0:15:05.56,0:15:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wignall Lindor.
Dialogue: 0,0:15:08.48,0:15:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama para siswa elite itu,\NWill pergi menyusuri dungeon.
Dialogue: 0,0:15:13.48,0:15:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, terjadi hal tak terduga\Ndalam Praksis Akbar tersebut.
Dialogue: 0,0:15:22.32,0:15:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuhan Penjaga Strata?
Dialogue: 0,0:15:24.56,0:15:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang melakukan ini?!
Dialogue: 0,0:15:33.66,0:15:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, di atas!
Dialogue: 0,0:15:39.08,0:15:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:15:43.70,0:15:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?!
Dialogue: 0,0:15:48.38,0:15:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wignall!
Dialogue: 0,0:16:01.72,0:16:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah diserang monster misterius,
Dialogue: 0,0:16:04.94,0:16:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will dan teman-temannya\Nterjatuh ke strata dalam.
Dialogue: 0,0:16:10.90,0:16:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berada di bawah strata 10.
Dialogue: 0,0:16:13.82,0:16:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zona di luar wilayah akademi.
Dialogue: 0,0:16:16.96,0:16:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tim kita tak segera berkumpul,\Nkita bisa terbunuh di dalam dungeon.
Dialogue: 0,0:16:22.00,0:16:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dungeon yang dipenuhi monster kuat,
Dialogue: 0,0:16:25.00,0:16:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will dan teman-temannya\Nbergegas berkumpul kembali.
Dialogue: 0,0:16:29.96,0:16:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ada ancaman lebih besar
Dialogue: 0,0:16:31.58,0:16:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menanti mereka.
Dialogue: 0,0:16:34.47,0:16:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kalian sebenarnya?!
Dialogue: 0,0:16:39.46,0:16:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya penjahat biasa.
Dialogue: 0,0:16:42.20,0:16:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin menghancurkan langit palsu.
Dialogue: 0,0:16:45.86,0:16:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langit palsu?
Dialogue: 0,0:16:47.52,0:16:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia membicarakan\Npenghalang buatan Magia Vander?
Dialogue: 0,0:16:50.37,0:16:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:16:51.62,0:16:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut cerita, malapetaka akan\Nterjadi jika penghalangnya hilang.
Dialogue: 0,0:16:55.50,0:16:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya habis.\NOrang-orang merepotkan sedang ke sini.
Dialogue: 0,0:17:00.20,0:17:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Enggak seru!\NKalau begitu, bunuh saja mereka.
Dialogue: 0,0:17:06.02,0:17:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duke.
Dialogue: 0,0:17:09.22,0:17:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir jahat itu meninggalkan\Nkeputusasaan luar biasa.
Dialogue: 0,0:17:14.85,0:17:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memanggil monster\Nyang muncul di strata 10?!
Dialogue: 0,0:17:25.78,0:17:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster senilai 270 kredit!
Dialogue: 0,0:17:28.60,0:17:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Evil Grand Duke!
Dialogue: 0,0:17:43.66,0:17:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah taman indah di dataran beku!
Dialogue: 0,0:17:45.80,0:17:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Armenta Auliscas!
Dialogue: 0,0:17:52.32,0:17:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir andalan Julius—
Dialogue: 0,0:17:54.00,0:17:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa ditahan?!
Dialogue: 0,0:17:56.84,0:17:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dihadang Evil Grand Duke\Nyang memiliki kekuatan absolut
Dialogue: 0,0:17:59.48,0:18:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bahkan bisa mematahkan\Nserangan dengan tekad siap mati.
Dialogue: 0,0:18:05.32,0:18:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette!
Dialogue: 0,0:18:08.60,0:18:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, Will tetap tidak menyerah.
Dialogue: 0,0:18:14.44,0:18:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggelegar, Tebing Baja!
Dialogue: 0,0:18:17.00,0:18:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuhlah, Taring Jurang Batu!
Dialogue: 0,0:18:23.83,0:18:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Loire Sique:
Dialogue: 0,0:18:25.86,0:18:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Golterre!
Dialogue: 0,0:18:41.72,0:18:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh Bara Api, sisa-sisa kota mati!
Dialogue: 0,0:18:45.31,0:18:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion?!
Dialogue: 0,0:18:46.58,0:18:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyalalah!
Dialogue: 0,0:18:47.92,0:18:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jejak-jejak kobaran api\Nyang menghanguskanmu!
Dialogue: 0,0:18:50.82,0:18:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah!
Dialogue: 0,0:18:52.22,0:18:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyala api kehancuran\Nyang menari di atas daratan legam!
Dialogue: 0,0:18:55.22,0:18:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tombak api ibu pertiwi\Nyang telah lama sirna,
Dialogue: 0,0:18:58.06,0:19:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakar habis semua musuh di hadapanku!
Dialogue: 0,0:19:01.78,0:19:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion!
Dialogue: 0,0:19:04.92,0:19:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau bisa,
Dialogue: 0,0:19:06.50,0:19:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pun pasti juga bisa!
Dialogue: 0,0:19:10.58,0:19:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iflamme Burdelyon!
Dialogue: 0,0:19:26.52,0:19:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat sihir saja tidak cukup!
Dialogue: 0,0:19:29.64,0:19:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang saja masih kurang!
Dialogue: 0,0:19:35.36,0:19:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:19:43.02,0:19:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah baik-baik, Will.
Dialogue: 0,0:19:45.92,0:19:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat sihir dan pedang.
Dialogue: 0,0:19:50.44,0:19:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat sihir dan pedang?
Dialogue: 0,0:19:57.34,0:19:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion!
Dialogue: 0,0:19:59.14,0:20:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakkan sihirmu!
Dialogue: 0,0:20:00.10,0:20:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satukan tongkat sihir dan pedang!
Dialogue: 0,0:20:06.72,0:20:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ignis Rooks!
Dialogue: 0,0:20:16.53,0:20:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wis!
Dialogue: 0,0:20:18.28,0:20:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:20:20.62,0:20:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangnya berselimut api?
Dialogue: 0,0:20:22.94,0:20:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penguatan elemen?\NTidak, sepertinya bukan!
Dialogue: 0,0:20:26.04,0:20:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirnya dilahap?
Dialogue: 0,0:20:29.38,0:20:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak Gagal, kau...
Dialogue: 0,0:20:35.66,0:20:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah pedangnya\Ndiselimuti sihir temannya,
Dialogue: 0,0:20:38.62,0:20:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will berhasil membuka kekuatan misterius.
Dialogue: 0,0:20:43.14,0:20:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengisian selesai!
Dialogue: 0,0:21:02.68,0:21:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ignis Wis!
Dialogue: 0,0:21:15.25,0:21:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ujung pertarungan sengit itu,\NEvil Grand Duke berhasil dikalahkan
Dialogue: 0,0:21:20.22,0:21:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kelompok Will pun keluar dari\Ndungeon dalam keadaan selamat.
Dialogue: 0,0:21:25.38,0:21:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, identitas penyihir misterius itu
Dialogue: 0,0:21:28.50,0:21:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih belum diketahui.
Dialogue: 0,0:21:32.92,0:21:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melewati\Nberbagai macam cobaan,
Dialogue: 0,0:21:34.77,0:21:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will kembali ke akademi.
Dialogue: 0,0:21:38.14,0:21:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan sekarang, ia menghadapi\Nujian terakhir.
Dialogue: 0,0:21:43.46,0:21:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ini, cuplikan perdana\Ndari musim kedua
Dialogue: 0,0:21:46.62,0:21:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menunjukkan kisah baru Will\Nakan ditayangkan!
Dialogue: 0,0:21:56.56,0:21:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal apa yang paling dihargai
Dialogue: 0,0:21:58.36,0:22:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di menara yang agung?
Dialogue: 0,0:22:21.97,0:22:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja talenta sihir.
Dialogue: 0,0:22:36.58,0:22:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk orang-orang tak bertalenta,
Dialogue: 0,0:22:40.13,0:22:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa mereka memiliki cara\Nuntuk mencapai puncak menara?
Dialogue: 0,0:22:56.72,0:22:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabannya...
Dialogue: 0,0:23:04.40,0:23:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melangkah\Nbersama teman-temanku!
Dialogue: 0,0:23:21.52,0:23:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie.
Dialogue: 0,0:23:23.18,0:23:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menyusulmu.
