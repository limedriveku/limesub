Dialogue: 0,0:02:29.02,0:02:33.70,tanda,,0000,0000,0000,,EPISODE 16: DAN KISAH PUN DIMULAI
Dialogue: 0,0:03:37.98,0:03:42.56,tanda,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:05:33.60,0:05:36.20,tanda,,0000,0000,0000,,"PEDANG SIHIR"
Dialogue: 0,0:12:13.35,0:12:14.58,tanda,,0000,0000,0000,,PEDANG PERAK MORIA
Dialogue: 0,0:12:14.98,0:12:18.05,tanda,,0000,0000,0000,,PEDANG PERAK MORIA
Dialogue: 0,0:12:19.88,0:12:22.99,tanda,,0000,0000,0000,,MULTOS
Dialogue: 0,0:17:09.40,0:17:09.58,tanda,,0000,0000,0000,,ISTANA DEWA BEKU,\NNEGERI SEPULUH RIBU ES DAN SERIBU BIRU
Dialogue: 0,0:19:25.73,0:19:35.53,tanda,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:28.95,0:23:31.06,tanda,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:42.08,0:23:48.30,tanda,,0000,0000,0000,,EPISODE 17: HARI KEBERANGKATAN
Dialogue: 0,0:00:09.50,0:00:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya menara itu sudah selesai.
Dialogue: 0,0:00:15.43,0:00:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harapan dunia ini.
Dialogue: 0,0:00:20.10,0:00:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin maksudmu jam menuju akhir zaman.
Dialogue: 0,0:00:24.28,0:00:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlihat seperti tangkai rapuh\Nyang bisa patah kapan saja.
Dialogue: 0,0:00:30.19,0:00:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangga langit sudah disegel.
Dialogue: 0,0:00:32.70,0:00:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita dapat sedikit waktu.
Dialogue: 0,0:00:35.52,0:00:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit waktu sebelum Penjajah Langit
Dialogue: 0,0:00:39.55,0:00:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghancurkan dunia ini.
Dialogue: 0,0:00:41.85,0:00:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara itu, aku akan\Nmengumpulkan tongkat sihir.
Dialogue: 0,0:00:46.10,0:00:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan tugasmu adalah menempa sebilah pedang.
Dialogue: 0,0:00:52.73,0:00:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu yakin dengan ini, Mercedes?
Dialogue: 0,0:00:55.03,0:00:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup!\NSampai kapan kamu menanyakan itu?
Dialogue: 0,0:01:01.58,0:01:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah semua ini kesepakatan\Nyang kamu tawarkan?
Dialogue: 0,0:01:12.28,0:01:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah kontrak kita, Finn.
Dialogue: 0,0:01:14.33,0:01:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus melahirkan\Npengguna elemen kelima.
Dialogue: 0,0:01:19.95,0:01:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini,
Dialogue: 0,0:01:20.95,0:01:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus mendapatkan kunci\Nuntuk menyelaraskan dunia.
Dialogue: 0,0:01:24.00,0:01:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini adalah "geas".\NAku bersumpah padamu.
Dialogue: 0,0:01:33.83,0:01:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi melindungi dunia ini,
Dialogue: 0,0:01:36.50,0:01:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus mencapai\Njalan tongkat sihir dan pedang.
Dialogue: 0,0:01:49.73,0:01:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:01:51.70,0:01:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada banyak lika-liku,\Nkita sudah sampai sejauh ini.
Dialogue: 0,0:01:55.80,0:01:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini akan menjadi rapsodi\Nyang kami harapkan?
Dialogue: 0,0:02:00.18,0:02:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau tragedi yang kejam?
Dialogue: 0,0:02:03.58,0:02:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau komedi yang spektakuler?
Dialogue: 0,0:02:06.90,0:02:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan padaku.
Dialogue: 0,0:02:08.40,0:02:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arah dari kontrak yang kubuat\Ndengan wanita sihir nan agung.
Dialogue: 0,0:03:47.37,0:03:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:03:48.12,0:03:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:03:53.46,0:03:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:04:01.21,0:04:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:04:02.39,0:04:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya itu menyingkirkan\Npara monster satu per satu.
Dialogue: 0,0:04:13.50,0:04:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halcon!
Dialogue: 0,0:04:23.78,0:04:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion!
Dialogue: 0,0:04:37.44,0:04:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari, Sion!
Dialogue: 0,0:04:39.81,0:04:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak... akan!
Dialogue: 0,0:04:42.43,0:04:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan!
Dialogue: 0,0:04:44.06,0:04:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga tidak mungkin lari!
Dialogue: 0,0:04:47.80,0:04:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah si pengecut\Nyang lebih berani dari siapa pun!
Dialogue: 0,0:04:52.00,0:04:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau kalah darinya!
Dialogue: 0,0:04:57.96,0:04:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah, Sion.
Dialogue: 0,0:05:00.70,0:05:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya iri pada kalian,\Ningin jadi kalian, mengagumi kalian,
Dialogue: 0,0:05:06.55,0:05:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengejar sosok kalian.
Dialogue: 0,0:05:09.22,0:05:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya orang menyedihkan.
Dialogue: 0,0:05:12.73,0:05:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, sekarang...
Dialogue: 0,0:05:33.60,0:05:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan jadi pedang kalian!
Dialogue: 0,0:05:48.68,0:05:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu kamu, Will?
Dialogue: 0,0:05:51.41,0:05:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak Gagal? Kau...
Dialogue: 0,0:06:08.46,0:06:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Devander telah mencapai Central Flos!
Dialogue: 0,0:06:11.11,0:06:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Akademi, kita harus pergi!
Dialogue: 0,0:06:12.91,0:06:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendidih dan bergejolak!
Dialogue: 0,0:06:14.32,0:06:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keridos Aquulum!
Dialogue: 0,0:06:25.03,0:06:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berhasil mencegahnya masuk akademi.
Dialogue: 0,0:06:27.78,0:06:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, apa yang terjadi?
Dialogue: 0,0:06:30.14,0:06:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Akademi, kita harus segera—
Dialogue: 0,0:06:31.98,0:06:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:06:39.13,0:06:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:06:53.48,0:06:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan aku!
Dialogue: 0,0:07:03.42,0:07:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa ini?
Dialogue: 0,0:07:05.93,0:07:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari pusat kota?
Dialogue: 0,0:07:08.20,0:07:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia sedang bertarung?
Dialogue: 0,0:07:11.33,0:07:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will...
Dialogue: 0,0:07:12.75,0:07:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di depan sana...
Dialogue: 0,0:07:15.38,0:07:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Wignall!
Dialogue: 0,0:07:17.28,0:07:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga, Lihanna?
Dialogue: 0,0:07:19.50,0:07:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sialan!
Dialogue: 0,0:07:21.27,0:07:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup!\NEnergi sihirku sudah habis!
Dialogue: 0,0:07:27.82,0:07:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama, cepatlah!
Dialogue: 0,0:07:29.98,0:07:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini...
Dialogue: 0,0:07:31.75,0:07:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu kau, Serfort?
Dialogue: 0,0:07:35.58,0:07:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia bertarung?
Dialogue: 0,0:07:38.75,0:07:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melawan monster itu?
Dialogue: 0,0:07:44.88,0:07:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:07:47.03,0:07:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:07:53.15,0:07:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:07:59.45,0:08:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:08:03.70,0:08:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu...
Dialogue: 0,0:08:07.33,0:08:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa mengimbanginya?
Dialogue: 0,0:08:09.10,0:08:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melawan monster yang pernah mengalahkannya?
Dialogue: 0,0:08:13.08,0:08:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed!
Dialogue: 0,0:08:14.20,0:08:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serah, ternyata kau—
Dialogue: 0,0:08:16.55,0:08:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, sakit!
Dialogue: 0,0:08:18.70,0:08:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih hidup, ya?
Dialogue: 0,0:08:20.83,0:08:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, kau selalu menang beruntung.
Dialogue: 0,0:08:23.23,0:08:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:08:26.55,0:08:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan itu!
Dialogue: 0,0:08:27.63,0:08:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:08:28.97,0:08:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa anak itu, Ed?!
Dialogue: 0,0:08:37.15,0:08:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renaisse, Jorua!\NApa yang terjadi?
Dialogue: 0,0:08:39.49,0:08:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka terlalu cepat untuk dilihat!
Dialogue: 0,0:08:41.20,0:08:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:08:42.38,0:08:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka saling serang!
Dialogue: 0,0:08:44.13,0:08:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga harus membantu!
Dialogue: 0,0:08:46.75,0:08:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Emma!
Dialogue: 0,0:08:47.98,0:08:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Palm!
Dialogue: 0,0:08:49.40,0:08:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster itu kebal sihir!
Dialogue: 0,0:08:52.43,0:08:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sihir kita mengenainya,\Nkita hanya akan membebani.
Dialogue: 0,0:08:58.08,0:09:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar kata Palm.\NSihir kita tidak akan berguna.
Dialogue: 0,0:09:01.98,0:09:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, bukankah dia si Nol Besar?
Dialogue: 0,0:09:05.95,0:09:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sering mengejek dan menertawakan dia.
Dialogue: 0,0:09:09.75,0:09:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa kita lakukan sekarang?
Dialogue: 0,0:09:18.18,0:09:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Na-Namun, dia sudah menyelamatkan kita!
Dialogue: 0,0:09:24.18,0:09:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sekarang, dia masih bertarung.
Dialogue: 0,0:09:26.52,0:09:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu permintaanku ini memberatkan.
Dialogue: 0,0:09:28.87,0:09:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:09:30.02,0:09:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melakukan sesuatu.
Dialogue: 0,0:09:34.85,0:09:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo maju!
Dialogue: 0,0:09:40.38,0:09:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo menang!
Dialogue: 0,0:09:42.80,0:09:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak Gagal!
Dialogue: 0,0:09:46.25,0:09:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa!
Dialogue: 0,0:09:47.92,0:09:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:09:50.63,0:09:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:09:53.38,0:09:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kalah, Will!
Dialogue: 0,0:09:54.62,0:09:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyerah!\NMaju!
Dialogue: 0,0:09:56.25,0:09:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanggung-tanggung\Ndan lakukan sesuatu!
Dialogue: 0,0:09:59.09,0:10:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semangat!\N- Maju, Will!
Dialogue: 0,0:10:01.33,0:10:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan kalah!\N- Will!
Dialogue: 0,0:10:03.80,0:10:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Julius?
Dialogue: 0,0:10:05.35,0:10:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sion?
Dialogue: 0,0:10:08.18,0:10:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semangat!
Dialogue: 0,0:10:10.18,0:10:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semangat, Will!
Dialogue: 0,0:10:13.23,0:10:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo maju!\N- Teruskan!
Dialogue: 0,0:10:15.99,0:10:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu bisa!\N- Tolonglah!
Dialogue: 0,0:10:18.15,0:10:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang! Kalahkan!
Dialogue: 0,0:10:19.99,0:10:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Serang!\N- Balas dia!
Dialogue: 0,0:10:24.90,0:10:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed!
Dialogue: 0,0:10:26.23,0:10:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak boleh mengandalkan orang\Nyang tidak bisa menggunakan sihir!
Dialogue: 0,0:10:32.83,0:10:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang tidak pernah berubah.
Dialogue: 0,0:10:35.70,0:10:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bukankah situasinya berbeda?
Dialogue: 0,0:10:39.83,0:10:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan saatnya melindungi muridmu,
Dialogue: 0,0:10:41.67,0:10:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mempercayainya.
Dialogue: 0,0:10:45.14,0:10:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan dia!
Dialogue: 0,0:10:46.47,0:10:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gentar!
Dialogue: 0,0:10:47.89,0:10:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:10:50.30,0:10:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo menang!
Dialogue: 0,0:10:51.48,0:10:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo menang!\N- Berjuanglah!
Dialogue: 0,0:10:55.58,0:10:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rigarden...
Dialogue: 0,0:10:56.92,0:10:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pusat dunia sihir ini
Dialogue: 0,0:10:59.05,0:11:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendukung si Nol Besar\Nyang tidak bisa sihir?
Dialogue: 0,0:11:02.53,0:11:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak percaya ini.
Dialogue: 0,0:11:11.63,0:11:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu merasa menyedihkan.
Dialogue: 0,0:11:15.60,0:11:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu menderita.
Dialogue: 0,0:11:19.20,0:11:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diasingkan,
Dialogue: 0,0:11:20.90,0:11:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dicemooh,
Dialogue: 0,0:11:23.00,0:11:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan pernah membenci dunia.
Dialogue: 0,0:11:27.50,0:11:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:11:28.81,0:11:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauh di dalam lubuk hatiku,
Dialogue: 0,0:11:31.00,0:11:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku selalu merasa ingin diakui!
Dialogue: 0,0:11:36.08,0:11:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo maju!\N- Jangan kalah!
Dialogue: 0,0:11:37.98,0:11:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Will!\N- Semangat!
Dialogue: 0,0:11:40.28,0:11:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ini terakhir kalinya\Nmereka memberiku dukungan,
Dialogue: 0,0:11:46.93,0:11:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin berjuang demi dunia\Nyang memberiku keberanian ini
Dialogue: 0,0:11:51.16,0:11:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan orang-orangnya!
Dialogue: 0,0:11:54.25,0:11:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melindungi mereka semua!
Dialogue: 0,0:12:07.65,0:12:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria?
Dialogue: 0,0:12:42.81,0:12:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangnya Will...
Dialogue: 0,0:12:44.59,0:12:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata Kak Will tidak sanggup\Nmengimbangi kekuatannya?
Dialogue: 0,0:12:47.83,0:12:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:12:49.19,0:12:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kehilangan senjata,\Nkeseimbangan ini akan hancur.
Dialogue: 0,0:12:59.54,0:13:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria!
Dialogue: 0,0:13:01.34,0:13:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Elfaria!
Dialogue: 0,0:13:03.61,0:13:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak boleh keluar dari ruangan ini.
Dialogue: 0,0:13:06.34,0:13:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berniat keluar.
Dialogue: 0,0:13:08.74,0:13:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin melihat dari balkon.
Dialogue: 0,0:13:14.44,0:13:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:13:19.94,0:13:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi...
Dialogue: 0,0:13:23.14,0:13:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sengaja menjatuhkan sesuatu.
Dialogue: 0,0:13:54.56,0:13:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan imaji.
Dialogue: 0,0:13:58.86,0:14:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Albis Wis!
Dialogue: 0,0:14:01.74,0:14:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kekuatan yang muncul\Nsaat melawan Grand Duke.
Dialogue: 0,0:14:06.19,0:14:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Will untuk menyerap\Nsihir orang lain melalui pedangnya.
Dialogue: 0,0:14:09.39,0:14:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:14:10.66,0:14:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, monster itu kebal sihir!
Dialogue: 0,0:14:13.29,0:14:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:14:14.00,0:14:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir sekuat apa pun tidak akan bekerja.
Dialogue: 0,0:14:18.74,0:14:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.
Dialogue: 0,0:14:21.06,0:14:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini
Dialogue: 0,0:14:23.76,0:14:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan
Dialogue: 0,0:14:26.34,0:14:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa dihentikan!
Dialogue: 0,0:14:42.24,0:14:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:14:44.71,0:14:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanannya tembus?!
Dialogue: 0,0:14:45.80,0:14:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah tidak ada penetral sihir?
Dialogue: 0,0:14:50.49,0:14:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wis.
Dialogue: 0,0:14:53.66,0:14:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?!\NApa yang terjadi?
Dialogue: 0,0:14:56.80,0:15:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana logikanya?\NKenapa dia bisa menghancurkan sleime?!
Dialogue: 0,0:15:00.96,0:15:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah keparat!
Dialogue: 0,0:15:03.09,0:15:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?!
Dialogue: 0,0:15:07.14,0:15:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:15:10.99,0:15:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hebat juga!
Dialogue: 0,0:15:13.79,0:15:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan energi sihir!\NKekuatan macam apa itu?
Dialogue: 0,0:15:16.69,0:15:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elemen kelima.
Dialogue: 0,0:15:18.68,0:15:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci primordial dalam legenda\Nyang menggerakkan dunia.
Dialogue: 0,0:15:24.79,0:15:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tercapai, ya, Finn?
Dialogue: 0,0:15:28.34,0:15:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat sihir dan pedang\Nyang dijanjikan Ratu Penyihir.
Dialogue: 0,0:15:58.01,0:15:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu kuat.
Dialogue: 0,0:15:59.71,0:16:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan mutlak tanpa ampun itu,\Nseolah-olah...
Dialogue: 0,0:16:04.31,0:16:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Albis Vina...
Dialogue: 0,0:16:08.74,0:16:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah Will sedang\Nbertarung bersama gadis itu.
Dialogue: 0,0:16:15.01,0:16:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Buntung!
Dialogue: 0,0:16:19.66,0:16:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir gerbang?!
Dialogue: 0,0:16:20.45,0:16:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada monster lagi?
Dialogue: 0,0:16:22.89,0:16:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara melawan mereka semua?!
Dialogue: 0,0:16:33.63,0:16:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:16:36.11,0:16:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sekarang bisa mengatasi segalanya.
Dialogue: 0,0:16:41.64,0:16:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Overlord!
Dialogue: 0,0:16:45.29,0:16:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Full Burst!
Dialogue: 0,0:16:51.39,0:16:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Glace Frosse, El Seven:
Dialogue: 0,0:17:06.26,0:17:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fruzel Cardeneia!
Dialogue: 0,0:17:24.04,0:17:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita akhiri.
Dialogue: 0,0:17:56.94,0:17:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:18:05.65,0:18:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:18:07.21,0:18:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiki!\NWill menang!
Dialogue: 0,0:18:10.41,0:18:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap!
Dialogue: 0,0:18:12.66,0:18:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Will...
Dialogue: 0,0:18:17.69,0:18:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar hebat!
Dialogue: 0,0:18:21.26,0:18:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerja kami memang hebat.
Dialogue: 0,0:18:28.56,0:18:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will...
Dialogue: 0,0:18:38.14,0:18:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:18:39.59,0:18:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini melebihi ekspektasi.
Dialogue: 0,0:18:41.34,0:18:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang harapan terakhir\Nyang tersisa untuk kita.
Dialogue: 0,0:18:47.84,0:18:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf lama, Mercedes!\NSaatnya melanjutkan kontrak.
Dialogue: 0,0:18:53.09,0:18:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, ini cuma lima ratus tahun.
Dialogue: 0,0:18:56.00,0:18:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma telat sedikit, kan?
Dialogue: 0,0:18:58.71,0:19:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prolog panjang ini telah berakhir!
Dialogue: 0,0:19:01.48,0:19:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu saja, langit palsu!
Dialogue: 0,0:19:04.06,0:19:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tirai akan terbuka!
Dialogue: 0,0:19:06.64,0:19:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo mulai!
Dialogue: 0,0:19:08.30,0:19:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah tongkat sihir dan pedang!\NWistoria kalian!
Dialogue: 0,0:23:36.02,0:23:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.15,0:23:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode tujuh belas:\N"Hari Keberangkatan".
