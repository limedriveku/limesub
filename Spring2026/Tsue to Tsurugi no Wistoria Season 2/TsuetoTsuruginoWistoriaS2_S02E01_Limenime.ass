Dialogue: 0,0:23:42.27,0:23:47.96,tanda,,0000,0000,0000,,EPISODE 14: PESTA NERAKA DIMULAI
Dialogue: 0,0:00:05.62,0:00:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal apa yang paling dihargai\Ndi dalam menara agung?
Dialogue: 0,0:00:31.20,0:00:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja talenta sihir.
Dialogue: 0,0:00:45.95,0:00:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi orang-orang tanpa talenta,
Dialogue: 0,0:00:49.33,0:00:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa mereka memiliki cara\Nuntuk mencapai puncak dunia sihir?
Dialogue: 0,0:01:05.76,0:01:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabannya...
Dialogue: 0,0:01:13.47,0:01:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melangkah maju\Nbersama teman-temanku!
Dialogue: 0,0:01:30.62,0:01:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie.
Dialogue: 0,0:01:32.49,0:01:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menyusulmu.
Dialogue: 0,0:03:08.96,0:03:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai sempurna
Dialogue: 0,0:03:09.86,0:03:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di semua bidang?!
Dialogue: 0,0:03:11.05,0:03:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudah kuperiksa berkali-kali.
Dialogue: 0,0:03:12.81,0:03:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi!
Dialogue: 0,0:03:14.05,0:03:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort!
Dialogue: 0,0:03:15.94,0:03:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian masih berlanjut,\Ntapi tidak ada kesalahan.
Dialogue: 0,0:03:18.34,0:03:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Lihanna pun gagal\Nmencapai prestasi seperti ini.
Dialogue: 0,0:03:21.20,0:03:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluangnya cukup besar.
Dialogue: 0,0:03:23.19,0:03:24.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si pembelajar bisa lolos.
Dialogue: 0,0:03:24.94,0:03:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dapat kredit penuh\Ndalam ujian tulis dan praksis.
Dialogue: 0,0:03:27.45,0:03:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pertama kalinya dalam sejarah,
Dialogue: 0,0:03:29.25,0:03:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada siswa tak bertalenta
Dialogue: 0,0:03:30.53,0:03:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang berhak masuk menara!
Dialogue: 0,0:03:39.78,0:03:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:03:42.42,0:03:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, Workner.
Dialogue: 0,0:03:45.04,0:03:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Impian anak didik kesayanganmu
Dialogue: 0,0:03:47.19,0:03:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan segera terwujud.
Dialogue: 0,0:03:48.68,0:03:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Eliza.
Dialogue: 0,0:03:50.69,0:03:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian belum selesai.
Dialogue: 0,0:03:52.52,0:03:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak boleh lengah sampai akhir.
Dialogue: 0,0:03:55.63,0:03:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang dilakukan\Nsi pembelajar itu?
Dialogue: 0,0:03:59.23,0:04:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa.
Dialogue: 0,0:04:07.09,0:04:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau baik-baik saja, Will?
Dialogue: 0,0:04:09.03,0:04:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin kau hampir tidak tidur, kan?
Dialogue: 0,0:04:11.56,0:04:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.\NTidak sebaik biasanya, sih.
Dialogue: 0,0:04:14.54,0:04:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok adalah hari terakhir ujian tulis.
Dialogue: 0,0:04:16.81,0:04:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok adalah hari terakhir ujian tulis.
Dialogue: 0,0:04:19.94,0:04:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jadwal Praksis Akbar yang ditunda itu
Dialogue: 0,0:04:23.00,0:04:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}digabungkan dengan ujian tulis terakhir.
Dialogue: 0,0:04:26.60,0:04:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita baru saja\Nmengalahkan Naberus kemarin.
Dialogue: 0,0:04:29.55,0:04:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Berkat Lihanna dan teman-teman,\Naku mengamankan seluruh kredit praksis.
Dialogue: 0,0:04:34.87,0:04:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh menyia-nyiakan\Nkebaikan kalian.
Dialogue: 0,0:04:37.81,0:04:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu maksudku.
Dialogue: 0,0:04:40.19,0:04:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga dapat sedikit
Dialogue: 0,0:04:41.82,0:04:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kredit realisasi sihir, kan?
Dialogue: 0,0:04:43.56,0:04:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Rosty.
Dialogue: 0,0:04:45.54,0:04:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat lima kredit\Ndari remedial Pak Edward.
Dialogue: 0,0:04:49.07,0:04:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian terakhir senilai enam kredit.
Dialogue: 0,0:04:51.63,0:04:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memanjat menara,\NAku cuma perlu satu kredit
Dialogue: 0,0:04:54.09,0:04:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak boleh lengah.
Dialogue: 0,0:04:55.95,0:04:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kau memaksakan diri...
Dialogue: 0,0:05:00.50,0:05:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:05:01.24,0:05:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!\NKau punya banyak uban.
Dialogue: 0,0:05:03.89,0:05:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?!
Dialogue: 0,0:05:05.52,0:05:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mencabut ubannya, kok.
Dialogue: 0,0:05:07.67,0:05:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu melakukannya.
Dialogue: 0,0:05:10.01,0:05:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah. Apa kau juga ingin melakukannya?
Dialogue: 0,0:05:13.14,0:05:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Mana mungkin!
Dialogue: 0,0:05:15.76,0:05:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin...
Dialogue: 0,0:05:17.01,0:05:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:05:21.14,0:05:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan di tengah jadwal padat pun,
Dialogue: 0,0:05:23.14,0:05:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian bisa mengalahkan Penjaga Strata.
Dialogue: 0,0:05:25.69,0:05:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sangat luar biasa.
Dialogue: 0,0:05:29.43,0:05:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya hanya dipaksa ikut, Bu Caldron.
Dialogue: 0,0:05:33.03,0:05:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tetap bisa masuk menara
Dialogue: 0,0:05:35.33,0:05:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa perlu mengalahkan Naberus.
Dialogue: 0,0:05:37.58,0:05:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, saya dipaksa Colette\Ndan teman-temannya.
Dialogue: 0,0:05:41.16,0:05:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang tidak diperlukan.
Dialogue: 0,0:05:44.16,0:05:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Es kebanggaanmu selalu dilelehkan
Dialogue: 0,0:05:46.78,0:05:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak terlalu berguna.
Dialogue: 0,0:05:48.88,0:05:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?!
Dialogue: 0,0:05:50.74,0:05:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di belakang si Nol Besar\NBukannya kau selalu berlindung
Dialogue: 0,0:05:52.98,0:05:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan main-main pakai api receh?!
Dialogue: 0,0:05:55.11,0:05:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan api Ulster!
Dialogue: 0,0:05:57.38,0:05:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Reinberg banyak gaya, tapi lemah!
Dialogue: 0,0:06:01.93,0:06:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak bisa meninggalkan Will, ya?
Dialogue: 0,0:06:06.26,0:06:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siapa?!
Dialogue: 0,0:06:08.49,0:06:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua dan kelompok Sion
Dialogue: 0,0:06:11.40,0:06:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah dapat semua kredit praksis.
Dialogue: 0,0:06:13.76,0:06:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Kita bisa membuktikan kepada menara
Dialogue: 0,0:06:17.67,0:06:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa kita sanggup\Nmengalahkan Penjaga Strata.
Dialogue: 0,0:06:19.92,0:06:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, semua itu tidak terlalu penting
Dialogue: 0,0:06:22.25,0:06:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kita sudah mengalahkan Grand Duke.
Dialogue: 0,0:06:25.27,0:06:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:06:28.96,0:06:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah berubah, Lihanna.
Dialogue: 0,0:06:31.09,0:06:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tampak lebih lembut\Ndari sebelumnya.
Dialogue: 0,0:06:34.67,0:06:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tampak lebih tenang dan santai.
Dialogue: 0,0:06:38.33,0:06:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dulu kau selalu\Nmenunjukkan senyuman lembut
Dialogue: 0,0:06:41.67,0:06:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyembunyikan rasa tertekan\Nyang lebih besar dari orang lain.
Dialogue: 0,0:06:47.38,0:06:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:48.69,0:06:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berkat dia.
Dialogue: 0,0:06:51.16,0:06:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengajarkan sisi baik kegagalan\Ndalam petualangan yang singkat itu.
Dialogue: 0,0:06:56.31,0:06:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga belajar banyak darinya.
Dialogue: 0,0:06:58.60,0:07:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa minder dan hati yang penakut
Dialogue: 0,0:07:01.82,0:07:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa diubah menjadi\Nsihir bernama keberanian.
Dialogue: 0,0:07:06.78,0:07:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia lakukan saat ini, ya?
Dialogue: 0,0:07:10.24,0:07:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabannya sudah pasti.
Dialogue: 0,0:07:12.87,0:07:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menyambut ujian terakhir.
Dialogue: 0,0:07:14.93,0:07:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will adalah pekerja keras\Nyang diakui oleh elf.
Dialogue: 0,0:07:21.33,0:07:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sampai selarut ini?\NSepertinya dia memaksakan diri.
Dialogue: 0,0:07:25.82,0:07:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will, aku membawa makan malam.
Dialogue: 0,0:07:28.64,0:07:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah minta izin Pak Workner\Nuntuk...
Dialogue: 0,0:07:47.60,0:07:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:07:50.51,0:07:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidur, ya?
Dialogue: 0,0:08:06.04,0:08:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa, Colette?
Dialogue: 0,0:08:12.56,0:08:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sejak kapan?
Dialogue: 0,0:08:14.42,0:08:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu! Bukan begitu!
Dialogue: 0,0:08:15.96,0:08:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku cuma khawatir padanya\Ndan menyelimutinya pakai jubah.
Dialogue: 0,0:08:19.47,0:08:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:08:21.13,0:08:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kau ingin menciumnya.
Dialogue: 0,0:08:25.04,0:08:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah salah paham.
Dialogue: 0,0:08:31.31,0:08:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar khawatir padanya.
Dialogue: 0,0:08:34.13,0:08:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tetap memaksakan diri\Nmeski keadaannya sudah buruk.
Dialogue: 0,0:08:37.96,0:08:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu dipenuhi luka.
Dialogue: 0,0:08:42.60,0:08:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci Magia Vander.
Dialogue: 0,0:08:47.98,0:08:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will selalu mengejar Albis Vina\Nkarena kena pengaruh sihirnya.
Dialogue: 0,0:08:53.01,0:08:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, gadis itu hanya diam\Ndan menunggu di menara.
Dialogue: 0,0:08:59.47,0:09:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kasihan sama Will.
Dialogue: 0,0:09:03.27,0:09:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:09:07.40,0:09:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju denganmu.
Dialogue: 0,0:09:19.93,0:09:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Nona Elfaria?
Dialogue: 0,0:09:24.07,0:09:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:09:27.02,0:09:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben sekali, Ratu Kemalasan.
Dialogue: 0,0:09:30.96,0:09:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau keluar dari sarangmu\Nyang nyaman itu.
Dialogue: 0,0:09:33.68,0:09:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa besok akan hujan tombak es?
Dialogue: 0,0:09:37.18,0:09:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ellenor.
Dialogue: 0,0:09:39.07,0:09:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau masih dendam\Nkarena kalah duel sihir denganku?
Dialogue: 0,0:09:43.49,0:09:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, kita cuma boleh pakai sihir es!
Dialogue: 0,0:09:46.00,0:09:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika boleh pakai sihir lain,\Naku pasti menang!
Dialogue: 0,0:09:49.29,0:09:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja berisik, ternyata ada kalian.
Dialogue: 0,0:09:53.73,0:09:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah jalanku.
Dialogue: 0,0:09:56.29,0:09:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat minggir!
Dialogue: 0,0:09:58.58,0:10:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kaulah yang harus minggir, Pria Biadab!\N- Minggir saja sendiri, Pria Biadab!
Dialogue: 0,0:10:02.42,0:10:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian tidak pernah berkaca,\Ncewek-cewek murahan?
Dialogue: 0,0:10:07.04,0:10:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian berdua di sini?
Dialogue: 0,0:10:10.78,0:10:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan banyak tanya.
Dialogue: 0,0:10:13.44,0:10:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bertiga sama, kan?
Dialogue: 0,0:10:16.04,0:10:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terminalia.
Dialogue: 0,0:10:17.64,0:10:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mempersiapkan diri\Nuntuk upacara merepotkan itu.
Dialogue: 0,0:10:21.09,0:10:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghalangnya sudah hampir lenyap.
Dialogue: 0,0:10:23.33,0:10:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir tahun sudah dekat.
Dialogue: 0,0:10:25.48,0:10:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar melihat\Nberapa banyak prospek berguna
Dialogue: 0,0:10:28.58,0:10:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang akan muncul.
Dialogue: 0,0:10:38.51,0:10:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya Pak Edward\Njadi pengawas di hari terakhir.
Dialogue: 0,0:10:42.12,0:10:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga periode bersama ular itu\Nadalah hal terburuk.
Dialogue: 0,0:10:45.69,0:10:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku tidak akan bisa ke menara.
Dialogue: 0,0:10:48.96,0:10:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap tenang!
Dialogue: 0,0:10:52.76,0:10:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian terakhir akan segera dimulai.
Dialogue: 0,0:10:55.91,0:10:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, aku ingin\Nmenyampaikan sesuatu.
Dialogue: 0,0:10:59.22,0:11:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya akan memberikan satu soal.
Dialogue: 0,0:11:02.14,0:11:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberikan enam kredit\Nkepada siswa yang bisa menjawabnya.
Dialogue: 0,0:11:08.90,0:11:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menjawab pertanyaan apa pun.
Dialogue: 0,0:11:11.40,0:11:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlihatkan hasil studi kalian\Nselama enam tahun di akademi ini.
Dialogue: 0,0:11:20.20,0:11:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dimulai!
Dialogue: 0,0:11:23.27,0:11:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu sihir?
Dialogue: 0,0:11:26.42,0:11:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdasarkan atribut sihir masing-masing,
Dialogue: 0,0:11:29.11,0:11:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jelaskan dengan menggunakan\Nkata-kata berikut ini:
Dialogue: 0,0:11:32.05,0:11:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tela, koneksi, dan manifestasi.
Dialogue: 0,0:11:35.05,0:11:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal uraian
Dialogue: 0,0:11:36.76,0:11:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang proses aktivasi sihir\Nserta syarat penggunaannya.
Dialogue: 0,0:11:40.07,0:11:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah proses penggunaan sihir\Nyang biasanya kami lakukan tanpa sadar.
Dialogue: 0,0:11:44.31,0:11:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kami diminta menjelaskannya\Ndengan kata-kata.
Dialogue: 0,0:11:47.94,0:11:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merangkai kata-kata memang sulit.
Dialogue: 0,0:11:50.56,0:11:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku bisa.
Dialogue: 0,0:11:52.57,0:11:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Penyihir dan elf\Npasti bisa menjawab soal ini.
Dialogue: 0,0:11:56.57,0:11:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ini mustahil bagi yang bukan.
Dialogue: 0,0:11:59.70,0:12:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana dengannya?
Dialogue: 0,0:12:06.09,0:12:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma.\NAku tidak bisa menjawabnya.
Dialogue: 0,0:12:09.04,0:12:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengetahuanku sia-sia.
Dialogue: 0,0:12:11.56,0:12:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak tertulis di buku.
Dialogue: 0,0:12:13.44,0:12:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan terlalu remeh untuk dijelaskan.
Dialogue: 0,0:12:15.30,0:12:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bergantung pada rasa\Ndan bakat seseorang sejak lahir.
Dialogue: 0,0:12:18.64,0:12:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai orang yang tidak bisa sihir,
Dialogue: 0,0:12:20.80,0:12:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak berhak menjawabnya!
Dialogue: 0,0:12:23.13,0:12:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menjawabnya sendiri!
Dialogue: 0,0:12:25.09,0:12:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku akan gagal?\NAku tidak akan bisa ke menara?
Dialogue: 0,0:12:28.47,0:12:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana janjiku pada Elfie?
Dialogue: 0,0:12:31.69,0:12:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyerah!
Dialogue: 0,0:12:35.76,0:12:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, sihir adalah...
Dialogue: 0,0:12:38.28,0:12:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aspirasi!
Dialogue: 0,0:12:40.47,0:12:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keajaiban yang jauh dari jangkauanku!
Dialogue: 0,0:12:44.41,0:12:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang indah, tapi kejam!
Dialogue: 0,0:12:49.91,0:12:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir adalah buah dari kerja keras!
Dialogue: 0,0:12:52.58,0:12:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin selama tidak menyerah,
Dialogue: 0,0:12:54.31,0:12:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih ada kekuatan\Nyang bisa melampaui sihir!
Dialogue: 0,0:12:57.18,0:12:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku...
Dialogue: 0,0:12:58.69,0:13:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi orang sepertiku, sihir adalah...
Dialogue: 0,0:13:05.89,0:13:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed!
Dialogue: 0,0:13:06.93,0:13:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ujian itu?\NApa-apaan soal itu?!
Dialogue: 0,0:13:10.33,0:13:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:13:12.02,0:13:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya menanyakan
Dialogue: 0,0:13:13.71,0:13:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}esensi terpenting sebagai penyihir\Nkepada para calon pemanjat menara.
Dialogue: 0,0:13:17.78,0:13:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada 40 persen siswa yang salah.
Dialogue: 0,0:13:21.22,0:13:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka benar-benar menyedihkan.
Dialogue: 0,0:13:23.70,0:13:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menanyakan itu!
Dialogue: 0,0:13:26.56,0:13:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seperti sengaja\Nmenjatuhkan satu siswa!
Dialogue: 0,0:13:29.20,0:13:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru macam apa yang tega\Nmelakukan kegilaan seperti itu?!
Dialogue: 0,0:13:34.36,0:13:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalianlah yang gila!
Dialogue: 0,0:13:40.40,0:13:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa mengirim siswa\Ntanpa bakat sihir ke menara?
Dialogue: 0,0:13:44.02,0:13:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa dia lakukan\Ndi kuburan tongkat sihir?!
Dialogue: 0,0:13:46.68,0:13:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi marmot percobaan?!
Dialogue: 0,0:13:49.18,0:13:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh! Itu tidak lucu!
Dialogue: 0,0:13:52.13,0:13:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia sihir ini, pedang tidak akan bisa\Njadi tongkat sihir!
Dialogue: 0,0:13:56.96,0:13:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sama-sama tidak waras.
Dialogue: 0,0:13:58.71,0:14:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dan Kepala Akademi.
Dialogue: 0,0:14:02.95,0:14:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mematahkan impian
Dialogue: 0,0:14:04.92,0:14:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mustahil diraih olehnya.
Dialogue: 0,0:14:06.13,0:14:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah bentuk belas kasih dariku.
Dialogue: 0,0:14:08.12,0:14:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah bentuk belas kasih dariku.
Dialogue: 0,0:14:12.29,0:14:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort.
Dialogue: 0,0:14:13.96,0:14:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah kredit: 7.999.
Dialogue: 0,0:14:18.11,0:14:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak memenuhi syarat\Nuntuk memanjat menara.
Dialogue: 0,0:14:36.47,0:14:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:14:38.04,0:14:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah perbaiki kacamata tempurmu.
Dialogue: 0,0:14:40.91,0:14:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku taruh di kamar.
Dialogue: 0,0:14:44.07,0:14:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:14:45.73,0:14:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosty.
Dialogue: 0,0:14:47.62,0:14:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Edward sangat jahat.
Dialogue: 0,0:14:50.49,0:14:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mungkin bisa\Nmenjawab soal seperti itu.
Dialogue: 0,0:14:55.38,0:14:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat jahat.\NKarena memberikan soal seperti itu.
Dialogue: 0,0:14:59.67,0:15:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:15:01.00,0:15:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:15:05.16,0:15:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Maafkan aku, Elfie!
Dialogue: 0,0:15:11.60,0:15:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kata-kataku ini\Ntidak akan berarti untukmu.
Dialogue: 0,0:15:16.60,0:15:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dengarkan aku.
Dialogue: 0,0:15:18.93,0:15:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu bersamamu.
Dialogue: 0,0:15:26.98,0:15:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihanna!\NApa kau menemukan Will?
Dialogue: 0,0:15:29.78,0:15:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Dia belum ditemukan.
Dialogue: 0,0:15:31.98,0:15:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencarinya bersama Wignall.
Dialogue: 0,0:15:35.07,0:15:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak ada di asrama.
Dialogue: 0,0:15:37.60,0:15:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia di luar lingkungan akademi.
Dialogue: 0,0:15:39.54,0:15:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pergi ke mana, Will?
Dialogue: 0,0:15:43.07,0:15:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa yang gagal masuk menara
Dialogue: 0,0:15:45.00,0:15:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meninggalkan akademi\Ndengan hati penuh kekecewaan.
Dialogue: 0,0:15:48.13,0:15:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini sedang musimnya?
Dialogue: 0,0:15:50.63,0:15:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius!
Dialogue: 0,0:15:52.20,0:15:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diseret buat mencari si Nol Besar\Nbenar-benar menyebalkan, sumpah.
Dialogue: 0,0:15:58.18,0:16:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja laki-laki menyedihkan\Nyang kabur itu.
Dialogue: 0,0:16:03.04,0:16:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik kata-katamu!
Dialogue: 0,0:16:04.71,0:16:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menghina teman baik elf!
Dialogue: 0,0:16:06.98,0:16:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sudah dilunakkan\Ndi dalam dungeon, ya, Paduka Peri?
Dialogue: 0,0:16:11.62,0:16:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Mungkin pikiranmu sudah\N"diracuni" olehnya.
Dialogue: 0,0:16:14.66,0:16:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?!
Dialogue: 0,0:16:18.73,0:16:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di akademi sihir ini!
Dialogue: 0,0:16:20.50,0:16:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia ini, sihir adalah segalanya!
Dialogue: 0,0:16:24.84,0:16:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah sehebat apa pun\Nkemampuannya di dungeon,
Dialogue: 0,0:16:27.58,0:16:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada tempat untuk pedang di sini!
Dialogue: 0,0:16:31.07,0:16:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau melihatku seperti itu, Sion?
Dialogue: 0,0:16:34.13,0:16:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau sama sepertiku\Ndan membenci si Nol Besar itu?
Dialogue: 0,0:16:39.27,0:16:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:40.78,0:16:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membalasnya\Nkarena dia membuatku kesal.
Dialogue: 0,0:16:46.07,0:16:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kesempatan itu lenyap.
Dialogue: 0,0:16:48.62,0:16:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu membuatku makin kesal.
Dialogue: 0,0:16:52.02,0:16:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kalian?
Dialogue: 0,0:16:54.42,0:16:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Workner!
Dialogue: 0,0:16:56.56,0:16:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang mencari Will.
Dialogue: 0,0:16:59.07,0:17:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak bisa menemukannya.
Dialogue: 0,0:17:03.02,0:17:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja yang mencarinya.
Dialogue: 0,0:17:05.51,0:17:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggalkanlah tempat ini.
Dialogue: 0,0:17:07.20,0:17:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Na-Namun...
Dialogue: 0,0:17:08.98,0:17:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini adalah akhir tahun.
Dialogue: 0,0:17:11.04,0:17:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terminalia.
Dialogue: 0,0:17:13.16,0:17:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmati waktu kalian\Ndan bersenang-senanglah.
Dialogue: 0,0:17:19.40,0:17:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival!
Dialogue: 0,0:17:22.69,0:17:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang\Ndi perayaan malam tahun baru!
Dialogue: 0,0:17:25.38,0:17:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam, seluruh dunia!
Dialogue: 0,0:17:27.94,0:17:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun ini, kita berkumpul\Ndi kota Urbus Rigarden lagi
Dialogue: 0,0:17:30.94,0:17:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengadakan festival terbesar\Nsekaligus upacara terpenting!
Dialogue: 0,0:17:36.69,0:17:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyiar tahun ini adalah saya, Clairie!
Dialogue: 0,0:17:40.87,0:17:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir agung dari menara,
Dialogue: 0,0:17:42.49,0:17:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}26 tahun, lajang,
Dialogue: 0,0:17:43.99,0:17:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clairie Serah!
Dialogue: 0,0:17:46.21,0:17:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di akhir tahun yang spesial ini,\Nsaya tetap kerja, kerja, dan kerja!
Dialogue: 0,0:17:51.34,0:17:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat melihat keluarga dan kekasih bahagia,
Dialogue: 0,0:17:53.84,0:17:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya jadi pengin menangis\Nkarena merasa beda sendiri.
Dialogue: 0,0:17:56.47,0:18:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ajak rekan kerja, tapi saya ditolak\Nkarena mereka mementingkan murid.
Dialogue: 0,0:18:00.98,0:18:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu banget, ya.
Dialogue: 0,0:18:04.73,0:18:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:18:05.73,0:18:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian dengar, Workner dan Ed?!
Dialogue: 0,0:18:08.27,0:18:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita adalah tiga serangkai\Ndi zaman sekolah!
Dialogue: 0,0:18:11.24,0:18:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas saja nanti!
Dialogue: 0,0:18:12.87,0:18:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu saat, aku akan di sana.
Dialogue: 0,0:18:15.24,0:18:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehem. Maaf.\NSaya kehilangan kendali.
Dialogue: 0,0:18:18.49,0:18:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum semua aib saya\Ntersebar ke seluruh dunia,
Dialogue: 0,0:18:21.56,0:18:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}izinkan saya menunjukkan\Npemandangan luar biasa ini!
Dialogue: 0,0:18:25.00,0:18:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar! Hari ini adalah Terminalia!
Dialogue: 0,0:18:28.27,0:18:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan melihat
Dialogue: 0,0:18:29.98,0:18:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penyusunan ulang penghalang besar\Nyang melindungi kita di langit!
Dialogue: 0,0:18:43.29,0:18:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu kala,
Dialogue: 0,0:18:46.42,0:18:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}umat manusia tidak mengenal langit\Ndan dunia ini terjebak dalam kegelapan.
Dialogue: 0,0:18:52.13,0:18:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanah kita dihancurkan Penjajah Langit
Dialogue: 0,0:18:56.18,0:18:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan deretan kematian\Ndari banyak nyawa pun tercipta.
Dialogue: 0,0:19:00.58,0:19:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, saat keputusasaan\Nhampir melahap segalanya,
Dialogue: 0,0:19:06.42,0:19:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}leluhur pendiri kita, Mercedes,
Dialogue: 0,0:19:08.36,0:19:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memanggil lima penyihir hebat\Nuntuk menyegel langit
Dialogue: 0,0:19:10.91,0:19:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengusir para Penjajah Langit!
Dialogue: 0,0:19:13.42,0:19:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu terjadi lima ratus tahun lalu!
Dialogue: 0,0:19:16.78,0:19:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghalang besar Magia Vander\Nmasih memisahkan kita dari langit
Dialogue: 0,0:19:21.42,0:19:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melindungi kita semua!
Dialogue: 0,0:19:27.00,0:19:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghalang itu hanya akan\Nbertahan selama satu tahun.
Dialogue: 0,0:19:29.69,0:19:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap akhir tahun, kami harus\Nmemasang penghalang besar baru.
Dialogue: 0,0:19:35.44,0:19:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika penghalangnya hilang,
Dialogue: 0,0:19:37.19,0:19:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka legenda akan terjadi.
Dialogue: 0,0:19:39.76,0:19:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak boleh gagal.
Dialogue: 0,0:19:41.70,0:19:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada keanehan di bawah.
Dialogue: 0,0:19:43.13,0:19:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana di atas sana?
Dialogue: 0,0:19:44.33,0:19:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya aman.
Dialogue: 0,0:19:46.04,0:19:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada sosok mencurigakan\Natau gangguan energi sihir.
Dialogue: 0,0:19:49.36,0:19:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya aman.\NPersiapan telah selesai.
Dialogue: 0,0:19:52.96,0:19:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Logwell.
Dialogue: 0,0:19:59.51,0:20:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya sudah tiba, Tuan Cariott.
Dialogue: 0,0:20:01.96,0:20:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:20:03.68,0:20:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai festival pembatas ini.
Dialogue: 0,0:20:08.20,0:20:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, semuanya!
Dialogue: 0,0:20:09.69,0:20:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari sambut mereka\Ndengan sorakan kemuliaan!
Dialogue: 0,0:20:12.49,0:20:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Magia Vander telah datang!
Dialogue: 0,0:20:15.44,0:20:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaisar Cahaya Agung!
Dialogue: 0,0:20:16.82,0:20:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan Aron!\N- Tuan Cariott!
Dialogue: 0,0:20:17.95,0:20:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bang Zeo!\N- Nona Ellenor!
Dialogue: 0,0:20:19.47,0:20:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nona Elfaria!\N- Jaya!
Dialogue: 0,0:20:21.45,0:20:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada orang-orang\Nyang merasakan kesedihan.
Dialogue: 0,0:20:24.73,0:20:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pula orang-orang\Nyang terjebak dalam keputusasaan.
Dialogue: 0,0:20:27.96,0:20:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, angkat wajah kalian.
Dialogue: 0,0:20:31.51,0:20:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie.
Dialogue: 0,0:20:33.89,0:20:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak boleh lupa.
Dialogue: 0,0:20:36.29,0:20:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Penjajah Langit\Nmasih mengincar dunia kita.
Dialogue: 0,0:20:40.73,0:20:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surga kecil kita masih terancam bahaya.
Dialogue: 0,0:20:45.49,0:20:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kita sedang terpuruk,
Dialogue: 0,0:20:47.00,0:20:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus tetap menopang langit\Ndan menghalau sumber kejahatan.
Dialogue: 0,0:20:51.89,0:20:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari kita nyalakan cahaya penunjuk!
Dialogue: 0,0:20:55.07,0:20:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita ikut andil untuk menopang langit!
Dialogue: 0,0:21:04.47,0:21:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai!
Dialogue: 0,0:21:05.99,0:21:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahkota Api.
Dialogue: 0,0:21:08.60,0:21:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permata Suci Air.
Dialogue: 0,0:21:11.04,0:21:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singgasana Petir.
Dialogue: 0,0:21:13.13,0:21:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat Raja Angin.
Dialogue: 0,0:21:14.63,0:21:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persembahkanlah, Altar Bumi.
Dialogue: 0,0:21:18.62,0:21:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbukalah, Oh Kegelapan Purba.
Dialogue: 0,0:21:21.60,0:21:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan demikian,
Dialogue: 0,0:21:22.76,0:21:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cahaya akan jadi pembatas\Nyang menghalau ancaman dari langit.
Dialogue: 0,0:21:30.33,0:21:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Megasihir:
Dialogue: 0,0:21:32.39,0:21:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vandes Terminalia!
Dialogue: 0,0:21:36.38,0:21:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima, empat!
Dialogue: 0,0:21:38.28,0:21:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga, dua, satu!
Dialogue: 0,0:21:43.28,0:21:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tahun baru!
Dialogue: 0,0:21:48.84,0:21:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal, tahun lalu!
Dialogue: 0,0:21:51.38,0:21:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, tahun baru!
Dialogue: 0,0:21:54.04,0:21:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dilindungi Mercedes!\NSemoga kita semua senantiasa
Dialogue: 0,0:21:57.98,0:22:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, Rigarden!\NSelamat datang, dunia baru!
Dialogue: 0,0:22:13.31,0:22:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tahun baru!
Dialogue: 0,0:22:18.02,0:22:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:22:19.16,0:22:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulah orang?
Dialogue: 0,0:22:20.38,0:22:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram.
Dialogue: 0,0:22:21.36,0:22:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu bagian dari pertunjukan?
Dialogue: 0,0:22:23.13,0:22:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.\NMereka tidak melakukan itu tahun lalu.
Dialogue: 0,0:22:26.56,0:22:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lingkaran sihir apa itu?!
Dialogue: 0,0:22:28.80,0:22:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat cari tahu asalnya!
Dialogue: 0,0:22:33.91,0:22:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama, apa itu?
Dialogue: 0,0:23:01.96,0:23:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah membuat penghalang besar,\NMagia Vander akan kehabisan energi
Dialogue: 0,0:23:06.49,0:23:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mereka takkan berdaya\Nsementara waktu.
Dialogue: 0,0:23:09.28,0:23:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mulai sekarang,
Dialogue: 0,0:23:22.36,0:23:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saatnya mengadakan pesta neraka.
Dialogue: 0,0:23:36.52,0:23:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.27,0:23:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode empat belas:\N"Pesta Neraka Dimulai."
