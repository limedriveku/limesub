Dialogue: 0,0:00:00.13,0:00:03.03,tanda,,0000,0000,0000,,TIGA TAHUN LALU
Dialogue: 0,0:02:17.02,0:02:21.70,tanda,,0000,0000,0000,,EPISODE 17: HARI KEBERANGKATAN
Dialogue: 0,0:03:25.98,0:03:30.56,tanda,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:11:06.33,0:11:07.23,tanda,,0000,0000,0000,,TONGKAT SIHIR NIGHTBLOOD
Dialogue: 0,0:11:07.70,0:11:10.94,tanda,,0000,0000,0000,,ELIZA NOSFERAT
Dialogue: 0,0:11:11.15,0:11:12.71,tanda,,0000,0000,0000,,TONGKAT SIHIR CRIMSONBLUE,\NSAPU BAJHA
Dialogue: 0,0:11:12.71,0:11:15.95,tanda,,0000,0000,0000,,CLAIRIE SERAH
Dialogue: 0,0:12:46.93,0:12:49.95,tanda,,0000,0000,0000,,"SATU TAHUN LALU"
Dialogue: 0,0:15:12.10,0:15:14.21,tanda,,0000,0000,0000,,AUDITORIUM AKADEMI SIHIR RIGARDEN
Dialogue: 0,0:17:38.91,0:17:40.00,tanda,,0000,0000,0000,,LIHANNA OWENZAUS,\NPEROLEHAN KREDIT: 12.000
Dialogue: 0,0:17:55.57,0:17:56.35,tanda,,0000,0000,0000,,WIGNALL LINDOR,\NPEROLEHAN KREDIT: 11.989
Dialogue: 0,0:17:58.75,0:17:59.60,tanda,,0000,0000,0000,,JULIUS REINBERG,\NPEROLEHAN KREDIT: 11.802
Dialogue: 0,0:18:01.91,0:18:02.85,tanda,,0000,0000,0000,,SION ULSTER,\NPEROLEHAN KREDIT: 11.801
Dialogue: 0,0:18:04.87,0:18:05.55,tanda,,0000,0000,0000,,EMMA CLEVER,\NPEROLEHAN KREDIT: 10.000
Dialogue: 0,0:18:08.01,0:18:08.36,tanda,,0000,0000,0000,,RENAISSE ARETTE,\NPEROLEHAN KREDIT: 9.655
Dialogue: 0,0:18:10.35,0:18:11.33,tanda,,0000,0000,0000,,COLETTE LOIRE,\NPEROLEHAN KREDIT: 9.024
Dialogue: 0,0:23:27.94,0:23:30.89,tanda,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:42.75,0:23:47.03,tanda,,0000,0000,0000,,EPISODE 18: FIRST BLOOM
Dialogue: 0,0:00:03.90,0:00:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria hebat sekali!
Dialogue: 0,0:00:06.05,0:00:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah yang namanya hujan?
Dialogue: 0,0:00:08.23,0:00:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah lihat hujan!
Dialogue: 0,0:00:11.03,0:00:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Magia Vander\Nsanggup mengendalikan langit!
Dialogue: 0,0:00:18.53,0:00:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh sekali.\NJauh dari jangkauanku.
Dialogue: 0,0:00:23.25,0:00:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berdiri di sampingmu,
Dialogue: 0,0:00:25.70,0:00:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi setetes air pun\Ntidak bisa kukendalikan.
Dialogue: 0,0:00:31.48,0:00:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie, apa aku bisa mengejarmu?
Dialogue: 0,0:00:40.58,0:00:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kamu sakit, lo.
Dialogue: 0,0:00:51.13,0:00:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini namanya "payung".\NAku membuatnya sendiri.
Dialogue: 0,0:00:55.08,0:00:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi rekayasawan sihir.
Dialogue: 0,0:00:58.28,0:00:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:00:59.50,0:01:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Rosty.\NRosty Nowman.
Dialogue: 0,0:01:03.05,0:01:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini, aku akan\Nmenjadi teman sekamarmu.
Dialogue: 0,0:01:06.88,0:01:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berteman denganmu,
Dialogue: 0,0:01:09.48,0:01:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort.
Dialogue: 0,0:01:20.23,0:01:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosty...
Dialogue: 0,0:01:30.40,0:01:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa memanfaatkan warisan\NRatu Penyihir dengan baik, Caldron.
Dialogue: 0,0:01:35.13,0:01:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang membuatnya bertahan\Ndi akademi ini.
Dialogue: 0,0:01:38.93,0:01:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku wajib membimbing dan mendukungnya.
Dialogue: 0,0:01:42.43,0:01:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perakitan memori berjalan baik.
Dialogue: 0,0:01:45.04,0:01:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dia bisa kembali\Nmenjadi Will yang biasanya.
Dialogue: 0,0:01:48.55,0:01:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan sang putri tidur tercinta itu\Nberada dalam buaian ingatan, ya.
Dialogue: 0,0:01:55.18,0:01:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, mimpi seperti apa\Nyang sedang kamu lihat?
Dialogue: 0,0:03:35.26,0:03:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, akhirnya siuman!
Dialogue: 0,0:03:39.30,0:03:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clairie... Ed...
Dialogue: 0,0:03:41.87,0:03:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka di tubuh sendiri\Ntidak pernah dipikirkan.
Dialogue: 0,0:03:44.55,0:03:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak pernah berubah\Nsejak kita masih pelajar, dasar bodoh!
Dialogue: 0,0:03:48.28,0:03:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski punya tubuh abadi,\Nsayangilah dirimu sendiri.
Dialogue: 0,0:03:52.60,0:03:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:03:53.93,0:03:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang klinik akademi.
Dialogue: 0,0:03:55.90,0:03:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eliza.
Dialogue: 0,0:03:57.63,0:04:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukanmu di atap tadi malam\Ndan memindahkanmu ke sini.
Dialogue: 0,0:04:03.80,0:04:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang melihatmu siuman, Workner.
Dialogue: 0,0:04:09.23,0:04:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu bertingkah\Nseperti istrinya, Junior Vampir?!
Dialogue: 0,0:04:13.98,0:04:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, Senior Nenek Sihir Bodoh.
Dialogue: 0,0:04:16.39,0:04:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhentilah sok-sokan mendua.
Dialogue: 0,0:04:19.10,0:04:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak gila dan memalukan.
Dialogue: 0,0:04:21.99,0:04:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Workner, dan Ed\Nterikat tali persahabatan kuat!
Dialogue: 0,0:04:26.05,0:04:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mencemari ikatan\Nrekan kerja kami, Wanita Pencuri!
Dialogue: 0,0:04:31.50,0:04:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Will?!\NApa yang terjadi padanya?
Dialogue: 0,0:04:34.53,0:04:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan banyak gerak, bodoh!
Dialogue: 0,0:04:36.68,0:04:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah ditangani Kepala Akademi Caldron.
Dialogue: 0,0:04:39.68,0:04:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Akademi?
Dialogue: 0,0:04:40.76,0:04:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mengandalkan nenek sihir itu,\Nkemungkinan buruk tidak akan terjadi.
Dialogue: 0,0:04:47.27,0:04:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidurlah dengan tenang.
Dialogue: 0,0:04:54.23,0:04:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:04:55.65,0:04:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Workner baik-baik saja!\NDia juga!
Dialogue: 0,0:04:58.90,0:05:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah, Lyril?
Dialogue: 0,0:05:00.68,0:05:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:01.53,0:05:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Eliza sudah bilang. Katanya, Will...
Dialogue: 0,0:05:06.00,0:05:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si pembelajar itu masih bisa\Nmenghadiri upacara kelulusan.
Dialogue: 0,0:05:10.04,0:05:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:05:11.92,0:05:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dialah yang paling berjuang keras!
Dialogue: 0,0:05:13.30,0:05:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa bersalah\Nkalau dia kenapa-kenapa.
Dialogue: 0,0:05:15.25,0:05:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tangguh seperti dwarf.
Dialogue: 0,0:05:16.67,0:05:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepolosan kalian tidak tertolong.
Dialogue: 0,0:05:19.70,0:05:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius?
Dialogue: 0,0:05:21.18,0:05:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa mengkhawatirkan orang\Nyang punya kekuatan enggak jelas itu?
Dialogue: 0,0:05:26.43,0:05:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu sinis begitu, Julius?
Dialogue: 0,0:05:28.93,0:05:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Padahal kamu dulu—\N- Jangan ungkit masa lalu, Emma!
Dialogue: 0,0:05:33.18,0:05:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kalian juga sempat\Nmeremehkan anak gagal itu?
Dialogue: 0,0:05:38.90,0:05:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kelihatan bagus sedikit,\Nkalian langsung mendukungnya.
Dialogue: 0,0:05:42.43,0:05:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua sama saja.
Dialogue: 0,0:05:44.03,0:05:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikiran kalian sudah diracuni\Nseperti Paduka Peri...
Dialogue: 0,0:05:46.85,0:05:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat jelas bahwa kamulah\Nyang tampak keras kepala sekarang.
Dialogue: 0,0:05:50.66,0:05:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau main keroyokan?\NAku tidak akan tunduk.
Dialogue: 0,0:05:55.75,0:05:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak bisa mengakuinya,
Dialogue: 0,0:05:57.38,0:06:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setidaknya kita masih bisa merasa\Nberterima kasih atas pertolongannya.
Dialogue: 0,0:06:03.93,0:06:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa para penyihir sudah melupakan\N"noblesse oblige"?
Dialogue: 0,0:06:07.68,0:06:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Bangsawan?
Dialogue: 0,0:06:10.95,0:06:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jelas, dia tidak bisa memanjat menara.
Dialogue: 0,0:06:14.69,0:06:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lega rasanya.
Dialogue: 0,0:06:18.10,0:06:19.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Sion?
Dialogue: 0,0:06:21.88,0:06:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion?
Dialogue: 0,0:06:24.53,0:06:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam insiden Festival Terminalia,\Nkorban tewas dan luka mencapai 3.000.
Dialogue: 0,0:06:27.95,0:06:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para dalang serangan itu\Nbelum diketahui keberadaannya.
Dialogue: 0,0:06:31.70,0:06:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusan investigasi\Nakan dibagi ke semua faksi.
Dialogue: 0,0:06:34.98,0:06:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prioritaskan perbaikan ibu kota dulu.
Dialogue: 0,0:06:38.33,0:06:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai kehendak Anda, Tuan Aaron.
Dialogue: 0,0:06:40.53,0:06:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian, Will Serfort.
Dialogue: 0,0:06:46.00,0:06:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa keberadaannya tidak tercium\Nmeski dia di akademi selama enam tahun?
Dialogue: 0,0:06:52.83,0:06:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karena Kepala Akademi Caldron.
Dialogue: 0,0:06:55.60,0:06:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia disembunyikan\Nsampai menginjak usia dewasa.
Dialogue: 0,0:06:59.11,0:07:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar wanita sihir kuali besar.
Dialogue: 0,0:07:02.00,0:07:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir segenerasi dengannya,\Ntermasuk Logwell, terlalu seenaknya.
Dialogue: 0,0:07:06.33,0:07:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawasan terhadap pedang\Nakan diserahkan kepada Finn.
Dialogue: 0,0:07:13.98,0:07:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Aaron, bagaimana pendapat Anda\Ntentang Will Serfort?
Dialogue: 0,0:07:19.23,0:07:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mengikuti takdir.
Dialogue: 0,0:07:21.68,0:07:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ini tongkat sihir dan pedang\Nyang dijanjikan Ratu Penyihir,
Dialogue: 0,0:07:25.53,0:07:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka semuanya akan terhubung.
Dialogue: 0,0:07:30.28,0:07:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu, Raja.
Dialogue: 0,0:07:33.30,0:07:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru juga kemarin, sekarang kumpul lagi.
Dialogue: 0,0:07:36.03,0:07:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau evaluasi bodoh lagi?!
Dialogue: 0,0:07:39.08,0:07:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan merengek, Pria Biadab!\NSuaramu merusak gendang telinga.
Dialogue: 0,0:07:44.65,0:07:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus berbagi info\Ntentang para penyerang.
Dialogue: 0,0:07:47.78,0:07:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjutkan investigasi,\Ndimulai dari kasus Praksis Akbar.
Dialogue: 0,0:07:51.25,0:07:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu kota, dungeon,\Nsampai bagian dalam menara.
Dialogue: 0,0:07:55.30,0:07:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selidiki semuanya.
Dialogue: 0,0:07:57.50,0:08:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada petunjuk\Ndari senjata pembunuh penyihir?
Dialogue: 0,0:08:00.98,0:08:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:08:02.05,0:08:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dari para monster?
Dialogue: 0,0:08:04.03,0:08:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Institut Tinggi pasti sudah\Nmembedah tubuh mereka, kan?
Dialogue: 0,0:08:07.55,0:08:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:08:08.78,0:08:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak ada terus?\NDasar raja tidak becus!
Dialogue: 0,0:08:11.80,0:08:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa tidak ada petunjuk sama sekali?
Dialogue: 0,0:08:14.75,0:08:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika harus menebak, ini berkaitan\Ndengan perang besar 10 tahun lalu.
Dialogue: 0,0:08:18.98,0:08:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memiliki aroma para perusak\Nyang pernah mengguncang dunia sihir.
Dialogue: 0,0:08:25.33,0:08:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada musuh yang masih tersisa\Ndari insiden Hari Kehancuran, ya?
Dialogue: 0,0:08:29.20,0:08:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik!
Dialogue: 0,0:08:30.93,0:08:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian datang lagi, ya,\Ndasar hantu-hantu kotor?
Dialogue: 0,0:08:34.20,0:08:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu benar-benar mereka?
Dialogue: 0,0:08:36.50,0:08:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah dihancurkan\Noleh Lefiya dan yang lainnya
Dialogue: 0,0:08:38.95,0:08:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan harga yang besar.
Dialogue: 0,0:08:40.13,0:08:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Apa kau ketakutan?
Dialogue: 0,0:08:42.53,0:08:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya. Kau tidak ikut perang itu.
Dialogue: 0,0:08:46.09,0:08:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau ingin kabur ke hutan,
Dialogue: 0,0:08:48.63,0:08:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita Ngengat?
Dialogue: 0,0:08:59.64,0:09:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah sebabnya aku tidak mau hadir\Ndalam pertemuan para Magia Vander.
Dialogue: 0,0:09:03.94,0:09:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau ingin dibunuh, berengsek?!
Dialogue: 0,0:09:06.53,0:09:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu\Nsetelah berusaha membunuhku.
Dialogue: 0,0:09:09.44,0:09:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau ingin dihajar duluan, hah?!
Dialogue: 0,0:09:13.78,0:09:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup!
Dialogue: 0,0:09:15.93,0:09:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua faksi wajib melakukan investigasi.
Dialogue: 0,0:09:18.90,0:09:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lenyapkan semua potensi bahaya baru.
Dialogue: 0,0:09:21.33,0:09:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Upacara inisiasi pun sudah dekat.
Dialogue: 0,0:09:23.21,0:09:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lalai mempersiapkan itu.
Dialogue: 0,0:09:26.73,0:09:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Sarissa.
Dialogue: 0,0:09:28.08,0:09:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?!
Dialogue: 0,0:09:29.08,0:09:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa di situ?
Dialogue: 0,0:09:30.97,0:09:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya, eh...
Dialogue: 0,0:09:32.97,0:09:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana perempuan itu?
Dialogue: 0,0:09:34.98,0:09:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua Magia Vander\Nharus datang tanpa terkecuali.
Dialogue: 0,0:09:38.88,0:09:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya...
Dialogue: 0,0:09:40.75,0:09:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau tidak hadir karena sakit perut.
Dialogue: 0,0:10:04.00,0:10:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette.
Dialogue: 0,0:10:07.33,0:10:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihanna.
Dialogue: 0,0:10:08.63,0:10:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu bawa bunga itu?
Dialogue: 0,0:10:11.23,0:10:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk Rosty.
Dialogue: 0,0:10:13.25,0:10:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski belum ada makamnya,\Ntapi aku ingin mendoakannya dengan ini.
Dialogue: 0,0:10:20.20,0:10:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa Rosty Nowman itu?
Dialogue: 0,0:10:24.00,0:10:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak terlalu kenal dia.
Dialogue: 0,0:10:27.00,0:10:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masuk jurusan rekayasawan sihir,\Njadi, kami jarang bertemu di akademi.
Dialogue: 0,0:10:32.40,0:10:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dia siswa pindahan\Ndari ibu kota barat, Terralis.
Dialogue: 0,0:10:36.66,0:10:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba dia muncul.\NTiba-tiba dia berada di sisi Will.
Dialogue: 0,0:10:43.28,0:10:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku cemburu padanya.
Dialogue: 0,0:10:58.28,0:11:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Will membanggakannya\Nsebagai teman berharga
Dialogue: 0,0:11:02.31,0:11:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tampak sangat senang karenanya.
Dialogue: 0,0:11:22.75,0:11:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rigarden memang hebat.
Dialogue: 0,0:11:24.33,0:11:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbaikannya sangat cepat\Nkarena ada kontribusi para dwarf.
Dialogue: 0,0:11:31.70,0:11:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kota ini akan\Nsegera kembali seperti semula.
Dialogue: 0,0:11:36.45,0:11:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Invess.
Dialogue: 0,0:11:44.15,0:11:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Iris.
Dialogue: 0,0:11:46.05,0:11:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah aku sudah memintamu\Nberhenti memanggilku seperti itu?
Dialogue: 0,0:11:49.03,0:11:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka nama itu.
Dialogue: 0,0:11:51.05,0:11:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas sekali.
Dialogue: 0,0:11:53.50,0:11:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat membencimu.
Dialogue: 0,0:11:56.95,0:11:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak pernah berubah, ya.
Dialogue: 0,0:11:59.45,0:12:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa kamu menghentikan orang\Nyang kamu benci ini?
Dialogue: 0,0:12:05.33,0:12:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyentuh Kak Will.
Dialogue: 0,0:12:08.18,0:12:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kamu terlibat dengannya,\Njarum jam akan jadi lebih cepat.
Dialogue: 0,0:12:13.70,0:12:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu terjadi,
Dialogue: 0,0:12:15.78,0:12:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tidak akan terhentikan lagi.
Dialogue: 0,0:12:18.45,0:12:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut.
Dialogue: 0,0:12:19.85,0:12:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya watcher sepertimu\Nbilang begitu.
Dialogue: 0,0:12:23.30,0:12:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu suka dia?
Dialogue: 0,0:12:24.68,0:12:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?!
Dialogue: 0,0:12:27.88,0:12:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iris, maaf mengatakan ini,
Dialogue: 0,0:12:31.18,0:12:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku akan mengambilnya.
Dialogue: 0,0:12:38.76,0:12:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini adalah upacara kelulusan.
Dialogue: 0,0:12:41.40,0:12:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainan Caldron sudah selesai.
Dialogue: 0,0:12:46.93,0:12:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Will. Misalnya...
Dialogue: 0,0:12:49.95,0:12:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku pergi suatu saat nanti,
Dialogue: 0,0:12:53.04,0:12:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kamu akan sedih?
Dialogue: 0,0:12:56.45,0:12:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:12:58.35,0:13:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah bertemu denganmu\Ndan memiliki banyak kenangan indah,
Dialogue: 0,0:13:03.03,0:13:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi kepikiran itu.
Dialogue: 0,0:13:05.06,0:13:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika perpisahan kita\Njustru membuatmu sedih,
Dialogue: 0,0:13:09.95,0:13:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin sebaiknya aku\Ntidak muncul di depanmu.
Dialogue: 0,0:13:13.81,0:13:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu tidak benar!
Dialogue: 0,0:13:15.90,0:13:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang bertemu denganmu!
Dialogue: 0,0:13:18.18,0:13:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bahagia!
Dialogue: 0,0:13:20.08,0:13:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan mengucapkan\Nkata-kata menyedihkan itu.
Dialogue: 0,0:13:25.63,0:13:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:13:27.03,0:13:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, saat kamu memanjat menara,\Nmungkin aku tidak bisa menemanimu.
Dialogue: 0,0:13:33.15,0:13:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kreditnya kurang?
Dialogue: 0,0:13:35.53,0:13:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mungkin seperti itu.
Dialogue: 0,0:13:39.35,0:13:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kamu memanjat menara kelak,\Nmungkin aku akan membuatmu sedih.
Dialogue: 0,0:13:44.95,0:13:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:13:49.95,0:13:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan selalu mengawasimu.
Dialogue: 0,0:14:20.63,0:14:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna rambutku kembali seperti semula.
Dialogue: 0,0:14:24.93,0:14:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa begitu, ya?
Dialogue: 0,0:14:50.10,0:14:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kamu masih di sini,\Napa kamu bisa mencerahkanku?
Dialogue: 0,0:14:55.18,0:14:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosty.
Dialogue: 0,0:15:04.15,0:15:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat.
Dialogue: 0,0:15:14.28,0:15:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Doktrin Sihir, Butir Pertama.
Dialogue: 0,0:15:18.03,0:15:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ratu Penyihir nan agung pernah berkata:
Dialogue: 0,0:15:21.03,0:15:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tertawalah. Rayakanlah."
Dialogue: 0,0:15:24.53,0:15:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Entah mekar atau tidak,\Nketika kuncup menghadap ke atas,
Dialogue: 0,0:15:28.98,0:15:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bunganya akan tetap mekar di surga."
Dialogue: 0,0:15:34.68,0:15:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak nyawa melayang\Ndalam tragedi Terminalia.
Dialogue: 0,0:15:40.08,0:15:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antaranya adalah profesor kami.
Dialogue: 0,0:15:42.58,0:15:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pula para siswa.
Dialogue: 0,0:15:46.03,0:15:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai dari para penyihir senior,
Dialogue: 0,0:15:48.15,0:15:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya menyampaikan belasungkawa\Ndan rasa hormat yang paling dalam
Dialogue: 0,0:15:51.15,0:15:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepada semua orang yang berkorban\Ndemi melindungi rakyat.
Dialogue: 0,0:15:55.60,0:16:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat yang sama, kita juga harus\Nmengakhiri masa keterpurukan ini.
Dialogue: 0,0:16:00.61,0:16:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak berhasil mengancam menara,\Nmungkin tragedi itu bukanlah akhir,
Dialogue: 0,0:16:05.88,0:16:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melainkan lonceng\Npenanda permulaan bencana.
Dialogue: 0,0:16:10.58,0:16:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita wajib meneruskan harapan\Nyang telah dipupuk ke masa depan.
Dialogue: 0,0:16:16.68,0:16:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai upacara kelulusan\NAkademi Sihir Rigarden.
Dialogue: 0,0:16:24.53,0:16:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa kelas 401, berdiri.
Dialogue: 0,0:16:28.00,0:16:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbaris di depan panggung.
Dialogue: 0,0:16:30.01,0:16:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para lulusan terpanggil\Ndipersilakan menerima ijazah.
Dialogue: 0,0:16:40.58,0:16:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agnes Houqes.
Dialogue: 0,0:16:43.85,0:16:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ardence Ritchie.
Dialogue: 0,0:16:46.75,0:16:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Austin Lott.
Dialogue: 0,0:16:50.50,0:16:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort.
Dialogue: 0,0:16:53.55,0:16:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Valerie Raiss.
Dialogue: 0,0:16:56.30,0:16:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zara Orbrand.
Dialogue: 0,0:16:59.04,0:17:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zera Orbrand.
Dialogue: 0,0:17:02.00,0:17:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zoe Garniga.
Dialogue: 0,0:17:07.05,0:17:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian, 250 siswa.
Dialogue: 0,0:17:09.53,0:17:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka telah menyelesaikan semua\Nmata pelajaran Akademi Sihir Rigarden,
Dialogue: 0,0:17:12.93,0:17:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dinyatakan lulus.
Dialogue: 0,0:17:19.95,0:17:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan terakhir,
Dialogue: 0,0:17:21.81,0:17:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami akan umumkan siswa\Nyang berhak pergi ke menara.
Dialogue: 0,0:17:25.03,0:17:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika namanya dipanggil,\Nsilakan naik ke panggung.
Dialogue: 0,0:17:28.50,0:17:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan memberikan topi Mercedes
Dialogue: 0,0:17:30.90,0:17:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai tanda bahwa kalian\Ndiizinkan memanjat menara.
Dialogue: 0,0:17:34.83,0:17:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimulai dari posisi pertama.
Dialogue: 0,0:17:37.08,0:17:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihanna Owenzaus.
Dialogue: 0,0:17:51.63,0:17:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisi kedua.
Dialogue: 0,0:17:53.30,0:17:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wignall Lindor.
Dialogue: 0,0:17:56.35,0:17:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius Reinberg.
Dialogue: 0,0:17:59.90,0:18:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion Ulster.
Dialogue: 0,0:18:03.15,0:18:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emma Clever.
Dialogue: 0,0:18:05.73,0:18:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renaisse Arette.
Dialogue: 0,0:18:08.60,0:18:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette Loire.
Dialogue: 0,0:18:11.35,0:18:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rose Prehnite.
Dialogue: 0,0:18:14.25,0:18:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jorua Moraine.
Dialogue: 0,0:18:17.20,0:18:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gordon Valley.
Dialogue: 0,0:18:19.88,0:18:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lyril Mars.
Dialogue: 0,0:18:23.08,0:18:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka adalah 49 siswa\Nyang diizinkan memanjat menara
Dialogue: 0,0:18:27.25,0:18:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena berhasil mengumpulkan kredit\Nyang diperlukan.
Dialogue: 0,0:18:33.85,0:18:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Elfie.
Dialogue: 0,0:18:36.39,0:18:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, masih ada satu siswa
Dialogue: 0,0:18:39.80,0:18:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang berhasil memenuhi syarat lain\Ndi saat-saat terakhir.
Dialogue: 0,0:18:48.27,0:18:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat memasuki menara ada dua.
Dialogue: 0,0:18:51.35,0:18:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama adalah mengumpulkan\N7.200 kredit.
Dialogue: 0,0:18:54.95,0:18:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua adalah menemukan sihir baru.
Dialogue: 0,0:18:59.60,0:19:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan sihir tersebut,\Ndia menghalau keputusasaan,
Dialogue: 0,0:19:03.98,0:19:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melindungi banyak orang\Nsaat menyelamatkan ibu kota.
Dialogue: 0,0:19:09.29,0:19:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pencapaian tersebut sangat membanggakan.
Dialogue: 0,0:19:12.08,0:19:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prestasi yang patut dipuji.
Dialogue: 0,0:19:14.80,0:19:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama sihirnya adalah
Dialogue: 0,0:19:17.78,0:19:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"keberanian".
Dialogue: 0,0:19:21.93,0:19:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort.
Dialogue: 0,0:19:24.13,0:19:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah.
Dialogue: 0,0:19:26.19,0:19:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Akademi!
Dialogue: 0,0:19:28.48,0:19:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada orang-orang\Nyang keberatan dengan ini.
Dialogue: 0,0:19:30.98,0:19:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, bagi siapa pun\Nyang mengakui keberaniannya
Dialogue: 0,0:19:33.78,0:19:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai salah satu bentuk sihir,
Dialogue: 0,0:19:35.74,0:19:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sambutlah dia dengan tepuk tangan meriah!
Dialogue: 0,0:20:31.80,0:20:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed, biarkan saja.
Dialogue: 0,0:20:34.08,0:20:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa!
Dialogue: 0,0:20:35.93,0:20:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa menunjukkan impian indah\Njika akhirnya hanya menjatuhkan?!
Dialogue: 0,0:20:40.83,0:20:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus dibuat\Nbernasib sama sepertiku?
Dialogue: 0,0:20:45.48,0:20:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti bisa melampauinya.
Dialogue: 0,0:20:47.60,0:20:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah ditempa habis-habisan\Noleh profesor yang seram tapi baik.
Dialogue: 0,0:20:55.95,0:20:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang serakah, Caldron.
Dialogue: 0,0:20:58.38,0:21:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini saatnya memacu pedang\Nuntuk mencari pemandangan baru.
Dialogue: 0,0:21:03.12,0:21:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian, 50 siswa.
Dialogue: 0,0:21:05.38,0:21:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan persetujuan bulat\Ndari para hadirin terhormat,
Dialogue: 0,0:21:08.15,0:21:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami menyetujui kenaikan mereka ke menara.
Dialogue: 0,0:21:11.98,0:21:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian adalah generasi penuh cobaan.
Dialogue: 0,0:21:14.43,0:21:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan mengalami pergolakan\Ndan cobaan yang datang silih berganti.
Dialogue: 0,0:21:20.28,0:21:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku berdoa
Dialogue: 0,0:21:22.50,0:21:26.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semoga kalian menggapai langit\Ndan mengusir sumber kejahatan!
Dialogue: 0,0:21:31.93,0:21:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, ya, Will.
Dialogue: 0,0:21:35.78,0:21:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Upacara kelulusan telah usai.
Dialogue: 0,0:21:38.40,0:21:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir baru akan datang ke menara...
Dialogue: 0,0:21:42.70,0:21:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria?
Dialogue: 0,0:21:45.18,0:21:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggumu, Will.
Dialogue: 0,0:21:49.53,0:21:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun 506, di Era Sihir.
Dialogue: 0,0:21:52.68,0:21:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun yang kelak dikenal sebagai\N"Tahun Harapan dan Kehilangan" ini
Dialogue: 0,0:21:57.15,0:21:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan segera dimulai.
Dialogue: 0,0:23:36.55,0:23:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.40,0:23:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode delapan belas: "First Bloom".
