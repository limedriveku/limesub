Dialogue: 0,0:00:00.00,0:00:02.98,sign,,0000,0000,0000,,TAMAN DI KEDIAMAN REINBERG
Dialogue: 0,0:00:32.00,0:00:36.73,sign,,0000,0000,0000,,EPISODE 20: BIMBINGAN WANITA SIHIR
Dialogue: 0,0:01:41.01,0:01:45.59,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:01:47.83,0:01:51.01,sign,,0000,0000,0000,,LANTAI PERTAMA MENARA, UJUNG TIMUR,\NPADANG RUMPUT SEPI
Dialogue: 0,0:05:08.48,0:05:09.23,sign,,0000,0000,0000,,LIGHSNOW
Dialogue: 0,0:05:17.80,0:05:18.54,sign,,0000,0000,0000,,ANNA EIRUS
Dialogue: 0,0:06:23.80,0:06:27.12,sign,,0000,0000,0000,,"LANTAI PERTAMA MENARA, KAWASAN HUNIAN"
Dialogue: 0,0:06:48.33,0:06:50.51,sign,,0000,0000,0000,,LANTAI PERTAMA MENARA,\NISTANA TERAPUNG NO. 1, BALNEY
Dialogue: 0,0:06:52.87,0:06:53.52,sign,,0000,0000,0000,,RUANG PENELITIAN KREUTZ
Dialogue: 0,0:06:58.02,0:06:59.33,sign,,0000,0000,0000,,KEPALA INSTITUT TINGGI\NDAN KETUA FAKSI TANPA WARNA
Dialogue: 0,0:06:59.33,0:07:00.27,sign,,0000,0000,0000,,KREUTZ HARLON
Dialogue: 0,0:07:24.33,0:07:25.72,sign,,0000,0000,0000,,"TONY HARVEY"
Dialogue: 0,0:07:29.63,0:07:32.30,sign,,0000,0000,0000,,"MARY LAW DAN AURON CHEEK"
Dialogue: 0,0:11:24.35,0:11:26.47,sign,,0000,0000,0000,,"CERRIDWEN"
Dialogue: 0,0:11:33.05,0:11:34.50,sign,,0000,0000,0000,,TONGKAT SIHIR KUALI KACAU,\NSAPU GOUVION
Dialogue: 0,0:11:34.50,0:11:38.05,sign,,0000,0000,0000,,CERRIDWEN
Dialogue: 0,0:11:38.05,0:11:39.55,sign,,0000,0000,0000,,TONGKAT SIHIR KEGELAPAN SEPI
Dialogue: 0,0:11:39.55,0:11:43.06,sign,,0000,0000,0000,,CHARLES LAUER
Dialogue: 0,0:12:51.40,0:12:52.40,sign,,0000,0000,0000,,"MERCEDES CAULIS"
Dialogue: 0,0:12:55.64,0:12:57.13,sign,,0000,0000,0000,,"KAMAR PRIBADI ELFARIA"
Dialogue: 0,0:12:57.43,0:12:59.92,sign,,0000,0000,0000,,"WATCHER, IRIS CHURCHILL"
Dialogue: 0,0:14:38.58,0:14:40.48,sign,,0000,0000,0000,,LANTAI SATU MENARA, DI SUATU TEMPAT
Dialogue: 0,0:14:52.10,0:14:54.00,sign,,0000,0000,0000,,RUMAH PERSEMBUNYIAN CLAIRIE
Dialogue: 0,0:18:23.93,0:18:24.41,sign,,0000,0000,0000,,AJUDAN KEPALA INSTITUT TINGGI,\NCHARLES LAUER
Dialogue: 0,0:23:28.04,0:23:30.99,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:43.83,0:23:48.25,sign,,0000,0000,0000,,EPISODE 21: HALAMAN YANG DIBALIK
Dialogue: 0,0:00:03.45,0:00:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu suka aku\Nyang seperti ini, Anna?
Dialogue: 0,0:00:07.55,0:00:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:08.98,0:00:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang, termasuk saya,
Dialogue: 0,0:00:11.33,0:00:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat menyukai Tuan Muda Julius\Nyang baik hati.
Dialogue: 0,0:01:58.93,0:02:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berapa kali ini?!
Dialogue: 0,0:02:01.23,0:02:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menghancurkan guardian-ku lagi.
Dialogue: 0,0:02:03.05,0:02:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak berkembang sama sekali.
Dialogue: 0,0:02:05.45,0:02:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak energi sihir\Nyang harus kubuang untukmu?!
Dialogue: 0,0:02:07.94,0:02:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf!
Dialogue: 0,0:02:09.65,0:02:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tekan daya keluarannya,\Ntapi aku hanya bisa bertahan 50 menit.
Dialogue: 0,0:02:13.45,0:02:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, energi sihirnya akan buyar.
Dialogue: 0,0:02:16.10,0:02:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi,
Dialogue: 0,0:02:17.43,0:02:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}begitu Wis-nya menghilang,\Nstaminaku juga ikut terkuras.
Dialogue: 0,0:02:21.98,0:02:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada kelemahan seperti ini.
Dialogue: 0,0:02:24.38,0:02:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dilanjutkan, kami hanya\Nakan membuang-buang waktu.
Dialogue: 0,0:02:27.96,0:02:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi!
Dialogue: 0,0:02:31.10,0:02:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa?! Bersiaplah!
Dialogue: 0,0:02:33.65,0:02:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius!
Dialogue: 0,0:02:35.03,0:02:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita menyelidiki Wis dulu.
Dialogue: 0,0:02:39.35,0:02:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga belum memahami kekuatan ini.
Dialogue: 0,0:02:43.98,0:02:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memeriksa\Nhampir semua buku di akademi,
Dialogue: 0,0:02:46.63,0:02:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak menemukan petunjuk.
Dialogue: 0,0:02:48.85,0:02:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Pak Workner tahu sesuatu,
Dialogue: 0,0:02:51.73,0:02:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi beliau tidak memahami\Ncara kerjanya.
Dialogue: 0,0:02:54.98,0:02:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini agak lama, tapi kita harus\Nminta bantuan penyihir senior
Dialogue: 0,0:02:57.80,0:03:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar kita bisa memeriksa arsip menara,
Dialogue: 0,0:03:00.05,0:03:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau mencari seseorang\Nyang tahu sesuatu.
Dialogue: 0,0:03:02.66,0:03:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melakukan semua itu!
Dialogue: 0,0:03:06.70,0:03:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengirim klonaku\Nke perpustakaan Institut Tinggi,
Dialogue: 0,0:03:10.30,0:03:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ke tempat Bu Eliza\Nuntuk meminta bantuannya
Dialogue: 0,0:03:12.65,0:03:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencari orang dari Klan Finn\Nyang mungkin tahu sesuatu!
Dialogue: 0,0:03:18.25,0:03:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ars Weiss jarak jauh?
Dialogue: 0,0:03:20.38,0:03:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kamu bisa\Nmelakukannya sendirian?
Dialogue: 0,0:03:22.26,0:03:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak punya waktu!
Dialogue: 0,0:03:24.58,0:03:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan dan mengumpulkan info!
Dialogue: 0,0:03:26.25,0:03:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya harus dilakukan bersamaan!
Dialogue: 0,0:03:31.73,0:03:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sialan.
Dialogue: 0,0:03:33.15,0:03:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikiranku jadi kacau-balau\Nkarena punya tiga sudut pandang.
Dialogue: 0,0:03:36.93,0:03:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci melakukan\Nbanyak hal bersamaan.
Dialogue: 0,0:03:39.80,0:03:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu berusaha sejauh itu\Nuntuk membantuku?
Dialogue: 0,0:03:44.03,0:03:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku punya niat tersembunyi!
Dialogue: 0,0:03:46.28,0:03:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarlah!
Dialogue: 0,0:03:48.10,0:03:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai penyihir Reinberg,\Naku pasti akan mencapai puncak!
Dialogue: 0,0:03:52.04,0:03:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memanfaatkanmu untuk itu!
Dialogue: 0,0:03:54.58,0:03:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian,
Dialogue: 0,0:03:56.38,0:03:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang bangsawan\Ntidak akan mengingkari janji.
Dialogue: 0,0:03:59.13,0:04:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu alasannya.
Dialogue: 0,0:04:02.15,0:04:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar,\Nsetelah Festival Sihir Agung,
Dialogue: 0,0:04:05.70,0:04:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius tetap menjaga janjinya\Nterhadap Pak Donnan dan yang lain.
Dialogue: 0,0:04:12.63,0:04:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, kamu memang baik.
Dialogue: 0,0:04:16.60,0:04:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:04:18.05,0:04:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap orang memiliki\Ncara mengungkapkan kebaikan.
Dialogue: 0,0:04:22.40,0:04:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebaikan Colette\Nyang diungkapkan lewat bantuannya
Dialogue: 0,0:04:24.95,0:04:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berbeda dengan kebaikan Pak Workner\Nyang diungkapkan melalui omelannya.
Dialogue: 0,0:04:28.85,0:04:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Sion juga punya cara sendiri\Nuntuk mengungkapkan kebaikan.
Dialogue: 0,0:04:32.88,0:04:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski itu karena Noblesse Oblige\Natau kewajiban seorang bangsawan,
Dialogue: 0,0:04:36.09,0:04:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, kamu sangat hebat\Ndan baik.
Dialogue: 0,0:04:41.53,0:04:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda sangat baik, Tuan Muda Julius.
Dialogue: 0,0:04:46.88,0:04:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bicara apa?!
Dialogue: 0,0:04:48.93,0:04:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar menjijikkan.
Dialogue: 0,0:04:51.53,0:04:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau istirahat dulu.
Dialogue: 0,0:04:53.36,0:04:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!\NAku akan berusaha sedikit lagi.
Dialogue: 0,0:04:57.05,0:04:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Julius!
Dialogue: 0,0:05:01.90,0:05:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebaikan apanya?
Dialogue: 0,0:05:04.60,0:05:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh kebaikan.
Dialogue: 0,0:05:09.28,0:05:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak apa-apa.
Dialogue: 0,0:05:18.60,0:05:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda sangat baik, Tuan Muda Julius.
Dialogue: 0,0:05:21.63,0:05:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:05:23.10,0:05:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menolong kaum lemah\Nadalah kewajiban bangsawan.
Dialogue: 0,0:05:36.00,0:05:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu suka aku\Nyang seperti ini, Anna?
Dialogue: 0,0:05:39.80,0:05:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:41.18,0:05:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang, termasuk saya,\Nsangat menyukai Tuan Muda Julius
Dialogue: 0,0:05:46.33,0:05:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang baik hati.
Dialogue: 0,0:05:52.63,0:05:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong!
Dialogue: 0,0:05:55.58,0:05:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah sebaik apa pun aku,
Dialogue: 0,0:05:57.83,0:06:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya kau tidak bisa menjadi milikku.
Dialogue: 0,0:06:09.60,0:06:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nlebih baik kubuang kebaikan itu.
Dialogue: 0,0:06:12.63,0:06:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi egois adalah pilihan cerdas.
Dialogue: 0,0:06:15.50,0:06:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamer bakat di mana-mana,\Nmemanfaatkan orang sesuka hati,
Dialogue: 0,0:06:19.20,0:06:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengejek orang-orang lemah,
Dialogue: 0,0:06:21.30,0:06:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membanggakan keunggulanku.
Dialogue: 0,0:06:23.80,0:06:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, kamu sangat hebat dan baik.
Dialogue: 0,0:06:29.33,0:06:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membicarakan kebaikan\Ndengan mata yang sama seperti Anna.
Dialogue: 0,0:06:33.25,0:06:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh kebaikan.
Dialogue: 0,0:06:36.78,0:06:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius Reinberg\Nyang hanya tahu kebaikan itu
Dialogue: 0,0:06:39.80,0:06:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah kubunuh sejak lama.
Dialogue: 0,0:06:51.00,0:06:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjuangan yang sia-sia.
Dialogue: 0,0:06:53.80,0:06:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Charles, cepat hubungi\Norang-orang Tanpa Warna.
Dialogue: 0,0:06:57.08,0:06:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:07:06.91,0:07:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, sialan!\NTempat ini seperti labirin.
Dialogue: 0,0:07:13.45,0:07:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frall!
Dialogue: 0,0:07:18.75,0:07:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian...
Dialogue: 0,0:07:20.58,0:07:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Institut Tinggi?!
Dialogue: 0,0:07:22.08,0:07:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dapat perintah dari atasan.
Dialogue: 0,0:07:24.33,0:07:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami disuruh menghajar
Dialogue: 0,0:07:25.72,0:07:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para pengacau yang bertindak seenaknya\Ndi taman ini.
Dialogue: 0,0:07:29.63,0:07:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya kalian tidak bisa melakukan latihan bodoh.
Dialogue: 0,0:07:33.00,0:07:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian ingin menghalangi kami?!
Dialogue: 0,0:07:35.23,0:07:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar kami tidak lolos\Npemekaran berikutnya.
Dialogue: 0,0:07:38.83,0:07:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir menara macam apa kalian?!
Dialogue: 0,0:07:44.38,0:07:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak mungkin mengerti!
Dialogue: 0,0:07:46.43,0:07:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menanggung malu\Nkarena harus berhenti di sini
Dialogue: 0,0:07:48.63,0:07:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diejek sebagai\Nfiguran tak berwarna!
Dialogue: 0,0:07:52.87,0:07:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau menjadi\Npenggerak menara terus!
Dialogue: 0,0:07:56.28,0:07:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kreutz sudah berjanji!
Dialogue: 0,0:07:58.38,0:07:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kami menghancurkan kalian,
Dialogue: 0,0:07:59.95,0:08:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau akan mengirimkan\Nsurat rekomendasi ke setiap faksi!
Dialogue: 0,0:08:05.60,0:08:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil dari persaingan ketat di menara.
Dialogue: 0,0:08:08.05,0:08:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para tongkat sihir menyedihkan
Dialogue: 0,0:08:10.09,0:08:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang rela buang harga diri\Ndemi keluar dari makam ini.
Dialogue: 0,0:08:13.03,0:08:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mereka tetap penyihir senior.
Dialogue: 0,0:08:18.00,0:08:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi sihirku sudah kering\Nkarena aku terlalu berlebihan
Dialogue: 0,0:08:20.68,0:08:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengeluarkan guardian\Ndan menggunakan Ars Weiss.
Dialogue: 0,0:08:23.11,0:08:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kalah jumlah.
Dialogue: 0,0:08:26.48,0:08:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:08:29.88,0:08:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Tony yang cuma setahun di atasku.
Dialogue: 0,0:08:32.45,0:08:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mary yang sombongnya setinggi langit.
Dialogue: 0,0:08:34.70,0:08:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Auron si junior kecil\Nyang belagunya minta ampun.
Dialogue: 0,0:08:37.98,0:08:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menciptakan sihir baru,\Nkalian dapat jalur spesial ke menara,
Dialogue: 0,0:08:41.79,0:08:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kenapa kalian terpuruk di sini,\Norang-orang genius di masa lalu?!
Dialogue: 0,0:08:45.63,0:08:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyedihkan!
Dialogue: 0,0:08:47.38,0:08:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian diperas Institut Tinggi\Nsampai kering!
Dialogue: 0,0:08:49.58,0:08:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski harus mati, aku tidak mau\Nmenjadi sapi kering seperti kalian!
Dialogue: 0,0:08:54.23,0:08:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tidak direkrut, kan?!
Dialogue: 0,0:08:58.05,0:08:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa matamu buta?
Dialogue: 0,0:09:00.35,0:09:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah Julius Reinberg!
Dialogue: 0,0:09:03.15,0:09:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memanfaatkan semua orang,\Ntermasuk Nol Besar tanpa bakat sihir itu!
Dialogue: 0,0:09:07.33,0:09:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memanjat menara\Ndan menjadi penerus Nona Elfaria!
Dialogue: 0,0:09:12.13,0:09:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,
Dialogue: 0,0:09:16.68,0:09:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari titik tertinggi menara,
Dialogue: 0,0:09:18.13,0:09:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan meremehkan orang-orang\Nyang pernah meninggalkanku!
Dialogue: 0,0:09:20.98,0:09:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi tujuan itu, aku akan\Nmemanfaatkan Magia Vander!
Dialogue: 0,0:09:23.93,0:09:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi sayangnya,
Dialogue: 0,0:09:25.50,0:09:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku cuma bertemu orang-orang\Nyang tidak berguna seperti kalian!
Dialogue: 0,0:09:28.58,0:09:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius!
Dialogue: 0,0:09:29.55,0:09:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membencimu\Nsejak di akademi!
Dialogue: 0,0:09:32.35,0:09:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah!
Dialogue: 0,0:09:35.33,0:09:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Aku tidak baik.
Dialogue: 0,0:09:38.78,0:09:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya adalah keberadaan\Norang-orang yang membenciku ini.
Dialogue: 0,0:09:43.93,0:09:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah ini, Anna.
Dialogue: 0,0:09:45.85,0:09:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak ada kebaikan\Ndi dalam diriku.
Dialogue: 0,0:09:56.80,0:09:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu baik-baik saja, Julius?!
Dialogue: 0,0:09:58.29,0:10:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat!
Dialogue: 0,0:10:03.73,0:10:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau... kenapa?
Dialogue: 0,0:10:06.00,0:10:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tiba-tiba diserang penyihir senior.
Dialogue: 0,0:10:08.10,0:10:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut kamu diserang juga,\Njadi, aku mencarimu bersama Kiki.
Dialogue: 0,0:10:12.73,0:10:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menolongku?!
Dialogue: 0,0:10:15.18,0:10:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:16.15,0:10:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kan kita saling menolong\Nsaat menjalani Praksis Akbar dulu.
Dialogue: 0,0:10:19.78,0:10:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sekarang pun,\Nkamu masih membantuku.
Dialogue: 0,0:10:22.18,0:10:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau masih belum sadar?!\NAku mempermalukanmu di festival!
Dialogue: 0,0:10:26.30,0:10:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya niat tersembunyi!
Dialogue: 0,0:10:27.93,0:10:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya memanfaatkanmu!
Dialogue: 0,0:10:29.45,0:10:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kau...
Dialogue: 0,0:10:30.94,0:10:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bodoh?!
Dialogue: 0,0:10:33.93,0:10:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:35.30,0:10:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mudah menyukai orang\Nyang baik kepadaku.
Dialogue: 0,0:10:38.30,0:10:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang bodoh.
Dialogue: 0,0:10:40.13,0:10:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang, termasuk saya,
Dialogue: 0,0:10:42.10,0:10:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat menyukai Tuan Muda Julius\Nyang baik hati.
Dialogue: 0,0:10:48.10,0:10:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:10:49.59,0:10:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?! Kenapa kamu memukulku?!\N- Sakit!
Dialogue: 0,0:10:54.38,0:10:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membencimu!
Dialogue: 0,0:10:55.47,0:10:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat membencimu!
Dialogue: 0,0:10:58.26,0:11:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka?
Dialogue: 0,0:11:00.70,0:11:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peduli amat!
Dialogue: 0,0:11:01.83,0:11:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan mereka!
Dialogue: 0,0:11:04.02,0:11:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, mundurlah!
Dialogue: 0,0:11:05.50,0:11:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyuruhku!
Dialogue: 0,0:11:13.48,0:11:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir tidak boleh dipakai seperti itu.
Dialogue: 0,0:11:16.43,0:11:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian tidak diajari di akademi?
Dialogue: 0,0:11:21.95,0:11:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:11:24.35,0:11:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Cerridwen.
Dialogue: 0,0:11:26.48,0:11:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kalian menunjukkan\Nmomen masa muda yang indah,
Dialogue: 0,0:11:29.00,0:11:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku boleh berterima kasih\Ndengan menjadi guru kalian?
Dialogue: 0,0:11:43.53,0:11:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Cerridwen.
Dialogue: 0,0:11:45.48,0:11:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kalian menunjukkan\Nmomen masa muda yang indah,
Dialogue: 0,0:11:48.06,0:11:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku boleh berterima kasih\Ndengan menjadi guru kalian?
Dialogue: 0,0:11:52.05,0:11:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerridwen?
Dialogue: 0,0:11:53.35,0:11:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu!\NAku tahu nama itu.
Dialogue: 0,0:11:56.70,0:12:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu dari tujuh misteri akademi\Nyang sebanding dengan Watcher.
Dialogue: 0,0:12:00.28,0:12:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah Wanita Sihir Palu Besi
Dialogue: 0,0:12:02.03,0:12:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menculik siswa tiap malam\Nuntuk dijadikan kelinci percobaan.
Dialogue: 0,0:12:06.28,0:12:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak melakukan hal seseram itu.
Dialogue: 0,0:12:09.00,0:12:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mencari siswa menarik\Nuntuk melatih dan membimbing mereka.
Dialogue: 0,0:12:14.33,0:12:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kalian sekarang.
Dialogue: 0,0:12:17.34,0:12:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melatih dan membimbing?
Dialogue: 0,0:12:20.15,0:12:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua?
Dialogue: 0,0:12:21.47,0:12:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yap.
Dialogue: 0,0:12:22.53,0:12:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kalian tidak tahu,
Dialogue: 0,0:12:24.00,0:12:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku sudah mengawasi kalian\Nsejak lama.
Dialogue: 0,0:12:27.73,0:12:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengawasi kami sejak lama?
Dialogue: 0,0:12:29.90,0:12:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah\Nbertemu wanita seperti—
Dialogue: 0,0:12:37.23,0:12:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritanya nanti saja.\NAyo pindah tempat dulu.
Dialogue: 0,0:12:41.08,0:12:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti antek-antek Institut Tinggi\Nkeburu datang.
Dialogue: 0,0:12:44.85,0:12:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udah, deh!\NMenurut dan pasrah saja!
Dialogue: 0,0:12:51.40,0:12:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Anda
Dialogue: 0,0:12:52.40,0:12:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak memberi berkah kepada Julius Reinberg,
Dialogue: 0,0:12:55.64,0:12:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria?
Dialogue: 0,0:12:57.43,0:12:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika orang sehebat dia ditelantarkan begitu saja,
Dialogue: 0,0:12:59.93,0:13:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Watcher seperti saya\Ntidak bisa tinggal diam.
Dialogue: 0,0:13:03.63,0:13:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, dia bilang mau membuka\Nsemua rahasiaku dengan nada mesum,
Dialogue: 0,0:13:08.23,0:13:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia kerap merundung Will.
Dialogue: 0,0:13:11.75,0:13:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:13:12.90,0:13:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara dia, aibku diketahui\Nsemua orang di akademi!
Dialogue: 0,0:13:18.23,0:13:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya karena dendam pribadi, ya?
Dialogue: 0,0:13:21.00,0:13:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, bukankah Kak Will\Nyang membocorkannya?
Dialogue: 0,0:13:24.45,0:13:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tauk, ah!
Dialogue: 0,0:13:27.93,0:13:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iris.
Dialogue: 0,0:13:29.33,0:13:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa pendapat Tuan Aaron\Ntentang Will?
Dialogue: 0,0:13:34.05,0:13:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau hanya berkata,\Nakan mengikuti takdir.
Dialogue: 0,0:13:37.55,0:13:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Aaron berbeda dari Bu Caldron\Ndan tidak sepenuhnya menyambut baik
Dialogue: 0,0:13:42.90,0:13:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keberadaan pedang\Ndi antara tongkat sihir.
Dialogue: 0,0:13:46.03,0:13:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika si pedang\Nmembuka jalannya sendiri,
Dialogue: 0,0:13:49.05,0:13:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau akan mengakui\Ntekad dan kekuatannya.
Dialogue: 0,0:13:53.83,0:13:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort.
Dialogue: 0,0:13:55.55,0:13:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemunculan Wis\Nmemecah kebijakan menara.
Dialogue: 0,0:13:59.32,0:14:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari awal, apa itu Wis?
Dialogue: 0,0:14:02.45,0:14:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih belum memahaminya.
Dialogue: 0,0:14:05.43,0:14:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang bisa membalikkan dunia.
Dialogue: 0,0:14:07.90,0:14:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah penyimpangan.
Dialogue: 0,0:14:10.43,0:14:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak enak kepada Nona Elfaria,
Dialogue: 0,0:14:12.53,0:14:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku pun tidak tahu\Ncara menangani pemuda itu.
Dialogue: 0,0:14:15.71,0:14:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, apabila situasinya\Nmulai memberatkan Kak Will,
Dialogue: 0,0:14:19.25,0:14:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya akan melindunginya\Nsebagai salah satu Watcher,
Dialogue: 0,0:14:22.10,0:14:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, tenang saja.
Dialogue: 0,0:14:23.90,0:14:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya boleh bermimpi\Nsaat tidur saja, Kucing Pencuri.
Dialogue: 0,0:14:31.33,0:14:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin menara ini bisa terbelah\Ngara-gara pemuda itu.
Dialogue: 0,0:14:36.75,0:14:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kita sampai.
Dialogue: 0,0:14:45.10,0:14:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di rumah nona sihir.
Dialogue: 0,0:14:50.38,0:14:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduklah di mana saja.
Dialogue: 0,0:15:10.63,0:15:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari kita makan dulu!
Dialogue: 0,0:15:13.25,0:15:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masak sendiri, lo!
Dialogue: 0,0:15:15.35,0:15:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sudi menyantap\Nhidangan wanita sihir—
Dialogue: 0,0:15:17.48,0:15:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan!
Dialogue: 0,0:15:19.55,0:15:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dimakan!
Dialogue: 0,0:15:21.03,0:15:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiki tidak merasakan bahaya, kok.\NTenang saja.
Dialogue: 0,0:15:25.85,0:15:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari awal, sebenarnya tempat apa ini?
Dialogue: 0,0:15:29.75,0:15:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempat persembunyian lantai satu\Nyang dibuat Clairie secara diam-diam.
Dialogue: 0,0:15:34.25,0:15:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah minta izin\Nuntuk menggunakannya.
Dialogue: 0,0:15:37.30,0:15:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Clairie?
Dialogue: 0,0:15:38.92,0:15:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Gadis itu adalah muridku.
Dialogue: 0,0:15:42.25,0:15:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:15:44.08,0:15:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku tidak meragukannya.
Dialogue: 0,0:15:46.68,0:15:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelakuan bodoh orang itu\Nditurunkan dari gurunya, ya?
Dialogue: 0,0:15:50.88,0:15:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang kau rencanakan\Ndengan memanfaatkan si bodoh ini?
Dialogue: 0,0:15:56.18,0:16:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, dia adalah penolong kita\Nsekaligus gurunya Nona Clairie—
Dialogue: 0,0:16:02.00,0:16:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajarlah mencurigai orang!
Dialogue: 0,0:16:05.15,0:16:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa saja dia pembunuh\Nyang dikirim Institut Tinggi.
Dialogue: 0,0:16:09.38,0:16:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tidak begitu,
Dialogue: 0,0:16:10.90,0:16:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mana ada penyihir berilmu tinggi\Nyang memberikan bimbingan gratis!
Dialogue: 0,0:16:14.78,0:16:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita akan\Ndijadikan kelinci percobaan
Dialogue: 0,0:16:16.85,0:16:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti rumor tujuh misteri itu!
Dialogue: 0,0:16:21.98,0:16:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah juga, ya.
Dialogue: 0,0:16:23.53,0:16:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kewaspadaan memang\Nbukti seorang penyihir unggul.
Dialogue: 0,0:16:28.10,0:16:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:16:34.70,0:16:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakan sihir berjumlah banyak?!
Dialogue: 0,0:16:37.13,0:16:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebanyak ini dalam sekejap,\Ntanpa merapal mantra sihir?
Dialogue: 0,0:16:40.43,0:16:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengaktifannya terlalu cepat.
Dialogue: 0,0:16:42.43,0:16:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir dari semua atribut, kecuali cahaya.
Dialogue: 0,0:16:45.00,0:16:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita ini adalah multos\Natau pengguna multiatribut.
Dialogue: 0,0:16:48.90,0:16:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku mau, kalian berdua
Dialogue: 0,0:16:52.88,0:16:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa kukalahkan dalam dua detik.
Dialogue: 0,0:16:56.53,0:17:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak bisa menjadi bukti,\Ntapi apa ini bisa meyakinkan kalian?
Dialogue: 0,0:17:01.25,0:17:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku memiliki niat jahat,\Nkalian sudah dimakan nona sihir seram.
Dialogue: 0,0:17:09.93,0:17:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, katakan semuanya!\NApa tujuanmu yang sebenarnya?
Dialogue: 0,0:17:13.89,0:17:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tidak bicara,
Dialogue: 0,0:17:15.15,0:17:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak boleh\Nmenjadi guru anak bodoh ini!
Dialogue: 0,0:17:18.45,0:17:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius...
Dialogue: 0,0:17:20.07,0:17:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan senang dulu!\NAkulah yang akan memanfaatkanmu!
Dialogue: 0,0:17:23.65,0:17:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma protes karena tidak terima
Dialogue: 0,0:17:26.00,0:17:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika kau dimanfaatkan orang lain!
Dialogue: 0,0:17:27.65,0:17:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah baik-baik!\NAku tidak mengenal kebaikan!
Dialogue: 0,0:17:32.88,0:17:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:17:35.75,0:17:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama,
Dialogue: 0,0:17:37.60,0:17:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku memiliki sedikit pengetahuan\Ntentang Wis.
Dialogue: 0,0:17:42.93,0:17:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku bisa membantu.
Dialogue: 0,0:17:45.58,0:17:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah alasan pertamaku.
Dialogue: 0,0:17:49.05,0:17:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua,
Dialogue: 0,0:17:50.93,0:17:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada pergerakan dari Institut Tinggi.
Dialogue: 0,0:17:52.63,0:17:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendeteksi pihak\Nyang ingin menekanmu, Will,
Dialogue: 0,0:17:55.55,0:17:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan cara yang tidak baik.
Dialogue: 0,0:17:59.65,0:18:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Institut Tinggi?
Dialogue: 0,0:18:01.68,0:18:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, orang itu?
Dialogue: 0,0:18:06.03,0:18:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort menghilang?!
Dialogue: 0,0:18:08.58,0:18:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Bersama Julius Reinberg.
Dialogue: 0,0:18:11.60,0:18:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut laporan, ada seseorang\Nyang membantu mereka.
Dialogue: 0,0:18:14.75,0:18:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat cari secara menyeluruh!
Dialogue: 0,0:18:17.20,0:18:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menemukan residu sihir\Nyang menandakan kepergian mereka.
Dialogue: 0,0:18:21.15,0:18:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti bersembunyi\Ndi suatu tempat.
Dialogue: 0,0:18:24.48,0:18:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa saya boleh bertanya?
Dialogue: 0,0:18:27.30,0:18:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Anda ingin\Nmenjatuhkan Will Serfort
Dialogue: 0,0:18:30.00,0:18:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai berani memicu amarah\NNona Elfaria?
Dialogue: 0,0:18:32.98,0:18:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan sebagus itu tidak boleh\Ndikuasai faksi penggila perang.
Dialogue: 0,0:18:37.78,0:18:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wis itu harus dimanfaatkan\Nsecara efisien dan tanpa sisa.
Dialogue: 0,0:18:46.40,0:18:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti Pembunuh Penyihir ini.
Dialogue: 0,0:18:49.90,0:18:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah organisasi mana\Nyang membuatnya,
Dialogue: 0,0:18:52.70,0:18:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kekuatannya luar biasa.
Dialogue: 0,0:18:55.11,0:18:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang bisa diperbanyak\Ndan dipakai monster tanpa kecerdasan.
Dialogue: 0,0:18:58.87,0:19:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persenjataan unggul yang bisa\Nmemperkuat penyihir tak berbakat.
Dialogue: 0,0:19:03.04,0:19:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang harus kita capai.
Dialogue: 0,0:19:06.68,0:19:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan adalah jumlah.
Dialogue: 0,0:19:08.33,0:19:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan efisiensi juga\Nditentukan oleh jumlah.
Dialogue: 0,0:19:11.40,0:19:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima penyihir terkuat tidak cukup\Nuntuk melawan para Penjajah Langit.
Dialogue: 0,0:19:16.85,0:19:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengejar Mahatinggi Tunggal,
Dialogue: 0,0:19:19.70,0:19:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melainkan kemutlakan\Nyang sudah distandarkan.
Dialogue: 0,0:19:22.58,0:19:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus membuat Wis\Nbisa digunakan semua orang.
Dialogue: 0,0:19:26.00,0:19:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah tujuan yang paling utama.
Dialogue: 0,0:19:30.33,0:19:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk bisa mencapainya,
Dialogue: 0,0:19:32.55,0:19:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuh Will Serfort
Dialogue: 0,0:19:36.73,0:19:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus kubedah.
Dialogue: 0,0:19:43.55,0:19:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangankan faksi di menara,
Dialogue: 0,0:19:45.53,0:19:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Magia Vander saja belum pernah\Nmelihat wajah lain Tuan Kreutz ini.
Dialogue: 0,0:19:50.43,0:19:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mad Dissector.
Dialogue: 0,0:19:52.17,0:19:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Nona Elfaria sampai tahu,
Dialogue: 0,0:19:55.45,0:19:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Institut Tinggi pasti hancur!
Dialogue: 0,0:20:09.23,0:20:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Charles.
Dialogue: 0,0:20:11.45,0:20:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu semua faksi\Nbahwa Pembunuh Penyihir
Dialogue: 0,0:20:13.88,0:20:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa segera ditangani.
Dialogue: 0,0:20:15.78,0:20:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memahami semuanya.
Dialogue: 0,0:20:18.45,0:20:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, aku akan\Nmembongkar rahasia Wis.
Dialogue: 0,0:20:25.23,0:20:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya,
Dialogue: 0,0:20:28.08,0:20:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku hanya ingin mengawasimu
Dialogue: 0,0:20:29.78,0:20:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencapai pemandangan baru\Ndengan kekuatanmu sendiri,
Dialogue: 0,0:20:36.25,0:20:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak bisa\Nterus-terusan begitu.
Dialogue: 0,0:20:38.95,0:20:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin kamu\Nmenjadi kelinci percobaan.
Dialogue: 0,0:20:43.18,0:20:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku menunggu momen ini\Nuntuk membantumu.
Dialogue: 0,0:20:47.35,0:20:50.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Elfaria juga\Nsudah meminta bantuanku.
Dialogue: 0,0:20:51.70,0:20:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie?
Dialogue: 0,0:20:52.98,0:20:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengatakan semuanya.
Dialogue: 0,0:20:55.08,0:20:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bebas menanggapinya.
Dialogue: 0,0:21:01.58,0:21:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius.
Dialogue: 0,0:21:03.88,0:21:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin percaya padanya.
Dialogue: 0,0:21:08.23,0:21:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia tidak berbohong.
Dialogue: 0,0:21:10.63,0:21:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, anehnya,
Dialogue: 0,0:21:13.28,0:21:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa sudah\Nmengenalnya sejak lama.
Dialogue: 0,0:21:20.63,0:21:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kau saja.
Dialogue: 0,0:21:23.05,0:21:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius.
Dialogue: 0,0:21:24.70,0:21:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpalinglah ke orang\Nyang lebih layak dimanfaatkan!
Dialogue: 0,0:21:27.13,0:21:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga cuma membantumu\Ndengan niat seperti itu!
Dialogue: 0,0:21:30.55,0:21:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!\NAku tidak bermaksud berpaling...
Dialogue: 0,0:21:34.55,0:21:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:21:35.85,0:21:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalian sudah akrab sekali.\N- Terima kasih atas kebaikanmu.
Dialogue: 0,0:21:38.03,0:21:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mereka bisa jadi tim yang hebat.\N- Sudah kubilang, ini bukan kebaikan!
Dialogue: 0,0:21:40.55,0:21:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma berdasar pada efisiensi!
Dialogue: 0,0:21:44.03,0:21:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:21:45.65,0:21:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah sepakat!
Dialogue: 0,0:21:47.00,0:21:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Cerridwen yang baik ini
Dialogue: 0,0:21:48.73,0:21:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan melatihmu\Nsupaya bisa berkembang!
Dialogue: 0,0:21:51.85,0:21:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, langsung saja, ya.
Dialogue: 0,0:21:55.35,0:21:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas bajumu.
Dialogue: 0,0:21:59.13,0:22:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:23:36.55,0:23:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.40,0:23:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode dua puluh satu:\N"Halaman yang Dibalik".
