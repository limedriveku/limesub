Dialogue: 0,0:00:00.78,0:00:03.53,sign,,0000,0000,0000,,LANTAI PERTAMA MENARA, COLORLESS GARDEN
Dialogue: 0,0:00:07.88,0:00:10.91,sign,,0000,0000,0000,,RUMAH PERSEMBUNYIAN CLAIRIE
Dialogue: 0,0:00:16.27,0:00:20.10,sign,,0000,0000,0000,,"WILL SERFORT"
Dialogue: 0,0:00:26.34,0:00:29.04,sign,,0000,0000,0000,,"JULIUS REINBERG"
Dialogue: 0,0:01:22.81,0:01:23.18,sign,,0000,0000,0000,,CERRIDWEN
Dialogue: 0,0:05:12.02,0:05:16.75,sign,,0000,0000,0000,,EPISODE 21: HALAMAN YANG DIBALIK
Dialogue: 0,0:06:21.03,0:06:25.61,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:06:31.08,0:06:33.00,sign,,0000,0000,0000,,"KAMAR RUMAH PERSEMBUNYIAN CLAIRIE"
Dialogue: 0,0:15:38.58,0:15:41.84,sign,,0000,0000,0000,,WILL KECIL
Dialogue: 0,0:15:43.73,0:15:46.88,sign,,0000,0000,0000,,ELFARIA KECIL
Dialogue: 0,0:23:27.97,0:23:30.92,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:44.03,0:23:48.18,sign,,0000,0000,0000,,EPISODE 22:\NPERASAAN, MEKAR, BERGEMURUH
Dialogue: 0,0:00:13.02,0:00:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:00:16.27,0:00:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus buka baju?!
Dialogue: 0,0:00:20.39,0:00:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, menurut saja.\NAku tidak akan berbuat jahat.
Dialogue: 0,0:00:25.12,0:00:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:00:26.34,0:00:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau punya selera aneh, ya?!
Dialogue: 0,0:00:29.49,0:00:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salah paham.\NIni memang diperlukan.
Dialogue: 0,0:00:32.97,0:00:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, turunkan tanganmu, Will.
Dialogue: 0,0:00:36.72,0:00:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:00:38.24,0:00:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah paham apanya?!
Dialogue: 0,0:00:39.89,0:00:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar wanita mesum tidak terbantah—
Dialogue: 0,0:00:45.62,0:00:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana asal bekas luka itu?
Dialogue: 0,0:00:49.39,0:00:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar rumornya,\Ntapi sesering apa dia memaksakan diri
Dialogue: 0,0:00:53.01,0:00:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memanjat menara?!
Dialogue: 0,0:00:56.81,0:00:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:00:58.59,0:00:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:01:00.84,0:01:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan dan kenapa kamu\Nbisa dapat luka di punggung ini?
Dialogue: 0,0:01:06.02,0:01:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin waktu kecil,\Nsaat aku melindungi Elfie.
Dialogue: 0,0:01:09.99,0:01:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:01:11.44,0:01:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin inilah yang kucari.
Dialogue: 0,0:01:14.47,0:01:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa yang sedang Anda lakukan?
Dialogue: 0,0:01:17.67,0:01:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memastikan letak kunci\Nuntuk membuka pintu berikutnya.
Dialogue: 0,0:01:23.19,0:01:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melihat latihan kalian.
Dialogue: 0,0:01:26.99,0:01:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkesan dengan ide\Npenambatan energi sihir itu.
Dialogue: 0,0:01:30.77,0:01:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengendalikan energi sihir\Nyang tertambat dalam diri
Dialogue: 0,0:01:33.47,0:01:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah cara menguasai Wis.
Dialogue: 0,0:01:35.32,0:01:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagasan itu sudah benar.
Dialogue: 0,0:01:38.12,0:01:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kamu lebih jujur\Nmengungkapkan perasaanmu.
Dialogue: 0,0:01:41.94,0:01:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang penyihir hebat, Julius.
Dialogue: 0,0:01:45.02,0:01:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh sanjungan palsu itu.
Dialogue: 0,0:01:47.24,0:01:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling aku salah, kan?
Dialogue: 0,0:01:50.44,0:01:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak salah, kok.
Dialogue: 0,0:01:52.34,0:01:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya Will sudah\Nberhasil dalam penambatan
Dialogue: 0,0:01:54.84,0:01:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau penyimpanan energi sihir itu.
Dialogue: 0,0:01:59.27,0:02:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena darah penyihir,
Dialogue: 0,0:02:01.34,0:02:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau darah tongkat sihir,\Njuga mengalir di tubuh Will.
Dialogue: 0,0:02:05.19,0:02:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, tubuh Will agak spesial.
Dialogue: 0,0:02:08.32,0:02:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhnya tidak bisa\Nmengeluarkan energi sihir
Dialogue: 0,0:02:10.82,0:02:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi menyimpannya di dalam\Nsecara rakus.
Dialogue: 0,0:02:14.24,0:02:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sampai menjerit keras,
Dialogue: 0,0:02:16.89,0:02:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuhnya tetap melahap\Nenergi sihir dari luar
Dialogue: 0,0:02:19.44,0:02:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyimpannya.
Dialogue: 0,0:02:20.79,0:02:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyimpannya?
Dialogue: 0,0:02:22.52,0:02:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasmu sekarang adalah\Nmenemukan cara mengakses
Dialogue: 0,0:02:25.07,0:02:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}energi sihir yang kamu simpan.
Dialogue: 0,0:02:28.37,0:02:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya,
Dialogue: 0,0:02:29.25,0:02:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa melakukan pemuatan sihir sendiri.
Dialogue: 0,0:02:32.99,0:02:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah tahap baru\Nyang harus kamu capai.
Dialogue: 0,0:02:35.99,0:02:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu!
Dialogue: 0,0:02:37.72,0:02:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah pemuatan itu
Dialogue: 0,0:02:39.53,0:02:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bergantung pada energi sihir\Ndari orang lain?
Dialogue: 0,0:02:42.44,0:02:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang benar, tapi tidak sebatas itu.
Dialogue: 0,0:02:45.97,0:02:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya kamu bisa menggunakan sihir\Nyang sebelumnya tidak kamu serap, kan?
Dialogue: 0,0:02:54.07,0:02:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kamu harus bisa menguasai itu.
Dialogue: 0,0:02:57.79,0:03:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan menelusuri kisah sihir\Nyang terikat dengan darah dan ingatan,
Dialogue: 0,0:03:01.74,0:03:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu bisa melakukan\Npemuatan sihir sendirian.
Dialogue: 0,0:03:05.72,0:03:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan Imaji baru yang tidak\Nbergantung pada sihir orang lain.
Dialogue: 0,0:03:10.62,0:03:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan Imaji baru?
Dialogue: 0,0:03:13.59,0:03:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja kekuatan perasaan.
Dialogue: 0,0:03:19.34,0:03:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengalirkan\Nenergi sihirku ke kuncinya
Dialogue: 0,0:03:22.54,0:03:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membimbingmu ke suatu tempat.
Dialogue: 0,0:03:25.47,0:03:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kamu di sana,\Ningatlah asal-usulmu.
Dialogue: 0,0:03:29.94,0:03:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ukirlah ke dalam tubuhmu.\NCara membangkitkan ingatan itu.
Dialogue: 0,0:03:35.69,0:03:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuhaturkan sumpah di sini.
Dialogue: 0,0:03:37.74,0:03:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembunyikan nama tabu pedang\Ndan telusuri silsilah garis darahnya.
Dialogue: 0,0:03:41.44,0:03:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuhadirkan lubang kunci di sini.
Dialogue: 0,0:03:43.52,0:03:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan meminjam nama penyihir,\Nterbukalah kisah lama yang tertutup.
Dialogue: 0,0:03:51.14,0:03:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbukalah.
Dialogue: 0,0:03:54.54,0:03:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Twarv Historia.
Dialogue: 0,0:03:58.54,0:04:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat jalan, Will.
Dialogue: 0,0:04:11.79,0:04:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:04:14.12,0:04:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini ingatanku selama ini?
Dialogue: 0,0:04:36.42,0:04:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:04:38.39,0:04:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:04:39.64,0:04:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:04:41.37,0:04:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu baik-baik saja?
Dialogue: 0,0:04:43.94,0:04:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini!
Dialogue: 0,0:04:45.59,0:04:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan itu berbahaya,\Nmari bergandengan tangan.
Dialogue: 0,0:04:49.67,0:04:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El... fie?
Dialogue: 0,0:04:52.72,0:04:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungimu!
Dialogue: 0,0:06:28.37,0:06:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa begini?!
Dialogue: 0,0:06:31.08,0:06:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah pingsan selama empat hari.
Dialogue: 0,0:06:33.00,0:06:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih belum bangun juga.
Dialogue: 0,0:06:35.40,0:06:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang menyelam ke alam mimpi.
Dialogue: 0,0:06:39.65,0:06:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menggunakan sihirku sebagai pemicu
Dialogue: 0,0:06:42.05,0:06:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar dia bisa memulihkan\Ningatan tentang masa lalunya.
Dialogue: 0,0:06:44.69,0:06:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi? Masa lalu?
Dialogue: 0,0:06:47.52,0:06:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pemulihan ingatan itu cukup\Nuntuk menguasai kekuatan baru?
Dialogue: 0,0:06:53.30,0:06:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sih kurang yakin soal itu.
Dialogue: 0,0:06:56.80,0:06:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya pedang adalah ranahnya Finn.
Dialogue: 0,0:06:58.57,0:06:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:07:01.20,0:07:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud\Nmenyangkal metode Finn.
Dialogue: 0,0:07:04.21,0:07:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika ingin menaklukkan langit,\Nmenurutku kita butuh pendekatan lain.
Dialogue: 0,0:07:11.60,0:07:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau bicarakan?
Dialogue: 0,0:07:13.82,0:07:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejarah terpendam di dalam tubuhmu.
Dialogue: 0,0:07:17.25,0:07:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jejak tongkat sihir dan pedang\Nyang terus-menerus bersinggungan.
Dialogue: 0,0:07:21.12,0:07:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telusurilah semua itu\Nsampai ke asal-usulmu.
Dialogue: 0,0:07:25.67,0:07:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan jika memungkinkan,
Dialogue: 0,0:07:27.98,0:07:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuharap kamu mencapai sumber\Ndari segalanya.
Dialogue: 0,0:07:35.82,0:07:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan dan kakiku terlihat kecil.
Dialogue: 0,0:07:39.55,0:07:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:07:42.12,0:07:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie juga kecil?!
Dialogue: 0,0:07:43.65,0:07:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Will?
Dialogue: 0,0:07:46.50,0:07:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah, aku kembali ke masa lalu.
Dialogue: 0,0:07:51.02,0:07:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini benar-benar masa laluku.
Dialogue: 0,0:07:55.17,0:07:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku kembali ke masa lalu\Nkarena sihir orang itu?
Dialogue: 0,0:07:58.50,0:08:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Sehebat apa pun sihirnya,\Naku tidak mungkin kembali ke masa lalu.
Dialogue: 0,0:08:04.20,0:08:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau begitu...\N- Hei.
Dialogue: 0,0:08:05.57,0:08:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, Will?\N- Apa ini kilas balik?
Dialogue: 0,0:08:07.25,0:08:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, Will!\N- Apa aku melihat kejadian masa lalu
Dialogue: 0,0:08:09.45,0:08:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melalui mimpi?
Dialogue: 0,0:08:12.02,0:08:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah aku!
Dialogue: 0,0:08:15.57,0:08:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti mikirin gadis lain, kan?
Dialogue: 0,0:08:19.78,0:08:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?! Tidak!
Dialogue: 0,0:08:21.42,0:08:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, kamu selalu memanjakan\NClaire dan yang lainnya.
Dialogue: 0,0:08:25.62,0:08:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma untuk membantu Ayah, kok.
Dialogue: 0,0:08:28.79,0:08:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:08:30.47,0:08:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku tidak mau diselingkuhi!\N- Oh, iya.
Dialogue: 0,0:08:33.35,0:08:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Saat masih kecil,\N- Pokoknya tidak boleh, Will!
Dialogue: 0,0:08:35.27,0:08:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Elfie memang lebih egois.\N- Pokoknya tidak boleh, Will!
Dialogue: 0,0:08:36.90,0:08:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak boleh selingkuh!
Dialogue: 0,0:08:38.04,0:08:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie, bagaimana cara\Nmendapat maaf darimu?
Dialogue: 0,0:08:43.12,0:08:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluk aku!
Dialogue: 0,0:08:52.30,0:08:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elus juga kepalaku.
Dialogue: 0,0:08:54.05,0:08:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:09:01.42,0:09:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi rindu.
Dialogue: 0,0:09:03.40,0:09:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku sering melakukan ini\Nuntuk membuatnya ceria lagi.
Dialogue: 0,0:09:10.42,0:09:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!\NAku sudah dapat energi Will!
Dialogue: 0,0:09:13.57,0:09:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita berangkat\Nuntuk basmi monster!
Dialogue: 0,0:09:16.35,0:09:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie?! Apa maksudmu?
Dialogue: 0,0:09:19.90,0:09:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada monster aneh di hutan.
Dialogue: 0,0:09:22.55,0:09:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuat Ayah susah,\Njadi, kita harus membereskannya.
Dialogue: 0,0:09:26.50,0:09:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?! Itu kan bahaya!
Dialogue: 0,0:09:30.32,0:09:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kamu hebat,\Ntapi aku tidak bisa sihir.
Dialogue: 0,0:09:35.32,0:09:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaraku keluar sendiri?
Dialogue: 0,0:09:37.35,0:09:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku menuturkan ucapan\Nyang kukatakan di saat ini?
Dialogue: 0,0:09:43.40,0:09:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:09:45.32,0:09:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawa buku favorit kita!
Dialogue: 0,0:09:48.87,0:09:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada ini, keberanian kita\Nakan meluap bagai ombak, kan?
Dialogue: 0,0:09:52.95,0:09:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mak byaar!
Dialogue: 0,0:09:54.75,0:09:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti aman, deh!
Dialogue: 0,0:09:57.60,0:09:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungimu, Will.
Dialogue: 0,0:10:01.37,0:10:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:03.55,0:10:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dulu sangat penakut\Ndan tidak berdaya.
Dialogue: 0,0:10:07.02,0:10:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Elfie selalu melindungiku.
Dialogue: 0,0:10:15.02,0:10:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan, ya, Elfie,
Dialogue: 0,0:10:16.77,0:10:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai bergantung padaku?
Dialogue: 0,0:10:31.97,0:10:32.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rehat!
Dialogue: 0,0:10:33.90,0:10:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang,
Dialogue: 0,0:10:35.62,0:10:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan tunjukkan sihir hebat\Nyang kupikirkan!
Dialogue: 0,0:10:38.85,0:10:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isnowmy Lazley!
Dialogue: 0,0:10:45.52,0:10:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, Will! Ini untukmu!
Dialogue: 0,0:10:49.10,0:10:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Elfie.
Dialogue: 0,0:10:53.55,0:10:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir rahasia kedua\Nyang diciptakan Elfie
Dialogue: 0,0:10:56.70,0:11:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanyalah sihir lembut\Nuntuk membuat permen es.
Dialogue: 0,0:11:03.72,0:11:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dulu sangat suka permen es ini.
Dialogue: 0,0:11:06.90,0:11:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasiakan ini dari Claire\Ndan yang lain, ya.
Dialogue: 0,0:11:09.20,0:11:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:11:11.60,0:11:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu memberiku\Nbanyak permen es, Elfie?
Dialogue: 0,0:11:15.60,0:11:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu selalu\Nmembagikan makananmu
Dialogue: 0,0:11:18.45,0:11:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepada semua anak di panti.
Dialogue: 0,0:11:21.47,0:11:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:11:23.22,0:11:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau makan banyak permenku,\Nkamu akan memikirkan aku terus, kan?
Dialogue: 0,0:11:28.52,0:11:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:11:31.30,0:11:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah! Sebelum bertualang,\Nmari kita tambah asupan keberanian!
Dialogue: 0,0:11:35.85,0:11:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membacakannya untukmu.
Dialogue: 0,0:11:38.52,0:11:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya. Aku belum bisa baca.
Dialogue: 0,0:11:41.77,0:11:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kok.
Dialogue: 0,0:11:46.05,0:11:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualangan Demuna.
Dialogue: 0,0:11:48.25,0:11:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buku berharga favorit Elfie
Dialogue: 0,0:11:50.07,0:11:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membuat kami berjanji\Nmelihat matahari terbenam bersama.
Dialogue: 0,0:11:54.67,0:11:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga rindu buku ini.
Dialogue: 0,0:11:56.52,0:11:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir wanita jahat pun berkata:
Dialogue: 0,0:11:59.27,0:12:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah! Harta karun merah jingga\Nyang paling indah di dunia itu tidak ada!
Dialogue: 0,0:12:04.70,0:12:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua hanya kebohonganmu!
Dialogue: 0,0:12:07.80,0:12:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan tengil pun berkata:
Dialogue: 0,0:12:10.29,0:12:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya langit\Nsedang murung hari ini.
Dialogue: 0,0:12:13.87,0:12:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.\NAku akan mengajaknya bicara.
Dialogue: 0,0:12:17.55,0:12:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pahlawan mencabut pedangnya,\Nlangit kelabu pun berbelah menjadi dua,
Dialogue: 0,0:12:21.75,0:12:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan muncullah merah jingga\Nyang paling indah di dunia.
Dialogue: 0,0:12:26.05,0:12:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Gambar itu...
Dialogue: 0,0:12:28.12,0:12:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru sadar, tapi itu mirip Finn?
Dialogue: 0,0:12:33.17,0:12:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terpesona oleh matahari terbenam\Nyang tidak tergantikan harta apa pun,
Dialogue: 0,0:12:36.50,0:12:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sang penyihir wanita pun menangis.
Dialogue: 0,0:12:40.17,0:12:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus bagaimana?
Dialogue: 0,0:12:45.35,0:12:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin cuma perasaanku.
Dialogue: 0,0:12:48.40,0:12:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ujung perjalanan panjang,\Npenyihir wanita berkata pada pahlawan.
Dialogue: 0,0:12:52.92,0:12:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi melihat matahari terbenam itu\Nsekali lagi...
Dialogue: 0,0:12:57.70,0:12:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will?
Dialogue: 0,0:13:00.10,0:13:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mengantuk?
Dialogue: 0,0:13:01.50,0:13:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, maaf.
Dialogue: 0,0:13:03.30,0:13:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:13:04.72,0:13:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga minta maaf\Nkarena membangunkanmu.
Dialogue: 0,0:13:11.42,0:13:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan meminjamkan pangkuan\Nsebagai bantalmu.
Dialogue: 0,0:13:15.47,0:13:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, sini.
Dialogue: 0,0:13:19.62,0:13:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kembali
Dialogue: 0,0:13:22.20,0:13:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke hari-hari tenang,\Nsaat berdua dengannya.
Dialogue: 0,0:13:25.27,0:13:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa permintaan itu\Ntidak diperbolehkan?
Dialogue: 0,0:13:45.44,0:13:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:46.52,0:13:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie?! Nona Elfie?
Dialogue: 0,0:13:48.19,0:13:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau apa?
Dialogue: 0,0:13:49.67,0:13:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu!
Dialogue: 0,0:13:54.00,0:13:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Elfie.
Dialogue: 0,0:13:56.30,0:13:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang apa?
Dialogue: 0,0:13:57.62,0:13:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?! Ti-Tidak ada!
Dialogue: 0,0:13:59.35,0:14:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin mengambil kotoran\Ndi wajahmu...
Dialogue: 0,0:14:03.65,0:14:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma itu, kok.
Dialogue: 0,0:14:04.92,0:14:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa cara bicaramu aneh?
Dialogue: 0,0:14:07.77,0:14:09.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yu-Yuk pergi!
Dialogue: 0,0:14:09.37,0:14:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo jaga perdamaian hutan!\N- Elfie?!
Dialogue: 0,0:14:12.52,0:14:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi malu menghadapi Elfie\Njika kami bertemu lagi.
Dialogue: 0,0:14:30.45,0:14:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada perang besar\Ndi tempat bernama "Rigarden".
Dialogue: 0,0:14:33.52,0:14:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, orang-orang seram\Ndan monster pun kabur ke sini.
Dialogue: 0,0:14:36.82,0:14:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:14:38.10,0:14:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Makanya monster\Nyang berulah di hutan ini
Dialogue: 0,0:14:40.92,0:14:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga datang dari Rigarden.
Dialogue: 0,0:14:44.52,0:14:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster.
Dialogue: 0,0:14:46.80,0:14:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat.
Dialogue: 0,0:14:48.32,0:14:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh tahun lalu,\Naku dan Elfie pergi ke sini,
Dialogue: 0,0:14:51.77,0:14:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke hutan belakang panti,\Nberdua saja.
Dialogue: 0,0:14:55.40,0:14:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Ayah sudah melarang kami.
Dialogue: 0,0:15:00.37,0:15:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pasti aman kalau ada kamu, kan?
Dialogue: 0,0:15:02.57,0:15:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, dong!
Dialogue: 0,0:15:04.92,0:15:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengingat percakapan ini.
Dialogue: 0,0:15:07.85,0:15:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku tidak ingat kelanjutannya.
Dialogue: 0,0:15:11.47,0:15:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi setelah ini?
Dialogue: 0,0:15:31.05,0:15:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:15:47.84,0:15:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster serigala?
Dialogue: 0,0:15:49.34,0:15:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan. Itu monster kristal?
Dialogue: 0,0:15:53.47,0:15:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan monster biasa.
Dialogue: 0,0:15:55.02,0:15:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku tahu.
Dialogue: 0,0:15:57.02,0:15:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah creature\Nyang diciptakan penyihir!
Dialogue: 0,0:16:00.17,0:16:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk itu terluka?
Dialogue: 0,0:16:02.34,0:16:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia kabur dari perang?
Dialogue: 0,0:16:07.54,0:16:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah di sini, Will!
Dialogue: 0,0:16:08.72,0:16:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie!
Dialogue: 0,0:16:10.62,0:16:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengalahkannya!
Dialogue: 0,0:16:15.39,0:16:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan sihir hebat yang kupikirkan!
Dialogue: 0,0:16:23.54,0:16:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ars Weiss!
Dialogue: 0,0:16:25.12,0:16:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghajarnya\Ndengan diriku yang banyak!
Dialogue: 0,0:16:31.20,0:16:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengeluarkan banyak Ars Weiss.
Dialogue: 0,0:16:33.58,0:16:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendali energi sihirnya\Nsudah tinggi sejak kecil.
Dialogue: 0,0:16:36.19,0:16:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie memang hebat.
Dialogue: 0,0:16:39.37,0:16:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tunggu...
Dialogue: 0,0:16:41.29,0:16:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku merasa gelisah?
Dialogue: 0,0:16:45.32,0:16:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo serang!
Dialogue: 0,0:16:47.12,0:16:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tearis Nono!
Dialogue: 0,0:16:52.54,0:16:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie! Larilah!
Dialogue: 0,0:16:58.04,0:16:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie!
Dialogue: 0,0:16:58.83,0:16:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf—
Dialogue: 0,0:17:03.89,0:17:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemantul sihir!
Dialogue: 0,0:17:05.29,0:17:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah karakteristiknya!
Dialogue: 0,0:17:08.54,0:17:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari! Larilah, Elfie!
Dialogue: 0,0:17:10.78,0:17:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak... takut...
Dialogue: 0,0:17:12.89,0:17:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak takut...
Dialogue: 0,0:17:15.09,0:17:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengalahkanmu!
Dialogue: 0,0:17:19.59,0:17:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus melindungi Will!
Dialogue: 0,0:17:26.56,0:17:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa bergerak.
Dialogue: 0,0:17:28.89,0:17:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku...
Dialogue: 0,0:17:30.57,0:17:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie...
Dialogue: 0,0:17:32.84,0:17:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:17:34.69,0:17:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergeraklah!
Dialogue: 0,0:17:35.59,0:17:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlarilah! Beranjaklah!
Dialogue: 0,0:17:37.84,0:17:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau paling\Nmembenci dirimu sendiri
Dialogue: 0,0:17:40.89,0:17:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena selalu dilindungi Elfie?!
Dialogue: 0,0:17:43.54,0:17:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:17:44.92,0:17:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah!
Dialogue: 0,0:17:46.34,0:17:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:18:03.49,0:18:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Will...?
Dialogue: 0,0:18:09.29,0:18:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:18:12.07,0:18:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will! Will! Bertahanlah!
Dialogue: 0,0:18:15.44,0:18:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Will! Will!\N- Aku ingat.
Dialogue: 0,0:18:17.74,0:18:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melindungi Elfie
Dialogue: 0,0:18:21.04,0:18:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan jatuh pingsan.
Dialogue: 0,0:18:25.47,0:18:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi setelah itu?
Dialogue: 0,0:18:27.89,0:18:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang menolong Elfie?
Dialogue: 0,0:18:32.14,0:18:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:18:42.77,0:18:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangkitlah!
Dialogue: 0,0:18:49.79,0:18:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku panas.
Dialogue: 0,0:18:52.42,0:18:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku serasa meledak.
Dialogue: 0,0:18:54.94,0:18:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku menjadi pedang itu sendiri.
Dialogue: 0,0:18:59.07,0:18:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will?
Dialogue: 0,0:19:01.39,0:19:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:06.04,0:19:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata petualangan ini
Dialogue: 0,0:19:08.52,0:19:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih ada kelanjutannya.
Dialogue: 0,0:19:11.79,0:19:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah awal mula pedang.
Dialogue: 0,0:19:19.94,0:19:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan Imaji.
Dialogue: 0,0:19:26.27,0:19:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tearis Wis!
Dialogue: 0,0:19:38.34,0:19:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku mengerti.
Dialogue: 0,0:19:40.82,0:19:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja aku merasa kalau\Nkekuatan ini tidak bisa dihentikan.
Dialogue: 0,0:19:46.59,0:19:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku sudah tahu.
Dialogue: 0,0:19:48.92,0:19:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah membuat pedang sihir ini
Dialogue: 0,0:19:51.72,0:19:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan sihir Elfie.
Dialogue: 0,0:19:57.84,0:19:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:20:25.02,0:20:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begitu.
Dialogue: 0,0:20:27.69,0:20:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah sihirmu, ya, Will.
Dialogue: 0,0:20:35.17,0:20:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah awal mulaku.
Dialogue: 0,0:20:38.69,0:20:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenangan berhargaku.
Dialogue: 0,0:20:42.52,0:20:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan lupa lagi.
Dialogue: 0,0:20:45.52,0:20:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu mengingat ikatan\Nyang kubuat dengan Elfie ini.
Dialogue: 0,0:20:49.49,0:20:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Will.
Dialogue: 0,0:20:59.19,0:21:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa kau sudah sadar?
Dialogue: 0,0:21:01.89,0:21:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius?
Dialogue: 0,0:21:03.42,0:21:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah!
Dialogue: 0,0:21:04.44,0:21:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah tidur selama enam hari!
Dialogue: 0,0:21:06.14,0:21:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Second Bloom akan segera dimulai!
Dialogue: 0,0:21:10.44,0:21:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Apa kau dengar?!
Dialogue: 0,0:21:12.49,0:21:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah!
Dialogue: 0,0:21:14.82,0:21:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu sudah\Nbisa mengakses energi sihir
Dialogue: 0,0:21:17.19,0:21:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau sumber kekuatan\Nyang tertambat di dalam dirimu?
Dialogue: 0,0:21:21.39,0:21:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:21:23.52,0:21:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu sudah bisa membangkitkan\Njejak kehidupan yang sudah kamu lalui?
Dialogue: 0,0:21:27.82,0:21:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa kapan saja!
Dialogue: 0,0:21:38.64,0:21:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah!
Dialogue: 0,0:21:40.44,0:21:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menuliskan kisah baru!
Dialogue: 0,0:21:42.99,0:21:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:23:36.39,0:23:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.11,0:23:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode dua puluh dua:\N"Perasaan, Mekar, Bergemuruh".
