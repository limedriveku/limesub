Dialogue: 0,0:04:42.03,0:04:46.76,sign,,0000,0000,0000,,EPISODE 22:\NPERASAAN, MEKAR, BERGEMURUH
Dialogue: 0,0:05:51.04,0:05:55.62,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:06:27.48,0:06:29.19,sign,,0000,0000,0000,,EMMA CLEVER, DIREKRUT FAKSI ANGIN
Dialogue: 0,0:06:36.85,0:06:39.81,sign,,0000,0000,0000,,MIKE MAIUS\NDIREKRUT FAKSI KEGELAPAN
Dialogue: 0,0:06:52.61,0:06:55.60,sign,,0000,0000,0000,,"LYRIL MARS DAN GORDON VALLEY DIREKRUT FAKSI API"
Dialogue: 0,0:10:57.68,0:11:01.02,sign,,0000,0000,0000,,WIS
Dialogue: 0,0:11:01.30,0:11:02.38,sign,,0000,0000,0000,,TEARIS WIS
Dialogue: 0,0:11:02.80,0:11:06.02,sign,,0000,0000,0000,,PEMUATAN IMAJI
Dialogue: 0,0:12:04.05,0:12:05.82,sign,,0000,0000,0000,,"AJUDAN FAKSI PETIR, GUILFORD ZURGAS"
Dialogue: 0,0:21:41.62,0:21:42.99,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:43.63,0:23:48.28,sign,,0000,0000,0000,,EPISODE 23:\NES DAN PETIR MENGGELEGAR
Dialogue: 0,0:00:16.77,0:00:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci Magia Vander.
Dialogue: 0,0:00:20.79,0:00:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will selalu mengejar Albis Vina\Nkarena kena pengaruh sihirnya.
Dialogue: 0,0:00:25.90,0:00:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, gadis itu hanya diam\Ndan menunggu di puncak menara.
Dialogue: 0,0:00:31.71,0:00:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kasihan sama Will.
Dialogue: 0,0:00:34.76,0:00:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu.
Dialogue: 0,0:00:36.54,0:00:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya karena sihirku.
Dialogue: 0,0:00:40.16,0:00:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sihirku...\NKutukan yang kuberikan,
Dialogue: 0,0:00:44.21,0:00:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will jadi sering terluka dan menderita.
Dialogue: 0,0:00:48.69,0:00:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak air mata pertama itu,
Dialogue: 0,0:00:54.74,0:00:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah sebanyak apa aku membuatmu menangis?
Dialogue: 0,0:00:59.93,0:01:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya aku berontak saja?
Dialogue: 0,0:01:03.01,0:01:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya aku pergi dari sini?
Dialogue: 0,0:01:05.86,0:01:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya aku bersikap masa bodoh\Ndan pergi memelukmu?
Dialogue: 0,0:01:20.94,0:01:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:01:25.49,0:01:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah membencimu, Elfie.
Dialogue: 0,0:01:29.94,0:01:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu justru jadi sendirian gara-gara aku.
Dialogue: 0,0:01:34.69,0:01:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya membenci satu hal.
Dialogue: 0,0:01:37.16,0:01:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu adalah
Dialogue: 0,0:01:38.86,0:01:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort yang tidak berdaya.
Dialogue: 0,0:01:44.44,0:01:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku harus bergegas.
Dialogue: 0,0:01:46.66,0:01:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menyusulmu.
Dialogue: 0,0:01:49.48,0:01:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berdiri di sampingmu\Ndan mewujudkan janji berharga kita.
Dialogue: 0,0:01:56.04,0:01:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kata-katamu itu
Dialogue: 0,0:01:58.96,0:02:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tetap menghiburku,\Nmeski kita berdua berjauhan,
Dialogue: 0,0:02:03.54,0:02:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku memutuskan untuk bersabar.
Dialogue: 0,0:02:06.79,0:02:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunggumu,\Ntanpa mengingkari janji.
Dialogue: 0,0:02:11.26,0:02:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolonglah, Cerry!
Dialogue: 0,0:02:12.59,0:02:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, Nona Cerridwen yang hebat!
Dialogue: 0,0:02:14.94,0:02:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bimbing Will!
Dialogue: 0,0:02:17.01,0:02:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh.
Dialogue: 0,0:02:18.14,0:02:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang aku ikut membantu\Nsecara diam-diam di belakang,
Dialogue: 0,0:02:22.24,0:02:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku ingin ikut berperan
Dialogue: 0,0:02:25.14,0:02:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam perjuanganmu untuk mengejarku.
Dialogue: 0,0:02:28.01,0:02:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membantumu.
Dialogue: 0,0:02:32.44,0:02:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halah.
Dialogue: 0,0:02:33.71,0:02:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling itulah yang dipikirkan\NNona Magia Vander si ratu mimpi itu.
Dialogue: 0,0:02:37.41,0:02:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin membantu Will, Pak Workner!
Dialogue: 0,0:02:42.19,0:02:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak berhak bilang begitu\Njika kamu sendiri sama sepertinya.
Dialogue: 0,0:02:46.79,0:02:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga sudah direkrut faksi.\NKalian tidak boleh pergi seenaknya.
Dialogue: 0,0:02:51.86,0:02:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya belum ingin berpisah dengan Will.
Dialogue: 0,0:02:54.51,0:02:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusan posisi itu nomor dua.
Dialogue: 0,0:02:59.89,0:03:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ada apa denganmu?\NKau terlihat aneh sekali.
Dialogue: 0,0:03:02.79,0:03:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan khawatir.
Dialogue: 0,0:03:04.86,0:03:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma sedikit bertaruh nyawa\Nuntuk sampai ke sini.
Dialogue: 0,0:03:08.86,0:03:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Ada apa, Lihanna?
Dialogue: 0,0:03:12.81,0:03:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Kuali Besar...
Dialogue: 0,0:03:13.79,0:03:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, Penyihir Palu Besi\Nsedang bergerak.
Dialogue: 0,0:03:16.81,0:03:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti baik-baik saja selama ada dia.
Dialogue: 0,0:03:19.89,0:03:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Palu Besi?
Dialogue: 0,0:03:21.24,0:03:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya penyihir wanita\Ndalam tujuh misteri akademi itu?
Dialogue: 0,0:03:24.49,0:03:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama saja seperti\Nbergantung pada orang lain!
Dialogue: 0,0:03:26.49,0:03:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sudah tahu, lo.
Dialogue: 0,0:03:28.16,0:03:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda ke menara setiap hari\Nkarena mengkhawatirkan Will
Dialogue: 0,0:03:31.01,0:03:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti istri gusar\Nyang ditinggal suaminya!
Dialogue: 0,0:03:33.16,0:03:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujung-ujungnya, diusir juga, sih.
Dialogue: 0,0:03:34.74,0:03:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!\NJangan bikin orang salah paham!
Dialogue: 0,0:03:37.01,0:03:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana kamu tahu itu?
Dialogue: 0,0:03:39.06,0:03:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Nona Clairie!
Dialogue: 0,0:03:41.39,0:03:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar mulut ember!
Dialogue: 0,0:03:43.35,0:03:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga ingin membantu Will!
Dialogue: 0,0:03:45.71,0:03:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu melakukan apa pun.
Dialogue: 0,0:03:47.69,0:03:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion?
Dialogue: 0,0:03:49.06,0:03:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bicara apa?
Dialogue: 0,0:03:50.39,0:03:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu juga ke sini\Nkarena ingin membantu Will?
Dialogue: 0,0:03:54.64,0:03:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin mengawasi kalian\Nagar tidak berbuat macam-macam.
Dialogue: 0,0:03:59.71,0:04:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sering disepelekan,\Ntapi dia bisa sampai sejauh ini.
Dialogue: 0,0:04:04.04,0:04:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sepengetahuanku,\Ndia terus berjuang mati-matian
Dialogue: 0,0:04:06.86,0:04:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melewati rintangan.
Dialogue: 0,0:04:09.46,0:04:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu saja.\NDia pasti bisa melewati rintangan ini.
Dialogue: 0,0:04:12.86,0:04:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:04:14.25,0:04:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika ditolong di saat-saat akhir,\Ndia akan kehilangan harga diri.
Dialogue: 0,0:04:19.04,0:04:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu sebagai seorang penyihir?
Dialogue: 0,0:04:24.04,0:04:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai seorang pria.
Dialogue: 0,0:06:17.92,0:06:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emma Clever berhak\Nmendapatkan berkah angin.
Dialogue: 0,0:06:29.22,0:06:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil!
Dialogue: 0,0:06:32.57,0:06:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mike Maius, Faksi Kegelapan menyambutmu.
Dialogue: 0,0:06:39.89,0:06:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik! Aku berhasil!
Dialogue: 0,0:06:47.64,0:06:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lyril Mars dan Gordon Valley!
Dialogue: 0,0:06:49.85,0:06:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua direkrut Faksi Api!
Dialogue: 0,0:06:52.61,0:06:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berhasil! - Asyik!
Dialogue: 0,0:06:55.99,0:06:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kalian berhasil.
Dialogue: 0,0:06:59.44,0:07:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, ya.
Dialogue: 0,0:07:01.09,0:07:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi para penyihir yang lolos,\Nsilakan ke faksi masing-masing.
Dialogue: 0,0:07:05.84,0:07:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu mereka kekurangan orang,
Dialogue: 0,0:07:07.99,0:07:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi standar kelulusan\Nsetiap faksi terlalu rendah.
Dialogue: 0,0:07:11.09,0:07:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sampai menerima penyihir\Nyang baru lulus.
Dialogue: 0,0:07:13.79,0:07:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh. Bukan begitu.
Dialogue: 0,0:07:16.84,0:07:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah insiden Terminalia,
Dialogue: 0,0:07:18.94,0:07:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka yang luput dari perekrutan pun\Nbisa meningkatkan kemampuan adaptasi.
Dialogue: 0,0:07:23.39,0:07:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka masih seperti\Nmakhluk rendahan bagiku, sih.
Dialogue: 0,0:07:27.67,0:07:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap orang telah berhasil\Nmenguasai ketidaktahuan.
Dialogue: 0,0:07:31.32,0:07:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ancaman maut memang efektif.
Dialogue: 0,0:07:33.39,0:07:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan anak-anak burung pun\Nbisa berubah jadi burung migran.
Dialogue: 0,0:07:37.54,0:07:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Second Bloom sudah mau selesai, nih.
Dialogue: 0,0:07:41.69,0:07:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will dan Julius belum datang!
Dialogue: 0,0:07:43.94,0:07:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa didiskualifikasi!
Dialogue: 0,0:07:46.87,0:07:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya buang-buang waktu.
Dialogue: 0,0:07:49.94,0:07:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka putus asa dan kabur\Nkarena tak berhasil menemukan solusi.
Dialogue: 0,0:07:54.59,0:07:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau sendiri yang menghalangi mereka.
Dialogue: 0,0:07:57.99,0:08:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika lari dari neraka penggemblengan,\Nmereka tidak layak memanjat menara.
Dialogue: 0,0:08:02.69,0:08:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan menangani mereka\Ndengan rasa penuh tanggung jawab.
Dialogue: 0,0:08:07.19,0:08:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah, kan, Nona Elfaria?
Dialogue: 0,0:08:16.24,0:08:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maaf atas keterlambatan kami!
Dialogue: 0,0:08:20.84,0:08:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya Julius Reinberg!
Dialogue: 0,0:08:22.34,0:08:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya Will Serfort!
Dialogue: 0,0:08:23.74,0:08:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kami hadir!
Dialogue: 0,0:08:25.89,0:08:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:08:26.99,0:08:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Will!\N- Julius juga!
Dialogue: 0,0:08:31.74,0:08:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci percobaan itu membuatku repot saja.
Dialogue: 0,0:08:35.69,0:08:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan metode seleksi\Nyang sama seperti sebelumnya,
Dialogue: 0,0:08:38.53,0:08:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami akan menguji kelayakannya\Nsebagai tongkat sihir.
Dialogue: 0,0:08:43.07,0:08:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort serta para Magia Vander,\Napa kalian setuju dengan ini?
Dialogue: 0,0:08:51.72,0:08:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:08:55.69,0:08:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:57.94,0:08:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia sudah siap?
Dialogue: 0,0:08:59.87,0:09:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, aku tidak tahu dia\Nbisa mengendalikan Wis atau tidak.
Dialogue: 0,0:09:05.47,0:09:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku pinjamkan saja sihirku\Nsecara diam-diam...
Dialogue: 0,0:09:13.29,0:09:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, aku memberimu berkah.
Dialogue: 0,0:09:15.97,0:09:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarilah tanpa berbuat apa pun.
Dialogue: 0,0:09:18.62,0:09:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria?! Tapi...
Dialogue: 0,0:09:21.19,0:09:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih karena sudah membantu Will.
Dialogue: 0,0:09:23.97,0:09:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percayalah padanya.
Dialogue: 0,0:09:36.92,0:09:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sia-siakan usahaku selama ini.
Dialogue: 0,0:09:40.77,0:09:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Julius.
Dialogue: 0,0:09:43.62,0:09:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, Elfie!
Dialogue: 0,0:09:48.29,0:09:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:09:49.84,0:09:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalur pedangnya sudah terbuka\Nmelalui sihirku.
Dialogue: 0,0:09:56.37,0:09:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti sudah memahami caranya.
Dialogue: 0,0:10:02.12,0:10:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tunjukkan padaku.
Dialogue: 0,0:10:04.09,0:10:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia pedang yang baru.
Dialogue: 0,0:10:07.42,0:10:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membayangkan
Dialogue: 0,0:10:09.57,0:10:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebuah buku.
Dialogue: 0,0:10:15.99,0:10:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka dan ingat perasaan itu.
Dialogue: 0,0:10:19.32,0:10:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari dan tandai halamannya.
Dialogue: 0,0:10:21.12,0:10:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukir dan baca lantang.
Dialogue: 0,0:10:22.94,0:10:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangkitkan sihir yang diperlukan
Dialogue: 0,0:10:28.07,0:10:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari berbagai kisah yang pernah kulalui!
Dialogue: 0,0:10:30.69,0:10:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan Imaji!
Dialogue: 0,0:10:33.07,0:10:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tearis Wis, Reload!
Dialogue: 0,0:10:39.50,0:10:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:10:41.24,0:10:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang cahaya?
Dialogue: 0,0:10:42.59,0:10:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu pedang es?!
Dialogue: 0,0:10:45.52,0:10:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:10:46.51,0:10:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa mengeluarkan Wis tanpa bantuan?!
Dialogue: 0,0:11:07.07,0:11:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkena sihirmu.
Dialogue: 0,0:11:10.92,0:11:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu bukan kutukan.
Dialogue: 0,0:11:14.62,0:11:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah sihir bernama "janji"\Nyang kita mulai berdua.
Dialogue: 0,0:11:19.70,0:11:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kamu sedang membenci diri\Nkarena merasa tidak berdaya.
Dialogue: 0,0:11:25.92,0:11:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.\NJangan berpikir begitu, Elfie.
Dialogue: 0,0:11:29.67,0:11:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah mendapatkan banyak hal darimu.
Dialogue: 0,0:11:32.72,0:11:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendapatkan keberanian\Ntidak terhitung darimu.
Dialogue: 0,0:11:36.37,0:11:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tunggulah aku.
Dialogue: 0,0:11:39.55,0:11:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tampak hebat di bagian akhir.
Dialogue: 0,0:11:43.45,0:11:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu telah memberiku\Nbegitu banyak hingga hari ini
Dialogue: 0,0:11:48.62,0:11:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku ingin menjemputmu.
Dialogue: 0,0:12:02.45,0:12:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuat!
Dialogue: 0,0:12:04.05,0:12:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya tidak sekuat Wis
Dialogue: 0,0:12:05.82,0:12:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan bantuan sihir orang lain.
Dialogue: 0,0:12:08.47,0:12:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, daya hancurnya\Nsetara sihir tingkat menengah.
Dialogue: 0,0:12:11.82,0:12:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mengejutkan.
Dialogue: 0,0:12:20.77,0:12:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan segenap perasaan!
Dialogue: 0,0:12:24.02,0:12:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk memperkuat pedang!
Dialogue: 0,0:12:28.72,0:12:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will...
Dialogue: 0,0:12:30.35,0:12:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga!
Dialogue: 0,0:12:32.11,0:12:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai sempurna!
Dialogue: 0,0:12:33.63,0:12:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memberimu penghargaan\Ndan senyuman, Will!
Dialogue: 0,0:12:37.15,0:12:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diam untuk menghormati tekadmu\Nsaat membantunya naik ke menara,
Dialogue: 0,0:12:41.62,0:12:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi semuanya berjalan lancar, ya,\NCerridwen?
Dialogue: 0,0:12:45.87,0:12:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.\NMaksudku, Kepala Akademi Caldron.
Dialogue: 0,0:12:50.30,0:12:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kamu memanggilku "Cerridwen"\Nsaat aku menggunakan wujud ini?
Dialogue: 0,0:12:53.95,0:12:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menuakan diri sendiri itu berat, tahu.\NSoalnya aku cantik begini.
Dialogue: 0,0:13:00.42,0:13:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, tempat ini hanya boleh\Ndiakses oleh para penyihir, tahu.
Dialogue: 0,0:13:06.27,0:13:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlambat, Penyihir Abadi.
Dialogue: 0,0:13:08.52,0:13:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, bukankah kamu\Njuga diam-diam ikut campur?
Dialogue: 0,0:13:13.57,0:13:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memberikan permata Wist\Nyang berharga itu kepada dwarf, kan?
Dialogue: 0,0:13:18.62,0:13:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pengguna elemen kelima yang baru.
Dialogue: 0,0:13:21.47,0:13:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah segitu mah bisa diabaikan saja, kan?
Dialogue: 0,0:13:25.55,0:13:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah wadah yang masih berkembang.
Dialogue: 0,0:13:28.37,0:13:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amplifikasi energinya belum cukup\Nuntuk melakukan pemuatan sihir sendiri.
Dialogue: 0,0:13:32.90,0:13:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, pedang dwiperak Wist itu\Ncukup untuk mengisi kekurangannya.
Dialogue: 0,0:13:38.10,0:13:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutnya memutih dan ingatannya hilang.
Dialogue: 0,0:13:40.77,0:13:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya dia belum matang\Nuntuk menggunakan pedang sihir
Dialogue: 0,0:13:44.07,0:13:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan konsekuensinya terlalu besar.
Dialogue: 0,0:13:46.52,0:13:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah enam tahun di akademi\Ndan mendapatkan perkembangan,
Dialogue: 0,0:13:50.10,0:13:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang aku bisa mengajarinya banyak hal.
Dialogue: 0,0:13:58.52,0:14:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kamu memperlihatkan
Dialogue: 0,0:14:01.27,0:14:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hasil dari "ketidaktahuan"\Nyang ingin dituju Cerridwen?
Dialogue: 0,0:14:09.52,0:14:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar melihatnya.
Dialogue: 0,0:14:15.52,0:14:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil...
Dialogue: 0,0:14:16.92,0:14:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Mustahil! Mustahil!
Dialogue: 0,0:14:17.95,0:14:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Mustahil! Mustahil!
Dialogue: 0,0:14:21.64,0:14:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Mustahil!
Dialogue: 0,0:14:23.42,0:14:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:14:28.37,0:14:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kreutz?
Dialogue: 0,0:14:30.52,0:14:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Creature itu dikalahkan...
Dialogue: 0,0:14:32.85,0:14:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan itu terlalu besar
Dialogue: 0,0:14:34.45,0:14:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk dikeluarkan\Nmakhluk rendahan seperti dwarf.
Dialogue: 0,0:14:38.50,0:14:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kalian menyadari\Nhasil dari kebodohannya itu.
Dialogue: 0,0:14:54.12,0:14:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangnya kembali seperti semula.
Dialogue: 0,0:14:56.95,0:15:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku melakukannya sendiri,\Nkonsumsi energinya lebih banyak.
Dialogue: 0,0:15:02.10,0:15:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak bisa dilakukan berulang.
Dialogue: 0,0:15:04.37,0:15:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum!
Dialogue: 0,0:15:06.00,0:15:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu belum boleh diakui!
Dialogue: 0,0:15:08.37,0:15:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan sihir!
Dialogue: 0,0:15:10.57,0:15:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kreutz, bukankah itu sama saja\Nseperti cari-cari kesalahan?
Dialogue: 0,0:15:13.69,0:15:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:15:14.75,0:15:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kekuatannya belum bisa dijelaskan,
Dialogue: 0,0:15:17.05,0:15:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa dia bisa disebut penyihir?!
Dialogue: 0,0:15:19.50,0:15:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari awal, bagaimana kalau\Npedang itu adalah alat sihir?!
Dialogue: 0,0:15:23.35,0:15:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama pemekaran, alat selain\Ntongkat sihir tidak diperbolehkan!
Dialogue: 0,0:15:27.08,0:15:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk memastikan bahwa\Ntidak ada peraturan yang dilanggar,
Dialogue: 0,0:15:30.27,0:15:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus memeriksa Will Serfort!
Dialogue: 0,0:15:34.35,0:15:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:15:37.07,0:15:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kalau pedang itu\Ndianggap sebagai tongkat sihir...
Dialogue: 0,0:15:40.10,0:15:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jelas, ini belum pernah terjadi\Nsebelumnya.
Dialogue: 0,0:15:43.12,0:15:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menilai dengan hati-hati.
Dialogue: 0,0:15:46.05,0:15:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan setelah semua ini,\Nmereka masih berdebat?
Dialogue: 0,0:15:48.62,0:15:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena Will Serfort adalah\Nanomali yang belum pernah ada.
Dialogue: 0,0:15:52.85,0:15:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir senior berbagai faksi pun\Nmasih bingung memperlakukannya.
Dialogue: 0,0:15:58.57,0:16:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi ini hanya bisa dikendalikan\Noleh penguasa menara, Magia Vander.
Dialogue: 0,0:16:04.12,0:16:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, apabila Nona Elfaria\Nsampai membela Will Serfort
Dialogue: 0,0:16:09.02,0:16:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau bisa dianggap pilih kasih\Nkarena mereka sudah seperti keluarga.
Dialogue: 0,0:16:14.30,0:16:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum Nona Elfaria meledak,
Dialogue: 0,0:16:16.95,0:16:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuharap ada cara untuk dapat\Ndukungan dari Magia Vander lain.
Dialogue: 0,0:16:22.45,0:16:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muter-muter terus.
Dialogue: 0,0:16:27.62,0:16:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak pakai cara simpel\Nuntuk menilai kapasitas bocah ini?
Dialogue: 0,0:16:36.05,0:16:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zeo?
Dialogue: 0,0:16:37.47,0:16:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Bocah Sialan.\NSatu serangan saja.
Dialogue: 0,0:16:41.67,0:16:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah dari seranganku.
Dialogue: 0,0:16:43.92,0:16:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau berhasil, aku akan mengakuimu.
Dialogue: 0,0:16:48.07,0:16:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengaumlah, oh Petir!
Dialogue: 0,0:16:50.49,0:16:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra singkat?
Dialogue: 0,0:16:52.45,0:16:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu sihir petir tingkat rendah?
Dialogue: 0,0:16:54.47,0:16:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larilah, Will!
Dialogue: 0,0:16:56.45,0:16:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zalgia Saga!
Dialogue: 0,0:17:02.72,0:17:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa ditahan.\NTidak bisa dihindari.
Dialogue: 0,0:17:05.61,0:17:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, hancur total.
Dialogue: 0,0:17:07.59,0:17:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk bisa selamat...
Dialogue: 0,0:17:12.55,0:17:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:17:25.31,0:17:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan Imaji!
Dialogue: 0,0:17:29.97,0:17:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zalgia Wis!
Dialogue: 0,0:17:32.29,0:17:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Pedang sihir elemen petir?
Dialogue: 0,0:17:34.45,0:17:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa?\NApa yang dia lakukan?
Dialogue: 0,0:17:37.77,0:17:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melahap sihirnya!
Dialogue: 0,0:17:39.95,0:17:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertepatan dengan sambaran petir,
Dialogue: 0,0:17:41.67,0:17:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia menyerap dan mengurangi\Nkekuatannya menjadi setengah.
Dialogue: 0,0:17:45.07,0:17:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, dia tidak bisa\Nmenyerap keseluruhan sihir,
Dialogue: 0,0:17:47.62,0:17:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tubuhnya kena petir Zeo\Nyang sangat dahsyat itu,
Dialogue: 0,0:17:51.30,0:17:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia selamat dari serangan maut\Nyang tidak bisa ditahan atau dihindari.
Dialogue: 0,0:18:01.70,0:18:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih hidup, ya, Bocah Sialan!
Dialogue: 0,0:18:04.32,0:18:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selamat dari seranganku!
Dialogue: 0,0:18:06.52,0:18:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian lihat itu?
Dialogue: 0,0:18:08.37,0:18:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih bisa berdiri setelah\Nkena serangan Magia Vander.
Dialogue: 0,0:18:12.15,0:18:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukti apa lagi yang kalian mau?!
Dialogue: 0,0:18:15.02,0:18:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengakuimu!\NTempatmu bukan di bawah sana!
Dialogue: 0,0:18:19.77,0:18:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naiklah ke atas, Will Serfort!
Dialogue: 0,0:18:22.87,0:18:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu sebentar, Tuan Zeo!
Dialogue: 0,0:18:25.27,0:18:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penentuan faksi dalam pemekaran suci ini
Dialogue: 0,0:18:27.75,0:18:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak boleh dilakukan\Ndengan cara seperti ini!
Dialogue: 0,0:18:32.00,0:18:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau juga mau menerima seranganku?
Dialogue: 0,0:18:36.27,0:18:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kau juga bisa sepertinya, kan?
Dialogue: 0,0:18:40.32,0:18:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau sampai gagal,\Nharga dirimu akan hancur,
Dialogue: 0,0:18:44.52,0:18:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacamata Jelek!
Dialogue: 0,0:18:48.95,0:18:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Saya mengakui Will Serfort...
Dialogue: 0,0:18:58.47,0:19:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Artinya...
Dialogue: 0,0:19:01.10,0:19:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will Serfort boleh masuk faksi!
Dialogue: 0,0:19:12.60,0:19:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria?!
Dialogue: 0,0:19:19.10,0:19:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Elfie?!
Dialogue: 0,0:19:21.00,0:19:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah! Aku senang!
Dialogue: 0,0:19:31.87,0:19:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.\NAku tidak bisa apa-apa.
Dialogue: 0,0:19:35.00,0:19:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan minta maaf, Elfie.
Dialogue: 0,0:19:37.52,0:19:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersenyumlah.
Dialogue: 0,0:19:42.12,0:19:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah sampai.
Dialogue: 0,0:19:43.35,0:19:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tempatmu menunggu.
Dialogue: 0,0:19:57.05,0:20:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie!\NAku pasti akan ke menara!
Dialogue: 0,0:20:00.87,0:20:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lihat matahari terbenam bersama!
Dialogue: 0,0:20:03.92,0:20:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunggumu!
Dialogue: 0,0:20:05.52,0:20:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu menunggumu!
Dialogue: 0,0:20:10.97,0:20:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah menunggumu!
Dialogue: 0,0:20:12.50,0:20:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu menunggumu!
Dialogue: 0,0:21:45.75,0:21:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ini sudah jelas, tapi kamu\Ningin ke faksi mana, Will Serfort?
Dialogue: 0,0:21:52.35,0:21:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku ingin ke faksi Elfie...\N- Tidak!
Dialogue: 0,0:21:56.12,0:21:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ambil bocah ini.
Dialogue: 0,0:22:01.05,0:22:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bicara apa?\NLihatlah situasinya!
Dialogue: 0,0:22:03.27,0:22:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bodoh, ya? Kamu bejat, ya?\NKamu maling, ya?
Dialogue: 0,0:22:05.77,0:22:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pelakor, ya?\NKamu setan agama sesat, ya?
Dialogue: 0,0:22:07.95,0:22:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu penjahat, ya?\N- Elfie! Tenangla...
Dialogue: 0,0:22:08.98,0:22:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu ingin menjadi es serut, ya?\N- Elfie! Tenangla...
Dialogue: 0,0:22:11.15,0:22:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku ingin ke faksi Elfi...
Dialogue: 0,0:22:13.72,0:22:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fa-Faksi...
Dialogue: 0,0:22:17.75,0:22:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:22:20.20,0:22:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:22:22.12,0:22:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin bergabung ke faksiku, ya?
Dialogue: 0,0:22:24.07,0:22:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke kalau begitu!
Dialogue: 0,0:22:25.95,0:22:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ngaco!
Dialogue: 0,0:22:28.02,0:22:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan Will!
Dialogue: 0,0:22:30.37,0:22:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa ini? Apa yang terjadi?
Dialogue: 0,0:22:33.90,0:22:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya jadi rebutan.
Dialogue: 0,0:22:37.05,0:22:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roze, ka-kalau begitu...
Dialogue: 0,0:22:39.67,0:22:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia harus gabung dengan kita, deh!
Dialogue: 0,0:22:41.90,0:22:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Will sangat hebat!
Dialogue: 0,0:22:43.47,0:22:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan karena aku ingin\Nbersamanya di menara, lo!
Dialogue: 0,0:22:46.37,0:22:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang! Tenang!
Dialogue: 0,0:22:48.80,0:22:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu, Zeo?
Dialogue: 0,0:22:50.90,0:22:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu tidak ikut\Nmerekrutnya sejak awal?
Dialogue: 0,0:22:54.60,0:22:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru saja menginginkannya.
Dialogue: 0,0:22:56.45,0:22:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu.
Dialogue: 0,0:23:00.97,0:23:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasrat itu tidak bisa dirantai.
Dialogue: 0,0:23:03.10,0:23:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah pegangan hidupku.
Dialogue: 0,0:23:05.07,0:23:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta, minuman, wanita, atau pria,\Naku akan merebutnya, selama aku mau.
Dialogue: 0,0:23:08.90,0:23:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya hidup untuk merebut.
Dialogue: 0,0:23:11.72,0:23:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Biadab.
Dialogue: 0,0:23:13.50,0:23:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, logika yang begitu indah!
Dialogue: 0,0:23:18.57,0:23:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali.
Dialogue: 0,0:23:21.92,0:23:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak ingin menyerahkan Will\Nkepada siapa pun.
Dialogue: 0,0:23:26.80,0:23:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kamu jadi penghalang,\Naku akan menghancurkanmu!
Dialogue: 0,0:23:36.70,0:23:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.45,0:23:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode dua puluh tiga:\N"Es dan Petir Menggelegar".
