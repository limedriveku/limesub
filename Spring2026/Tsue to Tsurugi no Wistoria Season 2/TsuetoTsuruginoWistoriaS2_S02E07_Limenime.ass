Dialogue: 0,0:00:00.73,0:00:02.48,sign,,0000,0000,0000,,LANTAI SATU MENARA,\NGERBANG PENYELEKSIAN
Dialogue: 0,0:00:03.13,0:00:05.23,sign,,0000,0000,0000,,"LANTAI SATU MENARA, AULA PENYELEKSIAN"
Dialogue: 0,0:00:06.40,0:00:08.43,sign,,0000,0000,0000,,"PEMIMPIN FAKSI ANGIN, ARVIN OULUS"
Dialogue: 0,0:00:08.78,0:00:10.97,sign,,0000,0000,0000,,"AJUDAN FAKSI ES, SARISSA ALFELD"
Dialogue: 0,0:00:20.80,0:00:21.32,sign,,0000,0000,0000,,WILL SERFORT
Dialogue: 0,0:00:22.50,0:00:24.38,sign,,0000,0000,0000,,"JULIUS REINBERG"
Dialogue: 0,0:00:24.38,0:00:26.51,sign,,0000,0000,0000,,"FAKSI PETIR, LIHANNA OWENZAUS"
Dialogue: 0,0:00:26.88,0:00:28.51,sign,,0000,0000,0000,,"FAKSI TANAH, COLETTE LOIRE"
Dialogue: 0,0:00:37.68,0:00:40.10,sign,,0000,0000,0000,,"MAGIA VANDER, ALBIS VINA, ELFARIA ALBIS SERFORT"
Dialogue: 0,0:03:17.55,0:03:19.37,sign,,0000,0000,0000,,FAKSI API, SION ULSTER
Dialogue: 0,0:03:23.89,0:03:25.64,sign,,0000,0000,0000,,MAGIA VANDER, THORZEUS FASCE,\NZEO THORZEUS REINBOLT
Dialogue: 0,0:04:15.02,0:04:19.70,sign,,0000,0000,0000,,EPISODE 19:\NKEPUTUSAN BERHENTI MENUNDUK
Dialogue: 0,0:05:23.98,0:05:28.56,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:15:05.85,0:15:08.97,sign,,0000,0000,0000,,DWIPERAK WIST
Dialogue: 0,0:15:09.23,0:15:10.50,sign,,0000,0000,0000,,TONGKAT SIHIR ANGIN RIBUT
Dialogue: 0,0:15:10.50,0:15:13.98,sign,,0000,0000,0000,,EMMA CLEVER
Dialogue: 0,0:15:14.75,0:15:17.98,sign,,0000,0000,0000,,LANTAI SATU MENARA,\NPERSINGGAHAN SEMENTARA
Dialogue: 0,0:18:17.93,0:18:20.35,sign,,0000,0000,0000,,LANTAI PERTAMA MENARA, UJUNG TIMUR,\NPADANG RUMPUT SEPI
Dialogue: 0,0:21:34.94,0:21:36.48,sign,,0000,0000,0000,,JLEEB
Dialogue: 0,0:21:43.45,0:21:46.03,sign,,0000,0000,0000,,LANTAI SATU MENARA, COLORLESS GARDEN
Dialogue: 0,0:23:28.04,0:23:30.99,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:42.58,0:23:48.25,sign,,0000,0000,0000,,EPISODE 20: BIMBINGAN WANITA SIHIR
Dialogue: 0,0:00:03.13,0:00:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain bocah es itu,
Dialogue: 0,0:00:05.23,0:00:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak melihat
Dialogue: 0,0:00:06.40,0:00:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penyihir lain yang terlihat menjanjikan.
Dialogue: 0,0:00:08.78,0:00:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, masih ada satu.
Dialogue: 0,0:00:10.98,0:00:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menjadi pusat perhatian,\Nentah karena hal baik atau buruk.
Dialogue: 0,0:00:21.33,0:00:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa lari terus?
Dialogue: 0,0:00:22.50,0:00:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan, Anak Gagal?!
Dialogue: 0,0:00:24.38,0:00:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan. Sebenarnya...
Dialogue: 0,0:00:26.88,0:00:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang mengamati.
Dialogue: 0,0:00:29.08,0:00:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur, Kiki.
Dialogue: 0,0:00:32.70,0:00:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak sedih\Nkarena hal ini, ya, Elfie.
Dialogue: 0,0:00:37.68,0:00:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyesal karena tidak bisa merekrutku.
Dialogue: 0,0:00:41.18,0:00:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tidak apa-apa.
Dialogue: 0,0:00:43.43,0:00:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyusulmu\Ndengan kedua kakiku sendiri!
Dialogue: 0,0:00:59.93,0:01:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:01:00.83,0:01:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Lebih dari itu...
Dialogue: 0,0:01:02.53,0:01:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat.
Dialogue: 0,0:01:03.75,0:01:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membelah Zoctonia\Ndari atas melewati perisai.
Dialogue: 0,0:01:07.25,0:01:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa membaca\Nsemua pergerakan musuh?
Dialogue: 0,0:01:10.13,0:01:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam waktu sesingkat ini?
Dialogue: 0,0:01:12.18,0:01:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melihat pola gerakan itu!
Dialogue: 0,0:01:15.80,0:01:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergerakan lawanku\Ntampak jauh lebih jelas.
Dialogue: 0,0:01:18.72,0:01:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gloria-ku terasa ringan dan fleksibel.
Dialogue: 0,0:01:20.85,0:01:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bergerak leluasa.
Dialogue: 0,0:01:22.98,0:01:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Pak Donnan\Njuga bisa menebas apa saja.
Dialogue: 0,0:01:25.78,0:01:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku yakin\Nbisa melakukan apa pun.
Dialogue: 0,0:01:34.10,0:01:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada lagi?!
Dialogue: 0,0:01:37.87,0:01:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glace Itier!
Dialogue: 0,0:01:40.70,0:01:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:01:41.91,0:01:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirku nyasar!
Dialogue: 0,0:01:43.54,0:01:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, maaf!\NAku pinjam, ya!
Dialogue: 0,0:01:54.90,0:01:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan Imaji.
Dialogue: 0,0:01:57.51,0:01:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glauss Wis!
Dialogue: 0,0:01:59.56,0:02:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will...
Dialogue: 0,0:02:02.48,0:02:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Load Burst!
Dialogue: 0,0:02:08.97,0:02:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glauss Mill!
Dialogue: 0,0:02:15.57,0:02:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:02:17.50,0:02:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir badai salju dan pedang angin.
Dialogue: 0,0:02:19.58,0:02:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa itu benar-benar sihir?
Dialogue: 0,0:02:22.28,0:02:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah Wis\Nyang muncul saat Terminalia.
Dialogue: 0,0:02:26.58,0:02:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh,\NZoctonia-nya sudah dibabat habis.
Dialogue: 0,0:02:31.13,0:02:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gimana, nih?
Dialogue: 0,0:02:50.48,0:02:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkah dari Albis Vina.
Dialogue: 0,0:02:53.20,0:02:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undangan Faksi Es.
Dialogue: 0,0:02:55.70,0:02:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya itu.
Dialogue: 0,0:02:57.53,0:03:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Incindia Barham, Faksi Api,\Njuga memberikan berkah.
Dialogue: 0,0:03:01.20,0:03:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Faksi Tanah, Faksi Angin,\Ndan Faksi Kegelapan juga tertarik.
Dialogue: 0,0:03:06.68,0:03:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia bukan "multos"\Natau penyihir multiatribut,
Dialogue: 0,0:03:09.80,0:03:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia dapat berkah dari lima faksi.
Dialogue: 0,0:03:13.63,0:03:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya.
Dialogue: 0,0:03:15.05,0:03:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini belum pernah terjadi?
Dialogue: 0,0:03:19.39,0:03:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian enaknya diborong sendiri.
Dialogue: 0,0:03:26.03,0:03:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika menerima banyak berkah,
Dialogue: 0,0:03:28.28,0:03:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hak pilih akan diberikan\Nkepada yang bersangkutan.
Dialogue: 0,0:03:32.18,0:03:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memilih faksi mana, Will Serfort?
Dialogue: 0,0:03:43.40,0:03:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku—
Dialogue: 0,0:03:44.54,0:03:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:03:50.08,0:03:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirnya tadi bukanlah sesuatu\Nyang layak disebut sihir.
Dialogue: 0,0:05:30.83,0:05:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mempertimbangkan jasanya\Ndalam insiden Terminalia tempo hari,
Dialogue: 0,0:05:34.10,0:05:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia diberi kesempatan masuk menara.
Dialogue: 0,0:05:36.60,0:05:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu masih bisa diterima.
Dialogue: 0,0:05:38.60,0:05:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, apa dia benar-benar layak\Nbergabung dengan faksi bergengsi?
Dialogue: 0,0:05:43.11,0:05:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya masih meragukannya.
Dialogue: 0,0:05:46.10,0:05:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tidak melihatnya, Kreutz?
Dialogue: 0,0:05:49.35,0:05:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia baru saja menyerang dengan sihir.
Dialogue: 0,0:05:52.20,0:05:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya melihatnya, Nona Elfaria.
Dialogue: 0,0:05:55.50,0:06:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, meski menyerang dengan sihir,\Ndia hanya menggunakan sihir orang lain.
Dialogue: 0,0:06:00.70,0:06:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tetaplah bukan penyihir.
Dialogue: 0,0:06:03.75,0:06:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melainkan pendekar kasar.
Dialogue: 0,0:06:06.73,0:06:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengizinkan sosok selevel dwarf\Nmemasuki menara yang agung ini
Dialogue: 0,0:06:10.28,0:06:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berpotensi menuai kecaman dunia.
Dialogue: 0,0:06:13.85,0:06:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayangkannya saja\Nsudah membuat saya takut.
Dialogue: 0,0:06:17.03,0:06:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bertele-tele! Apa maumu?
Dialogue: 0,0:06:20.35,0:06:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sederhana saja, Nona Ellenor.
Dialogue: 0,0:06:23.10,0:06:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia memang punya\Nsedikit bakat tongkat sihir,
Dialogue: 0,0:06:26.41,0:06:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia harus membuktikannya.
Dialogue: 0,0:06:41.68,0:06:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah "creature" penekan dwarf\Nyang kami kembangkan, Wors Ooze.
Dialogue: 0,0:06:47.47,0:06:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan menyaksikan.
Dialogue: 0,0:06:49.05,0:06:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Crysto Wreath.
Dialogue: 0,0:06:54.03,0:06:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dilihat sendiri,\Nwalau dengan sihir kecil,
Dialogue: 0,0:06:56.25,0:06:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka akan hancur\Njika terkena energi sihir.
Dialogue: 0,0:06:58.94,0:07:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan sebaliknya, makhluk berlendir itu
Dialogue: 0,0:07:02.44,0:07:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan bisa dikalahkan\Njika tidak punya energi sihir.
Dialogue: 0,0:07:13.83,0:07:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangku tidak mempan.
Dialogue: 0,0:07:16.08,0:07:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti saat melawan Balkar.
Dialogue: 0,0:07:19.20,0:07:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk ini kebal serangan fisik.
Dialogue: 0,0:07:28.26,0:07:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gimana, nih?
Dialogue: 0,0:07:31.30,0:07:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata-kata Kreutz ada benarnya.
Dialogue: 0,0:07:34.58,0:07:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lihat pertarungan ini.
Dialogue: 0,0:07:37.80,0:07:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai Magia Vander,\Naku harus mengatakan ini.
Dialogue: 0,0:07:41.40,0:07:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menara adalah puncak dunia sihir.
Dialogue: 0,0:07:44.03,0:07:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan tempatnya pedang
Dialogue: 0,0:07:46.28,0:07:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tidak bisa menggunakan\Nsihir sendiri.
Dialogue: 0,0:07:51.85,0:07:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seranganku tidak berarti.
Dialogue: 0,0:07:54.58,0:07:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, creature buatan\Npasti memiliki semacam inti.
Dialogue: 0,0:07:58.50,0:08:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu dihancurkan...
Dialogue: 0,0:08:04.40,0:08:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemikiran dangkal.
Dialogue: 0,0:08:07.70,0:08:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tubuhnya bisa jadi cairan lendir,
Dialogue: 0,0:08:10.09,0:08:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kamu berpikir intinya\Ntidak bisa jadi cairan lendir juga?
Dialogue: 0,0:08:14.22,0:08:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan puncak dunia sihir!
Dialogue: 0,0:08:17.73,0:08:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menara!
Dialogue: 0,0:08:20.85,0:08:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setrum?!
Dialogue: 0,0:08:27.86,0:08:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan setrum pengejut\Nyang bisa melumpuhkan dwarf.
Dialogue: 0,0:08:31.28,0:08:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, makhluk ciptaanmu\Nculas sekali, Kreutz.
Dialogue: 0,0:08:38.53,0:08:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:08:40.04,0:08:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini buruk?
Dialogue: 0,0:08:41.58,0:08:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, dia...
Dialogue: 0,0:08:52.70,0:08:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga sudah jadi penyihir senior!
Dialogue: 0,0:08:56.55,0:09:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia bisa memakai Wis\Ndengan bantuan sihir kita...
Dialogue: 0,0:09:04.45,0:09:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan macam-macam!
Dialogue: 0,0:09:07.10,0:09:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah bukan audisi untuk kalian.
Dialogue: 0,0:09:10.53,0:09:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah pengadilan\Nuntuk mengadili unsur asing.
Dialogue: 0,0:09:30.93,0:09:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kemampuanmu lebih dari ini!
Dialogue: 0,0:09:53.25,0:09:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum!
Dialogue: 0,0:09:55.70,0:09:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum menyerah!
Dialogue: 0,0:10:04.90,0:10:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya akan buang-buang waktu.
Dialogue: 0,0:10:07.88,0:10:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang tidak layak.
Dialogue: 0,0:10:13.35,0:10:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya dia tetap jadi Tanpa Warna
Dialogue: 0,0:10:15.33,0:10:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menempati posisi terakhir\Ndi Institut Tinggi.
Dialogue: 0,0:10:20.10,0:10:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Wis\Nyang bisa mengalahkan Devander
Dialogue: 0,0:10:23.06,0:10:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memang luar biasa.
Dialogue: 0,0:10:27.30,0:10:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan menguak misterinya
Dialogue: 0,0:10:29.78,0:10:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuat kekuatan itu\Nberkontribusi untuk dunia sihir.
Dialogue: 0,0:10:35.28,0:10:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kelinci percobaan, ya.
Dialogue: 0,0:10:38.53,0:10:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kita bisa mengungkap\Ndan memanfaatkan Elemen Kelima,
Dialogue: 0,0:10:42.80,0:10:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}entah di mana pun tempatnya nanti,\Naku tidak akan keberatan.
Dialogue: 0,0:10:47.45,0:10:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:10:54.98,0:10:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan marah seperti\Nanak kecil tantrum, Elfaria.
Dialogue: 0,0:11:00.00,0:11:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kreutz, seharusnya tidak begini.
Dialogue: 0,0:11:03.35,0:11:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku sedang naik pitam!
Dialogue: 0,0:11:09.45,0:11:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Elfie?
Dialogue: 0,0:11:11.60,0:11:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ocehan kalian bikin pusing,\Ndasar jalang dan sejenisnya!
Dialogue: 0,0:11:19.74,0:11:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemekaran akan diadakan lagi.
Dialogue: 0,0:11:22.48,0:11:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simpan ocehan kalian sampai saat itu.
Dialogue: 0,0:11:26.98,0:11:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, pemekaran berikutnya\Nakan diadakan setengah tahun lagi.
Dialogue: 0,0:11:31.55,0:11:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, karena insiden Terminalia,
Dialogue: 0,0:11:34.48,0:11:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setiap faksi harus mengisi\Nkekurangan personel mereka.
Dialogue: 0,0:11:39.28,0:11:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya sebagai pengecualian,
Dialogue: 0,0:11:41.45,0:11:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Second Bloom tahun ini\Nakan diadakan seminggu lagi.
Dialogue: 0,0:11:46.00,0:11:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian adalah Generasi Berliku\Nyang memiliki potensi terbesar
Dialogue: 0,0:11:50.03,0:11:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena berhasil selamat\Ndari tragedi kejam itu.
Dialogue: 0,0:11:53.38,0:11:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, menara—\NTidak.
Dialogue: 0,0:11:55.70,0:11:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh dunia mengharapkan kalian.
Dialogue: 0,0:11:58.66,0:12:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang bisa repot kalau kalian\Ntidak berjuang hingga muntah darah.
Dialogue: 0,0:12:02.88,0:12:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian yang belum\Nmenerima berkah hari ini,
Dialogue: 0,0:12:06.80,0:12:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bangkitlah di pemekaran berikutnya.
Dialogue: 0,0:12:09.65,0:12:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga, ya, Will Serfort.
Dialogue: 0,0:12:14.05,0:12:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian setuju dengan ini?
Dialogue: 0,0:12:16.53,0:12:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Institut Tinggi dan Magia Vander.
Dialogue: 0,0:12:19.70,0:12:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aturan menara hanya satu,\Nyaitu menunjukkan kehebatan.
Dialogue: 0,0:12:25.81,0:12:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:12:27.20,0:12:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pun juga menjadi Magia Vander
Dialogue: 0,0:12:29.00,0:12:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah berulang kali\Nmenunjukkan kehebatan.
Dialogue: 0,0:12:44.90,0:12:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelucon ini sudah berakhir.
Dialogue: 0,0:13:05.45,0:13:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya...
Dialogue: 0,0:13:13.00,0:13:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will...
Dialogue: 0,0:13:17.98,0:13:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang-buang waktu saja.
Dialogue: 0,0:13:19.73,0:13:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa menghela napas.
Dialogue: 0,0:13:31.75,0:13:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus melewati ujian seperti ini\Nsatu minggu lagi?
Dialogue: 0,0:13:36.10,0:13:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:13:44.90,0:13:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau menangis?
Dialogue: 0,0:13:46.60,0:13:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:13:48.40,0:13:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya merasa konyol.
Dialogue: 0,0:13:51.45,0:13:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konyol?
Dialogue: 0,0:13:53.10,0:13:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:57.23,0:14:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hadapan cobaan atau kesulitan,
Dialogue: 0,0:14:00.18,0:14:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat mulai melihat harapan,\Naku selalu dijatuhkan dengan keras.
Dialogue: 0,0:14:13.87,0:14:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:14:16.13,0:14:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan berhenti berjuang\Nuntuk melewati kesulitan ini!
Dialogue: 0,0:14:28.20,0:14:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak terduga.
Dialogue: 0,0:14:30.28,0:14:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya, Guil?
Dialogue: 0,0:14:32.33,0:14:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Zeo tidak memberi berkah\Nkepada Will Serfort.
Dialogue: 0,0:14:38.95,0:14:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya kira Anda menyukai\Norang-orang seperti itu.
Dialogue: 0,0:14:45.33,0:14:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.\NKau masih belum memahamiku.
Dialogue: 0,0:14:56.21,0:15:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang merangkak\Ndari dasar itu lebih menarik
Dialogue: 0,0:15:01.15,0:15:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sudah pasti kuat.
Dialogue: 0,0:15:17.98,0:15:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api, angin, tanah, petir,\Nair, kegelapan, dan cahaya.
Dialogue: 0,0:15:25.20,0:15:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuh atribut selain sihir elf ini\Nmembutuhkan pendekatan baru.
Dialogue: 0,0:15:30.83,0:15:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nol Besar sepertiku\Ntidak memiliki atribut apa pun.
Dialogue: 0,0:15:34.10,0:15:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, meski tidak bisa sihir,\Nbisa saja aku memakai energi sihir.
Dialogue: 0,0:15:37.87,0:15:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faktanya, aku berhasil\Nmembuktikannya dengan Wis.
Dialogue: 0,0:15:41.85,0:15:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku meneliti fenomena ini\Ndan belajar menggunakan energi sihir...
Dialogue: 0,0:15:46.55,0:15:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah pemekaran kemarin,\Ndia langsung belajar semalaman.
Dialogue: 0,0:15:51.13,0:15:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang aneh.
Dialogue: 0,0:15:53.60,0:15:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:15:55.80,0:15:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Pembelaja—
Dialogue: 0,0:15:57.45,0:16:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah. Hei, boleh kupanggil "Will"?
Dialogue: 0,0:16:02.15,0:16:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kok.
Dialogue: 0,0:16:04.05,0:16:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu yang menyapaku\Nsetelah Turnamen Sihir Agung?
Dialogue: 0,0:16:09.00,0:16:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Emma Clever.
Dialogue: 0,0:16:10.60,0:16:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berencana pergi ke dungeon\Nsampai pemekaran berikutnya.
Dialogue: 0,0:16:15.13,0:16:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah dapat izin dari Institut Tinggi.
Dialogue: 0,0:16:17.66,0:16:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian mau latihan?
Dialogue: 0,0:16:20.17,0:16:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:21.43,0:16:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir senior sudah diizinkan\Nmelewati strata sepuluh.
Dialogue: 0,0:16:25.83,0:16:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengalahkan penjaga itu,
Dialogue: 0,0:16:27.78,0:16:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami hanya bisa bekerja sama\Ndan latihan bersama.
Dialogue: 0,0:16:32.30,0:16:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Gordon\Njuga ingin masuk Faksi Api
Dialogue: 0,0:16:34.43,0:16:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyusul Sion.
Dialogue: 0,0:16:36.31,0:16:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa kamu mau ikut?
Dialogue: 0,0:16:38.43,0:16:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang tidak bisa\Nmenghapus kesalahan kami,
Dialogue: 0,0:16:42.93,0:16:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau kamu mau...
Dialogue: 0,0:16:46.20,0:16:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Tentu saja—
Dialogue: 0,0:16:47.88,0:16:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:16:50.38,0:16:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak Gagal ini akan latihan denganku!
Dialogue: 0,0:16:52.78,0:16:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?! Apa maksudmu?
Dialogue: 0,0:16:54.55,0:16:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius?
Dialogue: 0,0:16:55.73,0:16:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kau tidak butuh\Nsandiwara pertemanan!
Dialogue: 0,0:16:59.71,0:17:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melainkan cara mengendalikan Wis!
Dialogue: 0,0:17:03.33,0:17:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengendalikan?
Dialogue: 0,0:17:04.71,0:17:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membantumu!
Dialogue: 0,0:17:08.73,0:17:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang dengan tawaranmu,\Ntapi kenapa kamu melakukan itu?
Dialogue: 0,0:17:13.45,0:17:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita memang sering bertengkar,
Dialogue: 0,0:17:15.70,0:17:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sama seperti\NWignall dan yang lainnya,
Dialogue: 0,0:17:23.25,0:17:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah menganggapmu teman.
Dialogue: 0,0:17:27.59,0:17:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Teman?
Dialogue: 0,0:17:30.11,0:17:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Julius!\NTolong, ya!
Dialogue: 0,0:17:33.36,0:17:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman. Teman. Teman.
Dialogue: 0,0:17:37.03,0:17:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempurna.
Dialogue: 0,0:17:38.30,0:17:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang mau membantu Nol Besar.
Dialogue: 0,0:17:41.63,0:17:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua demi masa depanku sendiri.
Dialogue: 0,0:17:45.38,0:17:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Makasih, Julius!\N- Jika aku bantu temannya Nona Elfaria,
Dialogue: 0,0:17:47.65,0:17:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semuanya berkat kamu!\N- Jika aku bantu temannya Nona Elfaria,
Dialogue: 0,0:17:49.75,0:17:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan dapat poin positif.
Dialogue: 0,0:17:51.53,0:17:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Setelah itu, kehormatanku akan balik.\N- Kamu lumayan. Aku salah menilaimu.
Dialogue: 0,0:17:55.43,0:17:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memanfaatkan\Nanak setengah dwarf ini,
Dialogue: 0,0:17:58.03,0:18:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan masuk Faksi Es.
Dialogue: 0,0:18:01.53,0:18:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lama-lama, Anak Gagal!
Dialogue: 0,0:18:04.23,0:18:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo mulai latihannya sekarang!
Dialogue: 0,0:18:11.35,0:18:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:18:24.03,0:18:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan Imaji.
Dialogue: 0,0:18:27.18,0:18:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glauss Wis.
Dialogue: 0,0:18:29.63,0:18:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melakukannya\Nsesuai instruksimu.
Dialogue: 0,0:18:31.95,0:18:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang bagaimana?
Dialogue: 0,0:18:33.83,0:18:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahankan keadaan itu.
Dialogue: 0,0:18:37.30,0:18:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisikan beku.\NRedakan dan menarilah.
Dialogue: 0,0:18:42.06,0:18:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu adalah pelindung\Nsekaligus burung es.
Dialogue: 0,0:18:48.90,0:18:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fridde Gardinas!
Dialogue: 0,0:18:52.57,0:18:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:18:54.05,0:18:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski hanya guardian tingkat bawah,\Nmereka punya energi sihir cukup banyak.
Dialogue: 0,0:18:58.00,0:18:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kena energi sihir lemah sejenis,
Dialogue: 0,0:18:59.93,0:19:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tidak akan hancur.
Dialogue: 0,0:19:02.65,0:19:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus latihan bertarung\Nsambil menekan daya keluaran,
Dialogue: 0,0:19:05.78,0:19:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa menghancurkan guardian ini.
Dialogue: 0,0:19:08.40,0:19:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:19:10.98,0:19:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus bisa mengaktifkan Wis sendiri.
Dialogue: 0,0:19:17.09,0:19:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama enam tahun di akademi,\Nkau tidak bisa menggunakan sihir dasar.
Dialogue: 0,0:19:23.35,0:19:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada belajar sihir yang sudah ada,
Dialogue: 0,0:19:26.50,0:19:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menguasai kekuatan yang kau miliki\Nadalah pilihan yang lebih membangun.
Dialogue: 0,0:19:31.35,0:19:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang benar,\Ntapi bagaimana caranya?
Dialogue: 0,0:19:36.85,0:19:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak bisa sihir,\Naku menyerap sihir orang lain,
Dialogue: 0,0:19:40.93,0:19:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengandalkan\Nenergi sihir dari luar.
Dialogue: 0,0:19:43.43,0:19:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyiapkan sihir sendiri\Nuntuk mengaktifkan Wis
Dialogue: 0,0:19:46.40,0:19:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah hal kontradiktif.
Dialogue: 0,0:19:47.90,0:19:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama saja menciptakan sihir baru,\Nbagaikan menciptakan sesuatu dari nol.
Dialogue: 0,0:19:52.13,0:19:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, diamlah! Buang teori itu!
Dialogue: 0,0:19:55.15,0:19:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu pergi ke pelabuhan\Nyang entah bisa dicapai atau tidak.
Dialogue: 0,0:19:58.89,0:20:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasmu saat ini sangat sederhana.
Dialogue: 0,0:20:02.23,0:20:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penambatan energi sihir.
Dialogue: 0,0:20:04.55,0:20:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penambatan?
Dialogue: 0,0:20:08.18,0:20:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski hanya meminjam dariku,
Dialogue: 0,0:20:10.50,0:20:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika energi sihir itu tertambat padamu,\Nmaka itu akan menjadi sihirmu sendiri.
Dialogue: 0,0:20:16.15,0:20:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika biasanya kau butuh\Nseratus daya keluaran,
Dialogue: 0,0:20:18.98,0:20:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurangilah jadi seperseratus\Natau seperseribu.
Dialogue: 0,0:20:21.40,0:20:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, tekan daya keluarannya\Ndan pertahankan energi sihirnya.
Dialogue: 0,0:20:25.18,0:20:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahankan energi itu\Ndalam kehidupan sehari-hari,
Dialogue: 0,0:20:27.30,0:20:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan saat tidur.
Dialogue: 0,0:20:29.85,0:20:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus bisa mengendalikannya
Dialogue: 0,0:20:31.60,0:20:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai bisa meningkatkan\Ndaya keluaran saat bertarung saja.
Dialogue: 0,0:20:34.92,0:20:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu sudah bisa disebut...
Dialogue: 0,0:20:37.38,0:20:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir.
Dialogue: 0,0:20:44.43,0:20:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti harus melawan Ooze\Nsaat pemekaran berikutnya.
Dialogue: 0,0:20:49.03,0:20:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka telah menunjukkan
Dialogue: 0,0:20:50.94,0:20:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa energi sihir lemah pun cukup\Nuntuk menghancurkannya.
Dialogue: 0,0:20:54.44,0:20:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau harus mengalahkannya,
Dialogue: 0,0:20:56.33,0:20:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}energi sihir kecil pun\Nsudah lebih dari cukup.
Dialogue: 0,0:21:00.15,0:21:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seminggu itu terlalu terbatas\Nuntuk mencoba banyak hal baru!
Dialogue: 0,0:21:03.48,0:21:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapkan satu tujuan dan kurangi PR-mu!
Dialogue: 0,0:21:06.93,0:21:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cuma mencoba apa saja\Ntanpa memikirkan manfaatnya!
Dialogue: 0,0:21:10.30,0:21:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk tidak menghancurkan guardian\Ndalam simulasi pertempuran nyata ini,
Dialogue: 0,0:21:14.05,0:21:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus bisa menambatkan\Ndan mempertahankan energi sihir.
Dialogue: 0,0:21:18.38,0:21:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini latihan mengendalikan energi sihir\Ndengan guardian sebagai pengekang.
Dialogue: 0,0:21:22.63,0:21:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat. Ini masuk akal.
Dialogue: 0,0:21:25.40,0:21:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pantas menduduki\Nposisi ketiga di akademi.
Dialogue: 0,0:21:28.95,0:21:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Julius!
Dialogue: 0,0:21:31.10,0:21:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa orang sehebat kamu\Ntidak direkrut faksi mana pun, ya?
Dialogue: 0,0:21:36.48,0:21:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kau biang keroknya!
Dialogue: 0,0:21:38.90,0:21:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:21:53.20,0:21:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa muda, ya.
Dialogue: 0,0:21:55.50,0:21:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira bagaimana ya\Nhasil latihan mereka berdua?
Dialogue: 0,0:23:36.55,0:23:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.40,0:23:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode dua puluh:\N"Bimbingan Wanita Sihir".
