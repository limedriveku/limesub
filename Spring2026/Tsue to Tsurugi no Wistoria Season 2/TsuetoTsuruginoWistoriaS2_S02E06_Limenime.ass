Dialogue: 0,0:01:15.10,0:01:19.78,tanda,,0000,0000,0000,,EPISODE 18: FIRST BLOOM
Dialogue: 0,0:02:24.06,0:02:28.64,tanda,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:02:31.40,0:02:32.56,tanda,,0000,0000,0000,,DISTRIK BANGSAWAN,\NBUTIK BUSANA MEWAH, LES AILES
Dialogue: 0,0:02:54.76,0:02:56.66,tanda,,0000,0000,0000,,"BRANDTAL LES AILES"
Dialogue: 0,0:04:57.99,0:04:59.11,tanda,,0000,0000,0000,,SLUMLAND STREET,\NPANDAI BESI DONNAN
Dialogue: 0,0:07:24.84,0:07:27.52,tanda,,0000,0000,0000,,LANTAI PERTAMA MENARA,\NCOLORLESS GARDEN
Dialogue: 0,0:10:14.98,0:10:16.06,tanda,,0000,0000,0000,,GERBANG PENYELEKSIAN
Dialogue: 0,0:10:22.50,0:10:24.81,tanda,,0000,0000,0000,,AULA UPACARA PENYELEKSIAN
Dialogue: 0,0:10:40.38,0:10:40.83,tanda,,0000,0000,0000,,KREUTZ HARLON
Dialogue: 0,0:10:54.32,0:10:55.68,tanda,,0000,0000,0000,,MAGIA VANDER, PEMIMPIN FAKSI ES\NALBIS VINA
Dialogue: 0,0:10:55.68,0:10:56.47,tanda,,0000,0000,0000,,ELFARIA ALBIS SERFORT
Dialogue: 0,0:10:56.92,0:10:58.24,tanda,,0000,0000,0000,,MAGIA VANDER, PEMIMPIN FAKSI PETIR\NTHORZEUS FASCE
Dialogue: 0,0:10:58.24,0:10:59.14,tanda,,0000,0000,0000,,ZEO THORZEUS REINBOLT
Dialogue: 0,0:10:59.60,0:11:00.88,tanda,,0000,0000,0000,,MAGIA VANDER, PEMIMPIN FAKSI API\NINCINDIA BARHAM
Dialogue: 0,0:11:00.88,0:11:01.85,tanda,,0000,0000,0000,,CARIOT INCINDIA WISEMAN
Dialogue: 0,0:11:02.36,0:11:03.74,tanda,,0000,0000,0000,,MAGIA VANDER, PEMIMPIN FAKSI ELF\NELLEAF CANAAN
Dialogue: 0,0:11:03.74,0:11:04.60,tanda,,0000,0000,0000,,ELLENOR LJOS ALF
Dialogue: 0,0:12:47.18,0:12:50.46,tanda,,0000,0000,0000,,FAKSI API, SHION ULSTER
Dialogue: 0,0:12:51.30,0:12:54.46,tanda,,0000,0000,0000,,FAKSI PETIR, LIHANNA OWENZAUS
Dialogue: 0,0:12:55.30,0:12:58.47,tanda,,0000,0000,0000,,FAKSI ELF, WIGNALL LINDOR
Dialogue: 0,0:12:59.46,0:13:02.47,tanda,,0000,0000,0000,,FAKSI TANAH, COLETTE LOIRE
Dialogue: 0,0:13:27.34,0:13:28.52,tanda,,0000,0000,0000,,TONGKAT SIHIR SINTESIS
Dialogue: 0,0:13:28.52,0:13:32.00,tanda,,0000,0000,0000,,KREUTZ HARLON
Dialogue: 0,0:13:33.76,0:13:37.00,tanda,,0000,0000,0000,,COLORLESS GARDEN
Dialogue: 0,0:13:37.26,0:13:38.31,tanda,,0000,0000,0000,,SEHARI SEBELUMNYA
Dialogue: 0,0:23:43.88,0:23:47.76,tanda,,0000,0000,0000,,EPISODE 19:\NKEPUTUSAN BERHENTI MENUNDUK
Dialogue: 0,0:00:01.42,0:00:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya matahari terbenam itu\Nada di ujung terowongan panjang.
Dialogue: 0,0:00:06.58,0:00:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus melewati banyak bahaya\Nuntuk mencapainya.
Dialogue: 0,0:00:09.99,0:00:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mempelajari\Nbanyak sihir dan bersiap-siap.
Dialogue: 0,0:00:14.44,0:00:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menceritakan impian,\Nmatamu begitu indah bagai permata.
Dialogue: 0,0:00:20.28,0:00:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu berkilau,\Nsedangkan aku terlalu redup.
Dialogue: 0,0:00:24.88,0:00:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kamu bisa melakukannya.
Dialogue: 0,0:00:27.04,0:00:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku...
Dialogue: 0,0:00:29.13,0:00:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:00:33.06,0:00:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus ikut, Will!
Dialogue: 0,0:00:37.44,0:00:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tidak ada kamu,\Nsemuanya tidak akan berarti.
Dialogue: 0,0:00:43.44,0:00:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mari pergi bersama.
Dialogue: 0,0:00:49.10,0:00:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima tahun telah berlalu.
Dialogue: 0,0:00:52.26,0:00:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku akan menyusulmu.
Dialogue: 0,0:02:32.62,0:02:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kearifan, inspirasi,\Ndan ilmu pengetahuan.
Dialogue: 0,0:02:36.02,0:02:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga ajaran dasar\NAkademi Sihir Rigarden
Dialogue: 0,0:02:38.50,0:02:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan siapa pun orang\Nyang berhasil menguasainya
Dialogue: 0,0:02:42.00,0:02:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka mereka diizinkan
Dialogue: 0,0:02:43.54,0:02:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengenakan Colorless Gloria,\Natau lambang penyihir senior ini.
Dialogue: 0,0:02:47.54,0:02:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:02:49.20,0:02:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampak sempurna.
Dialogue: 0,0:02:51.42,0:02:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya merasa terhormat karena\Ndipercaya membuatkan busana
Dialogue: 0,0:02:54.76,0:02:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk para penyongsong masa depan.
Dialogue: 0,0:02:58.68,0:03:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa ringan\Ndan mudah bergerak.
Dialogue: 0,0:03:00.56,0:03:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ada resistansi sihirnya.
Dialogue: 0,0:03:03.18,0:03:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seragam akademi memang\Nsudah bagus sebagai pelindung,
Dialogue: 0,0:03:06.44,0:03:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini lebih bagus lagi.
Dialogue: 0,0:03:08.74,0:03:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir memang mahir\Nmembuat benda-benda seperti ini.
Dialogue: 0,0:03:12.10,0:03:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukurannya juga pas.
Dialogue: 0,0:03:13.92,0:03:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sejak generasi terdahulu,
Dialogue: 0,0:03:15.94,0:03:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kualitas produk kalian\Ntetap luar biasa, Brandtal.
Dialogue: 0,0:03:18.76,0:03:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya,\NTuan Muda Sion.
Dialogue: 0,0:03:21.46,0:03:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf karena\Nbaru bisa menyerahkannya
Dialogue: 0,0:03:24.60,0:03:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di hari keberangkatan Anda.
Dialogue: 0,0:03:26.06,0:03:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:03:27.78,0:03:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang juga terkena\Ndampak insiden Terminalia.
Dialogue: 0,0:03:33.74,0:03:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini busana resmi\Nuntuk memanjat menara, ya?
Dialogue: 0,0:03:37.64,0:03:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Julius?
Dialogue: 0,0:03:39.32,0:03:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak kurang semangat.
Dialogue: 0,0:03:41.46,0:03:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:03:42.70,0:03:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pedulikan aku!
Dialogue: 0,0:03:48.02,0:03:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette, sialan!
Dialogue: 0,0:03:49.92,0:03:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar ratu penghancur\Nyang terkutuk!
Dialogue: 0,0:03:52.67,0:03:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf!
Dialogue: 0,0:03:54.06,0:03:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku! Maafkan aku!
Dialogue: 0,0:03:55.98,0:03:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:03:57.24,0:03:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja seperti itu.
Dialogue: 0,0:03:58.68,0:04:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:04:03.48,0:04:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius aneh banget.
Dialogue: 0,0:04:06.08,0:04:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette.
Dialogue: 0,0:04:07.12,0:04:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu sudah direkrut\Nfaksi menara?
Dialogue: 0,0:04:09.76,0:04:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama dapat surat\Ndari Faksi Tanah.
Dialogue: 0,0:04:13.57,0:04:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku direkrut Faksi Petir.
Dialogue: 0,0:04:15.66,0:04:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wignall direkrut Faksi Elf.
Dialogue: 0,0:04:17.24,0:04:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion direkrut Faksi Api.\NDan undangannya sudah sampai.
Dialogue: 0,0:04:21.33,0:04:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan Julius belum direkrut.
Dialogue: 0,0:04:24.52,0:04:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah sebabnya.
Dialogue: 0,0:04:26.48,0:04:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah sentuhan terakhir.
Dialogue: 0,0:04:29.40,0:04:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko kami telah membuat
Dialogue: 0,0:04:31.92,0:04:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak gloria untuk orang-orang\Nyang berangkat menuju menara.
Dialogue: 0,0:04:37.06,0:04:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga perlindungan Ratu Penyihir\Nsenantiasa menyertai Anda sekalian.
Dialogue: 0,0:04:42.04,0:04:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, di mana Will?
Dialogue: 0,0:04:44.46,0:04:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum melihatnya.
Dialogue: 0,0:04:45.96,0:04:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Serfort telah datang\Nsebelum Anda sekalian.
Dialogue: 0,0:04:51.04,0:04:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau tampak terburu-buru\Nsaat meninggalkan tempat ini.
Dialogue: 0,0:04:55.02,0:04:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang,
Dialogue: 0,0:04:56.36,0:04:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pasti di tempat Pak Donnan.
Dialogue: 0,0:05:04.08,0:05:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambillah, Will.
Dialogue: 0,0:05:05.54,0:05:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pedang barumu.
Dialogue: 0,0:05:07.54,0:05:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari patahan pedang perak Moria\Nyang dilengkapi permata Wist.
Dialogue: 0,0:05:12.44,0:05:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang ini bisa menebas sihir
Dialogue: 0,0:05:14.62,0:05:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melipatgandakan energi sihir\Nyang tersimpan di permatanya.
Dialogue: 0,0:05:19.36,0:05:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya "Dwiperak Wist".
Dialogue: 0,0:05:22.13,0:05:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dwiperak Wist.
Dialogue: 0,0:05:25.74,0:05:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang sebelumnya\Nadalah karya kebanggaanku.
Dialogue: 0,0:05:28.80,0:05:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah kau patahkan begitu saja.
Dialogue: 0,0:05:30.70,0:05:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kehilangan muka\Ngara-gara kekuatanmu itu.
Dialogue: 0,0:05:34.10,0:05:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Pak Donnan.
Dialogue: 0,0:05:36.22,0:05:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:37.90,0:05:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya. Berapa harganya?
Dialogue: 0,0:05:39.90,0:05:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah.
Dialogue: 0,0:05:41.52,0:05:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja hadiah\Nkarena menyelamatkan kami.
Dialogue: 0,0:05:44.28,0:05:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah, Ahli Sihir Pedang.
Dialogue: 0,0:05:46.96,0:05:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengamuklah di menara!
Dialogue: 0,0:05:50.04,0:05:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:05:51.79,0:05:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu dia!
Dialogue: 0,0:05:54.56,0:05:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:05:56.04,0:05:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu sudah siap?
Dialogue: 0,0:05:58.06,0:05:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Maaf sudah menunggu.
Dialogue: 0,0:05:59.82,0:06:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita berangkat sekarang!
Dialogue: 0,0:06:01.55,0:06:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke menara!
Dialogue: 0,0:06:10.16,0:06:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lengkap 50 orang, ya.
Dialogue: 0,0:06:12.81,0:06:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gloria baru kalian tampak silau.
Dialogue: 0,0:06:16.30,0:06:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi satu-satunya pemandu\Nkarena kami sedang krisis orang,
Dialogue: 0,0:06:20.58,0:06:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku akan jadi pemandu\Nyang baik untuk kalian.
Dialogue: 0,0:06:23.57,0:06:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ahay!
Dialogue: 0,0:06:24.95,0:06:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia benar-benar penyihir senior?
Dialogue: 0,0:06:27.95,0:06:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sepertinya kalian\Nsudah cukup bersemangat.
Dialogue: 0,0:06:32.84,0:06:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari pergi sekarang.
Dialogue: 0,0:06:35.96,0:06:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang\Ndi surga pencarian ilmu
Dialogue: 0,0:06:37.70,0:06:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan neraka penggemblengan,\Nwahai anak-anak piyik baru.
Dialogue: 0,0:06:47.50,0:06:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai sejauh ini\Nberkat bantuanmu, Rosty.
Dialogue: 0,0:06:51.96,0:06:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang, Elfie.
Dialogue: 0,0:07:01.18,0:07:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:07:03.20,0:07:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa.
Dialogue: 0,0:07:04.99,0:07:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Acces, Clairie Serah.
Dialogue: 0,0:07:07.92,0:07:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gate, Unlock.
Dialogue: 0,0:07:11.92,0:07:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langit-langitnya terbuka?
Dialogue: 0,0:07:13.36,0:07:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya itu.
Dialogue: 0,0:07:14.84,0:07:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:07:16.00,0:07:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pijakannya bergerak?
Dialogue: 0,0:07:17.98,0:07:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terangkat ke atas?
Dialogue: 0,0:07:27.58,0:07:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:07:29.85,0:07:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota putih...\NBukan, kota tanpa warna?
Dialogue: 0,0:07:33.22,0:07:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada langitnya!
Dialogue: 0,0:07:34.54,0:07:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada cakrawala juga!\NBahkan ada cahaya di sini!
Dialogue: 0,0:07:36.84,0:07:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rose, awas jatuh!
Dialogue: 0,0:07:38.48,0:07:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Istananya melayang.
Dialogue: 0,0:07:40.76,0:07:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:07:42.22,0:07:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini sungguh di dalam menara?
Dialogue: 0,0:07:45.24,0:07:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah Colorless Garden,\Nlantai satu di dalam menara.
Dialogue: 0,0:07:49.32,0:07:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istilah "Institut Tinggi"\Nyang disebut orang-orang luar
Dialogue: 0,0:07:51.92,0:07:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}umumnya merujuk pada\Nfasilitas besar di lantai satu ini.
Dialogue: 0,0:07:54.87,0:07:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Basis produksi\Ndan landasan kehidupan
Dialogue: 0,0:07:57.06,0:07:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menopang menara\Ndari ujung bawah hingga atas.
Dialogue: 0,0:07:59.74,0:08:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekaligus institusi akademis tertinggi
Dialogue: 0,0:08:01.90,0:08:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk meneliti\Ndan mengembangkan sihir baru.
Dialogue: 0,0:08:04.20,0:08:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah kejayaan bagi para penyihir
Dialogue: 0,0:08:08.16,0:08:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tidak bisa dicapai\Ntanpa pengakuan Akademi Sihir.
Dialogue: 0,0:08:12.40,0:08:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah!
Dialogue: 0,0:08:13.80,0:08:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:08:15.14,0:08:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian,
Dialogue: 0,0:08:16.56,0:08:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau di sini terus pun\Njuga tergantung kalian.
Dialogue: 0,0:08:24.90,0:08:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari lanjut!
Dialogue: 0,0:08:26.46,0:08:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian adalah bintang tamu kami!
Dialogue: 0,0:08:28.96,0:08:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah ditunggu\Ndi aula upacara pusat!
Dialogue: 0,0:08:33.53,0:08:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wignall, langit dan cahaya\Ndi ruang ini...
Dialogue: 0,0:08:37.08,0:08:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Ini adalah sihir fantasi elf.
Dialogue: 0,0:08:40.96,0:08:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, sihirnya sangat rumit.
Dialogue: 0,0:08:44.12,0:08:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:08:47.00,0:08:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat itu, Will!
Dialogue: 0,0:08:49.50,0:08:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada banyak orang\Nyang memakai gloria seperti kita.
Dialogue: 0,0:08:54.24,0:08:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kebun rumput moly.
Dialogue: 0,0:08:56.39,0:08:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu mungkin semacam\Ntempat eksperimen makhluk sihir.
Dialogue: 0,0:08:59.77,0:09:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita benar-benar berada\Ndi lini terdepan penelitian sihir.
Dialogue: 0,0:09:03.80,0:09:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang telat,
Dialogue: 0,0:09:05.02,0:09:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku benar-benar\Nmerasa seperti penyihir senior.
Dialogue: 0,0:09:08.78,0:09:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:10.10,0:09:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti mimpi saja.
Dialogue: 0,0:09:13.22,0:09:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:09:14.16,0:09:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku melihat toko krep di sana!
Dialogue: 0,0:09:16.76,0:09:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Owen Sique: Lisolde Dua!
Dialogue: 0,0:09:19.54,0:09:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Algiz!
Dialogue: 0,0:09:21.84,0:09:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima?!
Dialogue: 0,0:09:22.92,0:09:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria tidak pernah membual.\NLalu, simpan saja kembaliannya.
Dialogue: 0,0:09:25.88,0:09:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu sedang apa, Lihanna?!
Dialogue: 0,0:09:28.67,0:09:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sama seperti masa orientasi\Ndi menara!
Dialogue: 0,0:09:31.68,0:09:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya makan!
Dialogue: 0,0:09:33.86,0:09:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ayo pergi!
Dialogue: 0,0:09:35.86,0:09:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihanna tidak pernah berubah, ya.
Dialogue: 0,0:09:37.90,0:09:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:39.02,0:09:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nafsu makan besar itu\Nsudah terasa normal bagiku.
Dialogue: 0,0:09:43.62,0:09:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:45.80,0:09:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlena, Anak Gagal.
Dialogue: 0,0:09:48.82,0:09:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menara ini tidak seterang dugaanmu.
Dialogue: 0,0:09:53.20,0:09:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:10:02.00,0:10:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:03.20,0:10:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa ada yang aneh\Ndengan tatapan para penyihir senior.
Dialogue: 0,0:10:07.42,0:10:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sialan.
Dialogue: 0,0:10:08.98,0:10:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata rumor itu benar.
Dialogue: 0,0:10:11.17,0:10:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika begini terus,\Nmungkin kami akan...
Dialogue: 0,0:10:16.12,0:10:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sampai.
Dialogue: 0,0:10:17.64,0:10:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, silakan masuk!
Dialogue: 0,0:10:25.54,0:10:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini aula upacaranya?
Dialogue: 0,0:10:28.24,0:10:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faksi tanah.
Dialogue: 0,0:10:29.84,0:10:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faksi angin.
Dialogue: 0,0:10:31.30,0:10:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faksi kegelapan.
Dialogue: 0,0:10:32.70,0:10:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka perwakilan penyihir\Ndari semua faksi?
Dialogue: 0,0:10:35.16,0:10:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,
Dialogue: 0,0:10:36.70,0:10:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tatapan mereka kepada kita\Ntampak agak menyeramkan.
Dialogue: 0,0:10:43.34,0:10:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:11:06.34,0:11:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ellenor.
Dialogue: 0,0:11:12.52,0:11:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie, maaf lama.
Dialogue: 0,0:11:17.64,0:11:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie?
Dialogue: 0,0:11:22.62,0:11:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kesediaan Anda\Ndatang dari puncak menara nan jauh,
Dialogue: 0,0:11:26.36,0:11:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oh Magia Vander.
Dialogue: 0,0:11:29.21,0:11:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya urusan sepele.
Dialogue: 0,0:11:31.32,0:11:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lakukan secara efisien\Nagar kami tidak bosan, Nona Clairie.
Dialogue: 0,0:11:38.32,0:11:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah sukses besar, ya,\NJunior Manis.
Dialogue: 0,0:11:41.98,0:11:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap sok berkuasamu\Njuga sudah natural banget.
Dialogue: 0,0:11:46.46,0:11:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkat pendidikan brutal\Ndari para senior menyenangkan.
Dialogue: 0,0:11:49.12,0:11:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Cariot.
Dialogue: 0,0:11:50.80,0:11:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, Logwell.
Dialogue: 0,0:12:01.99,0:12:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sesuai keinginan\NMagia Vander nan agung,
Dialogue: 0,0:12:05.96,0:12:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}inisiasi pemekaran\Nakan segera dimulai!
Dialogue: 0,0:12:09.12,0:12:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemekaran?
Dialogue: 0,0:12:10.96,0:12:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kita mulai\Ndari anak-anak piyik
Dialogue: 0,0:12:13.00,0:12:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dipilih setiap faksi\Nsaat Turnamen Sihir Agung
Dialogue: 0,0:12:15.92,0:12:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau di suatu titik\Nselama enam tahun terakhir.
Dialogue: 0,0:12:17.98,0:12:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan diberi berkah warna!
Dialogue: 0,0:12:40.52,0:12:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:13:02.47,0:13:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gloria-ku jadi warna merah?
Dialogue: 0,0:13:05.02,0:13:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gloria-ku jadi cokelat.
Dialogue: 0,0:13:07.72,0:13:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Brosnya juga berubah\Njadi emblem faksi tanah.
Dialogue: 0,0:13:18.92,0:13:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:23.68,0:13:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warnanya tidak berubah?
Dialogue: 0,0:13:38.38,0:13:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarissa pembohong!
Dialogue: 0,0:13:40.96,0:13:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:13:42.10,0:13:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya aku boleh merekrut Will\Nkalau dia berhasil masuk menara!
Dialogue: 0,0:13:47.86,0:13:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan rewel seperti anak kecil.
Dialogue: 0,0:13:51.16,0:13:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya jadi terlihat.
Dialogue: 0,0:13:52.68,0:13:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ditutup.
Dialogue: 0,0:13:55.76,0:13:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku rela bersabar\Nkarena Will masih sekolah!
Dialogue: 0,0:13:59.80,0:14:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu dan anggota faksi
Dialogue: 0,0:14:01.30,0:14:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menyambutnya\Njika dia lolos kualifikasi?!
Dialogue: 0,0:14:04.66,0:14:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, tuh!\NSurat cintaku untuk Will!
Dialogue: 0,0:14:07.08,0:14:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, maksudku, surat undangan.
Dialogue: 0,0:14:09.18,0:14:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya gagal kirim\Nkarena kamu, kan, Sarissa?
Dialogue: 0,0:14:12.20,0:14:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak yang Anda kirim?
Dialogue: 0,0:14:14.66,0:14:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan ulah saya.\NNamun, Institut Tinggi.
Dialogue: 0,0:14:19.74,0:14:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Institut Tinggi?\NMaksudmu si Kreutz?
Dialogue: 0,0:14:22.92,0:14:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:24.08,0:14:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak ikut campur\Ndalam keputusan akademi,
Dialogue: 0,0:14:27.10,0:14:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia mempertanyakan\Nkeputusan meloloskan pedang.
Dialogue: 0,0:14:30.64,0:14:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perekrutannya tidak diakui.
Dialogue: 0,0:14:33.68,0:14:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh ke Institut Tinggi sebentar\Nuntuk membekukan mereka semua?
Dialogue: 0,0:14:37.44,0:14:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:14:39.90,0:14:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap tenang.
Dialogue: 0,0:14:41.82,0:14:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia bisa memperlihatkan\Nkebolehan selama pemekaran,
Dialogue: 0,0:14:45.30,0:14:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kreutz berjanji akan\Nmenarik kata-katanya.
Dialogue: 0,0:14:47.48,0:14:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menara mengutamakan kemampuan.
Dialogue: 0,0:14:49.58,0:14:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Anda terlalu berpihak,
Dialogue: 0,0:14:51.78,0:14:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}reputasi Will Serfort akan\Nmemburuk di masa depan.
Dialogue: 0,0:14:55.86,0:14:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai seorang penyimpang,
Dialogue: 0,0:14:58.04,0:15:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia harus dapat pengakuan\Ndari semua pihak di menara.
Dialogue: 0,0:15:01.46,0:15:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya akan atur persiapan\Ndengan Clairie dan faksi lain.
Dialogue: 0,0:15:06.86,0:15:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin, Anda kurang yakin\Nakan kemampuannya?
Dialogue: 0,0:15:12.40,0:15:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:15:14.52,0:15:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will pasti bisa melampauinya.
Dialogue: 0,0:15:18.12,0:15:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkah warna yang kalian terima\Nadalah lambang kemuliaan sejati.
Dialogue: 0,0:15:21.90,0:15:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah! Menuju faksi\Nyang telah menanti kalian!
Dialogue: 0,0:15:26.24,0:15:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kalian semua\Nmencapai puncak menara!
Dialogue: 0,0:15:49.47,0:15:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:15:50.86,0:15:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak menerima berkah apa pun.
Dialogue: 0,0:15:54.18,0:15:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambutan semeriah tadi\Nlangsung berubah drastis?
Dialogue: 0,0:15:58.42,0:16:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian, anak-anak\Nyang belum mendapat berkah
Dialogue: 0,0:16:01.78,0:16:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kaum tanpa warna.
Dialogue: 0,0:16:04.22,0:16:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, tidak berharga.
Dialogue: 0,0:16:06.56,0:16:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya penyihir anggota faksi saja\Nyang diizinkan memanjat menara.
Dialogue: 0,0:16:10.74,0:16:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selebihnya tidak boleh beranjak dari sini.
Dialogue: 0,0:16:14.28,0:16:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata informasi internal\Nbangsawan tingkat tinggi itu
Dialogue: 0,0:16:16.78,0:16:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kebenaran.
Dialogue: 0,0:16:18.10,0:16:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir yang gagal masuk faksi
Dialogue: 0,0:16:20.14,0:16:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan terhenti di lantai satu\Ndan menjadi bagian dari menara.
Dialogue: 0,0:16:25.18,0:16:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya akan jadi roda gigi\Nyang menopang penyihir berbakat.
Dialogue: 0,0:16:28.88,0:16:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di balik gemerlap kejayaannya,\Nmenara menyandang nama lain.
Dialogue: 0,0:16:33.40,0:16:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan itu adalah "Makam Tongkat Sihir".
Dialogue: 0,0:16:36.52,0:16:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:16:38.14,0:16:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:16:40.40,0:16:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian akan diberi kesempatan\Nkarena berhasil mencapai menara.
Dialogue: 0,0:16:44.56,0:16:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kalian menunjukkan kehebatan,
Dialogue: 0,0:16:46.34,0:16:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin akan ada faksi\Nyang mau merekrut kalian.
Dialogue: 0,0:16:50.28,0:16:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah acara utama inisiasi pemekaran.
Dialogue: 0,0:16:53.68,0:16:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kalian belum sempat\Nmenunjukkan kapasitas kalian,
Dialogue: 0,0:16:56.90,0:16:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tunjukkan warna kalian sekarang!
Dialogue: 0,0:16:58.52,0:17:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mekarlah sekarang!
Dialogue: 0,0:17:02.24,0:17:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, itu...
Dialogue: 0,0:17:04.72,0:17:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster?!
Dialogue: 0,0:17:07.42,0:17:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aturannya hanya satu.
Dialogue: 0,0:17:09.96,0:17:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan kehebatan kalian!
Dialogue: 0,0:17:12.80,0:17:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}First Bloom, dimulai!
Dialogue: 0,0:17:15.78,0:17:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:17:20.30,0:17:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara mainnya simpel saja.
Dialogue: 0,0:17:22.54,0:17:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalahkan monster-monster itu.
Dialogue: 0,0:17:25.07,0:17:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bebas bertarung\Nmenggunakan taktik cerdik.
Dialogue: 0,0:17:27.40,0:17:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerang musuh dengan\Nsihir spektakuler pun boleh.
Dialogue: 0,0:17:30.03,0:17:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraksilah di depan semua faksi.
Dialogue: 0,0:17:33.22,0:17:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Bebas, katanya?
Dialogue: 0,0:17:35.84,0:17:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lyril!\NPokoknya serang saja!
Dialogue: 0,0:17:38.80,0:17:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ignis Rooks!
Dialogue: 0,0:17:45.32,0:17:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirnya tidak mempan?
Dialogue: 0,0:17:48.02,0:17:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga lantai satu\Nyang diciptakan menara, Zoctonia.
Dialogue: 0,0:17:52.72,0:17:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dinilai dari kekuatan murni saja,\Nsatu penjaga dihargai 30 kredit.
Dialogue: 0,0:17:57.70,0:18:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebanding dengan monster\Ndi paruh kedua strata tengah.
Dialogue: 0,0:18:02.66,0:18:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dikalahkan!
Dialogue: 0,0:18:03.98,0:18:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita sudah\Nbersusah payah ke menara!
Dialogue: 0,0:18:06.54,0:18:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir amatir yang baru lulus\Ntidak mungkin bisa mengalahkannya.
Dialogue: 0,0:18:10.84,0:18:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perisai kembar itu\Nbisa menampik sihir lemah.
Dialogue: 0,0:18:15.57,0:18:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lothr Hielsnow!
Dialogue: 0,0:18:26.17,0:18:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ars Weiss!
Dialogue: 0,0:18:30.59,0:18:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glace Itier!
Dialogue: 0,0:18:32.42,0:18:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengalahkan\Ndua Zoctonia sekaligus?!
Dialogue: 0,0:18:35.43,0:18:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jauh lebih mahir\Nsejak Festival Sihir Agung.
Dialogue: 0,0:18:39.81,0:18:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menggunakan\Nsihir klona Nona Elfaria
Dialogue: 0,0:18:42.16,0:18:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai sejauh itu.
Dialogue: 0,0:18:45.06,0:18:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah itu lebih menonjol\Ndibandingkan yang lainnya.
Dialogue: 0,0:18:48.88,0:18:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa jadi aset berharga.
Dialogue: 0,0:18:52.78,0:18:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa orang sehebat itu\Nmasih belum direkrut?
Dialogue: 0,0:18:56.32,0:18:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Aku adalah orang genius.
Dialogue: 0,0:18:59.02,0:19:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pengguna sihir klona,\Norang tampan, bangsawan muda!
Dialogue: 0,0:19:03.12,0:19:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pantas dibandingkan\Ndengan orang-orang remeh!
Dialogue: 0,0:19:06.33,0:19:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat layak direkrut!
Dialogue: 0,0:19:09.10,0:19:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:19:10.38,0:19:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku begitu indah!\NAku begitu unggul!
Dialogue: 0,0:19:13.92,0:19:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Nona Elfaria!\NTolong lihat aku!
Dialogue: 0,0:19:20.35,0:19:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ahh! Kenapa?!
Dialogue: 0,0:19:23.06,0:19:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gara-gara festival sihir?!
Dialogue: 0,0:19:24.64,0:19:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara aku berkata kasar\Ndan merundung si Nol Besar?!
Dialogue: 0,0:19:30.18,0:19:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bukan pengguna sihir es,\Nkita pasti sudah merekrutnya.
Dialogue: 0,0:19:34.70,0:19:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Andai saja.
Dialogue: 0,0:19:36.62,0:19:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:19:38.87,0:19:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:19:41.50,0:19:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain bocah es itu,
Dialogue: 0,0:19:43.62,0:19:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak melihat penyihir lain\Nyang terlihat menjanjikan.
Dialogue: 0,0:19:47.34,0:19:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, masih ada satu.
Dialogue: 0,0:19:49.76,0:19:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menjadi pusat perhatian,\Nentah karena hal baik atau buruk.
Dialogue: 0,0:19:59.56,0:20:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa lari terus?\NApa yang kau lakukan, Anak Gagal?!
Dialogue: 0,0:20:02.89,0:20:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan. Sebenarnya...
Dialogue: 0,0:20:05.26,0:20:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang mengamati.
Dialogue: 0,0:20:07.38,0:20:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur, Kiki.
Dialogue: 0,0:20:11.26,0:20:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak sedih\Nkarena hal ini, ya, Elfie.
Dialogue: 0,0:20:15.98,0:20:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyesal\Nkarena tidak bisa merekrutku.
Dialogue: 0,0:20:19.40,0:20:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tidak apa-apa.
Dialogue: 0,0:20:21.84,0:20:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyusulmu\Ndengan kedua kakiku sendiri!
Dialogue: 0,0:20:38.20,0:20:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:20:39.22,0:20:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Lebih dari itu...
Dialogue: 0,0:20:41.06,0:20:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat.
Dialogue: 0,0:20:42.12,0:20:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membelah Zoctonia\Ndari atas melewati perisai.
Dialogue: 0,0:20:45.72,0:20:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa membaca\Nsemua pergerakan musuh?
Dialogue: 0,0:20:48.68,0:20:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam waktu sesingkat ini?
Dialogue: 0,0:20:50.72,0:20:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melihat pola gerakan itu!
Dialogue: 0,0:20:54.24,0:20:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergerakan lawanku\Ntampak jauh lebih jelas.
Dialogue: 0,0:20:57.11,0:20:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gloria-ku terasa ringan dan fleksibel.
Dialogue: 0,0:20:59.30,0:21:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bergerak leluasa.
Dialogue: 0,0:21:01.36,0:21:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Pak Donnan\Njuga bisa menebas apa saja.
Dialogue: 0,0:21:04.14,0:21:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku yakin\Nbisa melakukan apa pun.
Dialogue: 0,0:21:12.44,0:21:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada lagi?!
Dialogue: 0,0:21:16.25,0:21:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glace Itier!
Dialogue: 0,0:21:19.20,0:21:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:21:20.30,0:21:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirku nyasar!
Dialogue: 0,0:21:21.93,0:21:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, maaf!\NAku pinjam, ya!
Dialogue: 0,0:21:33.24,0:21:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuatan Imaji.
Dialogue: 0,0:21:35.90,0:21:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glauss Wis!
Dialogue: 0,0:21:37.94,0:21:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will...
Dialogue: 0,0:21:40.86,0:21:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Load Burst!
Dialogue: 0,0:21:47.32,0:21:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glauss Mill!
Dialogue: 0,0:23:36.55,0:23:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.40,0:23:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode sembilan belas:\N"Keputusan Berhenti Menunduk".
