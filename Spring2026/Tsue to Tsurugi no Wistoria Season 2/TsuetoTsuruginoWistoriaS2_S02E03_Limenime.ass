Dialogue: 0,0:00:59.37,0:01:00.62,tanda,,0,0,0,,AJUDAN FRAKSI ES, SARISSA ALFELD
Dialogue: 0,0:01:01.63,0:01:03.37,tanda,,0,0,0,,AJUDAN FRAKSI PETIR, GUILFORD ZURGAS
Dialogue: 0,0:01:05.98,0:01:08.26,tanda,,0,0,0,,"CARIOTT INCINDIA WISEMAN"
Dialogue: 0,0:01:22.95,0:01:25.77,tanda,,0,0,0,,"ZEO THORZEUS REINBOLT"
Dialogue: 0,0:01:33.05,0:01:34.39,tanda,,0,0,0,,AARON MASTERIAS OLDKING
Dialogue: 0,0:02:20.48,0:02:22.71,tanda,,0,0,0,,"AJUDAN FRAKSI ELF, LEFIYA VIRIDIS"
Dialogue: 0,0:02:27.73,0:02:30.02,tanda,,0,0,0,,"ELLENOR LJOS ALF"
Dialogue: 0,0:02:31.96,0:02:35.05,tanda,,0,0,0,,"AJUDAN FRAKSI ELF, FILVIS CHALLIA"
Dialogue: 0,0:03:00.40,0:03:03.87,tanda,,0,0,0,,"ELFARIA ALBIS SERFORT"
Dialogue: 0,0:04:00.00,0:04:04.68,tanda,,0,0,0,,EPISODE 15: SATU-SATUNYA SIHIR
Dialogue: 0,0:05:08.96,0:05:13.54,tanda,,0,0,0,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:05:17.43,0:05:20.15,tanda,,0,0,0,,"PROFESOR AKADEMI SIHIR RIGARDEN, WORKNER NORGRAM"
Dialogue: 0,0:06:58.08,0:06:59.86,tanda,,0,0,0,,"LIHANNA OWENZAUS"
Dialogue: 0,0:07:00.55,0:07:01.53,tanda,,0,0,0,,"COLETTE LOIRE"
Dialogue: 0,0:07:03.28,0:07:04.61,tanda,,0,0,0,,"PIARAAN, KIKI"
Dialogue: 0,0:07:27.00,0:07:28.40,tanda,,0,0,0,,"JULIUS REINBERG"
Dialogue: 0,0:08:27.15,0:08:29.25,tanda,,0,0,0,,CLAIRIE SERAH
Dialogue: 0,0:08:51.47,0:08:53.68,tanda,,0,0,0,,"GINA"
Dialogue: 0,0:08:53.68,0:08:55.20,tanda,,0,0,0,,"EDWARD SERFENCE"
Dialogue: 0,0:10:01.28,0:10:03.83,tanda,,0,0,0,,"SION ULSTER"
Dialogue: 0,0:11:05.38,0:11:08.11,tanda,,0,0,0,,"ROSE PREHNITE"
Dialogue: 0,0:11:08.11,0:11:10.08,tanda,,0,0,0,,"MIKE MAIUS"
Dialogue: 0,0:11:33.46,0:11:36.38,tanda,,0,0,0,,"LYRIL MARS"
Dialogue: 0,0:11:37.22,0:11:38.68,tanda,,0,0,0,,SISWA AKADEMI SIHIR RIGARDEN TAHUN KE-6,\NGORDON VALLEY
Dialogue: 0,0:11:56.78,0:11:58.55,tanda,,0,0,0,,"ELIZA NOSFERAT"
Dialogue: 0,0:12:46.95,0:12:48.83,tanda,,0,0,0,,"EMMA CLEVER"
Dialogue: 0,0:13:09.03,0:13:10.94,tanda,,0,0,0,,"CALDRON ANOUVE"
Dialogue: 0,0:13:27.90,0:13:30.14,tanda,,0,0,0,,"IRIS CHURCHILL"
Dialogue: 0,0:14:09.28,0:14:10.38,tanda,,0,0,0,,TONGKAT SIHIR OKER
Dialogue: 0,0:14:10.78,0:14:14.00,tanda,,0,0,0,,ROSE PREHNITE
Dialogue: 0,0:14:15.65,0:14:19.00,tanda,,0,0,0,,DEVANDER
Dialogue: 0,0:21:45.33,0:21:47.90,tanda,,0,0,0,,"PEDANG SIHIR"
Dialogue: 0,0:23:28.09,0:23:31.04,tanda,,0,0,0,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:00:03.08,0:00:03.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:00:05.48,0:00:07.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan selalu bersamamu.
Dialogue: 0,0:00:27.98,0:00:29.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:00:39.20,0:00:40.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rosty!
Dialogue: 0,0:00:40.78,0:00:42.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rosty!
Dialogue: 0,0:00:42.58,0:00:45.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rosty!
Dialogue: 0,0:01:03.38,0:01:04.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Zeo?
Dialogue: 0,0:01:05.98,0:01:08.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau ke mana, Zeo?
Dialogue: 0,0:01:08.26,0:01:09.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah jelas, kan?
Dialogue: 0,0:01:10.33,0:01:12.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Medan perang.
Dialogue: 0,0:01:12.01,0:01:15.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka menjerit keras dan mati menyedihkan.
Dialogue: 0,0:01:15.35,0:01:17.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya tidak berguna.
Dialogue: 0,0:01:17.95,0:01:19.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:01:20.85,0:01:22.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kitalah yang paling tidak berguna
Dialogue: 0,0:01:22.95,0:01:25.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}karena membiarkan mereka mati!
Dialogue: 0,0:01:26.33,0:01:28.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Aaron sudah berkata.
Dialogue: 0,0:01:28.77,0:01:31.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika Magia Vander sampai kalah,
Dialogue: 0,0:01:31.05,0:01:33.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}penghalang besar juga akan lenyap.
Dialogue: 0,0:01:34.40,0:01:40.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dan akibatnya, Penjajah Langit\Nakan membumihanguskan dunia ini.
Dialogue: 0,0:01:40.58,0:01:42.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar fraksi api pengecut.
Dialogue: 0,0:01:42.90,0:01:46.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Posisi kita sedang dirugikan.
Dialogue: 0,0:01:46.45,0:01:49.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setidaknya tunggulah\Nsampai energi sihir kita pulih.
Dialogue: 0,0:01:49.55,0:01:52.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sadarilah posisimu sebagai\Nsalah satu Magia Vander, Zeo.
Dialogue: 0,0:01:53.68,0:01:55.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sering menasihatimu, kan?
Dialogue: 0,0:01:55.90,0:01:57.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Duduklah.
Dialogue: 0,0:01:57.93,0:02:01.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Posisi? Aku tidak butuh.
Dialogue: 0,0:02:02.15,0:02:04.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buat apa gelar vander pengecut?
Dialogue: 0,0:02:06.60,0:02:09.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menyuruhmu kembali.
Dialogue: 0,0:02:10.44,0:02:15.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika kamu berontak, aku akan\Nmenghentikanmu secara paksa.
Dialogue: 0,0:02:17.20,0:02:18.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coba saja.
Dialogue: 0,0:02:20.48,0:02:22.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pemandangan ini tidak baik untuk mata Anda.
Dialogue: 0,0:02:23.38,0:02:25.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang akan Anda lakukan, Nona Ellenor?
Dialogue: 0,0:02:26.35,0:02:27.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pertanyaan bodoh.
Dialogue: 0,0:02:27.73,0:02:30.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tetap akan mengawasi.
Dialogue: 0,0:02:30.03,0:02:31.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini hanyalah negeri para penyihir.
Dialogue: 0,0:02:31.96,0:02:35.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada satu kerabat kita yang bersekolah di akademi.
Dialogue: 0,0:02:35.43,0:02:36.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:02:39.25,0:02:40.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:02:40.55,0:02:42.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Pergilah.\N- Baik.
Dialogue: 0,0:02:43.53,0:02:46.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Situasi di kota sudah memprihatinkan.
Dialogue: 0,0:02:46.48,0:02:49.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para Magia Vander pun saling bertengkar.
Dialogue: 0,0:02:49.23,0:02:50.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika begini terus...
Dialogue: 0,0:02:53.08,0:02:54.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Tunggu...
Dialogue: 0,0:02:54.85,0:02:56.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Elfaria?
Dialogue: 0,0:03:00.40,0:03:03.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tarik perintahmu. Ini hanya buang-buang waktu.
Dialogue: 0,0:03:04.65,0:03:06.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keputusanku sudah bulat!
Dialogue: 0,0:03:06.63,0:03:08.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Duduklah, Elfaria!
Dialogue: 0,0:03:26.33,0:03:29.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan menolong orang-orang\Nyang kusayang,
Dialogue: 0,0:03:29.23,0:03:31.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}termasuk Will.
Dialogue: 0,0:03:31.40,0:03:34.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika masih menghalangi,\Naku akan menjatuhkanmu!
Dialogue: 0,0:03:36.05,0:03:38.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}No-Nona Elfaria?
Dialogue: 0,0:05:17.43,0:05:20.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lini depan kami runtuh karena kemunculan Devander.
Dialogue: 0,0:05:20.50,0:05:24.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dinoboros yang masih tersisa\Njuga mulai menekan para penyihir.
Dialogue: 0,0:05:24.60,0:05:28.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para dwarf pun tidak bisa\Nmemperbaiki keadaan buruk ini.
Dialogue: 0,0:05:28.58,0:05:31.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anak ini adalah satu-satunya harapan kami.
Dialogue: 0,0:05:32.13,0:05:33.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa...
Dialogue: 0,0:05:34.23,0:05:36.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa melindunginya!
Dialogue: 0,0:05:36.98,0:05:40.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa menyelamatkan siapa pun!\NAku tidak bisa apa-apa!
Dialogue: 0,0:05:41.83,0:05:44.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sama seperti saat itu.
Dialogue: 0,0:05:44.40,0:05:47.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat Elfie dibawa ke menara!
Dialogue: 0,0:05:50.10,0:05:52.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa karena aku tidak bisa sihir?
Dialogue: 0,0:05:53.23,0:05:55.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena aku tidak bisa sihir!
Dialogue: 0,0:05:55.98,0:05:59.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa melindungi Elfie, Rosty,\Natau siapa pun!
Dialogue: 0,0:05:59.05,0:06:01.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena aku anak gagal!
Dialogue: 0,0:06:01.88,0:06:04.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya adalah salahku!
Dialogue: 0,0:06:08.03,0:06:09.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tenanglah, Will!
Dialogue: 0,0:06:09.45,0:06:10.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pak Workner.
Dialogue: 0,0:06:11.83,0:06:13.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa aku?
Dialogue: 0,0:06:14.20,0:06:15.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa aku
Dialogue: 0,0:06:17.98,0:06:21.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}jadi satu-satunya orang\Nyang tidak bisa sihir?
Dialogue: 0,0:06:23.25,0:06:24.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:06:24.88,0:06:26.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuatkan dirimu, Will!
Dialogue: 0,0:06:27.68,0:06:28.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yo.
Dialogue: 0,0:06:30.49,0:06:34.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aroma yang keluar dari bocah itu\Nlebih merepotkan dari para dwarf.
Dialogue: 0,0:06:34.80,0:06:37.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aromanya sangat menyengat.
Dialogue: 0,0:06:38.21,0:06:40.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kubunuh kalian sekaligus.
Dialogue: 0,0:06:53.33,0:06:54.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, Colette.
Dialogue: 0,0:06:58.08,0:06:59.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Colette, kamu sedang apa?!
Dialogue: 0,0:07:00.55,0:07:01.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Barusan...
Dialogue: 0,0:07:03.28,0:07:04.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kiki!
Dialogue: 0,0:07:05.25,0:07:06.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu baik-baik saja, Kiki?
Dialogue: 0,0:07:09.60,0:07:12.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa itu tadi Will?
Dialogue: 0,0:07:16.73,0:07:19.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolonglah, Kiki!\NAntar aku ke tempat Will!
Dialogue: 0,0:07:23.58,0:07:24.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sion?!
Dialogue: 0,0:07:24.26,0:07:26.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku serahkan kepada kalian!
Dialogue: 0,0:07:27.00,0:07:28.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}He-Hei!
Dialogue: 0,0:07:28.40,0:07:30.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Julius! Keluarkan klona!\N- Hah?
Dialogue: 0,0:07:30.55,0:07:32.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Julius, cepat!\N- Hah?!
Dialogue: 0,0:07:32.25,0:07:35.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Cepatlah, Julius!\N- Masih lama, ya, Julius?!
Dialogue: 0,0:07:35.45,0:07:36.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Julius!
Dialogue: 0,0:07:38.68,0:07:43.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sialan, kalian semua!\NAku bukan pesuruh kalian!
Dialogue: 0,0:07:44.15,0:07:47.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya Marze sedang bersenang-senang.
Dialogue: 0,0:07:49.40,0:07:52.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Paduan suara jeritan,\Ndiiringi mars monster.
Dialogue: 0,0:07:52.95,0:07:55.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Melodi menyenangkan ini\Nakan terus berlanjut selamanya.
Dialogue: 0,0:07:56.55,0:08:00.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, aku juga ingin berburu kepala imut.
Dialogue: 0,0:08:00.80,0:08:04.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, sayang sekali.\NHari ini, aku adalah konduktor.
Dialogue: 0,0:08:05.08,0:08:07.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, saatnya kau pergi.
Dialogue: 0,0:08:13.38,0:08:15.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gawat! Dia pergi ke menara!
Dialogue: 0,0:08:16.45,0:08:20.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan biarkan dia mendekati\Npusat ibu kota Central Flos!
Dialogue: 0,0:08:22.43,0:08:25.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Monster ini bisa membunuh Magia Vander!
Dialogue: 0,0:08:33.15,0:08:34.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serah!
Dialogue: 0,0:08:36.03,0:08:38.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lakukan serangan maut, Dwarf!
Dialogue: 0,0:08:38.17,0:08:39.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pergilah ke pusat kota!
Dialogue: 0,0:08:40.23,0:08:43.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hancurkan senjata pembunuh penyihir\Nyang dibawa Devander!
Dialogue: 0,0:08:43.91,0:08:45.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:08:45.67,0:08:49.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami sudah babak belur\Nkarena melindungi kalian!
Dialogue: 0,0:08:49.45,0:08:51.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Donnan dan yang lain sudah kalah!
Dialogue: 0,0:08:51.47,0:08:53.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kau ingin kami mati?!
Dialogue: 0,0:08:53.68,0:08:55.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:56.53,0:09:00.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Demi ibu kota ini!\NDemi melindungi anak-anak!
Dialogue: 0,0:09:00.19,0:09:02.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Matilah, Dwarf!
Dialogue: 0,0:09:06.85,0:09:07.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gina!
Dialogue: 0,0:09:17.70,0:09:19.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Im Rulgur!
Dialogue: 0,0:09:27.03,0:09:29.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu... kenapa?
Dialogue: 0,0:09:30.03,0:09:32.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selama sihir tidak mempan,
Dialogue: 0,0:09:32.95,0:09:36.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}nyawaku tidak lebih berharga\Ndari nyawa kalian.
Dialogue: 0,0:09:37.30,0:09:38.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya itu.
Dialogue: 0,0:09:39.83,0:09:41.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami akan berkorban untuk kalian.
Dialogue: 0,0:09:41.48,0:09:45.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, serahkan nyawa kalian!
Dialogue: 0,0:09:48.58,0:09:52.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para lelaki!\NKumpulkan orang-orang!
Dialogue: 0,0:09:52.65,0:09:54.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pergi ke pusat kota!
Dialogue: 0,0:09:55.10,0:09:56.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Frubas Julier!
Dialogue: 0,0:10:01.28,0:10:03.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu, Colette! Jangan pergi sendirian!
Dialogue: 0,0:10:04.00,0:10:06.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, aku harus cepat untuk menolong Will!
Dialogue: 0,0:10:06.98,0:10:08.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar anak gagal.
Dialogue: 0,0:10:08.43,0:10:10.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia selalu membuat kita repot.
Dialogue: 0,0:10:13.18,0:10:14.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stia Biora!
Dialogue: 0,0:10:20.65,0:10:22.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Loire Sique:
Dialogue: 0,0:10:24.30,0:10:25.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa harus sekarang?!
Dialogue: 0,0:10:28.45,0:10:30.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Colette!
Dialogue: 0,0:10:33.88,0:10:35.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lini depan barat kota telah runtuh!
Dialogue: 0,0:10:35.82,0:10:38.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasukan penyihir agung\Ndi timur laut telah hancur!
Dialogue: 0,0:10:38.33,0:10:40.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dinoboros tidak bisa dihentikan!
Dialogue: 0,0:10:40.83,0:10:42.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seluruh warga, harap ke selatan!
Dialogue: 0,0:10:42.80,0:10:45.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Organo dan Fraksi Petir\Nsedang menghentikan musuh!
Dialogue: 0,0:10:45.83,0:10:48.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya, lawan balik!
Dialogue: 0,0:10:48.00,0:10:50.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekali lagi, lawan balik musuh!
Dialogue: 0,0:10:51.00,0:10:53.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lawan balik, katanya?
Dialogue: 0,0:10:54.15,0:10:57.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana mungkin.
Dialogue: 0,0:10:57.98,0:11:01.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di mana kamu, Colette?
Dialogue: 0,0:11:01.98,0:11:04.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin menemuimu untuk terakhir kalinya.
Dialogue: 0,0:11:05.38,0:11:08.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya tidak ada harapan lagi.
Dialogue: 0,0:11:08.11,0:11:10.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya, ke selatan!
Dialogue: 0,0:11:10.08,0:11:12.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ikutilah jalan ke selatan!
Dialogue: 0,0:11:12.88,0:11:14.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:11:15.68,0:11:18.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tempat ini tidak aman!\N- Aku kebanyakan teriak, tenggorokanku...
Dialogue: 0,0:11:18.33,0:11:19.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita harus ke mana?
Dialogue: 0,0:11:21.53,0:11:24.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ke selatan!
Dialogue: 0,0:11:25.90,0:11:28.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ignis Rooks!
Dialogue: 0,0:11:28.08,0:11:31.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lyril, ayo cepat lari!
Dialogue: 0,0:11:31.08,0:11:33.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun... tetap saja...
Dialogue: 0,0:11:33.46,0:11:36.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masa kita kabur sendiri setelah ditolong olehnya?!
Dialogue: 0,0:11:39.28,0:11:42.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan sok keren\Nkalau kakimu masih gemetar!
Dialogue: 0,0:11:48.27,0:11:49.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Urvel.
Dialogue: 0,0:11:54.75,0:11:56.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}B-Bu Eliza...
Dialogue: 0,0:11:56.78,0:11:58.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bantulah orang terluka!
Dialogue: 0,0:11:58.55,0:12:00.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini bukan usaha melarikan diri.
Dialogue: 0,0:12:01.85,0:12:04.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini adalah misi penyelamatan!
Dialogue: 0,0:12:04.98,0:12:07.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serahkan yang di sini padaku!\NPergilah!
Dialogue: 0,0:12:07.04,0:12:08.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:12:12.04,0:12:14.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sungguh merepotkan.
Dialogue: 0,0:12:14.73,0:12:15.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:12:21.30,0:12:24.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka adalah murid-murid yang kusayang.
Dialogue: 0,0:12:30.88,0:12:31.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Emma!
Dialogue: 0,0:12:31.78,0:12:34.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sedang apa di sini?!\NKita harus segera pergi!
Dialogue: 0,0:12:34.23,0:12:35.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gadis ini
Dialogue: 0,0:12:36.08,0:12:38.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}di kampung halamannya.\Npunya adik laki-laki kecil
Dialogue: 0,0:12:39.88,0:12:42.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia tidak sabar bertemu dengannya.
Dialogue: 0,0:12:43.73,0:12:45.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan tetapi...
Dialogue: 0,0:12:45.53,0:12:46.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kejam sekali!
Dialogue: 0,0:12:46.95,0:12:48.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini terlalu kejam!
Dialogue: 0,0:12:58.60,0:13:01.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Edward terluka parah!\NWorkner tidak bisa dihubungi!
Dialogue: 0,0:13:01.48,0:13:03.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Clairie, laporkan situasinya!
Dialogue: 0,0:13:03.98,0:13:06.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Clairie! Jawab aku!
Dialogue: 0,0:13:06.03,0:13:09.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Api di area pembangunan\Nmenyebar dengan cepat!
Dialogue: 0,0:13:09.03,0:13:10.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Situasinya sangat buruk.
Dialogue: 0,0:13:10.95,0:13:13.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami kewalahan melindungi warga.
Dialogue: 0,0:13:13.65,0:13:16.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami tidak bisa memukul mundur musuh.
Dialogue: 0,0:13:16.36,0:13:19.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para Dinoboros bergerak ke pusat!
Dialogue: 0,0:13:19.75,0:13:21.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pe-Percuma!
Dialogue: 0,0:13:21.23,0:13:24.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para dwarf telah mengurangi\Nsenjata pembunuh penyihir.
Dialogue: 0,0:13:24.80,0:13:27.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, Devander belum bisa dihentikan.
Dialogue: 0,0:13:27.90,0:13:30.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami terdesak di setiap lini.
Dialogue: 0,0:13:30.15,0:13:32.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami tidak bisa memobilisasi kekuatan.
Dialogue: 0,0:13:32.75,0:13:34.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika hanya mengandalkan dwarf\Nyang masih tersisa,
Dialogue: 0,0:13:34.70,0:13:36.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}kehancuran takkan terhindarkan.
Dialogue: 0,0:13:36.53,0:13:38.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika begini terus, menara akan jatuh.
Dialogue: 0,0:13:39.20,0:13:41.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang harus kami lakukan?
Dialogue: 0,0:13:42.73,0:13:44.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Musuh...
Dialogue: 0,0:13:44.08,0:13:45.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa-apaan itu?!
Dialogue: 0,0:13:45.43,0:13:46.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:46.64,0:13:49.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Laporkan situasinya!
Dialogue: 0,0:13:49.00,0:13:50.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang terjadi?!
Dialogue: 0,0:13:52.45,0:13:55.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iris, di mana si pedang?
Dialogue: 0,0:13:57.15,0:13:59.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ka-Kamu...
Dialogue: 0,0:14:04.83,0:14:07.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di mana si pedang?
Dialogue: 0,0:14:20.18,0:14:23.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Si keparat itu lumayan hebat.
Dialogue: 0,0:14:23.58,0:14:27.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia masih berusaha membunuhku\Ndalam keadaan seperti itu.
Dialogue: 0,0:14:27.50,0:14:30.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, aku sudah melubangimu.
Dialogue: 0,0:14:30.95,0:14:32.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tamat sudah.
Dialogue: 0,0:14:38.45,0:14:40.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:14:41.00,0:14:43.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ujung barat... kota.
Dialogue: 0,0:14:44.95,0:14:47.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita terjatuh.
Dialogue: 0,0:14:48.98,0:14:53.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya...\Naku hanya bisa melindungimu.
Dialogue: 0,0:15:02.50,0:15:05.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pak Workner?
Dialogue: 0,0:15:12.18,0:15:14.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maafkan aku, Will.
Dialogue: 0,0:15:15.38,0:15:18.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya bisa... mengandalkanmu.
Dialogue: 0,0:15:20.60,0:15:22.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya kamu...
Dialogue: 0,0:15:23.03,0:15:27.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku yakin, kamu bisa...\Nmenyelamatkan kota ini.
Dialogue: 0,0:15:29.65,0:15:32.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mustahil.\NItu mustahil, Pak Workner.
Dialogue: 0,0:15:33.55,0:15:38.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rosty mati karena aku!\NDan sekarang, Pak Workner pun...
Dialogue: 0,0:15:38.50,0:15:40.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya dilindungi terus
Dialogue: 0,0:15:40.65,0:15:43.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan tidak bisa menyelamatkan\Norang yang kusayang!
Dialogue: 0,0:15:44.88,0:15:46.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa mengubah apa pun!
Dialogue: 0,0:15:46.95,0:15:50.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pedang tidak bisa mengubah dunia!
Dialogue: 0,0:15:51.01,0:15:52.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa...
Dialogue: 0,0:15:52.55,0:15:54.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena aku tidak bisa menggunakan sihir!
Dialogue: 0,0:16:11.68,0:16:12.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Will...
Dialogue: 0,0:16:13.30,0:16:18.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya... aku selalu membohongimu...
Dialogue: 0,0:16:19.33,0:16:20.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:16:22.40,0:16:24.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}bisa menggunakan sihir.
Dialogue: 0,0:16:25.38,0:16:28.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Satu-satunya sihir
Dialogue: 0,0:16:28.30,0:16:32.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}yang bisa memberi harapan kepada semua...
Dialogue: 0,0:16:32.53,0:16:33.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}orang.
Dialogue: 0,0:16:38.20,0:16:40.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu! Tunggu sebentar!
Dialogue: 0,0:16:40.75,0:16:43.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan mati, Pak Workner!
Dialogue: 0,0:16:43.05,0:16:44.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Katakanlah!
Dialogue: 0,0:16:44.80,0:16:47.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sihir apa yang bisa kugunakan?!
Dialogue: 0,0:16:49.43,0:16:51.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kehendak kecil.
Dialogue: 0,0:16:51.88,0:16:56.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dan cahaya keperakan\Nyang bisa memotong apa pun.
Dialogue: 0,0:16:58.43,0:17:00.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu... Finn?
Dialogue: 0,0:17:01.38,0:17:03.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia baik-baik saja.
Dialogue: 0,0:17:03.75,0:17:07.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia akan bernapas lagi\Nsetelah detak jantungnya pulih.
Dialogue: 0,0:17:12.73,0:17:15.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masalahnya adalah kamu.
Dialogue: 0,0:17:15.57,0:17:16.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:17:17.23,0:17:18.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepat berdirilah!
Dialogue: 0,0:17:19.25,0:17:21.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Panggungnya sudah siap, kan?
Dialogue: 0,0:17:22.70,0:17:24.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cahaya keperakan?
Dialogue: 0,0:17:24.53,0:17:27.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, tunggu.\NApa maksudnya kehendak kecil tadi?
Dialogue: 0,0:17:28.23,0:17:29.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah dengar kata sihir darinya,
Dialogue: 0,0:17:29.73,0:17:32.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}apa menurutmu kamu bisa\Nmengendalikan api atau angin?
Dialogue: 0,0:17:33.83,0:17:35.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja tidak.
Dialogue: 0,0:17:36.45,0:17:39.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia membicarakan\Ntempat persemayaman kehendak.
Dialogue: 0,0:17:39.08,0:17:41.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin bisa disebut "perasaan".
Dialogue: 0,0:17:41.78,0:17:44.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Atau semacam sugesti diri.
Dialogue: 0,0:17:44.58,0:17:48.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bersuaralah, berteriak,\Ndan bangkitkan semangatmu.
Dialogue: 0,0:17:49.20,0:17:52.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Teriakan besar yang mengubah\Nkebohongan menjadi kenyataan.
Dialogue: 0,0:17:52.63,0:17:54.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:17:54.39,0:17:56.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tipu daya anak-anak itu
Dialogue: 0,0:17:56.55,0:17:58.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}tidak mungkin bisa menyelamatkan siapa pun!
Dialogue: 0,0:17:59.28,0:18:01.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu tidak cukup...
Dialogue: 0,0:18:02.83,0:18:06.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan bodoh!\NJustru itulah yang paling penting!
Dialogue: 0,0:18:07.25,0:18:11.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika tidak bisa mengubah diri,\Nkamu tidak akan bisa mengubah dunia!
Dialogue: 0,0:18:12.43,0:18:16.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah itu sejalan dengan dunia\Nyang kamu inginkan?
Dialogue: 0,0:18:20.03,0:18:22.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ingatlah asal-usulmu!
Dialogue: 0,0:18:23.28,0:18:25.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rebut kembali awal mulamu!
Dialogue: 0,0:18:26.93,0:18:28.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuncinya telah terbuka.
Dialogue: 0,0:18:30.18,0:18:32.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang, ambil pedangmu!
Dialogue: 0,0:18:33.35,0:18:34.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mari kita lakukan perjalanan.
Dialogue: 0,0:18:36.48,0:18:38.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menyeberangi bukit kegelapan
Dialogue: 0,0:18:38.22,0:18:40.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan melampaui langit palsu.
Dialogue: 0,0:18:50.80,0:18:53.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu sudah tahu.
Dialogue: 0,0:18:53.73,0:18:56.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nama sihir yang ada di dadamu.
Dialogue: 0,0:19:00.85,0:19:02.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serukan namanya!
Dialogue: 0,0:19:03.43,0:19:05.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nama sihirmu!
Dialogue: 0,0:19:21.72,0:19:23.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keberanian!
Dialogue: 0,0:19:33.95,0:19:35.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pelepasan pembatas.
Dialogue: 0,0:19:36.93,0:19:39.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nah, ayo hunuskan!
Dialogue: 0,0:19:47.38,0:19:49.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kita selamat?
Dialogue: 0,0:19:49.38,0:19:51.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:19:58.83,0:19:59.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:19:59.64,0:20:00.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:20:04.98,0:20:08.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:20:12.73,0:20:13.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:20:13.90,0:20:18.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cahaya itu menyingkirkan\Npara monster satu per satu.
Dialogue: 0,0:20:24.91,0:20:25.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Halcon!
Dialogue: 0,0:20:35.15,0:20:36.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sion!
Dialogue: 0,0:20:49.18,0:20:50.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lari, Sion!
Dialogue: 0,0:20:51.25,0:20:53.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak akan!
Dialogue: 0,0:20:53.78,0:20:55.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak akan!
Dialogue: 0,0:20:55.53,0:20:58.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia tidak mungkin lari!
Dialogue: 0,0:20:59.30,0:21:03.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia adalah si pengecut\Nyang lebih berani dari siapa pun!
Dialogue: 0,0:21:03.18,0:21:07.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak mau kalah darinya!
Dialogue: 0,0:21:09.90,0:21:11.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu salah, Sion.
Dialogue: 0,0:21:12.13,0:21:17.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya iri pada kalian,\Ningin jadi kalian, mengagumi kalian,
Dialogue: 0,0:21:18.08,0:21:20.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan mengejar sosok kalian.
Dialogue: 0,0:21:21.15,0:21:23.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya orang menyedihkan.
Dialogue: 0,0:21:24.38,0:21:27.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena itu, sekarang...
Dialogue: 0,0:21:45.33,0:21:47.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku akan jadi pedang kalian!
Dialogue: 0,0:23:36.02,0:23:39.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.15,0:23:42.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}episode enam belas:\N"Dan Kisah Pun Dimulai".
