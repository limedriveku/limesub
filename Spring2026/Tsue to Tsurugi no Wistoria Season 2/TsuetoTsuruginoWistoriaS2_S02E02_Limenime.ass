Dialogue: 0,0:00:22.98,0:00:24.47,tanda,,0000,0000,0000,,"CLAIRIE SERAH"
Dialogue: 0,0:00:25.46,0:00:26.80,tanda,,0000,0000,0000,,"ANGGOTA FRAKSI API, RODGE HOLLAND"
Dialogue: 0,0:02:23.60,0:02:25.96,tanda,,0000,0000,0000,,"AKADEMI SIHIR RIGARDEN"
Dialogue: 0,0:02:31.71,0:02:34.17,tanda,,0000,0000,0000,,"KEPALA AKADEMI SIHIR RIGARDEN, CALDRON ANOUVE"
Dialogue: 0,0:03:25.30,0:03:28.48,tanda,,0000,0000,0000,,"ELLENOR LJOS ALF"
Dialogue: 0,0:03:28.48,0:03:32.23,tanda,,0000,0000,0000,,"ZEO THORZEUS REINBOLT"
Dialogue: 0,0:03:32.23,0:03:34.99,tanda,,0000,0000,0000,,"CARIOTT INCINDIA WISEMAN"
Dialogue: 0,0:03:34.99,0:03:37.49,tanda,,0000,0000,0000,,"ELFARIA ALBIS SERFORT"
Dialogue: 0,0:03:37.49,0:03:40.84,tanda,,0000,0000,0000,,"AJUDAN FRAKSI API, LOGWELL"
Dialogue: 0,0:03:54.94,0:03:55.35,tanda,,0000,0000,0000,,AARON MASTERIAS OLDKING
Dialogue: 0,0:05:39.90,0:05:44.70,tanda,,0000,0000,0000,,EPISODE 14: PESTA NERAKA DIMULAI
Dialogue: 0,0:06:48.93,0:06:53.56,tanda,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA\NMUSIM 2
Dialogue: 0,0:14:35.98,0:14:37.33,tanda,,0000,0000,0000,,PEDANG PEMBUNUH PENYIHIR
Dialogue: 0,0:14:37.75,0:14:40.98,tanda,,0000,0000,0000,,PEDANG PEMBUNUH PENYIHIR
Dialogue: 0,0:14:42.63,0:14:45.99,tanda,,0000,0000,0000,,SIHIR GERBANG
Dialogue: 0,0:23:28.09,0:23:31.04,tanda,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:42.75,0:23:47.98,tanda,,0000,0000,0000,,EPISODE 15: SATU-SATUNYA SIHIR
Dialogue: 0,0:00:04.31,0:00:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu lingkaran sihir gerbang\Nyang kulihat di strata 11?
Dialogue: 0,0:00:09.07,0:00:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:00:15.53,0:00:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo ke sini!\N- Me-Mereka Dinoboros!
Dialogue: 0,0:00:16.43,0:00:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di sana bahaya!\N- Me-Mereka Dinoboros!
Dialogue: 0,0:00:17.54,0:00:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa monster strata dalam\Nbisa muncul di sini?!
Dialogue: 0,0:00:22.98,0:00:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rodge! Aku akan buat dinding!
Dialogue: 0,0:00:24.48,0:00:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percepat sihir kalian!
Dialogue: 0,0:00:25.46,0:00:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukanlah!
Dialogue: 0,0:00:26.80,0:00:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapkan serangan!
Dialogue: 0,0:00:38.02,0:00:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keridos Gardinas!
Dialogue: 0,0:00:47.69,0:00:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai merapal!
Dialogue: 0,0:00:48.94,0:00:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan barisan depan\Nkepada guardian milik Clairie!
Dialogue: 0,0:00:53.41,0:00:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musnahkan mereka!
Dialogue: 0,0:00:55.73,0:00:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fryde Leochel!
Dialogue: 0,0:01:01.91,0:01:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guardiannya banyak sekali.
Dialogue: 0,0:01:05.71,0:01:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan kejutan itu\Ndipatahkan dalam sekejap.
Dialogue: 0,0:01:08.33,0:01:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka penyihir agung dari menara.
Dialogue: 0,0:01:14.02,0:01:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani-beraninya mengusik ibu kota\Nyang dinaungi Magia Vander ini.
Dialogue: 0,0:01:17.71,0:01:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bedebah.
Dialogue: 0,0:01:19.78,0:01:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selidiki sumber lingkaran sihir itu!
Dialogue: 0,0:01:22.38,0:01:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pelaku yang melepaskan monster!
Dialogue: 0,0:01:24.61,0:01:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkap dia!
Dialogue: 0,0:01:29.49,0:01:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang selamat dari serangan besar tadi?
Dialogue: 0,0:01:32.07,0:01:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan!\NJangan merepotkan!
Dialogue: 0,0:01:44.25,0:01:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanguskan dia!\NErythrorias Gardelsync!
Dialogue: 0,0:01:49.56,0:01:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rodge! Larilah!
Dialogue: 0,0:02:05.70,0:02:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirnya tidak mempan?
Dialogue: 0,0:02:08.13,0:02:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sihirnya dinetralkan?
Dialogue: 0,0:02:10.00,0:02:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana guardian-ku?
Dialogue: 0,0:02:18.70,0:02:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang apa itu?\NApa itu pembunuh penyihir?
Dialogue: 0,0:02:23.60,0:02:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Invasi monster tidak terhenti!
Dialogue: 0,0:02:26.28,0:02:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garda Menara sudah ke kota.
Dialogue: 0,0:02:28.23,0:02:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keadaannya setengah hancur.
Dialogue: 0,0:02:30.00,0:02:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warga sipil juga jadi korban.
Dialogue: 0,0:02:31.71,0:02:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster macam apa itu?
Dialogue: 0,0:02:34.18,0:02:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh penyihir\Nyang dibawa rombongan Finn.
Dialogue: 0,0:02:37.72,0:02:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa senjata itu sudah diproduksi massal\Ndan digunakan dalam pertempuran ini?
Dialogue: 0,0:02:41.73,0:02:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada sihir gerbang, apa musuhnya\Nadalah penjahat di Praksis Akbar?
Dialogue: 0,0:02:48.50,0:02:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ini tidak mungkin\Ndilakukan sendirian.
Dialogue: 0,0:02:51.13,0:02:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu terorganisasi.
Dialogue: 0,0:02:53.63,0:02:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangannya bertepatan\Ndengan ritual Terminalia.
Dialogue: 0,0:02:57.65,0:02:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang diinginkan musuh?
Dialogue: 0,0:02:59.35,0:03:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Caldron!\NPihak akademi harus membantu—
Dialogue: 0,0:03:02.08,0:03:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:03:08.70,0:03:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerusuhan di ibu kota hanya pengecoh.
Dialogue: 0,0:03:11.75,0:03:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lindungi menara!
Dialogue: 0,0:03:14.95,0:03:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan musuh adalah kita.
Dialogue: 0,0:03:19.13,0:03:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah membuat penghalang besar,\NMagia Vander kehabisan energi sihir.
Dialogue: 0,0:03:25.30,0:03:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terminalia adalah satu-satunya momen dalam setahun
Dialogue: 0,0:03:28.48,0:03:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di mana semua Magia Vander melemah.
Dialogue: 0,0:03:32.23,0:03:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu si bodoh mana yang melakukannya,
Dialogue: 0,0:03:34.99,0:03:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mereka mengincar momen itu.
Dialogue: 0,0:03:37.49,0:03:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Cariott, kita harus membantu.
Dialogue: 0,0:03:40.85,0:03:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika keadaan ini berlanjut,\Nnyawa warga bisa melayang.
Dialogue: 0,0:03:43.85,0:03:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kekuatan Magia Vander—
Dialogue: 0,0:03:46.25,0:03:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diamlah, Logwell!
Dialogue: 0,0:03:50.05,0:03:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin batang tenggorokanmu\Ndicongkel seperti matamu, ya, bodoh.
Dialogue: 0,0:03:55.40,0:03:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan macam-macam.
Dialogue: 0,0:03:57.75,0:03:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai aibku.
Dialogue: 0,0:03:59.89,0:04:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kita lakukan, Kek?
Dialogue: 0,0:04:02.58,0:04:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap menonton dari tempat aman?
Dialogue: 0,0:04:04.89,0:04:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:04:07.40,0:04:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melarang Magia Vander\Nmeninggalkan tempat ini.
Dialogue: 0,0:04:11.28,0:04:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika salah satu dari kita kalah\Ndan penghalang besar lenyap,
Dialogue: 0,0:04:14.93,0:04:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjajah Langit akan menyerang.
Dialogue: 0,0:04:17.93,0:04:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu terjadi, bukan hanya Rigarden,\Nseluruh dunia akan terbakar habis.
Dialogue: 0,0:04:24.16,0:04:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mencegah hal itu.
Dialogue: 0,0:04:29.03,0:04:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Magia Vander bedebah itu\Nmasih belum keluar.
Dialogue: 0,0:04:32.67,0:04:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita sudah menebar umpan.
Dialogue: 0,0:04:35.67,0:04:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika salah satu dari mereka muncul,\Nkita bisa langsung membunuhnya.
Dialogue: 0,0:04:39.63,0:04:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita nikmati saja.
Dialogue: 0,0:04:42.10,0:04:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan fantastis ini.
Dialogue: 0,0:04:45.73,0:04:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:04:47.00,0:04:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para rakyat... harta ibu kota...
Dialogue: 0,0:04:50.06,0:04:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para talenta untuk melawan langit...
Dialogue: 0,0:04:53.05,0:04:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak boleh dibiarkan.
Dialogue: 0,0:04:56.10,0:04:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama!
Dialogue: 0,0:05:03.53,0:05:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aureum Iris!
Dialogue: 0,0:05:08.80,0:05:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:05:19.72,0:05:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Will!
Dialogue: 0,0:06:55.73,0:06:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dunia ini tidak adil padaku?
Dialogue: 0,0:07:00.13,0:07:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sekejam ini terhadap pedang?
Dialogue: 0,0:07:03.25,0:07:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah berpikir begitu.
Dialogue: 0,0:07:05.90,0:07:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa bohong\Ndan menyangkal kebencianku.
Dialogue: 0,0:07:09.13,0:07:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:07:13.87,0:07:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak menginginkan hal ini!
Dialogue: 0,0:07:26.88,0:07:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gemetar!
Dialogue: 0,0:07:28.78,0:07:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku berhenti karena takut,\Nmungkin seseorang akan mati!
Dialogue: 0,0:07:40.48,0:07:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:07:42.11,0:07:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalahkan monster bersenjata!
Dialogue: 0,0:07:46.03,0:07:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Crysto Wreath!
Dialogue: 0,0:07:49.55,0:07:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para penyihir masih bisa\Nmelawan monster tak bersenjata!
Dialogue: 0,0:07:53.98,0:07:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:08:07.00,0:08:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Kak Will bisa...
Dialogue: 0,0:08:09.33,0:08:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin orang itu bisa\Nmematahkan pembunuh penyihir!
Dialogue: 0,0:08:12.72,0:08:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dia tidak bisa\Nberbuat banyak seorang diri.
Dialogue: 0,0:08:15.93,0:08:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuhnya terlalu banyak.
Dialogue: 0,0:08:20.38,0:08:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iris, aku meminjamkan otoritasku.
Dialogue: 0,0:08:23.90,0:08:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerahkan para dwarf!\NHentikan kebiadaban ini!
Dialogue: 0,0:08:29.20,0:08:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Tuan Aaron.
Dialogue: 0,0:08:33.15,0:08:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas nama Masterias Noah,\Naku, Watcher, memerintahkan!
Dialogue: 0,0:08:37.03,0:08:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gordvere! Gordvere!
Dialogue: 0,0:08:39.35,0:08:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para dwarf diizinkan bertempur!
Dialogue: 0,0:08:42.00,0:08:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir dan dwarf harus kerja sama\Nuntuk membasmi para monster di kota!
Dialogue: 0,0:08:46.42,0:08:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diulangi!\NPerintah khusus: Gordvere!
Dialogue: 0,0:08:51.03,0:08:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:08:53.35,0:08:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon! Tolong bantu kami!
Dialogue: 0,0:08:57.78,0:09:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, baru ganti tahun,\Nlangsung disuruh kerja, ya?
Dialogue: 0,0:09:00.88,0:09:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar penyihir.
Dialogue: 0,0:09:02.10,0:09:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara terus, ayo pergi!
Dialogue: 0,0:09:04.13,0:09:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian!
Dialogue: 0,0:09:05.36,0:09:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo selamatkan Will dan yang lainnya!
Dialogue: 0,0:09:09.65,0:09:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dax Darbicans!
Dialogue: 0,0:09:14.18,0:09:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan para dwarf\Nmelawan monster bersenjata!
Dialogue: 0,0:09:16.90,0:09:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir harus fokus membasmi sisanya!
Dialogue: 0,0:09:19.50,0:09:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para siswa, kalian juga harus bekerja!
Dialogue: 0,0:09:22.50,0:09:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kekurangan orang!\NJadi penghambat pun boleh!
Dialogue: 0,0:09:25.88,0:09:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah tongkat sihir\Nyang melindungi rakyat!
Dialogue: 0,0:09:29.15,0:09:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekerja?
Dialogue: 0,0:09:30.60,0:09:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika penyihir agung pun kalah,\Napa yang bisa kita lakukan?
Dialogue: 0,0:09:34.01,0:09:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Owen Sique:
Dialogue: 0,0:09:35.51,0:09:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lisolde Dua!
Dialogue: 0,0:09:38.53,0:09:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hebat.
Dialogue: 0,0:09:43.23,0:09:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dengan penguatan pun,\Nmereka belum kalah dalam satu serangan.
Dialogue: 0,0:09:47.05,0:09:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah kekuatan monster strata dalam?
Dialogue: 0,0:09:48.98,0:09:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi...
Dialogue: 0,0:09:55.10,0:09:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mendekati senjata itu,\Nsegala macam sihir bisa lenyap.
Dialogue: 0,0:09:59.53,0:10:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penetral sihir?\NAtau penyerap energi sihir?
Dialogue: 0,0:10:03.30,0:10:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jelas, senjata itu sangat\Nmematikan bagi penyihir.
Dialogue: 0,0:10:06.68,0:10:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada cara mengatasinya...
Dialogue: 0,0:10:09.10,0:10:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihanna!
Dialogue: 0,0:10:09.88,0:10:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri!
Dialogue: 0,0:10:11.53,0:10:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette, apa kamu bisa\Nmelakukan sesuatu untukku?
Dialogue: 0,0:10:16.25,0:10:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:10:18.53,0:10:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alfs Ringhul!
Dialogue: 0,0:10:22.58,0:10:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir fantasi juga bisa dinetralkan?!
Dialogue: 0,0:10:24.98,0:10:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak mungkin bertahan di sini\Nsampai para dwarf datang!
Dialogue: 0,0:10:28.30,0:10:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Lihanna kehabisan tenaga,\Nkita semua akan habis!
Dialogue: 0,0:10:32.03,0:10:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus lari!
Dialogue: 0,0:10:33.90,0:10:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:10:34.95,0:10:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menghapus sihir,
Dialogue: 0,0:10:37.35,0:10:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}monster itu tampak sedikit melambat.
Dialogue: 0,0:10:39.83,0:10:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya...
Dialogue: 0,0:10:41.83,0:10:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujani musuh dengan sihir!
Dialogue: 0,0:10:43.50,0:10:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak mempan,\Nkita harus sudutkan musuh!
Dialogue: 0,0:10:46.12,0:10:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Glace Itier!\N- Verdes Lana!
Dialogue: 0,0:10:51.18,0:10:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo! Serang terus!
Dialogue: 0,0:10:53.51,0:10:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berhenti!
Dialogue: 0,0:10:57.01,0:10:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus. Ini sempurna.
Dialogue: 0,0:10:59.88,0:11:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini, monster lain pasti\Nberkumpul dan berlindung di belakang.
Dialogue: 0,0:11:04.43,0:11:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu...
Dialogue: 0,0:11:05.69,0:11:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette!
Dialogue: 0,0:11:06.69,0:11:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:11:11.15,0:11:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Biora!
Dialogue: 0,0:11:13.33,0:11:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:11:30.29,0:11:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghancurkan patung monumen\NMagia Vander yang berjaya di masa lalu.
Dialogue: 0,0:11:34.38,0:11:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tidak takut dosa.
Dialogue: 0,0:11:36.55,0:11:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:38.20,0:11:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak bisa menetralkan\Nobjek tanpa energi sihir.
Dialogue: 0,0:11:41.81,0:11:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan batu atau apa pun!
Dialogue: 0,0:11:43.60,0:11:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir tanah, serang mereka dengan benda!
Dialogue: 0,0:11:46.68,0:11:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuasailah ketidaktahuan, Rigarden!
Dialogue: 0,0:11:49.18,0:11:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:11:50.63,0:11:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian hebat, anak-anak akademi.
Dialogue: 0,0:11:53.40,0:11:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Calon pemanjat menara tahun ini\Ndipenuhi anak-anak kompeten.
Dialogue: 0,0:11:56.19,0:11:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai seratus untuk kalian.
Dialogue: 0,0:11:58.00,0:12:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan dengan serangan penyihir tanah!
Dialogue: 0,0:12:00.45,0:12:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para dwarf akan segera datang!
Dialogue: 0,0:12:02.83,0:12:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku benci\Nmengandalkan bantuan dwarf,
Dialogue: 0,0:12:06.05,0:12:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kami tidak bisa memilih!
Dialogue: 0,0:12:09.75,0:12:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini adalah wilayah Magia Vander!
Dialogue: 0,0:12:11.88,0:12:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membiarkannya jatuh!
Dialogue: 0,0:12:14.43,0:12:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rigarden memang hebat.\NMereka bisa bangkit kembali.
Dialogue: 0,0:12:17.28,0:12:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana kita agak cacat\Nkarena para idiot pembuat "sleime"
Dialogue: 0,0:12:20.08,0:12:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak sengaja bertemu tim ekspedisi.
Dialogue: 0,0:12:23.85,0:12:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu sleime kita direbut\NMasterias Noah dan kurcaci itu.
Dialogue: 0,0:12:29.70,0:12:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar kebetulan bodoh.
Dialogue: 0,0:12:32.63,0:12:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain karena pengerahan para dwarf,\Nsebagian penyihir bisa bertindak cepat.
Dialogue: 0,0:12:37.50,0:12:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Info tentang kartu as kita\Nsudah menyebar luas.
Dialogue: 0,0:12:40.66,0:12:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa repot jika institut tinggi
Dialogue: 0,0:12:43.28,0:12:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berhasil mempelajari sleime\Ndan menemukan cara melawannya.
Dialogue: 0,0:12:47.08,0:12:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita terpaksa mempercepat rencana
Dialogue: 0,0:12:49.35,0:12:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa bisa melakukan produksi massal.
Dialogue: 0,0:12:52.88,0:12:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kartu as kita masih tersembunyi,\Nkita pasti bisa memberi kejutan hebat.
Dialogue: 0,0:12:58.67,0:13:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sepertinya itu\Nbukan satu-satunya alasan.
Dialogue: 0,0:13:03.83,0:13:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat. Ini agak cepat, tapi...
Dialogue: 0,0:13:08.75,0:13:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya mengeluarkan kejutan spesial.
Dialogue: 0,0:13:17.88,0:13:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... sihir gerbang?
Dialogue: 0,0:13:20.78,0:13:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa yang akan muncul?
Dialogue: 0,0:14:08.20,0:14:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:09.63,0:14:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sudah main kejar-kejarannya.
Dialogue: 0,0:14:11.90,0:14:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian orang yang membuat\Nsenjata pembunuh penyihir itu, kan?
Dialogue: 0,0:14:16.85,0:14:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritakan semuanya.
Dialogue: 0,0:14:22.25,0:14:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlambat.
Dialogue: 0,0:14:23.73,0:14:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya ditugaskan\Nmemancingmu ke dungeon!
Dialogue: 0,0:14:28.40,0:14:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas sana mungkin sudah—
Dialogue: 0,0:14:33.88,0:14:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:15:09.28,0:15:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatannya besar sekali.
Dialogue: 0,0:15:11.14,0:15:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masuk akal.
Dialogue: 0,0:15:14.35,0:15:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa monster itu lebih kuat dari Grand Duke?
Dialogue: 0,0:15:18.70,0:15:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster itu...
Dialogue: 0,0:15:20.40,0:15:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Devander?
Dialogue: 0,0:15:22.13,0:15:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster Notorious dari strata 40?
Dialogue: 0,0:15:25.10,0:15:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster yang bisa membunuh\NMagia Vander di masa lalu.
Dialogue: 0,0:15:29.66,0:15:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sampai kehilangan 50 orang\Nsaat memaksanya masuk gerbang.
Dialogue: 0,0:15:34.68,0:15:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menangkapnya hidup-hidup\Nadalah pekerjaan sulit.
Dialogue: 0,0:15:37.68,0:15:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengamuklah sepuasnya!
Dialogue: 0,0:15:43.63,0:15:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bisa menghindari serangan fatal,\Naku masih terpental seperti kertas.
Dialogue: 0,0:15:47.83,0:15:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bisa dilawan secara frontal.
Dialogue: 0,0:15:50.26,0:15:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus lari!
Dialogue: 0,0:16:03.18,0:16:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan...
Dialogue: 0,0:16:09.33,0:16:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak Gagal?!\NKau...
Dialogue: 0,0:16:11.88,0:16:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari...
Dialogue: 0,0:16:15.63,0:16:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari!
Dialogue: 0,0:16:38.98,0:16:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau baik-baik saja, Will?
Dialogue: 0,0:16:41.63,0:16:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Donnan?
Dialogue: 0,0:16:43.23,0:16:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diamlah di situ!
Dialogue: 0,0:16:45.45,0:16:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan menghancurkan monster itu!
Dialogue: 0,0:16:49.36,0:16:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama siswa pembelajar,
Dialogue: 0,0:16:50.93,0:16:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}fokuskan kekuatan di bagian selatan!
Dialogue: 0,0:16:52.93,0:16:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Devander adalah prioritas utama!
Dialogue: 0,0:16:55.23,0:16:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pembunuh penyihir\Ndihancurkan oleh para dwarf,
Dialogue: 0,0:16:58.30,0:16:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lakukan serangan serentak!
Dialogue: 0,0:17:00.13,0:17:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, ayo!\N- Ya!
Dialogue: 0,0:17:06.00,0:17:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dikeroyok.
Dialogue: 0,0:17:08.82,0:17:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya benar.
Dialogue: 0,0:17:10.88,0:17:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai rencana.
Dialogue: 0,0:17:14.51,0:17:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, ayo makan!
Dialogue: 0,0:17:19.27,0:17:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:17:23.52,0:17:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya... menonjol keluar?
Dialogue: 0,0:17:30.15,0:17:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perangkap?! Kami terjebak!
Dialogue: 0,0:17:32.25,0:17:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serap jejak sihirnya!
Dialogue: 0,0:17:33.98,0:17:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telat!
Dialogue: 0,0:17:46.98,0:17:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan unik Devander\Nadalah penyerapan jejak sihir monster.
Dialogue: 0,0:17:52.48,0:17:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, dia bisa memakan sesamanya\Ndan menjadi super kuat!
Dialogue: 0,0:17:56.81,0:17:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan penyerapannya!
Dialogue: 0,0:17:58.81,0:18:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo serang, semuanya!
Dialogue: 0,0:18:06.95,0:18:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mimpi!
Dialogue: 0,0:18:08.40,0:18:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah kelahiran\Nmonster sejati dari situ!
Dialogue: 0,0:18:46.58,0:18:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:18:48.11,0:18:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir penyihir dipatahkan!
Dialogue: 0,0:18:50.20,0:18:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan fisik dwarf tidak mempan!
Dialogue: 0,0:18:54.10,0:18:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster-monster itu dijadikan korban?
Dialogue: 0,0:18:56.58,0:19:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan Rigarden dimanfaatkan\Nuntuk memperkuat kartu as musuh?!
Dialogue: 0,0:19:03.05,0:19:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta ini adalah ritual.\NIbu kota ini adalah altar.
Dialogue: 0,0:19:07.20,0:19:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh Magia Vander telah lahir!
Dialogue: 0,0:19:13.98,0:19:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu kuat.
Dialogue: 0,0:19:15.63,0:19:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para penyihir dan dwarf\Ntidak berdaya di depannya.
Dialogue: 0,0:19:19.50,0:19:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menghentikannya,
Dialogue: 0,0:19:21.22,0:19:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku butuh kekuatan itu!
Dialogue: 0,0:19:24.48,0:19:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will! Siapkan pedangmu!
Dialogue: 0,0:19:31.05,0:19:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Crysto Wreath!
Dialogue: 0,0:19:51.96,0:19:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rosty!
Dialogue: 0,0:20:15.58,0:20:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiki.
Dialogue: 0,0:20:17.03,0:20:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah ke tempat Colette.
Dialogue: 0,0:20:20.00,0:20:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi majikanmu.
Dialogue: 0,0:20:24.16,0:20:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji.
Dialogue: 0,0:20:26.40,0:20:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pergilah.
Dialogue: 0,0:20:36.50,0:20:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:38.10,0:20:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada satu hal yang harus kulakukan.
Dialogue: 0,0:20:46.18,0:20:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau semarah apa pun, aku tidak bisa menang.
Dialogue: 0,0:20:49.33,0:20:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berpikir setenang apa pun,\Nrencanaku tidak bekerja sama sekali.
Dialogue: 0,0:20:54.03,0:20:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengetahuan dan kebijaksanaan...
Dialogue: 0,0:20:56.10,0:20:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmu pedang yang kuciptakan...
Dialogue: 0,0:20:58.28,0:20:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan perasaan kecil ini...
Dialogue: 0,0:21:00.25,0:21:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya tidak berarti\Ndi hadapan kenyataan kejam.
Dialogue: 0,0:21:09.98,0:21:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku...
Dialogue: 0,0:21:16.28,0:21:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar, orang gagal sepertiku...
Dialogue: 0,0:21:27.53,0:21:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:29.63,0:21:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:21:32.55,0:21:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu bersamamu.
