Dialogue: 0,0:00:00.00,0:00:01.75,sign,,0000,0000,0000,,DUA TAHUN LALU
Dialogue: 0,0:03:24.96,0:03:29.69,sign,,0000,0000,0000,,EPISODE 23:\NES DAN PETIR MENGGELEGAR
Dialogue: 0,0:04:33.98,0:04:38.56,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA MUSIM 2
Dialogue: 0,0:11:11.30,0:11:12.43,sign,,0000,0000,0000,,THORZEUS FASCE
Dialogue: 0,0:11:12.70,0:11:16.07,sign,,0000,0000,0000,,ZEO THORZEUS REINBOLT
Dialogue: 0,0:11:17.78,0:11:21.09,sign,,0000,0000,0000,,SARISSA ALFELD
Dialogue: 0,0:23:28.12,0:23:31.07,sign,,0000,0000,0000,,TONGKAT SIHIR DAN PEDANG WISTORIA
Dialogue: 0,0:23:42.76,0:23:48.28,sign,,0000,0000,0000,,EPISODE 24: SEBUAH KISAH TANPA AKHIR
Dialogue: 0,0:00:01.80,0:00:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah binatang.
Dialogue: 0,0:00:03.55,0:00:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk biadab dan sombong.
Dialogue: 0,0:00:06.75,0:00:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak berpendidikan\Ndan tidak punya tata krama.
Dialogue: 0,0:00:10.70,0:00:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatnya saja sudah membuatku mual.
Dialogue: 0,0:00:13.80,0:00:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, Pak Tua.
Dialogue: 0,0:00:15.83,0:00:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dwarf itu berguna.
Dialogue: 0,0:00:17.88,0:00:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak dijadikan\Nanggota faksi menara saja?
Dialogue: 0,0:00:21.39,0:00:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak bisa menggunakan sihir.
Dialogue: 0,0:00:24.25,0:00:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan berarti\Nmereka tidak punya kemampuan.
Dialogue: 0,0:00:26.83,0:00:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada menggali lubang,
Dialogue: 0,0:00:28.52,0:00:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik biarkan mereka\Nmengamuk di dalam dungeon.
Dialogue: 0,0:00:32.50,0:00:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kalian tidak mau\Nkarena harga diri picik itu,
Dialogue: 0,0:00:35.70,0:00:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serahkan mereka kepadaku.
Dialogue: 0,0:00:38.23,0:00:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak lucu
Dialogue: 0,0:00:39.55,0:00:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika dunia hancur karena kita\Ntidak mengerahkan seluruh kemampuan kita.
Dialogue: 0,0:00:43.15,0:00:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin,
Dialogue: 0,0:00:44.93,0:00:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa ada alasan tertentu?
Dialogue: 0,0:00:49.98,0:00:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa bungkam.
Dialogue: 0,0:00:54.04,0:00:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:00:57.10,0:00:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maumu, Biadab?
Dialogue: 0,0:00:59.26,0:01:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau langsung mundur begitu saja.\NApa itu tadi cuma gertakan kosong?
Dialogue: 0,0:01:03.85,0:01:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak berdalih atau menyangkalku.
Dialogue: 0,0:01:07.88,0:01:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya bisa bungkam.
Dialogue: 0,0:01:10.35,0:01:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, ini belum waktu\Nyang tepat untuk terbuka.
Dialogue: 0,0:01:15.00,0:01:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kadang, nalurinya tajam.
Dialogue: 0,0:01:18.73,0:01:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama bisa menghajar\Npara Penjajah Langit sialan itu,
Dialogue: 0,0:01:21.80,0:01:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau saja dibodohi.
Dialogue: 0,0:01:24.08,0:01:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau tidak bisa mengalahkan mereka,
Dialogue: 0,0:01:26.43,0:01:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selesailah sudah.
Dialogue: 0,0:01:29.78,0:01:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membuat binatang itu\Ntetap duduk diam,
Dialogue: 0,0:01:33.03,0:01:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan singgasana Magia Vander pun\Ntidak cukup.
Dialogue: 0,0:01:39.13,0:01:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara hidupnya
Dialogue: 0,0:01:40.93,0:01:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlalu mengguncang\Nnorma-norma di dunia sihir.
Dialogue: 0,0:01:44.95,0:01:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berlebihan, Zeo.
Dialogue: 0,0:01:47.40,0:01:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meragukan akal sehatmu\Nkarena berani melawan Tuan Aaron.
Dialogue: 0,0:01:51.48,0:01:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku yang bilang begitu.
Dialogue: 0,0:01:53.44,0:01:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika situasi ini merugikan kita,\Nkenapa tidak mencoba berubah?
Dialogue: 0,0:01:57.85,0:02:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya menghambat,\Nbuang saja akal sehat dan tatanan.
Dialogue: 0,0:02:01.83,0:02:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama nilai-nilai para penyihir.
Dialogue: 0,0:02:07.43,0:02:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersikaplah seperti seorang Magia Vander.
Dialogue: 0,0:02:10.47,0:02:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah aku baru bilang begitu kemarin?
Dialogue: 0,0:02:12.45,0:02:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mau" atau "tidak mau".
Dialogue: 0,0:02:15.43,0:02:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup cuma sesimpel itu.
Dialogue: 0,0:02:18.68,0:02:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara hidup sederhana itu\Ntidak hanya membuatku heran,
Dialogue: 0,0:02:21.93,0:02:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi juga membuatku sedikit iri.
Dialogue: 0,0:02:25.78,0:02:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang bodoh memang enak\Nkarena jarang berpikir, ya, Zeo.
Dialogue: 0,0:02:28.85,0:02:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalianlah yang kebanyakan berpikir.
Dialogue: 0,0:02:31.85,0:02:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bertindak sesuai hasratku.
Dialogue: 0,0:02:35.23,0:02:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:02:36.58,0:02:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si bodoh tanpa kekuatan\Nhanyalah orang dungu biasa.
Dialogue: 0,0:02:39.33,0:02:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, si bodoh yang memiliki kekuatan itu
Dialogue: 0,0:02:43.23,0:02:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlalu berbahaya.
Dialogue: 0,0:02:47.15,0:02:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menjadi sekutu, tidak ada masalah.
Dialogue: 0,0:02:49.55,0:02:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, saat menjadi musuh,
Dialogue: 0,0:02:52.55,0:02:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat Sihir Kaisar Petir, Thorzeus Fasce,
Dialogue: 0,0:02:56.08,0:02:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah rintangan terburuk.
Dialogue: 0,0:03:01.05,0:03:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ambil bocah ini.
Dialogue: 0,0:03:04.23,0:03:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:03:06.70,0:03:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti saat ini!
Dialogue: 0,0:04:41.10,0:04:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali, ya.
Dialogue: 0,0:04:42.77,0:04:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak ingin menyerahkan Will\Nkepada siapa pun.
Dialogue: 0,0:04:47.32,0:04:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kamu jadi penghalang,\Naku akan menghancurkanmu!
Dialogue: 0,0:04:51.32,0:04:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, Cewek Jalang.
Dialogue: 0,0:04:53.00,0:04:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita duel.\NPemenang dapat segalanya.
Dialogue: 0,0:04:55.57,0:04:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada masalah, kan?
Dialogue: 0,0:04:57.40,0:04:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa takut!
Dialogue: 0,0:04:58.81,0:05:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukanlah ide bagus!\NMagia Vander tidak boleh berduel!
Dialogue: 0,0:05:03.65,0:05:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, tolong hentikan mereka!
Dialogue: 0,0:05:06.67,0:05:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja.
Dialogue: 0,0:05:08.60,0:05:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kami ikut campur,\Nmasalahnya hanya akan tertunda.
Dialogue: 0,0:05:13.32,0:05:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika si perempuan malas\Ndan si biadab itu saling bunuh,
Dialogue: 0,0:05:16.42,0:05:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}suasana hatiku bisa membaik.
Dialogue: 0,0:05:18.47,0:05:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:05:21.57,0:05:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarissa, tolong jaga Will.
Dialogue: 0,0:05:25.22,0:05:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, sebentar...
Dialogue: 0,0:05:31.65,0:05:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu!\NApa mereka serius?!
Dialogue: 0,0:05:34.05,0:05:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir terkuat di dunia\Nberduel karena hal sepele begini?
Dialogue: 0,0:05:37.73,0:05:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:05:39.30,0:05:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah Magia Vander.
Dialogue: 0,0:05:43.62,0:05:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana aba-abanya?
Dialogue: 0,0:05:44.87,0:05:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah! Majulah!
Dialogue: 0,0:05:47.02,0:05:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ini bukan waktunya tidur!
Dialogue: 0,0:05:49.00,0:05:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunlah!
Dialogue: 0,0:05:51.65,0:05:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Glace Frosse.
Dialogue: 0,0:05:55.15,0:05:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Seven:
Dialogue: 0,0:06:02.20,0:06:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fruzel Cardeneia!
Dialogue: 0,0:06:13.64,0:06:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan pembuka?!
Dialogue: 0,0:06:14.51,0:06:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir besar?!
Dialogue: 0,0:06:19.07,0:06:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang kau serang?
Dialogue: 0,0:06:21.50,0:06:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raungan Petir!
Dialogue: 0,0:06:26.69,0:06:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria?!
Dialogue: 0,0:06:38.07,0:06:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ars Weiss?
Dialogue: 0,0:06:39.75,0:06:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan?
Dialogue: 0,0:06:41.55,0:06:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau melakukannya dalam sekejap\Nsaat Cardeneia menghalangi pandangan.
Dialogue: 0,0:06:45.92,0:06:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria memiliki kemampuan\Npengaktifan sihir tercepat di menara.
Dialogue: 0,0:06:51.00,0:06:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekejamannya ke musuh\Njuga tidak ada tandingannya,
Dialogue: 0,0:06:54.27,0:06:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan di antara Magia Vander.
Dialogue: 0,0:06:57.57,0:06:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyerahkan Will!
Dialogue: 0,0:07:00.45,0:07:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Armenta Auliscas.
Dialogue: 0,0:07:06.07,0:07:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir beruntun tanpa mantra?!
Dialogue: 0,0:07:07.61,0:07:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dengan sihir superior\Nyang butuh mantra sepuluh bait?!
Dialogue: 0,0:07:11.70,0:07:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam sekejap, dia mengaktifkan sihir\Nyang membuatku susah payah di strata 11?!
Dialogue: 0,0:07:16.82,0:07:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masuk akal!
Dialogue: 0,0:07:21.72,0:07:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Riville Calantibium.
Dialogue: 0,0:07:23.90,0:07:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stellas Natea.
Dialogue: 0,0:07:28.82,0:07:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menciptakan klona\Nyang bisa berperan sebagai artileri.
Dialogue: 0,0:07:32.82,0:07:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak lebih aktif\Ndan seenaknya sendiri.
Dialogue: 0,0:07:36.17,0:07:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain berkekuatan tinggi,\Nserangannya cepat dan akurat.
Dialogue: 0,0:07:40.07,0:07:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam baku tembak jarak jauh,\NElfaria memang lebih diunggulkan.
Dialogue: 0,0:07:44.65,0:07:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, lawannya juga monster.
Dialogue: 0,0:07:49.70,0:07:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Basi banget!
Dialogue: 0,0:07:57.67,0:07:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Volgan Flote.
Dialogue: 0,0:08:04.29,0:08:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa cuma segini?!
Dialogue: 0,0:08:06.90,0:08:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cewek Jalang!
Dialogue: 0,0:08:10.20,0:08:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaulah yang terakhir!
Dialogue: 0,0:08:13.15,0:08:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zalgia Saga!
Dialogue: 0,0:08:16.27,0:08:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klona lagi.
Dialogue: 0,0:08:18.25,0:08:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang asli...
Dialogue: 0,0:08:19.82,0:08:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di atas!
Dialogue: 0,0:08:21.85,0:08:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan selama ini\Nhanya sekadar persiapan
Dialogue: 0,0:08:25.22,0:08:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar dia bisa terbang ke atas\Ndan menyiapkan serangan utama.
Dialogue: 0,0:08:29.25,0:08:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil membuat klona detail\Nyang bisa menipu Magia Vander.
Dialogue: 0,0:08:34.00,0:08:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga pakai sihir kamuflase\Nuntuk mengelabui sihir deteksi.
Dialogue: 0,0:08:39.82,0:08:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu bisa bersenang-senang\Nsaat bermain dengan bonekaku?
Dialogue: 0,0:08:44.70,0:08:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chain Circle, Full Connect.
Dialogue: 0,0:08:48.10,0:08:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grand Glast Dogra.
Dialogue: 0,0:08:51.67,0:08:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga!
Dialogue: 0,0:08:57.35,0:08:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Pelindung!
Dialogue: 0,0:09:04.02,0:09:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}C-Chain Circle?
Dialogue: 0,0:09:06.00,0:09:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klona hancur pun juga dimanfaatkan\Nuntuk meningkatkan daya hancurnya.
Dialogue: 0,0:09:10.92,0:09:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan itu terlalu mematikan,\Nbahkan untuk seorang Magia Vander.
Dialogue: 0,0:09:15.17,0:09:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:09:17.60,0:09:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka-boneka itu masih kurang memuaskan.
Dialogue: 0,0:09:28.10,0:09:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan!
Dialogue: 0,0:09:30.62,0:09:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:09:33.00,0:09:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuhlah dulu!
Dialogue: 0,0:09:54.28,0:09:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria!
Dialogue: 0,0:10:01.17,0:10:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengambil bocah itu!
Dialogue: 0,0:10:12.02,0:10:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dari penyihir biasa,\Ndia selalu menyerang dari dekat.
Dialogue: 0,0:10:15.42,0:10:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?
Dialogue: 0,0:10:16.55,0:10:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia pakai sihir tempur\Njarak dekat seperti Lihanna?
Dialogue: 0,0:10:19.32,0:10:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:10:20.35,0:10:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya melepaskan\Nenergi sihir dari tubuh.
Dialogue: 0,0:10:23.77,0:10:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:10:25.22,0:10:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat baik-baik, Owenzaus.
Dialogue: 0,0:10:27.75,0:10:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah titik tertinggi\Nyang harus dikejar Faksi Petir.
Dialogue: 0,0:10:32.55,0:10:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa rangkaian sihir rumit
Dialogue: 0,0:10:34.87,0:10:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau bisa mengabaikan segalanya\Nhanya dengan mengalirkan energi sihir.
Dialogue: 0,0:10:38.45,0:10:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi Tuan Zeo, itu hanya\Nseperti pergerakan biasa.
Dialogue: 0,0:10:41.60,0:10:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik itu disebut "Amarah Petir"\Noleh mereka yang takut dan kagum.
Dialogue: 0,0:10:46.07,0:10:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amarah Petir milik Zeo berhasil\Nmelampaui kecepatan sihir Elfaria.
Dialogue: 0,0:10:51.04,0:10:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potensi monster mahadahsyat\Nyang menyangkal teori apa pun.
Dialogue: 0,0:10:57.17,0:11:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah simbol ketidakterukuran\Nyang selama ini kubenci.
Dialogue: 0,0:11:02.27,0:11:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah kekuatan Magia Vander,
Dialogue: 0,0:11:05.57,0:11:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thorzeus Fasce, Zeo Thorzeus Reinbolt?!
Dialogue: 0,0:11:22.40,0:11:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Valgnahr Donner!
Dialogue: 0,0:11:33.55,0:11:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frall!
Dialogue: 0,0:11:36.85,0:11:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurlah!
Dialogue: 0,0:11:45.57,0:11:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu siapa yang akan menang, Finn?
Dialogue: 0,0:11:48.50,0:11:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zeo.
Dialogue: 0,0:11:51.55,0:11:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Elfaria disebut ratu realisasi\Nkarena menciptakan dua belas sihir,
Dialogue: 0,0:11:56.27,0:11:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zeo adalah raja praksis.
Dialogue: 0,0:12:00.55,0:12:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klona lagi, ya?
Dialogue: 0,0:12:02.87,0:12:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xelunea Caulis!
Dialogue: 0,0:12:11.97,0:12:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang pintar bermain trik sulap licik.
Dialogue: 0,0:12:15.22,0:12:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyadari pertukaran posisimu.
Dialogue: 0,0:12:22.82,0:12:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klonamu sudah mulai habis, ya.
Dialogue: 0,0:12:40.25,0:12:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau cuma bisa lari?!
Dialogue: 0,0:12:47.70,0:12:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia telah mencapai strata 48
Dialogue: 0,0:12:49.55,0:12:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga kemajuannya\Nberada tepat di bawah Aaron.
Dialogue: 0,0:12:52.30,0:12:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuannya terlalu sempurna\Nuntuk digunakan dalam pertempuran.
Dialogue: 0,0:13:10.32,0:13:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang tongkat sihir,\Ntapi dia lebih mirip pedang.
Dialogue: 0,0:13:15.82,0:13:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh jujur,
Dialogue: 0,0:13:17.32,0:13:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurutku Will bisa berkembang\Njika dia bergabung dengan faksi Zeo.
Dialogue: 0,0:13:22.69,0:13:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dari pertarungan jarak jauh,
Dialogue: 0,0:13:24.42,0:13:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam jarak dekat, Zeo lebih mendominasi.
Dialogue: 0,0:13:27.67,0:13:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya hasilnya sudah jelas.
Dialogue: 0,0:13:33.72,0:13:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lefiya, kenapa Nona Ellenor\Ntampak cemberut sejak tadi?
Dialogue: 0,0:13:39.05,0:13:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begini, Filvis.
Dialogue: 0,0:13:41.07,0:13:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam duel sihir es,
Dialogue: 0,0:13:43.87,0:13:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ellenor pernah dikalahkan Albis Vina,
Dialogue: 0,0:13:46.32,0:13:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi beliau tidak ingin\Nmelihatnya menang atau kalah.
Dialogue: 0,0:13:49.20,0:13:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau sedang galau berat.
Dialogue: 0,0:13:51.52,0:13:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:13:52.62,0:13:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tutup mulut kalian!
Dialogue: 0,0:14:00.02,0:14:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria.
Dialogue: 0,0:14:02.57,0:14:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, cepat bangun!
Dialogue: 0,0:14:04.47,0:14:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus,\NNona Elfaria bisa kalah!
Dialogue: 0,0:14:08.22,0:14:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adalah satu-satunya orang\Nyang bisa jadi penyemangatnya!
Dialogue: 0,0:14:14.65,0:14:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie...
Dialogue: 0,0:14:22.87,0:14:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai, ya?
Dialogue: 0,0:14:24.40,0:14:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan\Nmengambil pedangmu itu.
Dialogue: 0,0:14:41.07,0:14:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini belum selesai, Finn.
Dialogue: 0,0:14:43.95,0:14:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu sangat gigih seperti Will.
Dialogue: 0,0:14:47.77,0:14:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kuserahkan.
Dialogue: 0,0:14:49.57,0:14:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will adalah milikku
Dialogue: 0,0:14:51.17,0:14:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku tidak akan menyerahkannya padamu!
Dialogue: 0,0:14:53.45,0:14:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menggonggong, ya?
Dialogue: 0,0:14:55.02,0:14:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku melihatmu\Ndikuasai amarah!
Dialogue: 0,0:14:59.12,0:15:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang mendorongmu sampai sejauh ini?!
Dialogue: 0,0:15:05.90,0:15:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta!
Dialogue: 0,0:15:07.72,0:15:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:15:11.15,0:15:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will selalu melindungiku.
Dialogue: 0,0:15:14.82,0:15:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will selalu mengejarku.
Dialogue: 0,0:15:18.52,0:15:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will selalu menjaga janji kami.
Dialogue: 0,0:15:23.71,0:15:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, sekarang adalah\Ngiliranku berjuang untuknya!
Dialogue: 0,0:15:27.75,0:15:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cintaku terhadap Will\Ntidak akan kalah dari siapa pun!
Dialogue: 0,0:15:32.15,0:15:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah sumber hasratmu?!
Dialogue: 0,0:15:37.37,0:15:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tunjukkan kepadaku!
Dialogue: 0,0:15:40.40,0:15:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan konyolmu itu!
Dialogue: 0,0:15:44.97,0:15:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amarah Petir Zeo memiliki kecepatan dewa.
Dialogue: 0,0:15:47.55,0:15:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mengalirkan\Nlistrik ke sekujur tubuhnya,
Dialogue: 0,0:15:49.90,0:15:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bisa meningkatkan\Nkecepatan bergerak dan reaksinya,
Dialogue: 0,0:15:54.27,0:15:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga serangannya\Nmembuat penyihir tak berkutik.
Dialogue: 0,0:15:57.32,0:15:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:15:58.27,0:15:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Glace Frosse.
Dialogue: 0,0:16:00.32,0:16:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Ten:
Dialogue: 0,0:16:02.47,0:16:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Amarah Petir itu bisa dibekukan,
Dialogue: 0,0:16:05.22,0:16:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tidak akan bisa apa-apa.
Dialogue: 0,0:16:08.55,0:16:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mildas Froiderite!
Dialogue: 0,0:16:12.00,0:16:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keparat! Apa ini?!
Dialogue: 0,0:16:14.90,0:16:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah kartu as rahasiaku\Nyang sangat merepotkan.
Dialogue: 0,0:16:19.85,0:16:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membuat area khusus\Ndengan setengah dari energi sihirku
Dialogue: 0,0:16:25.31,0:16:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menciptakan ranah beku abadi ini.
Dialogue: 0,0:16:27.50,0:16:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelemahannya adalah harus\Nmenembakkan sihir terus menerus.
Dialogue: 0,0:16:31.47,0:16:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi rentetan sihir superior itu\Nhanya persiapan untuk sihir ini?!
Dialogue: 0,0:16:35.65,0:16:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia telah menduga situasi tersudut\Ndan menyiapkan perangkap terbesar.
Dialogue: 0,0:16:40.37,0:16:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga berhasil membungkam sihirku\Ndengan kartu as itu.
Dialogue: 0,0:16:45.22,0:16:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menjadi titik beku yang akan membekukan
Dialogue: 0,0:16:48.00,0:16:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghentikan segalanya.
Dialogue: 0,0:16:50.22,0:16:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecepatan si biadab itu\Nmalah menjadi bumerang.
Dialogue: 0,0:16:53.77,0:16:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku menciptakan sihir ini\Nuntuk menangkap
Dialogue: 0,0:16:58.35,0:17:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memeluk Will yang pemalu.
Dialogue: 0,0:17:01.39,0:17:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, karena sudah terlanjur kupakai,\Naku akan menghancurkanmu dengan ini.
Dialogue: 0,0:17:07.15,0:17:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalang licik!
Dialogue: 0,0:17:10.09,0:17:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will adalah
Dialogue: 0,0:17:12.00,0:17:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}satu-satunya orang
Dialogue: 0,0:17:15.31,0:17:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang akan menikah denganku!
Dialogue: 0,0:17:24.52,0:17:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Zeo!
Dialogue: 0,0:17:25.90,0:17:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria membalas!
Dialogue: 0,0:17:27.92,0:17:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, lihat!
Dialogue: 0,0:17:29.17,0:17:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Elfaria berhasil!
Dialogue: 0,0:17:31.82,0:17:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie?
Dialogue: 0,0:17:39.12,0:17:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Perampas telah datang!
Dialogue: 0,0:17:42.57,0:17:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh Cahaya tanpa setitik noda!
Dialogue: 0,0:17:45.60,0:17:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Suci tanpa dosa!
Dialogue: 0,0:17:49.10,0:17:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengoklah puncak kejayaan\Nyang telah lama dijanjikan!
Dialogue: 0,0:17:54.37,0:17:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuilah bahwa segala kejayaan bisa runtuh\Nkarena ular berbisa!
Dialogue: 0,0:18:00.22,0:18:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zeo merapal mantra?\NSepertinya dia mulai serius.
Dialogue: 0,0:18:03.62,0:18:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mendobrak zona pelindung\Nyang bisa membekukan sihir,
Dialogue: 0,0:18:07.47,0:18:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia memang butuh daya hancur\Nyang lebih besar, tapi...
Dialogue: 0,0:18:11.30,0:18:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkutuklah kau, manusia biadab\Nyang tidak tahu aturan!
Dialogue: 0,0:18:14.02,0:18:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lefiya, Filvis!
Dialogue: 0,0:18:15.90,0:18:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siap laksanakan!
Dialogue: 0,0:18:18.50,0:18:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih!
Dialogue: 0,0:18:19.95,0:18:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:18:21.57,0:18:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihat sihir seperti itu.
Dialogue: 0,0:18:24.62,0:18:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, sihir itu...
Dialogue: 0,0:18:27.57,0:18:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu sihir yang lebih tinggi\Ndari sihir superior?
Dialogue: 0,0:18:33.02,0:18:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir Ekstrem!
Dialogue: 0,0:18:35.82,0:18:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Es putih melimpah ruah.
Dialogue: 0,0:18:37.97,0:18:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pusaran malapetaka datang.
Dialogue: 0,0:18:40.05,0:18:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perisai pelindung terkoyak.
Dialogue: 0,0:18:42.30,0:18:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa peperangan tertinggal.
Dialogue: 0,0:18:44.40,0:18:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Firdaus pun mati
Dialogue: 0,0:18:46.67,0:18:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terkubur debu keperakan.
Dialogue: 0,0:18:48.87,0:18:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angin salju menderu.
Dialogue: 0,0:18:50.67,0:18:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang penyihir pun\Nmengenang seribu pahlawan!
Dialogue: 0,0:18:54.90,0:18:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dosa dari dusta
Dialogue: 0,0:18:56.45,0:18:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mendatangkan ganjaran tidak adil.
Dialogue: 0,0:18:58.22,0:19:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang stigma dosa atas segala pelanggaran
Dialogue: 0,0:19:00.45,0:19:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke ujung lautan darah!
Dialogue: 0,0:19:03.75,0:19:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuhlah, nama-nama luhur!
Dialogue: 0,0:19:06.15,0:19:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyanyian guntur berbalik
Dialogue: 0,0:19:07.72,0:19:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi pedang yang membantai cintamu!
Dialogue: 0,0:19:10.65,0:19:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurlah, akal-akal sehat!
Dialogue: 0,0:19:12.80,0:19:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ratapan kesedihan itu\Nmendambakan topeng Minos!
Dialogue: 0,0:19:22.72,0:19:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyerang, bergerak,\Ndan merapal mantra bersamaan.
Dialogue: 0,0:19:27.07,0:19:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah Perapalan Harmoni.
Dialogue: 0,0:19:29.20,0:19:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sampai mencuri teknik rahasia Elf.
Dialogue: 0,0:19:31.30,0:19:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul-betul manusia biadab.
Dialogue: 0,0:19:40.37,0:19:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rakyat pun lenyap.
Dialogue: 0,0:19:41.60,0:19:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjajah sirna.
Dialogue: 0,0:19:42.97,0:19:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ketiadaan pun datang.
Dialogue: 0,0:19:45.57,0:19:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang penyihir berdiri sendirian\Ndi kastel es.
Dialogue: 0,0:19:48.57,0:19:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air mata menuai makam.
Dialogue: 0,0:19:49.90,0:19:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Doa-doa menuai abu.
Dialogue: 0,0:19:51.45,0:19:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan sumpah menuai akhir.
Dialogue: 0,0:19:53.57,0:19:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singgasana kesepian pun kini\Nmenyatakan diri sebagai pelindung.
Dialogue: 0,0:19:57.92,0:19:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perapalan Warisan.
Dialogue: 0,0:19:59.77,0:20:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meneruskan bait dengan klona\Ndan menyambungkan rapalan mantra.
Dialogue: 0,0:20:03.65,0:20:05.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu versi asli dari teknik
Dialogue: 0,0:20:05.10,0:20:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diajarkan padaku\Nsaat melawan Grand Duke.
Dialogue: 0,0:20:10.02,0:20:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:20:11.97,0:20:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Elfie bertarung?
Dialogue: 0,0:20:16.85,0:20:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipu daya keji menjadi\Nkapak untuk kebenaran!
Dialogue: 0,0:20:20.15,0:20:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rampaslah!
Dialogue: 0,0:20:21.67,0:20:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tindaslah!
Dialogue: 0,0:20:23.37,0:20:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantailah!
Dialogue: 0,0:20:25.22,0:20:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumbalkan ular berbisa\Nuntuk merayakan keputusasaan!
Dialogue: 0,0:20:30.95,0:20:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan sayap tanah beku,
Dialogue: 0,0:20:32.90,0:20:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}paruh sang penjaga,
Dialogue: 0,0:20:34.75,0:20:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kebenaran putih.
Dialogue: 0,0:20:36.57,0:20:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Engkaulah raja langit es\Nyang memutus rantai duka!
Dialogue: 0,0:20:40.72,0:20:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis bernyanyi riang!
Dialogue: 0,0:20:42.57,0:20:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahardika bersenandung khidmat!
Dialogue: 0,0:20:44.50,0:20:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melantunkan pujian abadi
Dialogue: 0,0:20:45.99,0:20:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk bunga fana yang membohongi dunia!
Dialogue: 0,0:20:52.25,0:20:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurlah, Kerajaan Guntur bergemuruh!
Dialogue: 0,0:20:54.08,0:20:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarlah kiamat konyol terjadi!
Dialogue: 0,0:20:56.75,0:20:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datanglah, Dunia Perak!
Dialogue: 0,0:20:58.40,0:21:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadirkan langit damai tanpa konflik!
Dialogue: 0,0:21:00.92,0:21:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie! Tunggu...
Dialogue: 0,0:21:27.95,0:21:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vilgus Argo Thorzeus!
Dialogue: 0,0:21:31.90,0:21:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glacia Last Albis!
Dialogue: 0,0:21:43.50,0:21:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dio Grail!
Dialogue: 0,0:23:36.78,0:23:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Tongkat Sihir\Ndan Pedang Wistoria,
Dialogue: 0,0:23:39.55,0:23:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}episode dua puluh empat:\N"Sebuah Kisah Tanpa Akhir".
