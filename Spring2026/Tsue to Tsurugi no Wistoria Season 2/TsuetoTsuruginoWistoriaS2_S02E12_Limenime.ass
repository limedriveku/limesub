Dialogue: 0,0:00:04.81,0:00:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ledakan besar dari dalam menara!
Dialogue: 0,0:00:06.81,0:00:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kekuatannya sedahsyat ini...
Dialogue: 0,0:00:10.08,0:00:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster tak masuk akal\Nyang menyebalkan!
Dialogue: 0,0:00:13.70,0:00:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Magia Vander!
Dialogue: 0,0:01:50.15,0:01:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku masih hidup.
Dialogue: 0,0:01:52.24,0:01:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir aku akan mati.
Dialogue: 0,0:01:54.27,0:01:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie!
Dialogue: 0,0:02:02.84,0:02:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imbang, ya.
Dialogue: 0,0:02:04.82,0:02:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau boleh juga, Keparat!
Dialogue: 0,0:02:07.07,0:02:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku yang bilang begitu!
Dialogue: 0,0:02:09.44,0:02:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi sihirku sudah habis.
Dialogue: 0,0:02:13.00,0:02:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:02:14.31,0:02:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini masih belum selesai, kan?
Dialogue: 0,0:02:16.08,0:02:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:02:18.71,0:02:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo maju!
Dialogue: 0,0:02:20.80,0:02:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan kalah!
Dialogue: 0,0:02:32.42,0:02:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup.
Dialogue: 0,0:02:37.23,0:02:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir, Ellenor!
Dialogue: 0,0:02:39.08,0:02:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya sudah habis, bodoh.
Dialogue: 0,0:02:41.11,0:02:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal lebih seru kalau\Nkalian saling menghancurkan.
Dialogue: 0,0:02:44.48,0:02:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah, sialan!
Dialogue: 0,0:02:46.15,0:02:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah berbaik hati\Nmenjadi pengawas kalian.
Dialogue: 0,0:02:48.11,0:02:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah sendiri karena belum\Nbisa menyelesaikannya, Zeo.
Dialogue: 0,0:02:51.82,0:02:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:02:53.68,0:02:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian tidak bisa\Nmembantah sang raja, kan?
Dialogue: 0,0:03:02.77,0:03:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:03:08.31,0:03:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengizinkan konflik\Ndi antara sesama Magia Vander.
Dialogue: 0,0:03:13.42,0:03:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengganggu, Pak Tua!
Dialogue: 0,0:03:15.01,0:03:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja mendamaikan kami!
Dialogue: 0,0:03:17.53,0:03:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak akan berhenti\Nsampai mendapatkan Will!
Dialogue: 0,0:03:19.68,0:03:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya cara\Ncuma bertarung, kan?!
Dialogue: 0,0:03:38.33,0:03:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suit.
Dialogue: 0,0:03:41.66,0:03:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Suit?!
Dialogue: 0,0:03:48.35,0:03:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kalian memakai cara lain,\Naku akan merekrut Will Serfort.
Dialogue: 0,0:03:56.40,0:03:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalkan tangan kalian.
Dialogue: 0,0:04:00.08,0:04:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangsat!
Dialogue: 0,0:04:02.13,0:04:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, sialan!
Dialogue: 0,0:04:03.76,0:04:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa takut!
Dialogue: 0,0:04:06.22,0:04:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu, gunting, kertas!
Dialogue: 0,0:04:08.82,0:04:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulangi lagi!
Dialogue: 0,0:04:10.33,0:04:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulangi lagi! Ulangi lagi!
Dialogue: 0,0:04:14.66,0:04:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, Julius.\N- Ulangi lagi! Ulangi lagi! Ulangi lagi!
Dialogue: 0,0:04:16.75,0:04:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa yang terjadi?\N- Ulangi lagi! Ulangi lagi! Ulangi lagi!
Dialogue: 0,0:04:19.07,0:04:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semuanya karena kau.\N- Ulangi lagi! Ulangi lagi! Ulangi lagi!
Dialogue: 0,0:04:23.17,0:04:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulangi lagi!
Dialogue: 0,0:04:25.33,0:04:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulangi lagi! Ulangi lagi!
Dialogue: 0,0:04:28.42,0:04:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulangi lagi! Ulangi lagi! Ulangi lagi!
Dialogue: 0,0:04:33.00,0:04:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulangi lagi! Ulangi lagi!
Dialogue: 0,0:04:35.91,0:04:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulangi lagi!
Dialogue: 0,0:04:48.48,0:04:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arghh!
Dialogue: 0,0:04:51.36,0:04:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menang!
Dialogue: 0,0:04:53.35,0:04:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepuk tangan, Owenzaus!
Dialogue: 0,0:04:55.66,0:04:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:04:59.31,0:05:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Elfie.
Dialogue: 0,0:05:01.91,0:05:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah jadi milikku!
Dialogue: 0,0:05:03.88,0:05:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan protes lagi!
Dialogue: 0,0:05:07.04,0:05:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NTidak! Tidak! Tidak!
Dialogue: 0,0:05:10.08,0:05:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bersama Will!
Dialogue: 0,0:05:14.37,0:05:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will! Aku tidak mau!
Dialogue: 0,0:05:18.02,0:05:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:05:19.73,0:05:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kami berpisah,\NElfie memanjat menara sendirian
Dialogue: 0,0:05:23.97,0:05:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menungguku selama enam tahun.
Dialogue: 0,0:05:27.02,0:05:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku juga ingin bersamanya.
Dialogue: 0,0:05:29.82,0:05:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:05:31.75,0:05:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:05:34.02,0:05:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan bertemu lagi.
Dialogue: 0,0:05:35.97,0:05:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Aku akan menemuimu.
Dialogue: 0,0:05:39.64,0:05:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will...
Dialogue: 0,0:05:41.06,0:05:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona!
Dialogue: 0,0:05:42.16,0:05:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita pergi!
Dialogue: 0,0:05:43.41,0:05:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mematuhi Tuan Aaron!
Dialogue: 0,0:05:47.67,0:05:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?! Bentar!
Dialogue: 0,0:05:48.68,0:05:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan! Jangan! Jangan! Jangan!\N- Jangan permalukan diri Anda lebih jauh!
Dialogue: 0,0:05:50.80,0:05:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nggak mau! Ogah! Ogah!\N- Jangan permalukan diri Anda lebih jauh!
Dialogue: 0,0:05:52.75,0:05:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nona Elfaria!\N- Lepaskan! Tolong aku, Will!
Dialogue: 0,0:05:55.17,0:05:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:06:01.48,0:06:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau patuh juga, ya.
Dialogue: 0,0:06:03.60,0:06:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau akan berontak\Nseperti seekor binatang buas.
Dialogue: 0,0:06:07.11,0:06:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika saya menuruti ego,
Dialogue: 0,0:06:09.13,0:06:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin Elfie akan bertarung\Ndan membuat dirinya terluka lagi.
Dialogue: 0,0:06:12.82,0:06:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:06:14.46,0:06:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisakah Anda berjanji?
Dialogue: 0,0:06:16.68,0:06:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk tidak memusuhi Elfie lagi.
Dialogue: 0,0:06:19.40,0:06:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Anda menolak,
Dialogue: 0,0:06:22.04,0:06:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya akan mengalahkan Anda\Ndan mengejar Elfie sekarang juga!
Dialogue: 0,0:06:33.86,0:06:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyalimu boleh juga, Bocah!
Dialogue: 0,0:06:36.08,0:06:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka!
Dialogue: 0,0:06:51.42,0:06:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini,\Nkau adalah anggota Faksi Petir.
Dialogue: 0,0:07:04.62,0:07:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan berbaik hati!
Dialogue: 0,0:07:06.55,0:07:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapkan dirimu!
Dialogue: 0,0:07:09.13,0:07:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:07:21.77,0:07:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkatan ke-401 atau Generasi Berliku!
Dialogue: 0,0:07:25.57,0:07:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat karena semuanya masuk faksi,
Dialogue: 0,0:07:27.28,0:07:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa terkecuali!
Dialogue: 0,0:07:29.74,0:07:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:07:31.43,0:07:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!
Dialogue: 0,0:07:33.83,0:07:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:07:36.10,0:07:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Siapa bilang kita boleh\Nbikin keributan di dalam menara!
Dialogue: 0,0:07:40.15,0:07:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masalahnya, Emma?
Dialogue: 0,0:07:41.94,0:07:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kita dibebaskan\Nsampai pengarahan besok.
Dialogue: 0,0:07:45.61,0:07:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah beda faksi!
Dialogue: 0,0:07:48.70,0:07:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada saingan akur begini?
Dialogue: 0,0:07:50.74,0:07:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah.\NNona Emma yang berprestasi.
Dialogue: 0,0:07:54.28,0:07:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga sangat senang\Nsampai ingin lompat-lompat, kan?
Dialogue: 0,0:08:01.94,0:08:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang banget!
Dialogue: 0,0:08:03.23,0:08:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga ingin merayakannya, kan?
Dialogue: 0,0:08:05.38,0:08:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin merayakannya!
Dialogue: 0,0:08:07.01,0:08:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pesta!
Dialogue: 0,0:08:08.25,0:08:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk Emma yang menuntun\Nanak-anak tertinggal seperti kita!
Dialogue: 0,0:08:11.50,0:08:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang sekali lagi!
Dialogue: 0,0:08:14.26,0:08:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:08:15.64,0:08:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!
Dialogue: 0,0:08:18.14,0:08:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:08:32.50,0:08:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu baik-baik saja, Lihanna?
Dialogue: 0,0:08:36.53,0:08:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:08:37.76,0:08:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku makin lelah setiap hari.
Dialogue: 0,0:08:40.48,0:08:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti segera memahaminya.
Dialogue: 0,0:08:42.42,0:08:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menjadi anggota Faksi Petir.
Dialogue: 0,0:08:45.77,0:08:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuatku sangat penasaran\Ndan agak takut di saat yang sama.
Dialogue: 0,0:08:49.50,0:08:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan?
Dialogue: 0,0:08:51.14,0:08:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau.
Dialogue: 0,0:08:57.01,0:09:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bikin aku repot\Ngara-gara masuk Faksi Petir.
Dialogue: 0,0:09:01.94,0:09:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kami menghibur Nona Elfaria\Nyang tantrum dan terus menangis,
Dialogue: 0,0:09:04.83,0:09:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tiba-tiba mau minggat\Nsambil bilang mau berhenti.
Dialogue: 0,0:09:08.81,0:09:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh anggota faksi kami sampai\Ndikerahkan untuk menghentikannya!
Dialogue: 0,0:09:12.10,0:09:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu—
Dialogue: 0,0:09:13.07,0:09:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maafkan aku!
Dialogue: 0,0:09:20.01,0:09:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melupakan ini.
Dialogue: 0,0:09:21.17,0:09:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambillah.
Dialogue: 0,0:09:23.19,0:09:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Julius.
Dialogue: 0,0:09:24.74,0:09:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?!
Dialogue: 0,0:09:26.32,0:09:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kalian makin akrab?!
Dialogue: 0,0:09:29.12,0:09:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette? Kenapa kamu marah?
Dialogue: 0,0:09:31.81,0:09:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku enggak marah, kok.
Dialogue: 0,0:09:34.54,0:09:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette hanya cemburu.
Dialogue: 0,0:09:36.85,0:09:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena di belakangnya,
Dialogue: 0,0:09:38.68,0:09:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius telah menjalin\Ntali persahabatan denganmu.
Dialogue: 0,0:09:41.28,0:09:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wi-Wignall!
Dialogue: 0,0:09:42.22,0:09:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan tali persahabatan!
Dialogue: 0,0:09:45.03,0:09:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau terlibat dalam\Nsandiwara pertemanan konyol kalian!
Dialogue: 0,0:09:48.90,0:09:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang sandiwara!
Dialogue: 0,0:09:51.65,0:09:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sih kata-katamu\Nselalu mengundang benci?
Dialogue: 0,0:09:54.03,0:09:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku agak memahaminya.
Dialogue: 0,0:09:56.48,0:09:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebaikan Julius.
Dialogue: 0,0:09:58.66,0:10:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Pembelajar!
Dialogue: 0,0:10:00.32,0:10:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mencarimu!
Dialogue: 0,0:10:02.34,0:10:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikutlah kami!
Dialogue: 0,0:10:03.63,0:10:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kan sama-sama selamat dari neraka!
Dialogue: 0,0:10:07.66,0:10:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah.
Dialogue: 0,0:10:09.19,0:10:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berhak dihargai lebih tinggi.
Dialogue: 0,0:10:12.28,0:10:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.\NAku pergi dulu, ya.
Dialogue: 0,0:10:16.50,0:10:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang ingin bicara denganmu.
Dialogue: 0,0:10:18.81,0:10:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:19.57,0:10:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caramu\Nmenggunakan teknik itu?
Dialogue: 0,0:10:24.23,0:10:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emma benar sekali.
Dialogue: 0,0:10:27.19,0:10:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa memonopoli Will lagi.
Dialogue: 0,0:10:31.03,0:10:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colette?
Dialogue: 0,0:10:32.34,0:10:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesepian.
Dialogue: 0,0:10:34.90,0:10:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bukan satu-satunya\Nteman Will.
Dialogue: 0,0:10:39.72,0:10:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang egois dan menyusahkan.
Dialogue: 0,0:10:42.90,0:10:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah berubah sejak dulu.
Dialogue: 0,0:10:46.08,0:10:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merendahkan diri tidak akan\Nmenghasilkan apa pun.
Dialogue: 0,0:10:49.37,0:10:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berhenti menunggu.
Dialogue: 0,0:10:51.77,0:10:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wignall.
Dialogue: 0,0:10:53.34,0:10:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan berarti aku menyerah.
Dialogue: 0,0:10:55.85,0:10:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lebih aktif mendekati
Dialogue: 0,0:10:57.54,0:11:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang menarik minatku\Ndengan kekuatanku sendiri.
Dialogue: 0,0:11:00.83,0:11:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belajar dari Will.
Dialogue: 0,0:11:03.43,0:11:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengecut yang takut melarikan diri.
Dialogue: 0,0:11:07.03,0:11:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu disebut "keberanian",\NColette?
Dialogue: 0,0:11:12.34,0:11:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang egois dan menyusahkan,
Dialogue: 0,0:11:19.43,0:11:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku ingin menyampaikan\Nsesuatu kepada Will!
Dialogue: 0,0:11:21.86,0:11:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, temuilah dia.
Dialogue: 0,0:11:25.48,0:11:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:37.41,0:11:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah kita bantu?
Dialogue: 0,0:11:39.99,0:11:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita awasi saja dulu.
Dialogue: 0,0:11:48.05,0:11:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau melamun?
Dialogue: 0,0:11:50.90,0:11:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau kesepian karena tidak\Npunya bahan rundungan lagi?
Dialogue: 0,0:11:54.77,0:11:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dari keluarga Ulster\Nyang pendendam itu.
Dialogue: 0,0:11:57.54,0:12:00.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kau masih\Ningin merundungnya, kan?
Dialogue: 0,0:12:05.59,0:12:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak diperlukan lagi.
Dialogue: 0,0:12:09.10,0:12:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah tidak menyedihkan.
Dialogue: 0,0:12:11.17,0:12:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membuatku kesal,\Ntapi dia tidak mengganggu.
Dialogue: 0,0:12:15.13,0:12:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka hari ini akan datang.
Dialogue: 0,0:12:17.83,0:12:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sion!
Dialogue: 0,0:12:19.48,0:12:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum sempat bilang,
Dialogue: 0,0:12:21.50,0:12:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi terima kasih sudah membantuku\Nsaat Terminalia dan upacara kelulusan.
Dialogue: 0,0:12:27.30,0:12:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bolehkah aku ke sana?
Dialogue: 0,0:12:31.65,0:12:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa?
Dialogue: 0,0:12:32.97,0:12:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Untuk...
Dialogue: 0,0:12:34.90,0:12:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berterima kasih?
Dialogue: 0,0:12:36.54,0:12:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, lawanlah aku.
Dialogue: 0,0:12:39.99,0:12:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:12:46.28,0:12:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sempurna sebagai\Npengganti terima kasih, kan?
Dialogue: 0,0:12:49.03,0:12:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.\NBiarkan aku bergabung.
Dialogue: 0,0:12:55.70,0:12:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja ini\Nsebagai biaya pelatihan.
Dialogue: 0,0:12:58.01,0:12:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?! Tunggu!
Dialogue: 0,0:13:00.90,0:13:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah!\NKamu pasti bisa, Colette Loire!
Dialogue: 0,0:13:04.74,0:13:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:13:06.51,0:13:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will!
Dialogue: 0,0:13:08.05,0:13:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bilang sesuatu!
Dialogue: 0,0:13:09.68,0:13:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maju!
Dialogue: 0,0:13:11.81,0:13:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:21.63,0:13:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tidak ikut mereka, Iris?
Dialogue: 0,0:13:24.50,0:13:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya akan membuat\Nmereka semua kebingungan.
Dialogue: 0,0:13:27.53,0:13:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku takut identitasku\Ndiketahui Kak Will.
Dialogue: 0,0:13:32.54,0:13:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Watcher memang selalu suka rahasia.
Dialogue: 0,0:13:37.14,0:13:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu langkah buruk.
Dialogue: 0,0:13:40.81,0:13:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kamu tetap pakai topeng junior,\Nmungkin dia akan direbut gadis lain.
Dialogue: 0,0:13:45.92,0:13:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan muncul tiba-tiba!
Dialogue: 0,0:13:48.08,0:13:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, itu urusanku!
Dialogue: 0,0:13:50.70,0:13:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendukungmu, kok, Iris.
Dialogue: 0,0:13:55.77,0:13:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inves, berjanjilah kepadaku.
Dialogue: 0,0:13:58.19,0:14:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku mau dengar\Njika kamu memanggilku "Finn".
Dialogue: 0,0:14:01.97,0:14:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Finn.
Dialogue: 0,0:14:04.23,0:14:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Will telah menjadi\Nbagian dari menara secara resmi.
Dialogue: 0,0:14:07.90,0:14:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,\Ntolong jangan bawa dia pergi dulu.
Dialogue: 0,0:14:13.41,0:14:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:15.21,0:14:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menghormati kehendak Cerridwen,
Dialogue: 0,0:14:17.28,0:14:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan mengawasinya\Nuntuk sementara waktu.
Dialogue: 0,0:14:20.12,0:14:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kalau dia\Ntidak bisa berkembang,
Dialogue: 0,0:14:23.72,0:14:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan langsung membawanya.
Dialogue: 0,0:14:25.97,0:14:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan saja.
Dialogue: 0,0:14:27.99,0:14:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya demi melampaui langit.
Dialogue: 0,0:14:33.54,0:14:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua!
Dialogue: 0,0:14:35.68,0:14:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan?!
Dialogue: 0,0:14:40.70,0:14:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah naik ke menara,\Ntapi kenapa masih seperti pelajar?
Dialogue: 0,0:14:44.92,0:14:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesadaran kalian sebagai\Npenyihir senior masih kurang!
Dialogue: 0,0:14:48.19,0:14:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, yah.
Dialogue: 0,0:14:49.41,0:14:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika masih jadi guru kalian,\Naku pasti mengomel seperti itu.
Dialogue: 0,0:14:54.63,0:14:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu lalai, ya.
Dialogue: 0,0:14:56.61,0:14:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah nasihat dariku\Nsebagai senior kalian.
Dialogue: 0,0:15:00.05,0:15:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Workner.
Dialogue: 0,0:15:02.68,0:15:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:15:04.72,0:15:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bicara sebentar?
Dialogue: 0,0:15:10.63,0:15:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:15:11.76,0:15:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas keberhasilanmu\Nmelewati Second Bloom.
Dialogue: 0,0:15:14.70,0:15:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda sering mengucapkan selamat\Nsetelah acara kelulusan.
Dialogue: 0,0:15:18.39,0:15:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Anda juga menangis\Nlebih banyak dari saya.
Dialogue: 0,0:15:20.64,0:15:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan mengejekku, dasar bodoh!
Dialogue: 0,0:15:22.99,0:15:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang begitulah guru.
Dialogue: 0,0:15:24.90,0:15:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:15:26.79,0:15:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Workner.
Dialogue: 0,0:15:29.14,0:15:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya punya permintaan.
Dialogue: 0,0:15:31.23,0:15:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:32.52,0:15:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada cara untuk menemui Elfie?
Dialogue: 0,0:15:35.77,0:15:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ingin menemuinya.
Dialogue: 0,0:15:40.92,0:15:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak bisa menemui\NMagia Vander dari faksi lain.
Dialogue: 0,0:15:45.94,0:15:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kebetulan ada seorang siswi\Nyang ingin bertemu denganmu.
Dialogue: 0,0:15:51.99,0:15:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganti bajumu!
Dialogue: 0,0:15:53.12,0:15:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi dari menara!
Dialogue: 0,0:15:59.72,0:16:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Workner.\NDia terlalu pilih kasih.
Dialogue: 0,0:16:02.82,0:16:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya berperan sebagai "malaikat".
Dialogue: 0,0:16:05.23,0:16:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah ada profesor\Nmenyeramkan seperti ular
Dialogue: 0,0:16:08.39,0:16:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang suka mencambuk muridnya\Ndan berperan sebagai "setan".
Dialogue: 0,0:16:13.61,0:16:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa muda yang indah.
Dialogue: 0,0:16:15.43,0:16:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kita dulu.
Dialogue: 0,0:16:19.45,0:16:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjemputmu pukul dua belas.
Dialogue: 0,0:16:21.54,0:16:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sisakan penyesalan apa pun, ya.
Dialogue: 0,0:16:34.32,0:16:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elfie.
Dialogue: 0,0:16:37.97,0:16:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Will.
Dialogue: 0,0:16:39.25,0:16:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, terlamba—
Dialogue: 0,0:16:42.23,0:16:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu ke faksi Zeo?!
Dialogue: 0,0:16:45.54,0:16:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu benci aku?!
Dialogue: 0,0:16:48.25,0:16:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:16:48.74,0:16:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kamu kan kalah suit.
Dialogue: 0,0:16:51.57,0:16:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak mau! Enggak mau!\NEnggak mau!
Dialogue: 0,0:16:54.30,0:16:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah senang\Nkarena kita bisa bertemu lagi,
Dialogue: 0,0:16:57.77,0:17:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kamu malah menikah\Ndengan Zeo!
Dialogue: 0,0:17:00.23,0:17:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak terima!
Dialogue: 0,0:17:01.83,0:17:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikah?!\NItu tidak akan terjadi!
Dialogue: 0,0:17:06.74,0:17:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin bersamamu,\Ntapi aku memikirkan sesuatu.
Dialogue: 0,0:17:10.72,0:17:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh langsung\Nmencapai tujuan?
Dialogue: 0,0:17:13.19,0:17:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan?
Dialogue: 0,0:17:15.11,0:17:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu ingat janji kita?
Dialogue: 0,0:17:18.30,0:17:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi Magia Vander\Ndan melihat matahari terbenam.
Dialogue: 0,0:17:22.97,0:17:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:24.36,0:17:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum berhak berdiri di sampingmu.
Dialogue: 0,0:17:27.84,0:17:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi lebih kuat.
Dialogue: 0,0:17:30.28,0:17:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tetap enggak mau!
Dialogue: 0,0:17:33.23,0:17:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bersamamu,
Dialogue: 0,0:17:36.08,0:17:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyentuhmu,\Ndan merasakan kehangatanmu.
Dialogue: 0,0:17:40.03,0:17:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:17:43.14,0:17:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu pernah begini\Ndan berbuat iseng kepadaku?
Dialogue: 0,0:17:48.41,0:17:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-A-Apa maksudmu berbuat iseng?
Dialogue: 0,0:17:52.61,0:17:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti mau menciumku?
Dialogue: 0,0:17:53.77,0:17:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-A-Aku enggak tahu, kok!
Dialogue: 0,0:17:57.08,0:17:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:17:57.88,0:18:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar, kok!\NAku enggak seperti Colette!
Dialogue: 0,0:18:01.54,0:18:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba bahas Colette?
Dialogue: 0,0:18:07.52,0:18:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mengingatnya?
Dialogue: 0,0:18:09.39,0:18:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:10.45,0:18:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sepertinya belum semuanya.
Dialogue: 0,0:18:15.17,0:18:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Cerridwen juga bilang.
Dialogue: 0,0:18:17.17,0:18:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa berkembang lebih jauh\Njika mengingat kembali kisah sihirku.
Dialogue: 0,0:18:22.99,0:18:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:18:24.08,0:18:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika masih ada yang terlupa,\Naku ingin mengingatnya lagi.
Dialogue: 0,0:18:26.72,0:18:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk kenangan indah kita.
Dialogue: 0,0:18:31.05,0:18:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu serakah banget.
Dialogue: 0,0:18:33.30,0:18:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:34.41,0:18:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan kalah darimu.
Dialogue: 0,0:18:36.30,0:18:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:37.68,0:18:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku maafkan, deh.
Dialogue: 0,0:18:40.10,0:18:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya,
Dialogue: 0,0:18:41.92,0:18:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo kita memandang langit.
Dialogue: 0,0:18:50.97,0:18:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tempat yang lebih dekat\Ndari yang pernah kita janjikan.
Dialogue: 0,0:18:58.34,0:19:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau tangga ini\Ndilihat orang?
Dialogue: 0,0:19:01.23,0:19:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menutupinya\Ndengan sihir ilusi.
Dialogue: 0,0:19:04.61,0:19:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bergegas!\NNanti keburu waktunya habis.
Dialogue: 0,0:19:08.03,0:19:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:11.10,0:19:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punggungmu jadi lebih besar, ya.
Dialogue: 0,0:19:15.05,0:19:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:19:16.71,0:19:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:18.10,0:19:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh lebih besar.
Dialogue: 0,0:19:21.22,0:19:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:19:23.41,0:19:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehangatannya tetap sama.
Dialogue: 0,0:19:33.74,0:19:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu indah,\Ntapi itu hanya langit palsu
Dialogue: 0,0:19:38.79,0:19:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memisahkan kita\Ndari Penjajah Langit.
Dialogue: 0,0:19:43.24,0:19:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:44.61,0:19:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin janji kita adalah hal\Nyang paling sulit di dunia ini.
Dialogue: 0,0:19:54.08,0:19:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:19:55.57,0:19:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Meski begitu...
Dialogue: 0,0:19:58.00,0:20:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku akan menjaga janji kita.
Dialogue: 0,0:20:01.10,0:20:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mari kita lihat matahari terbenam.
Dialogue: 0,0:21:52.49,0:21:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin kita terlalu berlebihan, ya.
Dialogue: 0,0:21:55.68,0:21:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mual karena kebanyakan\Nmakan dan minum.
Dialogue: 0,0:21:58.05,0:22:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan dibahas di pengarahan ini?
Dialogue: 0,0:22:01.25,0:22:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti aturan-aturan dasar di menara.
Dialogue: 0,0:22:04.57,0:22:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ada faksi juga.
Dialogue: 0,0:22:05.97,0:22:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Kudengar aturannya\Nberbeda dengan Akademi Sihir.
Dialogue: 0,0:22:12.01,0:22:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu!
Dialogue: 0,0:22:13.77,0:22:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan selamat karena kalian\Nberhasil masuk ke dalam faksi!
Dialogue: 0,0:22:18.57,0:22:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Generasi Berliku memang hebat.
Dialogue: 0,0:22:20.90,0:22:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak yang gagal\Ndalam First Bloom pun
Dialogue: 0,0:22:22.83,0:22:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berhasil menguasai misteri\Ndan mendapatkan berkah.
Dialogue: 0,0:22:26.53,0:22:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potensi kalian memang\Nyang paling cemerlang!
Dialogue: 0,0:22:31.08,0:22:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya kami akan memberi\Npengarahan tentang menara ini,
Dialogue: 0,0:22:36.66,0:22:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi khusus untuk kali ini,\Nkami akan memberikan order rahasia.
Dialogue: 0,0:22:41.29,0:22:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus menyelidiki\Nfaksi kalian masing-masing.
Dialogue: 0,0:22:45.32,0:22:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percakapan antar para anggota,\Nperilaku mereka, dan catatan di sana.
Dialogue: 0,0:22:48.23,0:22:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selidiki hal-hal mencurigakan\Ndan laporkan semua kepada kami.
Dialogue: 0,0:22:53.30,0:22:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:22:54.68,0:22:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian masih\Ningat insiden Terminalia?
Dialogue: 0,0:22:59.01,0:23:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kami menyelidiki penyebabnya,
Dialogue: 0,0:23:02.31,0:23:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami menemukan jejak
Dialogue: 0,0:23:04.28,0:23:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mengindikasikan\Nketerlibatan orang dalam.
Dialogue: 0,0:23:10.30,0:23:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:23:11.57,0:23:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:23:12.57,0:23:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pengkhianat di menara.
Dialogue: 0,0:23:24.54,0:23:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengkhianat?
