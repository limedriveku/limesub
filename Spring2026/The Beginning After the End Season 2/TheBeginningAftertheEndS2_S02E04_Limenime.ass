Dialogue: 0,0:01:30.23,0:01:36.49,6-normal,signs,0,0,0,,{\fad(800,0)\fs80\bord3\blur0\3c&HFFFFFF&\c&H000000&\pos(1827,886)\b1}#4  Sang{\c&H138BC6&} Raja, {\c&H000000&}Pulang ke{\c&H138BC6&} Rumah{\c&H000000&}.
Dialogue: 0,0:01:40.49,0:01:42.99,dialog,,0,0,0,,Syukurlah kita bisa\Nmengirimkan barangnya, ya.
Dialogue: 0,0:01:42.99,0:01:43.90,dialog,,0,0,0,,Ya.
Dialogue: 0,0:01:43.90,0:01:46.70,dialog,,0,0,0,,Aku terkejut saat melihatmu lari.
Dialogue: 0,0:01:46.70,0:01:48.50,dialog,,0,0,0,,Kau bisa melakukan hal seperti itu juga, ya.
Dialogue: 0,0:01:48.50,0:01:51.50,dialog,,0,0,0,,Aku memfokuskan sihir angin di kakiku.
Dialogue: 0,0:01:51.50,0:01:55.76,dialog,,0,0,0,,Cara penerapan Mana yang kupelajari\Ndari Ar— darimu, sejak lama.
Dialogue: 0,0:01:55.76,0:01:59.26,dialog,,0,0,0,,Jadi, bisa digunakan seperti itu, ya.
Dialogue: 0,0:02:03.33,0:02:05.02,dialog,,0,0,0,,Yo, Jasmine.
Dialogue: 0,0:02:07.86,0:02:09.00,dialog,,0,0,0,,Apa kau mengenalnya?
Dialogue: 0,0:02:09.00,0:02:12.52,dialog,,0,0,0,,Brald, petualang Kelas AA.
Dialogue: 0,0:02:12.93,0:02:15.20,dialog,,0,0,0,,Suatu kehormatan kau mengenalku.
Dialogue: 0,0:02:15.20,0:02:17.53,dialog,,0,0,0,,Aku datang untuk meminta bantuan.
Dialogue: 0,0:02:18.06,0:02:20.20,dialog,,0,0,0,,Ada harta karun yang besar.
Dialogue: 0,0:02:20.20,0:02:22.40,dialog,,0,0,0,,Aku ingin kau membantuku.
Dialogue: 0,0:02:24.86,0:02:27.66,dialog,,0,0,0,,Petualang Kelas AA, sama seperti Jasmine.
Dialogue: 0,0:02:28.56,0:02:30.93,dialog,,0,0,0,,Mungkin kemampuannya tak perlu diragukan.
Dialogue: 0,0:02:30.93,0:02:32.16,dialog,,0,0,0,,Tapi
Dialogue: 0,0:02:32.16,0:02:34.86,dialog,,0,0,0,,saat dia mendekati Jasmine,
Dialogue: 0,0:02:34.86,0:02:36.50,dialog,,0,0,0,,hatiku merasa tidak tenang.
Dialogue: 0,0:02:52.81,0:02:55.57,dialog,,0,0,0,,Apa kau sudah siap, Arthur?
Dialogue: 0,0:02:55.57,0:02:57.32,dialog,,0,0,0,,Kau bisa memulainya, Adam.
Dialogue: 0,0:02:57.73,0:02:58.83,dialog,,0,0,0,,Ayo mulai!
Dialogue: 0,0:03:18.38,0:03:19.76,dialog,,0,0,0,,Kesempatan!
Dialogue: 0,0:03:37.06,0:03:38.16,dialog,,0,0,0,,Dia akan menyerang!
Dialogue: 0,0:03:39.13,0:03:40.65,dialog,,0,0,0,,Tusukan atau pukulan?
Dialogue: 0,0:03:42.90,0:03:43.91,dialog,,0,0,0,,Bukan!
Dialogue: 0,0:03:54.96,0:03:56.34,dialog,,0,0,0,,Kau menghentikannya.
Dialogue: 0,0:03:56.76,0:03:57.96,dialog,,0,0,0,,Sepertinya begitu.
Dialogue: 0,0:03:58.66,0:04:01.33,dialog,,0,0,0,,Kau bisa menebak\Nkalau aku menyerang dari atas.
Dialogue: 0,0:04:01.33,0:04:03.34,dialog,,0,0,0,,Tebakanku hanya kebetulan benar.
Dialogue: 0,0:04:03.34,0:04:06.10,dialog,,0,0,0,,Sudah lama seranganku\Ntidak bisa dihentikan.
Dialogue: 0,0:04:06.10,0:04:07.85,dialog,,0,0,0,,Kau bertambah kuat lagi, ya.
Dialogue: 0,0:04:07.85,0:04:09.16,dialog,,0,0,0,,Terima kasih.
Dialogue: 0,0:04:10.20,0:04:11.53,dialog,,0,0,0,,Kau terlalu berlebihan.
Dialogue: 0,0:04:11.53,0:04:13.53,dialog,,0,0,0,,Apa kau tidak tahu cara untuk menahan diri?
Dialogue: 0,0:04:13.53,0:04:14.86,dialog,,0,0,0,,Kalian melihatnya, bukan?
Dialogue: 0,0:04:14.86,0:04:17.36,dialog,,0,0,0,,Itu bukan monster kecil lagi.
Dialogue: 0,0:04:17.36,0:04:18.61,dialog,,0,0,0,,Sudah jadi monster sungguhan.
Dialogue: 0,0:04:18.61,0:04:20.86,dialog,,0,0,0,,Jangan menindas Kakak!
Dialogue: 0,0:04:20.86,0:04:22.53,dialog,,0,0,0,,Apa kau tidak terluka?
Dialogue: 0,0:04:22.53,0:04:24.36,dialog,,0,0,0,,Tanganku sedikit kesemutan.
Dialogue: 0,0:04:24.36,0:04:27.00,dialog,,0,0,0,,Alice tidak marah pada Adam, ya?
Dialogue: 0,0:04:27.00,0:04:28.90,dialog,,0,0,0,,Dia bertarung dengan sungguh-sungguh, lo.
Dialogue: 0,0:04:28.90,0:04:31.40,dialog,,0,0,0,,Karena itu adalah pelatihan, apa boleh buat.
Dialogue: 0,0:04:31.73,0:04:33.06,dialog,,0,0,0,,Ditambah, aku hanya
Dialogue: 0,0:04:33.06,0:04:35.15,dialog,,0,0,0,,tidak ingin anakku\Nmelakukan sesuatu yang berbahaya
Dialogue: 0,0:04:35.15,0:04:37.25,dialog,,0,0,0,,di tempat yang jauh dari pengawasanku.
Dialogue: 0,0:04:39.25,0:04:42.46,dialog,,0,0,0,,Arthur, selanjutnya pelatihan memanah.
Dialogue: 0,0:04:42.46,0:04:44.51,dialog,,0,0,0,,Setelah itu sihir tanah.
Dialogue: 0,0:04:44.90,0:04:47.51,dialog,,0,0,0,,Lalu, yang terakhir sihir angin denganku.
Dialogue: 0,0:04:48.16,0:04:49.26,dialog,,0,0,0,,Mohon bantuannya.
Dialogue: 0,0:04:50.46,0:04:51.83,dialog,,0,0,0,,Twin Horn.
Dialogue: 0,0:04:52.73,0:04:56.30,dialog,,0,0,0,,Pelatihan bersama mereka,\Npara petualang Kelas AA,
Dialogue: 0,0:04:56.30,0:04:58.52,dialog,,0,0,0,,adalah sesuatu yang sulit didapatkan.
Dialogue: 0,0:05:03.28,0:05:06.78,dialog,,0,0,0,,Maaf, kau ingin pergi bersama Arthur, 'kan?
Dialogue: 0,0:05:07.13,0:05:08.90,dialog,,0,0,0,,Ah, tidak, bukan masalah.
Dialogue: 0,0:05:08.90,0:05:11.13,dialog,,0,0,0,,Apa yang ingin kau bicarakan?
Dialogue: 0,0:05:11.13,0:05:13.26,dialog,,0,0,0,,Apa kau mengenal Brald?
Dialogue: 0,0:05:13.26,0:05:14.54,dialog,,0,0,0,,Ya.
Dialogue: 0,0:05:17.04,0:05:19.30,dialog,,0,0,0,,Dia selalu di garis depan.
Dialogue: 0,0:05:19.30,0:05:24.05,dialog,,0,0,0,,Dia menjalankan tugas yang paling berbahaya,\Nyaitu menahan serangan musuh.
Dialogue: 0,0:05:24.05,0:05:29.06,dialog,,0,0,0,,Walaupun begitu, dia menyelesaikan\Nbanyak misi tanpa terluka.
Dialogue: 0,0:05:31.66,0:05:34.36,dialog,,0,0,0,,Si Kebal Brald atau sang Kastel Putih.
Dialogue: 0,0:05:34.36,0:05:38.26,dialog,,0,0,0,,Atau Kesatria Putih, banyak julukannya.
Dialogue: 0,0:05:38.26,0:05:43.03,dialog,,0,0,0,,Bukan hanya dari Guild, dia mendapatkan\Nkepercayaan dari banyak petualang.
Dialogue: 0,0:05:44.56,0:05:45.82,dialog,,0,0,0,,Dia orang seperti apa?
Dialogue: 0,0:05:45.82,0:05:49.26,dialog,,0,0,0,,Dia orang baik seperti yang dirumorkan.
Dialogue: 0,0:05:49.26,0:05:51.13,dialog,,0,0,0,,Kemampuannya pun tidak diragukan lagi.
Dialogue: 0,0:05:51.13,0:05:54.03,dialog,,0,0,0,,Untuk menembus tameng miliknya,\Nbagiku pun akan sulit.
Dialogue: 0,0:05:54.50,0:05:56.10,dialog,,0,0,0,,Ada apa dengan Brald?
Dialogue: 0,0:05:56.56,0:05:58.30,dialog,,0,0,0,,Aku diajak untuk mengikuti misi.
Dialogue: 0,0:05:59.16,0:06:01.16,dialog,,0,0,0,,Aneh sekali.
Dialogue: 0,0:06:01.16,0:06:03.59,dialog,,0,0,0,,Seharusnya dia memiliki party-nya sendiri.
Dialogue: 0,0:06:03.59,0:06:04.90,dialog,,0,0,0,,Ya.
Dialogue: 0,0:06:04.90,0:06:08.43,dialog,,0,0,0,,Bukan hanya aku,\Nsepertinya dia juga mengajak yang lain.
Dialogue: 0,0:06:08.86,0:06:10.26,dialog,,0,0,0,,Aku jadi penasaran.
Dialogue: 0,0:06:11.66,0:06:14.26,dialog,,0,0,0,,Alasan dia tiba-tiba mengumpulkan orang, ya?
Dialogue: 0,0:06:14.90,0:06:16.53,dialog,,0,0,0,,Bagaimana menurutmu, Jasmine?
Dialogue: 0,0:06:16.53,0:06:18.35,dialog,,0,0,0,,Ada anggota party yang cedera?
Dialogue: 0,0:06:18.35,0:06:21.86,dialog,,0,0,0,,Tidak, anggotanya pun\Norang-orang yang berbakat.
Dialogue: 0,0:06:21.86,0:06:24.00,dialog,,0,0,0,,Kemungkinannya kecil.
Dialogue: 0,0:06:24.00,0:06:25.26,dialog,,0,0,0,,Apa ada yang lain?
Dialogue: 0,0:06:25.26,0:06:26.53,dialog,,0,0,0,,Yang lain?
Dialogue: 0,0:06:26.53,0:06:28.11,dialog,,0,0,0,,Perbedaan pendapat.
Dialogue: 0,0:06:28.11,0:06:31.49,dialog,,0,0,0,,Itu adalah penyebab nomor satu\Nsebuah party bisa bubar.
Dialogue: 0,0:06:31.49,0:06:35.46,dialog,,0,0,0,,Kalau begitu, alasannya adalah\Nmisi yang dibilang oleh Brald.
Dialogue: 0,0:06:35.46,0:06:37.40,dialog,,0,0,0,,Wajar jika kau berpikir seperti itu.
Dialogue: 0,0:06:37.40,0:06:39.60,dialog,,0,0,0,,Akan tetapi, tidak baik\Nuntuk mengambil kesimpulan sepihak.
Dialogue: 0,0:06:40.37,0:06:43.10,dialog,,0,0,0,,Prasangka itu mempersempit sudut pandang.
Dialogue: 0,0:06:43.10,0:06:46.26,dialog,,0,0,0,,Seorang pemimpin harus\Ntetap tenang dan adil.
Dialogue: 0,0:06:46.26,0:06:50.00,dialog,,0,0,0,,Itu adalah hal yang selalu kuingat\Nsaat aku menjadi pemimpin party kita.
Dialogue: 0,0:06:50.00,0:06:52.80,dialog,,0,0,0,,Walaupun banyak hal yang berjalan\Ntidak sesuai dengan keinginan.
Dialogue: 0,0:06:52.80,0:06:55.00,dialog,,0,0,0,,Ya, kau selalu melihat Alice.
Dialogue: 0,0:06:55.00,0:06:57.56,dialog,,0,0,0,,Ah, tidak usah bahas hal itu.
Dialogue: 0,0:06:58.52,0:07:00.50,dialog,,0,0,0,,Aku akan menyelidikinya lagi.
Dialogue: 0,0:07:00.50,0:07:02.40,dialog,,0,0,0,,Karena aku adalah pemimpin party sekarang.
Dialogue: 0,0:07:02.40,0:07:05.26,dialog,,0,0,0,,Ya, kutitipkan Arthur padamu.
Dialogue: 0,0:07:07.28,0:07:09.83,dialog,,0,0,0,,Baiklah, aku juga akan pergi.
Dialogue: 0,0:07:22.79,0:07:25.50,dialog,,0,0,0,,Apa kalian tahu cara untuk menahan diri?
Dialogue: 0,0:07:25.50,0:07:27.16,dialog,,0,0,0,,Tidak sengaja.
Dialogue: 0,0:07:27.16,0:07:30.93,dialog,,0,0,0,,Aku tidak berpikir Arthur akan sekuat itu.
Dialogue: 0,0:07:31.30,0:07:32.73,dialog,,0,0,0,,Maafkan aku.
Dialogue: 0,0:07:32.73,0:07:35.16,dialog,,0,0,0,,Jangan menindas Kakak!
Dialogue: 0,0:07:35.16,0:07:36.43,dialog,,0,0,0,,Kalian ini, ya...
Dialogue: 0,0:07:36.97,0:07:39.97,dialog,,0,0,0,,Arthur, apa kau sudah selesai pemanasan?
Dialogue: 0,0:07:40.00,0:07:43.30,dialog,,0,0,0,,Selesai, ya. Kalau begitu,\Nselanjutnya ayo lakukan bersama Ayah.
Dialogue: 0,0:07:44.06,0:07:46.16,dialog,,0,0,0,,Pelatihan sudah selesai.
Dialogue: 0,0:07:46.16,0:07:47.07,dialog,,0,0,0,,Selesai!
Dialogue: 0,0:07:47.07,0:07:49.20,dialog,,0,0,0,,Eh, tapi Ayah belum.
Dialogue: 0,0:07:49.20,0:07:51.10,dialog,,0,0,0,,Selesai jika aku bilang selesai.
Dialogue: 0,0:07:51.10,0:07:51.82,dialog,,0,0,0,,Selesai.
Dialogue: 0,0:07:51.82,0:07:54.66,dialog,,0,0,0,,Interaksi antara anak dan ayah...
Dialogue: 0,0:07:54.66,0:07:56.86,dialog,,0,0,0,,Tolong lakukan itu selain saat latihan.
Dialogue: 0,0:07:56.86,0:07:57.83,dialog,,0,0,0,,Tolong, ya.
Dialogue: 0,0:07:57.83,0:07:59.83,dialog,,0,0,0,,Baik.
Dialogue: 0,0:08:00.80,0:08:03.53,dialog,,0,0,0,,Apa kau tidak apa-apa?\NKau boleh istirahat dulu.
Dialogue: 0,0:08:03.53,0:08:05.73,dialog,,0,0,0,,Tapi aku tidak berhak mengatakan itu.
Dialogue: 0,0:08:05.73,0:08:07.66,dialog,,0,0,0,,Tidak, terima kasih.
Dialogue: 0,0:08:07.66,0:08:09.20,dialog,,0,0,0,,Di mana Jasmine?
Dialogue: 0,0:08:09.20,0:08:10.96,dialog,,0,0,0,,Dia pergi untuk mencari tahu sesuatu.
Dialogue: 0,0:08:11.34,0:08:15.50,dialog,,0,0,0,,Kalau begitu, Arthur,\Nselanjutnya kau pergi menemani kita.
Dialogue: 0,0:08:15.50,0:08:16.85,dialog,,0,0,0,,Menemani kita.
Dialogue: 0,0:08:17.46,0:08:18.76,dialog,,0,0,0,,Aku mengerti.
Dialogue: 0,0:08:18.76,0:08:20.83,dialog,,0,0,0,,Terkadang perasaanku merasa aneh.
Dialogue: 0,0:08:21.36,0:08:26.36,dialog,,0,0,0,,Kata yang mudah untuk dikatakan,\Nsebuah kata yang singkat.
Dialogue: 0,0:08:26.70,0:08:28.76,dialog,,0,0,0,,Entah kapan
Dialogue: 0,0:08:28.76,0:08:32.36,dialog,,0,0,0,,aku akan terbiasa mengatakan kata ini?
Dialogue: 0,0:08:36.86,0:08:37.96,dialog,,0,0,0,,"Ibu".
Dialogue: 0,0:08:45.37,0:08:48.56,dialog,,0,0,0,,Ini adalah misi mengumpulkan tanaman herbal.
Dialogue: 0,0:08:48.56,0:08:49.65,dialog,,0,0,0,,Membosankan.
Dialogue: 0,0:08:49.65,0:08:52.50,dialog,,0,0,0,,Kalau begitu, bagaimana dengan\Nmencari Mana Beast yang tersesat?
Dialogue: 0,0:08:52.50,0:08:53.38,dialog,,0,0,0,,Tidak berguna.
Dialogue: 0,0:08:53.38,0:08:56.70,dialog,,0,0,0,,Kalau begitu, bagaimana dengan\Nmembantu pindahan seorang penyihir?
Dialogue: 0,0:08:56.70,0:08:57.64,dialog,,0,0,0,,Jangan bercanda!
Dialogue: 0,0:08:57.64,0:09:00.80,dialog,,0,0,0,,Kalau begitu, bagaimana dengan\Nmembersihkan saluran air?
Dialogue: 0,0:09:00.80,0:09:02.13,dialog,,0,0,0,,Apa kau sedang mempermainkanku?!
Dialogue: 0,0:09:03.14,0:09:05.30,dialog,,0,0,0,,Tidak ada misi yang normal, ya.
Dialogue: 0,0:09:05.66,0:09:08.15,dialog,,0,0,0,,Maafkan kami, Tuan Muda Lucas.
Dialogue: 0,0:09:08.15,0:09:12.30,dialog,,0,0,0,,Banyak petualang yang menjadi korban\Ndalam kekacauan yang terjadi baru-baru ini.
Dialogue: 0,0:09:12.30,0:09:15.36,dialog,,0,0,0,,Sepertinya pihak Guild sedikit\Nmembutuhkan waktu untuk menyelidikinya.
Dialogue: 0,0:09:15.73,0:09:19.76,dialog,,0,0,0,,Mana Beast yang sudah diselidiki,\Ntapi berbeda itu, ya.
Dialogue: 0,0:09:19.76,0:09:22.86,dialog,,0,0,0,,Yah, aku akan mengalahkan mereka semua\Njika aku yang turun tangan.
Dialogue: 0,0:09:22.86,0:09:24.70,dialog,,0,0,0,,Seperti yang diharapkan\Ndari Tuan Muda Lucas.
Dialogue: 0,0:09:24.70,0:09:25.76,dialog,,0,0,0,,Hm.
Dialogue: 0,0:09:25.76,0:09:30.70,dialog,,0,0,0,,Padahal sebelum masuk ke akademi,\Naku ingin melakukan misi yang besar.
Dialogue: 0,0:09:32.73,0:09:36.43,dialog,,0,0,0,,Kalau begitu, ada sesuatu yang ingin\Nsaya sampaikan pada Anda.
Dialogue: 0,0:09:36.43,0:09:38.30,dialog,,0,0,0,,Apa, Shiun?
Dialogue: 0,0:09:38.30,0:09:41.43,dialog,,0,0,0,,Apa Anda mengenal Brald?
Dialogue: 0,0:09:41.43,0:09:43.18,dialog,,0,0,0,,Kalau tidak salah, dia Kelas AA.
Dialogue: 0,0:09:43.18,0:09:44.60,dialog,,0,0,0,,Benar.
Dialogue: 0,0:09:44.60,0:09:47.94,dialog,,0,0,0,,Sepertinya dia sedang mencari anggota party.
Dialogue: 0,0:09:47.94,0:09:52.50,dialog,,0,0,0,,Sepertinya dia berniat untuk menyerang\Ndungeon kelas atas yang belum ditemukan.
Dialogue: 0,0:09:52.90,0:09:54.80,dialog,,0,0,0,,Secara rahasia dari Guild.
Dialogue: 0,0:09:54.80,0:09:55.60,dialog,,0,0,0,,Heh.
Dialogue: 0,0:09:55.60,0:09:59.83,dialog,,0,0,0,,Dengan kekuatan Tuan Lucas,\NAnda pasti akan terpilih tanpa masalah.
Dialogue: 0,0:10:00.60,0:10:02.20,dialog,,0,0,0,,Sepertinya menarik.
Dialogue: 0,0:10:02.20,0:10:03.76,dialog,,0,0,0,,Tidak boleh, Tuan Muda.
Dialogue: 0,0:10:03.76,0:10:06.96,dialog,,0,0,0,,Menerima misi di luar Guild\Nitu terlalu berbahaya.
Dialogue: 0,0:10:06.96,0:10:08.03,dialog,,0,0,0,,Tutup mulut kalian!
Dialogue: 0,0:10:09.86,0:10:13.46,dialog,,0,0,0,,Shiun, kau boleh juga.
Dialogue: 0,0:10:13.46,0:10:17.56,dialog,,0,0,0,,Aku pikir kau hanya pengawas dari Ayah.
Dialogue: 0,0:10:17.96,0:10:19.43,dialog,,0,0,0,,Terima kasih.
Dialogue: 0,0:10:21.60,0:10:22.47,dialog,,0,0,0,,Oh, ya.
Dialogue: 0,0:10:23.06,0:10:24.86,dialog,,0,0,0,,Anda mau ke mana, Tuan Muda?
Dialogue: 0,0:10:24.86,0:10:26.56,dialog,,0,0,0,,Tunggu kami!
Dialogue: 0,0:10:26.56,0:10:27.30,dialog,,0,0,0,,Tuan Muda!
Dialogue: 0,0:10:27.48,0:10:28.60,dialog,,0,0,0,,Tuan Muda!
Dialogue: 0,0:10:28.60,0:10:30.26,dialog,,0,0,0,,Tunggu, Tuan Muda!
Dialogue: 0,0:10:52.76,0:10:53.75,dialog,,0,0,0,,Terlihat imut.
Dialogue: 0,0:10:57.76,0:11:00.00,dialog,,0,0,0,,Eh, kenapa?
Dialogue: 0,0:11:00.00,0:11:02.60,dialog,,0,0,0,,Aku harus mengajarimu hal lain\Nselain cara untuk bertualang.
Dialogue: 0,0:11:03.10,0:11:05.43,dialog,,0,0,0,,Arthur, kau datang untuk apa kali ini?
Dialogue: 0,0:11:05.87,0:11:06.95,dialog,,0,0,0,,Eng...
Dialogue: 0,0:11:09.16,0:11:11.02,dialog,,0,0,0,,Kau terlihat cantik, Eleanor.
Dialogue: 0,0:11:13.52,0:11:15.53,dialog,,0,0,0,,Syukurlah, Eleanor.
Dialogue: 0,0:11:15.53,0:11:17.70,dialog,,0,0,0,,Apa kau mau ini untuk gaun ulang tahun?
Dialogue: 0,0:11:17.70,0:11:18.41,dialog,,0,0,0,,Ya!
Dialogue: 0,0:11:20.30,0:11:24.23,dialog,,0,0,0,,Dengan bertambahnya umur,\Nkau makin dekat untuk jadi dewasa.
Dialogue: 0,0:11:24.66,0:11:27.54,dialog,,0,0,0,,Memang benar, cantik adalah kata yang tepat.
Dialogue: 0,0:11:28.06,0:11:30.73,dialog,,0,0,0,,Lebih mudah bertarung dengan Beast.
Dialogue: 0,0:11:30.73,0:11:33.06,dialog,,0,0,0,,Selanjutnya, ayo kita pilih-pilih sepatu.
Dialogue: 0,0:11:33.06,0:11:33.79,dialog,,0,0,0,,Selanjutnya?
Dialogue: 0,0:11:33.79,0:11:36.16,dialog,,0,0,0,,Tidak mungkin hanya gaun saja, 'kan?
Dialogue: 0,0:11:36.16,0:11:39.55,dialog,,0,0,0,,Kita harus memikirkan sepatu,\Naksesori, dan gaya rambut.
Dialogue: 0,0:11:39.55,0:11:41.76,dialog,,0,0,0,,Ah, benar juga.
Dialogue: 0,0:11:43.30,0:11:44.80,dialog,,0,0,0,,Ayo, Kak!
Dialogue: 0,0:11:46.33,0:11:48.36,dialog,,0,0,0,,Aku tidak bisa melarikan diri.
Dialogue: 0,0:11:50.46,0:11:53.56,dialog,,0,0,0,,Hei, Tessia, apa kau sudah bertemu\Ndengan Arthur?
Dialogue: 0,0:11:53.96,0:11:58.26,dialog,,0,0,0,,Aku selalu mendapat halangan\Nsaat sebentar lagi bisa bertemu.
Dialogue: 0,0:11:58.26,0:12:01.32,dialog,,0,0,0,,Dia tidak akan melakukan hal seperti ini\Nsekarang jika kami berhasil bertemu.
Dialogue: 0,0:12:01.32,0:12:03.93,dialog,,0,0,0,,Fei, saat aku menjadi ratu nanti,
Dialogue: 0,0:12:03.93,0:12:06.73,dialog,,0,0,0,,hal yang pertama kali akan kulakukan\Nadalah mengusirmu.
Dialogue: 0,0:12:06.73,0:12:08.81,dialog,,0,0,0,,Waw, deklarasi seorang tiran.
Dialogue: 0,0:12:08.82,0:12:11.58,dialog,,0,0,0,,Kita harus menyiapkan\Nrevolusi dari sekarang.
Dialogue: 0,0:12:12.93,0:12:15.16,dialog,,0,0,0,,Kenapa aku tidak bisa bertemu dengannya, ya?
Dialogue: 0,0:12:15.16,0:12:16.46,dialog,,0,0,0,,Mungkin tidak jodoh.
Dialogue: 0,0:12:16.46,0:12:18.76,dialog,,0,0,0,,Padahal aku sangat ingin bertemu.
Dialogue: 0,0:12:19.16,0:12:20.84,dialog,,0,0,0,,Kau lebih baik menyerah saja.
Dialogue: 0,0:12:20.84,0:12:22.60,dialog,,0,0,0,,Perintah ratu.
Dialogue: 0,0:12:22.60,0:12:24.76,dialog,,0,0,0,,Gunakan kata-kata yang lebih baik.
Dialogue: 0,0:12:24.76,0:12:27.31,dialog,,0,0,0,,Kau pasti bisa bertemu.
Dialogue: 0,0:12:27.31,0:12:30.18,dialog,,0,0,0,,Dia juga pasti berpikir\Ningin bertemu denganmu.
Dialogue: 0,0:12:30.35,0:12:33.36,dialog,,0,0,0,,Ya, 'kan?\NKalian berdua berpikir seperti itu, 'kan?
Dialogue: 0,0:12:34.20,0:12:36.43,dialog,,0,0,0,,Tunggu, ratu kita kembali ceria
Dialogue: 0,0:12:36.43,0:12:40.06,dialog,,0,0,0,,dengan kata-kata yang dia paksakan sendiri.
Dialogue: 0,0:12:40.06,0:12:44.00,dialog,,0,0,0,,Kebohongan pun bisa\Nmenyelamatkan hati seseorang, ya.
Dialogue: 0,0:12:44.84,0:12:48.37,dialog,,0,0,0,,Apakah misi tidak datang dari Tetua Virion?
Dialogue: 0,0:12:48.37,0:12:50.78,dialog,,0,0,0,,Dia menyuruh kita menunggu\Nsampai investigasi selesai.
Dialogue: 0,0:12:50.78,0:12:54.86,dialog,,0,0,0,,Yah, lebih baik daripada harus bertemu\Ndengan Mana Beast yang aneh.
Dialogue: 0,0:12:54.86,0:12:57.06,dialog,,0,0,0,,Sepertinya pihak Guild\Njuga melakukan investigasi.
Dialogue: 0,0:12:57.06,0:12:58.88,dialog,,0,0,0,,Tapi sepertinya tidak ada kemajuan.
Dialogue: 0,0:13:00.36,0:13:03.03,dialog,,0,0,0,,Padahal kita tidak akan kalah\Nentah apa pun yang akan keluar.
Dialogue: 0,0:13:03.38,0:13:06.66,dialog,,0,0,0,,Kau ini selalu lupa\Ndi mana posisimu berada, ya.
Dialogue: 0,0:13:06.66,0:13:09.39,dialog,,0,0,0,,Padahal itu tetap berbahaya\Nwalau tidak pasti.
Dialogue: 0,0:13:13.66,0:13:15.46,dialog,,0,0,0,,Ah, ada Arthur.
Dialogue: 0,0:13:15.46,0:13:16.73,dialog,,0,0,0,,Eh, di mana?
Dialogue: 0,0:13:16.73,0:13:18.15,dialog,,0,0,0,,Di sini.
Dialogue: 0,0:13:20.65,0:13:23.06,dialog,,0,0,0,,Eh, di mana? Di mana?
Dialogue: 0,0:13:24.80,0:13:29.43,dialog,,0,0,0,,Dia benar-benar ada tadi.\NJangan melihatku dengan mata itu.
Dialogue: 0,0:13:36.92,0:13:39.30,dialog,,0,0,0,,Ini memang mahal, ya.
Dialogue: 0,0:13:39.30,0:13:40.26,dialog,,0,0,0,,Arthur!
Dialogue: 0,0:13:41.30,0:13:43.17,dialog,,0,0,0,,Apa kau sedang mencari cincin dimensi?
Dialogue: 0,0:13:43.17,0:13:46.76,dialog,,0,0,0,,Ya, aku ingin membelinya suatu saat nanti.
Dialogue: 0,0:13:47.26,0:13:50.43,dialog,,0,0,0,,Omong-omong, seberapa banyak barang\Nyang bisa masuk untuk yang paling murah ini?
Dialogue: 0,0:13:52.93,0:13:55.30,dialog,,0,0,0,,Sekitar 10 koin emas?
Dialogue: 0,0:13:55.30,0:13:57.80,dialog,,0,0,0,,Busurku tidak muat, ya.
Dialogue: 0,0:13:57.80,0:13:59.96,dialog,,0,0,0,,Kalau begitu, tidak berguna.
Dialogue: 0,0:14:01.80,0:14:02.94,dialog,,0,0,0,,Bagaimana dengan yang itu?
Dialogue: 0,0:14:02.94,0:14:06.95,dialog,,0,0,0,,Yang itu bisa masuk alat-alat\Nuntuk berkemah, ya.
Dialogue: 0,0:14:06.95,0:14:09.59,dialog,,0,0,0,,Tapi harganya, ya...
Dialogue: 0,0:14:30.53,0:14:32.40,dialog,,0,0,0,,Mahal, ya.
Dialogue: 0,0:14:32.40,0:14:33.50,dialog,,0,0,0,,Ya.
Dialogue: 0,0:14:35.72,0:14:37.49,dialog,,0,0,0,,Ketemu!
Dialogue: 0,0:14:37.50,0:14:39.93,dialog,,0,0,0,,Ibu, aku menemukan Kakak.
Dialogue: 0,0:14:39.93,0:14:42.36,dialog,,0,0,0,,Ada Helen dan Angela juga.
Dialogue: 0,0:14:42.73,0:14:46.36,dialog,,0,0,0,,Apa kau melarikan diri dari pergi belanja\Nbersama ibu dan adikmu?
Dialogue: 0,0:14:46.36,0:14:49.56,dialog,,0,0,0,,Tidak boleh seperti itu.\NKau harus menemani mereka sampai selesai.
Dialogue: 0,0:14:50.40,0:14:51.60,dialog,,0,0,0,,Aku mengerti.
Dialogue: 0,0:14:57.76,0:14:59.43,dialog,,0,0,0,,Aku lelah.
Dialogue: 0,0:15:01.40,0:15:03.56,dialog,,0,0,0,,Maaf, Sylvie.
Dialogue: 0,0:15:04.50,0:15:06.13,dialog,,0,0,0,,Selamat datang kembali, Arthur.
Dialogue: 0,0:15:06.13,0:15:07.30,dialog,,0,0,0,,Ada apa?
Dialogue: 0,0:15:07.30,0:15:09.26,dialog,,0,0,0,,Tugas keluarga.
Dialogue: 0,0:15:09.26,0:15:11.76,dialog,,0,0,0,,Aku hanya kelelahan karena\Nmereka berdua sangat kuat.
Dialogue: 0,0:15:11.76,0:15:13.20,dialog,,0,0,0,,Apa boleh buat.
Dialogue: 0,0:15:13.20,0:15:16.50,dialog,,0,0,0,,Karena Alice dan Eleanor juga\Ningin bertemu denganmu.
Dialogue: 0,0:15:16.50,0:15:19.14,dialog,,0,0,0,,Aku juga ingin bertemu\Ndengan Ibu dan Eleanor.
Dialogue: 0,0:15:20.40,0:15:22.84,dialog,,0,0,0,,Hei, kita akan pergi bertualang lagi, 'kan?
Dialogue: 0,0:15:22.84,0:15:24.65,dialog,,0,0,0,,Kapan mau pergi?\NPergi sekarang?
Dialogue: 0,0:15:25.50,0:15:29.26,dialog,,0,0,0,,Aku sedang istirahat dulu untuk bertualang,\Nsekarang masih melakukan persiapan.
Dialogue: 0,0:15:29.60,0:15:30.90,dialog,,0,0,0,,Apa kau sangat ingin pergi?
Dialogue: 0,0:15:30.90,0:15:33.40,dialog,,0,0,0,,Aku cepat merasa lapar.
Dialogue: 0,0:15:33.40,0:15:34.41,dialog,,0,0,0,,Aneh sekali.
Dialogue: 0,0:15:34.41,0:15:36.26,dialog,,0,0,0,,Makanannya kurang banyak?
Dialogue: 0,0:15:36.26,0:15:37.40,dialog,,0,0,0,,Bukan makanan.
Dialogue: 0,0:15:37.40,0:15:40.66,dialog,,0,0,0,,Aku ingin memakan yang bulat dan bersinar.
Dialogue: 0,0:15:41.26,0:15:43.33,dialog,,0,0,0,,Kau ingin makan Mana Core, ya.
Dialogue: 0,0:15:43.33,0:15:45.56,dialog,,0,0,0,,Kalau begitu,\Nkita harus pergi bertualang, ya.
Dialogue: 0,0:15:45.56,0:15:49.00,dialog,,0,0,0,,Kalau beli di sini, aku akan bangkrut\Nkarena biaya makanmu, ya.
Dialogue: 0,0:15:49.66,0:15:50.70,dialog,,0,0,0,,Tapi...
Dialogue: 0,0:15:50.70,0:15:51.96,dialog,,0,0,0,,Kenapa?
Dialogue: 0,0:15:53.46,0:15:55.66,dialog,,0,0,0,,Sebentar lagi dua tahun akan berlalu.
Dialogue: 0,0:15:57.00,0:15:59.30,dialog,,0,0,0,,Aku bisa jadi petualang
Dialogue: 0,0:15:59.30,0:16:02.30,dialog,,0,0,0,,sampai aku masuk ke Akademi Xyrus.
Dialogue: 0,0:16:02.30,0:16:05.00,dialog,,0,0,0,,Waktu yang kujanjikan sudah dekat.
Dialogue: 0,0:16:06.20,0:16:09.69,dialog,,0,0,0,,Mungkin misi yang selanjutnya\Nakan menjadi yang terakhir.
Dialogue: 0,0:16:10.40,0:16:12.20,dialog,,0,0,0,,Jika itu sudah berakhir,
Dialogue: 0,0:16:12.90,0:16:15.83,dialog,,0,0,0,,apa yang akan dipikirkan Jasmine?
Dialogue: 0,0:16:17.36,0:16:18.83,dialog,,0,0,0,,Jasmine, apa kau ada di situ?
Dialogue: 0,0:16:19.20,0:16:20.19,dialog,,0,0,0,,Arthur?
Dialogue: 0,0:16:20.19,0:16:22.13,dialog,,0,0,0,,Kau boleh masuk.
Dialogue: 0,0:16:22.13,0:16:23.73,dialog,,0,0,0,,Cepat masuk.
Dialogue: 0,0:16:23.73,0:16:25.03,dialog,,0,0,0,,Tunggu.
Dialogue: 0,0:16:41.73,0:16:44.53,dialog,,0,0,0,,Karena kau selalu merawat Arthur,
Dialogue: 0,0:16:44.53,0:16:45.90,dialog,,0,0,0,,ini ucapan terima kasih kami.
Dialogue: 0,0:16:45.90,0:16:48.10,dialog,,0,0,0,,Aku dan Ibu memilihnya.
Dialogue: 0,0:16:48.10,0:16:49.43,dialog,,0,0,0,,Ah, begitu?
Dialogue: 0,0:16:53.86,0:16:55.66,dialog,,0,0,0,,Aku sudah belajar.
Dialogue: 0,0:16:55.99,0:17:00.33,dialog,,0,0,0,,Eleanor yang masih kecil benci\Ndiperlakukan seperti anak kecil.
Dialogue: 0,0:17:00.33,0:17:03.00,dialog,,0,0,0,,Kalau begitu, Jasmine yang sudah dewasa...
Dialogue: 0,0:17:03.66,0:17:05.66,dialog,,0,0,0,,Jasmine, kau terlihat imut.
Dialogue: 0,0:17:12.26,0:17:13.86,dialog,,0,0,0,,Eh?
Dialogue: 0,0:17:13.86,0:17:16.30,dialog,,0,0,0,,Jasmine terlihat malu.
Dialogue: 0,0:17:16.30,0:17:18.19,dialog,,0,0,0,,Terlihat malu.
Dialogue: 0,0:17:18.20,0:17:20.37,dialog,,0,0,0,,Padahal ada sesuatu yang ingin kubicarakan.
Dialogue: 0,0:17:26.90,0:17:29.26,dialog,,0,0,0,,Apa yang akan kau lakukan\Ndengan ajakan dari Brald?
Dialogue: 0,0:17:29.66,0:17:31.96,dialog,,0,0,0,,Jujur saja, kita seharusnya\Ntidak menerima ajakannya.
Dialogue: 0,0:17:31.96,0:17:33.10,dialog,,0,0,0,,Apa alasannya?
Dialogue: 0,0:17:33.10,0:17:34.53,dialog,,0,0,0,,Aku sudah sedikit menyelidikinya.
Dialogue: 0,0:17:35.06,0:17:37.76,dialog,,0,0,0,,Kali ini Brald bergerak sendiri.
Dialogue: 0,0:17:37.76,0:17:40.16,dialog,,0,0,0,,Party-nya tidak akan ikut.
Dialogue: 0,0:17:40.56,0:17:42.90,dialog,,0,0,0,,Karena itu dia mengajakmu.
Dialogue: 0,0:17:43.30,0:17:46.56,dialog,,0,0,0,,Petualang itu tidak akan bisa bertahan hidup\Njika dia tidak menjadi pengecut.
Dialogue: 0,0:17:47.10,0:17:49.54,dialog,,0,0,0,,Hm, iya, ya.
Dialogue: 0,0:17:50.13,0:17:52.30,dialog,,0,0,0,,Tapi kau ingin melakukannya, ya?
Dialogue: 0,0:17:52.30,0:17:53.50,dialog,,0,0,0,,Eh?
Dialogue: 0,0:17:53.50,0:17:56.30,dialog,,0,0,0,,Aku tahu karena kita selalu bersama.
Dialogue: 0,0:17:59.80,0:18:01.86,dialog,,0,0,0,,Bahaya itu harus dihindari.
Dialogue: 0,0:18:01.86,0:18:05.30,dialog,,0,0,0,,Itu adalah hal yang kupelajari dalam hidup.
Dialogue: 0,0:18:05.81,0:18:09.26,dialog,,0,0,0,,Tapi yang menunggu di saat kita\Nberhasil melewati bahaya itu
Dialogue: 0,0:18:09.26,0:18:11.06,dialog,,0,0,0,,adalah sebuah pertemuan baru.
Dialogue: 0,0:18:45.10,0:18:47.50,dialog,,0,0,0,,Menghindari bahaya itu
Dialogue: 0,0:18:47.50,0:18:50.40,dialog,,0,0,0,,sama saja dengan menutup diri dari dunia.
Dialogue: 0,0:18:51.20,0:18:54.96,dialog,,0,0,0,,Aku mempelajari hal itu di kehidupan kedua.
Dialogue: 0,0:18:54.96,0:18:56.80,dialog,,0,0,0,,Aku juga masih belum mengetahuinya.
Dialogue: 0,0:18:56.80,0:19:01.63,dialog,,0,0,0,,Hanya saja, misi selanjutnya\Nakan menjadi misi dirimu dan Note.
Dialogue: 0,0:19:03.00,0:19:05.90,dialog,,0,0,0,,Tidak ada misi yang normal\Ndi Guild sekarang, bukan?
Dialogue: 0,0:19:06.30,0:19:09.66,dialog,,0,0,0,,Aku merasa akan menyenangkan meskipun\Nitu misi mengumpulkan tanaman herbal,
Dialogue: 0,0:19:09.66,0:19:13.13,dialog,,0,0,0,,tapi aku ingin sesuatu\Nyang akan lebih berkesan.
Dialogue: 0,0:19:14.10,0:19:16.13,dialog,,0,0,0,,Nyawa adalah yang terpenting.
Dialogue: 0,0:19:16.13,0:19:17.13,dialog,,0,0,0,,Ya.
Dialogue: 0,0:19:17.13,0:19:19.16,dialog,,0,0,0,,Tapi benar juga.
Dialogue: 0,0:19:19.16,0:19:22.50,dialog,,0,0,0,,Akan terasa tidak enak jika mengumpulkan\Ntanaman herbal sebagai misi terakhir.
Dialogue: 0,0:19:22.50,0:19:23.89,dialog,,0,0,0,,Ayo kita melakukan persiapan.
Dialogue: 0,0:19:24.26,0:19:26.00,dialog,,0,0,0,,Terima kasih, Jasmine.
Dialogue: 0,0:19:39.46,0:19:43.86,dialog,,0,0,0,,Ayah, apa yang paling kau jaga\Nsaat pergi dalam misi?
Dialogue: 0,0:19:44.50,0:19:45.60,dialog,,0,0,0,,Apa, ya?
Dialogue: 0,0:19:46.30,0:19:49.73,dialog,,0,0,0,,Makan sambil tertawa bersama semuanya\Nsaat misi itu selesai.
Dialogue: 0,0:19:49.73,0:19:50.79,dialog,,0,0,0,,Makan?
Dialogue: 0,0:19:51.20,0:19:53.33,dialog,,0,0,0,,Tertawa itu hal yang penting.
Dialogue: 0,0:19:53.33,0:19:57.23,dialog,,0,0,0,,Walaupun gagal atau berhasil,\Ntidak masalah asalkan semuanya hidup.
Dialogue: 0,0:19:59.56,0:20:01.43,dialog,,0,0,0,,Ya, benar juga.
Dialogue: 0,0:20:01.43,0:20:03.36,dialog,,0,0,0,,Pulanglah dengan selamat.
Dialogue: 0,0:20:03.36,0:20:05.22,dialog,,0,0,0,,Berdua dengan Jasmine.
Dialogue: 0,0:20:05.22,0:20:06.21,dialog,,0,0,0,,Ya.
Dialogue: 0,0:20:23.76,0:20:25.36,dialog,,0,0,0,,Apa yang akan kau lakukan, Sylvie?
Dialogue: 0,0:20:25.36,0:20:27.96,dialog,,0,0,0,,Aku benci gua karena lembap.
Dialogue: 0,0:20:28.53,0:20:29.49,dialog,,0,0,0,,Aku mengerti.
Dialogue: 0,0:20:30.93,0:20:33.00,dialog,,0,0,0,,Arthur, semangat, ya.
Dialogue: 0,0:20:33.00,0:20:34.50,dialog,,0,0,0,,Sylvie juga, ya.
Dialogue: 0,0:20:59.93,0:21:01.76,dialog,,0,0,0,,Sudah kuduga, dengan kelas seperti ini
Dialogue: 0,0:21:01.76,0:21:04.30,dialog,,0,0,0,,tidak bisa dikontrol secara penuh, ya.
Dialogue: 0,0:21:04.30,0:21:05.70,dialog,,0,0,0,,Tapi ini cukup.
Dialogue: 0,0:21:06.40,0:21:09.16,dialog,,0,0,0,,Aktivitas di sini pun sudah mencapai batas.
Dialogue: 0,0:21:10.06,0:21:12.56,dialog,,0,0,0,,Akan kubuat mereka bekerja\Nuntuk terakhir kali.
