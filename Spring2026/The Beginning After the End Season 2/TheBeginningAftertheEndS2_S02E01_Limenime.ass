Dialogue: 0,0:02:40.24,0:02:45.01,5-normal,,0,0,0,,{\an3\fad(835,0)\fs90\bord4\blur4\3c&HFFFFFF&\c&H000000&\pos(1828,928)}#1 Sang {\c&H1A82A6&}Raja, {\c&H000000&}Pergi {\c&H1A82A6&}Bertualang{\c&H000000&}.
Dialogue: 10,0:00:07.80,0:00:09.98,dialog,,0,0,0,,Aku adalah seorang raja...
Dialogue: 10,0:00:14.00,0:00:15.26,dialog,,0,0,0,,yang terkuat.
Dialogue: 10,0:00:32.06,0:00:33.93,dialog,,0,0,0,,Sebagai seorang raja,
Dialogue: 10,0:00:33.96,0:00:36.23,dialog,,0,0,0,,aku telah merenggut banyak nyawa.
Dialogue: 10,0:00:36.26,0:00:38.90,dialog,,0,0,0,,Aku telah melakukan banyak dosa.
Dialogue: 10,0:00:41.40,0:00:43.03,dialog,,0,0,0,,Aku yang seperti itu...
Dialogue: 10,0:00:53.06,0:00:56.10,dialog,,0,0,0,,Arthur, misi selanjutnya sudah ditentukan.
Dialogue: 10,0:00:56.95,0:00:58.53,dialog,,0,0,0,,Aku mengerti.
Dialogue: 10,0:00:58.56,0:01:00.23,dialog,,0,0,0,,Ayo, Jasmine.
Dialogue: 10,0:01:03.20,0:01:06.70,dialog,,0,0,0,,Kini aku diberikan kehidupan kedua.
Dialogue: 10,0:02:46.23,0:02:47.70,dialog,,0,0,0,,Konfirmasi misi.
Dialogue: 10,0:02:48.03,0:02:51.77,dialog,,0,0,0,,Ada laporan dari desa tentang kemunculan\Nhabitat Beast di sekitarnya.
Dialogue: 10,0:02:51.80,0:02:53.56,dialog,,0,0,0,,Tugas kita menyelidiki penyebabnya.
Dialogue: 10,0:02:54.02,0:02:55.57,dialog,,0,0,0,,Apa prioritas utama kita?
Dialogue: 10,0:02:55.60,0:02:57.03,dialog,,0,0,0,,Bertahan hidup.
Dialogue: 10,0:02:57.53,0:03:00.00,dialog,,0,0,0,,Bagaimana jika ada Beast yang agresif?
Dialogue: 10,0:03:00.03,0:03:02.21,dialog,,0,0,0,,Membasmi mereka bukanlah tugas kita.
Dialogue: 10,0:03:02.24,0:03:04.31,dialog,,0,0,0,,Jadi, tak perlu memaksakan diri melawannya.
Dialogue: 10,0:03:04.53,0:03:05.83,dialog,,0,0,0,,Kau lulus.
Dialogue: 10,0:03:06.56,0:03:08.27,dialog,,0,0,0,,Bagaimana denganmu, Sylvie?
Dialogue: 10,0:03:08.30,0:03:10.47,dialog,,0,0,0,,Aku akan berlatih di sekitar sini.
Dialogue: 10,0:03:10.50,0:03:12.87,dialog,,0,0,0,,Baiklah, akan kupanggil jika sudah selesai.
Dialogue: 10,0:03:12.90,0:03:14.83,dialog,,0,0,0,,Kau juga semangat, ya, Arthur.
Dialogue: 10,0:03:25.00,0:03:27.68,dialog,,0,0,0,,Note, apa kau menyadarinya?
Dialogue: 10,0:03:28.10,0:03:30.67,dialog,,0,0,0,,Ada jejak kaki yang mengarah ke desa,
Dialogue: 10,0:03:30.70,0:03:33.31,dialog,,0,0,0,,tapi jejak yang keluar terlalu sedikit.
Dialogue: 10,0:03:33.80,0:03:34.89,dialog,,0,0,0,,Di saat seperti ini?
Dialogue: 10,0:03:34.92,0:03:37.75,dialog,,0,0,0,,Mengumpulkan informasi adalah langkah utama.
Dialogue: 10,0:03:37.78,0:03:38.83,dialog,,0,0,0,,Benar.
Dialogue: 10,0:03:50.16,0:03:52.00,dialog,,0,0,0,,Tidak ada tanda-tanda kehidupan.
Dialogue: 10,0:03:52.58,0:03:54.53,dialog,,0,0,0,,Apa mereka diserang Beast?
Dialogue: 10,0:03:54.56,0:03:57.20,dialog,,0,0,0,,Aneh juga jika tak ada jejak perlawanan.
Dialogue: 10,0:03:58.23,0:03:59.43,dialog,,0,0,0,,Hm?
Dialogue: 10,0:04:00.36,0:04:01.33,dialog,,0,0,0,,Note.
Dialogue: 10,0:04:01.36,0:04:02.27,dialog,,0,0,0,,Eh?
Dialogue: 10,0:04:02.30,0:04:03.84,dialog,,0,0,0,,Apa itu?
Dialogue: 10,0:04:04.16,0:04:05.43,dialog,,0,0,0,,Ayo kita pastikan.
Dialogue: 10,0:04:08.23,0:04:09.43,dialog,,0,0,0,,Kristal?
Dialogue: 10,0:04:09.85,0:04:11.86,dialog,,0,0,0,,Kenapa ada di tempat seperti ini?
Dialogue: 10,0:04:20.11,0:04:21.00,dialog,,0,0,0,,Jasmine!
Dialogue: 10,0:04:28.70,0:04:30.77,dialog,,0,0,0,,Bisa kau ceritakan apa yang terjadi?
Dialogue: 10,0:04:30.80,0:04:32.20,dialog,,0,0,0,,Aku tak tahu.
Dialogue: 10,0:04:32.23,0:04:35.77,dialog,,0,0,0,,Tadi aku pergi ke hutan mencari herbal.
Dialogue: 10,0:04:35.80,0:04:37.24,dialog,,0,0,0,,Namun, saat kembali...
Dialogue: 10,0:04:41.66,0:04:43.50,dialog,,0,0,0,,Apa ini ulah Beast?
Dialogue: 10,0:04:44.80,0:04:46.00,dialog,,0,0,0,,Tapi...
Dialogue: 10,0:05:00.60,0:05:02.44,dialog,,0,0,0,,Tidak!
Dialogue: 10,0:05:03.50,0:05:04.70,dialog,,0,0,0,,Kenapa?
Dialogue: 10,0:05:09.27,0:05:12.27,dialog,,0,0,0,,Tidak, Ibu!
Dialogue: 10,0:05:16.56,0:05:17.58,dialog,,0,0,0,,Ayo pergi!
Dialogue: 10,0:05:33.03,0:05:37.83,dialog,,0,0,0,,Aliansi tiga negara,\Nantara manusia, elf, dan dwarf.
Dialogue: 10,0:05:37.86,0:05:41.36,dialog,,0,0,0,,Bagi kita, ini situasi yang merugikan.
Dialogue: 10,0:05:41.70,0:05:44.10,dialog,,0,0,0,,Segala sesuatu pasti memiliki arusnya.
Dialogue: 10,0:05:44.46,0:05:48.23,dialog,,0,0,0,,Terkadang tak ada salahnya\Nikut terbawa arus itu.
Dialogue: 10,0:05:50.74,0:05:53.00,dialog,,0,0,0,,Habitat Beast, ya?
Dialogue: 10,0:05:53.56,0:05:57.80,dialog,,0,0,0,,Mengumpulkan mereka yang akan memikul\Nmasa depan benua ini
Dialogue: 10,0:05:57.83,0:05:59.75,dialog,,0,0,0,,dan mengasah kemampuan mereka.
Dialogue: 10,0:06:01.10,0:06:02.66,dialog,,0,0,0,,Masa depan, ya?
Dialogue: 10,0:06:03.80,0:06:07.16,dialog,,0,0,0,,Kita yang harus menentukannya.
Dialogue: 10,0:06:08.26,0:06:10.85,dialog,,0,0,0,,Kupikir ini adalah peran yang membosankan,
Dialogue: 10,0:06:10.88,0:06:13.26,dialog,,0,0,0,,tapi sepertinya\Nakan menjadi sedikit menarik.
Dialogue: 10,0:06:16.46,0:06:17.53,dialog,,0,0,0,,Yang tadi itu...
Dialogue: 10,0:06:17.56,0:06:18.83,dialog,,0,0,0,,Arachne.
Dialogue: 10,0:06:18.86,0:06:22.57,dialog,,0,0,0,,Dia masuk daftar Beast\Nyang sangat kuhindari.
Dialogue: 10,0:06:22.60,0:06:23.80,dialog,,0,0,0,,Apa kau pernah melawannya?
Dialogue: 10,0:06:23.83,0:06:26.90,dialog,,0,0,0,,Dari lima kali,\Naku hanya pernah menang sekali.
Dialogue: 10,0:06:27.36,0:06:29.80,dialog,,0,0,0,,Itu pun dengan anggota lengkap Twin Horn.
Dialogue: 10,0:06:31.46,0:06:33.16,dialog,,0,0,0,,Reynold dan Alice.
Dialogue: 10,0:06:33.56,0:06:35.90,dialog,,0,0,0,,Bersama dengan kedua orang tuamu.
Dialogue: 10,0:06:37.23,0:06:40.51,dialog,,0,0,0,,Tanpa Alice, kami tak akan bisa menang.
Dialogue: 10,0:06:40.54,0:06:42.47,dialog,,0,0,0,,Kekuatan seorang Emitter?
Dialogue: 10,0:06:42.50,0:06:43.54,dialog,,0,0,0,,Benar.
Dialogue: 10,0:06:44.05,0:06:47.33,dialog,,0,0,0,,Hanya Emitter yang bisa melepas\Nkutukan Arachne.
Dialogue: 10,0:06:47.36,0:06:50.70,dialog,,0,0,0,,Sisanya, kami hanya perlu\Nmengalahkan tubuh aslinya.
Dialogue: 10,0:06:51.54,0:06:56.00,dialog,,0,0,0,,Tapi pertahanannya kuat.\NSerangan sihir sulit menembusnya.
Dialogue: 10,0:06:56.03,0:06:59.17,dialog,,0,0,0,,Kulitnya pun keras,\Npedang kita akan terpental.
Dialogue: 10,0:06:59.20,0:07:01.77,dialog,,0,0,0,,Kita yang sekarang kurang daya serang, ya.
Dialogue: 10,0:07:01.80,0:07:06.20,dialog,,0,0,0,,Ya. Namun, Arachne membenci sinar matahari.
Dialogue: 10,0:07:06.23,0:07:08.96,dialog,,0,0,0,,Seharusnya dia ada di dasar dungeon.
Dialogue: 10,0:07:09.76,0:07:11.60,dialog,,0,0,0,,Yang lebih penting, Note...
Dialogue: 10,0:07:11.63,0:07:12.60,dialog,,0,0,0,,Hm?
Dialogue: 10,0:07:12.63,0:07:18.08,dialog,,0,0,0,,Aku sudah mengajarkan dasar-dasar\Nseorang petualang kepadamu.
Dialogue: 10,0:07:19.10,0:07:21.76,dialog,,0,0,0,,Bukan sekadar ilmu pedang dan sihir,
Dialogue: 10,0:07:23.26,0:07:25.60,dialog,,0,0,0,,tetapi juga kemampuan untuk bertahan hidup.
Dialogue: 10,0:07:26.09,0:07:28.10,dialog,,0,0,0,,Aku sudah mewariskan semuanya.
Dialogue: 10,0:07:29.09,0:07:33.63,dialog,,0,0,0,,Jadi, apa yang harus kita lakukan sekarang?
Dialogue: 10,0:07:36.85,0:07:37.90,dialog,,0,0,0,,Kita mundur.
Dialogue: 10,0:07:38.66,0:07:39.70,dialog,,0,0,0,,Lapor ke Guild.
Dialogue: 10,0:07:39.73,0:07:42.82,dialog,,0,0,0,,Lakukan persiapan matang,\Nlalu kembali selamatkan desa itu.
Dialogue: 10,0:07:42.85,0:07:44.10,dialog,,0,0,0,,Ya.
Dialogue: 10,0:07:50.02,0:07:50.73,dialog,,0,0,0,,Arthur!
Dialogue: 10,0:07:53.53,0:07:54.42,dialog,,0,0,0,,Jasmine!
Dialogue: 10,0:07:54.86,0:07:56.24,dialog,,0,0,0,,Menjauh, Arthur!
Dialogue: 10,0:07:56.66,0:07:58.74,dialog,,0,0,0,,Setidaknya, kau harus...
Dialogue: 10,0:08:40.40,0:08:42.00,dialog,,0,0,0,,Beraninya kau.
Dialogue: 10,0:08:58.51,0:09:02.18,dialog,,0,0,0,,Dulu, aku adalah seorang raja.
Dialogue: 10,0:09:05.31,0:09:09.06,dialog,,0,0,0,,Raja yang paling kuat.
Dialogue: 10,0:09:17.03,0:09:19.20,dialog,,0,0,0,,Hanya dengan satu tebasan pedang,
Dialogue: 10,0:09:31.50,0:09:34.20,dialog,,0,0,0,,aku memenangkan segala pertempuran.
Dialogue: 10,0:09:47.35,0:09:49.63,dialog,,0,0,0,,Hanya mengandalkan pedang saja tak cukup.
Dialogue: 10,0:10:00.63,0:10:03.04,dialog,,0,0,0,,Kalau begitu,\Nbagaimana dengan pedang dan api?
Dialogue: 10,0:10:08.37,0:10:10.46,dialog,,0,0,0,,Apa ini akan berhasil?
Dialogue: 10,0:10:18.02,0:10:18.93,dialog,,0,0,0,,Berhasilkah?
Dialogue: 10,0:10:23.80,0:10:25.24,dialog,,0,0,0,,Oh, ya.
Dialogue: 10,0:10:25.27,0:10:28.63,dialog,,0,0,0,,Jasmine bilang serangan sihir\Nsulit menembusnya.
Dialogue: 10,0:10:45.29,0:10:46.56,dialog,,0,0,0,,Percuma.
Dialogue: 10,0:11:16.82,0:11:20.07,dialog,,0,0,0,,Pernahkah kau diserang sihir\Ndari dalam tubuhmu?
Dialogue: 10,0:11:28.08,0:11:29.96,dialog,,0,0,0,,Kembalikan Jasmine!
Dialogue: 10,0:11:48.43,0:11:49.63,dialog,,0,0,0,,Jasmine.
Dialogue: 10,0:11:56.90,0:11:59.11,dialog,,0,0,0,,Dasar makhluk keras kepala.
Dialogue: 10,0:12:01.56,0:12:04.24,dialog,,0,0,0,,Namun, ada satu hal yang patut kusyukuri.
Dialogue: 10,0:12:05.36,0:12:09.43,dialog,,0,0,0,,Aku bisa mengingat kembali ilmu pedangku.
Dialogue: 10,0:12:26.43,0:12:28.70,dialog,,0,0,0,,Bebannya masih terlalu besar.
Dialogue: 10,0:12:31.03,0:12:33.13,dialog,,0,0,0,,Ilmu pedangku,
Dialogue: 10,0:12:33.16,0:12:37.66,dialog,,0,0,0,,ditambah sihir,\Nkekuatan baru dari dunia ini,
Dialogue: 10,0:12:38.11,0:12:40.34,dialog,,0,0,0,,masih jauh dari kata sempurna.
Dialogue: 10,0:12:42.03,0:12:44.23,dialog,,0,0,0,,Aku harus berlatih lebih giat lagi.
Dialogue: 10,0:12:45.17,0:12:51.11,dialog,,0,0,0,,Arthur!
Dialogue: 10,0:12:53.63,0:12:55.77,dialog,,0,0,0,,Apa yang terjadi?\NKau tak apa-apa?
Dialogue: 10,0:12:55.80,0:12:58.79,dialog,,0,0,0,,Wajahmu terlihat sangat marah.
Dialogue: 10,0:12:59.56,0:13:03.06,dialog,,0,0,0,,Tenanglah, semuanya sudah berakhir.
Dialogue: 10,0:13:03.76,0:13:05.01,dialog,,0,0,0,,Benarkah?
Dialogue: 10,0:13:05.04,0:13:06.27,dialog,,0,0,0,,Tentu.
Dialogue: 10,0:13:06.30,0:13:10.07,dialog,,0,0,0,,Syukurlah kalau begitu. Tetap semangat, ya!
Dialogue: 10,0:13:10.10,0:13:11.08,dialog,,0,0,0,,Semangat untuk apa?
Dialogue: 10,0:13:11.11,0:13:11.86,dialog,,0,0,0,,Itu...
Dialogue: 10,0:13:14.14,0:13:14.62,dialog,,0,0,0,,Ah.
Dialogue: 10,0:13:16.16,0:13:19.60,dialog,,0,0,0,,Jasmine, syukurlah.\NKutukannya sudah lepas, ya.
Dialogue: 10,0:13:20.06,0:13:22.00,dialog,,0,0,0,,Aku bisa mengalahkanmu\Ndengan mudah sekarang.
Dialogue: 10,0:13:22.03,0:13:25.07,dialog,,0,0,0,,Kau bercanda, 'kan?
Dialogue: 10,0:13:25.76,0:13:27.43,dialog,,0,0,0,,Sepertinya kau tak bercanda.
Dialogue: 10,0:13:27.46,0:13:29.32,dialog,,0,0,0,,Hanya itu yang ingin kau katakan?
Dialogue: 10,0:13:32.43,0:13:33.83,dialog,,0,0,0,,Maafkan aku.
Dialogue: 10,0:13:33.86,0:13:35.66,dialog,,0,0,0,,Untuk apa?
Dialogue: 10,0:13:36.08,0:13:40.34,dialog,,0,0,0,,Karena aku mengabaikan perintahmu\Ndan malah melawannya.
Dialogue: 10,0:13:41.36,0:13:43.80,dialog,,0,0,0,,Aku hanya terbawa emosi.
Dialogue: 10,0:13:44.60,0:13:46.23,dialog,,0,0,0,,Tak apa jika kau sudah paham.
Dialogue: 10,0:13:47.80,0:13:50.35,dialog,,0,0,0,,Kau benar-benar mengalahkannya sendirian.
Dialogue: 10,0:13:50.70,0:13:52.06,dialog,,0,0,0,,Sekadar mengalahkan saja.
Dialogue: 10,0:13:52.46,0:13:55.36,dialog,,0,0,0,,Itu memang kubutuhkan,\Ntapi bukan itu yang kuinginkan.
Dialogue: 10,0:13:55.85,0:13:58.46,dialog,,0,0,0,,Lalu, kekuatan apa yang kau inginkan?
Dialogue: 10,0:13:59.06,0:14:00.36,dialog,,0,0,0,,Kekuatan untuk melindungi.
Dialogue: 10,0:14:01.26,0:14:02.87,dialog,,0,0,0,,Karena kelemahanku,
Dialogue: 10,0:14:02.90,0:14:07.91,dialog,,0,0,0,,aku terpisah dari ayah, ibu, dan Eleanor.
Dialogue: 10,0:14:08.70,0:14:10.83,dialog,,0,0,0,,Andai saja aku lebih kuat,
Dialogue: 10,0:14:10.86,0:14:13.26,dialog,,0,0,0,,aku pasti bisa melindungi orang-orang\Nyang berharga bagiku.
Dialogue: 10,0:14:15.20,0:14:16.53,dialog,,0,0,0,,Maafkan aku.
Dialogue: 10,0:14:16.56,0:14:18.50,dialog,,0,0,0,,Itu bukan salahmu, Jasmine.
Dialogue: 10,0:14:18.86,0:14:21.46,dialog,,0,0,0,,Lagi pula, masa lalu tak bisa diubah.
Dialogue: 10,0:14:24.50,0:14:28.46,dialog,,0,0,0,,Aku hanya perlu terus hidup\Nagar tidak ada lagi penyesalan.
Dialogue: 10,0:14:30.34,0:14:34.10,dialog,,0,0,0,,Meski begitu, jika terjadi sesuatu padamu,
Dialogue: 10,0:14:34.13,0:14:36.03,dialog,,0,0,0,,Alice dan yang lainnya pasti akan bersedih.
Dialogue: 10,0:14:36.06,0:14:38.40,dialog,,0,0,0,,Jangan lakukan hal berbahaya demi diriku.
Dialogue: 10,0:14:38.43,0:14:39.63,dialog,,0,0,0,,Itu mustahil.
Dialogue: 10,0:14:40.35,0:14:44.11,dialog,,0,0,0,,Karena bagiku, kau juga orang yang berharga.
Dialogue: 10,0:14:48.05,0:14:51.80,dialog,,0,0,0,,Tak baik bersikap manis\Nhanya demi sebuah maaf.
Dialogue: 10,0:14:51.83,0:14:54.06,dialog,,0,0,0,,Aku tak bermaksud begitu.
Dialogue: 10,0:14:55.12,0:14:57.37,dialog,,0,0,0,,Mulutmu makin manis saja.
Dialogue: 10,0:14:57.40,0:14:58.86,dialog,,0,0,0,,Aku serius.
Dialogue: 10,0:15:03.90,0:15:05.70,dialog,,0,0,0,,Terima kasih sudah menolongku.
Dialogue: 10,0:15:06.10,0:15:07.63,dialog,,0,0,0,,Sama-sama.
Dialogue: 10,0:15:10.38,0:15:14.60,dialog,,0,0,0,,Oh, ya. Kita harus mengambil\NMana Core milik Arachne.
Dialogue: 10,0:15:38.76,0:15:41.17,dialog,,0,0,0,,Kalian melawan Arachne?
Dialogue: 10,0:15:41.55,0:15:43.37,dialog,,0,0,0,,Hebat sekali kalian bisa selamat.
Dialogue: 10,0:15:43.40,0:15:44.83,dialog,,0,0,0,,Kami hanya sedang beruntung.
Dialogue: 10,0:15:45.16,0:15:46.50,dialog,,0,0,0,,Hei, Note.
Dialogue: 10,0:15:47.47,0:15:50.47,dialog,,0,0,0,,Apa kalian sungguh bertemu Arachne?
Dialogue: 10,0:15:50.50,0:15:52.83,dialog,,0,0,0,,Lucas, kau ini...
Dialogue: 10,0:15:52.86,0:15:54.67,dialog,,0,0,0,,Wajar kalau aku curiga, 'kan?
Dialogue: 10,0:15:54.70,0:15:57.68,dialog,,0,0,0,,Mana mungkin Arachne muncul di permukaan.
Dialogue: 10,0:15:58.10,0:16:00.37,dialog,,0,0,0,,Kau tidak sedang mengarang cerita, 'kan?
Dialogue: 10,0:16:00.40,0:16:02.43,dialog,,0,0,0,,Bagaimana agar kau percaya?
Dialogue: 10,0:16:02.81,0:16:05.86,dialog,,0,0,0,,Tunjukkan Mana Core miliknya.
Dialogue: 10,0:16:08.06,0:16:09.26,dialog,,0,0,0,,Kyu.
Dialogue: 10,0:16:10.23,0:16:12.86,dialog,,0,0,0,,Sayang sekali, kami gagal mengambilnya.
Dialogue: 10,0:16:13.96,0:16:16.55,dialog,,0,0,0,,Kalau begitu, ceritamu makin mencurigakan.
Dialogue: 10,0:16:16.58,0:16:20.60,dialog,,0,0,0,,Mungkin kalian salah mengiranya\Nsebagai Giant Spider?
Dialogue: 10,0:16:24.36,0:16:26.84,dialog,,0,0,0,,Apa kau sudah percaya sekarang?
Dialogue: 10,0:16:27.26,0:16:29.03,dialog,,0,0,0,,Mata Pembeku?
Dialogue: 10,0:16:30.30,0:16:31.66,dialog,,0,0,0,,Ini asli.
Dialogue: 10,0:16:32.06,0:16:33.36,dialog,,0,0,0,,Mustahil.
Dialogue: 10,0:16:33.70,0:16:35.26,dialog,,0,0,0,,Ini pertama kalinya aku melihatnya.
Dialogue: 10,0:16:36.86,0:16:37.87,dialog,,0,0,0,,Keras sekali.
Dialogue: 10,0:16:37.90,0:16:39.66,dialog,,0,0,0,,Bisa-bisanya kau memotong benda sekeras ini.
Dialogue: 10,0:16:39.96,0:16:41.66,dialog,,0,0,0,,Bagaimana, Lucas?
Dialogue: 10,0:16:42.70,0:16:45.35,dialog,,0,0,0,,Sepertinya kau tidak berbohong.
Dialogue: 10,0:16:45.70,0:16:48.57,dialog,,0,0,0,,Tapi mana Beast level ini
Dialogue: 10,0:16:48.60,0:16:50.60,dialog,,0,0,0,,sama sekali bukan ancaman bagiku.
Dialogue: 10,0:16:50.63,0:16:51.60,dialog,,0,0,0,,Tentu saja.
Dialogue: 10,0:16:51.63,0:16:55.43,dialog,,0,0,0,,Kalau ada kesempatan, aku ingin meminjam\Nkekuatanmu lagi, Lucas Wykes.
Dialogue: 10,0:16:55.46,0:16:57.00,dialog,,0,0,0,,Hmph!
Dialogue: 10,0:16:57.03,0:16:58.37,dialog,,0,0,0,,Ayo pergi.
Dialogue: 10,0:16:59.00,0:17:01.60,dialog,,0,0,0,,Sikapnya tak pernah berubah.
Dialogue: 10,0:17:02.00,0:17:03.20,dialog,,0,0,0,,Benar.
Dialogue: 10,0:17:03.76,0:17:06.37,dialog,,0,0,0,,Note, kita harus bergegas.
Dialogue: 10,0:17:06.40,0:17:07.83,dialog,,0,0,0,,Kalian mau pergi ke mana?
Dialogue: 10,0:17:07.86,0:17:09.50,dialog,,0,0,0,,Kami mau pulang kampung.
Dialogue: 10,0:17:13.98,0:17:15.18,dialog,,0,0,0,,Aku pulang.
Dialogue: 10,0:17:15.38,0:17:17.61,dialog,,0,0,0,,Kakak!
Dialogue: 10,0:17:17.64,0:17:21.60,dialog,,0,0,0,,Ayo ceritakan petualangan hebat apa\Nyang kau alami kali ini.
Dialogue: 10,0:17:21.63,0:17:23.46,dialog,,0,0,0,,Pahlawan keluarga kita.
Dialogue: 10,0:17:25.20,0:17:27.54,dialog,,0,0,0,,Kau mengalahkan Arachne?
Dialogue: 10,0:17:28.46,0:17:30.62,dialog,,0,0,0,,Kau hebat sekali, Arthur.
Dialogue: 10,0:17:30.65,0:17:33.53,dialog,,0,0,0,,Dulu kami sangat kesulitan\Nmelawan makhluk itu.
Dialogue: 10,0:17:33.56,0:17:35.13,dialog,,0,0,0,,Benar, 'kan, Jasmine?
Dialogue: 10,0:17:35.16,0:17:38.27,dialog,,0,0,0,,Ya, kami sampai kalah\Nempat kali berturut-turut.
Dialogue: 10,0:17:38.30,0:17:40.10,dialog,,0,0,0,,Kakak memang paling hebat!
Dialogue: 10,0:17:40.76,0:17:42.63,dialog,,0,0,0,,Bagaimana caramu mengalahkannya?
Dialogue: 10,0:17:42.66,0:17:46.92,dialog,,0,0,0,,Karena cangkangnya keras, aku memusatkan\Nserangan hanya pada satu titik.
Dialogue: 10,0:17:47.24,0:17:50.20,dialog,,0,0,0,,Kupikir sihir akan lebih mematikan\Njika diserang dari dalam.
Dialogue: 10,0:17:51.86,0:17:53.92,dialog,,0,0,0,,Duduklah di sana.
Dialogue: 10,0:17:56.36,0:17:59.80,dialog,,0,0,0,,Bukankah kau sudah berjanji\Ntakkan melakukan hal berbahaya?
Dialogue: 10,0:17:59.83,0:18:01.40,dialog,,0,0,0,,Ya, 'kan?
Dialogue: 10,0:18:01.43,0:18:02.58,dialog,,0,0,0,,Ingin rasanya kubilang,
Dialogue: 10,0:18:02.61,0:18:05.78,dialog,,0,0,0,,hal itu mustahil kujanjikan\Njika aku menjadi petualang.
Dialogue: 10,0:18:05.81,0:18:08.13,dialog,,0,0,0,,Tapi janji tetaplah janji.
Dialogue: 10,0:18:08.16,0:18:09.20,dialog,,0,0,0,,Maafkan aku.
Dialogue: 10,0:18:09.23,0:18:10.53,dialog,,0,0,0,,Jasmine.
Dialogue: 10,0:18:10.56,0:18:13.53,dialog,,0,0,0,,Padahal kau bersamanya,\Napa maksud semua ini?
Dialogue: 10,0:18:13.56,0:18:14.93,dialog,,0,0,0,,Maafkan aku.
Dialogue: 10,0:18:14.96,0:18:16.42,dialog,,0,0,0,,Arachne itu
Dialogue: 10,0:18:16.45,0:18:20.13,dialog,,0,0,0,,masuk lima besar Beast yang harus dihindari\Nkalau bertemu, bukan?
Dialogue: 10,0:18:20.16,0:18:21.40,dialog,,0,0,0,,Maafkan aku.
Dialogue: 10,0:18:21.43,0:18:24.73,dialog,,0,0,0,,Jasmine tak bersalah.\NItu sepenuhnya keputusanku.
Dialogue: 10,0:18:24.76,0:18:27.00,dialog,,0,0,0,,Ibu sedang bicara dengan Jasmine!
Dialogue: 10,0:18:27.03,0:18:27.96,dialog,,0,0,0,,Maafkan aku.
Dialogue: 10,0:18:28.36,0:18:29.60,dialog,,0,0,0,,Maafkan aku.
Dialogue: 10,0:18:30.10,0:18:33.03,dialog,,0,0,0,,Karena kau yang bersikeras,
Dialogue: 10,0:18:33.35,0:18:36.18,dialog,,0,0,0,,dan Jasmine bersedia membimbingmu,
Dialogue: 10,0:18:36.21,0:18:39.80,dialog,,0,0,0,,Ibu pun mengizinkanmu menjadi petualang.
Dialogue: 10,0:18:40.63,0:18:41.96,dialog,,0,0,0,,Tapi...
Dialogue: 10,0:18:42.72,0:18:46.66,dialog,,0,0,0,,kenapa kau malah melawan\NBeast berbahaya seperti Arachne?
Dialogue: 10,0:18:47.00,0:18:50.76,dialog,,0,0,0,,Lagi pula, bagaimana ceritanya\Nkau bisa mengalahkan monster itu?
Dialogue: 10,0:18:52.76,0:18:54.23,dialog,,0,0,0,,Sudahlah.
Dialogue: 10,0:18:56.00,0:19:01.40,dialog,,0,0,0,,Arthur, lain kali patuhi instruksi Jasmine.\NKau paham, 'kan?
Dialogue: 10,0:19:03.06,0:19:04.33,dialog,,0,0,0,,Ya.
Dialogue: 10,0:19:04.36,0:19:06.75,dialog,,0,0,0,,Jasmine, bagaimana soal Arachne itu?
Dialogue: 10,0:19:07.04,0:19:09.50,dialog,,0,0,0,,Aku sudah meminta Guild menyelidikinya.
Dialogue: 10,0:19:09.84,0:19:10.54,dialog,,0,0,0,,Terima kasih.
Dialogue: 10,0:19:10.82,0:19:13.77,dialog,,0,0,0,,Aku akan meminta Helen dan yang lain\Nuntuk lebih waspada.
Dialogue: 10,0:19:13.80,0:19:14.97,dialog,,0,0,0,,Ya.
Dialogue: 10,0:19:15.00,0:19:17.90,dialog,,0,0,0,,Kalau begitu, jangan murung lagi.
Dialogue: 10,0:19:19.03,0:19:23.13,dialog,,0,0,0,,Tindakan Arthur memang berbahaya,\Ntapi kau patut berbangga.
Dialogue: 10,0:19:23.16,0:19:25.23,dialog,,0,0,0,,Bukan karena dia mengalahkan Arachne,
Dialogue: 10,0:19:25.60,0:19:29.03,dialog,,0,0,0,,melainkan karena dia kembali dengan selamat.
Dialogue: 10,0:19:29.86,0:19:31.27,dialog,,0,0,0,,Benar juga.
Dialogue: 10,0:19:31.90,0:19:35.50,dialog,,0,0,0,,Arthur, jangan sering-sering\Nmembuat Ibu khawatir, ya.
Dialogue: 10,0:19:35.86,0:19:37.70,dialog,,0,0,0,,Aku mengerti, Ibu.
Dialogue: 10,0:19:40.86,0:19:42.46,dialog,,0,0,0,,Kita kena marah.
Dialogue: 10,0:19:43.43,0:19:46.34,dialog,,0,0,0,,Bagiku, Alice-lah yang paling menakutkan.
Dialogue: 10,0:19:46.37,0:19:48.76,dialog,,0,0,0,,Aku bisa memahaminya.
Dialogue: 10,0:19:48.79,0:19:51.54,dialog,,0,0,0,,Lain kali, jangan sampai kena marah lagi.
Dialogue: 10,0:19:52.10,0:19:53.30,dialog,,0,0,0,,Kau benar.
Dialogue: 10,0:20:02.16,0:20:03.90,dialog,,0,0,0,,Tanpa sihir.
Dialogue: 10,0:20:05.43,0:20:06.63,dialog,,0,0,0,,Baiklah.
Dialogue: 10,0:20:12.44,0:20:14.90,dialog,,0,0,0,,Hal yang tak kumiliki\Ndi kehidupanku sebelumnya.
Dialogue: 10,0:20:17.94,0:20:20.86,dialog,,0,0,0,,Di kehidupan ini,\Naku bersumpah melindunginya.
Dialogue: 10,0:20:23.86,0:20:27.66,dialog,,0,0,0,,Demi itu, aku butuh lebih banyak kekuatan.
Dialogue: 10,0:20:28.80,0:20:32.50,dialog,,0,0,0,,Kekuatan untuk melindungi mereka\Nyang berharga bagiku.
Dialogue: 10,0:20:39.40,0:20:41.03,dialog,,0,0,0,,Terima kasih banyak.
Dialogue: 10,0:20:48.83,0:20:50.36,dialog,,0,0,0,,Ada apa?
Dialogue: 10,0:20:51.16,0:20:53.16,dialog,,0,0,0,,Aku hanya teringat sesuatu.
Dialogue: 10,0:20:57.70,0:21:00.26,dialog,,0,0,0,,Seseorang yang berembus seperti angin.
Dialogue: 10,0:21:01.52,0:21:02.80,dialog,,0,0,0,,Bagaimana kabarmu...
Dialogue: 10,0:21:04.20,0:21:05.40,dialog,,0,0,0,,Tessia?
Dialogue: 10,0:21:05.99,0:21:08.79,dialog,,0,0,0,,Aku tak mau dengar!
Dialogue: 10,0:21:08.94,0:21:11.80,dialog,,0,0,0,,Aku tak mau dengar!
Dialogue: 10,0:21:12.75,0:21:16.15,dialog,,0,0,0,,Aku tak pernah dengar akan jadi seperti ini!
