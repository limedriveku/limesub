Dialogue: 0,0:03:32.98,0:03:37.98,6-normal,,0,0,0,,{\fad(800,900)\fs80\bord3\blur0\3c&HFFFFFF&\c&H000000&\pos(1827,886)\b1}#5  Sang{\c&H138BC6&} Raja, {\c&H000000&}Ber{\c&H138BC6&}juang{\c&H000000&}.
Dialogue: 10,0:00:10.49,0:00:12.15,dialog,,0,0,0,,Kalian datang, ya.
Dialogue: 10,0:00:12.15,0:00:14.31,dialog,,0,0,0,,Kami sudah mendengar dari Brald.
Dialogue: 10,0:00:14.74,0:00:18.35,dialog,,0,0,0,,Katanya kalian kenal Lucas dan Elijah?
Dialogue: 10,0:00:18.35,0:00:19.62,dialog,,0,0,0,,Ya.
Dialogue: 10,0:00:19.62,0:00:22.15,dialog,,0,0,0,,Namaku Reginald Bastion.
Dialogue: 10,0:00:22.15,0:00:24.65,dialog,,0,0,0,,Aku Augmenter Kelas A.
Dialogue: 10,0:00:24.65,0:00:26.78,dialog,,0,0,0,,Namaku Criol Masser.
Dialogue: 10,0:00:26.78,0:00:29.55,dialog,,0,0,0,,Aku juga Augmenter Kelas A.
Dialogue: 10,0:00:29.88,0:00:31.71,dialog,,0,0,0,,Pengguna elemen air.
Dialogue: 10,0:00:31.71,0:00:32.81,dialog,,0,0,0,,Salam kenal.
Dialogue: 10,0:00:33.45,0:00:36.21,dialog,,0,0,0,,Namaku Oliver Hembett.
Dialogue: 10,0:00:36.21,0:00:38.31,dialog,,0,0,0,,Aku Conjurer Kelas A.
Dialogue: 10,0:00:39.51,0:00:41.05,dialog,,0,0,0,,Batu itu...
Dialogue: 10,0:00:42.15,0:00:43.77,dialog,,0,0,0,,Namanya Oliver?
Dialogue: 10,0:00:44.41,0:00:46.61,dialog,,0,0,0,,Dia sama seperti Alice.
Dialogue: 10,0:00:46.95,0:00:48.31,dialog,,0,0,0,,Seorang Emitter.
Dialogue: 10,0:00:49.41,0:00:52.85,dialog,,0,0,0,,Kehadiran Emitter di dalam party\Nmembuatku merasa tenang.
Dialogue: 10,0:00:52.85,0:00:54.32,dialog,,0,0,0,,Namaku Samantha.
Dialogue: 10,0:00:54.81,0:00:56.81,dialog,,0,0,0,,Aku Conjurer Kelas A.
Dialogue: 10,0:00:56.81,0:00:58.15,dialog,,0,0,0,,Salam kenal.
Dialogue: 10,0:00:59.05,0:01:01.51,dialog,,0,0,0,,Siapa namamu, Pria Bertopeng?
Dialogue: 10,0:01:01.51,0:01:05.18,dialog,,0,0,0,,Namaku Note, Augmenter Kelas A.
Dialogue: 10,0:01:05.18,0:01:08.31,dialog,,0,0,0,,Jasmine, Augmenter Kelas AA.
Dialogue: 10,0:01:08.98,0:01:12.84,dialog,,0,0,0,,Senang rasanya ada satu lagi\Npetualang Kelas AA di party kita.
Dialogue: 10,0:01:13.18,0:01:15.95,dialog,,0,0,0,,Semuanya sudah berkumpul.
Dialogue: 10,0:01:15.95,0:01:17.15,dialog,,0,0,0,,Kau terlambat.
Dialogue: 10,0:01:18.21,0:01:19.68,dialog,,0,0,0,,Maaf membuat kalian menunggu.
Dialogue: 10,0:01:20.10,0:01:24.71,dialog,,0,0,0,,Seperti yang kalian tahu,\Naku Brald, ketua party ini.
Dialogue: 10,0:01:24.71,0:01:27.60,dialog,,0,0,0,,Aku Augmenter\Nyang baru saja naik ke Kelas AA.
Dialogue: 10,0:01:28.51,0:01:29.81,dialog,,0,0,0,,Barang bawaanmu itu...
Dialogue: 10,0:01:30.11,0:01:33.35,dialog,,0,0,0,,Apa kalian berdua tak punya cincin dimensi?
Dialogue: 10,0:01:33.35,0:01:33.93,dialog,,0,0,0,,Ya.
Dialogue: 10,0:01:33.93,0:01:34.75,dialog,,0,0,0,,Ah...
Dialogue: 10,0:01:36.78,0:01:39.31,dialog,,0,0,0,,Kalian bisa menitipkannya padaku,
Dialogue: 10,0:01:39.31,0:01:42.62,dialog,,0,0,0,,tapi sudah penuh oleh barang Samantha.
Dialogue: 10,0:01:42.62,0:01:45.12,dialog,,0,0,0,,Mau menitipkannya padaku saja?
Dialogue: 10,0:01:45.12,0:01:46.95,dialog,,0,0,0,,Aku masih punya tempat.
Dialogue: 10,0:01:48.46,0:01:49.85,dialog,,0,0,0,,Itu saja?
Dialogue: 10,0:01:49.85,0:01:53.21,dialog,,0,0,0,,Ya, ini semuanya. Terima kasih.
Dialogue: 10,0:01:53.21,0:01:54.46,dialog,,0,0,0,,Terima kasih.
Dialogue: 10,0:01:54.46,0:01:55.95,dialog,,0,0,0,,Sama-sama.
Dialogue: 10,0:01:56.51,0:01:57.47,dialog,,0,0,0,,Kalau begitu...
Dialogue: 10,0:01:57.95,0:02:00.01,dialog,,0,0,0,,Ayo kita berangkat.
Dialogue: 10,0:03:33.78,0:03:37.51,dialog - atas,,0,0,0,,Alasan kami bekerja sama\Ndengan orang-orang tak dikenal ini,
Dialogue: 10,0:03:37.51,0:03:39.49,dialog - atas,,0,0,0,,karena kami diundang oleh Brald.
Dialogue: 10,0:03:40.41,0:03:43.71,dialog,,0,0,0,,Di lantai paling bawah\Nterdapat banyak batu sihir.
Dialogue: 10,0:03:44.15,0:03:45.49,dialog,,0,0,0,,Batu sihir?
Dialogue: 10,0:03:45.49,0:03:47.65,dialog,,0,0,0,,Batu alam berukuran besar
Dialogue: 10,0:03:47.65,0:03:51.95,dialog,,0,0,0,,yang bisa memperkuat sihir\Ndan menjadi sumber berbagai energi.
Dialogue: 10,0:03:51.95,0:03:55.11,dialog,,0,0,0,,Seseorang memberiku misi\Nuntuk mengambilnya.
Dialogue: 10,0:03:55.11,0:03:58.08,dialog,,0,0,0,,Jadi, aku mengumpulkan petualang andal.
Dialogue: 10,0:04:00.51,0:04:02.95,dialog,,0,0,0,,Kalian kenal Lucas dan Elijah, 'kan?
Dialogue: 10,0:04:03.38,0:04:04.26,dialog,,0,0,0,,Ya.
Dialogue: 10,0:04:04.26,0:04:06.78,dialog,,0,0,0,,Mereka juga ikut bergabung.
Dialogue: 10,0:04:06.78,0:04:09.35,dialog,,0,0,0,,Mereka yang mengusulkan kalian berdua.
Dialogue: 10,0:04:10.77,0:04:15.01,dialog,,0,0,0,,Karena Jasmine, Lucas, dan Elijah\Nikut bergabung,
Dialogue: 10,0:04:15.01,0:04:16.77,dialog,,0,0,0,,aku pun memutuskan untuk ikut.
Dialogue: 10,0:04:17.45,0:04:20.78,dialog,,0,0,0,,Aku malah takut\Nterjadi sesuatu pada mereka.
Dialogue: 10,0:04:21.35,0:04:24.85,dialog,,0,0,0,,Kenapa kalian ikut bergabung\Ndalam misi ini?
Dialogue: 10,0:04:25.21,0:04:30.61,dialog,,0,0,0,,Karena kudengar Brald mengumpulkan\Npetualang Kelas A yang berbakat.
Dialogue: 10,0:04:32.05,0:04:34.31,dialog,,0,0,0,,Kau ikut bukan karena bonusnya?
Dialogue: 10,0:04:34.31,0:04:35.71,dialog,,0,0,0,,Dengar, ya,
Dialogue: 10,0:04:35.71,0:04:38.29,dialog,,0,0,0,,aku tak kekurangan uang.
Dialogue: 10,0:04:38.65,0:04:40.70,dialog,,0,0,0,,Daripada soal bonus,
Dialogue: 10,0:04:40.71,0:04:44.74,dialog,,0,0,0,,aku lebih mengincar reputasi\Nkarena berhasil menaklukkan dungeon.
Dialogue: 10,0:04:44.74,0:04:47.80,dialog,,0,0,0,,Enaknya jadi orang yang serbakecukupan.
Dialogue: 10,0:04:48.38,0:04:51.45,dialog,,0,0,0,,Aku butuh banyak uang karena\Nuntuk menghidupi anak-anakku.
Dialogue: 10,0:04:51.91,0:04:56.56,dialog,,0,0,0,,Aku juga. Aku butuh modal\Nuntuk membuka toko roti.
Dialogue: 10,0:04:56.56,0:05:00.81,dialog,,0,0,0,,Meski alasannya berbeda-beda,\Nkini kita adalah satu party.
Dialogue: 10,0:05:00.81,0:05:02.91,dialog,,0,0,0,,Mari kita bekerja sama.
Dialogue: 10,0:05:03.58,0:05:04.68,dialog,,0,0,0,,Benar.
Dialogue: 10,0:05:05.78,0:05:07.68,dialog,,0,0,0,,Ini gerbang masuknya.
Dialogue: 10,0:05:08.65,0:05:10.65,dialog,,0,0,0,,Kalau begitu, ayo masuk.
Dialogue: 10,0:05:13.61,0:05:16.68,dialog,,0,0,0,,Kelihatannya seperti dungeon biasa.
Dialogue: 10,0:05:18.11,0:05:20.84,dialog,,0,0,0,,Aku sudah menyelidikinya lebih dulu.
Dialogue: 10,0:05:21.38,0:05:24.38,dialog,,0,0,0,,Hebat sekali, Ketua.
Dialogue: 10,0:05:24.38,0:05:28.09,dialog,,0,0,0,,Jadi, kau sudah tahu jalan\Nmenuju lantai bawah?
Dialogue: 10,0:05:28.65,0:05:31.10,dialog,,0,0,0,,Tidak, aku tak pergi sampai ke sana.
Dialogue: 10,0:05:31.10,0:05:34.51,dialog,,0,0,0,,Intinya, kita takkan menemui masalah\Njika terus maju dari sini.
Dialogue: 10,0:05:34.51,0:05:36.48,dialog,,0,0,0,,Kalau begitu, misi ini akan mudah.
Dialogue: 10,0:05:37.85,0:05:42.45,dialog,,0,0,0,,Tidak, kabarnya ada makhluk abadi\Ndi dungeon ini.
Dialogue: 10,0:05:42.45,0:05:45.81,dialog,,0,0,0,,Monster yang kita kalahkan\Nbisa hidup kembali.
Dialogue: 10,0:05:45.81,0:05:47.61,dialog,,0,0,0,,Memangnya ada monster seperti itu?
Dialogue: 10,0:05:47.95,0:05:51.05,dialog,,0,0,0,,Ditambah lagi, kita tak bisa\Nmengambil Mana Core mereka.
Dialogue: 10,0:05:51.05,0:05:53.51,dialog,,0,0,0,,Tidak ada untungnya\Nbertarung melawan mereka.
Dialogue: 10,0:05:53.51,0:05:55.62,dialog,,0,0,0,,Tempat ini disebut Kuburan Teror.
Dialogue: 10,0:05:56.15,0:05:57.43,dialog,,0,0,0,,Apa maksudnya itu?
Dialogue: 10,0:05:57.43,0:06:00.13,dialog,,0,0,0,,Makanya, bertarunglah seefisien mungkin.
Dialogue: 10,0:06:00.13,0:06:02.38,dialog,,0,0,0,,Jangan buang-buang Mana dengan percuma.
Dialogue: 10,0:06:03.18,0:06:05.71,dialog,,0,0,0,,Aku hanya perlu mengalahkan mereka\Ndengan satu serangan saja, 'kan?
Dialogue: 10,0:06:05.71,0:06:08.95,dialog,,0,0,0,,Simpan saja semangatmu itu.
Dialogue: 10,0:06:08.95,0:06:09.76,dialog,,0,0,0,,Apa?
Dialogue: 10,0:06:09.76,0:06:12.64,dialog,,0,0,0,,Kau sudah terlalu berlebihan sebelumnya.
Dialogue: 10,0:06:17.18,0:06:19.11,dialog,,0,0,0,,Ah, benar juga.
Dialogue: 10,0:06:19.11,0:06:19.72,dialog,,0,0,0,,Benar, 'kan?
Dialogue: 10,0:06:19.72,0:06:20.95,dialog,,0,0,0,,Berisik!
Dialogue: 10,0:06:23.91,0:06:25.15,dialog,,0,0,0,,Sepi sekali, ya?
Dialogue: 10,0:06:25.55,0:06:28.98,dialog,,0,0,0,,Seharusnya belum ada monster\Ndi sekitar sini.
Dialogue: 10,0:06:28.98,0:06:30.31,dialog,,0,0,0,,Apa-apaan ini?
Dialogue: 10,0:06:30.31,0:06:31.71,dialog,,0,0,0,,Membosankan.
Dialogue: 10,0:06:31.71,0:06:33.78,dialog,,0,0,0,,Sebaiknya kau jangan lengah.
Dialogue: 10,0:06:33.78,0:06:38.41,dialog,,0,0,0,,Paling-paling monster di dekat\Npintu masuk tidak ada yang kuat.
Dialogue: 10,0:06:38.78,0:06:39.88,dialog,,0,0,0,,Dasar.
Dialogue: 10,0:06:41.35,0:06:43.61,dialog,,0,0,0,,Bocah ini selalu saja begitu.
Dialogue: 10,0:06:48.51,0:06:49.98,dialog,,0,0,0,,Bat Runner?
Dialogue: 10,0:06:49.99,0:06:50.65,dialog,,0,0,0,,Eh?
Dialogue: 10,0:06:51.55,0:06:52.65,dialog,,0,0,0,,Jumlahnya banyak sekali.
Dialogue: 10,0:06:55.67,0:06:56.78,dialog,,0,0,0,,Menunduk!
Dialogue: 10,0:07:12.81,0:07:14.99,dialog,,0,0,0,,Jangan buang-buang stamina dan Mana.
Dialogue: 10,0:07:14.99,0:07:16.49,dialog,,0,0,0,,Tapi...
Dialogue: 10,0:07:16.49,0:07:19.84,dialog,,0,0,0,,Apa kau melihat mereka\Nsaat pertama kali datang ke sini?
Dialogue: 10,0:07:19.84,0:07:20.48,dialog,,0,0,0,,Tidak.
Dialogue: 10,0:07:21.18,0:07:22.48,dialog,,0,0,0,,Mereka seolah tak ada habisnya.
Dialogue: 10,0:07:23.25,0:07:24.91,dialog,,0,0,0,,Lucas, tolong!
Dialogue: 10,0:07:27.01,0:07:28.65,dialog,,0,0,0,,Biar kubantu.
Dialogue: 10,0:07:40.35,0:07:41.31,dialog,,0,0,0,,Berhasil!
Dialogue: 10,0:07:41.31,0:07:42.45,dialog,,0,0,0,,Kau menyelamatkan kami.
Dialogue: 10,0:07:42.45,0:07:43.91,dialog,,0,0,0,,Tapi itu terlalu berlebihan.
Dialogue: 10,0:07:45.91,0:07:48.75,dialog,,0,0,0,,Padahal sudah kubilang\Njangan buang-buang Mana.
Dialogue: 10,0:07:48.75,0:07:49.57,dialog,,0,0,0,,Tak masalah, 'kan?
Dialogue: 10,0:07:49.62,0:07:51.03,dialog,,0,0,0,,Yang penting aku berhasil menumpasnya.
Dialogue: 10,0:07:55.18,0:07:58.11,dialog,,0,0,0,,Ayo bergegas sebelum mereka hidup lagi.
Dialogue: 10,0:08:08.45,0:08:12.05,dialog,,0,0,0,,Elijah, bisa buatkan tangga di dinding?
Dialogue: 10,0:08:23.55,0:08:25.31,dialog,,0,0,0,,Oke, kalian bisa menyeberang.
Dialogue: 10,0:08:27.51,0:08:28.85,dialog,,0,0,0,,Apa kau baik-baik saja?
Dialogue: 10,0:08:29.38,0:08:31.31,dialog,,0,0,0,,Biar aku turun duluan.
Dialogue: 10,0:08:31.31,0:08:34.31,dialog,,0,0,0,,Aku akan menangkapmu jika kau terjatuh.
Dialogue: 10,0:08:34.71,0:08:35.78,dialog,,0,0,0,,Terima kasih.
Dialogue: 10,0:08:35.78,0:08:37.88,dialog,,0,0,0,,Aku takut ketinggian.
Dialogue: 10,0:08:38.81,0:08:43.21,dialog,,0,0,0,,Seharusnya ada lorong\Nyang menyambung ke lantai bawah.
Dialogue: 10,0:08:43.21,0:08:44.54,dialog,,0,0,0,,Seharusnya?
Dialogue: 10,0:08:44.95,0:08:47.54,dialog,,0,0,0,,Maksudku, lorongnya ada\Nsaat aku datang sebelumnya.
Dialogue: 10,0:08:47.54,0:08:49.75,dialog,,0,0,0,,Pokoknya, ayo bergegas.
Dialogue: 10,0:08:49.75,0:08:52.21,dialog,,0,0,0,,Kita ingin cepat dapat hartanya, 'kan?
Dialogue: 10,0:08:52.58,0:08:54.55,dialog,,0,0,0,,Benar juga, ya.
Dialogue: 10,0:08:56.35,0:08:59.05,dialog,,0,0,0,,Kalian tertolong berkat sihirku, 'kan?
Dialogue: 10,0:08:59.05,0:08:59.95,dialog,,0,0,0,,Ya.
Dialogue: 10,0:08:59.95,0:09:02.06,dialog,,0,0,0,,Kau menyelamatkan kami.
Dialogue: 10,0:09:02.45,0:09:06.06,dialog,,0,0,0,,Note, sebaiknya kau tak buang-buang Mana.
Dialogue: 10,0:09:06.55,0:09:08.31,dialog,,0,0,0,,Kau ini mudah khawatir, ya.
Dialogue: 10,0:09:24.18,0:09:25.28,dialog,,0,0,0,,Jebakan?
Dialogue: 10,0:09:25.65,0:09:26.79,dialog,,0,0,0,,Hei!
Dialogue: 10,0:09:27.11,0:09:29.11,dialog,,0,0,0,,Aku tak diberi tahu\Nkalau di sini ada jebakan.
Dialogue: 10,0:09:31.98,0:09:33.91,dialog,,0,0,0,,Ini tak sesuai dengan janjimu!
Dialogue: 10,0:09:35.95,0:09:39.30,dialog,,0,0,0,,Jika kau berhasil mengumpulkan\Npetualang berbakat,
Dialogue: 10,0:09:39.65,0:09:41.41,dialog,,0,0,0,,hadiahnya akan sangat besar.
Dialogue: 10,0:09:41.41,0:09:42.31,dialog,,0,0,0,,Ya.
Dialogue: 10,0:09:42.31,0:09:44.06,dialog,,0,0,0,,Aku punya beberapa kenalan.
Dialogue: 10,0:09:44.51,0:09:47.45,dialog,,0,0,0,,Oh, ya? Bagus sekali.
Dialogue: 10,0:09:47.45,0:09:51.32,dialog,,0,0,0,,Tempat seperti apa Kuburan Teror itu?
Dialogue: 10,0:09:51.32,0:09:54.85,dialog,,0,0,0,,Tidak ada jebakan atau monster kuat.
Dialogue: 10,0:09:55.18,0:09:58.25,dialog,,0,0,0,,Hanya saja, monster di sana tak bisa mati.
Dialogue: 10,0:09:58.57,0:10:01.80,dialog,,0,0,0,,Karena itu, kita harus hancurkan mereka\Nagar tak bisa beregenerasi.
Dialogue: 10,0:10:01.81,0:10:04.83,dialog,,0,0,0,,Itulah mengapa dibutuhkan\Npetualang yang berbakat.
Dialogue: 10,0:10:05.58,0:10:09.83,dialog,,0,0,0,,Takkan jadi masalah bagi orang-orang\Nyang kau ajak, 'kan?
Dialogue: 10,0:10:10.78,0:10:11.88,dialog,,0,0,0,,Benar juga.
Dialogue: 10,0:10:15.34,0:10:18.28,dialog,,0,0,0,,Ini peta menuju lantai bawah.
Dialogue: 10,0:10:19.21,0:10:21.75,dialog,,0,0,0,,Kudengar tak ada jebakan di sini.
Dialogue: 10,0:10:21.75,0:10:23.05,dialog,,0,0,0,,Apa yang terjadi?
Dialogue: 10,0:10:27.75,0:10:30.68,dialog,,0,0,0,,Semuanya, aku akan maju pelan-pelan.
Dialogue: 10,0:10:34.78,0:10:36.81,dialog,,0,0,0,,Apa kalian merasa kepanasan?
Dialogue: 10,0:10:36.81,0:10:38.11,dialog,,0,0,0,,Hanya kau saja, 'kan?
Dialogue: 10,0:10:38.58,0:10:40.75,dialog,,0,0,0,,Aku juga merasa panas.
Dialogue: 10,0:10:41.12,0:10:42.98,dialog,,0,0,0,,Ada yang aneh.
Dialogue: 10,0:10:42.98,0:10:46.78,dialog,,0,0,0,,Apa dulu hawanya tidak sepanas ini?
Dialogue: 10,0:10:46.78,0:10:49.48,dialog,,0,0,0,,Tidak, bukan seperti itu.
Dialogue: 10,0:10:49.87,0:10:51.45,dialog,,0,0,0,,Perasaan tidak enak itu
Dialogue: 10,0:10:51.45,0:10:55.05,dialog,,0,0,0,,pasti berasal dari makhluk kuat\Ndi depan sana, 'kan?
Dialogue: 10,0:11:04.21,0:11:05.88,dialog,,0,0,0,,Tempat apa ini?
Dialogue: 10,0:11:05.88,0:11:06.51,dialog,,0,0,0,,Ya.
Dialogue: 10,0:11:06.91,0:11:08.91,dialog,,0,0,0,,Ditambah hawa panas ini.
Dialogue: 10,0:11:10.91,0:11:11.71,dialog,,0,0,0,,Apa?
Dialogue: 10,0:11:11.71,0:11:13.21,dialog,,0,0,0,,Aku juga tidak tahu.
Dialogue: 10,0:11:13.21,0:11:16.31,dialog,,0,0,0,,Dari tadi kau cuma bilang\N"aneh" dan "tidak tahu"!
Dialogue: 10,0:11:16.31,0:11:18.99,dialog,,0,0,0,,Apa kau benar-benar\Nsudah menyelidiki tempat ini?
Dialogue: 10,0:11:21.55,0:11:22.74,dialog,,0,0,0,,Kau!
Dialogue: 10,0:11:24.94,0:11:25.80,dialog,,0,0,0,,Criol!
Dialogue: 10,0:11:27.58,0:11:28.87,dialog,,0,0,0,,Serahkan padaku!
Dialogue: 10,0:11:39.98,0:11:42.13,dialog,,0,0,0,,Hei, jawab dengan jujur.
Dialogue: 10,0:11:42.13,0:11:44.75,dialog,,0,0,0,,Apa kau benar sudah menyelidiki tempat ini
Dialogue: 10,0:11:44.75,0:11:46.01,dialog,,0,0,0,,atau belum sama sekali?
Dialogue: 10,0:11:46.55,0:11:49.71,dialog,,0,0,0,,Aku mendengar detail dungeon ini\Ndari si pemberi misi.
Dialogue: 10,0:11:49.71,0:11:51.64,dialog,,0,0,0,,Aku juga diberi petanya.
Dialogue: 10,0:11:52.55,0:11:55.27,dialog,,0,0,0,,Kawanan Bat Runner masih bisa diatasi...
Dialogue: 10,0:11:55.27,0:11:57.45,dialog,,0,0,0,,Tapi bagaimana dengan jebakan?
Dialogue: 10,0:11:57.45,0:11:59.53,dialog,,0,0,0,,Lalu bagaimana dengan Worm besar itu?
Dialogue: 10,0:12:00.93,0:12:02.03,dialog,,0,0,0,,Itu...
Dialogue: 10,0:12:03.58,0:12:06.78,dialog,,0,0,0,,Itu Mana Beast yang seharusnya tidak ada?
Dialogue: 10,0:12:08.79,0:12:13.55,dialog,,0,0,0,,Aneh, tiba-tiba ada Mana Beast\Nbaru muncul di dungeon ini?
Dialogue: 10,0:12:14.05,0:12:16.25,dialog,,0,0,0,,Bukan tiba-tiba.
Dialogue: 10,0:12:16.25,0:12:18.88,dialog,,0,0,0,,Dari awal informasinya disembunyikan.
Dialogue: 10,0:12:19.31,0:12:21.55,dialog,,0,0,0,,Tapi dengan tujuan apa?
Dialogue: 10,0:12:29.55,0:12:31.12,dialog,,0,0,0,,Ikutlah denganku.
Dialogue: 10,0:12:31.12,0:12:31.80,dialog,,0,0,0,,Eh?
Dialogue: 10,0:12:31.81,0:12:33.95,dialog,,0,0,0,,Brald itu pembohong.
Dialogue: 10,0:12:33.95,0:12:37.61,dialog,,0,0,0,,Kita akan jadi santapan monster\Njika terus mengikutinya.
Dialogue: 10,0:12:38.32,0:12:40.95,dialog,,0,0,0,,Saat mereka sibuk melawan Worm,
Dialogue: 10,0:12:40.95,0:12:43.51,dialog,,0,0,0,,kita pergi saja mengambil hartanya.
Dialogue: 10,0:12:43.51,0:12:44.17,dialog,,0,0,0,,Tapi...
Dialogue: 10,0:12:44.17,0:12:45.95,dialog,,0,0,0,,Sudahlah, ayo ikut!
Dialogue: 10,0:12:49.98,0:12:51.48,dialog,,0,0,0,,Ada yang aneh.
Dialogue: 10,0:12:51.95,0:12:52.85,dialog,,0,0,0,,Tunggu!
Dialogue: 10,0:12:52.85,0:12:55.75,dialog,,0,0,0,,Aku tak mau mati di sini bersama kalian!
Dialogue: 10,0:12:55.75,0:12:57.51,dialog,,0,0,0,,Jangan! Lucas!
Dialogue: 10,0:12:57.51,0:12:58.85,dialog,,0,0,0,,Aku mengerti.
Dialogue: 10,0:13:07.97,0:13:10.05,dialog,,0,0,0,,Oliver, masuklah!
Dialogue: 10,0:13:10.05,0:13:11.11,dialog,,0,0,0,,Hah?
Dialogue: 10,0:13:11.11,0:13:12.60,dialog,,0,0,0,,Apa maksudmu?
Dialogue: 10,0:13:13.18,0:13:14.31,dialog,,0,0,0,,Sudah kubilang, 'kan?
Dialogue: 10,0:13:14.31,0:13:16.08,dialog,,0,0,0,,Aku tak mau mati...
Dialogue: 10,0:13:41.75,0:13:43.35,dialog,,0,0,0,,Samantha!
Dialogue: 10,0:13:44.78,0:13:47.91,dialog,,0,0,0,,Tukar itu dengan kristal di tongkatmu.
Dialogue: 10,0:13:48.35,0:13:50.14,dialog,,0,0,0,,Kekuatannya akan meningkat.
Dialogue: 10,0:13:54.38,0:13:56.01,dialog,,0,0,0,,Ayo kita keluar dari sini.
Dialogue: 10,0:13:56.01,0:13:57.38,dialog,,0,0,0,,Ya.
Dialogue: 10,0:13:57.38,0:14:01.65,dialog,,0,0,0,,Note benar,\Nayo keluar sebelum terjadi ledakan lagi.
Dialogue: 10,0:14:09.51,0:14:10.66,dialog,,0,0,0,,Criol!
Dialogue: 10,0:14:10.66,0:14:11.85,dialog,,0,0,0,,Tolong!
Dialogue: 10,0:14:11.85,0:14:12.91,dialog,,0,0,0,,Biar aku saja.
Dialogue: 10,0:14:17.98,0:14:19.11,dialog,,0,0,0,,Sialan!
Dialogue: 10,0:14:19.11,0:14:20.92,dialog,,0,0,0,,Samantha! Elijah!
Dialogue: 10,0:14:20.92,0:14:22.35,dialog,,0,0,0,,Serang!
Dialogue: 10,0:14:31.55,0:14:35.11,dialog,,0,0,0,,Batu milik Oliver kuat sekali.
Dialogue: 10,0:14:44.38,0:14:46.19,dialog,,0,0,0,,Apa daya serang kita masih kurang?
Dialogue: 10,0:14:47.75,0:14:49.45,dialog,,0,0,0,,Jasmine! Reginald!
Dialogue: 10,0:14:49.45,0:14:51.07,dialog,,0,0,0,,Maju bersamaku!
Dialogue: 10,0:14:51.07,0:14:51.79,dialog,,0,0,0,,Ya.
Dialogue: 10,0:14:51.97,0:14:52.81,dialog,,0,0,0,,Ya!
Dialogue: 10,0:14:55.78,0:14:58.78,dialog,,0,0,0,,Jasmine, bantu aku alihkan perhatiannya!
Dialogue: 10,0:14:58.78,0:14:59.58,dialog,,0,0,0,,Aku mengerti.
Dialogue: 10,0:14:59.58,0:15:02.98,dialog,,0,0,0,,Sementara itu, Reginald...\NSerang tepat di celah kepalanya!
Dialogue: 10,0:15:02.98,0:15:04.01,dialog,,0,0,0,,Mengerti!
Dialogue: 10,0:15:04.71,0:15:07.59,dialog,,0,0,0,,Lucas, Note, cari kelemahannya!
Dialogue: 10,0:15:07.77,0:15:08.31,dialog,,0,0,0,,Ya.
Dialogue: 10,0:15:14.51,0:15:16.98,dialog,,0,0,0,,Sihir api biasa takkan mempan.
Dialogue: 10,0:15:16.98,0:15:20.85,dialog,,0,0,0,,Kalau begitu, tak ada cara lain\Nselain sihir api yang lebih kuat?
Dialogue: 10,0:15:38.21,0:15:39.31,dialog,,0,0,0,,Note!
Dialogue: 10,0:15:56.95,0:16:00.35,dialog,,0,0,0,,Apa aku sedang ketakutan?
Dialogue: 10,0:16:00.73,0:16:02.13,dialog,,0,0,0,,Lucas!
Dialogue: 10,0:16:03.98,0:16:05.05,dialog,,0,0,0,,Jasmine!
Dialogue: 10,0:16:13.28,0:16:14.53,dialog,,0,0,0,,Lucas!
Dialogue: 10,0:16:21.11,0:16:23.11,dialog,,0,0,0,,Apa dia berhasil lolos?
Dialogue: 10,0:16:23.45,0:16:26.04,dialog,,0,0,0,,Setidaknya kita aman untuk sementara waktu.
Dialogue: 10,0:16:26.58,0:16:28.45,dialog,,0,0,0,,Ayo bergerak selagi bisa.
Dialogue: 10,0:16:32.55,0:16:35.55,dialog,,0,0,0,,Worm itu tak berniat membunuh kita.
Dialogue: 10,0:16:35.55,0:16:38.88,dialog,,0,0,0,,Ia hanya mengulur waktu\Nsambil menunggu ledakan berikutnya.
Dialogue: 10,0:16:39.91,0:16:40.85,dialog,,0,0,0,,Lucas!
Dialogue: 10,0:16:40.85,0:16:42.14,dialog,,0,0,0,,Pelindung...
Dialogue: 10,0:16:43.53,0:16:44.66,dialog,,0,0,0,,Bocah bodoh ini.
Dialogue: 10,0:17:04.45,0:17:05.55,dialog,,0,0,0,,Note...
Dialogue: 10,0:17:06.08,0:17:08.11,dialog,,0,0,0,,Syukurlah kau selamat.
Dialogue: 10,0:17:08.11,0:17:09.09,dialog,,0,0,0,,Dasar kau ini.
Dialogue: 10,0:17:10.61,0:17:12.65,dialog,,0,0,0,,Jangan bertindak ceroboh.
Dialogue: 10,0:17:15.75,0:17:16.86,dialog,,0,0,0,,Kau tak apa-apa?
Dialogue: 10,0:17:16.86,0:17:17.61,dialog,,0,0,0,,Ya.
Dialogue: 10,0:17:18.31,0:17:21.10,dialog,,0,0,0,,Apa kau tak terluka, Brald?
Dialogue: 10,0:17:25.91,0:17:28.81,dialog,,0,0,0,,Ayo bergegas pergi dari sini!
Dialogue: 10,0:17:32.41,0:17:33.22,dialog,,0,0,0,,Bertahanlah.
Dialogue: 10,0:17:33.22,0:17:34.71,dialog,,0,0,0,,Sedikit lagi.
Dialogue: 10,0:17:44.18,0:17:46.12,dialog,,0,0,0,,Apa kau mau makan ini?
Dialogue: 10,0:17:46.91,0:17:48.01,dialog,,0,0,0,,Terima kasih.
Dialogue: 10,0:17:48.38,0:17:51.45,dialog,,0,0,0,,Sandwich andalanku saat bertualang.
Dialogue: 10,0:17:52.51,0:17:54.48,dialog,,0,0,0,,Bagaimana? Enak, 'kan?
Dialogue: 10,0:17:54.85,0:17:56.25,dialog,,0,0,0,,Sangat enak.
Dialogue: 10,0:17:56.25,0:17:58.11,dialog,,0,0,0,,Itu resep dari Clara.
Dialogue: 10,0:17:58.11,0:17:59.25,dialog,,0,0,0,,Clara?
Dialogue: 10,0:17:59.25,0:18:00.75,dialog,,0,0,0,,Tunanganku.
Dialogue: 10,0:18:01.65,0:18:05.89,dialog,,0,0,0,,Jadi, kau mau buka toko roti bersama Clara?
Dialogue: 10,0:18:08.38,0:18:09.65,dialog,,0,0,0,,Begitulah.
Dialogue: 10,0:18:09.65,0:18:13.03,dialog,,0,0,0,,Tolong sampaikan kalau resepnya enak sekali.
Dialogue: 10,0:18:13.03,0:18:14.45,dialog,,0,0,0,,Ya.
Dialogue: 10,0:18:14.45,0:18:15.95,dialog,,0,0,0,,Dia pasti akan senang.
Dialogue: 10,0:18:15.95,0:18:17.21,dialog,,0,0,0,,Hentikan!
Dialogue: 10,0:18:17.21,0:18:18.75,dialog,,0,0,0,,Aku tak salah!
Dialogue: 10,0:18:19.31,0:18:24.79,dialog,,0,0,0,,Aku ikut karena ketuanya adalah\Npetualang Kelas AA yang veteran.
Dialogue: 10,0:18:24.79,0:18:28.41,dialog,,0,0,0,,Tapi jangankan melindungi Emitter,
Dialogue: 10,0:18:28.41,0:18:30.81,dialog,,0,0,0,,kau malah kehilangan satu lenganmu.
Dialogue: 10,0:18:30.81,0:18:32.51,dialog,,0,0,0,,Apa yang harus kita lakukan sekarang?
Dialogue: 10,0:18:32.51,0:18:34.81,dialog,,0,0,0,,Kau sendiri menjatuhkan senjatamu\Ndi saat yang genting.
Dialogue: 10,0:18:34.81,0:18:36.67,dialog,,0,0,0,,Kau juga jadi beban, 'kan?
Dialogue: 10,0:18:37.18,0:18:39.93,dialog,,0,0,0,,Jangan sombong!\NPadahal Note baru saja menyelamatkanmu!
Dialogue: 10,0:18:39.93,0:18:41.18,dialog,,0,0,0,,Berisik!
Dialogue: 10,0:18:41.18,0:18:42.93,dialog,,0,0,0,,Sudah kubilang, hentikan!
Dialogue: 10,0:18:43.41,0:18:45.61,dialog,,0,0,0,,Andai kau lebih cepat buat pelindung,
Dialogue: 10,0:18:45.61,0:18:47.68,dialog,,0,0,0,,tanganku takkan berakhir seperti ini.
Dialogue: 10,0:18:48.11,0:18:49.78,dialog,,0,0,0,,Jangan jadikan aku kambing hitam!
Dialogue: 10,0:18:49.78,0:18:50.88,dialog,,0,0,0,,Lucas!
Dialogue: 10,0:18:52.19,0:18:53.91,dialog,,0,0,0,,Cukup sampai di situ.
Dialogue: 10,0:18:53.91,0:18:55.21,dialog,,0,0,0,,Apa?
Dialogue: 10,0:18:55.21,0:18:57.57,dialog,,0,0,0,,Berhentilah saling menyalahkan.
Dialogue: 10,0:19:02.55,0:19:03.91,dialog,,0,0,0,,Brald.
Dialogue: 10,0:19:03.91,0:19:07.11,dialog,,0,0,0,,Sebelum lanjut,\Nada yang harus kau putuskan.
Dialogue: 10,0:19:07.45,0:19:09.81,dialog,,0,0,0,,Apa kita akan tetap lanjut?
Dialogue: 10,0:19:09.81,0:19:11.08,dialog,,0,0,0,,Atau mundur?
Dialogue: 10,0:19:12.25,0:19:14.88,dialog,,0,0,0,,Satu lagi, jangan ada yang ditutupi.
Dialogue: 10,0:19:15.51,0:19:18.38,dialog,,0,0,0,,Rasa saling curiga dan tak percaya\Nhanya akan membunuh kita di sini.
Dialogue: 10,0:19:20.41,0:19:23.41,dialog,,0,0,0,,Aku bohong pernah datang ke sini.
Dialogue: 10,0:19:24.21,0:19:27.01,dialog,,0,0,0,,Aku cuma dapat informasi\Ndari si pemberi misi.
Dialogue: 10,0:19:27.01,0:19:29.02,dialog,,0,0,0,,Aku sama sekali belum pernah kemari.
Dialogue: 10,0:19:32.95,0:19:34.35,dialog,,0,0,0,,Sudah kuduga.
Dialogue: 10,0:19:34.77,0:19:37.78,dialog,,0,0,0,,Harga dari menyeret kalian\Nke dalam situasi mematikan ini,
Dialogue: 10,0:19:38.21,0:19:40.15,dialog,,0,0,0,,kurasa tak sepadan\Nhanya dengan kehilangan lengan ini.
Dialogue: 10,0:19:40.78,0:19:43.66,dialog,,0,0,0,,Namun, aku ingin kita tetap lanjut.
Dialogue: 10,0:19:44.18,0:19:45.91,dialog,,0,0,0,,Mungkin bagiku
Dialogue: 10,0:19:45.91,0:19:48.41,dialog,,0,0,0,,ini akan menjadi dungeon terakhirku.
Dialogue: 10,0:19:48.98,0:19:51.16,dialog,,0,0,0,,Tolong biarkan aku\Nmenyelesaikannya sampai akhir.
Dialogue: 10,0:19:51.16,0:19:53.81,dialog,,0,0,0,,Kita harus batalkan misi ini, 'kan?
Dialogue: 10,0:19:53.81,0:19:55.62,dialog,,0,0,0,,Seperti kata Jasmine.
Dialogue: 10,0:19:55.62,0:19:57.67,dialog,,0,0,0,,Kita tak bisa lanjut\Ndengan keadaan lukamu itu.
Dialogue: 10,0:19:57.98,0:20:01.11,dialog,,0,0,0,,Biarpun begini,\Naku adalah Augmenter Kelas AA.
Dialogue: 10,0:20:01.75,0:20:04.11,dialog,,0,0,0,,Aku takkan menyusahkan siapa pun.
Dialogue: 10,0:20:05.41,0:20:09.11,dialog,,0,0,0,,Kita takkan bisa pulang\Ndengan selamat kalau begini.
Dialogue: 10,0:20:09.11,0:20:12.39,dialog,,0,0,0,,Apa batu sihir itu benar-benar ada?
Dialogue: 10,0:20:12.39,0:20:14.45,dialog,,0,0,0,,Kalau soal itu, aku yakin sekali.
Dialogue: 10,0:20:14.85,0:20:15.95,dialog,,0,0,0,,Hm.
Dialogue: 10,0:20:16.27,0:20:17.55,dialog,,0,0,0,,Aku mohon.
Dialogue: 10,0:20:18.17,0:20:21.03,dialog,,0,0,0,,Maju atau mundur sama-sama neraka.
Dialogue: 10,0:20:21.91,0:20:23.01,dialog,,0,0,0,,Kalau begitu...
Dialogue: 10,0:20:23.91,0:20:25.25,dialog,,0,0,0,,Aku mengerti.
Dialogue: 10,0:20:25.25,0:20:26.35,dialog,,0,0,0,,Note.
Dialogue: 10,0:20:30.41,0:20:31.75,dialog,,0,0,0,,Ditambah,
Dialogue: 10,0:20:32.51,0:20:35.33,dialog,,0,0,0,,kurasa lebih baik Note yang jadi ketua.
Dialogue: 10,0:20:36.45,0:20:38.91,dialog,,0,0,0,,Saat menghadapi situasi tak terduga,
Dialogue: 10,0:20:38.91,0:20:43.25,dialog,,0,0,0,,kau yang paling tenang\Ndan bisa mengendalikan keadaan.
Dialogue: 10,0:20:43.25,0:20:45.09,dialog,,0,0,0,,Kau terlahir sebagai pemimpin.
Dialogue: 10,0:20:46.18,0:20:47.28,dialog,,0,0,0,,Bagaimana?
Dialogue: 10,0:20:50.97,0:20:51.68,dialog,,0,0,0,,Aku mengerti.
Dialogue: 10,0:20:56.01,0:21:00.28,dialog,,0,0,0,,Kudengar jalan menuju lantai dasar\Nada di balik gerbang ini.
Dialogue: 10,0:21:14.11,0:21:15.21,dialog,,0,0,0,,Ini...
