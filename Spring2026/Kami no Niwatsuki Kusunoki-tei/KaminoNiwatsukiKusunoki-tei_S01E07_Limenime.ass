Dialogue: 0,0:01:01.86,0:01:04.48,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:02:21.01,0:02:25.94,tanda,,0000,0000,0000,,KUNCI KEKUATAN ADA PADA INGATAN
Dialogue: 0,0:04:09.41,0:04:11.21,tanda,,0000,0000,0000,,KEESOKAN HARINYA
Dialogue: 0,0:04:35.85,0:04:37.47,tanda,,0000,0000,0000,,"KUE MADU PREMIUM"
Dialogue: 0,0:05:05.83,0:05:07.95,tanda,,0000,0000,0000,,LENTERA ROH
Dialogue: 0,0:05:35.22,0:05:38.90,tanda,,0000,0000,0000,,"ES SERUT"
Dialogue: 0,0:08:10.06,0:08:12.42,tanda,,0000,0000,0000,,PENGINAPAN KUSUNOKI
Dialogue: 0,0:08:24.57,0:08:26.03,tanda,,0000,0000,0000,,"TEKANAN"
Dialogue: 0,0:08:51.11,0:08:52.82,tanda,,0000,0000,0000,,"PENGINAPAN KUSUNOKI"
Dialogue: 0,0:09:53.19,0:09:55.49,tanda,,0000,0000,0000,,"HATI"
Dialogue: 0,0:10:48.02,0:10:49.38,tanda,,0000,0000,0000,,"MUNDUR"
Dialogue: 0,0:11:59.03,0:12:05.01,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:12:10.45,0:12:13.37,tanda,,0000,0000,0000,,RUMAH KUSUNOKI
Dialogue: 0,0:17:04.39,0:17:07.02,tanda,,0000,0000,0000,,"MUNDUR"
Dialogue: 0,0:18:49.19,0:18:51.61,tanda,,0000,0000,0000,,SUARA LONCENG ANGIN
Dialogue: 0,0:23:36.54,0:23:39.33,tanda,,0000,0000,0000,,SELANJUTNYA:\NGUNUNG SEBELAH PUNYA IKATAN SEJAK DULU
Dialogue: 0,0:00:08.59,0:00:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kali aku melihatnya...
Dialogue: 0,0:00:13.55,0:00:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:00:17.92,0:00:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku berusia lima tahun.
Dialogue: 0,0:00:23.60,0:00:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek! Kakek!
Dialogue: 0,0:00:26.44,0:00:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:00:27.47,0:00:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semanggi berdaun empat dari Warashi.
Dialogue: 0,0:00:32.04,0:00:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau akrab dengan Warashi, ya.
Dialogue: 0,0:00:34.92,0:00:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:35.75,0:00:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warashi bilang itu\Nbalasan untuk camilannya.
Dialogue: 0,0:00:41.00,0:00:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Identitas aslinya adalah
Dialogue: 0,0:00:42.73,0:00:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yokai yang tinggal di rumah ini\Nsejak sebelum Kakek lahir.
Dialogue: 0,0:00:47.01,0:00:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo makan bersama.
Dialogue: 0,0:00:48.58,0:00:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warashi.
Dialogue: 0,0:02:26.30,0:02:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganjil genap.
Dialogue: 0,0:02:29.30,0:02:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganjil ganjil genap.
Dialogue: 0,0:02:31.85,0:02:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warashi, coba ikuti yang kulakukan.
Dialogue: 0,0:02:35.39,0:02:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:37.23,0:02:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganjil genap.
Dialogue: 0,0:02:39.00,0:02:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganjil genap.
Dialogue: 0,0:02:40.68,0:02:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganjil ganjil genap.
Dialogue: 0,0:02:43.39,0:02:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, hebat!
Dialogue: 0,0:02:45.29,0:02:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:02:47.00,0:02:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warashi, kuberikan sesuatu yang bagus.
Dialogue: 0,0:02:49.21,0:02:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:02:50.58,0:02:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek sepertinya masih bisa melihat\Nbanyak yokai yang tidak bisa kulihat.
Dialogue: 0,0:02:59.98,0:03:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Nue!
Dialogue: 0,0:03:01.11,0:03:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan datang mengganggu!
Dialogue: 0,0:03:03.88,0:03:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh menyebalkan.
Dialogue: 0,0:03:07.75,0:03:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warashi, monaka ini besar.
Dialogue: 0,0:03:10.27,0:03:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita bagi dua.
Dialogue: 0,0:03:11.51,0:03:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:14.05,0:03:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato ini
Dialogue: 0,0:03:15.21,0:03:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pandai juga menjadi kakak.
Dialogue: 0,0:03:26.27,0:03:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:03:31.60,0:03:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini…
Dialogue: 0,0:03:33.05,0:03:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Babun.
Dialogue: 0,0:03:35.24,0:03:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babun, kembalikan topiku.
Dialogue: 0,0:03:41.64,0:03:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:47.05,0:03:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek!
Dialogue: 0,0:03:48.55,0:03:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek, dengarkan aku.
Dialogue: 0,0:03:50.61,0:03:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babun menggangguku.
Dialogue: 0,0:03:53.54,0:03:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena makhluk-makhluk itu\Ntidak ada kerjaan.
Dialogue: 0,0:03:55.70,0:03:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menggodamu untuk bersenang-senang.
Dialogue: 0,0:03:58.64,0:03:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?
Dialogue: 0,0:03:59.64,0:04:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski senggang pun,\Ntidak boleh menggangguku.
Dialogue: 0,0:04:03.25,0:04:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa akur dengannya atau tidak,
Dialogue: 0,0:04:05.37,0:04:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu tergantung padamu.
Dialogue: 0,0:04:15.96,0:04:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:04:24.16,0:04:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babun!
Dialogue: 0,0:04:25.54,0:04:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan topiku!
Dialogue: 0,0:04:31.54,0:04:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji tidak akan menggangguku lagi.
Dialogue: 0,0:04:34.63,0:04:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:04:35.85,0:04:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuberikan kue madu ini.
Dialogue: 0,0:04:38.28,0:04:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau suka kue madu, 'kan?
Dialogue: 0,0:04:40.14,0:04:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah melihatmu\Nmengambilnya dari altar.
Dialogue: 0,0:04:44.14,0:04:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan dulu topiku, baru kuberikan.
Dialogue: 0,0:04:57.85,0:04:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:05:01.56,0:05:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu, aku dan Babun\Nmenjadi teman baik.
Dialogue: 0,0:05:08.45,0:05:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lama kemudian, Kakek meninggal.
Dialogue: 0,0:05:14.87,0:05:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terjadi suatu hari setelah aku\Nnaik ke kelas lima SD.
Dialogue: 0,0:05:20.78,0:05:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas sekali.
Dialogue: 0,0:05:23.42,0:05:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ranmaru, kalau bilang panas,\Nakan terasa makin panas, lo.
Dialogue: 0,0:05:27.65,0:05:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi memang sangat panas.
Dialogue: 0,0:05:31.08,0:05:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo pikirkan hal-hal\Nyang membuat hati menjadi sejuk.
Dialogue: 0,0:05:34.04,0:05:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya apa?
Dialogue: 0,0:05:35.22,0:05:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Camilanku hari ini adalah es serut.
Dialogue: 0,0:05:38.90,0:05:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, enak sekali.
Dialogue: 0,0:05:40.74,0:05:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya bicara saja,\Ndi rumahku juga ada es krim.
Dialogue: 0,0:05:48.45,0:05:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi.
Dialogue: 0,0:05:49.56,0:05:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak terasa lebih sejuk.
Dialogue: 0,0:06:12.53,0:06:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan baik-baik, Minato.
Dialogue: 0,0:06:14.55,0:06:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika bertemu yokai di luar,
Dialogue: 0,0:06:16.65,0:06:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus lari sebelum\Nia menyadari keberadaanmu.
Dialogue: 0,0:06:19.48,0:06:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena yokai tidak selalu jinak.
Dialogue: 0,0:06:27.54,0:06:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ran-Ranmaru, ayo kita pulang.
Dialogue: 0,0:06:29.90,0:06:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba bilang begitu?
Dialogue: 0,0:06:33.44,0:06:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Es serut.
Dialogue: 0,0:06:34.57,0:06:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, aku ingin cepat makan es serut.
Dialogue: 0,0:06:36.98,0:06:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, cepat, lari.
Dialogue: 0,0:06:39.39,0:06:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlari di cuaca panas seperti ini,\Nbenar-benar tidak bisa.
Dialogue: 0,0:06:42.22,0:06:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya tidak terlalu jauh, 'kan?
Dialogue: 0,0:06:45.29,0:06:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, cepat pulang!
Dialogue: 0,0:06:53.63,0:06:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak.
Dialogue: 0,0:06:56.31,0:07:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus main di bawah terik matahari,\Nbisa terkena sengatan panas.
Dialogue: 0,0:07:01.68,0:07:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:04.41,0:07:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghilang?
Dialogue: 0,0:07:06.59,0:07:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, katanya di sekitar sini\Nada Jalan Onsen.
Dialogue: 0,0:07:15.74,0:07:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan Onsen yang sangat berkarakter.
Dialogue: 0,0:07:18.56,0:07:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Anda memesan penginapan?
Dialogue: 0,0:07:21.31,0:07:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:22.00,0:07:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mungkin tidak ada\Ntempat menginap.
Dialogue: 0,0:07:24.84,0:07:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:07:26.16,0:07:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penginapan di daerah sini\Nseharusnya sudah penuh.
Dialogue: 0,0:07:29.87,0:07:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di musim sekarang?
Dialogue: 0,0:07:31.39,0:07:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tempat ini populer sepanjang tahun.
Dialogue: 0,0:07:33.75,0:07:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penginapan mana pun\Nnyaman untuk ditinggali.
Dialogue: 0,0:07:36.73,0:07:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Kalau begitu,\Naku benar-benar ingin mencobanya.
Dialogue: 0,0:07:40.96,0:07:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita diskusi di rumahmu.
Dialogue: 0,0:07:45.47,0:07:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Anda tahu rumahku\Nadalah penginapan onsen?
Dialogue: 0,0:07:48.17,0:07:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:07:50.30,0:07:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria misterius itu
Dialogue: 0,0:07:52.18,0:07:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi tamu di penginapan onsen
Dialogue: 0,0:07:53.70,0:07:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dikelola keluarganya,\NPenginapan Kusunoki.
Dialogue: 0,0:07:57.10,0:07:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan hari itu ada\Nyang membatalkan kamar mendadak,
Dialogue: 0,0:07:59.60,0:08:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga ada satu kamar kosong.
Dialogue: 0,0:08:02.59,0:08:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, para yokai mulai gelisah.
Dialogue: 0,0:08:05.60,0:08:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sama sekali tak berani\Nmendekati kamar pria itu.
Dialogue: 0,0:08:18.63,0:08:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasnya merepotkan sekali.
Dialogue: 0,0:08:24.57,0:08:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisannya bagus sekali.
Dialogue: 0,0:08:26.39,0:08:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisannya sangat mudah dibaca.
Dialogue: 0,0:08:28.50,0:08:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:30.13,0:08:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya.
Dialogue: 0,0:08:32.27,0:08:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisanmu seolah mengandung\Nketulusan dan kemurnian hatimu.
Dialogue: 0,0:08:37.29,0:08:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku?
Dialogue: 0,0:08:39.86,0:08:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:40.98,0:08:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jagalah baik-baik.
Dialogue: 0,0:08:44.79,0:08:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:46.85,0:08:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengikuti nasihat orang itu.
Dialogue: 0,0:08:49.96,0:08:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat papan nama pun
Dialogue: 0,0:08:51.11,0:08:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berjalan lancar.
Dialogue: 0,0:08:54.62,0:08:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir sekarang,
Dialogue: 0,0:08:55.63,0:09:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak awal orang itu sudah tahu tulisanku\Nmengandung kekuatan mengusir roh jahat.
Dialogue: 0,0:09:01.03,0:09:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu mungkin adalah\Npengusir roh pengelana.
Dialogue: 0,0:09:04.44,0:09:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau yang biasa disebut pengusir roh.
Dialogue: 0,0:09:06.55,0:09:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengusir roh?
Dialogue: 0,0:09:07.71,0:09:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dengan onmyoji,\Nyang hanya warga biasa,
Dialogue: 0,0:09:11.10,0:09:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi pria itu sangat ahli.
Dialogue: 0,0:09:14.05,0:09:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:09:15.34,0:09:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya para yokai menghindarinya, 'kan?
Dialogue: 0,0:09:18.69,0:09:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:20.06,0:09:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, bagaimana latihan\Nkekuatan segelmu?
Dialogue: 0,0:09:25.40,0:09:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai lupa,
Dialogue: 0,0:09:26.86,0:09:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedang latihan menyegel\Nkekuatan mengusir roh jahat ke jimat.
Dialogue: 0,0:09:30.86,0:09:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petunjuknya ada dalam ingatanmu.
Dialogue: 0,0:09:35.34,0:09:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:36.37,0:09:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengusir roh itu
Dialogue: 0,0:09:37.97,0:09:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah melihat hakikat dari kekuatanmu.
Dialogue: 0,0:09:42.76,0:09:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisanmu seolah mengandung\Nketulusan dan kemurnian hatimu.
Dialogue: 0,0:09:48.98,0:09:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku paham.
Dialogue: 0,0:09:51.33,0:09:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung pernah bilang
Dialogue: 0,0:09:53.19,0:09:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}imajinasi itu penting, 'kan?
Dialogue: 0,0:09:55.90,0:10:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayangkan menyegel hatiku\Nke dalam jimat ini.
Dialogue: 0,0:10:04.69,0:10:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup seperti itu saja.
Dialogue: 0,0:10:06.17,0:10:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:10:07.75,0:10:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya berhasil.
Dialogue: 0,0:10:10.14,0:10:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:10:33.55,0:10:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tsubaki dan yang lain.
Dialogue: 0,0:10:37.18,0:10:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana situasinya?
Dialogue: 0,0:10:38.24,0:10:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, kau datang tepat waktu.
Dialogue: 0,0:10:40.84,0:10:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata dan kekuatan spiritual kami\Nsudah hampir habis.
Dialogue: 0,0:10:44.06,0:10:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan kami jimat Tuan Hisui.
Dialogue: 0,0:10:46.29,0:10:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:10:48.02,0:10:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk kalian.
Dialogue: 0,0:10:51.30,0:10:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:52.71,0:10:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Saiga!
Dialogue: 0,0:10:53.85,0:10:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan kami jimat juga.
Dialogue: 0,0:10:55.90,0:10:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!
Dialogue: 0,0:10:58.07,0:11:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jumlahnya banyak sekali.
Dialogue: 0,0:11:11.47,0:11:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terselamatkan.
Dialogue: 0,0:11:12.68,0:11:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:14.48,0:11:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hisui, terima kasih banyak.
Dialogue: 0,0:11:17.19,0:11:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat kapan pun, orang di sisimu…
Dialogue: 0,0:11:19.52,0:11:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah hal ini selesai,\Naku akan bepergian.
Dialogue: 0,0:11:21.51,0:11:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Padahal semuanya cantik,\N- Aku akan berendam onsen.
Dialogue: 0,0:11:23.52,0:11:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tapi tak ada\N- Lalu menonton film yang tertumpuk.
Dialogue: 0,0:11:24.48,0:11:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- yang menarik.\N- Jangan lupa minum.
Dialogue: 0,0:11:26.82,0:11:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, kita harus segera\Nmembersihkan roh jahat.
Dialogue: 0,0:11:30.71,0:11:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saiga.
Dialogue: 0,0:11:31.53,0:11:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana jimatnya?
Dialogue: 0,0:11:32.65,0:11:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal satu lembar terakhir.
Dialogue: 0,0:11:34.51,0:11:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ambil lagi.
Dialogue: 0,0:11:37.01,0:11:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:39.59,0:11:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Saiga.
Dialogue: 0,0:11:41.48,0:11:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda akan menemui Tuan Hisui, 'kan?
Dialogue: 0,0:11:44.71,0:11:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa orangnya?
Dialogue: 0,0:11:46.53,0:11:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pria, 'kan? Tampan?
Dialogue: 0,0:11:48.82,0:11:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanya dia.
Dialogue: 0,0:11:50.46,0:11:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku tak bisa membedakan\Ncantik atau jelek.
Dialogue: 0,0:12:13.67,0:12:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, silakan masuk.
Dialogue: 0,0:12:20.83,0:12:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah tekanan ini berasal dari para dewa?
Dialogue: 0,0:12:34.54,0:12:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:12:37.55,0:12:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai jimat yang kuminta sebelumnya…
Dialogue: 0,0:12:43.40,0:12:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:44.79,0:12:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan makhluk Reiju\Nmengamuk karena marah?
Dialogue: 0,0:12:49.02,0:12:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu…
Dialogue: 0,0:12:59.20,0:13:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipedulikan.
Dialogue: 0,0:13:02.05,0:13:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap tenang saat menghadapi\NReiju mengamuk.
Dialogue: 0,0:13:05.46,0:13:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki Minato memang tidak biasa.
Dialogue: 0,0:13:08.39,0:13:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jimatnya.
Dialogue: 0,0:13:10.31,0:13:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, beberapa hari lalu\Naku dapat kekuatan baru.
Dialogue: 0,0:13:14.55,0:13:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucoba pakai itu untuk menyegel\Nkekuatan mengusir roh jahat ke jimat.
Dialogue: 0,0:13:19.79,0:13:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kekuatannya tak bocor,\Nefeknya seharusnya lebih tahan lama.
Dialogue: 0,0:13:24.00,0:13:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya, terima kasih banyak.
Dialogue: 0,0:13:28.98,0:13:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlihat lelah.
Dialogue: 0,0:13:30.89,0:13:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena akhir-akhir ini banyak lagi\Nroh jahat yang bermunculan.
Dialogue: 0,0:13:34.89,0:13:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:13:37.07,0:13:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Fujin, Tuan Raijin.
Dialogue: 0,0:13:39.36,0:13:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, lama tidak berjumpa.
Dialogue: 0,0:13:41.49,0:13:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, pria ini
Dialogue: 0,0:13:43.38,0:13:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kelihatan lelah sekali.
Dialogue: 0,0:13:45.00,0:13:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sampai-sampai mengundang rasa iba.
Dialogue: 0,0:13:48.41,0:13:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya!
Dialogue: 0,0:13:50.03,0:13:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku lakukan elektroterapi padanya.
Dialogue: 0,0:13:53.44,0:13:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima, Tuan Raijin ingin\Nmelakukan elektroterapi padamu.
Dialogue: 0,0:13:57.83,0:13:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:58.74,0:14:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai, ya.
Dialogue: 0,0:14:09.36,0:14:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai!
Dialogue: 0,0:14:13.09,0:14:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima!
Dialogue: 0,0:14:14.84,0:14:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:15.59,0:14:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kekuatanku berlebihan?
Dialogue: 0,0:14:17.82,0:14:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan Harima! Tuan Harima!\N- Sedot…
Dialogue: 0,0:14:23.16,0:14:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu apakah urusan Tuan Harima\Nberjalan lancar atau tidak.
Dialogue: 0,0:14:26.50,0:14:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, selanjutnya serahkan padanya.
Dialogue: 0,0:14:29.55,0:14:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:30.37,0:14:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu,
Dialogue: 0,0:14:31.66,0:14:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kue sakura baru dari Echizentei\Nsangat kunantikan.
Dialogue: 0,0:14:35.49,0:14:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:36.64,0:14:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita cepat pulang.
Dialogue: 0,0:14:39.90,0:14:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,\Napakah daerah sini terasa aneh?
Dialogue: 0,0:14:43.42,0:14:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udara terasa berat.
Dialogue: 0,0:14:47.68,0:14:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah dewa terbengkalai?
Dialogue: 0,0:14:59.95,0:15:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:15:01.69,0:15:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar terlalu lengah.
Dialogue: 0,0:15:03.78,0:15:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatianku terfokus pada kue sakura.
Dialogue: 0,0:15:07.17,0:15:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini wilayah dewa\Ndari dewa yang merosot, 'kan?
Dialogue: 0,0:15:11.99,0:15:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, dibuat oleh dewa\Nyang tidak begitu kuat.
Dialogue: 0,0:15:16.56,0:15:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana dewa itu?
Dialogue: 0,0:15:18.80,0:15:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.
Dialogue: 0,0:15:20.00,0:15:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya keluar dari sini?
Dialogue: 0,0:15:22.17,0:15:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan kekuatan anginmu\Nuntuk membelah ruang.
Dialogue: 0,0:15:26.16,0:15:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba.
Dialogue: 0,0:15:30.45,0:15:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:15:31.71,0:15:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita keluar dari sini,
Dialogue: 0,0:15:33.78,0:15:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang akan terjadi pada dewa\Nyang menciptakan tempat ini?
Dialogue: 0,0:15:36.53,0:15:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibiarkan, energi negatif\Nakan bertambah.
Dialogue: 0,0:15:39.15,0:15:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambat laun akan\Nmemengaruhi daerah sekitar.
Dialogue: 0,0:15:43.89,0:15:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa tinggal diam saja?
Dialogue: 0,0:15:46.09,0:15:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang orang yang terlalu baik.
Dialogue: 0,0:15:48.18,0:15:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin.
Dialogue: 0,0:15:49.92,0:15:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu mirip gayamu.
Dialogue: 0,0:15:54.64,0:15:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita cari dewa itu.
Dialogue: 0,0:16:02.78,0:16:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:16:05.89,0:16:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah dewanya?
Dialogue: 0,0:16:08.45,0:16:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya seharusnya ini\Nadalah sebilah pedang.
Dialogue: 0,0:16:11.13,0:16:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Dewa Pedang?
Dialogue: 0,0:16:13.66,0:16:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, roh dewa tidak akan tinggal\Nsecara alami pada benda buatan manusia.
Dialogue: 0,0:16:18.09,0:16:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia yang memanggil\Nroh dewa ini ke pedang.
Dialogue: 0,0:16:23.21,0:16:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa rasanya sesak.
Dialogue: 0,0:16:25.94,0:16:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ia marah?
Dialogue: 0,0:16:27.35,0:16:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya begitu.
Dialogue: 0,0:16:28.63,0:16:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ingin kau lakukan?\NMemusnahkannya?
Dialogue: 0,0:16:32.66,0:16:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa ini marah karena\Ntidak diperlakukan dengan baik, 'kan?
Dialogue: 0,0:16:37.52,0:16:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau berpikir begitu?
Dialogue: 0,0:16:39.45,0:16:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena melihat tingkat karatnya,
Dialogue: 0,0:16:42.00,0:16:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan jadi seperti ini kalau\Ndirawat dan dipuja dengan baik.
Dialogue: 0,0:16:46.18,0:16:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:47.55,0:16:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin memusnahkannya.
Dialogue: 0,0:16:52.50,0:16:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau coba mengusir energi negatif\Ndengan jimat baru.
Dialogue: 0,0:16:59.71,0:17:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi negatifnya sangat mengerikan.
Dialogue: 0,0:17:01.54,0:17:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, kalau jimat biasa,
Dialogue: 0,0:17:04.39,0:17:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah pasti tidak akan mempan.
Dialogue: 0,0:17:10.94,0:17:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan segel sudah berfungsi?
Dialogue: 0,0:17:14.31,0:17:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:15.29,0:17:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya serahkan padaku.
Dialogue: 0,0:17:17.70,0:17:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga baru pertama kali\Nmerawat dewa lain.
Dialogue: 0,0:17:20.78,0:17:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu bagaimana hasilnya.
Dialogue: 0,0:17:22.40,0:17:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:23.27,0:17:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya sangat membuat khawatir.
Dialogue: 0,0:17:33.42,0:17:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana dewanya?
Dialogue: 0,0:17:34.59,0:17:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyelamatkannya, sudah aman.
Dialogue: 0,0:17:37.80,0:17:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:17:46.74,0:17:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang ini akan lenyap.
Dialogue: 0,0:17:48.48,0:17:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:49.37,0:17:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat, gunakan kekuatan angin.
Dialogue: 0,0:17:51.16,0:17:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:17:54.80,0:17:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya, Nomor Lima!
Dialogue: 0,0:18:01.25,0:18:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, kerja bagus.
Dialogue: 0,0:18:05.01,0:18:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sudah kenyang secepat ini?
Dialogue: 0,0:18:09.44,0:18:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, Ichijo dan Horikawa sedang apa?
Dialogue: 0,0:18:23.28,0:18:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:18:24.48,0:18:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikawa, lambat sekali\Nkau datang membantuku.
Dialogue: 0,0:18:27.57,0:18:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar dungu!
Dialogue: 0,0:18:29.25,0:18:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir-akhir ini kau terlalu imut…\NEh, salah.
Dialogue: 0,0:18:34.18,0:18:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kau agak gemukan,\Njadi lambat saat berlari.
Dialogue: 0,0:18:40.10,0:18:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih merepotkan daripada sebelumnya.
Dialogue: 0,0:18:44.97,0:18:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara lonceng angin!
Dialogue: 0,0:18:51.98,0:18:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efeknya luar biasa.
Dialogue: 0,0:18:58.52,0:19:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan spiritualnya tidak cukup.
Dialogue: 0,0:19:00.34,0:19:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, jimatnya juga sudah habis.
Dialogue: 0,0:19:02.24,0:19:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tinggal sedikit lagi.
Dialogue: 0,0:19:04.06,0:19:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bagaimana ini?
Dialogue: 0,0:19:05.67,0:19:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, tenang.
Dialogue: 0,0:19:11.88,0:19:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Saiga!
Dialogue: 0,0:19:13.78,0:19:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:19:14.93,0:19:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jimat baru.
Dialogue: 0,0:19:16.32,0:19:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah mengusir begitu banyak,\Ntapi kekuatannya tidak hilang.
Dialogue: 0,0:19:19.55,0:19:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jimat baru yang mengandung\Nkekuatan mengusir roh jahat.
Dialogue: 0,0:19:23.25,0:19:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hisui memang hebat!
Dialogue: 0,0:19:24.75,0:19:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu ada caranya.
Dialogue: 0,0:19:25.66,0:19:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat ingin bertemu dengannya.
Dialogue: 0,0:19:32.06,0:19:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya Zamrud.
Dialogue: 0,0:19:33.60,0:19:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Tuan itu?
Dialogue: 0,0:19:35.43,0:19:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki Minato…
Dialogue: 0,0:19:38.62,0:19:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat silau!
Dialogue: 0,0:19:40.53,0:19:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku tidak bisa melihat.
Dialogue: 0,0:19:43.28,0:19:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa melihat orangnya.
Dialogue: 0,0:19:46.91,0:19:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hisui, terima kasih banyak.
Dialogue: 0,0:19:49.98,0:19:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar dari tempat yang aneh.
Dialogue: 0,0:19:53.40,0:19:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:19:54.55,0:19:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima?
Dialogue: 0,0:19:56.55,0:19:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, semuanya wanita cantik.
Dialogue: 0,0:19:59.26,0:20:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima sebenarnya punya harem?
Dialogue: 0,0:20:02.10,0:20:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya saudara sedarah.
Dialogue: 0,0:20:03.81,0:20:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang menjerit-jerit\Nsambil meronta-ronta.
Dialogue: 0,0:20:06.64,0:20:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena benda yang kau pegang itu
Dialogue: 0,0:20:08.79,0:20:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengeluarkan cahaya terang\Nsehingga mereka tidak bisa melihat.
Dialogue: 0,0:20:12.61,0:20:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi.
Dialogue: 0,0:20:13.47,0:20:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:20:19.21,0:20:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi itu…
Dialogue: 0,0:20:24.07,0:20:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, seharusnya tidak mungkin.
Dialogue: 0,0:20:28.03,0:20:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah Kusunoki Minato?
Dialogue: 0,0:20:29.83,0:20:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak disangka dia begitu hebat.
Dialogue: 0,0:20:33.57,0:20:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya sekali.
Dialogue: 0,0:20:34.58,0:20:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat menyukai topi itu, 'kan?
Dialogue: 0,0:20:37.34,0:20:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:20:38.35,0:20:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pun ciri khas ayahku.
Dialogue: 0,0:20:42.38,0:20:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat ayahmu…
Dialogue: 0,0:20:45.73,0:20:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang pengusir roh.
Dialogue: 0,0:20:49.38,0:20:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:20:51.58,0:20:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ansho?
Dialogue: 0,0:20:53.50,0:20:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka ada di sini?
Dialogue: 0,0:20:59.03,0:21:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyam…
Dialogue: 0,0:21:01.57,0:21:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya, Tuan Dewa Gunung?
Dialogue: 0,0:21:04.71,0:21:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dengan Echigoya,\Nkekenyalan dan rasanya mantap.
Dialogue: 0,0:21:09.94,0:21:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:21:13.91,0:21:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kembali ke wujud semula.
Dialogue: 0,0:21:22.63,0:21:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:24.34,0:21:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:21:25.52,0:21:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh dewa yang tinggal di pedang.
Dialogue: 0,0:21:28.40,0:21:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membawanya kembali?
Dialogue: 0,0:21:30.23,0:21:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memasukkannya ke dalam wadah ini.
Dialogue: 0,0:21:32.69,0:21:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya dia bisa menjadi kerabatku.
Dialogue: 0,0:21:35.39,0:21:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:21:36.60,0:21:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tidak bergerak.\NApakah kurang semangat?
Dialogue: 0,0:21:39.88,0:21:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ingin istirahat,\Nmungkin akan pulih nanti.
Dialogue: 0,0:21:44.36,0:21:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:21:46.07,0:21:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:21:53.91,0:21:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pulih, ya.
Dialogue: 0,0:23:31.48,0:23:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 8.
Dialogue: 0,0:23:32.82,0:23:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunung Sebelah Punya Ikatan Sejak Dulu.
