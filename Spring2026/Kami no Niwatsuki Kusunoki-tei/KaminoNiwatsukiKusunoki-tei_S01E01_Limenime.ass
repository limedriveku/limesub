Dialogue: 0,0:22:10.27,0:22:12.90,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:23:37.34,0:23:40.10,tanda,,0000,0000,0000,,SELANJUTNYA: KUIL DI GUNUNG\NDAN POHON SUCI DI TAMAN
Dialogue: 0,0:00:16.67,0:00:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:00:29.80,0:00:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untukmu, Minato.
Dialogue: 0,0:00:34.27,0:00:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:00:59.19,0:01:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Camilannya hilang!
Dialogue: 0,0:01:13.69,0:01:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek.
Dialogue: 0,0:01:16.51,0:01:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau juga bisa melihatnya?
Dialogue: 0,0:01:20.29,0:01:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau hanya bisa\Nmelihat hal-hal baik.
Dialogue: 0,0:01:23.41,0:01:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa gadis itu?
Dialogue: 0,0:01:24.84,0:01:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu warashi.
Dialogue: 0,0:01:25.96,0:01:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepatnya Zashiki-warashi.
Dialogue: 0,0:01:28.38,0:01:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh sebelum aku lahir,
Dialogue: 0,0:01:30.48,0:01:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia sudah tinggal di rumah ini.
Dialogue: 0,0:01:32.60,0:01:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan marah kalau dia\Nmengambil camilanmu, ya.
Dialogue: 0,0:01:35.13,0:01:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya beberapa camilan,\Nberikan saja dengan ikhlas.
Dialogue: 0,0:01:38.25,0:01:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:38.98,0:01:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, dengar baik-baik.
Dialogue: 0,0:01:40.67,0:01:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa melihat apa\Nyang tak terlihat orang lain.
Dialogue: 0,0:01:44.27,0:01:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini pasti akan membantumu kelak.
Dialogue: 0,0:02:09.88,0:02:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ayo cepat!
Dialogue: 0,0:02:11.37,0:02:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:02:12.36,0:02:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tunggu!\N- Lambat sekali!
Dialogue: 0,0:02:23.91,0:02:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai!
Dialogue: 0,0:02:26.22,0:02:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai!
Dialogue: 0,0:02:28.79,0:02:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku akan segera ke sana.
Dialogue: 0,0:02:35.43,0:02:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia bukan penduduk setempat.
Dialogue: 0,0:02:38.28,0:02:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tuan Muda Harima, ayo!
Dialogue: 0,0:02:42.27,0:02:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil aku seperti itu.
Dialogue: 0,0:02:50.12,0:02:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini tempatnya?
Dialogue: 0,0:02:55.88,0:02:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:03:02.98,0:03:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok berkabut?
Dialogue: 0,0:03:11.05,0:03:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Listrik statis?
Dialogue: 0,0:03:12.80,0:03:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:13.88,0:03:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisannya memudar?
Dialogue: 0,0:03:53.25,0:03:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamannya besar sekali!
Dialogue: 0,0:03:56.39,0:03:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:03:58.00,0:04:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisinya sangat terbengkalai.
Dialogue: 0,0:04:00.47,0:04:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:04:05.97,0:04:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, sudah sampai?
Dialogue: 0,0:04:07.52,0:04:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau makan tepat waktu?
Dialogue: 0,0:04:10.34,0:04:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, aku sudah bukan anak kecil lagi.
Dialogue: 0,0:04:15.01,0:04:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong urus tempat itu mulai hari ini, ya.
Dialogue: 0,0:04:17.70,0:04:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh boleh tinggal\Nsendirian di sini?
Dialogue: 0,0:04:19.76,0:04:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kan sudah Ibu bilang.
Dialogue: 0,0:04:21.67,0:04:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah itu dibangun kerabat jauh ayahmu\Nuntuk menghabiskan masa tuanya.
Dialogue: 0,0:04:26.51,0:04:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia sudah meninggal.
Dialogue: 0,0:04:28.37,0:04:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, rumah itu sudah kosong\Nselama dua tahun.
Dialogue: 0,0:04:34.66,0:04:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taman di sini lebih besar\Ndari yang kubayangkan.
Dialogue: 0,0:04:37.09,0:04:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku tak sanggup\Nmengurusnya sendirian.
Dialogue: 0,0:04:39.38,0:04:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kan waktumu banyak.
Dialogue: 0,0:04:41.72,0:04:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong urus dengan baik, ya.
Dialogue: 0,0:04:45.19,0:04:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi rumahnya sebagus ini,
Dialogue: 0,0:04:46.87,0:04:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa tidak ada yang mau beli?
Dialogue: 0,0:04:48.86,0:04:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu juga tidak tahu.
Dialogue: 0,0:04:49.94,0:04:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada beberapa orang yang sempat melihatnya,
Dialogue: 0,0:04:51.71,0:04:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ujung-ujungnya tidak jadi beli.
Dialogue: 0,0:04:54.25,0:04:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu juga tidak tahu pasti alasannya.
Dialogue: 0,0:04:56.45,0:04:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan ini rumah bermasalah?
Dialogue: 0,0:05:05.16,0:05:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, selanjutnya.
Dialogue: 0,0:05:07.81,0:05:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tukang kebun datang besok…
Dialogue: 0,0:05:09.89,0:05:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:12.89,0:05:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunga?
Dialogue: 0,0:05:15.18,0:05:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang menaruhnya di sini?
Dialogue: 0,0:05:22.63,0:05:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak untuk hari ini.
Dialogue: 0,0:05:25.09,0:05:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamannya jadi seperti baru.
Dialogue: 0,0:05:27.06,0:05:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya selesai dengan mudah.
Dialogue: 0,0:05:31.07,0:05:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kau tanam sesuatu\Nsekalian di sana?
Dialogue: 0,0:05:34.69,0:05:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya terlalu kosong sekarang.
Dialogue: 0,0:05:36.82,0:05:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:05:38.70,0:05:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku hanya tinggal sementara di sini,
Dialogue: 0,0:05:42.15,0:05:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi rasanya kurang enak\Nkalau bertindak sembarangan.
Dialogue: 0,0:05:45.75,0:05:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:48.63,0:05:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:05:49.75,0:05:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bagian yang sakit?
Dialogue: 0,0:05:51.43,0:05:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini badanku terasa kurang sehat.
Dialogue: 0,0:06:00.32,0:06:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kertas catatanku…
Dialogue: 0,0:06:04.35,0:06:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:06:06.30,0:06:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ringan sekali.
Dialogue: 0,0:06:07.46,0:06:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:08.93,0:06:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tadi lenganku terasa sangat berat.
Dialogue: 0,0:06:12.16,0:06:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:06:15.52,0:06:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ringan sekali.
Dialogue: 0,0:06:17.70,0:06:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:19.24,0:06:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisannya hilang lagi?
Dialogue: 0,0:06:23.32,0:06:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang membawa mugwort ini?
Dialogue: 0,0:06:26.79,0:06:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:06:27.84,0:06:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan ditaruh di sana?
Dialogue: 0,0:06:30.21,0:06:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku ambil?
Dialogue: 0,0:06:41.19,0:06:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:44.08,0:06:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini arbei.
Dialogue: 0,0:07:04.51,0:07:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membalas budi.
Dialogue: 0,0:07:15.36,0:07:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sesajen, sebaiknya pilih\Nsake dan camilan Jepang.
Dialogue: 0,0:07:19.44,0:07:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau…
Dialogue: 0,0:07:36.88,0:07:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anjing?
Dialogue: 0,0:07:39.49,0:07:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:07:41.38,0:07:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anjingnya bicara?
Dialogue: 0,0:07:46.02,0:07:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan anjing.
Dialogue: 0,0:07:47.60,0:07:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah Dewa Gunung.
Dialogue: 0,0:07:49.49,0:07:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung?
Dialogue: 0,0:07:53.24,0:07:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa dari gunung sebelah.
Dialogue: 0,0:07:56.86,0:07:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa?
Dialogue: 0,0:08:00.27,0:08:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Tuan Dewa Gunung.
Dialogue: 0,0:08:02.95,0:08:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:04.70,0:08:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak terkejut sama sekali, ya.
Dialogue: 0,0:08:08.29,0:08:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:09.37,0:08:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa aku jadi merasa bersalah.
Dialogue: 0,0:08:11.33,0:08:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang aneh.
Dialogue: 0,0:08:13.61,0:08:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Dewa Gunung yang memberiku\Narbei dan barang-barang itu?
Dialogue: 0,0:08:17.58,0:08:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, itu sekadar hadiah dariku.
Dialogue: 0,0:08:20.83,0:08:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:23.14,0:08:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.\NKubelikan ini khusus untukmu.
Dialogue: 0,0:08:26.43,0:08:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai balasan atas kebaikanmu.
Dialogue: 0,0:08:32.77,0:08:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya?
Dialogue: 0,0:08:36.98,0:08:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak berminyak, tapi enak.
Dialogue: 0,0:08:41.54,0:08:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum sake untuk\Nmenghilangkan rasa berminyaknya?
Dialogue: 0,0:08:44.67,0:08:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanku belum sepenuhnya pulih.
Dialogue: 0,0:08:47.81,0:08:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, air putih saja.
Dialogue: 0,0:08:52.38,0:08:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:08:54.40,0:08:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini air yang kubeli.
Dialogue: 0,0:08:59.74,0:09:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya?
Dialogue: 0,0:09:01.71,0:09:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat enak.
Dialogue: 0,0:09:03.39,0:09:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kalah enak dari air pegununganku.
Dialogue: 0,0:09:06.96,0:09:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:09:08.65,0:09:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dirimu, aku bisa selamat.
Dialogue: 0,0:09:10.91,0:09:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:09:12.37,0:09:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat aku?
Dialogue: 0,0:09:14.42,0:09:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa mengusir makhluk jahat.
Dialogue: 0,0:09:17.35,0:09:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku masih lemah,
Dialogue: 0,0:09:19.42,0:09:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makhluk yang bersarang di sekitar sini,
Dialogue: 0,0:09:22.25,0:09:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya lenyap tanpa jejak.
Dialogue: 0,0:09:24.76,0:09:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh luar biasa.
Dialogue: 0,0:09:27.30,0:09:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:28.20,0:09:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisanmu bisa mengusir energi negatif.
Dialogue: 0,0:09:32.87,0:09:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisanku?
Dialogue: 0,0:09:34.79,0:09:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu sebabnya tulisannya hilang?
Dialogue: 0,0:09:37.25,0:09:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:09:38.97,0:09:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada barangku yang tertinggal.
Dialogue: 0,0:09:42.48,0:09:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah meninggalkan peralatan kerjaku.
Dialogue: 0,0:09:45.07,0:09:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sungguh memalukan.\N- Ini…
Dialogue: 0,0:09:47.71,0:09:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kucari dulu.
Dialogue: 0,0:09:50.21,0:09:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:09:51.63,0:09:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki, maaf sudah mengganggu.
Dialogue: 0,0:09:53.70,0:09:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, aku pamit.
Dialogue: 0,0:09:58.00,0:10:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kau yang bisa melihatku.
Dialogue: 0,0:10:04.70,0:10:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum lagi?
Dialogue: 0,0:10:06.49,0:10:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau.
Dialogue: 0,0:10:12.65,0:10:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:10:13.84,0:10:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:21.48,0:10:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini air soda.
Dialogue: 0,0:10:23.41,0:10:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lidahku kesemutan.
Dialogue: 0,0:10:26.68,0:10:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini juga lumayan enak.
Dialogue: 0,0:10:28.56,0:10:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:10:30.49,0:10:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa tulisanku\Nbisa punya kekuatan seperti itu?
Dialogue: 0,0:10:37.19,0:10:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:10:38.67,0:10:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pernah ada yang memuji tulisanmu?
Dialogue: 0,0:10:43.42,0:10:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau tanya begitu,\Nmemang pernah sekali.
Dialogue: 0,0:10:45.92,0:10:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kecil, ada tugas sekolah\Nmembuat papan nama.
Dialogue: 0,0:10:50.62,0:10:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah orang tuaku adalah penginapan onsen.
Dialogue: 0,0:10:53.40,0:10:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku mengukir nama penginapannya,
Dialogue: 0,0:10:54.70,0:10:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayahku memasangnya.
Dialogue: 0,0:10:56.68,0:10:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tulisanku waktu itu
Dialogue: 0,0:10:58.11,0:10:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauh lebih jelek daripada sekarang,
Dialogue: 0,0:10:59.44,0:11:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi suatu hari ada tamu yang aneh.
Dialogue: 0,0:11:04.28,0:11:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini luar biasa.
Dialogue: 0,0:11:05.69,0:11:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah ini kau yang buat?
Dialogue: 0,0:11:08.61,0:11:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:10.07,0:11:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan pernah dilepas.
Dialogue: 0,0:11:14.11,0:11:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusarankan kau buat satu lagi\Nuntuk dipasang di rumah.
Dialogue: 0,0:11:20.36,0:11:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu mau membayarku,
Dialogue: 0,0:11:22.58,0:11:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan minta dibuatkan juga.
Dialogue: 0,0:11:25.13,0:11:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm…
Dialogue: 0,0:11:26.29,0:11:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia orang yang bisa\Nmelihat hal gaib.
Dialogue: 0,0:11:28.88,0:11:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, aku jadi hobi\Nmembuat papan nama untuk rumah mereka.
Dialogue: 0,0:11:33.86,0:11:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga buat papan nama untuk rumah ini.
Dialogue: 0,0:11:41.86,0:11:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba pasang.
Dialogue: 0,0:11:47.55,0:11:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal pintu belakang.
Dialogue: 0,0:12:02.47,0:12:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:03.61,0:12:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu…
Dialogue: 0,0:12:05.15,0:12:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung.
Dialogue: 0,0:12:06.60,0:12:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelindungnya sudah terpasang.
Dialogue: 0,0:12:08.74,0:12:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu di rumah ini?
Dialogue: 0,0:12:10.10,0:12:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:11.07,0:12:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini, roh jahat\Ntak akan bisa mendekati rumah ini.
Dialogue: 0,0:12:15.37,0:12:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan nama itu sehebat itu?
Dialogue: 0,0:12:18.57,0:12:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanmu itu sangat langka.
Dialogue: 0,0:12:21.16,0:12:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau sadar dan melatihnya,
Dialogue: 0,0:12:22.83,0:12:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau pasti bisa mendapatkan\Nkekuatan yang jauh lebih besar.
Dialogue: 0,0:12:25.64,0:12:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya?
Dialogue: 0,0:12:29.12,0:12:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:12:30.53,0:12:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, selamat datang lagi hari ini.
Dialogue: 0,0:12:33.13,0:12:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, mau makan camilan?
Dialogue: 0,0:12:35.79,0:12:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau.
Dialogue: 0,0:12:43.01,0:12:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat suka camilan Jepang, ya.
Dialogue: 0,0:12:46.31,0:12:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:12:51.77,0:12:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Auramu terasa lebih kuat, ya?
Dialogue: 0,0:12:54.50,0:12:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini berkatmu.
Dialogue: 0,0:12:56.89,0:12:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara makan banyak, ya?
Dialogue: 0,0:12:58.81,0:13:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan karena itu.
Dialogue: 0,0:13:01.03,0:13:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karena ketulusanmu saat memberikannya.
Dialogue: 0,0:13:06.21,0:13:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, terima kasih\Nsudah sudi datang kemari.
Dialogue: 0,0:13:16.06,0:13:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang memancarkan aura sakral.
Dialogue: 0,0:13:18.71,0:13:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku ini Dewa Gunung.
Dialogue: 0,0:13:24.41,0:13:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung.
Dialogue: 0,0:13:25.60,0:13:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:26.83,0:13:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tolong kurangi cahayanya?
Dialogue: 0,0:13:29.07,0:13:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku silau...
Dialogue: 0,0:13:44.81,0:13:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua prajurit, maju ke depan!
Dialogue: 0,0:13:53.94,0:13:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:13:59.09,0:14:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, dia kabur!
Dialogue: 0,0:14:01.43,0:14:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kukejar.
Dialogue: 0,0:14:04.64,0:14:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harima!
Dialogue: 0,0:14:05.94,0:14:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di depan ada pusat perbelanjaan.
Dialogue: 0,0:14:07.72,0:14:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mengusirnya di sini!
Dialogue: 0,0:14:11.26,0:14:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuda itu…
Dialogue: 0,0:14:12.89,0:14:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:14:16.60,0:14:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:17.65,0:14:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh sekuat itu,\Nlangsung lenyap dalam sekejap...
Dialogue: 0,0:14:23.06,0:14:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:14:25.74,0:14:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghilang lagi.
Dialogue: 0,0:14:28.30,0:14:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku tulisan.
Dialogue: 0,0:14:29.83,0:14:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:14:31.09,0:14:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sengaja mencatat barang belanjaanku\Nagar tidak lupa.
Dialogue: 0,0:14:35.35,0:14:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, di situ dia!
Dialogue: 0,0:14:38.43,0:14:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa maksudmu.
Dialogue: 0,0:14:40.30,0:14:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat penting\Nuntuk kehidupan sehari-hari.
Dialogue: 0,0:14:42.21,0:14:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya digunakan secara rutin\Nsetiap minggu.
Dialogue: 0,0:14:44.44,0:14:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kantong sampah?
Dialogue: 0,0:14:45.75,0:14:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:14:47.59,0:14:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu tempat membeli\Nkantong sampah di sekitar sini?
Dialogue: 0,0:14:50.68,0:14:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di depan sana ada toko obat.
Dialogue: 0,0:14:53.61,0:14:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Syukurlah.
Dialogue: 0,0:14:56.59,0:14:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:14:59.88,0:15:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya pemuda itu?
Dialogue: 0,0:15:24.26,0:15:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Dewa Gunung?
Dialogue: 0,0:15:26.82,0:15:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau datang, ya...
Dialogue: 0,0:15:42.65,0:15:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali!
Dialogue: 0,0:15:43.91,0:15:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang membuat semua ini?
Dialogue: 0,0:15:45.94,0:15:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal kecil seperti ini sangat mudah.
Dialogue: 0,0:15:47.76,0:15:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah Dewa Gunung.
Dialogue: 0,0:15:49.76,0:15:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, kau bisa\Nmelakukan hal seperti ini juga?
Dialogue: 0,0:15:55.57,0:15:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jadi mengecil?
Dialogue: 0,0:15:57.97,0:16:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karena aku menggunakan kekuatan.
Dialogue: 0,0:16:00.12,0:16:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jadi imut sekali.
Dialogue: 0,0:16:02.83,0:16:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa, aku bisa segera kembali normal.
Dialogue: 0,0:16:10.31,0:16:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini Dewa Gunung\Ntak pernah datang.
Dialogue: 0,0:16:14.63,0:16:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia baik-baik saja?
Dialogue: 0,0:16:17.67,0:16:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung!
Dialogue: 0,0:16:23.60,0:16:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:16:26.24,0:16:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir.
Dialogue: 0,0:16:27.62,0:16:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:28.65,0:16:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung!
Dialogue: 0,0:16:32.55,0:16:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius, nih?
Dialogue: 0,0:16:35.53,0:16:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jadi lebih kecil lagi.
Dialogue: 0,0:16:37.76,0:16:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberapa banyak kekuatan yang kau pakai\Nsampai jadi begini?
Dialogue: 0,0:16:40.39,0:16:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:43.20,0:16:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa anak kecil juga?\NKau yang melahirkan mereka?
Dialogue: 0,0:16:46.97,0:16:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembar tiga pula.
Dialogue: 0,0:16:49.62,0:16:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Dewa Gunung itu om-om, 'kan?
Dialogue: 0,0:16:51.63,0:16:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memanggil om itu terlalu tidak sopan.
Dialogue: 0,0:16:53.96,0:16:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:54.58,0:16:56.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya panggil paman.
Dialogue: 0,0:16:56.60,0:16:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil aku Pak Tua.
Dialogue: 0,0:16:57.95,0:16:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:00.47,0:17:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka adalah cerpelai, kerabatku.
Dialogue: 0,0:17:03.66,0:17:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerabat?
Dialogue: 0,0:17:05.08,0:17:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka klona yang kuciptakan.
Dialogue: 0,0:17:07.81,0:17:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kau jadi sekecil ini?
Dialogue: 0,0:17:10.78,0:17:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:12.58,0:17:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Seri.
Dialogue: 0,0:17:14.69,0:17:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Torika.
Dialogue: 0,0:17:18.24,0:17:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Utsugi.
Dialogue: 0,0:17:20.19,0:17:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Minato, salam kenal.
Dialogue: 0,0:17:22.60,0:17:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya!
Dialogue: 0,0:17:23.49,0:17:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lapar?
Dialogue: 0,0:17:27.04,0:17:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harum sekali!
Dialogue: 0,0:17:29.61,0:17:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi, kau tidak sopan.
Dialogue: 0,0:17:32.26,0:17:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya kue madu. Mau coba?
Dialogue: 0,0:17:41.01,0:17:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:17:42.14,0:17:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelezatan yang baru pertama kali kurasakan!
Dialogue: 0,0:17:44.07,0:17:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seumur hidupku baru kali ini\Naku makan seenak ini.
Dialogue: 0,0:17:47.01,0:17:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kan kalian baru saja lahir.
Dialogue: 0,0:17:49.82,0:17:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka suka camilan Barat.
Dialogue: 0,0:17:52.09,0:17:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah sepuasnya.
Dialogue: 0,0:17:54.12,0:17:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:17:55.16,0:17:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:56.31,0:17:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kau yang terbaik.
Dialogue: 0,0:17:59.19,0:18:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja cukup.
Dialogue: 0,0:18:06.26,0:18:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kekenyangan sampai tertidur.
Dialogue: 0,0:18:09.22,0:18:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut sekali.
Dialogue: 0,0:18:13.56,0:18:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar sudah kembali normal.
Dialogue: 0,0:18:17.45,0:18:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada yang datang.
Dialogue: 0,0:18:22.56,0:18:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan tempat ini?
Dialogue: 0,0:18:24.31,0:18:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan aura yang sangat kuat.
Dialogue: 0,0:18:27.05,0:18:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan ini kawasan suci?
Dialogue: 0,0:18:31.80,0:18:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang waktu itu…
Dialogue: 0,0:18:33.82,0:18:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:18:35.25,0:18:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku masuk?
Dialogue: 0,0:18:38.64,0:18:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onmyoji?
Dialogue: 0,0:18:40.59,0:18:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu sering muncul\Ndi novel fantasi...
Dialogue: 0,0:18:43.79,0:18:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dari instansi pemerintah.\NNamaku Harima Saiga.
Dialogue: 0,0:18:47.36,0:18:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kusunoki Minato.
Dialogue: 0,0:18:49.22,0:18:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa hari lalu, kau yang memakai\Nkekuatan untuk mengusir roh jahat, 'kan?
Dialogue: 0,0:18:53.23,0:18:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:18:58.84,0:19:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan yang waktu itu?
Dialogue: 0,0:19:01.00,0:19:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini terlalu banyak\Nroh jahat yang sulit diatasi,
Dialogue: 0,0:19:03.87,0:19:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kami kekurangan onmyoji.
Dialogue: 0,0:19:06.48,0:19:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengusir roh jahat yang tersisa\Nsedikit juga jadi alasan.
Dialogue: 0,0:19:09.56,0:19:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:11.25,0:19:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kau jual jimatmu padaku?
Dialogue: 0,0:19:14.13,0:19:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jimat?
Dialogue: 0,0:19:15.48,0:19:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia menginginkan\Nkertas tulisanmu.
Dialogue: 0,0:19:19.18,0:19:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:22.77,0:19:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini?
Dialogue: 0,0:19:23.97,0:19:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:19:27.80,0:19:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga tak bisa melihatku.
Dialogue: 0,0:19:32.32,0:19:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya daftar belanja biasa.
Dialogue: 0,0:19:35.18,0:19:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daftar belanja?
Dialogue: 0,0:19:36.66,0:19:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kertas yang tampaknya\Ntidak berharga sepeser pun...
Dialogue: 0,0:19:39.60,0:19:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat yang tak bisa diusir\Noleh tiga onmyoji sekalipun,
Dialogue: 0,0:19:42.65,0:19:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah diusir oleh orang awam\Ndengan selembar daftar belanja?
Dialogue: 0,0:19:46.18,0:19:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kau mau,\Nbiar kutulis beberapa untukmu.
Dialogue: 0,0:19:49.32,0:19:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian aku tulis yang banyak.
Dialogue: 0,0:19:52.03,0:19:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkan.
Dialogue: 0,0:19:53.50,0:19:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan dia tulis?
Dialogue: 0,0:19:55.52,0:19:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai, ya.
Dialogue: 0,0:19:56.89,0:20:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantou gula merah, mantou kastanye,\Nronde millet, ronde mugwort, kue sakura…
Dialogue: 0,0:20:00.61,0:20:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak apa?
Dialogue: 0,0:20:08.17,0:20:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya ini…
Dialogue: 0,0:20:10.07,0:20:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daftar camilan biasa...
Dialogue: 0,0:20:11.93,0:20:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa-bisanya punya kekuatan seperti ini!
Dialogue: 0,0:20:13.70,0:20:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:20:15.24,0:20:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, badanku lelah sekali.
Dialogue: 0,0:20:18.04,0:20:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena menggunakan kekuatan.
Dialogue: 0,0:20:21.78,0:20:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:20:23.12,0:20:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sanggup segini.
Dialogue: 0,0:20:24.82,0:20:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah cukup.
Dialogue: 0,0:20:26.80,0:20:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong terimalah ini.
Dialogue: 0,0:20:28.57,0:20:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa terima uang sebanyak ini!
Dialogue: 0,0:20:30.14,0:20:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kertasnya saja hanya kubeli\Ndi toko 100 yen.
Dialogue: 0,0:20:32.49,0:20:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini sangat berharga.
Dialogue: 0,0:20:34.07,0:20:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang segini saja masih kurang.
Dialogue: 0,0:20:35.57,0:20:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya kubayar nanti.
Dialogue: 0,0:20:37.47,0:20:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh tak bisa menerimanya.
Dialogue: 0,0:20:38.97,0:20:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima saja.
Dialogue: 0,0:20:39.84,0:20:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kan sudah kubilang,\Naku tak bisa menerimanya.
Dialogue: 0,0:20:41.91,0:20:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima saja, jangan sungkan.
Dialogue: 0,0:20:44.45,0:20:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau terima saja.\N- Ambillah.
Dialogue: 0,0:20:45.76,0:20:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau tak diterima, dia tak akan pergi.\N- Aku tak bisa.
Dialogue: 0,0:20:51.36,0:20:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kuterima.
Dialogue: 0,0:20:55.07,0:20:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:20:57.72,0:21:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih merasa agak sungkan.
Dialogue: 0,0:21:00.04,0:21:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa ulurkan tanganmu?
Dialogue: 0,0:21:09.40,0:21:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bahas onmyoji,\Npasti ingat simbol pentagram, 'kan?
Dialogue: 0,0:21:12.37,0:21:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini bisa memberi sedikit efek.
Dialogue: 0,0:21:18.52,0:21:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku jawab telepon dulu.
Dialogue: 0,0:21:21.40,0:21:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, dengan Harima.
Dialogue: 0,0:21:22.92,0:21:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:21:23.47,0:21:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima, mohon segera\Ndatang untuk membantu.
Dialogue: 0,0:21:33.30,0:21:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Katsuragi! Horikawa!
Dialogue: 0,0:21:36.19,0:21:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gegabah!
Dialogue: 0,0:21:37.48,0:21:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun itu kau, makhluk sebesar ini\Ntakkan bisa diusir sendirian.
Dialogue: 0,0:21:45.73,0:21:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:21:48.01,0:21:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:23:31.94,0:23:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 2.
Dialogue: 0,0:23:33.72,0:23:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuil di Gunung dan Pohon Suci di Taman.
