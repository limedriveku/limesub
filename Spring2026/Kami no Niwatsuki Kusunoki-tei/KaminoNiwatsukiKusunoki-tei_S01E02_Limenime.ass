Dialogue: 0,0:00:51.53,0:00:57.03,tanda,,0000,0000,0000,,"CATATAN KEUANGAN"
Dialogue: 0,0:01:23.81,0:01:26.40,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:02:43.02,0:02:47.97,tanda,,0000,0000,0000,,KUIL DI GUNUNG DAN POHON SUCI DI TAMAN
Dialogue: 0,0:02:48.46,0:02:51.82,tanda,,0000,0000,0000,,KAFE HOJO
Dialogue: 0,0:02:54.72,0:02:55.06,tanda,,0000,0000,0000,,CARI PEKERJA PARUH WAKTU, TERIMA SISWA SMA
Dialogue: 0,0:02:55.06,0:02:56.83,tanda,,0000,0000,0000,,"CARI PEKERJA PARUH WAKTU, TERIMA SISWA SMA"
Dialogue: 0,0:02:56.83,0:03:02.59,tanda,,0000,0000,0000,,"USIA DI ATAS 18 TAHUN, SEMUA JENIS KELAMIN"
Dialogue: 0,0:03:08.09,0:03:10.13,tanda,,0000,0000,0000,,"JALAN PERBELANJAAN HOJOCHO, LOKASI UNDIAN"
Dialogue: 0,0:03:10.72,0:03:13.00,tanda,,0000,0000,0000,,"MENJUAL BUAH DAN SAYURAN"
Dialogue: 0,0:03:17.56,0:03:19.37,tanda,,0000,0000,0000,,"TIKET UNDIAN"
Dialogue: 0,0:03:32.11,0:03:33.92,tanda,,0000,0000,0000,,"HADIAH UANG 100.000 YEN"
Dialogue: 0,0:03:40.78,0:03:42.18,tanda,,0000,0000,0000,,TOKO SAKE TAMBA
Dialogue: 0,0:03:50.87,0:03:54.00,tanda,,0000,0000,0000,,"ULANG TAHUN KE-333"
Dialogue: 0,0:04:06.51,0:04:11.79,tanda,,0000,0000,0000,,"HADIAH UANG TUNAI 100.000 YEN"
Dialogue: 0,0:04:28.44,0:04:31.75,tanda,,0000,0000,0000,,"REIKI"
Dialogue: 0,0:05:10.50,0:05:10.94,tanda,,0000,0000,0000,,IBU MENELEPON
Dialogue: 0,0:05:16.77,0:05:25.77,tanda,,0000,0000,0000,,"TAMAN ONSEN"
Dialogue: 0,0:07:30.08,0:07:31.61,tanda,,0000,0000,0000,,"RAIJIN, FUJIN"
Dialogue: 0,0:08:34.08,0:08:36.48,tanda,,0000,0000,0000,,JUNMAI DAIGINJO, KORA, SAKE, KAME
Dialogue: 0,0:11:28.01,0:11:33.93,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:18:18.09,0:18:19.54,tanda,,0000,0000,0000,,ORYU
Dialogue: 0,0:19:10.11,0:19:12.03,tanda,,0000,0000,0000,,SAKE, KAME, ANGGUR
Dialogue: 0,0:20:00.78,0:20:03.92,tanda,,0000,0000,0000,,"MIZU YOKAN"
Dialogue: 0,0:20:33.78,0:20:35.98,tanda,,0000,0000,0000,,"SPIDOL"
Dialogue: 0,0:21:38.44,0:21:40.71,tanda,,0000,0000,0000,,"TOKO DAGING USHIYAMA"
Dialogue: 0,0:21:40.71,0:21:41.95,tanda,,0000,0000,0000,,TOKO DAGING USHIYAMA
Dialogue: 0,0:23:37.03,0:23:39.03,tanda,,0000,0000,0000,,"BERIKUTNYA: KEKUATAN ANGIN,\NBERKULTIVASILAH DI KAWASAN SUCI"
Dialogue: 0,0:00:07.00,0:00:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada uang lagi.
Dialogue: 0,0:00:09.47,0:00:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Tuan Harima baru saja\Nmembeli daftar belanjaan dariku...
Dialogue: 0,0:00:15.40,0:00:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi uang itu sudah habis.
Dialogue: 0,0:00:18.41,0:00:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena...
Dialogue: 0,0:00:19.54,0:00:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak sekali!
Dialogue: 0,0:00:21.54,0:00:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krimnya sangat kental,\Nkualitas premium.
Dialogue: 0,0:00:24.64,0:00:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, terima kasih.
Dialogue: 0,0:00:26.15,0:00:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini pasti mahal, 'kan?
Dialogue: 0,0:00:28.22,0:00:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:00:30.09,0:00:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kalian mencoba makanan enak.
Dialogue: 0,0:00:32.47,0:00:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Kalau begitu...
Dialogue: 0,0:00:34.72,0:00:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau makan satu lagi.
Dialogue: 0,0:00:36.46,0:00:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi, kau sudah makan terlalu banyak.
Dialogue: 0,0:00:41.09,0:00:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kintsuba dari Chikugendo memang beda\Nkarena sudah berdiri lebih dari 200 tahun.
Dialogue: 0,0:00:46.96,0:00:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar meleleh di mulut.
Dialogue: 0,0:00:51.53,0:00:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung dan yang lain tidak kenal sungkan.
Dialogue: 0,0:00:54.52,0:00:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku membeli barang murah...
Dialogue: 0,0:00:58.83,0:01:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasana hati mereka langsung merosot.
Dialogue: 0,0:02:55.06,0:02:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja paruh waktu, ya?
Dialogue: 0,0:02:56.83,0:02:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini bisa menutupi biaya camilan?
Dialogue: 0,0:02:59.64,0:03:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, gaji kerja paruh waktu terkenal sedikit.
Dialogue: 0,0:03:03.25,0:03:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya harus menurunkan\Nkualitas camilan.
Dialogue: 0,0:03:05.97,0:03:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:03:07.46,0:03:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:08.09,0:03:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi undian ada di sini.
Dialogue: 0,0:03:10.72,0:03:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini adalah loket layanan.
Dialogue: 0,0:03:13.45,0:03:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu tiket undian untuk sekali memutar.
Dialogue: 0,0:03:17.56,0:03:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik. Satu, ya?
Dialogue: 0,0:03:24.60,0:03:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, dapat hadiah utama.
Dialogue: 0,0:03:29.35,0:03:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah utama?
Dialogue: 0,0:03:30.43,0:03:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiahnya.
Dialogue: 0,0:03:32.11,0:03:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Voucher senilai 100.000 yen.
Dialogue: 0,0:03:33.92,0:03:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:35.56,0:03:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seratus ribu?
Dialogue: 0,0:03:38.68,0:03:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dengan ini...
Dialogue: 0,0:03:43.24,0:03:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beli sake untuk Tuan Dewa Gunung.
Dialogue: 0,0:03:46.03,0:03:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat!
Dialogue: 0,0:03:48.38,0:03:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:49.26,0:03:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini adalah hari peringatan ke-333
Dialogue: 0,0:03:50.87,0:03:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko Sake Tamba.
Dialogue: 0,0:03:54.00,0:03:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepada pelanggan ke-333, kami akan berikan
Dialogue: 0,0:03:56.65,0:03:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}paket sake premium.
Dialogue: 0,0:04:00.67,0:04:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti kebetulan.
Dialogue: 0,0:04:03.84,0:04:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada yang salah!
Dialogue: 0,0:04:06.51,0:04:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, aku menang terus.
Dialogue: 0,0:04:09.38,0:04:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka bisa seberuntung ini.
Dialogue: 0,0:04:12.12,0:04:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini perbuatanmu, Tuan Dewa Gunung?
Dialogue: 0,0:04:15.06,0:04:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan kekuatanku.
Dialogue: 0,0:04:17.52,0:04:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa...
Dialogue: 0,0:04:19.52,0:04:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kekuatan dia.
Dialogue: 0,0:04:21.41,0:04:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:22.78,0:04:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kura-kura?
Dialogue: 0,0:04:26.28,0:04:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kura-kura yang memiliki kekuatan ajaib.
Dialogue: 0,0:04:28.44,0:04:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reiki.
Dialogue: 0,0:04:29.88,0:04:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:04:32.09,0:04:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat makhluk suci pembawa keberuntungan\Ndisebut "Shirei".
Dialogue: 0,0:04:36.62,0:04:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia salah satunya.
Dialogue: 0,0:04:38.51,0:04:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan dia muncul?
Dialogue: 0,0:04:40.23,0:04:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dulu kau pernah membantunya.
Dialogue: 0,0:04:42.86,0:04:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:43.42,0:04:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:04:47.47,0:04:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:04:50.03,0:04:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak ingat.\NApa mungkin salah orang?
Dialogue: 0,0:04:53.21,0:04:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau mengusir roh jahat\Ndi jalanan sebelumnya.
Dialogue: 0,0:04:57.86,0:04:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:59.40,0:05:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu?
Dialogue: 0,0:05:02.44,0:05:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keberuntunganmu berasal dari\Nkekuatan Reiki.
Dialogue: 0,0:05:06.09,0:05:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar? Mana mungkin?
Dialogue: 0,0:05:10.94,0:05:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:05:11.98,0:05:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, ada apa?
Dialogue: 0,0:05:13.14,0:05:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanya ada apa, kau membuat Ibu kaget!
Dialogue: 0,0:05:16.23,0:05:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:16.77,0:05:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pernah ikut undian sebelum ke sana, 'kan?
Dialogue: 0,0:05:20.57,0:05:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undian?
Dialogue: 0,0:05:21.54,0:05:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu.
Dialogue: 0,0:05:22.74,0:05:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menang, hadiahnya satu juta yen.
Dialogue: 0,0:05:25.78,0:05:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu juta yen?
Dialogue: 0,0:05:27.96,0:05:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kau sudah percaya?
Dialogue: 0,0:05:32.35,0:05:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:05:34.12,0:05:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kame, terima kasih.
Dialogue: 0,0:05:36.97,0:05:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:05:38.99,0:05:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Reiki ingin\Ntinggal di kolam itu.
Dialogue: 0,0:05:41.73,0:05:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:43.29,0:05:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, Anda tidak keberatan?
Dialogue: 0,0:05:45.25,0:05:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tamanmu.
Dialogue: 0,0:05:47.35,0:05:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau putuskan sendiri saja.
Dialogue: 0,0:05:49.84,0:05:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak masalah.
Dialogue: 0,0:05:51.79,0:05:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya begitu.
Dialogue: 0,0:05:53.14,0:05:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:06:02.03,0:06:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kame.
Dialogue: 0,0:06:04.16,0:06:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum sake?
Dialogue: 0,0:06:15.95,0:06:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kame suka sake, ya?
Dialogue: 0,0:06:18.74,0:06:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kuat minum.
Dialogue: 0,0:06:20.76,0:06:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan minum sepuasnya.
Dialogue: 0,0:06:24.42,0:06:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:29.46,0:06:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:06:31.64,0:06:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benih?
Dialogue: 0,0:06:32.90,0:06:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hadiah dari Reiki.
Dialogue: 0,0:06:35.49,0:06:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah dari Tuan Kame?
Dialogue: 0,0:06:40.14,0:06:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutanam di taman ini saja.
Dialogue: 0,0:06:42.34,0:06:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu akan tumbuh sangat besar.
Dialogue: 0,0:06:45.37,0:06:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Tuan Dewa Gunung,\Nsilakan tentukan tempatnya.
Dialogue: 0,0:06:51.13,0:06:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanam di sini seharusnya tidak masalah.
Dialogue: 0,0:06:53.37,0:06:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ini benih apa?
Dialogue: 0,0:06:56.26,0:06:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya kau tanya itu\Nsebelum tanam, 'kan?
Dialogue: 0,0:06:59.45,0:07:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:07:00.99,0:07:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan tahu suatu hari nanti.
Dialogue: 0,0:07:02.81,0:07:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nantikan saja ia tumbuh besar.
Dialogue: 0,0:07:08.60,0:07:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kue kering ini enak sekali.
Dialogue: 0,0:07:11.58,0:07:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, mau tambah kue kering?
Dialogue: 0,0:07:14.46,0:07:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kelihatannya enak.
Dialogue: 0,0:07:16.64,0:07:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:17.62,0:07:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah kami mencobanya?
Dialogue: 0,0:07:20.61,0:07:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu kaget begitu.
Dialogue: 0,0:07:22.49,0:07:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat tidak sopan.
Dialogue: 0,0:07:23.96,0:07:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa, Fujin, Raijin.
Dialogue: 0,0:07:27.99,0:07:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, lama tidak berjumpa.
Dialogue: 0,0:07:30.08,0:07:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu.
Dialogue: 0,0:07:32.20,0:07:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujin dan Raijin itu yang terkenal...
Dialogue: 0,0:07:35.50,0:07:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:37.02,0:07:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia digambarkan dalam buku-buku\Ndan layar sekat sejak zaman dulu.
Dialogue: 0,0:07:41.48,0:07:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan imut.
Dialogue: 0,0:07:43.99,0:07:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak keberatan, silakan dinikmati.
Dialogue: 0,0:07:47.65,0:07:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:07:49.25,0:07:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, kau masih bertahan hidup, ya.
Dialogue: 0,0:07:53.39,0:07:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sebelumnya sangat lemah.
Dialogue: 0,0:07:55.17,0:07:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kau sudah mati.
Dialogue: 0,0:07:57.60,0:08:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ngawur!\NAku tidak akan mati semudah itu!
Dialogue: 0,0:08:02.11,0:08:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kue kering kami.
Dialogue: 0,0:08:04.15,0:08:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara kaku seperti itu.
Dialogue: 0,0:08:06.23,0:08:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kerabat yang terkenal itu?
Dialogue: 0,0:08:08.59,0:08:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:08:09.92,0:08:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian datang untuk apa?
Dialogue: 0,0:08:11.69,0:08:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa.
Dialogue: 0,0:08:12.90,0:08:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kabar angin yang mengatakan\Ntempat ini jadi lebih nyaman ditinggali,
Dialogue: 0,0:08:16.41,0:08:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku mampir.
Dialogue: 0,0:08:17.85,0:08:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang di sini jadi lebih nyaman.
Dialogue: 0,0:08:25.59,0:08:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang minum minuman enak, ya.
Dialogue: 0,0:08:27.67,0:08:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum?
Dialogue: 0,0:08:29.11,0:08:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan langka, terima saja.
Dialogue: 0,0:08:31.41,0:08:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, mari minum.
Dialogue: 0,0:08:38.30,0:08:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyang sekali minumnya.
Dialogue: 0,0:08:40.32,0:08:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, hanya hidangan sederhana.
Dialogue: 0,0:08:42.87,0:08:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:08:44.60,0:08:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai balasan, aku pinjamkan\Nsedikit kekuatan padamu.
Dialogue: 0,0:08:49.99,0:08:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:57.53,0:08:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu...
Dialogue: 0,0:08:59.19,0:09:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kau lihat,\Nitu kekuatan angin.
Dialogue: 0,0:09:02.19,0:09:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara menggunakannya?
Dialogue: 0,0:09:06.68,0:09:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayangkan dirimu mengembuskan angin.
Dialogue: 0,0:09:10.50,0:09:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayangkan?
Dialogue: 0,0:09:12.75,0:09:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehm... Mengembuskan angin...
Dialogue: 0,0:09:21.14,0:09:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kau hebat sekali!
Dialogue: 0,0:09:24.79,0:09:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar muncul angin.
Dialogue: 0,0:09:27.09,0:09:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi masih sebatas angin sepoi-sepoi.
Dialogue: 0,0:09:31.16,0:09:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus lebih ditingkatkan lagi.
Dialogue: 0,0:09:33.38,0:09:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini bisa berguna saat\Nmenyapu daun-daun jatuh?
Dialogue: 0,0:09:37.35,0:09:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang tahu...
Dialogue: 0,0:09:59.39,0:10:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan hampir hilang?
Dialogue: 0,0:10:02.32,0:10:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka Kusunoki Minato\Npunya kekuatan sehebat itu.
Dialogue: 0,0:10:07.48,0:10:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ichijo!
Dialogue: 0,0:10:11.95,0:10:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat!
Dialogue: 0,0:10:13.76,0:10:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Seishiro.
Dialogue: 0,0:10:14.84,0:10:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau, cepat selamatkan aku!
Dialogue: 0,0:10:17.28,0:10:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau rekan kerjaku, 'kan, wanita sialan?
Dialogue: 0,0:10:27.70,0:10:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:10:29.47,0:10:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik-baik saja, terima kasih.
Dialogue: 0,0:10:36.56,0:10:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi tadi?
Dialogue: 0,0:10:38.41,0:10:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget sekali.
Dialogue: 0,0:10:40.35,0:10:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau bicarakan?
Dialogue: 0,0:10:41.65,0:10:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikawa.
Dialogue: 0,0:10:43.34,0:10:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf untuk yang tadi.
Dialogue: 0,0:10:45.94,0:10:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau sudah tahu
Dialogue: 0,0:10:48.32,0:10:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}asal daftar belanja yang\Ndigunakan si Harima?
Dialogue: 0,0:10:52.69,0:10:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.
Dialogue: 0,0:10:54.91,0:10:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya tahu itu dia dapatkan\Ndari seseorang baru-baru ini,
Dialogue: 0,0:10:58.64,0:11:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak tahu detailnya.
Dialogue: 0,0:11:01.15,0:11:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh, kau benar-benar\Ntidak berguna.
Dialogue: 0,0:11:04.83,0:11:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:11:06.96,0:11:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:08.07,0:11:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menganggap Tuan Harima\Nsebagai musuh?
Dialogue: 0,0:11:11.42,0:11:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah karena dia lebih unggul?
Dialogue: 0,0:11:13.93,0:11:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau...
Dialogue: 0,0:11:18.52,0:11:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:11:20.30,0:11:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:11:22.21,0:11:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harima, aku tidak akan kalah darimu.
Dialogue: 0,0:11:39.41,0:11:41.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya hujan sudah reda, ya.
Dialogue: 0,0:11:41.83,0:11:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hubungannya dengan taman ini.
Dialogue: 0,0:11:44.10,0:11:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini kawasan suci.
Dialogue: 0,0:11:46.50,0:11:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak terpengaruh hujan, hebat sekali.
Dialogue: 0,0:11:52.90,0:11:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benih yang ditanam waktu itu?
Dialogue: 0,0:11:56.32,0:11:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:57.85,0:12:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sampai kemarin\Nmasih belum berkecambah.
Dialogue: 0,0:12:00.68,0:12:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pohon suci di kediaman Kusunoki ini.
Dialogue: 0,0:12:03.34,0:12:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki.
Dialogue: 0,0:12:05.26,0:12:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pohon suci?
Dialogue: 0,0:12:08.40,0:12:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah nutrisinya cukup atau tidak.
Dialogue: 0,0:12:11.16,0:12:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya siram dulu saja.
Dialogue: 0,0:12:17.75,0:12:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, bagaimana rasanya?
Dialogue: 0,0:12:20.56,0:12:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu makanan khas kampungku, onsen manju.
Dialogue: 0,0:12:24.64,0:12:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin ketagihan.
Dialogue: 0,0:12:26.21,0:12:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga minta Ibu\Nmengirim banyak barang kemari.
Dialogue: 0,0:12:32.00,0:12:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau mendaki gunung?
Dialogue: 0,0:12:34.28,0:12:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku ingin mendaki gunung Anda.
Dialogue: 0,0:12:38.28,0:12:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Gunung Hojo?
Dialogue: 0,0:12:40.44,0:12:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:41.54,0:12:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Anda Dewa Gunung?
Dialogue: 0,0:12:44.15,0:12:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku ingin pergi berdoa ke gunung itu.
Dialogue: 0,0:12:47.14,0:12:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan akhir-akhir ini\Naku juga kurang olahraga.
Dialogue: 0,0:12:49.24,0:12:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunungku bukan tempat yang bisa didaki\Ndengan santai hanya demi bersenang-senang.
Dialogue: 0,0:12:54.16,0:12:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, makanya aku\Nmenyiapkan perlengkapan ini.
Dialogue: 0,0:12:57.94,0:13:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekitar lereng gunung ada sebuah kuil.
Dialogue: 0,0:13:00.63,0:13:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya sampai di sekitar sana,\Nseharusnya tidak menguras banyak tenaga.
Dialogue: 0,0:13:05.03,0:13:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan mendaki\Nsampai di sana saja.
Dialogue: 0,0:13:07.63,0:13:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun dulu sering dikunjungi orang,
Dialogue: 0,0:13:10.94,0:13:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang sudah benar-benar terbengkalai.
Dialogue: 0,0:13:13.71,0:13:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya.
Dialogue: 0,0:13:15.67,0:13:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan kerabat-kerabatku yang menuntunmu.
Dialogue: 0,0:13:27.19,0:13:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih melelahkan daripada\Nyang dibayangkan.
Dialogue: 0,0:13:29.93,0:13:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, hati-hati saat melangkah.
Dialogue: 0,0:13:33.30,0:13:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:13:36.26,0:13:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, semangat!
Dialogue: 0,0:13:38.83,0:13:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah katanya kalau hanya sampai kuil,\Ntidak menguras banyak tenaga?
Dialogue: 0,0:13:43.28,0:13:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi, cepat turun!
Dialogue: 0,0:13:46.06,0:13:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menambah beban Minato.
Dialogue: 0,0:13:48.67,0:13:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:13:50.37,0:13:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, lagi pula\Ntidak terlalu berat.
Dialogue: 0,0:13:53.87,0:13:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, memanjakannya seperti itu.
Dialogue: 0,0:13:58.49,0:13:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, ya!
Dialogue: 0,0:13:59.79,0:14:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melewati sungai di depan,\Nsebentar lagi sampai.
Dialogue: 0,0:14:17.22,0:14:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah kuil Tuan Dewa Gunung?
Dialogue: 0,0:14:20.29,0:14:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu membersihkan kuilnya.
Dialogue: 0,0:14:22.23,0:14:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung tidak akan\Nmempermasalahkannya.
Dialogue: 0,0:14:24.41,0:14:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, karena Minato langsung\Nmenyembah Dewa Gunung.
Dialogue: 0,0:14:28.81,0:14:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, ayo kita makan camilan.
Dialogue: 0,0:14:31.61,0:14:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tetap tidak bisa membiarkannya.
Dialogue: 0,0:14:34.56,0:14:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu orang bisa terus\Nmempercayai Dewa Gunung,
Dialogue: 0,0:14:38.34,0:14:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berkat kuil ini, 'kan?
Dialogue: 0,0:14:42.10,0:14:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, ayo kita bantu juga.
Dialogue: 0,0:14:44.77,0:14:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:14:55.98,0:14:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bersih, ya.
Dialogue: 0,0:14:57.98,0:15:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimakan bersama, terasa lebih enak.
Dialogue: 0,0:15:00.26,0:15:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:15:01.75,0:15:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung juga pasti senang.
Dialogue: 0,0:15:05.98,0:15:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:08.16,0:15:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:09.98,0:15:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:15:11.43,0:15:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:15:19.37,0:15:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya.
Dialogue: 0,0:15:23.04,0:15:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:15:25.16,0:15:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabut hitam itu...
Dialogue: 0,0:15:27.42,0:15:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:15:28.74,0:15:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat.
Dialogue: 0,0:15:30.29,0:15:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat?
Dialogue: 0,0:15:31.78,0:15:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bergerak!
Dialogue: 0,0:15:32.80,0:15:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati!
Dialogue: 0,0:15:35.14,0:15:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato!
Dialogue: 0,0:15:36.33,0:15:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:15:39.62,0:15:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu yang dirasuki roh jahat.
Dialogue: 0,0:15:43.14,0:15:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kau tidak melihatnya?
Dialogue: 0,0:15:45.69,0:15:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi negatif yang menyelimuti area ini.
Dialogue: 0,0:15:48.24,0:15:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa melihat hal-hal baik.
Dialogue: 0,0:15:50.96,0:15:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bahkan yang seperti ini pun\Nbisa kulihat secara samar-samar,
Dialogue: 0,0:15:54.34,0:15:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti itu roh jahat yang sangat kuat.
Dialogue: 0,0:15:56.54,0:15:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena pengaruh energi negatif,
Dialogue: 0,0:15:58.15,0:16:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tidak bisa terus mendekat.
Dialogue: 0,0:16:00.80,0:16:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jijik sekali.
Dialogue: 0,0:16:03.81,0:16:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kau membawa kertas catatan?
Dialogue: 0,0:16:07.14,0:16:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:11.11,0:16:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:16:12.96,0:16:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:16:17.98,0:16:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, tidak bisa mendekatinya.
Dialogue: 0,0:16:20.52,0:16:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bagaimana?
Dialogue: 0,0:16:22.41,0:16:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya!
Dialogue: 0,0:16:31.71,0:16:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan angin.
Dialogue: 0,0:16:32.98,0:16:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:42.20,0:16:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:16:43.08,0:16:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:16:44.43,0:16:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak disangka kau bisa memanfaatkan\Nkekuatan dari Fujin.
Dialogue: 0,0:16:50.93,0:16:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu rusa?
Dialogue: 0,0:16:53.06,0:16:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bukan.
Dialogue: 0,0:16:59.20,0:17:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:17:07.55,0:17:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:17:08.78,0:17:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seketika sudah lari ke tempat itu.
Dialogue: 0,0:17:11.02,0:17:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, yang penting\Ndia kembali bersemangat.
Dialogue: 0,0:17:14.05,0:17:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dah!
Dialogue: 0,0:17:19.72,0:17:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membantuku\Nmembersihkan kuil.
Dialogue: 0,0:17:23.68,0:17:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, makhluk apa itu?
Dialogue: 0,0:17:27.49,0:17:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambat laun kau akan tahu.
Dialogue: 0,0:17:30.87,0:17:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh.
Dialogue: 0,0:17:31.91,0:17:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:33.62,0:17:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pohon Kusunoki sepertinya berhenti tumbuh.
Dialogue: 0,0:17:36.53,0:17:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena pohon Kusunoki ini\Nadalah pohon suci,
Dialogue: 0,0:17:39.83,0:17:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cara tumbuhnya berbeda dengan pohon biasa.
Dialogue: 0,0:17:42.94,0:17:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir.
Dialogue: 0,0:17:44.40,0:17:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah?
Dialogue: 0,0:17:47.47,0:17:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kame, ada apa?
Dialogue: 0,0:17:49.41,0:17:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:17:58.55,0:18:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang aku selamatkan di gunung...
Dialogue: 0,0:18:00.47,0:18:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, penampilannya benar-benar berbeda.
Dialogue: 0,0:18:07.78,0:18:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sopan sekali.
Dialogue: 0,0:18:10.94,0:18:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kame mengenalnya?
Dialogue: 0,0:18:13.08,0:18:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sama seperti Reiki, merupakan\Nsalah satu dari empat Shirei.
Dialogue: 0,0:18:16.77,0:18:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Oryu.
Dialogue: 0,0:18:19.84,0:18:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:22.53,0:18:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:35.97,0:18:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba muncul awan.
Dialogue: 0,0:18:42.75,0:18:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turun hujan di kawasan suci.
Dialogue: 0,0:19:02.31,0:19:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Oryu ingin\Ntinggal di kolam ini.
Dialogue: 0,0:19:05.21,0:19:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, kalau Tuan Kame tidak keberatan.
Dialogue: 0,0:19:08.08,0:19:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:19:15.84,0:19:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ryu suka anggur, ya.
Dialogue: 0,0:19:18.43,0:19:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertambah satu teman minum lagi,\NReiki juga senang.
Dialogue: 0,0:19:21.98,0:19:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oryu sangat berterima kasih padamu.
Dialogue: 0,0:19:25.10,0:19:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:19:26.22,0:19:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sebelumnya ada seorang onmyoji?
Dialogue: 0,0:19:28.60,0:19:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Tuan Harima?
Dialogue: 0,0:19:30.97,0:19:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya ketika Oryu\Nditelan oleh roh jahat,
Dialogue: 0,0:19:33.52,0:19:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang itulah yang membantu\Nmengusir roh jahat sehingga dia selamat.
Dialogue: 0,0:19:37.68,0:19:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu jasa Tuan Harima?
Dialogue: 0,0:19:41.97,0:19:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berkat pentagrammu.
Dialogue: 0,0:19:44.85,0:19:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga, untung kau selamat.
Dialogue: 0,0:19:54.07,0:19:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daftar belanjaan baru yang kau minta padaku...
Dialogue: 0,0:19:56.66,0:19:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, jimatnya di sini.
Dialogue: 0,0:19:59.26,0:20:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, selalu merepotkanmu.
Dialogue: 0,0:20:00.78,0:20:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:20:02.03,0:20:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, selalu menerima hadiahmu.
Dialogue: 0,0:20:09.47,0:20:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:10.50,0:20:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa.
Dialogue: 0,0:20:12.60,0:20:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana efek pentagramnya?
Dialogue: 0,0:20:15.26,0:20:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melebihi ekspektasi.
Dialogue: 0,0:20:17.14,0:20:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hari ini aku ingin kau menggambar\Npola kotak-kotak untukku.
Dialogue: 0,0:20:21.11,0:20:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:22.02,0:20:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benci bentuk bintang?
Dialogue: 0,0:20:24.30,0:20:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, karena itu bukan\Nlambang keluargaku.
Dialogue: 0,0:20:28.07,0:20:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata pentagram adalah\Nlambang keluarga?
Dialogue: 0,0:20:30.84,0:20:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak tahu.
Dialogue: 0,0:20:33.78,0:20:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau gambar berapa kotak?
Dialogue: 0,0:20:39.49,0:20:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisimu belakangan ini sangat bagus.
Dialogue: 0,0:20:42.74,0:20:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah semuanya berkat\NTuan Daftar Belanjaan yang hebat itu?
Dialogue: 0,0:20:46.56,0:20:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatannya sangat langka.
Dialogue: 0,0:20:49.23,0:20:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kertas catatan itu sulit digunakan, 'kan?
Dialogue: 0,0:20:53.40,0:20:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dilempar.
Dialogue: 0,0:20:55.01,0:20:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kali ini aku memintanya\Nmembuat kartu nama.
Dialogue: 0,0:20:59.91,0:21:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau melempar kartu nama?
Dialogue: 0,0:21:01.98,0:21:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memakai baju ketat, lalu bersama\Nkakak dan adik, bertiga.
Dialogue: 0,0:21:05.80,0:21:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus pakai baju ketat\Nuntuk melempar kartu nama?
Dialogue: 0,0:21:09.15,0:21:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak tahu? Inikah yang disebut\Nkesenjangan generasi?
Dialogue: 0,0:21:14.68,0:21:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar membuatku sedih.
Dialogue: 0,0:21:18.42,0:21:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Harima, kau harus\Nlebih berhati-hati.
Dialogue: 0,0:21:23.19,0:21:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika hal tentangnya diketahui orang lain,
Dialogue: 0,0:21:26.54,0:21:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membuat warga biasa\Nterlibat dalam bahaya.
Dialogue: 0,0:21:29.94,0:21:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sudah terlihat.
Dialogue: 0,0:21:32.68,0:21:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh Ichijo yang menganggapmu\Nsebagai musuhnya.
Dialogue: 0,0:21:38.44,0:21:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga tidak terjadi apa-apa.
Dialogue: 0,0:21:45.09,0:21:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:21:51.65,0:21:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu melotot seperti itu, 'kan?
Dialogue: 0,0:23:31.28,0:23:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 3.
Dialogue: 0,0:23:33.05,0:23:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Angin, Berkultivasilah di Kawasan Suci.
