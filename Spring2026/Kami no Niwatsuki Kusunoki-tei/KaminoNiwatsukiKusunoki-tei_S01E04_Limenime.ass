Dialogue: 0,0:01:53.86,0:01:56.50,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:03:12.97,0:03:17.86,tanda,,0000,0000,0000,,PERGI KE DUNIA LAIN UNTUK MENGUSIR ROH JAHAT,\NBERANGKAT SEKARANG
Dialogue: 0,0:05:09.52,0:05:10.95,tanda,,0000,0000,0000,,"RUMAH KUSUNOKI"
Dialogue: 0,0:08:23.04,0:08:24.95,tanda,,0000,0000,0000,,SASA DANGO
Dialogue: 0,0:08:53.77,0:08:56.71,tanda,,0000,0000,0000,,STASIUN SHINKANSEN
Dialogue: 0,0:09:12.55,0:09:13.83,tanda,,0000,0000,0000,,STASIUN TOKITODA
Dialogue: 0,0:12:07.97,0:12:13.92,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:12:22.78,0:12:23.93,tanda,,0000,0000,0000,,"KASHIWAMOCHI"
Dialogue: 0,0:16:29.76,0:16:34.75,tanda,,0000,0000,0000,,ENYAH, BERSIH, MURNI
Dialogue: 0,0:17:36.82,0:17:38.40,tanda,,0000,0000,0000,,"KUSUNOKI"
Dialogue: 0,0:21:40.77,0:21:42.45,tanda,,0000,0000,0000,,"HOO"
Dialogue: 0,0:23:36.36,0:23:39.13,tanda,,0000,0000,0000,,SELANJUTNYA: WILAYAH SANG DEWI\NDAN KEKUATAN SEGEL
Dialogue: 0,0:00:20.33,0:00:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:00:24.23,0:00:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau
Dialogue: 0,0:00:26.72,0:00:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah mulai menguasai kekuatan angin.
Dialogue: 0,0:00:30.62,0:00:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika dibandingkan dengan Tuan Fujin,\Naku masih belum ada apa-apanya.
Dialogue: 0,0:00:35.01,0:00:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kau sudah sangat hebat.
Dialogue: 0,0:00:38.30,0:00:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Fujin! Tuan Raijin!
Dialogue: 0,0:00:40.95,0:00:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil latihanmu terlihat sangat jelas.
Dialogue: 0,0:00:43.90,0:00:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua berkat bantuan kalian.
Dialogue: 0,0:00:45.69,0:00:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus berusaha.
Dialogue: 0,0:00:47.61,0:00:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap semangat!
Dialogue: 0,0:00:48.87,0:00:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini, nanti kau bisa santai
Dialogue: 0,0:00:50.89,0:00:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghancurkan rumah orang yang kau benci.
Dialogue: 0,0:00:53.83,0:00:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya sembarangan!
Dialogue: 0,0:00:55.95,0:00:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, aku juga akan\Nmeminjamkan kekuatanku.
Dialogue: 0,0:00:59.53,0:01:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kurasa tidak perlu.
Dialogue: 0,0:01:02.48,0:01:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, di mana para kerabatmu,\NTuan Dewa Gunung?
Dialogue: 0,0:01:05.51,0:01:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga sedang berlatih.
Dialogue: 0,0:01:09.61,0:01:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kita butuhkan hanyalah tekad.
Dialogue: 0,0:01:12.39,0:01:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kosongkan pikiran,\Nfokuslah pada diri sendiri.
Dialogue: 0,0:01:15.73,0:01:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus pada diri sendiri?
Dialogue: 0,0:01:17.92,0:01:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulailah bermeditasi.
Dialogue: 0,0:01:21.09,0:01:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap fokus.
Dialogue: 0,0:01:25.11,0:01:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menghadapi energi negatif\Nbersamamu di gunung tempo hari,
Dialogue: 0,0:01:28.26,0:01:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tak bisa berbuat apa-apa.
Dialogue: 0,0:01:30.34,0:01:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya hal itu membuat mereka kesal.
Dialogue: 0,0:01:33.88,0:01:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:01:35.35,0:01:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka gigih sekali, ya.
Dialogue: 0,0:01:37.35,0:01:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus...
Dialogue: 0,0:03:27.88,0:03:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati, Tuan Dewa Gunung.
Dialogue: 0,0:03:34.47,0:03:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan ubi bakar di taman seperti ini\Npunya nuansa tersendiri, bagus sekali.
Dialogue: 0,0:03:40.01,0:03:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:03:41.34,0:03:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya, Tuan Ryu?
Dialogue: 0,0:03:45.33,0:03:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya enak sekali.
Dialogue: 0,0:03:47.48,0:03:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:03:50.48,0:03:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:03:52.03,0:03:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kame lebih suka shochu ubi\Ndaripada ubi bakarnya.
Dialogue: 0,0:03:56.33,0:03:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Fujin, Tuan Raijin\Nsilakan dicicipi juga, jangan sungkan.
Dialogue: 0,0:03:59.62,0:04:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ubi bakar seperti ini\Nbisa kami buat kapan saja.
Dialogue: 0,0:04:03.56,0:04:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya?
Dialogue: 0,0:04:04.88,0:04:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutunjukkan.
Dialogue: 0,0:04:08.73,0:04:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai, ya.
Dialogue: 0,0:04:13.03,0:04:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah matang.
Dialogue: 0,0:04:15.06,0:04:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matang apanya? Ini jadi arang semua!
Dialogue: 0,0:04:17.64,0:04:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, perhitungan sekali.
Dialogue: 0,0:04:21.89,0:04:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:25.83,0:04:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kirin, sudah kembali\Nsetelah keliling dunia?
Dialogue: 0,0:04:31.27,0:04:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih selalu memberiku buah langka.
Dialogue: 0,0:04:34.90,0:04:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan ubi bakar bersama?
Dialogue: 0,0:04:39.17,0:04:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu, sesama manusia pun\Nbisa dijatuhi hukuman bakar.
Dialogue: 0,0:04:41.69,0:04:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kebiasaan manusia yang mengerikan.
Dialogue: 0,0:04:44.30,0:04:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan aku juga akan dibakar?
Dialogue: 0,0:04:49.08,0:04:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:04:50.94,0:04:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia masih belum\Nmembuka hatinya padaku.
Dialogue: 0,0:04:53.73,0:04:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirin sepertinya suka bir.
Dialogue: 0,0:04:56.49,0:04:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bir? Lain kali akan kusiapkan.
Dialogue: 0,0:05:02.05,0:05:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:05:05.41,0:05:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima?
Dialogue: 0,0:05:09.52,0:05:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima?
Dialogue: 0,0:05:10.95,0:05:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda baik-baik saja, Tuan Harima?
Dialogue: 0,0:05:20.93,0:05:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda terlihat sangat lelah.
Dialogue: 0,0:05:24.29,0:05:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:05:26.04,0:05:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dibandingkan soal itu,
Dialogue: 0,0:05:29.40,0:05:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa tekanannya terasa lebih berat\Ndari biasanya?
Dialogue: 0,0:05:32.47,0:05:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya? Itu hanya perasaanmu.
Dialogue: 0,0:05:35.73,0:05:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan itu, ada keperluan apa?
Dialogue: 0,0:05:38.75,0:05:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin meminta bantuanmu.
Dialogue: 0,0:05:41.78,0:05:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama aku bisa, silakan katakan.
Dialogue: 0,0:05:43.82,0:05:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada roh jahat yang tak bisa\Ndisingkirkan oleh onmyoji.
Dialogue: 0,0:05:47.83,0:05:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kau bersedia pergi ke sana\Nuntuk mengusirnya.
Dialogue: 0,0:05:52.16,0:05:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini ceritanya.
Dialogue: 0,0:05:53.73,0:05:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah boneka dibawa ke kuil\Nuntuk disucikan.
Dialogue: 0,0:05:58.55,0:06:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pengusir rohnya kebetulan meninggal.
Dialogue: 0,0:06:00.65,0:06:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang bisa menanganinya.
Dialogue: 0,0:06:02.99,0:06:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ditemukan,\Nboneka itu sudah menjadi roh jahat.
Dialogue: 0,0:06:07.43,0:06:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujud asli roh tersebut\Nseharusnya adalah dewa tertentu.
Dialogue: 0,0:06:12.25,0:06:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang gangguan spiritual di sana\Nsangat parah.
Dialogue: 0,0:06:14.14,0:06:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan onmyoji pun tak bisa mendekat.
Dialogue: 0,0:06:18.64,0:06:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa mencariku?
Dialogue: 0,0:06:21.07,0:06:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi kuil itu bukan di dunia ini,
Dialogue: 0,0:06:24.71,0:06:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melainkan di dunia lain yang khusus.
Dialogue: 0,0:06:26.80,0:06:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti tempat ini.
Dialogue: 0,0:06:28.79,0:06:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau bisa tinggal di sini,
Dialogue: 0,0:06:30.95,0:06:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diizinkan menetap...
Dialogue: 0,0:06:33.61,0:06:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kau bisa masuk ke dunia lain itu?
Dialogue: 0,0:06:35.95,0:06:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:37.38,0:06:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa melihat mereka, 'kan?
Dialogue: 0,0:06:39.56,0:06:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa dan hewan spiritual di rumah ini.
Dialogue: 0,0:06:45.52,0:06:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengharapkan kekuatanku?
Dialogue: 0,0:06:48.31,0:06:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia, jangan lancang!
Dialogue: 0,0:06:52.61,0:06:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung?
Dialogue: 0,0:06:54.14,0:06:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:59.42,0:07:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, Anda berlebihan.
Dialogue: 0,0:07:01.76,0:07:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat ketakutan.
Dialogue: 0,0:07:03.74,0:07:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan sekali.
Dialogue: 0,0:07:05.87,0:07:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian.
Dialogue: 0,0:07:12.38,0:07:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima, Anda baik-baik saja?
Dialogue: 0,0:07:16.46,0:07:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu...
Dialogue: 0,0:07:18.30,0:07:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dengan kekuatan Tuan Dewa Gunung,
Dialogue: 0,0:07:21.04,0:07:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa masuk ke dunia lain itu?
Dialogue: 0,0:07:23.22,0:07:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku kan Dewa Gunung.
Dialogue: 0,0:07:26.58,0:07:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bersedia membantu kita.
Dialogue: 0,0:07:28.66,0:07:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:07:30.26,0:07:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada satu syarat.
Dialogue: 0,0:07:32.79,0:07:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat?
Dialogue: 0,0:07:40.83,0:07:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana camilan pemberian Tuan Harima?
Dialogue: 0,0:07:45.27,0:07:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ankoro Mochi dari Toko Suruga Honpo\Nmemang tiada duanya.
Dialogue: 0,0:07:47.88,0:07:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:07:51.10,0:07:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya berangkat.
Dialogue: 0,0:07:53.11,0:07:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:07:54.16,0:07:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan ikut.
Dialogue: 0,0:07:55.91,0:07:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:07:56.54,0:07:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kami perlu kekuatanmu\Nuntuk memasuki dunia lain?
Dialogue: 0,0:07:59.70,0:08:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, jangan khawatir.
Dialogue: 0,0:08:02.68,0:08:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang akan menemanimu\Nsebagai pengganti Dewa Gunung.
Dialogue: 0,0:08:06.40,0:08:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian.
Dialogue: 0,0:08:07.40,0:08:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihannya sudah selesai?
Dialogue: 0,0:08:09.13,0:08:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:09.98,0:08:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah berbeda dari sebelumnya.
Dialogue: 0,0:08:12.45,0:08:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami yang membantumu.
Dialogue: 0,0:08:14.54,0:08:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu aku turun tangan sendiri.
Dialogue: 0,0:08:16.63,0:08:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai kerabatku, tunjukkanlah\Nhasil latihan kalian!
Dialogue: 0,0:08:19.57,0:08:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:20.70,0:08:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa diandalkan sekali.
Dialogue: 0,0:08:32.05,0:08:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tolong jaga rumah.
Dialogue: 0,0:08:34.49,0:08:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan tugas dengan baik.
Dialogue: 0,0:08:37.84,0:08:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat.
Dialogue: 0,0:08:39.26,0:08:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, tetap semangat!
Dialogue: 0,0:08:41.38,0:08:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berangkat!
Dialogue: 0,0:09:04.98,0:09:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sampai.
Dialogue: 0,0:09:08.70,0:09:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kulihat.
Dialogue: 0,0:09:10.69,0:09:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ke arah sana.
Dialogue: 0,0:09:18.69,0:09:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya benar di depan sini...
Dialogue: 0,0:09:23.53,0:09:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:25.41,0:09:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya?
Dialogue: 0,0:09:31.95,0:09:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pai apelnya sudah matang.
Dialogue: 0,0:09:34.58,0:09:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru saja diangkat dari oven.
Dialogue: 0,0:09:36.54,0:09:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato.
Dialogue: 0,0:09:42.64,0:09:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan!
Dialogue: 0,0:09:46.98,0:09:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apelnya sangat renyah.
Dialogue: 0,0:09:48.69,0:09:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekstur kulit painya juga mantap.
Dialogue: 0,0:09:52.35,0:09:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya benar-benar enak.
Dialogue: 0,0:09:54.71,0:09:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi, telan dulu baru bicara.
Dialogue: 0,0:09:57.80,0:09:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo selesaikan dengan cepat,
Dialogue: 0,0:09:59.23,0:10:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekalian beli oleh-oleh\Nuntuk dibawa pulang.
Dialogue: 0,0:10:01.24,0:10:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju!
Dialogue: 0,0:10:04.43,0:10:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:06.22,0:10:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung gagak itu...
Dialogue: 0,0:10:07.79,0:10:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia mau memandu kita.
Dialogue: 0,0:10:10.67,0:10:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita ikuti.
Dialogue: 0,0:10:16.55,0:10:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya di depan sini.
Dialogue: 0,0:10:18.47,0:10:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi negatifnya sangat kuat, hati-hati.
Dialogue: 0,0:10:21.55,0:10:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang jalan di depan.
Dialogue: 0,0:10:29.25,0:10:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para gagak tak berani mendekat.
Dialogue: 0,0:10:31.32,0:10:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja.
Dialogue: 0,0:10:33.13,0:10:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi negatifnya mengerikan.
Dialogue: 0,0:10:35.20,0:10:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan aku pun bisa melihatnya.
Dialogue: 0,0:10:39.21,0:10:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, di sini Harima.
Dialogue: 0,0:10:40.70,0:10:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Kusunoki, aku baru saja sampai.
Dialogue: 0,0:10:43.88,0:10:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima, Anda di mana?
Dialogue: 0,0:10:45.63,0:10:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di pintu belakang, kau di depan?
Dialogue: 0,0:10:48.43,0:10:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu, di sini ada\Npatung Vajrapani.
Dialogue: 0,0:10:52.97,0:10:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, lihat kemampuanku!
Dialogue: 0,0:10:56.43,0:10:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi negatif ini sungguh luar biasa.
Dialogue: 0,0:11:00.31,0:11:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bahkan tak bisa mendekat.
Dialogue: 0,0:11:03.02,0:11:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin terdengar tak bertanggung jawab\Nsetelah meminta bantuanmu,
Dialogue: 0,0:11:04.87,0:11:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tolong jangan memaksakan diri.
Dialogue: 0,0:11:06.75,0:11:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam situasi terburuk,\Nsegeralah melarikan diri.
Dialogue: 0,0:11:08.65,0:11:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti, aku akan berusaha semampuku.
Dialogue: 0,0:11:12.34,0:11:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:11:17.82,0:11:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di balik ini adalah dunia lain.
Dialogue: 0,0:11:20.03,0:11:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita buka pintu masuknya.
Dialogue: 0,0:11:21.86,0:11:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:32.66,0:11:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, ayo!
Dialogue: 0,0:11:34.66,0:11:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:44.24,0:11:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di dalam sana.
Dialogue: 0,0:11:46.24,0:11:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dalangnya ada di sana.
Dialogue: 0,0:11:50.12,0:11:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak salah lagi.
Dialogue: 0,0:11:51.54,0:11:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:11:54.56,0:11:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:22.03,0:12:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya,
Dialogue: 0,0:12:22.78,0:12:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sembunyi di belakangku!
Dialogue: 0,0:12:30.99,0:12:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:12:32.41,0:12:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka?
Dialogue: 0,0:12:34.26,0:12:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang lagi!
Dialogue: 0,0:12:38.12,0:12:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju, kita harus melindungi Minato!
Dialogue: 0,0:12:40.73,0:12:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:41.44,0:12:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan aku!
Dialogue: 0,0:12:42.82,0:12:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:12:44.00,0:12:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah!
Dialogue: 0,0:12:45.14,0:12:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima ini!
Dialogue: 0,0:12:48.95,0:12:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya?
Dialogue: 0,0:12:50.16,0:12:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi!
Dialogue: 0,0:12:50.94,0:12:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lengah!
Dialogue: 0,0:13:00.78,0:13:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi!
Dialogue: 0,0:13:11.06,0:13:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:13:12.34,0:13:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya sudah kubilang jangan lengah?
Dialogue: 0,0:13:15.84,0:13:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak apa-apa?
Dialogue: 0,0:13:17.39,0:13:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baik-baik saja.
Dialogue: 0,0:13:30.97,0:13:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:13:32.47,0:13:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi negatifnya jauh lebih pekat\Ndari sebelumnya.
Dialogue: 0,0:13:36.40,0:13:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa makhluk itu sumbernya?
Dialogue: 0,0:13:42.69,0:13:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat sangat marah.
Dialogue: 0,0:13:44.59,0:13:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik sekali, bikin kesal!
Dialogue: 0,0:13:45.88,0:13:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bereskan dan segera pulang.
Dialogue: 0,0:13:47.89,0:13:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, pai apelnya keburu habis.
Dialogue: 0,0:13:49.98,0:13:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya.
Dialogue: 0,0:14:12.16,0:14:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:14:15.24,0:14:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, awas!
Dialogue: 0,0:14:20.04,0:14:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato!
Dialogue: 0,0:14:31.34,0:14:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, kita bisa kalah.
Dialogue: 0,0:14:34.30,0:14:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung...
Dialogue: 0,0:14:42.62,0:14:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato...
Dialogue: 0,0:14:44.59,0:14:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah bangun!
Dialogue: 0,0:14:47.64,0:14:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bersamamu.
Dialogue: 0,0:15:16.77,0:15:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa, Minato?
Dialogue: 0,0:15:18.43,0:15:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:15:21.09,0:15:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana boneka itu?
Dialogue: 0,0:15:28.13,0:15:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti merasa sangat kesakitan.
Dialogue: 0,0:15:40.26,0:15:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya dia bebas dari energi negatif.
Dialogue: 0,0:15:44.85,0:15:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu teriakan Tuan Dewa Gunung?
Dialogue: 0,0:15:47.53,0:15:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:49.07,0:15:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengirimkan kekuatannya dari jauh.
Dialogue: 0,0:15:51.59,0:15:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali, 'kan?
Dialogue: 0,0:15:55.36,0:15:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya rohnya belum sepenuhnya terusir.
Dialogue: 0,0:16:06.46,0:16:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:16:08.22,0:16:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi inilah biang keladinya?
Dialogue: 0,0:16:10.48,0:16:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung yang sebenarnya.
Dialogue: 0,0:16:12.52,0:16:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak sangat menderita.
Dialogue: 0,0:16:14.21,0:16:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup usir energi negatifnya saja.
Dialogue: 0,0:16:16.79,0:16:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera menyelamatkanmu.
Dialogue: 0,0:16:22.93,0:16:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kertas catatanku habis.
Dialogue: 0,0:16:25.51,0:16:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, masih ada sisa.
Dialogue: 0,0:16:35.75,0:16:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:16:49.95,0:16:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rohnya masih belum terusir.
Dialogue: 0,0:16:51.79,0:16:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada hal lain yang bisa kutulis?
Dialogue: 0,0:16:54.20,0:16:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupikirkan.
Dialogue: 0,0:16:57.14,0:16:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia lain ini mulai runtuh.
Dialogue: 0,0:17:00.35,0:17:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat, Minato!
Dialogue: 0,0:17:07.04,0:17:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun! Ada sehelai daun di sakuku.
Dialogue: 0,0:17:09.64,0:17:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:11.25,0:17:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:17:12.51,0:17:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun dari pohon Kusunoki.
Dialogue: 0,0:17:16.43,0:17:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, itu pohon suci.
Dialogue: 0,0:17:19.13,0:17:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daunnya pun mengandung kekuatan.
Dialogue: 0,0:17:20.94,0:17:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, pengusiran roh bisa tuntas.
Dialogue: 0,0:17:23.10,0:17:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, masih kuat menulis?
Dialogue: 0,0:17:24.72,0:17:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba.
Dialogue: 0,0:17:28.24,0:17:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir pingsan.
Dialogue: 0,0:17:29.89,0:17:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu banyak energi yang terkuras.
Dialogue: 0,0:17:33.20,0:17:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku harus bertahan sampai akhir.
Dialogue: 0,0:17:36.82,0:17:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ini sudah cukup.
Dialogue: 0,0:17:52.42,0:17:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:17:55.29,0:17:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kehabisan waktu.
Dialogue: 0,0:17:57.07,0:17:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari sekarang!
Dialogue: 0,0:18:03.52,0:18:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki Minato masih di dalam!
Dialogue: 0,0:18:06.99,0:18:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua bisa terseret!
Dialogue: 0,0:18:09.23,0:18:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan nekat, Harima!
Dialogue: 0,0:18:19.07,0:18:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika begini terus,\Nkita akan hancur bersama dunia lain ini.
Dialogue: 0,0:18:23.44,0:18:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah!
Dialogue: 0,0:18:26.63,0:18:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu keluarnya sudah dekat.
Dialogue: 0,0:18:59.06,0:19:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil keluar dari dunia lain.
Dialogue: 0,0:19:01.05,0:19:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah! Tapi bagaimana kita bisa selamat?
Dialogue: 0,0:19:04.44,0:19:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, benar-benar merepotkan saja.
Dialogue: 0,0:19:08.58,0:19:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Fujin! Tuan Raijin!
Dialogue: 0,0:19:10.75,0:19:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kukatakan?
Dialogue: 0,0:19:12.25,0:19:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghancurkan rumah orang yang dibenci
Dialogue: 0,0:19:13.83,0:19:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah masalah besar.
Dialogue: 0,0:19:17.09,0:19:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Maaf, ya.
Dialogue: 0,0:19:20.52,0:19:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya masih banyak\Nyang harus kau pelajari.
Dialogue: 0,0:19:26.06,0:19:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini bantuanmu sangat berarti.
Dialogue: 0,0:19:28.98,0:19:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:19:30.08,0:19:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama, aku senang bisa membantu.
Dialogue: 0,0:19:33.26,0:19:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sampaikan rasa terima kasihku\Npada para dewa.
Dialogue: 0,0:19:35.59,0:19:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih karena selalu memberiku hadiah.
Dialogue: 0,0:19:37.63,0:19:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:19:38.51,0:19:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada waktu, mau ikut pesta barbeku?
Dialogue: 0,0:19:41.32,0:19:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah.
Dialogue: 0,0:19:42.45,0:19:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang buru-buru, tak ingin mengganggu.
Dialogue: 0,0:19:56.49,0:19:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara soal manju, pasta kacang merah halus\Nmemang yang terbaik.
Dialogue: 0,0:19:59.22,0:20:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:20:00.87,0:20:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawa camilan dari Tuan Harima.
Dialogue: 0,0:20:05.91,0:20:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Minato, berikan padaku!
Dialogue: 0,0:20:08.22,0:20:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi, telan dulu baru ambil lagi.
Dialogue: 0,0:20:10.72,0:20:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, lihat! Dagingnya gosong.
Dialogue: 0,0:20:18.88,0:20:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski panas, tapi rasanya nyaman sekali.
Dialogue: 0,0:20:20.91,0:20:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak terasa kita sudah lama berendam.
Dialogue: 0,0:20:24.96,0:20:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin sake dingin?
Dialogue: 0,0:20:28.39,0:20:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami tak akan sungkan.
Dialogue: 0,0:20:33.78,0:20:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan diminum.
Dialogue: 0,0:20:35.09,0:20:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:37.35,0:20:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kirin!
Dialogue: 0,0:20:39.58,0:20:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kirin, ada bir, lo.
Dialogue: 0,0:20:41.93,0:20:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ikut bergabung?
Dialogue: 0,0:20:55.16,0:20:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya sudah kubilang,
Dialogue: 0,0:20:56.43,0:20:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan bawa sampah ke taman suci!
Dialogue: 0,0:20:59.48,0:21:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, itu bukan sampah.
Dialogue: 0,0:21:01.08,0:21:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu durian, buah yang enak.
Dialogue: 0,0:21:04.94,0:21:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau sekali! Hidungmu rusak?
Dialogue: 0,0:21:08.59,0:21:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kurang ajar!
Dialogue: 0,0:21:12.19,0:21:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau busuk ini tak tertahankan!
Dialogue: 0,0:21:17.46,0:21:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuku terkena bau sampah!
Dialogue: 0,0:21:19.80,0:21:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang itu bukan sampah!
Dialogue: 0,0:21:21.95,0:21:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengakui benda ini\Nsebagai makanan.
Dialogue: 0,0:21:23.91,0:21:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.
Dialogue: 0,0:21:24.63,0:21:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buah.
Dialogue: 0,0:21:25.68,0:21:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki, terima kasih.
Dialogue: 0,0:21:28.21,0:21:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, cepat lihat kemari!
Dialogue: 0,0:21:31.95,0:21:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perubahan pada mutiaranya.
Dialogue: 0,0:21:36.87,0:21:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ayam?
Dialogue: 0,0:21:38.61,0:21:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jenis terakhir dari Shirei.
Dialogue: 0,0:21:40.77,0:21:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoo.
Dialogue: 0,0:21:43.62,0:21:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu sekali!
Dialogue: 0,0:21:45.85,0:21:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dirasuki roh jahat tadi adalah Hoo.
Dialogue: 0,0:21:50.05,0:21:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah bisa selamat.
Dialogue: 0,0:21:52.28,0:21:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hoo, selamat datang\Ndi kediaman Kusunoki.
Dialogue: 0,0:23:31.93,0:23:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 5.
Dialogue: 0,0:23:33.49,0:23:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah sang Dewi dan Kekuatan Segel.
