Dialogue: 0,0:01:02.54,0:01:03.50,tanda,,0000,0000,0000,,MANJU KASTANYE
Dialogue: 0,0:03:19.95,0:03:24.90,tanda,,0000,0000,0000,,TAMU YANG BERBONDONG-BONDONG\NKE TAMAN MUSIM SEMI
Dialogue: 0,0:05:40.30,0:05:41.73,tanda,,0000,0000,0000,,UGUISU MOCHI
Dialogue: 0,0:11:05.53,0:11:08.09,tanda,,0000,0000,0000,,"MUSTAR SEGAR"
Dialogue: 0,0:12:33.86,0:12:35.52,tanda,,0000,0000,0000,,RAJA, PION
Dialogue: 0,0:13:46.03,0:13:49.20,tanda,,0000,0000,0000,,"DEWA EBISU"
Dialogue: 0,0:17:34.55,0:17:37.07,tanda,,0000,0000,0000,,"TSUMUGI"
Dialogue: 0,0:23:36.24,0:23:39.45,tanda,,0000,0000,0000,,SELANJUTNYA:\NKUNCI KEKUATAN ADA PADA INGATAN
Dialogue: 0,0:00:03.98,0:00:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori tidur terus
Dialogue: 0,0:00:08.42,0:00:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena waktu itu demi meminta tolong,\Ndia berubah kembali ke wujud aslinya,
Dialogue: 0,0:00:12.40,0:00:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menggunakan terlalu banyak kekuatan?
Dialogue: 0,0:00:15.46,0:00:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:00:16.74,0:00:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi seharusnya dia akan segera bangun.
Dialogue: 0,0:00:19.67,0:00:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:00:21.80,0:00:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoo bukanlah makhluk yang bisa\Ndikalahkan oleh hal sepele.
Dialogue: 0,0:00:28.80,0:00:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:00:42.31,0:00:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin belajar mengendalikan\Nkekuatan segel yang diberikan Dewi.
Dialogue: 0,0:00:48.08,0:00:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa menyegel\Nkekuatan mengusir roh jahat,
Dialogue: 0,0:00:50.89,0:00:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin aku bisa lebih banyak\Nmembantu Tuan Harima dan semua orang.
Dialogue: 0,0:00:55.27,0:00:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:56.54,0:00:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyegel kekuatan yang sebelumnya\Ntersebar ke mana-mana,
Dialogue: 0,0:00:59.50,0:01:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu ide yang menarik.
Dialogue: 0,0:01:04.16,0:01:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat, Amaterasu juga\Nmenggunakan kotak kayu seperti ini.
Dialogue: 0,0:01:12.81,0:01:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:01:17.53,0:01:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan meluap seperti asap.
Dialogue: 0,0:01:21.24,0:01:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:01:22.82,0:01:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:23.87,0:01:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyegel bergantung pada imajinasi.
Dialogue: 0,0:01:26.73,0:01:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imajinasi?
Dialogue: 0,0:01:29.80,0:01:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertawa saja terang-terangan.
Dialogue: 0,0:01:32.24,0:01:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tertawa.
Dialogue: 0,0:01:36.87,0:01:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Torika juga pernah jujur bilang\Nbahwa pengucapanku buruk.
Dialogue: 0,0:01:40.26,0:01:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku sudah tahu sejak lama.
Dialogue: 0,0:01:42.47,0:01:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Torika juga jadi berani bicara ya.
Dialogue: 0,0:02:00.85,0:02:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:03:25.73,0:03:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:03:27.68,0:03:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan kekuatan segelnya lancar?
Dialogue: 0,0:03:30.83,0:03:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih tidak bisa.
Dialogue: 0,0:03:33.08,0:03:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, aku baru saja menerima telepon.
Dialogue: 0,0:03:35.87,0:03:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang rencananya mau\Nmelihat rumah di sini, batal lagi.
Dialogue: 0,0:03:42.27,0:03:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:03:43.92,0:03:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah ketiga kalinya\Ndibatalkan mendadak.
Dialogue: 0,0:03:48.29,0:03:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia memang mudah berubah.
Dialogue: 0,0:03:51.77,0:03:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kenapa?
Dialogue: 0,0:03:53.87,0:03:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ini 1LDK di desa, ada taman\Nyang tenang dan cantik,
Dialogue: 0,0:03:58.19,0:04:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan juga ditambah Tuan Dewa Gunung.
Dialogue: 0,0:04:00.58,0:04:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah secara paksa,\Ntidak bisa dikembalikan.
Dialogue: 0,0:04:02.68,0:04:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membersihkan setiap sudut,\Ndan menyiapkan camilan Jepang.
Dialogue: 0,0:04:07.33,0:04:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat itu, camilan ini jadi milikku.
Dialogue: 0,0:04:10.04,0:04:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk bagian Tuan Dewa Gunung,\Naku sudah beli terpisah.
Dialogue: 0,0:04:14.89,0:04:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna hijau kekuningan,
Dialogue: 0,0:04:16.48,0:04:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merah muda sakura dari sakura manju.
Dialogue: 0,0:04:19.66,0:04:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna-warna lembut yang tidak saling\Nberebut perhatian.
Dialogue: 0,0:04:22.50,0:04:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat terasa nuansa musim semi.
Dialogue: 0,0:04:38.20,0:04:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taman ini ternyata…
Dialogue: 0,0:04:39.88,0:04:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang harus melihat bunga sakura.
Dialogue: 0,0:04:42.10,0:04:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, musim semi tidak akan dimulai.
Dialogue: 0,0:04:44.85,0:04:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi kecil lagi.
Dialogue: 0,0:04:47.33,0:04:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu-bulunya…
Dialogue: 0,0:04:48.55,0:04:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tubuh Anda tidak apa-apa?
Dialogue: 0,0:04:50.91,0:04:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, untuk kembali ke bentuk semula,\Nmungkin butuh waktu.
Dialogue: 0,0:04:57.02,0:04:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana Anda melakukannya tadi?
Dialogue: 0,0:04:59.59,0:05:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat mata.
Dialogue: 0,0:05:01.30,0:05:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hehe.
Dialogue: 0,0:05:02.65,0:05:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata?
Dialogue: 0,0:05:03.97,0:05:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:04.97,0:05:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, cara ini yang paling mudah.
Dialogue: 0,0:05:08.91,0:05:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi Tuan Dewa Gunung, yang paling mudah…
Dialogue: 0,0:05:12.78,0:05:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup temukan benda yang menurutmu berguna.
Dialogue: 0,0:05:17.73,0:05:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda yang berguna bagiku…
Dialogue: 0,0:05:20.89,0:05:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya!
Dialogue: 0,0:05:22.96,0:05:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika pakai kertas yang biasa, mungkin\Nbisa segel kekuatan mengusir roh jahat.
Dialogue: 0,0:05:27.39,0:05:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap orang punya sesuatu\Nyang cocok dan tidak cocok.
Dialogue: 0,0:05:31.12,0:05:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajar.
Dialogue: 0,0:05:39.71,0:05:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:44.60,0:05:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara kicauan itu, sangat cocok dengan\Ntaman penuh nuansa musim semi ini.
Dialogue: 0,0:05:48.42,0:05:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:05:57.43,0:05:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, mohon bantuannya.
Dialogue: 0,0:06:23.24,0:06:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan berusaha.
Dialogue: 0,0:06:31.48,0:06:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, cepat, cepat!
Dialogue: 0,0:06:34.41,0:06:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, semangat!
Dialogue: 0,0:06:38.77,0:06:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus mencari rebung\Ndi saat seperti ini?
Dialogue: 0,0:06:41.97,0:06:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hubungannya dengan kekuatan segel?
Dialogue: 0,0:06:44.80,0:06:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di gunung milik Dewa Gunung,\Nbanyak rebung yang bisa dipetik.
Dialogue: 0,0:06:48.30,0:06:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa mencicipi makanan segar\Nkhas musim semi,
Dialogue: 0,0:06:50.58,0:06:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin kekuatan akan muncul.
Dialogue: 0,0:06:53.22,0:06:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja.
Dialogue: 0,0:07:01.65,0:07:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang sebelumnya\Ningin membeli rumah ini,
Dialogue: 0,0:07:05.33,0:07:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kulempar ke wilayah dewaku sebentar,\Nlalu kubebaskan.
Dialogue: 0,0:07:09.34,0:07:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh begitu, kalian yang mengaturnya, ya.
Dialogue: 0,0:07:11.83,0:07:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kejam sekali.
Dialogue: 0,0:07:14.23,0:07:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani sekali kau bicaranya.
Dialogue: 0,0:07:16.12,0:07:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau juga ingin mengurung\Norang yang ingin menendang pintu?
Dialogue: 0,0:07:20.60,0:07:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang pantas!
Dialogue: 0,0:07:22.77,0:07:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang ingin merusak pintu masuk kuil,
Dialogue: 0,0:07:25.57,0:07:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah seharusnya bersujud berterima kasih\Nkarena tidak dicabut nyawanya.
Dialogue: 0,0:07:29.57,0:07:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:07:30.88,0:07:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh, menakutkan sekali.
Dialogue: 0,0:07:36.66,0:07:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah dewa terbengkalai lagi?
Dialogue: 0,0:07:40.23,0:07:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergerak ke arah gunung.
Dialogue: 0,0:07:42.49,0:07:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya Minato yang menariknya.
Dialogue: 0,0:07:44.76,0:07:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:07:46.69,0:07:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:07:51.42,0:07:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melihat berbagai macam manusia,
Dialogue: 0,0:07:53.60,0:07:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi orang yang bisa menarik wilayah dewa,
Dialogue: 0,0:07:55.63,0:07:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tidak biasa.
Dialogue: 0,0:07:58.73,0:08:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski manusia, tapi dia tinggal\Ndi wilayah dewa,
Dialogue: 0,0:08:00.99,0:08:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bercampur dengan berbagai hal,\Ndan menjadi tubuh yang aneh.
Dialogue: 0,0:08:04.31,0:08:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak heran dia memiliki sifat kedewaan.
Dialogue: 0,0:08:08.03,0:08:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lama ini dia diseret\Nke wilayah dewa, 'kan?
Dialogue: 0,0:08:12.27,0:08:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mencegah hal itu terjadi lagi,
Dialogue: 0,0:08:14.36,0:08:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin memberinya lebih banyak kekuatan.
Dialogue: 0,0:08:17.01,0:08:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:08:18.08,0:08:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika diberi kekuatan lagi, Minato tak bisa\Ntetap menjadi manusia.
Dialogue: 0,0:08:22.44,0:08:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting adalah bagaimana dia\Nmenggunakan kekuatan itu ke depannya.
Dialogue: 0,0:08:32.59,0:08:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kita hampir sampai.
Dialogue: 0,0:08:34.77,0:08:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal sebentar lagi sampai\Ndi tempat rebung tumbuh.
Dialogue: 0,0:08:37.86,0:08:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, ada banyak rebung yang sedang musim.
Dialogue: 0,0:08:42.40,0:08:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:08:44.64,0:08:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini terlalu mendadak,\Naku tidak bawa cangkul.
Dialogue: 0,0:08:55.62,0:08:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:06.87,0:09:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar saling menatap.
Dialogue: 0,0:09:11.35,0:09:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini? Pura-pura mati?\NApa tidak terlambat?
Dialogue: 0,0:09:15.28,0:09:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:09:17.60,0:09:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang perlu ditakuti.
Dialogue: 0,0:09:20.50,0:09:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia makhluk yang lembut, tapi sangat kuat.
Dialogue: 0,0:09:24.55,0:09:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Tuan Dewa Gunung?
Dialogue: 0,0:09:27.51,0:09:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:28.82,0:09:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda masuk ke tubuh Utsugi?
Dialogue: 0,0:09:31.32,0:09:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kukatakan, mereka adalah klonaku.
Dialogue: 0,0:09:35.23,0:09:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Level seperti ini hal sepele.
Dialogue: 0,0:09:41.87,0:09:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pemimpin telah menerima perawatanmu."
Dialogue: 0,0:09:44.11,0:09:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia berkata begitu.
Dialogue: 0,0:09:46.33,0:09:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pemimpinnya?
Dialogue: 0,0:09:47.96,0:09:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Kirin.
Dialogue: 0,0:09:51.78,0:09:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Izinkan aku mengungkapkan terima kasih."
Dialogue: 0,0:09:55.40,0:09:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Er…
Dialogue: 0,0:10:04.93,0:10:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat beruntung dia teman kita.
Dialogue: 0,0:10:16.98,0:10:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ia ingin aku menerima ini?
Dialogue: 0,0:10:21.75,0:10:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau bisa mengerti ucapannya sekarang.
Dialogue: 0,0:10:25.05,0:10:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, hanya perasaan.
Dialogue: 0,0:10:28.37,0:10:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:31.80,0:10:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sekarang paling enak, cepat makan."
Dialogue: 0,0:10:35.03,0:10:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia berkata begitu.
Dialogue: 0,0:10:37.66,0:10:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:39.25,0:10:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari makan rebung\Nyang baru digali pagi ini.
Dialogue: 0,0:10:42.34,0:10:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan di sini?
Dialogue: 0,0:10:43.82,0:10:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menikmati sesuatu yang baru dipetik\Nadalah kebahagiaan tiada tara.
Dialogue: 0,0:10:48.87,0:10:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah pesona terbesar dari bahan musiman.
Dialogue: 0,0:10:52.65,0:10:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak sulit bergerak.
Dialogue: 0,0:10:54.76,0:10:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, nanti juga terbiasa.
Dialogue: 0,0:10:57.17,0:10:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kuma, terima kasih.
Dialogue: 0,0:11:02.07,0:11:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan rebung segar\Nharus berpacu dengan waktu.
Dialogue: 0,0:11:05.53,0:11:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini pakai saus mustar saja.
Dialogue: 0,0:11:08.09,0:11:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, silakan dinikmati.
Dialogue: 0,0:11:10.47,0:11:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:11:12.61,0:11:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:11:13.87,0:11:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:14.74,0:11:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hubungan kekuatanku\Ndengan menggali rebung?
Dialogue: 0,0:11:18.25,0:11:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa bilang ada hubungannya?
Dialogue: 0,0:11:20.94,0:11:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Anda hanya ingin\Nmakan rebung?
Dialogue: 0,0:11:25.28,0:11:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau terlalu bersemangat.
Dialogue: 0,0:11:27.55,0:11:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku ini kegiatan rekreasi bagus.
Dialogue: 0,0:11:31.04,0:11:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menghirup udara bersih,\Nhatiku jadi tenang.
Dialogue: 0,0:11:35.31,0:11:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa terhubung\Ndengan hewan-hewan.
Dialogue: 0,0:11:39.44,0:11:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga cicipi rebung ini.
Dialogue: 0,0:11:44.20,0:11:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tidak sungkan lagi.
Dialogue: 0,0:11:46.81,0:11:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dari yang lain.
Dialogue: 0,0:11:48.25,0:11:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:11:53.43,0:11:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:11:54.68,0:11:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:12:01.78,0:12:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:12:03.19,0:12:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba ambil itu?
Dialogue: 0,0:12:04.51,0:12:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir sesekali kita main.
Dialogue: 0,0:12:07.20,0:12:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau main Shogi Kuzushi,\Nseharusnya tidak masalah.
Dialogue: 0,0:12:10.15,0:12:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temani aku sebentar.
Dialogue: 0,0:12:13.11,0:12:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang akan kuperagakan.
Dialogue: 0,0:12:16.32,0:12:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:17.12,0:12:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup geser bidaknya keluar seperti ini.
Dialogue: 0,0:12:20.32,0:12:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan sampai bersuara.
Dialogue: 0,0:12:23.28,0:12:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bersuara, ganti pemain.
Dialogue: 0,0:12:25.18,0:12:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:26.45,0:12:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dapat bidak lebih banyak menang.
Dialogue: 0,0:12:29.18,0:12:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudah sekali.
Dialogue: 0,0:12:31.58,0:12:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya cukup sulit, lo.
Dialogue: 0,0:12:37.40,0:12:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:12:39.34,0:12:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi!
Dialogue: 0,0:12:43.29,0:12:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, cuma satu bidak,
Dialogue: 0,0:12:46.36,0:12:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beraninya melawanku?
Dialogue: 0,0:12:49.71,0:12:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bidak sialan,\Nsiapa yang mengizinkanmu bersuara?
Dialogue: 0,0:12:53.02,0:12:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, jangan merusaknya.
Dialogue: 0,0:12:55.41,0:12:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:59.89,0:13:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:13:01.11,0:13:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, curang itu tidak baik.
Dialogue: 0,0:13:03.65,0:13:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi Anda pakai kekuatan, 'kan?
Dialogue: 0,0:13:05.23,0:13:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau bicarakan?\NIni juga bagian dari latihan.
Dialogue: 0,0:13:08.17,0:13:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliranku.
Dialogue: 0,0:13:09.99,0:13:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Anda bersikeras begitu…
Dialogue: 0,0:13:15.75,0:13:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, itu…
Dialogue: 0,0:13:17.87,0:13:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang ada yang salah masuk.
Dialogue: 0,0:13:20.40,0:13:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kali ini juga begitu.
Dialogue: 0,0:13:22.30,0:13:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama kali dengar.
Dialogue: 0,0:13:24.23,0:13:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya tidak apa-apa.
Dialogue: 0,0:13:26.46,0:13:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa?
Dialogue: 0,0:13:33.91,0:13:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:13:36.51,0:13:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, mengganggu kalian.
Dialogue: 0,0:13:38.55,0:13:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali bukan orang mencurigakan.
Dialogue: 0,0:13:41.60,0:13:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya…
Dialogue: 0,0:13:43.70,0:13:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tak perlu khusus dijelaskan.
Dialogue: 0,0:13:46.03,0:13:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Ebisu.
Dialogue: 0,0:13:50.76,0:13:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau orang yang diberi kekuatan itu, 'kan?
Dialogue: 0,0:13:56.25,0:13:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehm…
Dialogue: 0,0:13:58.11,0:13:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:00.36,0:14:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kau bisa panggil aku Tuan Ebi.
Dialogue: 0,0:14:05.03,0:14:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal, Tuan Ebi.
Dialogue: 0,0:14:07.56,0:14:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh tahu kenapa Anda mengenalku?
Dialogue: 0,0:14:10.01,0:14:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar ada manusia langka\Nyang mendapatkan kekuatan dari para dewa.
Dialogue: 0,0:14:15.38,0:14:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku ingin datang untuk menemuimu.
Dialogue: 0,0:14:17.32,0:14:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu berlebihan.
Dialogue: 0,0:14:18.84,0:14:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, taman ini sangat elegan.
Dialogue: 0,0:14:23.48,0:14:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya.
Dialogue: 0,0:14:35.10,0:14:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan apa ini?
Dialogue: 0,0:14:36.96,0:14:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, apa artinya perasaan penuh\Nsemangat yang tak ingin kalah ini?
Dialogue: 0,0:14:43.81,0:14:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya?
Dialogue: 0,0:14:46.33,0:14:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan…
Dialogue: 0,0:14:49.96,0:14:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta?
Dialogue: 0,0:14:51.92,0:14:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah akhirnya musim semiku tiba juga?
Dialogue: 0,0:14:55.72,0:14:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sepertinya bukan.
Dialogue: 0,0:15:03.27,0:15:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada onsen juga?
Dialogue: 0,0:15:05.62,0:15:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:15:07.03,0:15:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tidak keberatan, silakan berendam.
Dialogue: 0,0:15:10.14,0:15:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tidak sungkan lagi.
Dialogue: 0,0:15:12.03,0:15:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, bolehkah aku masuk berendam?
Dialogue: 0,0:15:15.33,0:15:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kau.
Dialogue: 0,0:15:17.00,0:15:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:18.78,0:15:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai balasannya, ini untukmu.
Dialogue: 0,0:15:21.63,0:15:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:23.34,0:15:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini taiyaki, nanti makan bersama.
Dialogue: 0,0:15:27.91,0:15:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasta kacang merah halus, 'kan?
Dialogue: 0,0:15:29.14,0:15:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada berbagai rasa, tentu saja\Ntermasuk pasta kacang merah halus.
Dialogue: 0,0:15:33.92,0:15:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:35.47,0:15:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku pergi berendam di onsen.
Dialogue: 0,0:15:38.28,0:15:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan berendam, santai saja.
Dialogue: 0,0:15:50.10,0:15:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya menyimpang agak jauh.
Dialogue: 0,0:15:52.96,0:15:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:15:53.84,0:15:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya menyimpang?
Dialogue: 0,0:15:58.95,0:16:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:16:13.96,0:16:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya tinggal sedikit lagi
Dialogue: 0,0:16:15.69,0:16:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah bisa menguasai\Nkekuatan segel dengan lancar.
Dialogue: 0,0:16:24.36,0:16:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernikahan rubah sudah usai, ya.
Dialogue: 0,0:16:27.04,0:16:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin?
Dialogue: 0,0:16:29.09,0:16:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak akan menikah\Nhanya karena hujan di hari cerah.
Dialogue: 0,0:16:32.77,0:16:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu lagi?
Dialogue: 0,0:16:34.70,0:16:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu
Dialogue: 0,0:16:37.31,0:16:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}onsen sehebat ini ternyata\Nada di dekat sini.
Dialogue: 0,0:16:42.25,0:16:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini rumahmu?
Dialogue: 0,0:16:44.82,0:16:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, aku pengurus di sini.
Dialogue: 0,0:16:47.60,0:16:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:51.72,0:16:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin berendam di onsen?
Dialogue: 0,0:16:53.48,0:16:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan begitu.
Dialogue: 0,0:16:55.94,0:16:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang menangani urusan penting.
Dialogue: 0,0:16:58.48,0:16:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:16:59.79,0:17:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat mendesak?
Dialogue: 0,0:17:01.14,0:17:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya tidak terlalu mendesak.
Dialogue: 0,0:17:07.25,0:17:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengaku saja dengan jujur.
Dialogue: 0,0:17:09.75,0:17:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menu makan siang hari ini\Nadalah inarizushi.
Dialogue: 0,0:17:14.70,0:17:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak keberatan,\Nmaukah makan dulu sebelum pergi?
Dialogue: 0,0:17:16.05,0:17:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku ikut makan siang bersama?
Dialogue: 0,0:17:19.86,0:17:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, makan sampai kenyang baru pergi.
Dialogue: 0,0:17:21.95,0:17:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:24.77,0:17:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah kerabat dewa\Nyang tinggal di gunung sebelah.
Dialogue: 0,0:17:29.95,0:17:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunung sebelah juga ada dewanya, ya?
Dialogue: 0,0:17:33.09,0:17:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:17:34.55,0:17:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Tsumugi.
Dialogue: 0,0:17:37.07,0:17:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bimbingannya ke depannya.
Dialogue: 0,0:17:39.50,0:17:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama, mohon bimbingannya juga.
Dialogue: 0,0:17:41.66,0:17:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Er, aku ingin bertanya.
Dialogue: 0,0:17:45.14,0:17:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inarizushi yang kau sebutkan itu\Nbuatan sendiri?
Dialogue: 0,0:17:47.56,0:17:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski yang dijual di pasaran juga enak,
Dialogue: 0,0:17:51.01,0:17:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi inarizushi buatan sendiri\Ntetap yang terenak.
Dialogue: 0,0:17:54.68,0:17:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya buatan sendiri,\Ntapi ditambahkan sayuran liar.
Dialogue: 0,0:17:57.97,0:17:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:17:59.39,0:18:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu apakah kau akan suka.
Dialogue: 0,0:18:02.11,0:18:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan yang dibuat oleh manusia\Ndengan teliti,
Dialogue: 0,0:18:04.25,0:18:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya itu saja sudah sangat berharga.
Dialogue: 0,0:18:07.09,0:18:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:07.87,0:18:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bentuknya segitiga pasti lebih bagus.
Dialogue: 0,0:18:12.49,0:18:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, lama tidak bertemu.
Dialogue: 0,0:18:16.01,0:18:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:16.91,0:18:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kenyang, silakan pergi\Nberendam di onsen.
Dialogue: 0,0:18:19.48,0:18:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuka hatimu.
Dialogue: 0,0:18:20.65,0:18:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:18:23.13,0:18:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,\Nsangat terasa aura dewanya.
Dialogue: 0,0:18:26.44,0:18:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar! Aku adalah\NDewa Gunung yang agung.
Dialogue: 0,0:18:30.05,0:18:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan ini sangat mulia.
Dialogue: 0,0:18:34.84,0:18:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:18:41.66,0:18:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inarizushi ini,
Dialogue: 0,0:18:43.20,0:18:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah digigit, saus kecapnya\Nmeluap dari kulit tahu.
Dialogue: 0,0:18:46.48,0:18:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak berlebihan, pas sekali.
Dialogue: 0,0:18:49.52,0:18:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali!
Dialogue: 0,0:18:53.34,0:18:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas hidangannya.
Dialogue: 0,0:18:55.05,0:18:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya hidangan sederhana, tidak seberapa.
Dialogue: 0,0:18:56.71,0:18:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prinsipku adalah tidak berutang budi.
Dialogue: 0,0:18:59.76,0:19:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong terima hadiah terima kasih ini.
Dialogue: 0,0:19:02.93,0:19:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:19:04.68,0:19:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini persik yang dipetik di rumahku.
Dialogue: 0,0:19:06.55,0:19:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong terima satu buah.
Dialogue: 0,0:19:07.96,0:19:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipetik di gunung milikmu?
Dialogue: 0,0:19:09.79,0:19:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya,\Ndipetik di taman kebanggaanku
Dialogue: 0,0:19:12.45,0:19:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tak kalah hebat dari taman ini.
Dialogue: 0,0:19:15.39,0:19:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini khusus untuk dewa.
Dialogue: 0,0:19:16.81,0:19:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik kau jangan memakannya.
Dialogue: 0,0:19:19.64,0:19:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:21.59,0:19:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak akan busuk,\Ndan aromanya harum.
Dialogue: 0,0:19:25.28,0:19:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus juga untuk dijadikan hiasan.
Dialogue: 0,0:19:27.31,0:19:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmm, apa aku benar-benar boleh menerimanya?
Dialogue: 0,0:19:30.82,0:19:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:19:31.72,0:19:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang diberikan dewaku kepadaku.
Dialogue: 0,0:19:34.67,0:19:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewamu?
Dialogue: 0,0:19:36.42,0:19:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membuktikan kami lebih unggul.
Dialogue: 0,0:19:41.07,0:19:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:42.60,0:19:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, aku terima ya.
Dialogue: 0,0:19:45.01,0:19:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti akan aku makan.
Dialogue: 0,0:19:47.01,0:19:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, apa Anda\Nkenal dewa Tsumugi?
Dialogue: 0,0:19:50.67,0:19:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu?
Dialogue: 0,0:20:00.27,0:20:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berendam di onsen?
Dialogue: 0,0:20:01.87,0:20:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima kasih.
Dialogue: 0,0:20:04.53,0:20:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau juga berendam di onsen itu?
Dialogue: 0,0:20:07.75,0:20:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berendam setiap hari.
Dialogue: 0,0:20:09.53,0:20:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya, pantas saja kau\Ntak terlihat seperti manusia.
Dialogue: 0,0:20:13.79,0:20:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:23.06,0:20:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa lagi.
Dialogue: 0,0:20:28.05,0:20:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,\Naku memang tidak mirip manusia.
Dialogue: 0,0:20:32.96,0:20:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sebelumnya sudah kurasakan.
Dialogue: 0,0:20:36.30,0:20:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya menyimpang agak jauh.
Dialogue: 0,0:20:39.22,0:20:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya aku sudah keluar\Ndari batas manusia, 'kan?
Dialogue: 0,0:20:43.81,0:20:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:20:45.28,0:20:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang hanya manusia biasa,
Dialogue: 0,0:20:47.49,0:20:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mana mungkin tak terpengaruh?
Dialogue: 0,0:20:53.46,0:20:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ingin belajar\Nmengendalikan kekuatan segel,
Dialogue: 0,0:20:57.88,0:21:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi perubahan dalam diriku ini\Nmasih membuatku takut.
Dialogue: 0,0:21:02.10,0:21:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:21:03.58,0:21:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski diberi kekuatan, kau tetaplah dirimu.
Dialogue: 0,0:21:07.51,0:21:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tetaplah aku.
Dialogue: 0,0:21:09.45,0:21:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah aku bisa meninggal sebagai manusia?
Dialogue: 0,0:21:12.36,0:21:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bisa.
Dialogue: 0,0:21:14.68,0:21:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau cukup berusaha saja\Nuntuk mengendalikan kekuatanmu.
Dialogue: 0,0:21:19.81,0:21:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:21:21.05,0:21:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petunjuk kekuatan segel\Nmungkin tersembunyi di masa lalumu.
Dialogue: 0,0:21:25.92,0:21:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa laluku?
Dialogue: 0,0:21:28.16,0:21:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil kau bisa melihat, 'kan?
Dialogue: 0,0:21:31.59,0:21:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa melihat makhluk bukan manusia.
Dialogue: 0,0:21:45.57,0:21:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kali aku melihat itu.
Dialogue: 0,0:21:50.39,0:21:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:21:54.83,0:21:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku berusia lima tahun.
Dialogue: 0,0:23:32.17,0:23:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 7.
Dialogue: 0,0:23:34.05,0:23:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci Kekuatan Ada pada Ingatan.
