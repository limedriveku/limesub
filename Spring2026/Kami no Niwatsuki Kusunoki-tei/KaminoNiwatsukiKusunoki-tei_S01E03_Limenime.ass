Dialogue: 0,0:00:05.68,0:00:09.85,tanda,,0000,0000,0000,,KASHIWAMOCHI, UMEKO MANJU, OHAGI
Dialogue: 0,0:01:11.79,0:01:14.43,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GOD
Dialogue: 0,0:02:31.01,0:02:35.94,tanda,,0000,0000,0000,,KEKUATAN ANGIN,\NBERKULTIVASILAH DI KAWASAN SUCI
Dialogue: 0,0:03:02.18,0:03:04.56,tanda,,0000,0000,0000,,RUMAH KUSUNOKI
Dialogue: 0,0:04:41.27,0:04:44.14,tanda,,0000,0000,0000,,DAIFUKU, YOKAN, MANJU
Dialogue: 0,0:04:49.09,0:04:50.51,tanda,,0000,0000,0000,,"ECHIGOYA, MANJU SAKE BARU"
Dialogue: 0,0:04:50.51,0:04:51.82,tanda,,0000,0000,0000,,"ISIAN KACANG MERAH KASAR"
Dialogue: 0,0:05:13.18,0:05:15.71,tanda,,0000,0000,0000,,"IWAYAMAYA"
Dialogue: 0,0:05:39.83,0:05:43.05,tanda,,0000,0000,0000,,"TEH HIJAU, SANSHOKU DANGO"
Dialogue: 0,0:05:51.34,0:05:54.52,tanda,,0000,0000,0000,,"TOKO MANGKUK TEH, YAMADOAN"
Dialogue: 0,0:06:25.47,0:06:27.72,tanda,,0000,0000,0000,,"ECHIGOYA"
Dialogue: 0,0:08:50.52,0:08:51.99,tanda,,0000,0000,0000,,"ECHIGOYA"
Dialogue: 0,0:12:41.04,0:12:46.99,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GOD
Dialogue: 0,0:12:49.93,0:12:50.99,tanda,,0000,0000,0000,,RUMAH KUSUNOKI
Dialogue: 0,0:14:53.92,0:14:56.86,tanda,,0000,0000,0000,,KIRIN
Dialogue: 0,0:15:24.44,0:15:26.70,tanda,,0000,0000,0000,,30 MENIT BERLALU
Dialogue: 0,0:15:36.01,0:15:38.26,tanda,,0000,0000,0000,,30 MENIT BERLALU LAGI
Dialogue: 0,0:15:53.96,0:15:56.42,tanda,,0000,0000,0000,,"MILIK MINATO"
Dialogue: 0,0:17:46.63,0:17:48.40,tanda,,0000,0000,0000,,MENDESAK! PAPAN NAMA RUSAK,\NCADANGAN HABIS, SEGERA BUAT YANG BARU
Dialogue: 0,0:18:20.25,0:18:23.00,tanda,,0000,0000,0000,,"RUMAH KUSUNOKI"
Dialogue: 0,0:18:27.20,0:18:30.05,tanda,,0000,0000,0000,,"RUMAH KUSUNOKI"
Dialogue: 0,0:20:08.69,0:20:10.12,tanda,,0000,0000,0000,,"DURIAN"
Dialogue: 0,0:21:50.14,0:21:52.43,tanda,,0000,0000,0000,,RUMAH KUSUNOKI
Dialogue: 0,0:23:36.51,0:23:38.51,tanda,,0000,0000,0000,,SELANJUTNYA: PERGI KE DUNIA LAIN UNTUK\NMENGUSIR SILUMAN, BERANGKAT SEKARANG
Dialogue: 0,0:00:10.36,0:00:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pena tinta memang yang paling nyaman.
Dialogue: 0,0:00:19.19,0:00:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kejadian aneh belakangan ini?
Dialogue: 0,0:00:22.96,0:00:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, pria kasar yang mendadak muncul.
Dialogue: 0,0:00:26.56,0:00:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak ada.
Dialogue: 0,0:00:28.39,0:00:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada rekan seangkatan yang memusuhiku.
Dialogue: 0,0:00:30.04,0:00:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orangnya cukup menyebalkan.
Dialogue: 0,0:00:32.40,0:00:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melihat jimat buatanmu.
Dialogue: 0,0:00:35.52,0:00:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sekarang dia mengincarmu. Maaf.
Dialogue: 0,0:00:38.61,0:00:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tipe yang akan mengirim Shikigami
Dialogue: 0,0:00:40.56,0:00:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengawasiku.
Dialogue: 0,0:00:42.97,0:00:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shikigami? Benar-benar gaya onmyoji.
Dialogue: 0,0:00:45.29,0:00:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Shikigami pengawas itu\Nselalu kusingkirkan,
Dialogue: 0,0:00:47.39,0:00:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus tetap waspada.
Dialogue: 0,0:00:50.39,0:00:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia itu makhluk bodoh.
Dialogue: 0,0:00:53.28,0:00:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak berubah sejak zaman kuno.
Dialogue: 0,0:00:56.52,0:01:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan kalah dari keroco sepertinya.
Dialogue: 0,0:02:45.21,0:02:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sinikah tempatnya?
Dialogue: 0,0:02:48.18,0:02:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rencanamu setelah menemuinya?
Dialogue: 0,0:02:52.66,0:02:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, membeli hak eksklusif jimatnya
Dialogue: 0,0:02:55.01,0:02:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau memintanya membuat jimat khusus.
Dialogue: 0,0:03:00.94,0:03:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara lonceng angin?
Dialogue: 0,0:03:05.05,0:03:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Firasatku agak buruk.
Dialogue: 0,0:03:09.45,0:03:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, keluarlah!
Dialogue: 0,0:03:15.86,0:03:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan main-main!
Dialogue: 0,0:03:17.43,0:03:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jauh-jauh datang mencarimu!
Dialogue: 0,0:03:20.79,0:03:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:03:22.69,0:03:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar sekarang!
Dialogue: 0,0:03:23.86,0:03:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:03:33.09,0:03:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya apa yang terjadi?
Dialogue: 0,0:03:41.03,0:03:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:03:42.95,0:03:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tadi aku di depan rumah.
Dialogue: 0,0:03:46.25,0:03:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikawa!
Dialogue: 0,0:03:47.29,0:03:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikawa!
Dialogue: 0,0:04:18.83,0:04:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuilnya sama seperti tadi.
Dialogue: 0,0:04:21.00,0:04:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda, ya?
Dialogue: 0,0:04:22.36,0:04:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya juga berhenti.
Dialogue: 0,0:04:24.66,0:04:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jam tanganku rusak?
Dialogue: 0,0:04:45.71,0:04:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan.
Dialogue: 0,0:04:49.09,0:04:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:50.51,0:04:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Produk baru Echigoya
Dialogue: 0,0:04:51.82,0:04:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}isiannya bukan kacang merah halus,\Ntapi kasar?
Dialogue: 0,0:04:56.00,0:05:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Pak Tua itu mulai pikun?
Dialogue: 0,0:05:00.46,0:05:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Echigoya?
Dialogue: 0,0:05:02.31,0:05:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering ke toko ini.
Dialogue: 0,0:05:09.47,0:05:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru pertama kali keluar\Nbareng Tuan Dewa Gunung.
Dialogue: 0,0:05:13.18,0:05:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak gugup.
Dialogue: 0,0:05:16.17,0:05:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, jarang ada yang bisa melihatku.
Dialogue: 0,0:05:20.48,0:05:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu ya.
Dialogue: 0,0:05:26.40,0:05:27.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:05:27.32,0:05:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cium bau harum?
Dialogue: 0,0:05:29.09,0:05:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?
Dialogue: 0,0:05:30.37,0:05:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak cium apa-apa.
Dialogue: 0,0:05:32.09,0:05:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tercium?
Dialogue: 0,0:05:33.15,0:05:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya seperti hutan pegunungan.
Dialogue: 0,0:05:39.83,0:05:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:43.99,0:05:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang saleh atau berhati suci
Dialogue: 0,0:05:47.27,0:05:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa merasakan kehadiran Tuan Dewa Gunung?
Dialogue: 0,0:05:51.34,0:05:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, mampir sebentar?
Dialogue: 0,0:05:54.52,0:05:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:56.24,0:05:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana yang ini?
Dialogue: 0,0:05:58.38,0:06:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa mangkuk biasa sudah cukup.
Dialogue: 0,0:06:03.28,0:06:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum pakai mangkuk itu tak nyaman.
Dialogue: 0,0:06:05.45,0:06:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda harus pakai cangkir yang layak.
Dialogue: 0,0:06:09.09,0:06:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm…
Dialogue: 0,0:06:10.42,0:06:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, selanjutnya bantal duduk.
Dialogue: 0,0:06:12.94,0:06:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak butuh bantal duduk.
Dialogue: 0,0:06:17.13,0:06:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas sekali.
Dialogue: 0,0:06:19.13,0:06:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu kecil.
Dialogue: 0,0:06:21.81,0:06:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari pesan sesuai ukuran.
Dialogue: 0,0:06:23.74,0:06:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:25.47,0:06:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya ratusan tahun tak kemari.
Dialogue: 0,0:06:28.72,0:06:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang?
Dialogue: 0,0:06:30.54,0:06:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:06:32.92,0:06:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pemuda yang pindah\Nke dekat gunung itu, 'kan?
Dialogue: 0,0:06:37.46,0:06:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai beberapa waktu lalu…
Dialogue: 0,0:06:39.82,0:06:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Kakek tampak bersemangat.
Dialogue: 0,0:06:42.51,0:06:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat suruh dia berhenti pakai\Nisian kacang kasar untuk produk baru.
Dialogue: 0,0:06:46.36,0:06:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia tim kacang merah halus?
Dialogue: 0,0:06:49.91,0:06:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah pernah naik gunung?
Dialogue: 0,0:06:52.81,0:06:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, beberapa kali.
Dialogue: 0,0:06:54.86,0:06:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau menemuinya?
Dialogue: 0,0:06:57.33,0:06:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertemu siapa?
Dialogue: 0,0:06:59.08,0:07:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Inu di gunung itu.
Dialogue: 0,0:07:02.99,0:07:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm…
Dialogue: 0,0:07:05.27,0:07:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serigala.
Dialogue: 0,0:07:07.26,0:07:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, belum pernah.
Dialogue: 0,0:07:09.49,0:07:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tak dihitung bohong, 'kan?
Dialogue: 0,0:07:11.99,0:07:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa Tuan Inu itu?
Dialogue: 0,0:07:14.84,0:07:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Tuan Inu yang sangat ramah\Ndi gunung itu.
Dialogue: 0,0:07:20.48,0:07:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu aku masih muda dan bugar.
Dialogue: 0,0:07:28.53,0:07:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku tersesat,
Dialogue: 0,0:07:32.80,0:07:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menemukan sebuah kuil.
Dialogue: 0,0:07:50.61,0:07:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa barusan itu?
Dialogue: 0,0:07:57.45,0:07:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncul lagi.
Dialogue: 0,0:08:04.22,0:08:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang lagi!
Dialogue: 0,0:08:05.98,0:08:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:08:11.03,0:08:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:08:12.37,0:08:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tempat ini…
Dialogue: 0,0:08:18.68,0:08:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itulah aku sadar,
Dialogue: 0,0:08:21.98,0:08:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bermaksud mengantarku ke kaki gunung.
Dialogue: 0,0:08:28.22,0:08:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu anjing siluman penunjuk jalan.
Dialogue: 0,0:08:32.36,0:08:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siluman? Aku ini Dewa Gunung.
Dialogue: 0,0:08:36.87,0:08:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai tanda terima kasih,\Naku memanggilnya Tuan Inu.
Dialogue: 0,0:08:40.92,0:08:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering menaruh manju di sana\Nsebagai imbalan.
Dialogue: 0,0:08:46.43,0:08:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin bertemu Tuan Inu.
Dialogue: 0,0:08:50.52,0:08:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kunjungannya.
Dialogue: 0,0:08:52.67,0:08:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya, Kakek terlihat sangat lesu.
Dialogue: 0,0:08:55.63,0:08:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut melihatnya bugar kembali.
Dialogue: 0,0:08:58.51,0:09:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pencernaannya bermasalah.
Dialogue: 0,0:09:01.34,0:09:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gorengan kesukaannya saja tak dimakan.
Dialogue: 0,0:09:04.96,0:09:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirannya kalut, membuat\Nfisik dan mentalnya melemah.
Dialogue: 0,0:09:09.61,0:09:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa pun tak bisa mencegah\Nkematian manusia.
Dialogue: 0,0:09:14.68,0:09:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hingga saat itu tiba,
Dialogue: 0,0:09:17.52,0:09:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjaga tubuhnya tetap sehat
Dialogue: 0,0:09:20.33,0:09:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih bisa diupayakan.
Dialogue: 0,0:09:24.38,0:09:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata berkat kekuatanmu?
Dialogue: 0,0:09:26.43,0:09:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bos generasi ke-12 ini\Ntumbang sekarang,
Dialogue: 0,0:09:28.75,0:09:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bakal sangat kerepotan.
Dialogue: 0,0:09:30.79,0:09:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kek, aku terlambat.
Dialogue: 0,0:09:33.44,0:09:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa. Jangan dipikirkan.
Dialogue: 0,0:09:35.17,0:09:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub lebih penting.
Dialogue: 0,0:09:37.53,0:09:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baru sembuh, 'kan?\NJangan memaksakan diri.
Dialogue: 0,0:09:44.50,0:09:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:09:50.42,0:09:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan.
Dialogue: 0,0:09:54.79,0:09:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berkeringat, mau mandi dulu.
Dialogue: 0,0:09:57.03,0:09:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:58.28,0:10:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucoba dulu produk baru ini.
Dialogue: 0,0:10:07.26,0:10:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jauh-jauh datang mencarimu!
Dialogue: 0,0:10:17.47,0:10:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini ulahnya?
Dialogue: 0,0:10:19.26,0:10:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ini semua salahmu, Harima!
Dialogue: 0,0:10:23.64,0:10:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau orang di rumah itu…
Dialogue: 0,0:10:50.63,0:10:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek! Aku sudah muak.
Dialogue: 0,0:11:01.47,0:11:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku harus terus begini seumur hidup?
Dialogue: 0,0:11:08.85,0:11:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf.
Dialogue: 0,0:11:11.36,0:11:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf.
Dialogue: 0,0:11:13.53,0:11:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kembalikan aku ke duniaku.
Dialogue: 0,0:11:17.28,0:11:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku kembali.
Dialogue: 0,0:11:19.31,0:11:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lancang pada hutan dan gunung.
Dialogue: 0,0:11:21.39,0:11:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf.
Dialogue: 0,0:11:22.93,0:11:24.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, aku sangat menyesal.
Dialogue: 0,0:11:25.27,0:11:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, kumohon antar aku…
Dialogue: 0,0:11:31.38,0:11:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antar aku kembali…
Dialogue: 0,0:11:39.38,0:11:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kembali?
Dialogue: 0,0:11:42.08,0:11:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikawa, sudah berapa hari kau di sini?
Dialogue: 0,0:11:45.60,0:11:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:46.40,0:11:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:11:48.17,0:11:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kan baru saja tiba.
Dialogue: 0,0:11:59.64,0:12:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara lonceng angin?
Dialogue: 0,0:12:04.29,0:12:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita cepat pergi.
Dialogue: 0,0:12:06.70,0:12:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa, tadi sepertinya\Naku mendengar lonceng.
Dialogue: 0,0:12:09.46,0:12:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu?
Dialogue: 0,0:12:10.90,0:12:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada siapa-siapa.
Dialogue: 0,0:12:12.96,0:12:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa? Aneh.
Dialogue: 0,0:12:15.64,0:12:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasa manjunya?
Dialogue: 0,0:12:18.24,0:12:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isian kacang merah kasar lumayan enak.
Dialogue: 0,0:12:21.47,0:12:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak sia-sia kita jauh-jauh ke sana.
Dialogue: 0,0:12:24.28,0:12:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelamaan berendam bikin kepanasan.
Dialogue: 0,0:12:27.73,0:12:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben.
Dialogue: 0,0:12:29.20,0:12:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya kau hanya\Nmandi kilat pakai shower.
Dialogue: 0,0:12:33.72,0:12:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:35.01,0:12:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendadak rindu\Nonsen di kampung halamanku.
Dialogue: 0,0:12:53.88,0:12:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau belerang?
Dialogue: 0,0:12:56.83,0:12:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:58.43,0:12:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen?
Dialogue: 0,0:13:01.07,0:13:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berendam.
Dialogue: 0,0:13:03.86,0:13:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja mandi pagi.
Dialogue: 0,0:13:05.43,0:13:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih. Kalau begitu,\Naku takkan sungkan.
Dialogue: 0,0:13:11.67,0:13:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmatnya.
Dialogue: 0,0:13:14.54,0:13:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:13:16.67,0:13:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah mewah dengan onsen\Nmemang beda kelasnya.
Dialogue: 0,0:13:21.53,0:13:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ke mana\NTuan Kame dan Tuan Ryu?
Dialogue: 0,0:13:23.72,0:13:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:13:24.73,0:13:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mungkin masih tidur di dasar kolam.
Dialogue: 0,0:13:28.41,0:13:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semalam aku, Oryu, dan Reiki
Dialogue: 0,0:13:30.95,0:13:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuat onsen ini dan minum sampai pagi.
Dialogue: 0,0:13:34.65,0:13:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:13:36.08,0:13:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus berterima kasih pada kalian.
Dialogue: 0,0:13:39.80,0:13:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen Dewa Gunung luar biasa!
Dialogue: 0,0:13:45.36,0:13:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantainya dingin.
Dialogue: 0,0:13:47.46,0:13:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kau baik-baik saja?
Dialogue: 0,0:13:50.23,0:13:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, aku tak apa-apa.
Dialogue: 0,0:13:56.51,0:14:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum hojicha hangat usai berendam\Nmemang paling mantap.
Dialogue: 0,0:14:02.57,0:14:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, gawat!
Dialogue: 0,0:14:04.25,0:14:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:05.85,0:14:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada tamu lagi.
Dialogue: 0,0:14:08.90,0:14:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencariku?
Dialogue: 0,0:14:10.42,0:14:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temannya Tuan Ryu dan Tuan Kame?
Dialogue: 0,0:14:17.16,0:14:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh.
Dialogue: 0,0:14:21.50,0:14:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:14:30.19,0:14:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang waktu itu…
Dialogue: 0,0:14:33.05,0:14:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:36.86,0:14:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tanya boleh masuk atau tidak.
Dialogue: 0,0:14:39.63,0:14:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk.
Dialogue: 0,0:14:59.49,0:15:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia mau mengatakan sesuatu padaku?
Dialogue: 0,0:15:02.74,0:15:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Terima kasih banyak\Natas pertolonganmu waktu itu."
Dialogue: 0,0:15:06.69,0:15:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu katanya.
Dialogue: 0,0:15:08.12,0:15:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:15:12.40,0:15:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkatmu, aku bisa\Nmenemukan jati diriku kembali.
Dialogue: 0,0:15:16.42,0:15:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:18.10,0:15:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa syukur ini sulit diungkapkan.
Dialogue: 0,0:15:20.42,0:15:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan melupakan kebaikanmu\Nseumur hidupku.
Dialogue: 0,0:15:22.70,0:15:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi…
Dialogue: 0,0:15:27.21,0:15:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah ini sangat megah.
Dialogue: 0,0:15:30.48,0:15:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti nyaman ditinggali. Aku kagum!
Dialogue: 0,0:15:32.94,0:15:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini aku sedang berkelana...
Dialogue: 0,0:15:38.26,0:15:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah, semuanya sudah berubah.
Dialogue: 0,0:15:41.76,0:15:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatku merasa seperti Urashima Taro.
Dialogue: 0,0:15:45.20,0:15:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku ingin membalas budi.
Dialogue: 0,0:15:49.84,0:15:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah penguasa atas separuh dunia ini.
Dialogue: 0,0:15:53.96,0:15:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Separuh dunia?
Dialogue: 0,0:15:56.92,0:15:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hargai niat baikmu.
Dialogue: 0,0:16:00.77,0:16:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:01.85,0:16:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya manusia itu makhluk tamak\Nyang berebut tanah dan sumber daya,
Dialogue: 0,0:16:03.74,0:16:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saling bunuh,
Dialogue: 0,0:16:05.50,0:16:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hina dan kejam?
Dialogue: 0,0:16:10.96,0:16:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak punya ambisi semacam itu.
Dialogue: 0,0:16:13.86,0:16:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menguasai separuh dunia pun\Nbelum tentu bahagia.
Dialogue: 0,0:16:18.80,0:16:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:20.85,0:16:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sangat membantu.
Dialogue: 0,0:16:24.68,0:16:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:16:25.99,0:16:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa tubuh kalian bertambah besar?
Dialogue: 0,0:16:29.26,0:16:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh kami berangsur\Nkembali seperti semula.
Dialogue: 0,0:16:31.96,0:16:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkatmu.
Dialogue: 0,0:16:33.94,0:16:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sudah kulakukan?
Dialogue: 0,0:16:36.31,0:16:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengakui dan menghormati kami.
Dialogue: 0,0:16:39.59,0:16:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghormati kami,
Dialogue: 0,0:16:41.11,0:16:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu menguatkan eksistensi kami.
Dialogue: 0,0:16:43.17,0:16:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:44.51,0:16:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini balasan dariku.
Dialogue: 0,0:16:48.64,0:16:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:16:55.43,0:16:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, hebat.
Dialogue: 0,0:16:57.00,0:16:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kau juga bisa melakukannya?
Dialogue: 0,0:16:59.03,0:17:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada kesempatan, mungkin saja.
Dialogue: 0,0:17:02.15,0:17:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bicaramu jadi kaku?
Dialogue: 0,0:17:11.40,0:17:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sudah mulai bisa\Nmengendalikan kekuatan angin.
Dialogue: 0,0:17:14.98,0:17:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:22.40,0:17:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:23.67,0:17:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa.
Dialogue: 0,0:17:25.06,0:17:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sengaja menahan kekuatanmu?
Dialogue: 0,0:17:27.43,0:17:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau takut?
Dialogue: 0,0:17:28.80,0:17:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut? Apa aku terlihat takut?
Dialogue: 0,0:17:32.14,0:17:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cemas akan melukai\Norang di sekitarmu, 'kan?
Dialogue: 0,0:17:35.71,0:17:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mengerahkan kekuatan penuh\Ndan tahu batasannya,
Dialogue: 0,0:17:38.63,0:17:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bisa mengendalikannya lebih leluasa.
Dialogue: 0,0:17:41.99,0:17:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan penuh…
Dialogue: 0,0:17:48.40,0:17:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan nama rusak.
Dialogue: 0,0:17:49.90,0:17:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cadangan habis.
Dialogue: 0,0:17:51.36,0:17:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera buat yang baru.
Dialogue: 0,0:17:54.04,0:17:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali papannya bisa rusak.
Dialogue: 0,0:17:57.85,0:17:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:17:59.51,0:18:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti ini biasa di rumah kami.
Dialogue: 0,0:18:02.46,0:18:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dirusak orang.
Dialogue: 0,0:18:05.15,0:18:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang merusaknya?
Dialogue: 0,0:18:07.03,0:18:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada makhluk selain manusia\Ndi rumahmu.
Dialogue: 0,0:18:11.24,0:18:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:12.58,0:18:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan…
Dialogue: 0,0:18:15.76,0:18:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia ingin memberitahu\Nkalau papan itu sudah tak mempan.
Dialogue: 0,0:18:20.25,0:18:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan namaku dulu juga sering jatuh.
Dialogue: 0,0:18:23.01,0:18:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu papan nama rumahku sering jatuh.
Dialogue: 0,0:18:24.93,0:18:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah dipasang kuat.
Dialogue: 0,0:18:27.20,0:18:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Tuan Warashi sengaja merusaknya.
Dialogue: 0,0:18:30.05,0:18:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar aku segera menggantinya.
Dialogue: 0,0:18:34.85,0:18:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan nama buatanmu
Dialogue: 0,0:18:37.06,0:18:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengandung kekuatan pelindung rumah.
Dialogue: 0,0:18:41.80,0:18:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus segera membuat\Ndan mengirim papan yang baru.
Dialogue: 0,0:18:44.58,0:18:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa aku bisa membuat\Nyang lebih baik dari sebelumnya?
Dialogue: 0,0:18:49.48,0:18:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus meningkatkan\Nkekuatan tolak balamu.
Dialogue: 0,0:18:53.28,0:18:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meningkatkan kekuatan?
Dialogue: 0,0:18:55.41,0:18:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar kau bisa menyalurkan\Nenergi yang lebih kuat ke papannya.
Dialogue: 0,0:18:59.99,0:19:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya bisa?
Dialogue: 0,0:19:02.19,0:19:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus tingkatkan kekuatan angin.
Dialogue: 0,0:19:05.40,0:19:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah ke tempat yang tepat.
Dialogue: 0,0:19:07.54,0:19:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikuti aku.
Dialogue: 0,0:19:08.92,0:19:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:10.41,0:19:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu belakang?
Dialogue: 0,0:19:12.11,0:19:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba buka.
Dialogue: 0,0:19:17.35,0:19:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:19:19.11,0:19:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba masuk.
Dialogue: 0,0:19:20.36,0:19:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:21.59,0:19:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:25.35,0:19:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Apa yang terjadi?
Dialogue: 0,0:19:30.60,0:19:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato.
Dialogue: 0,0:19:32.63,0:19:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya.
Dialogue: 0,0:19:33.78,0:19:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini wilayah dewa buatan kaumku.
Dialogue: 0,0:19:37.48,0:19:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diciptakan oleh kalian semua?
Dialogue: 0,0:19:38.97,0:19:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarkanlah seluruh kekuatanmu di sini.
Dialogue: 0,0:19:41.95,0:19:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini?
Dialogue: 0,0:19:43.16,0:19:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak mau merusak\Npohon di sini tanpa alasan.
Dialogue: 0,0:19:46.90,0:19:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:19:49.05,0:19:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya palsu.
Dialogue: 0,0:19:50.36,0:19:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Palsu?
Dialogue: 0,0:19:51.68,0:19:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebanglah sesuka hatimu.
Dialogue: 0,0:19:55.25,0:19:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ragu, kerahkan kekuatan penuhmu.
Dialogue: 0,0:19:58.74,0:19:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:20:02.31,0:20:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Tuan Rumah sedang berburu kerabatnya?
Dialogue: 0,0:20:07.43,0:20:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus tinggalkan tanda terima kasih.
Dialogue: 0,0:20:18.65,0:20:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa ini?
Dialogue: 0,0:20:20.36,0:20:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keterlaluan, membuang sampah\Nsaat Tuan Rumah pergi.
Dialogue: 0,0:20:24.33,0:20:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa pulang lagi!
Dialogue: 0,0:20:25.87,0:20:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampah apa? Jaga bicaramu!
Dialogue: 0,0:20:28.25,0:20:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buah.
Dialogue: 0,0:20:30.81,0:20:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sangat lezat.
Dialogue: 0,0:20:49.84,0:20:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan kekuatan penuh.
Dialogue: 0,0:21:01.39,0:21:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh…
Dialogue: 0,0:21:12.68,0:21:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda yang memindahkanku ke sini?
Dialogue: 0,0:21:16.32,0:21:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengeluarkan terlalu\Nbanyak tenaga sekaligus.
Dialogue: 0,0:21:19.08,0:21:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:21:20.58,0:21:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya latihanku kurang.
Dialogue: 0,0:21:41.33,0:21:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:21:42.37,0:21:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya energi kali ini lebih besar.
Dialogue: 0,0:21:46.12,0:21:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau begitu.
Dialogue: 0,0:21:53.97,0:21:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi di sini?
Dialogue: 0,0:23:32.23,0:23:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode keempat.
Dialogue: 0,0:23:33.48,0:23:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi ke Dunia Lain untuk\NMengusir Siluman, Berangkat Sekarang.
