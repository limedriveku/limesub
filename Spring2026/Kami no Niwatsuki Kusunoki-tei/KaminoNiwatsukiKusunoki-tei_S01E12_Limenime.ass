Dialogue: 0,0:02:38.04,0:02:42.93,sign,,0000,0000,0000,,(TAMAN DEWA KUSUNOKI)
Dialogue: 0,0:03:27.49,0:03:28.59,sign,,0000,0000,0000,,"ECHIGOYA"
Dialogue: 0,0:04:39.29,0:04:43.15,sign,,0000,0000,0000,,USIR
Dialogue: 0,0:06:22.22,0:06:24.58,sign,,0000,0000,0000,,USIR
Dialogue: 0,0:08:29.81,0:08:31.83,sign,,0000,0000,0000,,"PENERBITAN MUSASHI"
Dialogue: 0,0:11:18.33,0:11:19.71,sign,,0000,0000,0000,,"ECHIGOYA, MANJU SPESIAL"
Dialogue: 0,0:18:01.84,0:18:04.55,sign,,0000,0000,0000,,"PENGINAPAN KUSUNOKI"
Dialogue: 0,0:23:37.38,0:23:39.40,sign,,0000,0000,0000,,SAMPAI JUMPA
Dialogue: 0,0:00:09.81,0:00:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung!
Dialogue: 0,0:00:19.12,0:00:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, jangan dipaksakan!
Dialogue: 0,0:00:31.97,0:00:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Dewa Gunung!
Dialogue: 0,0:00:35.64,0:00:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh sekali.
Dialogue: 0,0:00:39.48,0:00:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Tenko?
Dialogue: 0,0:00:41.45,0:00:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:00:43.03,0:00:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kukatakan?
Dialogue: 0,0:00:44.45,0:00:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu dekat dengan manusia,\Nakan menghancurkan diri sendiri.
Dialogue: 0,0:00:48.92,0:00:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa aku gunakan kekuatanku,\Nitu adalah kebebasanku.
Dialogue: 0,0:00:51.83,0:00:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak berhak ikut campur!
Dialogue: 0,0:00:54.71,0:00:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang di kota ini tidak percaya\Nakan keberadaanmu.
Dialogue: 0,0:01:00.49,0:01:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah lama melupakan\Nasal-usul festival ini.
Dialogue: 0,0:01:02.44,0:01:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya larut dalam pesta pora.
Dialogue: 0,0:01:05.01,0:01:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya itu.
Dialogue: 0,0:01:06.81,0:01:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada orang yang terbelenggu nafsu,\Nhanya mementingkan keinginan pribadi,
Dialogue: 0,0:01:09.67,0:01:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang lebih merepotkan daripada roh jahat.
Dialogue: 0,0:01:13.50,0:01:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau ingin menggunakan kekuatan\Nuntuk orang-orang seperti itu?
Dialogue: 0,0:01:17.75,0:01:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini peringatan terakhirku, berhentilah.
Dialogue: 0,0:01:22.61,0:01:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung!
Dialogue: 0,0:01:24.33,0:01:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenko, camilan buatan manusia itu\Nsangat enak, lo.
Dialogue: 0,0:01:28.80,0:01:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:01:42.80,0:01:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:01:46.43,0:01:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu…
Dialogue: 0,0:01:53.94,0:01:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu masuk ke wilayah dewa\Nterbengkalai sudah hilang.
Dialogue: 0,0:01:55.84,0:01:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Tuan Dewa Gunung!
Dialogue: 0,0:01:57.70,0:02:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan senang dulu.
Dialogue: 0,0:02:11.62,0:02:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:02:13.01,0:02:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biang keladi dari semua ini, roh jahat.
Dialogue: 0,0:02:15.36,0:02:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Anda sudah mengusirnya?
Dialogue: 0,0:02:17.38,0:02:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, dia muncul di dunia ini\Ntepat sebelum pintu masuk
Dialogue: 0,0:02:20.75,0:02:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke wilayah dewa menghilang.
Dialogue: 0,0:02:22.86,0:02:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu biang keladinya?
Dialogue: 0,0:02:27.77,0:02:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, aku tidak bisa lagi menggunakan\Nkekuatan mengusir roh jahat.
Dialogue: 0,0:02:32.93,0:02:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan kekuatanmu\Nuntuk mengusir roh jahat itu.
Dialogue: 0,0:02:46.75,0:02:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya sebanyak itu,\Nbagaimana cara mengusirnya?
Dialogue: 0,0:02:49.16,0:02:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gentar, bukankah kau\Nmemiliki kekuatan mengusir roh jahat?
Dialogue: 0,0:02:53.82,0:02:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka datang!
Dialogue: 0,0:03:01.46,0:03:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya.
Dialogue: 0,0:03:03.12,0:03:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu…
Dialogue: 0,0:03:14.20,0:03:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima!
Dialogue: 0,0:03:15.76,0:03:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu tertolong oleh jimatmu.
Dialogue: 0,0:03:19.34,0:03:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini giliranku membantumu.
Dialogue: 0,0:03:27.49,0:03:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek!
Dialogue: 0,0:03:28.59,0:03:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini, tiba-tiba aku sesak napas?
Dialogue: 0,0:03:32.20,0:03:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku tidak bisa kugerakkan.
Dialogue: 0,0:03:36.56,0:03:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah.
Dialogue: 0,0:03:38.26,0:03:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akibat energi jahat,\Norang-orang di kota tampak menderita.
Dialogue: 0,0:03:42.25,0:03:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mendapat pengaruh dari roh jahat?
Dialogue: 0,0:03:44.69,0:03:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika begini terus, tidak lama lagi
Dialogue: 0,0:03:46.72,0:03:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung juga tidak bisa\Nmempertahankan wujudnya.
Dialogue: 0,0:03:49.69,0:03:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:50.78,0:03:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu artinya aku tidak bisa\Nbertemu dengan Tuan Dewa Gunung lagi?
Dialogue: 0,0:03:55.14,0:03:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:03:58.44,0:04:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menyelamatkanmu!
Dialogue: 0,0:04:01.24,0:04:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri harus berhati-hati.
Dialogue: 0,0:04:09.63,0:04:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sudah mencapai batas kemampuanku.
Dialogue: 0,0:04:12.44,0:04:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima.
Dialogue: 0,0:04:14.97,0:04:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua jimat terbawa angin.
Dialogue: 0,0:04:17.61,0:04:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Terbawa angin?
Dialogue: 0,0:04:19.72,0:04:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:21.14,0:04:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:04:28.02,0:04:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini… jimat.
Dialogue: 0,0:04:30.53,0:04:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar merepotkan.
Dialogue: 0,0:04:32.78,0:04:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat orang khawatir saja.
Dialogue: 0,0:04:34.74,0:04:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Fujin, terima kasih.
Dialogue: 0,0:04:36.98,0:04:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampaikan terima kasih pada Roh Angin saja.
Dialogue: 0,0:04:43.55,0:04:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat, semangat!
Dialogue: 0,0:04:45.71,0:04:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya.
Dialogue: 0,0:04:46.71,0:04:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:04:47.72,0:04:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:50.58,0:04:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima!
Dialogue: 0,0:04:57.92,0:04:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima, gunakan ini.
Dialogue: 0,0:05:01.20,0:05:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertolong.
Dialogue: 0,0:05:02.85,0:05:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan memikirkan cara\Nuntuk menyingkirkan roh jahat di kota.
Dialogue: 0,0:05:06.14,0:05:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki Minato,
Dialogue: 0,0:05:07.53,0:05:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisakah kau menggunakan kekuatanmu\Nuntuk menghadapi biang keladi itu?
Dialogue: 0,0:05:10.21,0:05:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:11.21,0:05:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin aku menghadapi itu?
Dialogue: 0,0:05:12.73,0:05:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana caranya?
Dialogue: 0,0:05:14.78,0:05:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:05:15.92,0:05:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bisa menggunakan angin\Nuntuk menerbangkan jimat ke dekatnya…
Dialogue: 0,0:05:19.32,0:05:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan bagus\Nuntuk menunjukkan kekuatan anginmu, lo.
Dialogue: 0,0:05:23.11,0:05:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kucoba.
Dialogue: 0,0:05:25.45,0:05:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, mohon bantuannya.
Dialogue: 0,0:05:28.60,0:05:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekaranglah saatnya menunjukkan\Nkemampuan kekuatan yang kuberikan.
Dialogue: 0,0:05:32.39,0:05:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai gagal, ya.
Dialogue: 0,0:05:46.82,0:05:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil dihadang.
Dialogue: 0,0:05:51.05,0:05:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus,\Nroh jahat pun tak bisa kusentuh.
Dialogue: 0,0:05:53.94,0:05:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:05:57.99,0:05:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:05:59.26,0:06:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, dia datang.
Dialogue: 0,0:06:09.40,0:06:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus…
Dialogue: 0,0:06:15.89,0:06:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia.
Dialogue: 0,0:06:18.90,0:06:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia teringat sesuatu.
Dialogue: 0,0:06:27.83,0:06:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berputar, angin akan menguat.
Dialogue: 0,0:06:31.09,0:06:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti cara bermain gasing, ya?\NKau pintar juga memikirkannya.
Dialogue: 0,0:06:41.69,0:06:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan angin telah menyingkirkan\Nenergi negatif.
Dialogue: 0,0:06:44.29,0:06:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga.
Dialogue: 0,0:06:53.07,0:06:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:06:55.72,0:06:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau yang membual\Nbisa menyelamatkan Dewa Gunung?
Dialogue: 0,0:06:59.61,0:07:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Nona Tenko.
Dialogue: 0,0:07:29.68,0:07:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil.
Dialogue: 0,0:07:31.76,0:07:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hisui.
Dialogue: 0,0:07:33.30,0:07:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:00.98,0:08:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai sudah.
Dialogue: 0,0:08:02.51,0:08:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja yang bagus.
Dialogue: 0,0:08:04.19,0:08:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya.
Dialogue: 0,0:08:10.56,0:08:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:08:11.66,0:08:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki Minato, kau tidak apa-apa?
Dialogue: 0,0:08:14.12,0:08:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima, aku tidak apa-apa.
Dialogue: 0,0:08:18.07,0:08:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, bagaimana dengan\Norang-orang di kota?
Dialogue: 0,0:08:20.45,0:08:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal ini…
Dialogue: 0,0:08:22.87,0:08:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek, kau sudah tidak apa-apa?
Dialogue: 0,0:08:26.17,0:08:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi Tuan Inu,\Naku harus segera bersiap-siap.
Dialogue: 0,0:08:28.82,0:08:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:29.81,0:08:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tadi itu…
Dialogue: 0,0:08:31.83,0:08:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direktur, kumohon bertahanlah.
Dialogue: 0,0:08:33.98,0:08:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok adalah Festival Hojo, lo.
Dialogue: 0,0:08:35.78,0:08:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya.
Dialogue: 0,0:08:37.47,0:08:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi Tuan Dewa Gunung, kita harus kejar.
Dialogue: 0,0:08:40.33,0:08:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat telah menghilang dari kota.
Dialogue: 0,0:08:42.49,0:08:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar melakukannya dengan baik.
Dialogue: 0,0:08:44.37,0:08:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku juga harus\Nberterima kasih pada kalian.
Dialogue: 0,0:08:50.09,0:08:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:08:55.06,0:08:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,\Nkau sudah kembali ke wujud semula.
Dialogue: 0,0:08:57.76,0:08:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kau lihat.
Dialogue: 0,0:08:59.47,0:09:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Anda sudah tidak apa-apa?
Dialogue: 0,0:09:01.00,0:09:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:09:02.82,0:09:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah Dewa Gunung.
Dialogue: 0,0:09:05.31,0:09:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah niat hati semua orang di kota\Nyang membangkitkanmu?
Dialogue: 0,0:09:09.59,0:09:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:13.54,0:09:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, i-ini terlalu terang.
Dialogue: 0,0:09:16.83,0:09:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, tahanlah sedikit.
Dialogue: 0,0:09:22.83,0:09:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Tenko.
Dialogue: 0,0:09:23.96,0:09:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda sangat membantu tadi.
Dialogue: 0,0:09:26.72,0:09:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian benar-benar bodoh.
Dialogue: 0,0:09:32.92,0:09:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Dewa Gunung,
Dialogue: 0,0:09:34.38,0:09:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya kau bertemu manusia yang baik.
Dialogue: 0,0:09:49.06,0:09:50.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh sial sekali.
Dialogue: 0,0:09:50.73,0:09:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah muak dengan kota seperti ini.
Dialogue: 0,0:09:53.76,0:09:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:55.14,0:09:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik kita cepat kabur.
Dialogue: 0,0:09:57.91,0:10:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat semua kejahatan yang kalian\Nlakukan sebelumnya,
Dialogue: 0,0:10:00.50,0:10:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai sesama pengusir roh,\Naku tidak bisa tinggal diam.
Dialogue: 0,0:10:03.78,0:10:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah nasib kalian.
Dialogue: 0,0:10:05.38,0:10:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sharchi!
Dialogue: 0,0:10:10.04,0:10:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:10:20.15,0:10:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:10:21.39,0:10:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival Hojo tiga tahun sekali\Ntelah berhasil diselenggarakan.
Dialogue: 0,0:10:27.76,0:10:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:10:28.95,0:10:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:10:31.23,0:10:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi, habiskan dulu baru bicara.
Dialogue: 0,0:10:34.50,0:10:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin makan itu.
Dialogue: 0,0:10:36.34,0:10:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, itu tidak sopan, lo.\N- Yang ini juga lumayan enak.
Dialogue: 0,0:10:46.99,0:10:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir.
Dialogue: 0,0:10:55.58,0:10:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, Tuan Dewa Gunung, itu curang.
Dialogue: 0,0:10:58.71,0:11:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Apa yang kau bicarakan?
Dialogue: 0,0:11:03.57,0:11:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untukmu.
Dialogue: 0,0:11:07.05,0:11:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,\Nbagaimana rasa manju spesialnya?
Dialogue: 0,0:11:11.73,0:11:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manju memang harus\Nyang pasta kacang merah halus.
Dialogue: 0,0:11:14.49,0:11:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini makanan kesukaan Tuan Inu.
Dialogue: 0,0:11:16.37,0:11:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manju spesial, lo.
Dialogue: 0,0:11:18.33,0:11:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba satu?
Dialogue: 0,0:11:19.71,0:11:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesukaan Tuan Inu.
Dialogue: 0,0:11:22.34,0:11:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini serigala!
Dialogue: 0,0:11:33.81,0:11:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmati saja hari seperti ini.
Dialogue: 0,0:11:38.70,0:11:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya hari ini saja, ya.
Dialogue: 0,0:11:40.65,0:11:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau makan?
Dialogue: 0,0:11:43.66,0:11:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:11:45.81,0:11:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau.
Dialogue: 0,0:11:47.43,0:11:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat bergabung dengan yang lain.
Dialogue: 0,0:11:49.55,0:11:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:10.23,0:12:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik sekali.
Dialogue: 0,0:12:12.02,0:12:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:12:19.22,0:12:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:21.14,0:12:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:12:38.41,0:12:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Katsuragi, aku pulang.
Dialogue: 0,0:12:42.13,0:12:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, bagaimana dengan\Npara pengusir roh itu?
Dialogue: 0,0:12:44.81,0:12:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya, mereka tampak\Nhidup tenang di kota sebelah.
Dialogue: 0,0:12:48.48,0:12:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau begitu.
Dialogue: 0,0:12:50.25,0:12:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aneh juga, ya.
Dialogue: 0,0:12:52.61,0:12:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:53.90,0:12:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku mendapat laporan\Ndan bergegas ke sana hari itu,
Dialogue: 0,0:12:56.64,0:12:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ansho dan Enno sudah ditangkap.
Dialogue: 0,0:12:59.42,0:13:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ditanya siapa yang memukul mereka,
Dialogue: 0,0:13:01.22,0:13:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka malah bilang tidak ingat apa-apa.
Dialogue: 0,0:13:04.39,0:13:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya?
Dialogue: 0,0:13:06.99,0:13:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau penasaran? Itu…
Dialogue: 0,0:13:09.40,0:13:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:13:11.25,0:13:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat muncul di dekat pemakaman.
Dialogue: 0,0:13:16.36,0:13:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih harus bekerja?
Dialogue: 0,0:13:18.66,0:13:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Tuan Katsuragi.
Dialogue: 0,0:13:20.57,0:13:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu aku!
Dialogue: 0,0:13:23.27,0:13:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harima, jangan tinggalkan aku.
Dialogue: 0,0:13:25.16,0:13:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikawa.
Dialogue: 0,0:13:26.68,0:13:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, jangan berkeliaran\Ntanpa sepengetahuanku!
Dialogue: 0,0:13:30.50,0:13:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa khawatir padamu.
Dialogue: 0,0:13:33.67,0:13:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kau selalu jadi beban.
Dialogue: 0,0:13:38.15,0:13:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan suara itu!
Dialogue: 0,0:13:39.87,0:13:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:13:41.56,0:13:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, ayo kita pergi.
Dialogue: 0,0:13:51.78,0:13:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hangat sekali.
Dialogue: 0,0:13:54.22,0:13:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim dingin memang harus berendam onsen.
Dialogue: 0,0:13:58.08,0:14:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:14:00.76,0:14:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini…
Dialogue: 0,0:14:01.97,0:14:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsumugi?
Dialogue: 0,0:14:03.12,0:14:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:04.97,0:14:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau datang?
Dialogue: 0,0:14:07.07,0:14:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu, dewa kami\Nsangat tidak sopan padamu.
Dialogue: 0,0:14:10.72,0:14:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak sopan bagaimana.
Dialogue: 0,0:14:13.52,0:14:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat berterima kasih\Ndia sudah membantuku.
Dialogue: 0,0:14:16.81,0:14:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berendam onsen?
Dialogue: 0,0:14:18.34,0:14:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah?
Dialogue: 0,0:14:20.08,0:14:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sekadar ungkapan rasa terima kasih.
Dialogue: 0,0:14:22.17,0:14:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini juga ada inarizushi, lo.
Dialogue: 0,0:14:24.39,0:14:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, izinkan aku mencicipinya!
Dialogue: 0,0:14:27.18,0:14:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kau.
Dialogue: 0,0:14:30.79,0:14:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:14:35.57,0:14:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:14:41.44,0:14:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:14:45.63,0:14:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga enak sekali.
Dialogue: 0,0:14:48.86,0:14:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak, lo.
Dialogue: 0,0:14:52.86,0:14:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, isi di dalamnya berbeda-beda.
Dialogue: 0,0:14:55.32,0:14:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya enak sekali.
Dialogue: 0,0:14:59.07,0:15:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Fujin, Tuan Raijin.
Dialogue: 0,0:15:01.39,0:15:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan kami bergabung juga.
Dialogue: 0,0:15:03.33,0:15:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, silakan.
Dialogue: 0,0:15:05.16,0:15:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah banyak dibantu\Noleh kalian berdua.
Dialogue: 0,0:15:08.95,0:15:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada yang datang lagi.
Dialogue: 0,0:15:12.21,0:15:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:15:19.24,0:15:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan itu…
Dialogue: 0,0:15:20.52,0:15:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini? Ramai sekali.
Dialogue: 0,0:15:23.56,0:15:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ebi.
Dialogue: 0,0:15:25.43,0:15:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:15:27.54,0:15:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:15:28.56,0:15:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sebenarnya
Dialogue: 0,0:15:30.76,0:15:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hari ini aku punya kabar baik untukmu.
Dialogue: 0,0:15:36.91,0:15:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa ini?
Dialogue: 0,0:15:38.63,0:15:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncul lagi perasaan aneh,\Naku tidak boleh kalah darinya.
Dialogue: 0,0:15:54.88,0:15:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bumbu hari ini lumayan enak.
Dialogue: 0,0:15:57.43,0:15:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Susanoo, sejak kapan kau di sini?
Dialogue: 0,0:15:59.59,0:16:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf ganggu.
Dialogue: 0,0:16:00.96,0:16:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa?
Dialogue: 0,0:16:02.79,0:16:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir, aku akan membantumu\Nlatihan khusus lagi.
Dialogue: 0,0:16:05.58,0:16:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan khusus? Sekarang?
Dialogue: 0,0:16:07.51,0:16:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu melawan roh jahat tempo hari,\Nbukankah kau sangat kesulitan?
Dialogue: 0,0:16:11.63,0:16:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengusirnya.
Dialogue: 0,0:16:14.16,0:16:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan anginmu masih terlalu lemah.
Dialogue: 0,0:16:17.46,0:16:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Tua, aku pinjam bocah ini ya.
Dialogue: 0,0:16:19.68,0:16:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kau.
Dialogue: 0,0:16:21.20,0:16:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:16:22.97,0:16:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan banyak omong!
Dialogue: 0,0:16:24.84,0:16:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:16:25.90,0:16:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak perlu.
Dialogue: 0,0:16:27.71,0:16:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung!
Dialogue: 0,0:16:29.33,0:16:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, jangan berlama-lama.
Dialogue: 0,0:16:31.47,0:16:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susanoo.
Dialogue: 0,0:16:33.87,0:16:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu kau.
Dialogue: 0,0:16:36.22,0:16:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:16:37.73,0:16:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amaterasu.
Dialogue: 0,0:16:39.28,0:16:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kabur lagi tanpa izin, ya.
Dialogue: 0,0:16:42.62,0:16:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kenapa kau kasar sekali\Npada manusia?
Dialogue: 0,0:16:45.91,0:16:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ini demi kebaikannya.
Dialogue: 0,0:16:49.49,0:16:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang seperti ini, gunakan saja\Nkekuatan yang kuberikan padamu
Dialogue: 0,0:16:52.21,0:16:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengurungnya\Ndi suatu wilayah dewa terbengkalai.
Dialogue: 0,0:16:58.90,0:17:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan harap bisa kabur.
Dialogue: 0,0:17:01.63,0:17:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, ampunilah aku.
Dialogue: 0,0:17:03.22,0:17:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan mengampunimu.
Dialogue: 0,0:17:04.85,0:17:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau, jangan tertawa!
Dialogue: 0,0:17:06.13,0:17:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara seperti itu.
Dialogue: 0,0:17:07.48,0:17:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:09.42,0:17:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau apes sekali waktu itu.
Dialogue: 0,0:17:13.44,0:17:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak, bukan masalah besar.
Dialogue: 0,0:17:15.96,0:17:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk merayakan kau sudah pulih\Ndan kembali normal.
Dialogue: 0,0:17:17.98,0:17:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo minum.
Dialogue: 0,0:17:19.01,0:17:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas niat baiknya,\Naku punya ini.
Dialogue: 0,0:17:24.11,0:17:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar suka makanan manis, ya.
Dialogue: 0,0:17:26.81,0:17:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau makan?
Dialogue: 0,0:17:28.28,0:17:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau dijadikan teman minum?
Dialogue: 0,0:17:30.73,0:17:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar mantap.
Dialogue: 0,0:17:34.05,0:17:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untukmu.
Dialogue: 0,0:17:35.25,0:17:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:37.58,0:17:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan merepotkan manusia.
Dialogue: 0,0:17:40.04,0:17:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu kau selalu\Nsetengah-setengah begitu.
Dialogue: 0,0:17:48.89,0:17:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Ibu?
Dialogue: 0,0:17:51.86,0:17:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah terima paketnya, terima kasih.
Dialogue: 0,0:17:54.42,0:17:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak pernah menghubungiku,\Napa kabarmu?
Dialogue: 0,0:17:59.02,0:18:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja, jadi jangan khawatir.
Dialogue: 0,0:18:00.81,0:18:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:18:01.84,0:18:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisnis penginapan onsen ramai sekali.
Dialogue: 0,0:18:04.99,0:18:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti berkat papan nama yang kau buat.
Dialogue: 0,0:18:08.60,0:18:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manju yang kau kirim,\Nsudah aku nikmati juga, lo.
Dialogue: 0,0:18:15.12,0:18:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:18:16.13,0:18:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Camilan pilihan Minato,\Nmemang tidak pernah salah.
Dialogue: 0,0:18:18.87,0:18:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali, kau pulanglah.
Dialogue: 0,0:18:21.52,0:18:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin begitu,
Dialogue: 0,0:18:23.20,0:18:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi menjadi pengurus di sini\Nlebih sibuk dari yang kubayangkan.
Dialogue: 0,0:18:26.58,0:18:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat menyenangkan.
Dialogue: 0,0:18:27.66,0:18:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Kalau begitu,\Ntolong urus terus, ya.
Dialogue: 0,0:18:31.03,0:18:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:18:32.04,0:18:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya.
Dialogue: 0,0:18:33.08,0:18:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masukkan paket camilan\Nhasil undian ke dalamnya, lo.
Dialogue: 0,0:18:42.91,0:18:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, bagaimana?
Dialogue: 0,0:18:44.51,0:18:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kenyal sekali, aku suka.
Dialogue: 0,0:18:48.31,0:18:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:18:49.66,0:18:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu gum anjing\Nyang tidak sengaja dikirim ibuku.
Dialogue: 0,0:18:53.43,0:18:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anjing? Aku ini serigala!
Dialogue: 0,0:18:56.74,0:18:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tidak cocok, ya?
Dialogue: 0,0:19:02.30,0:19:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini barang yang kau minta.
Dialogue: 0,0:19:04.68,0:19:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuanmu selama ini.
Dialogue: 0,0:19:06.32,0:19:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami seluruh onmyoji,\Nsangat berterima kasih padamu.
Dialogue: 0,0:19:08.85,0:19:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak, tidak.
Dialogue: 0,0:19:10.00,0:19:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dorayaki pasta kacang merah krim asin.
Dialogue: 0,0:19:12.37,0:19:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya enak.
Dialogue: 0,0:19:14.21,0:19:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, maukah kau minum teh dulu\Nsebelum pergi?
Dialogue: 0,0:19:17.04,0:19:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas niat baiknya,\Ntapi aku tidak punya waktu.
Dialogue: 0,0:19:19.40,0:19:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat muncul lagi.
Dialogue: 0,0:19:21.46,0:19:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Hati-hati.
Dialogue: 0,0:19:26.59,0:19:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih sama seperti biasanya, ya.
Dialogue: 0,0:19:30.29,0:19:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krim asin dan pasta kacang merah.
Dialogue: 0,0:19:33.25,0:19:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perpaduan Jepang dan Barat, ya.
Dialogue: 0,0:19:36.58,0:19:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa para kerabat dapat dorayaki,
Dialogue: 0,0:19:38.71,0:19:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah dapat gum anjing?
Dialogue: 0,0:19:40.86,0:19:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat tidak adil.
Dialogue: 0,0:19:42.43,0:19:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf. Ada juga bagian untukmu.
Dialogue: 0,0:19:45.73,0:19:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dorayaki cukup diisi dengan\Npasta kacang merah saja, 'kan?
Dialogue: 0,0:19:48.53,0:19:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menambahkan krim asin\Nbukankah itu aliran sesat?
Dialogue: 0,0:19:53.24,0:19:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Tidak cocok dengan seleramu?
Dialogue: 0,0:19:58.87,0:20:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:20:01.88,0:20:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, sepertinya cocok dengan seleramu.
Dialogue: 0,0:20:07.53,0:20:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasta kacang merah dan krim asin\Nternyata sangat cocok.
Dialogue: 0,0:20:10.32,0:20:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama kali\Nmakan dorayaki seperti ini.
Dialogue: 0,0:20:13.21,0:20:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dora… yaki?
Dialogue: 0,0:20:16.64,0:20:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau terkejut begitu?
Dialogue: 0,0:20:18.79,0:20:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dora adalah alat musik pukul\Nyang terbuat dari logam.
Dialogue: 0,0:20:21.92,0:20:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa memanggang benda seperti itu\Nuntuk dimakan?
Dialogue: 0,0:20:24.39,0:20:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia benar-benar menakutkan.
Dialogue: 0,0:20:27.39,0:20:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun omnivora, ini sudah berlebihan.
Dialogue: 0,0:20:30.64,0:20:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:20:31.99,0:20:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membosankan, sake-nya jadi tidak enak.
Dialogue: 0,0:20:37.70,0:20:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lulus.
Dialogue: 0,0:20:38.97,0:20:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terakhir giliranmu.
Dialogue: 0,0:20:42.40,0:20:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ikut teriak denganku.
Dialogue: 0,0:20:54.85,0:20:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lulus, aku perlu memujimu.
Dialogue: 0,0:20:58.57,0:21:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kelas luar ruangan Tuan Tori\Nakan segera berakhir?
Dialogue: 0,0:21:01.48,0:21:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:21:04.98,0:21:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori, sudah bekerja keras.
Dialogue: 0,0:21:15.79,0:21:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:21:18.04,0:21:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, hanya merasa kehidupan seperti ini\Nsangat menyenangkan.
Dialogue: 0,0:21:24.07,0:21:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat suka menjalani\Nhari-hari di sini bersama semuanya.
Dialogue: 0,0:21:28.82,0:21:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku akan terus\Nmenjadi pengurus Kusunoki.
Dialogue: 0,0:21:37.98,0:21:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:21:43.19,0:21:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh dewa yang pernah diselamatkan.
Dialogue: 0,0:21:45.82,0:21:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah akan bangkit?
Dialogue: 0,0:21:52.66,0:21:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Dewa Gunung, ini…
Dialogue: 0,0:22:04.13,0:22:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tupai terbang?
Dialogue: 0,0:22:05.97,0:22:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu sekali.
Dialogue: 0,0:22:07.75,0:22:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini, kau adalah kerabatku.
Dialogue: 0,0:22:12.61,0:22:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kusunoki Minato, mohon bantuannya.
Dialogue: 0,0:22:18.93,0:22:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Kusunoki.
