Dialogue: 0,0:02:32.99,0:02:37.95,sign,,0000,0000,0000,,LATIHAN PAKSA BERSAMA DEWA MURKA
Dialogue: 0,0:02:54.89,0:02:56.38,sign,,0000,0000,0000,,"USIR"
Dialogue: 0,0:06:15.43,0:06:18.19,sign,,0000,0000,0000,,"SUSANOO"
Dialogue: 0,0:13:47.46,0:13:48.37,sign,,0000,0000,0000,,USIR
Dialogue: 0,0:23:37.20,0:23:39.20,sign,,0000,0000,0000,,SELANJUTNYA:\NDENDAM ROH JAHAT MENODAI RITUAL
Dialogue: 0,0:00:13.20,0:00:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, silakan masuk.
Dialogue: 0,0:00:16.77,0:00:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah datang?
Dialogue: 0,0:00:27.23,0:00:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekanan yang belum pernah kurasakan…
Dialogue: 0,0:00:30.43,0:00:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini masih bisa ditahan?\NBenar-benar hebat.
Dialogue: 0,0:00:34.21,0:00:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tekanannya lebih besar\Ndari sebelumnya.
Dialogue: 0,0:00:36.57,0:00:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegigihan yang patut dikagumi.
Dialogue: 0,0:00:38.15,0:00:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tidak main-main.
Dialogue: 0,0:00:39.81,0:00:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memberi tekanan lagi.
Dialogue: 0,0:00:44.49,0:00:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima.
Dialogue: 0,0:00:46.34,0:00:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk, lewat sini.
Dialogue: 0,0:00:52.18,0:00:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kepala pun terasa sangat berat.
Dialogue: 0,0:00:56.03,0:00:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Tuan Tori juga seperti ini.
Dialogue: 0,0:00:58.55,0:01:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada sesuatu\Nyang melilit leherku.
Dialogue: 0,0:01:13.80,0:01:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:02:39.58,0:02:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah jimat untuk menyegel\Nkekuatan mengusir roh jahat itu berguna?
Dialogue: 0,0:02:45.30,0:02:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efeknya tahan lama, jadi sangat membantu.
Dialogue: 0,0:02:48.64,0:02:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:02:50.11,0:02:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belakangan ini di kota\Nsering muncul roh jahat.
Dialogue: 0,0:02:54.89,0:02:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak bisa diusir semua,
Dialogue: 0,0:02:56.38,0:02:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami menempelkan jimat di seluruh kota\Nuntuk mengatasinya.
Dialogue: 0,0:02:59.90,0:03:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak peduli berapa banyak\Nyang ditempel,
Dialogue: 0,0:03:02.35,0:03:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}roh jahat tidak berkurang,\Nmalah terus bertambah.
Dialogue: 0,0:03:06.21,0:03:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertambah? Kenapa?
Dialogue: 0,0:03:08.64,0:03:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini sedang diselidiki penyebabnya.
Dialogue: 0,0:03:12.21,0:03:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga, baguslah bisa membantu.
Dialogue: 0,0:03:16.02,0:03:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah terima kasih, silakan diterima.
Dialogue: 0,0:03:18.44,0:03:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebanyak ini?
Dialogue: 0,0:03:20.14,0:03:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari sepupu-sepupuku.
Dialogue: 0,0:03:22.42,0:03:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyuruhku menyampaikan salam\Nuntuk Tuan Hisui.
Dialogue: 0,0:03:26.59,0:03:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hisui?
Dialogue: 0,0:03:28.06,0:03:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kekuatanmu untuk mengusir roh jahat\Nmemancarkan cahaya hijau zamrud.
Dialogue: 0,0:03:34.63,0:03:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru pertama kali aku dengar ini.
Dialogue: 0,0:03:36.81,0:03:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tidak bisa melihatnya.
Dialogue: 0,0:03:43.98,0:03:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wangi sekali.
Dialogue: 0,0:03:46.41,0:03:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cium dulu.
Dialogue: 0,0:03:47.37,0:03:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak sabar ingin coba.
Dialogue: 0,0:03:49.98,0:03:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuterima semua ini dengan penuh syukur.
Dialogue: 0,0:03:52.32,0:03:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, apakah sebelumnya ada dua\Npengusir roh yang masuk ke rumah ini?
Dialogue: 0,0:03:58.39,0:04:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:04:00.13,0:04:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya ada dua orang\Nyang sangat bau itu?
Dialogue: 0,0:04:02.44,0:04:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka benar-benar keterlaluan.
Dialogue: 0,0:04:04.90,0:04:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berhasil mengusir mereka.
Dialogue: 0,0:04:06.93,0:04:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah terjadi hal seperti itu?
Dialogue: 0,0:04:09.32,0:04:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:10.64,0:04:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka pernah datang,\Ntapi diusir pulang.
Dialogue: 0,0:04:14.08,0:04:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak kapok,\Nmungkin masih ada taktik lain.
Dialogue: 0,0:04:18.05,0:04:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah berwaspada.
Dialogue: 0,0:04:19.95,0:04:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:04:32.70,0:04:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Tuan Dewa Gunung?
Dialogue: 0,0:04:35.17,0:04:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkait perkataan pria itu…
Dialogue: 0,0:04:37.48,0:04:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Tuan Harima bilang muncul\Nbanyak roh jahat di kota?
Dialogue: 0,0:04:41.99,0:04:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:43.20,0:04:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya ada kekuatan jahat\Nyang sedang mengganggu.
Dialogue: 0,0:04:46.83,0:04:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan jahat?
Dialogue: 0,0:04:49.19,0:04:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga masalahnya tidak makin besar.
Dialogue: 0,0:04:52.72,0:04:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, semoga tidak terjadi apa-apa.
Dialogue: 0,0:04:59.71,0:05:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya akan terjadi sesuatu.
Dialogue: 0,0:05:14.79,0:05:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:05:18.50,0:05:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, salam kenal.
Dialogue: 0,0:05:24.11,0:05:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau
Dialogue: 0,0:05:25.44,0:05:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diberi kekuatan oleh para dewa?
Dialogue: 0,0:05:30.62,0:05:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan jahat yang dikatakan\NTuan Dewa Gunung,
Dialogue: 0,0:05:32.94,0:05:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan-jangan…
Dialogue: 0,0:05:38.82,0:05:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung tampaknya\Nsama sekali tidak tertarik.
Dialogue: 0,0:05:41.92,0:05:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mendengar kakakku\Nmenceritakan tentangmu.
Dialogue: 0,0:05:45.93,0:05:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakmu?
Dialogue: 0,0:05:47.19,0:05:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai membuat kakakku\Nmeminjamkan kekuatan padamu,
Dialogue: 0,0:05:49.65,0:05:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kupikir manusia sehebat apa,\Nsampai aku sengaja datang melihat,
Dialogue: 0,0:05:52.51,0:05:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata hanya bocah yang tak mencolok.
Dialogue: 0,0:05:54.79,0:05:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meminjamkan kekuatan padaku…
Dialogue: 0,0:06:00.79,0:06:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Amaterasu?
Dialogue: 0,0:06:03.22,0:06:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:04.59,0:06:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:06:05.92,0:06:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara soal ular berkepala delapan…
Dialogue: 0,0:06:08.65,0:06:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu Yamata no Orochi?
Dialogue: 0,0:06:12.00,0:06:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya Anda adalah Susanoo?
Dialogue: 0,0:06:15.43,0:06:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:18.85,0:06:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan segel yang diberikan\Noleh Amaterasu,
Dialogue: 0,0:06:21.61,0:06:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kugunakan dengan sangat hati-hati.
Dialogue: 0,0:06:23.84,0:06:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sampaikan salamku padanya.
Dialogue: 0,0:06:25.75,0:06:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:06:26.48,0:06:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, masuk tanpa izin.
Dialogue: 0,0:06:28.22,0:06:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai permintaan maaf, ini untukmu.
Dialogue: 0,0:06:36.36,0:06:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sungkan, terimalah.
Dialogue: 0,0:06:38.54,0:06:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-terima kasih.
Dialogue: 0,0:06:42.34,0:06:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:06:45.17,0:06:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kame.
Dialogue: 0,0:06:46.26,0:06:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menerima sake.
Dialogue: 0,0:06:48.17,0:06:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:06:53.16,0:06:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orochi!
Dialogue: 0,0:06:54.62,0:06:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sake itu bukan untukmu!
Dialogue: 0,0:06:59.68,0:07:01.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang kau sebut bocah, berengsek?
Dialogue: 0,0:07:01.94,0:07:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu memanggilku dengan\Nnama yang merendahkan.
Dialogue: 0,0:07:03.93,0:07:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berkelahi, dasar kau ini!
Dialogue: 0,0:07:06.69,0:07:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani sekali.
Dialogue: 0,0:07:08.01,0:07:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas nanti kupotong-potong lagi!
Dialogue: 0,0:07:10.04,0:07:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sangat mudah marah.\N- Baiklah, ayo maju.
Dialogue: 0,0:07:15.67,0:07:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau dihajar lagi?
Dialogue: 0,0:07:19.80,0:07:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memenggal semua kepalamu!
Dialogue: 0,0:07:27.74,0:07:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti, dasar!
Dialogue: 0,0:07:29.15,0:07:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, Tuan Dewa Gunung!
Dialogue: 0,0:07:32.05,0:07:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tertidur lelap?
Dialogue: 0,0:07:36.35,0:07:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tolong jangan berkelahi di sini.
Dialogue: 0,0:07:40.01,0:07:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:07:42.16,0:07:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau makhluk ini dibelah,\Ndari ekornya akan keluar pedang, lo.
Dialogue: 0,0:07:45.03,0:07:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik, 'kan?
Dialogue: 0,0:07:46.53,0:07:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Pedang Kusanagi?
Dialogue: 0,0:07:48.79,0:07:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu banyak, ya.
Dialogue: 0,0:07:50.35,0:07:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga ingin melihat wujud aslinya, 'kan?
Dialogue: 0,0:07:52.49,0:07:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin melihatnya.
Dialogue: 0,0:07:54.36,0:07:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong!
Dialogue: 0,0:07:55.53,0:07:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau seorang pria, seharusnya kau\Njuga menyukai hal seperti itu, 'kan?
Dialogue: 0,0:07:58.07,0:07:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, jangan menghalangi!
Dialogue: 0,0:08:06.71,0:08:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menggunakan kekuatan angin\Ndengan cukup mahir, ya.
Dialogue: 0,0:08:09.73,0:08:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih kurang.
Dialogue: 0,0:08:11.43,0:08:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:13.71,0:08:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih amatir.
Dialogue: 0,0:08:15.66,0:08:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amatir?
Dialogue: 0,0:08:16.70,0:08:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku akan melatihmu.
Dialogue: 0,0:08:19.16,0:08:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan!
Dialogue: 0,0:08:21.62,0:08:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tidak bisa di sini,\Nayo ke rumahku.
Dialogue: 0,0:08:25.34,0:08:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu, maafkan aku menolak.
Dialogue: 0,0:08:28.08,0:08:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan banyak bicara, ayo ikut aku!
Dialogue: 0,0:08:29.83,0:08:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tunggu!
Dialogue: 0,0:08:37.24,0:08:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, apa yang Anda lakukan?
Dialogue: 0,0:08:39.64,0:08:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan sedikit, sebentar lagi sampai.
Dialogue: 0,0:08:43.32,0:08:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda tinggal di dekat sini?\NSebentar lagi sampai?
Dialogue: 0,0:08:47.41,0:08:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku akan segera\Nmenyambungkannya sekarang.
Dialogue: 0,0:08:49.40,0:08:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan-jalan di udara akan segera berakhir.
Dialogue: 0,0:08:54.04,0:08:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah dewa?
Dialogue: 0,0:08:55.57,0:08:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:08:59.44,0:09:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani sekali dia bertindak sendiri.
Dialogue: 0,0:09:05.62,0:09:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan bocah itu.
Dialogue: 0,0:09:08.07,0:09:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah terlalu lama\Ntidak ada yang bermain dengannya.
Dialogue: 0,0:09:11.59,0:09:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:09:13.28,0:09:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo kita ke sana juga.
Dialogue: 0,0:09:15.13,0:09:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa membiarkan\Nbocah itu begitu saja.
Dialogue: 0,0:09:23.89,0:09:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kame.
Dialogue: 0,0:09:31.61,0:09:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:09:33.35,0:09:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, sudah sampai.
Dialogue: 0,0:09:35.69,0:09:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasar sekali Anda terhadapku.
Dialogue: 0,0:09:38.59,0:09:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau gadis muda,\Nmungkin aku akan menggendongmu.
Dialogue: 0,0:09:43.85,0:09:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak tertarik melakukan\Nhal seperti itu pada pria sialan.
Dialogue: 0,0:09:46.70,0:09:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak ingin memintamu\Nmelakukannya.
Dialogue: 0,0:09:48.72,0:09:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan itu, cepat berdiri!
Dialogue: 0,0:09:52.45,0:09:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini wilayah dewa Tuan Susanoo?
Dialogue: 0,0:09:55.42,0:09:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku akan menemanimu berlatih sekarang.
Dialogue: 0,0:10:02.22,0:10:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:10:09.43,0:10:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh nostalgia, pemandangannya bagus.
Dialogue: 0,0:10:13.62,0:10:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya?
Dialogue: 0,0:10:14.85,0:10:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, belakangan sepertinya\Ntidak melihat rumah gaya seperti itu.
Dialogue: 0,0:10:19.42,0:10:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dunia manusia berubah dengan cepat,\Ntren pun datang dan pergi dengan cepat.
Dialogue: 0,0:10:23.65,0:10:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar.
Dialogue: 0,0:10:29.16,0:10:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang beristirahat.
Dialogue: 0,0:10:30.94,0:10:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan mengabaikanku!
Dialogue: 0,0:10:35.80,0:10:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah harus bertarung secara paksa?
Dialogue: 0,0:10:38.51,0:10:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyerang!
Dialogue: 0,0:10:49.33,0:10:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti kau!
Dialogue: 0,0:10:56.22,0:10:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Anda terlalu berlebihan!
Dialogue: 0,0:10:58.33,0:11:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang ada di sini bisa rusak, lo.
Dialogue: 0,0:11:00.69,0:11:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abaikan itu, hancurkan sepuasnya.
Dialogue: 0,0:11:03.39,0:11:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tidak ada yang tinggal di sini.
Dialogue: 0,0:11:16.29,0:11:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak punya senjata.
Dialogue: 0,0:11:18.23,0:11:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang sekali menebasku dengan pedang!
Dialogue: 0,0:11:20.61,0:11:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anginmu terlalu lemah, membuatku kesal.
Dialogue: 0,0:11:24.84,0:11:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kau juga ambil senjata?
Dialogue: 0,0:11:26.93,0:11:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya dan tidak berniat\Nmengambilnya.
Dialogue: 0,0:11:29.46,0:11:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan? Dasar membosankan!
Dialogue: 0,0:11:33.23,0:11:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau merasa sudah cukup jika bisa\Nmengendalikan angin?
Dialogue: 0,0:11:37.51,0:11:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya perlu bisa melindungi diriku\Ndan orang-orang di sekitarku.
Dialogue: 0,0:11:40.89,0:11:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berniat mencari masalah\Ndengan bertarung.
Dialogue: 0,0:11:44.98,0:11:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir dengan angin sepoi-sepoi itu\Nbisa melindungi orang di sekitarmu?
Dialogue: 0,0:11:48.33,0:11:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya angin sepoi-sepoi?
Dialogue: 0,0:11:49.78,0:11:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau adalah manusia pertama\Nyang diberi kekuatan oleh Fujin.
Dialogue: 0,0:11:55.72,0:11:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau terlalu lemah,\Nakan mempermalukan Fujin.
Dialogue: 0,0:12:00.05,0:12:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang pertama?
Dialogue: 0,0:12:02.00,0:12:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau tidak tahu?
Dialogue: 0,0:12:04.11,0:12:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah ada cukup lama.
Dialogue: 0,0:12:06.68,0:12:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pernah kulihat Fujin memberikan\Nkekuatan kepada manusia lain.
Dialogue: 0,0:12:10.67,0:12:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:12:13.13,0:12:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai lupa.
Dialogue: 0,0:12:14.74,0:12:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susanoo adalah dewa agung\Nyang muncul dalam mitos.
Dialogue: 0,0:12:19.21,0:12:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh…
Dialogue: 0,0:12:21.96,0:12:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku berbicara lancang.
Dialogue: 0,0:12:25.72,0:12:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba merendahkan diri\Nseperti ini?
Dialogue: 0,0:12:28.15,0:12:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu?
Dialogue: 0,0:12:29.45,0:12:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku bilang aku sudah ada cukup lama?
Dialogue: 0,0:12:35.67,0:12:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau merasa aku sangat tua, 'kan?
Dialogue: 0,0:12:39.68,0:12:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin? Aku mana merasa Anda tua?
Dialogue: 0,0:12:41.87,0:12:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih sangat muda!
Dialogue: 0,0:12:43.16,0:12:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum menjadi om, juga bukan pak tua!
Dialogue: 0,0:12:45.15,0:12:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salah paham.
Dialogue: 0,0:12:47.04,0:12:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:48.61,0:12:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:49.80,0:12:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena belum lama ini dia menangis histeris\Nkarena merindukan ibunya.
Dialogue: 0,0:12:54.23,0:12:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:12:55.60,0:12:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, dia sangat berisik.
Dialogue: 0,0:13:00.78,0:13:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik sekali kalian yang menonton!
Dialogue: 0,0:13:09.33,0:13:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup.
Dialogue: 0,0:13:11.19,0:13:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup?\NKau jadi tidak kuat minum ya.
Dialogue: 0,0:13:16.42,0:13:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku hanya mencicip sedikit saja.
Dialogue: 0,0:13:18.80,0:13:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku masih bisa makan banyak camilan.
Dialogue: 0,0:13:21.73,0:13:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal ini sama sekali tidak berubah.
Dialogue: 0,0:13:27.51,0:13:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasananya persis seperti di izakaya.
Dialogue: 0,0:13:30.97,0:13:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tersenyum-senyum di sana!
Dialogue: 0,0:13:34.84,0:13:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, lanjut!
Dialogue: 0,0:13:39.01,0:13:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:13:48.37,0:13:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, di sini juga ada.
Dialogue: 0,0:13:50.14,0:13:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:13:51.35,0:13:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para onmyoji itu malah menempelkan\Nbenda merepotkan seperti ini.
Dialogue: 0,0:13:55.10,0:13:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, roh jahat akan semakin banyak.
Dialogue: 0,0:13:57.25,0:14:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan mengusir roh jahat kita\Njuga tidak akan ada habisnya.
Dialogue: 0,0:14:01.51,0:14:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus terus meraup\Nuntung besar seperti ini.
Dialogue: 0,0:14:06.57,0:14:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sha!
Dialogue: 0,0:14:11.29,0:14:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu…
Dialogue: 0,0:14:13.81,0:14:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu…
Dialogue: 0,0:14:15.31,0:14:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onmyoji?
Dialogue: 0,0:14:18.26,0:14:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kabur!
Dialogue: 0,0:14:23.27,0:14:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bekerja keras, ya.
Dialogue: 0,0:14:25.00,0:14:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kenyang?
Dialogue: 0,0:14:26.14,0:14:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sha.
Dialogue: 0,0:14:27.23,0:14:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Penpen…\N- Patuh sekali.
Dialogue: 0,0:14:32.85,0:14:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka…
Dialogue: 0,0:14:38.13,0:14:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Katsuragi!
Dialogue: 0,0:14:39.84,0:14:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harima.
Dialogue: 0,0:14:41.56,0:14:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:14:43.53,0:14:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat sana!
Dialogue: 0,0:14:46.43,0:14:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jimatnya sudah dirobek.
Dialogue: 0,0:14:48.46,0:14:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya di sini,\Nsudah dirobek belasan lembar.
Dialogue: 0,0:14:51.79,0:14:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat di kota tidak berkurang,\Napakah ini penyebabnya?
Dialogue: 0,0:14:55.84,0:14:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi, ini perbuatan\Npara pengusir roh itu.
Dialogue: 0,0:14:58.73,0:15:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menangkap mereka.
Dialogue: 0,0:15:01.07,0:15:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi agak aneh.
Dialogue: 0,0:15:03.63,0:15:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang aneh?
Dialogue: 0,0:15:05.02,0:15:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dipahami kalau hanya roh jahat\Nyang tidak berkurang.
Dialogue: 0,0:15:07.44,0:15:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa terus bertambah?
Dialogue: 0,0:15:09.91,0:15:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:11.30,0:15:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Katsuragi! Tuan Saiga!
Dialogue: 0,0:15:14.52,0:15:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:15.78,0:15:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tanah kosong di sana\Nmuncul banyak roh jahat.
Dialogue: 0,0:15:20.34,0:15:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:21.51,0:15:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat? Apa yang terjadi?
Dialogue: 0,0:15:24.15,0:15:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu,\Ntapi energi jahat sedang menyebar.
Dialogue: 0,0:15:27.69,0:15:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harima.
Dialogue: 0,0:15:37.26,0:15:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bagaimana?
Dialogue: 0,0:15:40.54,0:15:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin kabur sampai kapan?
Dialogue: 0,0:15:48.83,0:15:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya sudah agak bersemangat?
Dialogue: 0,0:15:51.04,0:15:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi terlalu lemah, terlalu lemah!
Dialogue: 0,0:15:53.54,0:15:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, seranganku bisa ditebak.
Dialogue: 0,0:15:56.21,0:15:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliranku menyerang!
Dialogue: 0,0:15:59.13,0:16:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dari jarak jauh,\Nseranganku bisa ditebak.
Dialogue: 0,0:16:01.78,0:16:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usahakan untuk memancingnya mendekat.
Dialogue: 0,0:16:07.54,0:16:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum.
Dialogue: 0,0:16:09.85,0:16:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum, harus lebih dekat lagi.
Dialogue: 0,0:16:13.50,0:16:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang saatnya!
Dialogue: 0,0:16:24.01,0:16:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:16:34.72,0:16:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angin barusan lumayan bagus.
Dialogue: 0,0:16:37.18,0:16:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau bertahan sampai\Ndetik terakhir baru balas menyerang.
Dialogue: 0,0:16:39.93,0:16:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih berani daripada yang kukira.
Dialogue: 0,0:16:42.26,0:16:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini cukup sampai di sini.
Dialogue: 0,0:16:45.61,0:16:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipuji?
Dialogue: 0,0:16:47.41,0:16:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau banyak bicara,
Dialogue: 0,0:16:49.01,0:16:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang manusia bisa mengendalikan\Nkekuatan dewa dengan tubuhnya,
Dialogue: 0,0:16:53.21,0:16:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu sudah sangat luar biasa.
Dialogue: 0,0:16:55.50,0:16:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya.
Dialogue: 0,0:17:03.92,0:17:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi masih belum bisa menandingi Fujin.
Dialogue: 0,0:17:08.29,0:17:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalimat ini tidak perlu, 'kan?
Dialogue: 0,0:17:21.13,0:17:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah berolahraga, perut jadi lapar.
Dialogue: 0,0:17:23.93,0:17:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga lapar, 'kan?
Dialogue: 0,0:17:31.02,0:17:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, makanlah sepuasnya.
Dialogue: 0,0:17:42.65,0:17:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:17:43.83,0:17:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa chikuzenni ini enak sekali!
Dialogue: 0,0:17:46.27,0:17:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akar teratai yang renyah\Njuga menyerap bumbunya. Enak!
Dialogue: 0,0:17:49.23,0:17:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat suka.
Dialogue: 0,0:17:50.27,0:17:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya.
Dialogue: 0,0:17:51.97,0:17:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya sisa makanan tadi malam.
Dialogue: 0,0:17:55.00,0:17:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:17:56.50,0:17:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan terong rebus ini sepertinya\Nkurang sesuatu, aku tidak terlalu suka.
Dialogue: 0,0:17:59.94,0:18:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukan berarti tidak enak.
Dialogue: 0,0:18:02.34,0:18:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya tidak sesuai dengan seleraku.
Dialogue: 0,0:18:04.61,0:18:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena merepotkan, jadi aku pakai\Nbumbu mentsuyu untuk menghemat waktu.
Dialogue: 0,0:18:07.46,0:18:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau asal-asalan begitu?
Dialogue: 0,0:18:09.65,0:18:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di bagian seperti inilah kau kurang teliti.
Dialogue: 0,0:18:12.91,0:18:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian seperti ini, maksudnya apa?
Dialogue: 0,0:18:14.52,0:18:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan barusan itu.
Dialogue: 0,0:18:16.91,0:18:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tadi Anda memujiku?
Dialogue: 0,0:18:20.27,0:18:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memujimu.
Dialogue: 0,0:18:22.18,0:18:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya merasa kau ada sedikit kemajuan.
Dialogue: 0,0:18:29.43,0:18:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orochi sialan, dengkuranmu terlalu berisik.
Dialogue: 0,0:18:32.23,0:18:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sake pun jadi tidak enak.
Dialogue: 0,0:18:34.44,0:18:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mau minum wine-ku\Nuntuk ganti selera?
Dialogue: 0,0:18:37.85,0:18:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:18:39.05,0:18:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bersulang dengan bir saja.
Dialogue: 0,0:18:41.71,0:18:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga ada buah asing sebagai pencuci mulut…
Dialogue: 0,0:18:44.54,0:18:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang tidak mau!
Dialogue: 0,0:18:46.27,0:18:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja bau!
Dialogue: 0,0:18:48.60,0:18:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua sangat konservatif, ya.
Dialogue: 0,0:18:52.17,0:18:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, kau kurus, tapi bisa makan banyak
Dialogue: 0,0:18:55.28,0:18:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan makan sangat cepat.\NHarus kunyah pelan-pelan.
Dialogue: 0,0:18:59.92,0:19:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kita tidak jauh berbeda.
Dialogue: 0,0:19:02.16,0:19:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begini, makan banyak pun\Ntidak akan tumbuh lagi, 'kan?
Dialogue: 0,0:19:06.13,0:19:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dewasa, tidak muda lagi.
Dialogue: 0,0:19:08.58,0:19:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menurutku, kau masih bayi.
Dialogue: 0,0:19:11.50,0:19:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sebenarnya tidak jauh berbeda\Ndenganku.
Dialogue: 0,0:19:14.18,0:19:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lihat penampilan saja.
Dialogue: 0,0:19:16.08,0:19:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi jangan anggap aku tua, aku masih muda.
Dialogue: 0,0:19:21.14,0:19:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, baiklah.
Dialogue: 0,0:19:22.84,0:19:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bersama bocah tengik sepertimu,
Dialogue: 0,0:19:25.46,0:19:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada lebih baik daripada tidak.
Dialogue: 0,0:19:27.97,0:19:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Pak Tua Dewa Gunung itu,\Nkalau dibiarkan saja,
Dialogue: 0,0:19:30.06,0:19:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bisa menjadi kecil karena\Nterlalu banyak pakai kekuatan, 'kan?
Dialogue: 0,0:19:32.85,0:19:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:19:33.84,0:19:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekitar sini banyak masalah seperti\Nroh jahat dan wilayah dewa terbengkalai.
Dialogue: 0,0:19:41.52,0:19:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kau pakai kekuatan itu\Nuntuk membantu Pak Tua.
Dialogue: 0,0:19:50.20,0:19:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Susanoo, jangan-jangan Anda\Nmencariku demi hal ini?
Dialogue: 0,0:19:55.37,0:19:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi karena itu Anda melatihku?
Dialogue: 0,0:19:58.17,0:19:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin!
Dialogue: 0,0:19:59.95,0:20:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:01.63,0:20:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang bukan!
Dialogue: 0,0:20:03.70,0:20:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, silakan, makan lagi.
Dialogue: 0,0:20:06.91,0:20:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:20:08.69,0:20:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan ini, kapan kita bertarung lagi?
Dialogue: 0,0:20:11.40,0:20:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok atau lusa?
Dialogue: 0,0:20:12.98,0:20:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda masih ingin bertarung?
Dialogue: 0,0:20:16.90,0:20:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Susanoo!
Dialogue: 0,0:20:21.06,0:20:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak…
Dialogue: 0,0:20:22.22,0:20:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amaterasu.
Dialogue: 0,0:20:24.01,0:20:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:20:26.25,0:20:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau ini!
Dialogue: 0,0:20:27.56,0:20:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kasar pada manusia?
Dialogue: 0,0:20:29.99,0:20:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah minta orang lain mentraktirmu makan.
Dialogue: 0,0:20:32.38,0:20:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin melatihnya.
Dialogue: 0,0:20:35.61,0:20:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan kalau terus merepotkannya.
Dialogue: 0,0:20:39.10,0:20:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau urusan selesai, cepat pulang!
Dialogue: 0,0:20:42.93,0:20:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu…
Dialogue: 0,0:20:44.77,0:20:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum makan semuanya!
Dialogue: 0,0:20:47.09,0:20:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melawan!
Dialogue: 0,0:20:48.64,0:20:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:20:50.29,0:20:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah makan,\Nmau mencoba hasil pegunungan?
Dialogue: 0,0:20:53.12,0:20:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru dipanen.
Dialogue: 0,0:20:55.57,0:20:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihai juga, bocah-bocah!
Dialogue: 0,0:20:58.40,0:20:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang!
Dialogue: 0,0:21:00.43,0:21:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:21:01.85,0:21:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak boleh bilang tidak mau!\N- Aku belum mau pulang!
Dialogue: 0,0:21:03.26,0:21:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar seperti bayi.
Dialogue: 0,0:21:05.56,0:21:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul sekali.
Dialogue: 0,0:21:09.65,0:21:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di sana, jangan tertawa!
Dialogue: 0,0:21:12.92,0:21:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi kemunculan roh jahat\Nada di sekitar sini.
Dialogue: 0,0:21:16.39,0:21:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi jahatnya sangat kuat…
Dialogue: 0,0:21:18.44,0:21:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usir semuanya sekaligus.
Dialogue: 0,0:21:25.99,0:21:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:21:31.52,0:21:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat keluar dari dalam sana.
Dialogue: 0,0:21:34.10,0:21:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:21:35.12,0:21:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat terus bertambah,\Napakah karena itu?
Dialogue: 0,0:21:39.48,0:21:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bergerak.
Dialogue: 0,0:21:50.99,0:21:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:23:31.73,0:23:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 11.
Dialogue: 0,0:23:33.39,0:23:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dendam Roh Jahat Menodai Ritual.
