Dialogue: 0,0:03:25.97,0:03:30.95,sign,,0000,0000,0000,,GUNUNG SEBELAH PUNYA IKATAN SEJAK DULU
Dialogue: 0,0:10:04.79,0:10:08.76,sign,,0000,0000,0000,,"TENKO"
Dialogue: 0,0:10:51.84,0:10:55.19,sign,,0000,0000,0000,,"KUIL INARI"
Dialogue: 0,0:23:37.00,0:23:39.00,sign,,0000,0000,0000,,SELANJUTNYA: SAAT JALAN-JALAN DI KOTA,\NDATANG TAMU TAK DIUNDANG
Dialogue: 0,0:00:15.41,0:00:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir aku akan mati kepanasan.
Dialogue: 0,0:00:18.13,0:00:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini panasnya luar biasa.
Dialogue: 0,0:00:20.69,0:00:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi taman ini adalah wilayah dewa.
Dialogue: 0,0:00:23.78,0:00:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peduli kapan pun, selalu nyaman.
Dialogue: 0,0:00:25.85,0:00:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:28.53,0:00:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, agar lebih nyaman,
Dialogue: 0,0:00:31.26,0:00:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan merombak taman ini.
Dialogue: 0,0:00:33.50,0:00:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:00:34.36,0:00:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan.
Dialogue: 0,0:00:36.37,0:00:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terlalu banyak\Nmenggunakan kekuatan, kau akan…
Dialogue: 0,0:00:38.84,0:00:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:00:50.19,0:00:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali?
Dialogue: 0,0:00:52.09,0:00:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar ada air yang mengalir.
Dialogue: 0,0:00:54.45,0:00:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesan yang diberikan sangat berbeda.
Dialogue: 0,0:00:56.84,0:00:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terlalu monoton\Nkalau hanya begini saja.
Dialogue: 0,0:00:59.68,0:01:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, 'kan?
Dialogue: 0,0:01:05.63,0:01:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih kurang sebuah jembatan.
Dialogue: 0,0:01:10.28,0:01:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisinya kurang tepat, agak ke sini lagi.
Dialogue: 0,0:01:13.68,0:01:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Tuan Dewa Gunung...
Dialogue: 0,0:01:15.21,0:01:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menggunakan kekuatan\Ntanpa dikendalikan…
Dialogue: 0,0:01:17.24,0:01:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ke sebelah sini?
Dialogue: 0,0:01:18.66,0:01:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, berhenti, berhenti!
Dialogue: 0,0:01:20.71,0:01:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata masih kurang sesuatu.
Dialogue: 0,0:01:22.56,0:01:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, kurang suara air?
Dialogue: 0,0:01:25.66,0:01:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara air?
Dialogue: 0,0:01:26.72,0:01:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah poin utamanya?
Dialogue: 0,0:01:32.75,0:01:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa! Air terjun!
Dialogue: 0,0:01:35.83,0:01:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara air terjun, benar-benar menenangkan.
Dialogue: 0,0:01:39.99,0:01:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung jadi sejuk, ya, Tuan Dewa Gunung.
Dialogue: 0,0:01:43.59,0:01:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda kembali menyusut\Njadi seukuran Chihuahua!
Dialogue: 0,0:01:46.35,0:01:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chihuahua? Aku adalah Dewa Gunung.
Dialogue: 0,0:01:48.74,0:01:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku tahu itu.
Dialogue: 0,0:01:53.83,0:01:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan suaranya pun lucu.
Dialogue: 0,0:02:06.85,0:02:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:03:31.29,0:03:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung,\Nseharusnya sudah sering kukatakan.
Dialogue: 0,0:03:33.81,0:03:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan gunakan kekuatan\Nsecara berlebihan.
Dialogue: 0,0:03:35.71,0:03:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda menjadi seperti ini\Nkarena terlalu bersemangat.
Dialogue: 0,0:03:39.44,0:03:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:40.57,0:03:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh bisa-bisanya menyusut\Njadi lebih kecil dari kami.
Dialogue: 0,0:03:42.86,0:03:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tak seberapa.
Dialogue: 0,0:03:45.58,0:03:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski menyusut, aku tetaplah aku.
Dialogue: 0,0:03:48.31,0:03:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, bukankah sekarang\Njadi cukup elegan?
Dialogue: 0,0:03:51.70,0:03:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, kenapa Anda\Nbegitu bersikeras merombak taman?
Dialogue: 0,0:03:55.39,0:03:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hobiku, hanya menyesuaikan\Ndengan musim saja.
Dialogue: 0,0:03:59.55,0:04:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Anda jelas-jelas membiarkan\Ngunungmu sendiri terlantar.
Dialogue: 0,0:04:03.52,0:04:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda alami itu indah apa adanya, bukan?
Dialogue: 0,0:04:07.57,0:04:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa kupahami.
Dialogue: 0,0:04:10.58,0:04:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ukuran sekarang ini\Nsangat merepotkan, 'kan?
Dialogue: 0,0:04:12.64,0:04:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus secepatnya kembali ke ukuran semula.
Dialogue: 0,0:04:14.30,0:04:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa, tidak perlu buru-buru.
Dialogue: 0,0:04:20.10,0:04:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ryu, kau suka tempat itu, ya?
Dialogue: 0,0:04:23.46,0:04:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya nyaman berada di sana.
Dialogue: 0,0:04:29.09,0:04:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa yang diselamatkan dari\Nwilayah dewa itu belum juga bangun.
Dialogue: 0,0:04:33.16,0:04:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:04:34.98,0:04:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dia hanya sedikit lelah saja.
Dialogue: 0,0:04:37.75,0:04:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lama lagi seharusnya bangun.
Dialogue: 0,0:04:39.93,0:04:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ke sini.
Dialogue: 0,0:04:41.44,0:04:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori juga kelelahan, ya.
Dialogue: 0,0:04:45.72,0:04:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, lihat ke sini!
Dialogue: 0,0:04:51.53,0:04:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikan koi?
Dialogue: 0,0:04:52.43,0:04:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka datang dari mana?
Dialogue: 0,0:04:54.91,0:04:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka tersasar masuk.
Dialogue: 0,0:04:57.15,0:04:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Depan adalah jalan buntu.
Dialogue: 0,0:05:05.97,0:05:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ikan melompat gerbang naga.
Dialogue: 0,0:05:07.97,0:05:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada disebut\Nikan melompat gerbang naga,
Dialogue: 0,0:05:10.29,0:05:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih tepatnya ikan terbang di langit.
Dialogue: 0,0:05:19.20,0:05:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:05:20.95,0:05:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tersasar masuk lagi, ya.
Dialogue: 0,0:05:23.08,0:05:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengagetkan saja.
Dialogue: 0,0:05:24.70,0:05:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, konon ikan koi yang berhasil\Npanjat air terjun akan berubah jadi naga.
Dialogue: 0,0:05:30.25,0:05:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga kerabat dewa.
Dialogue: 0,0:05:32.44,0:05:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya makhluk dari kota sebelah.
Dialogue: 0,0:05:36.28,0:05:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota sebelah, ya?
Dialogue: 0,0:05:38.89,0:05:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsumugi dari gunung sebelah
Dialogue: 0,0:05:40.88,0:05:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak pernah muncul lagi.
Dialogue: 0,0:05:43.20,0:05:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana keadaannya.
Dialogue: 0,0:05:44.47,0:05:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang tahu?
Dialogue: 0,0:05:45.78,0:05:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persik yang ditinggalkannya
Dialogue: 0,0:05:50.05,0:05:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat sepat.
Dialogue: 0,0:05:52.31,0:05:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya memberi oleh-oleh\Nkualitas buruk.
Dialogue: 0,0:05:54.60,0:05:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh keterlaluan!
Dialogue: 0,0:05:55.90,0:05:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti majikan, seperti kerabat.
Dialogue: 0,0:05:59.19,0:06:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,
Dialogue: 0,0:06:00.63,0:06:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa Anda tidak akur dengan dewa sebelah?
Dialogue: 0,0:06:03.99,0:06:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:06:06.82,0:06:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh penasaran dewa seperti apa.
Dialogue: 0,0:06:12.02,0:06:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ryu?
Dialogue: 0,0:06:18.42,0:06:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah ikan koi yang panjat air terjun\Nbenar-benar berubah jadi naga?
Dialogue: 0,0:06:24.55,0:06:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia turun!
Dialogue: 0,0:06:28.85,0:06:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali!
Dialogue: 0,0:06:30.30,0:06:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panik.
Dialogue: 0,0:06:31.77,0:06:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Anda begitu tenang?
Dialogue: 0,0:06:33.86,0:06:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kenalan Oryu.
Dialogue: 0,0:06:36.07,0:06:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:36.91,0:06:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, tutup matamu.
Dialogue: 0,0:06:44.80,0:06:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyusut?
Dialogue: 0,0:06:48.42,0:06:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tanya apakah boleh masuk.
Dialogue: 0,0:06:50.76,0:06:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, silakan masuk.
Dialogue: 0,0:06:54.46,0:06:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:07:01.04,0:07:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:07:02.48,0:07:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang ini hadiah perkenalan.
Dialogue: 0,0:07:04.52,0:07:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah.
Dialogue: 0,0:07:06.93,0:07:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Anda terlalu sungkan.
Dialogue: 0,0:07:11.23,0:07:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada?
Dialogue: 0,0:07:15.83,0:07:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:07:18.20,0:07:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sangat berterima kasih,\Ntapi aku tidak bisa menerima lagi.
Dialogue: 0,0:07:30.45,0:07:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang sudah waktunya untuk pergi.
Dialogue: 0,0:07:34.66,0:07:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, maaf jika\Ntidak melayani dengan baik.
Dialogue: 0,0:07:41.07,0:07:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang lagi lain kali jika ada waktu.
Dialogue: 0,0:07:43.93,0:07:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, semua itu apa?
Dialogue: 0,0:07:46.81,0:07:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba buka saja.
Dialogue: 0,0:07:51.26,0:07:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya enak.
Dialogue: 0,0:07:52.58,0:07:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kue bulan, 'kan?
Dialogue: 0,0:07:54.48,0:07:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya berupa isian manis.
Dialogue: 0,0:07:58.00,0:08:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, Tuan Dewa Gunung.
Dialogue: 0,0:08:00.27,0:08:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah makan ini, Anda seharusnya\Nbisa kembali ke ukuran semula, 'kan?
Dialogue: 0,0:08:03.37,0:08:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tidak sungkan lagi.
Dialogue: 0,0:08:11.33,0:08:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:08:13.44,0:08:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan enak.
Dialogue: 0,0:08:14.71,0:08:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi belum kembali seperti semula.
Dialogue: 0,0:08:17.74,0:08:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini camilan yang langka.
Dialogue: 0,0:08:20.06,0:08:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini teh Tiongkok.
Dialogue: 0,0:08:23.46,0:08:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:26.03,0:08:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, silakan makan sepuasnya.
Dialogue: 0,0:08:36.53,0:08:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang terakhir.
Dialogue: 0,0:08:39.42,0:08:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini pasti bisa.
Dialogue: 0,0:08:40.70,0:08:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:08:41.99,0:08:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya tak tertandingi.
Dialogue: 0,0:08:46.89,0:08:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak bisa kembali ke semula?
Dialogue: 0,0:08:48.91,0:08:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti harus makan lebih banyak\Nuntuk memulihkan kekuatan.
Dialogue: 0,0:08:53.01,0:08:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mencobanya.
Dialogue: 0,0:09:04.51,0:09:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membeli semua camilan Jepang\Npremium yang terpikir olehku.
Dialogue: 0,0:09:08.13,0:09:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar untuk mencicipinya.
Dialogue: 0,0:09:10.06,0:09:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon cepat kembali ke ukuran semula.
Dialogue: 0,0:09:13.67,0:09:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gunung tempat Tsumugi tinggal, 'kan?
Dialogue: 0,0:09:16.38,0:09:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:17.76,0:09:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunung ini sangat lucu.
Dialogue: 0,0:09:20.30,0:09:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir hanya gunung besar\Nyang ada dewanya.
Dialogue: 0,0:09:23.65,0:09:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukuran tidak penting.
Dialogue: 0,0:09:25.44,0:09:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada di mana-mana,\Ntapi makhluk di sini…
Dialogue: 0,0:09:29.47,0:09:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Wilayah dewa terbengkalai lagi?
Dialogue: 0,0:09:37.88,0:09:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bertindak sembarangan!
Dialogue: 0,0:09:45.08,0:09:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya muncul di hadapanku,\Njarang sekali.
Dialogue: 0,0:09:50.07,0:09:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:52.30,0:09:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rubah?
Dialogue: 0,0:09:56.29,0:09:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memiliki sembilan ekor.
Dialogue: 0,0:09:58.59,0:09:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yokai?
Dialogue: 0,0:09:59.69,0:10:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, dia adalah dewa.
Dialogue: 0,0:10:01.75,0:10:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, dia adalah dewa gunung ini?
Dialogue: 0,0:10:04.79,0:10:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah Tenko, Tsumugi kerabatnya.
Dialogue: 0,0:10:12.83,0:10:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, Anda\Ndan Nona Tenko memang tidak akur, ya?
Dialogue: 0,0:10:16.76,0:10:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan soal akur atau tidak.
Dialogue: 0,0:10:18.78,0:10:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, Tuan Dewa Gunung.
Dialogue: 0,0:10:21.29,0:10:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengundangmu pergi bertamu.
Dialogue: 0,0:10:23.87,0:10:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:24.99,0:10:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku pertama kali lewat sini,
Dialogue: 0,0:10:27.63,0:10:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga belum pernah bertemu dengannya.
Dialogue: 0,0:10:29.62,0:10:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tahu tentangmu.
Dialogue: 0,0:10:31.64,0:10:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena setiap gerak-gerik kerabat\Ndiketahui dengan jelas oleh Dewa Utama.
Dialogue: 0,0:10:36.59,0:10:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:10:37.80,0:10:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak tahu dia hanya ingin\Nmelihatmu secara langsung,
Dialogue: 0,0:10:40.36,0:10:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau karena inarizushi.
Dialogue: 0,0:10:43.32,0:10:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cukup dominan, ya.
Dialogue: 0,0:10:45.27,0:10:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika diundang dengan cara normal,\Naku bisa pergi.
Dialogue: 0,0:10:48.80,0:10:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak bisa menjamin\Nkau akan kembali dengan selamat.
Dialogue: 0,0:10:51.84,0:10:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sebaiknya lupakan saja.
Dialogue: 0,0:10:56.70,0:10:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Pengusir roh dari kota sebelah?
Dialogue: 0,0:10:59.53,0:11:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya saat mengusir roh\Ndi rumah sakit terbengkalai,
Dialogue: 0,0:11:02.18,0:11:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku melihat seorang pria bernama Ansho.
Dialogue: 0,0:11:07.51,0:11:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pengusir roh dari kota sebelah, 'kan?
Dialogue: 0,0:11:10.13,0:11:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia muncul\Ndi wilayah yurisdiksi kita?
Dialogue: 0,0:11:12.15,0:11:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.
Dialogue: 0,0:11:13.48,0:11:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Saiga.
Dialogue: 0,0:11:14.70,0:11:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga agak khawatir tentang hal itu.
Dialogue: 0,0:11:16.34,0:11:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku melakukan penyelidikan\Nsecara diam-diam.
Dialogue: 0,0:11:18.96,0:11:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah bekerja keras. Lalu?
Dialogue: 0,0:11:21.09,0:11:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria bernama Ansho itu\Nmembawa pria yang seperti bawahannya,
Dialogue: 0,0:11:24.33,0:11:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sering muncul di Hojocho.
Dialogue: 0,0:11:27.58,0:11:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini belum tahu apa tujuannya.
Dialogue: 0,0:11:30.02,0:11:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat mengkhawatirkan.
Dialogue: 0,0:11:32.42,0:11:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku juga akan mencari tahu.
Dialogue: 0,0:11:34.75,0:11:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:11:36.46,0:11:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:37.06,0:11:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek, pinggangmu sakit?
Dialogue: 0,0:11:39.46,0:11:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti karena roh jahat.
Dialogue: 0,0:11:43.40,0:11:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat?
Dialogue: 0,0:11:44.90,0:11:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah pengusir roh,\Njadi bisa melihat hal semacam itu.
Dialogue: 0,0:11:50.18,0:11:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kalian melakukan sesuatu?
Dialogue: 0,0:11:52.69,0:11:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah. Jimat ini bisa\Nmembantu mengusir roh jahat.
Dialogue: 0,0:11:57.67,0:11:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efeknya luar biasa.
Dialogue: 0,0:11:59.08,0:12:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang beli satu set 10 lembar,\Ndapat tambahan satu lembar.
Dialogue: 0,0:12:02.67,0:12:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau beli itu.
Dialogue: 0,0:12:06.95,0:12:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:11.09,0:12:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:12:18.27,0:12:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sangat elegan.
Dialogue: 0,0:12:21.91,0:12:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis segar kastanya benar-benar terasa.
Dialogue: 0,0:12:24.89,0:12:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah makan sebanyak ini,\Nmasih tidak bisa kembali ke ukuran semula.
Dialogue: 0,0:12:30.14,0:12:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kubilang jangan buru-buru?
Dialogue: 0,0:12:35.10,0:12:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:12:36.99,0:12:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:39.22,0:12:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak ranting yang rontok.
Dialogue: 0,0:12:42.22,0:12:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukti pohon Kusunoki sedang tumbuh.
Dialogue: 0,0:12:45.27,0:12:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya.
Dialogue: 0,0:12:52.33,0:12:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:13:03.59,0:13:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau takuti sejak tadi?
Dialogue: 0,0:13:05.84,0:13:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah senjata mematikan\Nyang menakutkan.
Dialogue: 0,0:13:08.97,0:13:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak zaman dahulu, berapa banyak\Nmakhluk hidup yang dibunuh manusia?
Dialogue: 0,0:13:13.20,0:13:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Tuan Rumah berencana menggunakan\Npahat ukir itu untuk membantai kerabatnya?
Dialogue: 0,0:13:17.60,0:13:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik! Kau mengganggu tidur siangku.
Dialogue: 0,0:13:21.36,0:13:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:13:23.08,0:13:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah
Dialogue: 0,0:13:24.65,0:13:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gantungan kunci kamar untuk tamu dari\Npenginapan onsen di kampung halamanku.
Dialogue: 0,0:13:29.27,0:13:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada barang seperti itu.
Dialogue: 0,0:13:31.71,0:13:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama tidak membuatnya, kali ini aku\Ningin coba pakai cabang pohon Kusunoki.
Dialogue: 0,0:13:36.01,0:13:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:13:40.86,0:13:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai.
Dialogue: 0,0:13:41.94,0:13:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyegel kekuatan mengusir roh jahat\Nke dalamnya.
Dialogue: 0,0:13:44.04,0:13:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini sudah selesai.
Dialogue: 0,0:13:45.51,0:13:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:13:46.37,0:13:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok digunakan sebagai jimat.
Dialogue: 0,0:13:48.58,0:13:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk Tuan Dewa Gunung,\Nsilakan diterima.
Dialogue: 0,0:13:51.62,0:13:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk aku?
Dialogue: 0,0:13:53.20,0:13:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah jimat.
Dialogue: 0,0:13:54.71,0:13:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak tahu apakah ini\Nbisa membantumu.
Dialogue: 0,0:13:58.68,0:14:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan bagus.
Dialogue: 0,0:14:00.82,0:14:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah kembali seperti semula.
Dialogue: 0,0:14:03.05,0:14:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:11.34,0:14:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia juga menginginkan\Nbalok kayu yang kau ukir.
Dialogue: 0,0:14:14.80,0:14:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:14:16.36,0:14:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu yang terakhir.
Dialogue: 0,0:14:21.74,0:14:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, produk gagal pun tidak apa-apa.
Dialogue: 0,0:14:25.55,0:14:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kalau tidak keberatan, silakan ambil.
Dialogue: 0,0:14:57.99,0:14:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai.
Dialogue: 0,0:15:01.73,0:15:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya enak, 'kan?
Dialogue: 0,0:15:03.56,0:15:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak segera dimakan,\Nmungkin akan mengundang rubah lagi.
Dialogue: 0,0:15:07.34,0:15:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Tsumugi?
Dialogue: 0,0:15:08.86,0:15:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak mungkin muncul sesering itu.
Dialogue: 0,0:15:11.45,0:15:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, selamat makan.
Dialogue: 0,0:15:13.16,0:15:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:15:16.60,0:15:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru saja dibicarakan, langsung datang.
Dialogue: 0,0:15:18.83,0:15:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau datang karena\Nmencium aroma inarizushi?
Dialogue: 0,0:15:21.32,0:15:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau katakan?\NAku tidak mengerti maksudmu.
Dialogue: 0,0:15:26.16,0:15:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku masuk?
Dialogue: 0,0:15:27.80,0:15:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk.
Dialogue: 0,0:15:30.32,0:15:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini versi sederhana yang hanya\Nditambah wijen putih.
Dialogue: 0,0:15:33.85,0:15:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan?
Dialogue: 0,0:15:34.68,0:15:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:15:36.41,0:15:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga yang berisi soba.
Dialogue: 0,0:15:38.61,0:15:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:40.10,0:15:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, diisi dengan soba\Nsebagai pengganti nasi cuka.
Dialogue: 0,0:15:43.62,0:15:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini disebut inari soba.
Dialogue: 0,0:15:45.76,0:15:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihatnya,\Napalagi memakannya.
Dialogue: 0,0:15:48.57,0:15:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong biarkan aku mencobanya.
Dialogue: 0,0:15:50.86,0:15:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, silakan makan.
Dialogue: 0,0:15:52.60,0:15:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan!
Dialogue: 0,0:15:56.85,0:16:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, hari ini aku datang\Nuntuk meminta maaf.
Dialogue: 0,0:16:00.80,0:16:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:02.17,0:16:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa waktu lalu, Dewa Tenko\Nyang kulayani, mengundangmu secara paksa.
Dialogue: 0,0:16:05.86,0:16:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf.
Dialogue: 0,0:16:08.27,0:16:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu, aku tidak keberatan.
Dialogue: 0,0:16:11.00,0:16:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau begitu.
Dialogue: 0,0:16:12.76,0:16:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bertemu Nona Inari berekor banyak,\Nmungkin itu keberuntungan.
Dialogue: 0,0:16:17.23,0:16:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah ekor sebanding dengan kekuatan.
Dialogue: 0,0:16:20.34,0:16:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:22.05,0:16:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Tenko yang kulayani sangat kuat.
Dialogue: 0,0:16:24.67,0:16:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuil di gunung tempat kami tinggal
Dialogue: 0,0:16:26.58,0:16:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah tempat dengan jemaah\Nterbanyak di daerah ini.
Dialogue: 0,0:16:29.98,0:16:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski banyak jemaah itu hal yang baik,
Dialogue: 0,0:16:33.01,0:16:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi terlalu berisik\Nmembuat sedikit terganggu.
Dialogue: 0,0:16:44.24,0:16:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski di luar berisik,\Nwilayah dewaku tetap tenang dan nyaman.
Dialogue: 0,0:16:49.29,0:16:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Maukah kau\Ndatang bermain ke tempatku?
Dialogue: 0,0:16:53.47,0:16:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, harus bawa inarizushi, ya.
Dialogue: 0,0:16:56.73,0:17:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sangat tertarik\Ndengan inari soba itu.
Dialogue: 0,0:17:00.36,0:17:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah itu Nona Rubah?
Dialogue: 0,0:17:02.41,0:17:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya Tenko, bodoh!
Dialogue: 0,0:17:04.57,0:17:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberapa rakusnya kau?
Dialogue: 0,0:17:06.93,0:17:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar rubah betina rendahan!
Dialogue: 0,0:17:08.91,0:17:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin dikatakan begitu olehmu!
Dialogue: 0,0:17:11.56,0:17:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudah disogok dengan sedikit camilan\Nsampai menahan amarahmu.
Dialogue: 0,0:17:16.26,0:17:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong! Aku berbeda denganmu.
Dialogue: 0,0:17:18.67,0:17:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah masuk wilayah dewa\Norang lain demi makanan.
Dialogue: 0,0:17:22.58,0:17:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan masuk ke sini! Pergi sana!
Dialogue: 0,0:17:25.97,0:17:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengizinkan kerabatku masuk.
Dialogue: 0,0:17:28.22,0:17:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya aku juga boleh masuk, 'kan?
Dialogue: 0,0:17:30.59,0:17:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong!
Dialogue: 0,0:17:31.39,0:17:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan seenaknya menafsirkan.
Dialogue: 0,0:17:33.90,0:17:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, masuk ke sini\Ntidak perlu izinmu, 'kan?
Dialogue: 0,0:17:38.48,0:17:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama pemiliknya mengizinkan,\Nsiapa pun bisa masuk ke taman ini.
Dialogue: 0,0:17:41.72,0:17:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:17:43.23,0:17:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ya.
Dialogue: 0,0:17:44.65,0:17:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah diremehkan olehmu,\Nbenar-benar membuat kesal.
Dialogue: 0,0:17:55.47,0:17:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu lemah! Terlalu lemah!\NSungguh menyedihkan!
Dialogue: 0,0:17:58.54,0:18:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanmu sekarang, jangankan lalat,\Nbahkan nyamuk pun lebih kuat darimu.
Dialogue: 0,0:18:01.68,0:18:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini!
Dialogue: 0,0:18:06.42,0:18:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk melawanmu sekarang,\Ntubuh Tsumugi saja sudah cukup.
Dialogue: 0,0:18:10.09,0:18:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku pasti menang.
Dialogue: 0,0:18:12.63,0:18:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar! Aku akan memberimu pelajaran!
Dialogue: 0,0:18:17.13,0:18:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar rubah kerdil!
Dialogue: 0,0:18:18.60,0:18:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah sekarang kau berhak\Nberkata seperti itu?
Dialogue: 0,0:18:21.17,0:18:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betapa menyedihkan penampilanmu,\Nlihatlah di cermin.
Dialogue: 0,0:18:24.58,0:18:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:18:30.59,0:18:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung!
Dialogue: 0,0:18:31.68,0:18:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat berhenti! Cepat berhenti!
Dialogue: 0,0:18:33.07,0:18:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu lambat! Terlalu lambat!
Dialogue: 0,0:18:34.66,0:18:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakannya benar-benar lamban.
Dialogue: 0,0:18:36.28,0:18:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh penampilan yang menyedihkan!
Dialogue: 0,0:18:38.12,0:18:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buatlah aku lebih senang lagi!
Dialogue: 0,0:18:40.49,0:18:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan banyak bicara!
Dialogue: 0,0:18:41.41,0:18:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, kekuatanmu berkurang drastis ya.
Dialogue: 0,0:18:44.92,0:18:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan lebih lemah\Ndari 500 tahun yang lalu.
Dialogue: 0,0:18:48.50,0:18:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, akan kutunjukkan\Nkekuatanku yang sebenarnya.
Dialogue: 0,0:18:51.80,0:18:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu lambat!
Dialogue: 0,0:19:04.13,0:19:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung!
Dialogue: 0,0:19:06.74,0:19:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ini sudah\Nputaran ke-33.332, 'kan?
Dialogue: 0,0:19:11.46,0:19:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menang untuk ke-22.222 kalinya.
Dialogue: 0,0:19:15.80,0:19:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang akan menghitung\Nhal sepele seperti itu?
Dialogue: 0,0:19:18.92,0:19:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak menerima kekalahan?
Dialogue: 0,0:19:20.67,0:19:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanmu berkurang karena bergaul\Nterlalu dekat dengan manusia itu, 'kan?
Dialogue: 0,0:19:24.81,0:19:28.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang menipu kepala pendeta Kuil Inari,
Dialogue: 0,0:19:28.11,0:19:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak berhak mengaturku!
Dialogue: 0,0:19:31.38,0:19:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani-beraninya bilang aku menipu!
Dialogue: 0,0:19:33.25,0:19:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia-manusia itu yang jatuh cinta\Npadaku sendiri tanpa kuminta.
Dialogue: 0,0:19:36.84,0:19:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya?
Dialogue: 0,0:19:38.25,0:19:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sekarang, aku sudah\Nberurusan dengan banyak manusia.
Dialogue: 0,0:19:41.64,0:19:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka aku tahu betul soal itu.
Dialogue: 0,0:19:43.74,0:19:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu dekat dengan manusia\Nakan menghancurkan dirimu sendiri.
Dialogue: 0,0:19:50.14,0:19:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, Anda baik-baik saja?
Dialogue: 0,0:19:52.06,0:19:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik-baik saja, jangan khawatir.\NItu hanya lelucon.
Dialogue: 0,0:19:55.25,0:19:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Anda sudah menguras kekuatan lagi.
Dialogue: 0,0:19:58.89,0:20:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:20:00.75,0:20:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jimat berharga itu hancur.
Dialogue: 0,0:20:04.53,0:20:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipikirkan, buat lagi saja.
Dialogue: 0,0:20:08.59,0:20:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku istirahat sebentar.
Dialogue: 0,0:20:15.82,0:20:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dikatakan Nona Tenko tadi…
Dialogue: 0,0:20:19.52,0:20:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:20.54,0:20:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu dekat dengan manusia\Nakan menghancurkan dirimu sendiri.
Dialogue: 0,0:20:27.10,0:20:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:20:28.65,0:20:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan urusanmu.
Dialogue: 0,0:20:31.02,0:20:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dikelabui olehnya.
Dialogue: 0,0:20:33.96,0:20:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:20:36.22,0:20:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah benar tidak masalah\Naku tinggal bersamamu?
Dialogue: 0,0:20:41.92,0:20:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:20:43.29,0:20:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sukarela tinggal di sini,\Nhanya itu.
Dialogue: 0,0:20:53.23,0:20:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh menyenangkan, Kakak.
Dialogue: 0,0:20:55.59,0:20:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tertipu oleh selembar kertas saja.
Dialogue: 0,0:20:58.18,0:21:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang tua itu benaran bodoh.
Dialogue: 0,0:21:05.78,0:21:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:21:06.93,0:21:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh.
Dialogue: 0,0:21:08.61,0:21:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pengusir roh.
Dialogue: 0,0:21:10.06,0:21:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sepertinya mendapat\Nbanyak keuntungan di kota kami.
Dialogue: 0,0:21:13.35,0:21:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:21:14.44,0:21:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kabur!
Dialogue: 0,0:21:15.34,0:21:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah mengetahui\Nsemua perbuatan jahat kalian.
Dialogue: 0,0:21:18.33,0:21:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera pergi dari kota ini!
Dialogue: 0,0:21:22.61,0:21:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar! Jangan datang lagi!
Dialogue: 0,0:21:28.15,0:21:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini, mereka seharusnya\Nbisa mengambil pelajaran dari hal ini.
Dialogue: 0,0:21:30.00,0:21:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja.
Dialogue: 0,0:21:35.97,0:21:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, para onmyoji sialan!
Dialogue: 0,0:21:39.65,0:21:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kubilang, Kakak?
Dialogue: 0,0:21:41.81,0:21:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu kota ini.
Dialogue: 0,0:21:43.68,0:21:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:21:44.67,0:21:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ragu-ragu sekarang.
Dialogue: 0,0:21:46.23,0:21:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit.
Dialogue: 0,0:21:47.49,0:21:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:21:52.27,0:21:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, ada apa?
Dialogue: 0,0:23:31.63,0:23:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 9.
Dialogue: 0,0:23:33.14,0:23:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Jalan-Jalan di Kota,\NDatang Tamu Tak Diundang.
