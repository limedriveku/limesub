Dialogue: 0,0:00:02.12,0:00:04.44,sign,,0000,0000,0000,,IWAYAMAYA, YAMANAKADO
Dialogue: 0,0:00:17.07,0:00:18.06,sign,,0000,0000,0000,,HOJOCHO, FESTIVAL TIGA TAHUN SEKALI
Dialogue: 0,0:00:21.33,0:00:24.84,sign,,0000,0000,0000,,"YAKISOBA SPESIAL"
Dialogue: 0,0:01:42.80,0:01:44.54,sign,,0000,0000,0000,,YAKITORI, PISANG COKELAT
Dialogue: 0,0:01:48.27,0:01:49.58,sign,,0000,0000,0000,,KARI DEWA DAN SILUMAN
Dialogue: 0,0:04:24.54,0:04:28.93,sign,,0000,0000,0000,,DENDAM ROH JAHAT MENODAI RITUAL
Dialogue: 0,0:04:31.09,0:04:31.77,sign,,0000,0000,0000,,"GUDANG MAINAN"
Dialogue: 0,0:06:03.43,0:06:04.93,sign,,0000,0000,0000,,"GUDANG MAINAN"
Dialogue: 0,0:15:43.91,0:15:45.09,sign,,0000,0000,0000,,USIR
Dialogue: 0,0:19:18.93,0:19:20.14,sign,,0000,0000,0000,,"USIR"
Dialogue: 0,0:23:36.11,0:23:40.08,sign,,0000,0000,0000,,SELANJUTNYA: TAMAN DEWA KUSUNOKI
Dialogue: 0,0:00:11.32,0:00:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, lihat, lihat!
Dialogue: 0,0:00:14.22,0:00:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sedang mempersiapkan festival.
Dialogue: 0,0:00:18.06,0:00:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok Festival Hojo tiga tahun sekali.
Dialogue: 0,0:00:21.33,0:00:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ritual yang dilakukan orang zaman dulu
Dialogue: 0,0:00:24.84,0:00:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk berterima kasih atas berkah gunung.
Dialogue: 0,0:00:27.74,0:00:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkah gunung, ya?
Dialogue: 0,0:00:29.68,0:00:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunung yang dimaksud…
Dialogue: 0,0:00:31.18,0:00:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja adalah aku.
Dialogue: 0,0:00:33.68,0:00:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang banyak orang\Nyang sudah lupa asal-usulnya.
Dialogue: 0,0:00:40.27,0:00:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krepes!
Dialogue: 0,0:00:41.48,0:00:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sana pisang cokelat.
Dialogue: 0,0:00:43.27,0:00:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada marshmallow dan kue telur juga.
Dialogue: 0,0:00:45.74,0:00:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo besok kita beli.
Dialogue: 0,0:00:47.20,0:00:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi, kau terlalu bersemangat.
Dialogue: 0,0:00:49.50,0:00:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:00:51.99,0:00:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Kak.
Dialogue: 0,0:00:54.79,0:00:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Pak Echigoya juga mau buka stan?
Dialogue: 0,0:00:58.50,0:00:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:00:59.87,0:01:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan persembahkan banyak\Nmanju spesial kesukaan Tuan Inu.
Dialogue: 0,0:01:06.17,0:01:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Inu pasti akan sangat senang.
Dialogue: 0,0:01:08.80,0:01:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah Dewa Gunung.
Dialogue: 0,0:01:12.01,0:01:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek, ayo kita cepat pulang,\Nlanjutkan persiapan untuk besok.
Dialogue: 0,0:01:15.64,0:01:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku akan melatihmu dengan baik.
Dialogue: 0,0:01:19.86,0:01:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera mandiri.
Dialogue: 0,0:01:22.23,0:01:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek tenang saja.
Dialogue: 0,0:01:24.73,0:01:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, masih sepuluh tahun\Nterlalu dini untukmu.
Dialogue: 0,0:01:26.94,0:01:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sake manju buatanku sebelumnya\Nlumayan berhasil.
Dialogue: 0,0:01:34.28,0:01:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru sebentar tak bertemu,\Ncucunya sudah sangat bisa diandalkan, ya.
Dialogue: 0,0:01:38.41,0:01:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa depan Echigoya seharusnya aman.
Dialogue: 0,0:01:50.11,0:01:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali orang yang meramaikan\Nfestival untuk Tuan Dewa Gunung.
Dialogue: 0,0:01:55.10,0:01:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh mengagumkan.
Dialogue: 0,0:01:56.39,0:01:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengaturan yang bagus.
Dialogue: 0,0:01:59.18,0:02:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, Anda terlalu silau!
Dialogue: 0,0:02:01.14,0:02:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kendalikan dirimu.
Dialogue: 0,0:02:06.90,0:02:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar saja,
Dialogue: 0,0:02:08.15,0:02:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung bisa tampil seperti ini
Dialogue: 0,0:02:10.53,0:02:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berkat orang-orang di kota.
Dialogue: 0,0:02:13.20,0:02:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,\Nmau beli camilan Jepang apa?
Dialogue: 0,0:02:17.20,0:02:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan saja kalau ada yang diinginkan.
Dialogue: 0,0:02:19.79,0:02:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Tuan Dewa Gunung\Nadalah tokoh utama festival besok.
Dialogue: 0,0:02:26.16,0:02:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:02:28.16,0:02:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuterima kebaikanmu.
Dialogue: 0,0:03:04.90,0:03:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:04:29.16,0:04:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, hebat!
Dialogue: 0,0:04:31.09,0:04:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo! Ayo!
Dialogue: 0,0:04:31.77,0:04:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya, semangat!
Dialogue: 0,0:04:33.38,0:04:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga takkan kalah.
Dialogue: 0,0:04:35.92,0:04:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya, seperti ini!\N- Lebih semangat lagi!
Dialogue: 0,0:04:38.09,0:04:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa.
Dialogue: 0,0:04:39.09,0:04:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih kuat.
Dialogue: 0,0:04:41.26,0:04:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main gasing, jadi nostalgia.
Dialogue: 0,0:04:43.89,0:04:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu permainan Tahun Baru, 'kan?
Dialogue: 0,0:04:46.72,0:04:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tapi di toko ini
Dialogue: 0,0:04:49.31,0:04:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya bisa dimainkan kapan saja.
Dialogue: 0,0:04:50.45,0:04:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalah lagi.\N- Aku menang!
Dialogue: 0,0:04:52.60,0:04:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat!
Dialogue: 0,0:04:53.40,0:04:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuk main gim di rumahku.
Dialogue: 0,0:04:54.78,0:04:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ayo, ayo.
Dialogue: 0,0:04:56.28,0:04:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lain kali aku pasti menang.\N- Ayo, ayo!
Dialogue: 0,0:05:01.74,0:05:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, mau main?
Dialogue: 0,0:05:03.78,0:05:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, ayo bertanding!
Dialogue: 0,0:05:09.12,0:05:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tidak main,\Ntidak tahu bisa atau tidak.
Dialogue: 0,0:05:12.04,0:05:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat seperti ini.
Dialogue: 0,0:05:16.25,0:05:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:05:18.71,0:05:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kau hebat!
Dialogue: 0,0:05:20.45,0:05:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan hebat.
Dialogue: 0,0:05:21.89,0:05:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak seberapa. Tuan Dewa Gunung bisa?
Dialogue: 0,0:05:26.35,0:05:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung?
Dialogue: 0,0:05:28.52,0:05:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal kecil seperti ini, sangat mudah bagiku.
Dialogue: 0,0:05:35.56,0:05:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu curang, 'kan?
Dialogue: 0,0:05:37.86,0:05:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana Anda melemparnya?
Dialogue: 0,0:05:40.40,0:05:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lempar saja seperti ini.
Dialogue: 0,0:05:51.79,0:05:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal latihan pasti bisa.
Dialogue: 0,0:05:54.23,0:05:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, semangat!
Dialogue: 0,0:06:03.43,0:06:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda menyebalkan!
Dialogue: 0,0:06:05.39,0:06:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali harus melilit tali perlahan.
Dialogue: 0,0:06:09.47,0:06:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:06:10.73,0:06:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lemparannya buruk karena\Nbentuk gasingnya jelek.
Dialogue: 0,0:06:13.90,0:06:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya bukan seperti itu.
Dialogue: 0,0:06:15.98,0:06:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ini masalahnya.
Dialogue: 0,0:06:18.07,0:06:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dohyo.
Dialogue: 0,0:06:19.27,0:06:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:20.23,0:06:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat sempit seperti ini\Nsama sekali tidak cocok denganku.
Dialogue: 0,0:06:23.86,0:06:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda benar-benar kompetitif.
Dialogue: 0,0:06:27.99,0:06:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda melemparnya terlalu kuat.
Dialogue: 0,0:06:30.79,0:06:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini coba letakkan\Npelan-pelan di dohyo.
Dialogue: 0,0:06:35.46,0:06:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, maju!
Dialogue: 0,0:06:40.88,0:06:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, Anda berhasil!
Dialogue: 0,0:06:43.47,0:06:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal sepele.
Dialogue: 0,0:06:45.68,0:06:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah bisa bertanding.
Dialogue: 0,0:06:47.74,0:06:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:49.39,0:06:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mulai sekarang.
Dialogue: 0,0:06:50.85,0:06:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan gasing satu ronde.
Dialogue: 0,0:06:53.60,0:06:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkirkan gasing lawan dari dohyo;
Dialogue: 0,0:06:56.66,0:06:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau tidak, yang berputar\Nlebih lama yang menang.
Dialogue: 0,0:06:59.25,0:07:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan berbelas kasih.
Dialogue: 0,0:07:01.99,0:07:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai keinginanku.
Dialogue: 0,0:07:03.86,0:07:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap, mulai!
Dialogue: 0,0:07:08.78,0:07:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo!\N- Bagus!
Dialogue: 0,0:07:10.71,0:07:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semangat, Dewa Gunung, Minato!\N- Benar, seperti ini!
Dialogue: 0,0:07:13.20,0:07:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, mari kita tentukan pemenangnya!
Dialogue: 0,0:07:16.84,0:07:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:07:19.96,0:07:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, tidak membalas?
Dialogue: 0,0:07:22.13,0:07:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu. Aku adalah Dewa Gunung.
Dialogue: 0,0:07:25.22,0:07:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam tak tergoyahkan bagai gunung\Nadalah jalan cepat menuju kemenangan.
Dialogue: 0,0:07:30.72,0:07:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu…
Dialogue: 0,0:07:34.43,0:07:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung bertahan lagi.
Dialogue: 0,0:07:36.27,0:07:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan seru,\Ntak ada yang mau mengalah.
Dialogue: 0,0:07:38.86,0:07:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat untuk keduanya!
Dialogue: 0,0:07:55.58,0:07:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan selesai. Dewa Gunung menang!
Dialogue: 0,0:07:59.54,0:08:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah.
Dialogue: 0,0:08:00.79,0:08:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung hebat sekali!
Dialogue: 0,0:08:02.42,0:08:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh duel yang menegangkan!
Dialogue: 0,0:08:11.85,0:08:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harima, ada apa?
Dialogue: 0,0:08:13.22,0:08:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:08:15.33,0:08:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:08:17.31,0:08:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, ini tempat ketiga.
Dialogue: 0,0:08:20.66,0:08:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh merepotkan.
Dialogue: 0,0:08:22.65,0:08:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak menemukan\Npara pengusir roh itu.
Dialogue: 0,0:08:26.42,0:08:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu…
Dialogue: 0,0:08:35.62,0:08:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya pusaran energi negatif\Nyang memunculkan roh jahat itu apa?
Dialogue: 0,0:08:40.03,0:08:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah benda besar itu\Njuga perbuatan para pengusir roh?
Dialogue: 0,0:08:43.95,0:08:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Ansho mengendalikannya\Nuntuk menciptakan roh jahat?
Dialogue: 0,0:08:48.68,0:08:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku tahu.
Dialogue: 0,0:08:50.14,0:08:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terpaksa menangkap lalu\Nmemaksa mereka mengaku.
Dialogue: 0,0:08:52.18,0:08:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana caranya?
Dialogue: 0,0:08:53.93,0:08:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:08:55.31,0:08:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikawa!
Dialogue: 0,0:08:56.52,0:08:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menghilang tanpa pamit lagi!
Dialogue: 0,0:08:58.77,0:09:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatku khawatir… ah, bukan begitu.
Dialogue: 0,0:09:01.02,0:09:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat pekerjaanku bertambah!
Dialogue: 0,0:09:03.15,0:09:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:09:04.15,0:09:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendapat informasi anonim.
Dialogue: 0,0:09:07.49,0:09:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya melihat orang\Nyang mirip pengusir roh.
Dialogue: 0,0:09:09.99,0:09:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anonim?
Dialogue: 0,0:09:11.16,0:09:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasinya bisa dipercaya?
Dialogue: 0,0:09:13.53,0:09:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu,\Ndi rumah kosong depan sana.
Dialogue: 0,0:09:16.24,0:09:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, ayo ke sana.
Dialogue: 0,0:09:26.75,0:09:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang-barang sudah dibeli, saatnya pulang.
Dialogue: 0,0:09:29.71,0:09:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:40.85,0:09:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu…
Dialogue: 0,0:09:44.85,0:09:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato?
Dialogue: 0,0:09:50.75,0:09:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah lihat?
Dialogue: 0,0:09:52.99,0:09:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato!
Dialogue: 0,0:09:54.78,0:09:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:09:57.02,0:09:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tadi
Dialogue: 0,0:09:57.95,0:10:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mirip dengan tamu di penginapan onsen kami\Nwaktu aku kecil dulu.
Dialogue: 0,0:10:02.79,0:10:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu yang tahu ada\Nkekuatan mengusir roh jahat di tulisanku.
Dialogue: 0,0:10:06.79,0:10:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi seharusnya dia\Ntidak mungkin ada di sini.
Dialogue: 0,0:10:11.18,0:10:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin orang itu adalah\Npengusir roh pengelana.
Dialogue: 0,0:10:14.99,0:10:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia datang karena\Nmerasakan sesuatu di kota ini.
Dialogue: 0,0:10:19.43,0:10:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu apa?
Dialogue: 0,0:10:21.56,0:10:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, gawat.
Dialogue: 0,0:10:22.98,0:10:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat bahaya!
Dialogue: 0,0:10:26.10,0:10:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu…
Dialogue: 0,0:10:27.15,0:10:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Roh Angin.
Dialogue: 0,0:10:28.61,0:10:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka memberi tahu kita\Nbahwa ada bahaya.
Dialogue: 0,0:10:31.61,0:10:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:32.90,0:10:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sepertinya bilang
Dialogue: 0,0:10:34.78,0:10:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatan jahat yang dirasakan sebelumnya
Dialogue: 0,0:10:36.49,0:10:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus meningkat.
Dialogue: 0,0:10:39.58,0:10:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda pernah mengatakannya, 'kan?
Dialogue: 0,0:10:41.33,0:10:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebenarnya apa?
Dialogue: 0,0:10:43.91,0:10:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:10:45.58,0:10:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Fujin, Tuan Raijin, ada apa?
Dialogue: 0,0:10:48.96,0:10:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya jadi rumit,\Nmakanya kami datang memberitahumu.
Dialogue: 0,0:10:51.97,0:10:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi rumit?
Dialogue: 0,0:10:53.51,0:10:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncul pintu masuk\Nwilayah dewa terbengkalai yang aneh.
Dialogue: 0,0:10:56.64,0:10:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya sangat besar.
Dialogue: 0,0:10:58.05,0:11:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat keluar dari dalamnya.
Dialogue: 0,0:11:00.39,0:11:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat keluar? Hal seperti itu…
Dialogue: 0,0:11:03.60,0:11:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga tidak pernah dengar.
Dialogue: 0,0:11:05.92,0:11:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga bisa berpindah. Sungguh misterius.
Dialogue: 0,0:11:10.60,0:11:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan jahat yang dirasakan\Noleh Tuan Dewa Gunung, jangan-jangan…
Dialogue: 0,0:11:13.74,0:11:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, memang itu.
Dialogue: 0,0:11:15.78,0:11:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaanku.
Dialogue: 0,0:11:16.78,0:11:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kedalaman wilayah dewa terbengkalai itu
Dialogue: 0,0:11:19.24,0:11:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tersembunyi kekuatan yang luar biasa.
Dialogue: 0,0:11:27.67,0:11:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menerima tugas pengusiran roh lagi?
Dialogue: 0,0:11:30.00,0:11:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:30.96,0:11:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka muncul roh jahat sebanyak ini.
Dialogue: 0,0:11:34.14,0:11:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus berterima kasih pada pusaran itu.
Dialogue: 0,0:11:37.29,0:11:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita benar-benar untung besar.
Dialogue: 0,0:11:39.51,0:11:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesti cari untung lebih banyak lagi.
Dialogue: 0,0:11:43.97,0:11:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kalian hidup senang, ya.
Dialogue: 0,0:11:46.98,0:11:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau ke mana?
Dialogue: 0,0:11:48.40,0:11:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:11:52.13,0:11:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai di sini saja!
Dialogue: 0,0:11:53.15,0:11:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertindak sembarangan,\Nkalian akan menyesal.
Dialogue: 0,0:12:03.12,0:12:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, jelaskan padaku.
Dialogue: 0,0:12:07.04,0:12:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian yang merobek jimat\Nyang ditempel di kota, 'kan?
Dialogue: 0,0:12:11.17,0:12:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pusaran energi negatif\Nyang memunculkan roh jahat itu apa?
Dialogue: 0,0:12:13.84,0:12:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kami yang merobek jimat,
Dialogue: 0,0:12:16.72,0:12:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kami tidak tahu soal pusaran itu.
Dialogue: 0,0:12:20.44,0:12:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong!
Dialogue: 0,0:12:21.76,0:12:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh!
Dialogue: 0,0:12:23.01,0:12:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kenapa kalian kabur?
Dialogue: 0,0:12:25.35,0:12:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pertama kali menemukan itu,
Dialogue: 0,0:12:28.98,0:12:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami merasa bisa memanfaatkannya.
Dialogue: 0,0:12:36.91,0:12:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh jahat…
Dialogue: 0,0:12:38.20,0:12:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, bagaimana ini?
Dialogue: 0,0:12:40.16,0:12:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda ini bisa dimanfaatkan.
Dialogue: 0,0:12:41.87,0:12:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:43.12,0:12:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kita biarkan benda itu begitu saja,
Dialogue: 0,0:12:45.75,0:12:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}roh jahat di kota ini akan terus bertambah.
Dialogue: 0,0:12:48.67,0:12:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita bisa meraup untung besar\Ndari pekerjaan mengusir roh.
Dialogue: 0,0:12:52.42,0:12:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:12:54.29,0:12:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bermaksud membuat kota ini\Ndipenuhi roh jahat,
Dialogue: 0,0:12:57.42,0:13:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya kami merobek jimat yang mengganggu.
Dialogue: 0,0:13:01.97,0:13:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu saja.
Dialogue: 0,0:13:03.10,0:13:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pura-pura bodoh!
Dialogue: 0,0:13:05.14,0:13:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pusaran energi negatif itu\Njuga perbuatan kalian, 'kan?
Dialogue: 0,0:13:07.73,0:13:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalian mengendalikannya?
Dialogue: 0,0:13:09.52,0:13:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami benar-benar tidak tahu.
Dialogue: 0,0:13:11.23,0:13:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengendalikan benda semacam itu\Nterlalu konyol.
Dialogue: 0,0:13:13.86,0:13:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong percaya pada kami.
Dialogue: 0,0:13:15.77,0:13:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kedua orang ini benar-benar\Ntidak tahu apa-apa?
Dialogue: 0,0:13:19.78,0:13:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:21.86,0:13:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apa sebenarnya itu?
Dialogue: 0,0:13:26.95,0:13:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa ini?
Dialogue: 0,0:13:28.66,0:13:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awasi mereka berdua.
Dialogue: 0,0:13:30.52,0:13:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:13:31.54,0:13:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harima!
Dialogue: 0,0:13:36.54,0:13:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:13:47.39,0:13:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang!
Dialogue: 0,0:13:56.15,0:13:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:13:57.57,0:13:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato.
Dialogue: 0,0:14:00.47,0:14:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki Minato!
Dialogue: 0,0:14:02.03,0:14:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima!
Dialogue: 0,0:14:03.32,0:14:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:14:04.57,0:14:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik-baik saja.
Dialogue: 0,0:14:05.66,0:14:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih penting, itu…\Nwilayah dewa terbengkalai.
Dialogue: 0,0:14:08.39,0:14:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah dewa terbengkalai?
Dialogue: 0,0:14:10.04,0:14:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakni wilayah dewa yang ditinggalkan\Noleh dewa penciptanya.
Dialogue: 0,0:14:16.08,0:14:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kali aku melihat wilayah dewa\Nyang begitu besar dan melahirkan roh jahat.
Dialogue: 0,0:14:26.55,0:14:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa? Kau baik-baik saja?
Dialogue: 0,0:14:32.98,0:14:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi jahat sedang menyebar.
Dialogue: 0,0:14:34.82,0:14:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus begini, semua orang akan…
Dialogue: 0,0:14:40.36,0:14:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihatnya.
Dialogue: 0,0:14:41.49,0:14:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam sana bersembunyi\Nroh jahat yang kuat.
Dialogue: 0,0:14:45.82,0:14:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima, ada roh jahat\Nyang hebat di dalam sana.
Dialogue: 0,0:14:49.20,0:14:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:50.87,0:14:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya itu roh jahat penuh dendam
Dialogue: 0,0:14:53.16,0:14:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kepercayaan pada dewa dikhianati.
Dialogue: 0,0:14:59.75,0:15:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian, mundur!
Dialogue: 0,0:15:13.64,0:15:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, wilayah dewa terbengkalai itu\Nmenghilang!
Dialogue: 0,0:15:17.81,0:15:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai?
Dialogue: 0,0:15:19.07,0:15:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lengah, masih ada banyak roh jahat.
Dialogue: 0,0:15:24.69,0:15:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya terlalu banyak.
Dialogue: 0,0:15:26.24,0:15:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato!
Dialogue: 0,0:15:31.19,0:15:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:15:32.74,0:15:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi negatif ini sangat menakutkan.
Dialogue: 0,0:15:35.92,0:15:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku sakit sekali,\Ntidak bisa dibuka sama sekali.
Dialogue: 0,0:15:39.09,0:15:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badan tidak bertenaga.
Dialogue: 0,0:15:41.55,0:15:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuusir sekarang juga.
Dialogue: 0,0:15:45.09,0:15:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup seperti ini saja.
Dialogue: 0,0:15:48.13,0:15:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan datang!
Dialogue: 0,0:15:53.26,0:15:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, kekuatan pengusiran tidak cukup.
Dialogue: 0,0:15:56.10,0:15:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah harus pakai pena tinta\Nyang biasa digunakan?
Dialogue: 0,0:15:58.56,0:16:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Harima, aku akan pulang dulu
Dialogue: 0,0:16:00.61,0:16:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membuat jimat yang lebih kuat.
Dialogue: 0,0:16:02.73,0:16:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mohon bantuannya.
Dialogue: 0,0:16:11.24,0:16:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:16:12.78,0:16:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, yang benar saja.
Dialogue: 0,0:16:17.04,0:16:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang saatnya!
Dialogue: 0,0:16:18.54,0:16:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian jangan kabur!
Dialogue: 0,0:16:20.42,0:16:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang itu…
Dialogue: 0,0:16:21.96,0:16:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Katsuragi, Tuan Seishiro!
Dialogue: 0,0:16:24.80,0:16:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, menangani roh-roh jahat itu\Nadalah tugas utama.
Dialogue: 0,0:16:27.26,0:16:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, pokoknya cepatlah pergi.
Dialogue: 0,0:16:33.02,0:16:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bangun!
Dialogue: 0,0:16:35.52,0:16:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baik-baik saja?
Dialogue: 0,0:16:37.88,0:16:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh memalukan.
Dialogue: 0,0:16:39.22,0:16:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, maaf.
Dialogue: 0,0:16:41.53,0:16:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, aku akan membuat jimat.
Dialogue: 0,0:16:44.33,0:16:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:52.07,0:16:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai festival besok dibatalkan.
Dialogue: 0,0:16:58.64,0:16:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori?
Dialogue: 0,0:17:03.96,0:17:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah dewa terbengkalai?
Dialogue: 0,0:17:05.30,0:17:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah diusir Tuan Dewa Gunung.
Dialogue: 0,0:17:08.01,0:17:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu masuk wilayah dewa berpindah tempat.
Dialogue: 0,0:17:10.76,0:17:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti belum berhasil diusir?
Dialogue: 0,0:17:12.53,0:17:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:13.42,0:17:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam sana masih ada roh jahat.
Dialogue: 0,0:17:17.67,0:17:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus begini, hewan-hewan di gunung…
Dialogue: 0,0:17:22.40,0:17:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa roh jahat itu\Nmenargetkan Gunung Hojo?
Dialogue: 0,0:17:25.40,0:17:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah roh jahat yang percaya\Npada para dewa, tapi dikhianati.
Dialogue: 0,0:17:29.28,0:17:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mestinya melampiaskan\Nkemarahannya padaku.
Dialogue: 0,0:17:32.66,0:17:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin...\NIni bukan kesalahanmu.
Dialogue: 0,0:17:43.33,0:17:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung-burung kecil…
Dialogue: 0,0:17:47.30,0:17:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini ada ikan koi.
Dialogue: 0,0:17:51.42,0:17:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hewan-hewan dari gunung?
Dialogue: 0,0:17:53.89,0:17:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mungkin datang\Nuntuk mengusir energi negatif.
Dialogue: 0,0:17:57.83,0:17:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, badanmu…
Dialogue: 0,0:18:04.10,0:18:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat tidak nyaman.
Dialogue: 0,0:18:06.65,0:18:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, bagaimana bisa…
Dialogue: 0,0:18:08.65,0:18:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena gunung tercemar?
Dialogue: 0,0:18:12.03,0:18:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya begitu saja.
Dialogue: 0,0:18:14.66,0:18:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumber kekuatanku berasal dari
Dialogue: 0,0:18:16.95,0:18:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekaguman manusia terhadap gunung.
Dialogue: 0,0:18:20.37,0:18:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu terputus oleh energi negatif,
Dialogue: 0,0:18:23.21,0:18:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak akan bisa\Nmempertahankan wujud ini.
Dialogue: 0,0:18:25.88,0:18:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus segera mengusir roh jahat.
Dialogue: 0,0:18:28.17,0:18:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, Tuan Dewa Gunung\Ndan yang lainnya akan…
Dialogue: 0,0:18:32.72,0:18:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Saiga!
Dialogue: 0,0:18:40.47,0:18:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, mohon bantuannya.
Dialogue: 0,0:18:42.39,0:18:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:18:44.56,0:18:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penpen!
Dialogue: 0,0:18:46.02,0:18:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penpen!
Dialogue: 0,0:18:47.56,0:18:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sha!
Dialogue: 0,0:18:49.36,0:18:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoeru!
Dialogue: 0,0:18:52.74,0:18:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya sangat banyak.
Dialogue: 0,0:19:02.33,0:19:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Horikawa.
Dialogue: 0,0:19:03.54,0:19:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi jauh dariku.
Dialogue: 0,0:19:07.71,0:19:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-bodoh! Jangan melirik-lirik!
Dialogue: 0,0:19:10.35,0:19:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan! Kau selalu saja jadi beban.
Dialogue: 0,0:19:18.93,0:19:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai.
Dialogue: 0,0:19:20.81,0:19:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Licik sekali.
Dialogue: 0,0:19:23.89,0:19:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu masuk wilayah dewa\Nberpindah lagi ke kota.
Dialogue: 0,0:19:28.90,0:19:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyelamatkan semua orang di kota.
Dialogue: 0,0:19:31.27,0:19:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena besok adalah festival yang langka.
Dialogue: 0,0:19:34.36,0:19:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan energi negatif di gunung padaku!
Dialogue: 0,0:19:37.07,0:19:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga.
Dialogue: 0,0:19:38.62,0:19:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu khawatir.
Dialogue: 0,0:19:41.20,0:19:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan merawat mereka.
Dialogue: 0,0:19:44.02,0:19:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku juga akan memikirkan cara\Nuntuk urusan di sini.
Dialogue: 0,0:19:46.71,0:19:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku kembali, kita pergi\Nmakan manju khusus Echigoya bersama.
Dialogue: 0,0:19:50.09,0:19:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:51.39,0:19:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:20:00.31,0:20:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:02.05,0:20:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:20:04.10,0:20:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya Zamrud…
Dialogue: 0,0:20:12.77,0:20:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia anak lelaki saat itu?
Dialogue: 0,0:20:15.44,0:20:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan padamu.
Dialogue: 0,0:20:22.62,0:20:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:20:24.45,0:20:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga datang untuk membantu.
Dialogue: 0,0:20:28.29,0:20:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:20:31.58,0:20:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita bertahan bersama.
Dialogue: 0,0:20:34.88,0:20:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai Tuan Hisui tiba.
Dialogue: 0,0:20:37.30,0:20:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerang bagaimanapun,\Nmereka tetap muncul terus.
Dialogue: 0,0:20:39.97,0:20:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus cepat diselesaikan\Nagar bisa menikmati festival.
Dialogue: 0,0:20:43.31,0:20:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival? Singkirkan pikiran\Nyang tidak perlu!
Dialogue: 0,0:20:46.39,0:20:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga, para nona.
Dialogue: 0,0:20:54.69,0:20:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu banyak.
Dialogue: 0,0:20:56.19,0:20:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika begini terus, tidak akan bertahan.
Dialogue: 0,0:20:58.36,0:20:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bagaimana?
Dialogue: 0,0:21:25.01,0:21:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:21:36.11,0:21:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung!
Dialogue: 0,0:21:46.37,0:21:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, jangan dipaksakan!
Dialogue: 0,0:21:57.55,0:21:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Dewa Gunung!
Dialogue: 0,0:23:32.35,0:23:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 12.
Dialogue: 0,0:23:34.31,0:23:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taman Dewa Kusunoki.
