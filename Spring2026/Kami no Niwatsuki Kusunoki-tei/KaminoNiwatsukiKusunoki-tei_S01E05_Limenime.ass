Dialogue: 0,0:00:03.01,0:00:04.91,tanda,,0000,0000,0000,,DAIFUKU STROBERI
Dialogue: 0,0:01:57.83,0:02:00.46,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:03:16.97,0:03:21.91,tanda,,0000,0000,0000,,WILAYAH SANG DEWI DAN KEKUATAN SEGEL
Dialogue: 0,0:03:25.74,0:03:26.48,tanda,,0000,0000,0000,,BOTAMOCHI
Dialogue: 0,0:04:17.32,0:04:19.24,tanda,,0000,0000,0000,,YAMANAKADO, TOKO SUVENIR
Dialogue: 0,0:04:43.97,0:04:45.85,tanda,,0000,0000,0000,,BERHENTI
Dialogue: 0,0:11:00.92,0:11:06.90,tanda,,0000,0000,0000,,KUSUNOKI'S GARDEN OF GODS
Dialogue: 0,0:13:14.93,0:13:15.77,tanda,,0000,0000,0000,,"TAHUN 894, PENGHAPUSAN MISI KE TANG"
Dialogue: 0,0:23:36.47,0:23:38.04,tanda,,0000,0000,0000,,SELANJUTNYA: TAMU YANG BERBONDONG-BONDONG\NKE TAMAN MUSIM SEMI
Dialogue: 0,0:00:05.78,0:00:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai ditulis.
Dialogue: 0,0:00:07.20,0:00:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, bagaimana rasanya?
Dialogue: 0,0:00:11.38,0:00:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging buah dan jusnya yang segar.
Dialogue: 0,0:00:14.20,0:00:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenikmatan duniawi yang hakiki.
Dialogue: 0,0:00:16.45,0:00:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kolaborasi pasta kacang merah halus\Ndan stroberi sangat luar biasa.
Dialogue: 0,0:00:20.12,0:00:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka Anda bisa mendeskripsikannya\Nmenggunakan bahasa Inggris.
Dialogue: 0,0:00:23.77,0:00:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hizen-an benar-benar tidak bisa diremehkan.
Dialogue: 0,0:00:27.19,0:00:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:34.43,0:00:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:00:35.85,0:00:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas luar ruangan Hoo.
Dialogue: 0,0:00:38.65,0:00:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia sedang mengajari\Nburung bulbul cara berkicau?
Dialogue: 0,0:00:41.09,0:00:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:43.71,0:00:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya "hoo" bisa lebih lebar sedikit.
Dialogue: 0,0:00:48.70,0:00:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sekali lagi.
Dialogue: 0,0:00:52.95,0:00:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya begitulah, berikutnya.
Dialogue: 0,0:00:57.83,0:01:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya bagus, patut dipuji.
Dialogue: 0,0:01:00.76,0:01:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, yang terakhir.
Dialogue: 0,0:01:08.94,0:01:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:01:10.27,0:01:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaramu salah!
Dialogue: 0,0:01:13.10,0:01:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini.
Dialogue: 0,0:01:18.48,0:01:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori sangat populer, ya.
Dialogue: 0,0:01:20.67,0:01:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu dikelilingi oleh semua makhluk.
Dialogue: 0,0:01:22.48,0:01:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat ramai.
Dialogue: 0,0:01:36.87,0:01:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim semi sudah tiba, ya.
Dialogue: 0,0:03:28.81,0:03:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Katsuragi, bagaimana situasi di sana?
Dialogue: 0,0:03:30.31,0:03:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum selesai dibersihkan.
Dialogue: 0,0:03:32.44,0:03:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas disebut\NFestival Roh Jahat Musim Semi.
Dialogue: 0,0:03:35.05,0:03:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya tidak main-main.
Dialogue: 0,0:03:36.43,0:03:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan spiritualku\Nmelemah sedikit demi sedikit.
Dialogue: 0,0:03:39.56,0:03:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka cuma keroco, serahkan saja padaku.
Dialogue: 0,0:03:42.17,0:03:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shikigami No. 1, makanlah sepuasnya.
Dialogue: 0,0:03:44.56,0:03:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sha!
Dialogue: 0,0:03:48.40,0:03:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Katsuragi.
Dialogue: 0,0:03:49.47,0:03:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:50.41,0:03:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:03:52.02,0:03:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No. 2!
Dialogue: 0,0:03:53.48,0:03:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penpen.
Dialogue: 0,0:03:55.17,0:03:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pen…
Dialogue: 0,0:03:59.64,0:04:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan lumayan banyak, ya.
Dialogue: 0,0:04:01.46,0:04:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penpen.
Dialogue: 0,0:04:03.18,0:04:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sha.
Dialogue: 0,0:04:04.47,0:04:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa? Belum kenyang?\N- Sha.
Dialogue: 0,0:04:06.26,0:04:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak apa-apa, lain kali masih ada.\N- Penpen.
Dialogue: 0,0:04:08.54,0:04:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sha.\N- Pen…
Dialogue: 0,0:04:09.88,0:04:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Roh jahat lagi?\N- Kalian tenanglah.
Dialogue: 0,0:04:12.15,0:04:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gigit kepalaku.
Dialogue: 0,0:04:13.67,0:04:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Harima!
Dialogue: 0,0:04:14.71,0:04:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, lepaskan aku! Sakit!
Dialogue: 0,0:04:23.35,0:04:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, oleh-oleh untuk semua orang\Njuga sudah dibeli.
Dialogue: 0,0:04:27.32,0:04:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:04:29.73,0:04:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, itu…
Dialogue: 0,0:04:30.77,0:04:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:31.19,0:04:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu orang yang mengendalikan burung.
Dialogue: 0,0:04:32.91,0:04:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dialah orang dalam rumor?
Dialogue: 0,0:04:34.84,0:04:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya orang\Nyang mengendalikan burung?
Dialogue: 0,0:04:36.61,0:04:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:39.90,0:04:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, makin banyak.
Dialogue: 0,0:04:41.87,0:04:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh aneh, cepat foto.
Dialogue: 0,0:04:48.24,0:04:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau keluar bersama Tuan Tori,\Nselalu menjadi seperti ini.
Dialogue: 0,0:04:55.56,0:04:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, selesai.
Dialogue: 0,0:04:57.56,0:05:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patung tembikar lucu yang ke-25 ekor,\Ntelah selesai.
Dialogue: 0,0:05:01.76,0:05:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patung tembikar bukan ke-25 ekor,\Ntapi ke-25 buah.
Dialogue: 0,0:05:06.79,0:05:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki.
Dialogue: 0,0:05:08.41,0:05:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa.
Dialogue: 0,0:05:10.02,0:05:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagar tanamannya sangat nyentrik, ya.
Dialogue: 0,0:05:14.43,0:05:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:15.35,0:05:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena pemiliknya bilang terserah aku\Nmau membuatnya seperti apa.
Dialogue: 0,0:05:19.46,0:05:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:20.51,0:05:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak mengunjungi rumahmu,\Nkondisiku sangat baik.
Dialogue: 0,0:05:24.55,0:05:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah.
Dialogue: 0,0:05:28.42,0:05:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada begitu banyak burung?
Dialogue: 0,0:05:30.25,0:05:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, ya?
Dialogue: 0,0:05:33.41,0:05:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku permisi dulu.
Dialogue: 0,0:05:35.58,0:05:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kusunoki!
Dialogue: 0,0:05:42.41,0:05:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung!
Dialogue: 0,0:05:43.92,0:05:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:05:45.46,0:05:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sisi gunung, terus bermunculan\Nwilayah dewa terbengkalai.
Dialogue: 0,0:05:48.48,0:05:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato pergi belanja dan belum kembali.
Dialogue: 0,0:05:51.72,0:05:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bagaimana?
Dialogue: 0,0:05:53.02,0:05:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panik.
Dialogue: 0,0:05:56.93,0:06:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah sebanyak itu\Ntidak bisa kalian tangani sendiri.
Dialogue: 0,0:06:00.40,0:06:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan turun tangan.
Dialogue: 0,0:06:01.84,0:06:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda akan turun tangan sendiri?
Dialogue: 0,0:06:03.84,0:06:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:09.85,0:06:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi juga.
Dialogue: 0,0:06:10.87,0:06:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya.\N- Baik.
Dialogue: 0,0:06:15.33,0:06:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Burung-burung menghilang,\Napa yang terjadi?
Dialogue: 0,0:06:23.58,0:06:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Fujin, Tuan Raijin.
Dialogue: 0,0:06:25.69,0:06:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik kau pulang lebih awal.
Dialogue: 0,0:06:28.09,0:06:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa begitu?
Dialogue: 0,0:06:29.55,0:06:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini tidak cuma muncul roh jahat,
Dialogue: 0,0:06:31.59,0:06:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi juga bermunculan wilayah\Ndewa terbengkalai secara tak wajar.
Dialogue: 0,0:06:34.48,0:06:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah dewa terbengkalai?
Dialogue: 0,0:06:36.31,0:06:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia ini ada delapan juta dewa,\Njumlah wilayah dewa juga sangat banyak.
Dialogue: 0,0:06:40.65,0:06:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antaranya juga ada wilayah dewa\Nyang ditinggalkan oleh Dewa Pencipta.
Dialogue: 0,0:06:44.77,0:06:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:06:48.83,0:06:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah muncul.
Dialogue: 0,0:06:55.20,0:06:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu apa?
Dialogue: 0,0:06:56.47,0:06:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah wilayah dewa terbengkalai.
Dialogue: 0,0:06:58.50,0:07:00.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu masuknya ada di mana-mana.
Dialogue: 0,0:07:00.38,0:07:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tanah, langit, bahkan di dalam air.
Dialogue: 0,0:07:03.25,0:07:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga bisa berpindah sendiri,\Nsangat merepotkan.
Dialogue: 0,0:07:06.69,0:07:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang ada manusia yang terseret masuk.
Dialogue: 0,0:07:10.38,0:07:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang disebut kamikakushi,\Nhilang secara misterius.
Dialogue: 0,0:07:12.52,0:07:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu sebabnya burung-burung tidak ikut?
Dialogue: 0,0:07:15.49,0:07:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar santai, ya.
Dialogue: 0,0:07:17.42,0:07:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang paling perlu berhati-hati.
Dialogue: 0,0:07:20.40,0:07:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:21.19,0:07:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena koneksi spiritualmu\Ndengan para dewa sangat tinggi.
Dialogue: 0,0:07:25.17,0:07:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan hanya karena kau\Ntinggal di wilayah dewa,
Dialogue: 0,0:07:27.41,0:07:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga karena kau pernah berendam\Ndi Onsen Dewa Gunung.
Dialogue: 0,0:07:31.00,0:07:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terseret ke wilayah dewa yang rumit,
Dialogue: 0,0:07:33.78,0:07:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak akan bisa keluar dengan\Nmengandalkan kekuatanmu sendiri.
Dialogue: 0,0:07:36.64,0:07:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berhati-hati.
Dialogue: 0,0:07:39.79,0:07:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya.
Dialogue: 0,0:07:41.30,0:07:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung sepertinya juga pergi untuk\Nmenghancurkan wilayah dewa terbengkalai.
Dialogue: 0,0:07:45.10,0:07:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung? Sampai segitunya?
Dialogue: 0,0:07:48.23,0:07:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhati-hatilah.
Dialogue: 0,0:07:49.88,0:07:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:07:51.75,0:07:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori,\Nhari ini kita ambil jalan pintas ya.
Dialogue: 0,0:08:11.30,0:08:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya banyak sekali.
Dialogue: 0,0:08:12.61,0:08:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, itu meluas ke arah rumah Minato.
Dialogue: 0,0:08:15.93,0:08:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus dihilangkan semuanya di sini.
Dialogue: 0,0:08:18.47,0:08:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita tangani secara terpisah.
Dialogue: 0,0:08:20.49,0:08:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:21.68,0:08:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:08:22.81,0:08:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo maju!
Dialogue: 0,0:08:36.28,0:08:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi di sini sangat parah.
Dialogue: 0,0:08:40.38,0:08:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ke sini.
Dialogue: 0,0:08:41.66,0:08:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi!
Dialogue: 0,0:08:44.21,0:08:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:45.75,0:08:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori, tadi kau berbicara?
Dialogue: 0,0:08:49.06,0:08:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku mendengar suara berbicara.\NApakah ini khayalanku?
Dialogue: 0,0:08:58.99,0:09:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku ditarik ke sana.
Dialogue: 0,0:09:10.98,0:09:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori?
Dialogue: 0,0:09:46.42,0:09:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tori, kau tidak apa-apa?
Dialogue: 0,0:09:51.19,0:09:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:09:53.91,0:09:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ini sangat mirip dengan\Nsaat memasuki wilayah dewa sebelumnya.
Dialogue: 0,0:09:57.73,0:09:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini juga wilayah dewa?
Dialogue: 0,0:10:00.32,0:10:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku merasa\Nagak tidak enak badan.
Dialogue: 0,0:10:03.55,0:10:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat temukan jalan keluar.
Dialogue: 0,0:10:15.06,0:10:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotak-kotak kayu ini apa?
Dialogue: 0,0:10:17.26,0:10:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya banyak sekali.
Dialogue: 0,0:10:19.65,0:10:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sebelumnya Tuan Dewa Gunung\Npernah bilang.
Dialogue: 0,0:10:22.55,0:10:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah dewa bagaikan\Ncerminan jiwa penciptanya.
Dialogue: 0,0:10:27.91,0:10:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan menciptakan ruang\Nyang paling nyaman bagi dirinya.
Dialogue: 0,0:10:33.26,0:10:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya orang ini\Nsangat menyukai kotak kayu.
Dialogue: 0,0:10:36.95,0:10:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:38.61,0:10:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:10:45.04,0:10:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udara di sini sangat buruk.
Dialogue: 0,0:10:49.33,0:10:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:50.95,0:10:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang?
Dialogue: 0,0:10:55.33,0:10:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini adalah dewa\Nyang menciptakan tempat ini.
Dialogue: 0,0:11:07.51,0:11:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini adalah dewa\Nyang menciptakan tempat ini.
Dialogue: 0,0:11:17.43,0:11:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, udara pengap ini.
Dialogue: 0,0:11:20.33,0:11:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lembap dan pengap,\Ntidur pun jadi tidak nyaman.
Dialogue: 0,0:11:23.14,0:11:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus mengganti udara.
Dialogue: 0,0:11:24.77,0:11:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu merepotkan.
Dialogue: 0,0:11:26.77,0:11:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ingin bergerak.
Dialogue: 0,0:11:29.02,0:11:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin tidur terus.
Dialogue: 0,0:11:31.77,0:11:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Er…
Dialogue: 0,0:11:32.78,0:11:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:33.99,0:11:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini wilayah dewa yang Anda ciptakan?
Dialogue: 0,0:11:37.30,0:11:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tapi siapa kau? Kau manusia, 'kan?
Dialogue: 0,0:11:41.47,0:11:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:42.50,0:11:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apakah itu Hoo?
Dialogue: 0,0:11:48.45,0:11:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau diliputi perlindungan dewa yang kuat.
Dialogue: 0,0:11:51.39,0:11:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau di sini?
Dialogue: 0,0:11:52.68,0:11:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memanggilmu, lo.
Dialogue: 0,0:11:54.54,0:11:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu.
Dialogue: 0,0:11:55.75,0:11:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau tersesat?
Dialogue: 0,0:11:57.48,0:11:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:11:58.51,0:12:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu masuk wilayah dewa seharusnya\Nsudah tertutup sepenuhnya.
Dialogue: 0,0:12:02.04,0:12:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang di dunia luar, pintu masuk\Nke wilayah dewa terbengkalai muncul terus.
Dialogue: 0,0:12:07.22,0:12:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lancang! Aku tidak\Nmeninggalkan tempat ini.
Dialogue: 0,0:12:10.95,0:12:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, apakah kekuatanku melemah?
Dialogue: 0,0:12:15.19,0:12:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuil yang kulihat sebelum terseret ke sini\Nsudah sangat lapuk.
Dialogue: 0,0:12:18.84,0:12:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Benar juga.
Dialogue: 0,0:12:20.66,0:12:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan jadi seperti ini?
Dialogue: 0,0:12:22.02,0:12:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berlalu begitu lama?
Dialogue: 0,0:12:24.13,0:12:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:12:25.37,0:12:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:25.98,0:12:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Er…
Dialogue: 0,0:12:27.25,0:12:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berhubungan dengan Fujin, 'kan?
Dialogue: 0,0:12:30.92,0:12:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pantas disebut berhubungan?
Dialogue: 0,0:12:33.35,0:12:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau memiliki Kekuatan Fujin?
Dialogue: 0,0:12:36.60,0:12:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bisa melihatnya?
Dialogue: 0,0:12:38.07,0:12:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:12:39.46,0:12:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujin yang sulit dihadapi itu bisa-bisanya\Nmeminjamkan kekuatannya kepada manusia.
Dialogue: 0,0:12:47.07,0:12:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya satu permintaan.
Dialogue: 0,0:12:49.98,0:12:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kau menggunakan Kekuatan Fujin\Nuntuk mengganti udara di sini?
Dialogue: 0,0:12:54.34,0:12:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengganti udara?
Dialogue: 0,0:12:56.37,0:12:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udara di sini sangat pengap, 'kan?
Dialogue: 0,0:12:58.90,0:13:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:13:00.32,0:13:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bisa, aku akan bantu.
Dialogue: 0,0:13:02.52,0:13:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan terakhir kali mengganti udara?
Dialogue: 0,0:13:05.79,0:13:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam dunia manusia,
Dialogue: 0,0:13:07.59,0:13:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya saat penghapusan misi ke Tang.
Dialogue: 0,0:13:12.67,0:13:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu seribu tahun yang lalu.
Dialogue: 0,0:13:14.93,0:13:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya?
Dialogue: 0,0:13:16.07,0:13:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena manusia tiba-tiba tidak ada lagi,
Dialogue: 0,0:13:18.52,0:13:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku tidak bisa mengingat nama\Ndengan baik.
Dialogue: 0,0:13:21.79,0:13:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:13:23.25,0:13:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mohon bantuannya.
Dialogue: 0,0:13:26.61,0:13:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah selesai, bisakah Anda\Nmembiarkanku pergi dari sini?
Dialogue: 0,0:13:29.57,0:13:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:13:30.70,0:13:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sepakat, ya.
Dialogue: 0,0:13:32.42,0:13:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet sekali.
Dialogue: 0,0:13:33.83,0:13:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku terlihat seperti\Ndewa yang sembarangan?
Dialogue: 0,0:13:37.03,0:13:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat begitu.
Dialogue: 0,0:13:43.96,0:13:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lubang ini…
Dialogue: 0,0:13:45.31,0:13:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian lempar semua kotak kayu\Nyang terlihat di sini ke dalamnya.
Dialogue: 0,0:13:50.77,0:13:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:14:08.74,0:14:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh spektakuler.
Dialogue: 0,0:14:19.47,0:14:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:14:23.97,0:14:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utsugi, kau baik-baik saja?
Dialogue: 0,0:14:27.01,0:14:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gagal.
Dialogue: 0,0:14:28.70,0:14:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, kalian berisik sekali.
Dialogue: 0,0:14:32.41,0:14:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung.
Dialogue: 0,0:14:34.00,0:14:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana situasinya sekarang?
Dialogue: 0,0:14:36.10,0:14:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah dewa di utara\Nsudah ditangani semuanya.
Dialogue: 0,0:14:38.85,0:14:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian barat selesai.
Dialogue: 0,0:14:40.34,0:14:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian timur juga sudah beres.
Dialogue: 0,0:14:42.32,0:14:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bekerja keras. Selanjutnya tinggal\Nmenyelamatkan Minato.
Dialogue: 0,0:14:46.74,0:14:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato?
Dialogue: 0,0:14:48.00,0:14:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak menyadarinya?\NDia terjebak di wilayah dewa.
Dialogue: 0,0:14:51.42,0:14:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:52.90,0:14:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar, teriakan Hoo tadi…
Dialogue: 0,0:14:55.65,0:14:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera selamatkan dia.
Dialogue: 0,0:14:57.53,0:14:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:59.35,0:15:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncul lagi.
Dialogue: 0,0:15:01.17,0:15:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada habisnya.
Dialogue: 0,0:15:02.60,0:15:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menuju ke arah rumah Minato pula.
Dialogue: 0,0:15:09.02,0:15:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya kalian dalam kesulitan.
Dialogue: 0,0:15:10.66,0:15:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan kami membantu.
Dialogue: 0,0:15:12.88,0:15:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:14.73,0:15:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan bagian sini padaku.\NKalian pergilah.
Dialogue: 0,0:15:17.61,0:15:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:15:18.98,0:15:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, selesaikan secepatnya.
Dialogue: 0,0:15:21.16,0:15:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik. Dewa Gunung, mau istirahat sebentar?
Dialogue: 0,0:15:24.12,0:15:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan banyak bicara!
Dialogue: 0,0:15:31.50,0:15:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh cakap.
Dialogue: 0,0:15:33.21,0:15:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengingatkanku pada waktu\Nmeletus dahsyat dulu.
Dialogue: 0,0:15:36.29,0:15:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan gunung ini terakhir kali meletus?
Dialogue: 0,0:15:39.72,0:15:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira seribu tahun yang lalu.
Dialogue: 0,0:15:41.44,0:15:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan asal tebak. Itu 1.500 tahun lalu.
Dialogue: 0,0:15:47.43,0:15:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang terakhir.
Dialogue: 0,0:15:50.59,0:15:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup?
Dialogue: 0,0:16:01.44,0:16:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jadi lebih segar.
Dialogue: 0,0:16:03.94,0:16:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi udaranya masih agak keruh.
Dialogue: 0,0:16:07.87,0:16:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu…
Dialogue: 0,0:16:09.82,0:16:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:16:10.93,0:16:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini daun pohon suci Kusunoki\Ndi taman rumahku.
Dialogue: 0,0:16:23.76,0:16:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga.
Dialogue: 0,0:16:25.24,0:16:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau membawa\Nbarang berguna seperti ini.
Dialogue: 0,0:16:28.26,0:16:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa waktu lalu,\Nini juga menyelamatkanku.
Dialogue: 0,0:16:30.99,0:16:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini untuk berjaga-jaga.
Dialogue: 0,0:16:34.50,0:16:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bekerja keras.
Dialogue: 0,0:16:37.17,0:16:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sangat bersih berkat kau.
Dialogue: 0,0:16:39.80,0:16:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat membantu Anda\Nadalah kehormatan bagiku.
Dialogue: 0,0:16:41.92,0:16:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau daun hijau itu masih ada,
Dialogue: 0,0:16:43.62,0:16:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berikanlah padaku.
Dialogue: 0,0:16:46.20,0:16:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:16:50.39,0:16:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun ini wangi sekali.
Dialogue: 0,0:16:53.67,0:16:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, sangat harum, 'kan?
Dialogue: 0,0:16:56.69,0:17:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai balasan, aku akan\Nmemberimu sedikit kekuatanku.
Dialogue: 0,0:17:01.46,0:17:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:06.15,0:17:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan seperti apa?
Dialogue: 0,0:17:07.97,0:17:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan segel.
Dialogue: 0,0:17:10.05,0:17:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyegel apa?
Dialogue: 0,0:17:12.89,0:17:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang kasatmata.
Dialogue: 0,0:17:15.25,0:17:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan manusia, obsesi yang tak bisa\Ndilepaskan, kekuatan supranatural.
Dialogue: 0,0:17:19.11,0:17:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, kau bisa menyegelnya\Npada benda yang kau inginkan.
Dialogue: 0,0:17:24.13,0:17:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kotak-kotak itu…
Dialogue: 0,0:17:25.84,0:17:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:27.21,0:17:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena manusia memohon padaku,
Dialogue: 0,0:17:28.53,0:17:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya aku membantu mereka\Nmenyegel hal-hal itu di dalamnya.
Dialogue: 0,0:17:30.48,0:17:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi yang tak bisa diabaikan,
Dialogue: 0,0:17:32.46,0:17:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasa iri dan dengki pada orang lain,
Dialogue: 0,0:17:34.65,0:17:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kekuatan supranatural\Nyang sulit dikendalikan.
Dialogue: 0,0:17:37.61,0:17:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tak mesti\Nmenyegelnya di kotak kayu.
Dialogue: 0,0:17:40.52,0:17:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup temukan benda yang menurutmu berguna.
Dialogue: 0,0:17:45.07,0:17:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kau mau pakai\Nkekuatanku atau tidak.
Dialogue: 0,0:17:50.53,0:17:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung apakah kau\Nmau menyegelnya selamanya,
Dialogue: 0,0:17:55.53,0:17:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau melepasnya dengan syarat tertentu.
Dialogue: 0,0:17:58.20,0:18:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan latihan,\Nkau bisa mengendalikannya sesukamu.
Dialogue: 0,0:18:00.41,0:18:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:18:01.47,0:18:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewi, jangan tidur.
Dialogue: 0,0:18:05.25,0:18:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana pintu keluarnya?
Dialogue: 0,0:18:07.49,0:18:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu keluar… Apa itu pintu keluar?
Dialogue: 0,0:18:12.59,0:18:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertidur.
Dialogue: 0,0:18:15.51,0:18:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mungkin membangunkannya secara paksa.\NBagaimana ini?
Dialogue: 0,0:18:19.96,0:18:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato!
Dialogue: 0,0:18:21.55,0:18:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:18:25.38,0:18:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:18:26.64,0:18:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak apa-apa.
Dialogue: 0,0:18:27.46,0:18:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menjemputku.
Dialogue: 0,0:18:29.51,0:18:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami terlambat.
Dialogue: 0,0:18:31.39,0:18:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena butuh waktu mengurus\Nwilayah dewa terbengkalai.
Dialogue: 0,0:18:33.75,0:18:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar sial.
Dialogue: 0,0:18:35.69,0:18:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dewi yang sangat kuno.
Dialogue: 0,0:18:38.23,0:18:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun dia dewi yang sangat pemalas.
Dialogue: 0,0:18:40.55,0:18:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewi yang sangat pemalas?
Dialogue: 0,0:18:42.65,0:18:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendapat kekuatan segel.
Dialogue: 0,0:18:44.75,0:18:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti Amaterasu.
Dialogue: 0,0:18:47.39,0:18:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amaterasu…
Dialogue: 0,0:18:49.02,0:18:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewi yang sangat terkenal itu?
Dialogue: 0,0:18:54.52,0:18:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sangat berbeda\Ndari yang kubayangkan.
Dialogue: 0,0:19:00.53,0:19:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalian tahu di mana aku?
Dialogue: 0,0:19:03.53,0:19:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memperkirakan lokasimu\Nlewat suara Hoo.
Dialogue: 0,0:19:07.03,0:19:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata suara Tuan Tori saat itu.
Dialogue: 0,0:19:13.48,0:19:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:19:16.33,0:19:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti saat dia bangun,\Nharus berterima kasih padanya.
Dialogue: 0,0:19:18.33,0:19:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau berterima kasih,\Nberterimakasihlah juga pada Roh Angin.
Dialogue: 0,0:19:21.40,0:19:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh Angin?
Dialogue: 0,0:19:22.84,0:19:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara anginlah yang menuntun kami ke sini.
Dialogue: 0,0:19:26.42,0:19:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum tersedot ke dalam,\Nkau tidak mendengar sesuatu?
Dialogue: 0,0:19:30.75,0:19:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ke sini.
Dialogue: 0,0:19:31.97,0:19:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi!
Dialogue: 0,0:19:34.39,0:19:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara tadi itu
Dialogue: 0,0:19:35.99,0:19:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedang memberitahuku\Nbahwa tempat itu berbahaya?
Dialogue: 0,0:19:38.78,0:19:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kau seharusnya tidak melihat\Ndan tidak mendengar suara mereka, 'kan?
Dialogue: 0,0:19:42.55,0:19:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah menyimak dengan saksama.
Dialogue: 0,0:19:44.62,0:19:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat penting untuk memusatkan perhatian\Npada mereka dan berusaha mendengar.
Dialogue: 0,0:19:48.96,0:19:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatian…
Dialogue: 0,0:19:59.20,0:20:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, ya.
Dialogue: 0,0:20:02.27,0:20:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu…
Dialogue: 0,0:20:03.78,0:20:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sudah mendengarnya.
Dialogue: 0,0:20:07.98,0:20:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih,
Dialogue: 0,0:20:09.28,0:20:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roh Angin.
Dialogue: 0,0:20:15.57,0:20:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harima, jangan tinggalkan aku!
Dialogue: 0,0:20:18.60,0:20:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah kehabisan tenaga.
Dialogue: 0,0:20:21.68,0:20:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:23.66,0:20:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh.
Dialogue: 0,0:20:25.31,0:20:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian datang terlambat sekali, onmyoji.
Dialogue: 0,0:20:29.12,0:20:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua energi jahat di area ini\Nsudah dilenyapkan oleh pengusir roh.
Dialogue: 0,0:20:34.37,0:20:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, terima kasih banyak.
Dialogue: 0,0:20:36.67,0:20:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang kalian lakukan\Ndi wilayah yurisdiksi kami?
Dialogue: 0,0:20:40.10,0:20:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada pengusir roh\Nyang tinggal di daerah setempat,
Dialogue: 0,0:20:42.79,0:20:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}onmyoji tidak boleh\Nmengusir roh jahat di kota itu.
Dialogue: 0,0:20:47.51,0:20:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah aturan tak tertulis, 'kan?
Dialogue: 0,0:20:51.07,0:20:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kami juga sibuk, pamit dulu.
Dialogue: 0,0:20:57.44,0:20:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu…
Dialogue: 0,0:20:58.84,0:21:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sekelompok pengusir roh buruk\Nyang meminta bayaran mahal.
Dialogue: 0,0:21:03.47,0:21:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah pemimpin kelompok itu.
Dialogue: 0,0:21:05.16,0:21:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga tidak menimbulkan masalah nanti.
Dialogue: 0,0:21:09.63,0:21:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, aku pulang.
Dialogue: 0,0:21:12.46,0:21:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beli oleh-oleh.
Dialogue: 0,0:21:16.09,0:21:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tuan Dewa Gunung!
Dialogue: 0,0:21:18.71,0:21:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:21:20.02,0:21:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:20.87,0:21:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini…
Dialogue: 0,0:21:22.09,0:21:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:21:24.65,0:21:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda mengecil lagi?
Dialogue: 0,0:21:27.15,0:21:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:27.82,0:21:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sepertinya menggunakan\Nterlalu banyak kekuatan.
Dialogue: 0,0:21:30.60,0:21:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan makan agak banyak,\Ncepatlah tumbuh besar.
Dialogue: 0,0:21:33.20,0:21:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga membeli camilan Jepang.
Dialogue: 0,0:21:35.08,0:21:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:39.74,0:21:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:21:41.11,0:21:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,\Nseharusnya bisa cepat kembali normal.
Dialogue: 0,0:21:44.36,0:21:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga begitu.
Dialogue: 0,0:21:46.74,0:21:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi penampilan Anda seperti ini\Njuga lumayan lucu.
Dialogue: 0,0:21:51.09,0:21:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bermain dengan Tuan Ryu dan Tuan Kirin,
Dialogue: 0,0:21:53.01,0:21:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ukuran ini pas sekali.
Dialogue: 0,0:21:54.82,0:21:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meremehkanku, aku ini Dewa Gunung!
Dialogue: 0,0:23:31.44,0:23:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 6.
Dialogue: 0,0:23:33.16,0:23:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamu yang Berbondong-bondong\Nke Taman Musim Semi.
