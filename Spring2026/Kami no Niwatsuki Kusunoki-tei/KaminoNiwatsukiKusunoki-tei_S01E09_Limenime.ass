Dialogue: 0,0:03:02.95,0:03:07.89,sign,,0000,0000,0000,,SAAT JALAN-JALAN DI KOTA,\NDATANG TAMU TAK DIUNDANG
Dialogue: 0,0:03:38.46,0:03:40.40,sign,,0000,0000,0000,,TOKO BUKU, STUDIO FOTO SASAMOTO
Dialogue: 0,0:04:06.18,0:04:07.93,sign,,0000,0000,0000,,"PENERBITAN MUSASHI"
Dialogue: 0,0:04:20.89,0:04:23.45,sign,,0000,0000,0000,,"PENERBITAN MUSASHI"
Dialogue: 0,0:06:48.53,0:06:51.63,sign,,0000,0000,0000,,"PENERBITAN MUSASHI"
Dialogue: 0,0:08:23.80,0:08:26.60,sign,,0000,0000,0000,,"RESTORAN MIMASAKA"
Dialogue: 0,0:08:48.72,0:08:51.11,sign,,0000,0000,0000,,"RESTORAN MIMASAKA"
Dialogue: 0,0:12:14.22,0:12:17.06,sign,,0000,0000,0000,,RUMAH KUSUNOKI
Dialogue: 0,0:12:37.69,0:12:40.17,sign,,0000,0000,0000,,RUMAH KUSUNOKI
Dialogue: 0,0:13:30.41,0:13:32.27,sign,,0000,0000,0000,,"RUMAH KUSUNOKI"
Dialogue: 0,0:17:06.40,0:17:08.38,sign,,0000,0000,0000,,RESTORAN MIMASAKA
Dialogue: 0,0:17:36.88,0:17:40.28,sign,,0000,0000,0000,,HALTE BUS
Dialogue: 0,0:21:25.13,0:21:27.71,sign,,0000,0000,0000,,DILARANG MASUK\NBAGI YANG TIDAK BERKEPENTINGAN
Dialogue: 0,0:23:37.24,0:23:39.24,sign,,0000,0000,0000,,SELANJUTNYA:\NLATIHAN PAKSA BERSAMA DEWA MURKA
Dialogue: 0,0:00:13.94,0:00:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup.
Dialogue: 0,0:00:15.27,0:00:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minato, apa itu?
Dialogue: 0,0:00:17.44,0:00:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jeruk musim panas yang dikirim ibuku\Ndari kampung.
Dialogue: 0,0:00:20.43,0:00:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeruk musim panas?
Dialogue: 0,0:00:22.66,0:00:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya harum.
Dialogue: 0,0:00:23.88,0:00:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya banyak.
Dialogue: 0,0:00:25.54,0:00:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nuansa musim panasnya sangat terasa.
Dialogue: 0,0:00:27.27,0:00:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, silakan makan sepuasnya.
Dialogue: 0,0:00:35.22,0:00:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum kembali seperti semula, ya.
Dialogue: 0,0:00:38.31,0:00:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak masalah?
Dialogue: 0,0:00:42.74,0:00:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya kurang bersemangat\Ndaripada biasanya.
Dialogue: 0,0:00:46.01,0:00:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah sedih karena kalah dari Nona Tenko?
Dialogue: 0,0:00:57.99,0:01:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan tak bisa kembali\Nseperti semula karena kurang energi?
Dialogue: 0,0:01:06.92,0:01:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, camilan Jepang\Nuntuk menjamu tamu sepertinya sudah habis.
Dialogue: 0,0:01:12.59,0:01:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:01:13.97,0:01:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak keberatan, maukah keluar\Nuntuk mencari makanan enak?
Dialogue: 0,0:01:18.79,0:01:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, asyik. Kalian mau makan apa?
Dialogue: 0,0:01:21.71,0:01:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung, sesekali jalan-jalan\Ndengan Minato juga bagus, 'kan?
Dialogue: 0,0:01:25.92,0:01:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami yang jaga rumah.
Dialogue: 0,0:01:28.16,0:01:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo kita pergi.
Dialogue: 0,0:01:43.83,0:01:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:03:14.22,0:03:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:03:15.26,0:03:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak keberatan,\Nsilakan naik ke pundakku.
Dialogue: 0,0:03:18.12,0:03:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh membiarkan dewa terlalu lelah.
Dialogue: 0,0:03:20.91,0:03:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tidak sungkan lagi.
Dialogue: 0,0:03:26.11,0:03:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaanmu sekarang?
Dialogue: 0,0:03:28.10,0:03:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, lumayan bagus.
Dialogue: 0,0:03:44.06,0:03:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,\Nbagaimana kalau kita ke toko itu?
Dialogue: 0,0:03:47.11,0:03:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmm…
Dialogue: 0,0:03:50.61,0:03:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana juga ada toko yang kelihatannya\Nmenjual makanan enak.
Dialogue: 0,0:03:56.05,0:03:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar memusingkan.
Dialogue: 0,0:03:58.35,0:04:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Npilih saja toko yang kau suka.
Dialogue: 0,0:04:00.93,0:04:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:03.91,0:04:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menemukan toko yang kau sukai?
Dialogue: 0,0:04:06.18,0:04:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan nama itu…
Dialogue: 0,0:04:07.93,0:04:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat itu penerbit majalah kota\Nyang sering kau baca, 'kan?
Dialogue: 0,0:04:12.00,0:04:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, seratus tahun lalu\Nhanya sebuah rumah kecil.
Dialogue: 0,0:04:15.20,0:04:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya penerbit itu\Nsudah ada sejak lama, ya?
Dialogue: 0,0:04:18.24,0:04:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:19.07,0:04:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:04:20.32,0:04:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:20.89,0:04:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, kau mau apa?
Dialogue: 0,0:04:23.79,0:04:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau memberikan sedikit saran.
Dialogue: 0,0:04:26.06,0:04:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu sebentar!
Dialogue: 0,0:04:33.21,0:04:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar pria yang sial.
Dialogue: 0,0:04:35.77,0:04:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sering sekali diganggu roh jahat.
Dialogue: 0,0:04:39.13,0:04:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjualan majalah kota juga tidak membaik.
Dialogue: 0,0:04:42.99,0:04:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Towada.
Dialogue: 0,0:04:44.35,0:04:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direktur.
Dialogue: 0,0:04:45.40,0:04:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau pergi wawancara sekarang?
Dialogue: 0,0:04:46.85,0:04:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, mau meliput camilan Jepang baru lagi.
Dialogue: 0,0:04:49.89,0:04:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Edisi Spesial Isian Kacang Merah Kasar\Nbulan lalu sangat bagus.
Dialogue: 0,0:04:53.08,0:04:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa dilihat oleh Tuan Dewa Gunung,\Nmungkin dia akan datang lagi ke kota.
Dialogue: 0,0:04:58.50,0:05:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantan Direktur pasti juga akan senang.
Dialogue: 0,0:05:01.48,0:05:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya aku ada rapat,\Njadi kembali dulu.
Dialogue: 0,0:05:07.91,0:05:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah laporanku benar-benar\Nbisa dilihat oleh Tuan Dewa Gunung itu?
Dialogue: 0,0:05:17.42,0:05:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diganggu oleh sesuatu lagi?
Dialogue: 0,0:05:27.10,0:05:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat ini.
Dialogue: 0,0:05:42.62,0:05:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Tuan Dewa Gunung!
Dialogue: 0,0:05:44.25,0:05:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh sembarangan masuk!
Dialogue: 0,0:05:45.93,0:05:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Dewa Gunung?
Dialogue: 0,0:05:48.09,0:05:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Anda…
Dialogue: 0,0:05:50.04,0:05:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:50.83,0:05:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa melihat Tuan Dewa Gunung?
Dialogue: 0,0:05:52.52,0:05:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri yang menampakkan diri.
Dialogue: 0,0:05:54.77,0:06:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar ada,\Ntapi penampilannya sangat lucu.
Dialogue: 0,0:06:00.80,0:06:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini Dewa Gunung.
Dialogue: 0,0:06:02.74,0:06:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang menulis laporan\Ntentang camilan Jepang?
Dialogue: 0,0:06:05.35,0:06:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:06.53,0:06:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu menanti-nanti\Nlaporan camilan Jepang.
Dialogue: 0,0:06:13.32,0:06:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung melihat laporanku…
Dialogue: 0,0:06:18.51,0:06:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Tuan Dewa Gunung, bisakah Anda\Nbertemu dengan direktur kami?
Dialogue: 0,0:06:23.79,0:06:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menanti Anda selama ini.
Dialogue: 0,0:06:25.58,0:06:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya direktur, karyawan lain juga.
Dialogue: 0,0:06:28.36,0:06:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku akan memanggil semua orang.
Dialogue: 0,0:06:30.48,0:06:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tunggu di sini sebentar.
Dialogue: 0,0:06:34.92,0:06:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direktur, semuanya, cepat ke sini!
Dialogue: 0,0:06:37.16,0:06:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung telah datang!
Dialogue: 0,0:06:39.68,0:06:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direktur!
Dialogue: 0,0:06:42.61,0:06:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini, Towada?
Dialogue: 0,0:06:45.53,0:06:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung ada di sini sekarang.
Dialogue: 0,0:06:48.53,0:06:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Di mana?
Dialogue: 0,0:06:51.63,0:06:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di sini.
Dialogue: 0,0:06:55.13,0:06:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:06:56.36,0:06:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan penampilanmu seperti itu,\Nmereka tak mengenalimu sebagai Dewa Gunung.
Dialogue: 0,0:06:58.94,0:07:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama kami menanti.
Dialogue: 0,0:07:00.91,0:07:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering dengar cerita Tuan Dewa Gunung\Ndari pendiri, mantan direktur Musashi.
Dialogue: 0,0:07:07.67,0:07:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:08.54,0:07:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon dulu direktur Musashi yang pernah\Ndibantu Tuan Dewa Gunung,
Dialogue: 0,0:07:11.94,0:07:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sering membawa Tuan Dewa Gunung\Nke toko camilan.
Dialogue: 0,0:07:16.20,0:07:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:17.25,0:07:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:18.19,0:07:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku memang sering\Npergi ke toko camilan bersamanya.
Dialogue: 0,0:07:21.61,0:07:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya ada hubungan baik seperti itu, ya.
Dialogue: 0,0:07:23.80,0:07:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah sekarang Anda juga\Nmasih membaca majalah?
Dialogue: 0,0:07:27.28,0:07:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:30.53,0:07:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku datang ke sini\Nuntuk memberi saran.
Dialogue: 0,0:07:35.28,0:07:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saran?
Dialogue: 0,0:07:36.80,0:07:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:37.54,0:07:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Edisi spesial untuk terbitan berikutnya,
Dialogue: 0,0:07:40.64,0:07:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan buat isian kacang merah kasar,\Nbuat saja pasta kacang merah halus.
Dialogue: 0,0:07:46.54,0:07:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:07:48.80,0:07:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, edisi berikutnya diputuskan menjadi\NEdisi Spesial Pasta Kacang Merah Halus!
Dialogue: 0,0:07:52.02,0:07:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:07:55.35,0:07:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, ayo makan sesuatu yang enak.
Dialogue: 0,0:07:57.67,0:07:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, ayo kita pergi.
Dialogue: 0,0:07:59.36,0:08:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang segera selidiki\Npasta kacang merah halus di seluruh kota!
Dialogue: 0,0:08:02.05,0:08:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}-Baik, ayo!\N-Baik!
Dialogue: 0,0:08:03.34,0:08:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, cepat!
Dialogue: 0,0:08:06.62,0:08:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung.
Dialogue: 0,0:08:07.55,0:08:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak disangka selain pemilik Echigoya,\NAnda juga akrab dengan orang lain.
Dialogue: 0,0:08:10.91,0:08:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:11.70,0:08:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena saat itu, lebih banyak orang\Nyang bisa melihat makhluk bukan manusia.
Dialogue: 0,0:08:16.74,0:08:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu ya.
Dialogue: 0,0:08:18.11,0:08:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung sepertinya\Nsudah agak pulih.
Dialogue: 0,0:08:20.93,0:08:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika begini…
Dialogue: 0,0:08:23.80,0:08:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tercium aroma wangi dari toko itu.
Dialogue: 0,0:08:26.60,0:08:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu aroma kari.
Dialogue: 0,0:08:28.16,0:08:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kari? Mantap sekali!
Dialogue: 0,0:08:30.30,0:08:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, pasti enak.
Dialogue: 0,0:08:32.37,0:08:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi.
Dialogue: 0,0:08:33.42,0:08:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo pergi.
Dialogue: 0,0:08:39.14,0:08:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:08:40.86,0:08:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah memutuskan mau memesan apa,
Dialogue: 0,0:08:42.84,0:08:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan panggil aku.
Dialogue: 0,0:08:44.70,0:08:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:48.72,0:08:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada dua menu?
Dialogue: 0,0:08:51.41,0:08:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegawai toko seharusnya tidak bisa\Nmelihat Tuan Dewa Gunung, 'kan?
Dialogue: 0,0:08:54.37,0:08:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa melihat.
Dialogue: 0,0:08:55.45,0:08:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya tidak bisa melihat,\Ndia juga tidak punya indra keenam.
Dialogue: 0,0:08:59.42,0:09:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kenapa…
Dialogue: 0,0:09:06.27,0:09:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, nanti ketahuan.
Dialogue: 0,0:09:08.50,0:09:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abaikan saja tatapan orang sekitar.
Dialogue: 0,0:09:10.57,0:09:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lihat baik-baik.
Dialogue: 0,0:09:12.12,0:09:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:17.34,0:09:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:09:19.23,0:09:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kecil, itu juga dewa.
Dialogue: 0,0:09:22.16,0:09:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa?
Dialogue: 0,0:09:26.82,0:09:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum lagi?
Dialogue: 0,0:09:28.97,0:09:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu ya? Kalau begitu,\Nkupesankan satu lagi untukmu.
Dialogue: 0,0:09:32.09,0:09:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu…
Dialogue: 0,0:09:33.58,0:09:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah di samping pria itu juga ada dewa?
Dialogue: 0,0:09:37.48,0:09:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku sama sekali\Ntidak merasakan aura apa pun.
Dialogue: 0,0:09:39.81,0:09:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan yokai?
Dialogue: 0,0:09:41.52,0:09:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, dia dikelilingi\Nbanyak sekali yokai.
Dialogue: 0,0:09:45.15,0:09:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:09:46.87,0:09:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau yokai, aku seharusnya\Njuga bisa melihatnya.
Dialogue: 0,0:09:49.66,0:09:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau sudah lama\Nmeninggalkan kampung halaman,
Dialogue: 0,0:09:52.68,0:09:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi indra keenammu melemah.
Dialogue: 0,0:09:54.42,0:09:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:09:56.14,0:09:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya ada dewa dan yokai.
Dialogue: 0,0:09:58.17,0:09:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan toko ini?
Dialogue: 0,0:09:59.86,0:10:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga selalu bersama dewa, bukan?
Dialogue: 0,0:10:03.02,0:10:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang begitu.
Dialogue: 0,0:10:05.26,0:10:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kau tidak pesan kari?
Dialogue: 0,0:10:07.72,0:10:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ya.
Dialogue: 0,0:10:09.81,0:10:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:10:16.46,0:10:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:10:20.93,0:10:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedasnya pas, lumayan.
Dialogue: 0,0:10:24.42,0:10:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, Tuan Dewa Gunung puas.
Dialogue: 0,0:10:41.12,0:10:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, gunting jahit itu\Nsekarang bergerak sendiri, 'kan?
Dialogue: 0,0:10:45.35,0:10:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah menjadi Tsukumogami.
Dialogue: 0,0:10:47.48,0:10:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukumogami…
Dialogue: 0,0:10:49.10,0:10:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peralatan yang digunakan\Ndengan penuh perhatian,
Dialogue: 0,0:10:51.31,0:10:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah melewati waktu yang lama\Nakan memiliki jiwa,
Dialogue: 0,0:10:54.19,0:10:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berubah menjadi Tsukumogami.
Dialogue: 0,0:10:56.18,0:10:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di rumah yang kau tinggali sekarang\Njuga ada.
Dialogue: 0,0:10:57.77,0:10:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak menyadarinya?
Dialogue: 0,0:10:59.02,0:11:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, ada?
Dialogue: 0,0:11:01.35,0:11:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:11:02.09,0:11:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lonceng angin.
Dialogue: 0,0:11:04.51,0:11:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, lonceng angin itu\Ntidak pernah berbunyi sendiri.
Dialogue: 0,0:11:07.44,0:11:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena ia hanya ingin\Nmenjadi lonceng angin.
Dialogue: 0,0:11:10.84,0:11:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu aku mengizinkannya\Ntinggal di rumah itu.
Dialogue: 0,0:11:14.31,0:11:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:11:15.96,0:11:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun ini juga harus\Nsering-sering menggunakannya, ya.
Dialogue: 0,0:11:18.61,0:11:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang-kadang rawatlah ia, ia akan senang.
Dialogue: 0,0:11:21.18,0:11:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjaganya dengan baik.
Dialogue: 0,0:11:27.26,0:11:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kunjungannya.
Dialogue: 0,0:11:29.96,0:11:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan datang kembali.
Dialogue: 0,0:11:34.23,0:11:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:35.03,0:11:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:11:36.19,0:11:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bel pintu tidak berbunyi.
Dialogue: 0,0:11:37.82,0:11:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Tadi jelas-jelas berbunyi, 'kan?
Dialogue: 0,0:11:40.49,0:11:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bel pintu itu juga Tsukumogami.
Dialogue: 0,0:11:42.57,0:11:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:11:44.22,0:11:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika ada makhluk bukan manusia\Nyang datang,
Dialogue: 0,0:11:46.14,0:11:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ia akan berbunyi\Nuntuk memberi tahu pelayan.
Dialogue: 0,0:11:51.19,0:11:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu pegawai toko tadi\Nmemberi kita dua menu, ya.
Dialogue: 0,0:11:55.81,0:11:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:57.54,0:12:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ini restoran yang bisa\Ndimasuki oleh dewa dan yokai.
Dialogue: 0,0:12:06.91,0:12:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Gunung…
Dialogue: 0,0:12:09.76,0:12:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seri? Ada apa?
Dialogue: 0,0:12:17.60,0:12:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang tamu tak diundang.
Dialogue: 0,0:12:21.82,0:12:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau sekali!
Dialogue: 0,0:12:23.77,0:12:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku\Nmencium orang sebau ini.
Dialogue: 0,0:12:25.73,0:12:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjelasan macam apa ini?
Dialogue: 0,0:12:27.54,0:12:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski yang kau katakan benar,
Dialogue: 0,0:12:29.18,0:12:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian amati dulu situasinya.
Dialogue: 0,0:12:31.04,0:12:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:32.43,0:12:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat pengap.\NKelembapannya tinggi sekali.
Dialogue: 0,0:12:35.54,0:12:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sangat buruk.
Dialogue: 0,0:12:40.17,0:12:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ini rumah orang\Nyang membuat papan nama kayu.
Dialogue: 0,0:12:43.19,0:12:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini ada bau sawah.
Dialogue: 0,0:12:45.35,0:12:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar tidak tahan\Ndengan bau amis ini.
Dialogue: 0,0:12:47.89,0:12:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik sawah itu lenyap saja.
Dialogue: 0,0:12:50.24,0:12:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kau tidak bisa\Nmakan beras kesukaanmu.
Dialogue: 0,0:12:53.49,0:12:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak boleh.
Dialogue: 0,0:12:54.97,0:12:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi bernegosiasi.
Dialogue: 0,0:12:55.75,0:12:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta orangnya menjual papan kayu itu\Nkepada kita dengan harga murah.
Dialogue: 0,0:12:58.95,0:13:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati kedua orang itu benar-benar jahat.
Dialogue: 0,0:13:01.63,0:13:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan mereka sepertinya\Nadalah papan kayu Minato.
Dialogue: 0,0:13:06.91,0:13:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kusunoki!
Dialogue: 0,0:13:10.80,0:13:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada di rumah?
Dialogue: 0,0:13:12.55,0:13:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan sawah, kalian lebih busuk.
Dialogue: 0,0:13:16.96,0:13:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tadi itu, apakah itu\Nmeniru Dewa Gunung?
Dialogue: 0,0:13:20.16,0:13:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski jiwa orang berhati jahat\Nmemang berbau busuk,
Dialogue: 0,0:13:24.68,0:13:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi baunya sampai menusuk mata,\Nsangat kuat.
Dialogue: 0,0:13:27.93,0:13:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku\Nmelihat orang seperti ini.
Dialogue: 0,0:13:30.41,0:13:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada cara lain lagi.
Dialogue: 0,0:13:34.25,0:13:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mau mencungkil pintu secara paksa.
Dialogue: 0,0:13:36.40,0:13:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka ada manusia\Nyang tidak bisa diselamatkan seperti ini.
Dialogue: 0,0:13:39.20,0:13:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:13:40.50,0:13:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian hukum saja sesuka kalian!
Dialogue: 0,0:13:42.88,0:13:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali!
Dialogue: 0,0:13:43.90,0:13:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima perintah!
Dialogue: 0,0:13:45.20,0:13:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan membuat mereka menyesal.
Dialogue: 0,0:13:47.95,0:13:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusunoki's Garden of Gods
Dialogue: 0,0:13:57.35,0:13:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pintu ini tidak bisa dibuka?
Dialogue: 0,0:13:59.89,0:14:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, kau mau menunda sampai kapan?
Dialogue: 0,0:14:02.68,0:14:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini benar-benar tidak bergerak.
Dialogue: 0,0:14:04.97,0:14:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang coba.
Dialogue: 0,0:14:13.20,0:14:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan?\NJelas-jelas tidak dikunci.
Dialogue: 0,0:14:15.42,0:14:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kok bisa?
Dialogue: 0,0:14:18.18,0:14:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang daerah pedesaan,\Nsama sekali tidak waspada.
Dialogue: 0,0:14:22.12,0:14:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kusunoki!
Dialogue: 0,0:14:23.61,0:14:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tuan Kusunoki!
Dialogue: 0,0:14:28.05,0:14:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kusunoki!
Dialogue: 0,0:14:30.83,0:14:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar tidak ada di rumah.
Dialogue: 0,0:14:37.24,0:14:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:14:38.51,0:14:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya gerbang,\Nbahkan pintu masuk juga tidak dikunci?
Dialogue: 0,0:14:42.72,0:14:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat tidak waspada.
Dialogue: 0,0:14:44.70,0:14:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:46.73,0:14:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau jeruk?
Dialogue: 0,0:14:49.76,0:14:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya? Tapi aku sama sekali\Ntidak melihat jeruk.
Dialogue: 0,0:14:54.26,0:14:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:14:55.14,0:14:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia tidak ada di rumah,\Ncepat masuk dan geledah.
Dialogue: 0,0:15:10.61,0:15:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahnya besar sekali.
Dialogue: 0,0:15:28.21,0:15:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan rumah ini?
Dialogue: 0,0:15:29.78,0:15:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya koridor.
Dialogue: 0,0:15:32.25,0:15:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat jalan.
Dialogue: 0,0:15:34.06,0:15:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak menyadarinya?
Dialogue: 0,0:15:35.77,0:15:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun dipikir, ini sangat aneh.
Dialogue: 0,0:15:38.52,0:15:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin di rumah ini
Dialogue: 0,0:15:39.57,0:15:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada koridor sepanjang ini?
Dialogue: 0,0:15:42.09,0:15:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:15:43.89,0:15:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan bau ini…
Dialogue: 0,0:15:45.61,0:15:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma jeruk makin kuat.
Dialogue: 0,0:15:49.47,0:15:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya tercium sampai sini.
Dialogue: 0,0:15:51.64,0:15:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:52.45,0:15:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat ini, kita sangat terbantu.
Dialogue: 0,0:15:54.31,0:15:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, saat berbicara,\Nsingkirkan dulu benda itu dari depan hidung.
Dialogue: 0,0:15:58.61,0:16:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeruk musim panas benar-benar\Nbanyak membantu kita.
Dialogue: 0,0:16:01.21,0:16:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada ini, hidung kita\Nakan rusak karena bau mereka.
Dialogue: 0,0:16:06.73,0:16:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma jeruk menjadi makin pekat.
Dialogue: 0,0:16:12.83,0:16:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koridornya menghilang?
Dialogue: 0,0:16:14.43,0:16:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, kalau terus begini, kita…
Dialogue: 0,0:16:17.25,0:16:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Enno, cepat lari!
Dialogue: 0,0:16:21.08,0:16:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku!
Dialogue: 0,0:16:26.62,0:16:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan rumah itu?
Dialogue: 0,0:16:28.78,0:16:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, kita akan tertangkap!
Dialogue: 0,0:16:37.82,0:16:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu apa?
Dialogue: 0,0:16:40.16,0:16:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu? Cepat lari!
Dialogue: 0,0:16:44.86,0:16:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjalan lancar, Torika.
Dialogue: 0,0:16:46.85,0:16:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, karena aku sudah menanamkan sugesti.
Dialogue: 0,0:16:49.24,0:16:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat mereka takut saat\Nmencium bau jeruk musim panas.
Dialogue: 0,0:16:51.61,0:16:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka datang lagi,\Nhadapi mereka dengan serangan jeruk.
Dialogue: 0,0:16:54.79,0:16:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau menyarankan Minato\Nmenaruh penyegar jeruk di pintu masuk?
Dialogue: 0,0:17:01.69,0:17:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penpen.
Dialogue: 0,0:17:08.72,0:17:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh kari yang lezat.
Dialogue: 0,0:17:11.06,0:17:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali, lain kali kita datang lagi.
Dialogue: 0,0:17:13.32,0:17:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:17:15.06,0:17:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira Tuan Dewa Gunung senang,
Dialogue: 0,0:17:17.84,0:17:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia belum kembali seperti semula.
Dialogue: 0,0:17:20.13,0:17:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kita harus pulang.
Dialogue: 0,0:17:22.89,0:17:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Seri dan yang lain\Njuga menunggu kita.
Dialogue: 0,0:17:25.99,0:17:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sepertinya mengusir\Ntamu tak diundang saat kita tidak ada.
Dialogue: 0,0:17:30.63,0:17:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:31.45,0:17:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak disangka jeruk musim panasmu berguna.
Dialogue: 0,0:17:34.51,0:17:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeruk musim panas?
Dialogue: 0,0:17:48.83,0:17:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Anda nyaman di pundakku?
Dialogue: 0,0:17:50.92,0:17:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:51.65,0:17:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan nyaman.
Dialogue: 0,0:17:59.59,0:18:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek itu…
Dialogue: 0,0:18:16.82,0:18:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Oogami…
Dialogue: 0,0:18:20.15,0:18:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Oogami?
Dialogue: 0,0:18:24.69,0:18:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:18:27.24,0:18:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:18:28.97,0:18:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau datang untuk mempersembahkan sesuatu\Nkepada Jizo?
Dialogue: 0,0:18:31.97,0:18:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:18:34.15,0:18:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu.
Dialogue: 0,0:18:36.44,0:18:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat khawatir padamu.
Dialogue: 0,0:18:38.75,0:18:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau datang ke sini sendirian lagi, ya.
Dialogue: 0,0:18:41.74,0:18:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, ayo kita pulang.
Dialogue: 0,0:18:43.79,0:18:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, baik.
Dialogue: 0,0:18:45.11,0:18:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:18:47.92,0:18:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:18:49.57,0:18:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu Tuan Oogami?
Dialogue: 0,0:18:53.05,0:18:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Dewa Gunung yang dianut ibu mertuaku.
Dialogue: 0,0:18:56.58,0:19:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sering bilang padaku,\Ndi gunung itu tinggal Tuan Oogami.
Dialogue: 0,0:19:02.78,0:19:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya sekarang dia juga seperti ini,
Dialogue: 0,0:19:04.85,0:19:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}datang berdoa di hadapan Jizo\Nuntuk menyembah Tuan Oogami.
Dialogue: 0,0:19:08.66,0:19:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu ya.
Dialogue: 0,0:19:11.04,0:19:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami pamit.
Dialogue: 0,0:19:21.35,0:19:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung sangat dicintai, ya.
Dialogue: 0,0:19:24.79,0:19:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:25.57,0:19:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:29.51,0:19:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung,\NAnda sudah kembali seperti semula!
Dialogue: 0,0:19:32.22,0:19:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:33.02,0:19:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura keberadaannya juga sangat kuat.
Dialogue: 0,0:19:35.43,0:19:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku adalah Dewa Gunung.
Dialogue: 0,0:19:38.70,0:19:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung, tolong tahan sedikit!
Dialogue: 0,0:19:40.99,0:19:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Mataku!
Dialogue: 0,0:19:46.24,0:19:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kubilang?
Dialogue: 0,0:19:47.87,0:19:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan segera pulih.
Dialogue: 0,0:19:49.49,0:19:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Anda sudah kembali bersemangat.
Dialogue: 0,0:19:52.30,0:19:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Apa yang kau katakan?
Dialogue: 0,0:19:54.24,0:19:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:55.23,0:19:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah karena Anda terlalu sedih kalah\Ndari Nona Tenko, jadi tidak bisa pulih?
Dialogue: 0,0:19:59.57,0:20:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu. Bukankah aku sering bilang?
Dialogue: 0,0:20:02.82,0:20:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini hanya kehabisan\Nterlalu banyak tenaga.
Dialogue: 0,0:20:06.10,0:20:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kenapa pagi tadi\NAnda terlihat tidak bersemangat?
Dialogue: 0,0:20:09.09,0:20:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi?
Dialogue: 0,0:20:11.39,0:20:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku melihat\Nedisi spesial majalah pagi ini
Dialogue: 0,0:20:13.76,0:20:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Edisi Spesial\NIsian Kacang Merah Kasar,
Dialogue: 0,0:20:15.75,0:20:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi suasana hatiku tidak baik.
Dialogue: 0,0:20:19.00,0:20:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Edisi Spesial Isian Kacang Merah Kasar?
Dialogue: 0,0:20:20.87,0:20:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu ya?
Dialogue: 0,0:20:22.91,0:20:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, ayo pulang.
Dialogue: 0,0:20:38.07,0:20:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:39.70,0:20:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:20:40.63,0:20:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya merasa lega Anda bisa\Nkembali bersemangat.
Dialogue: 0,0:20:46.00,0:20:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dewa Gunung\Nbisa kembali seperti semula,
Dialogue: 0,0:20:49.60,0:20:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin karena orang-orang di kota ini\Npercaya akan keberadaan Tuan Dewa Gunung.
Dialogue: 0,0:21:05.61,0:21:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penpen…
Dialogue: 0,0:21:10.56,0:21:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:12.38,0:21:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ansho dan anggotanya\Npergi ke rumah Kusunoki Minato?
Dialogue: 0,0:21:15.28,0:21:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penpen…
Dialogue: 0,0:21:17.16,0:21:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, akhirnya bagaimana?
Dialogue: 0,0:21:19.16,0:21:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:21:20.44,0:21:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pengusir roh itu sepertinya\Ndihajar habis-habisan.
Dialogue: 0,0:21:23.56,0:21:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu ya.
Dialogue: 0,0:21:31.08,0:21:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya ada apa dengan rumah itu?
Dialogue: 0,0:21:33.84,0:21:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, ayo kita pulang.
Dialogue: 0,0:21:37.17,0:21:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak datang ke kota ini,\Ntak pernah mengalami hal baik.
Dialogue: 0,0:21:40.54,0:21:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak akan menyerah,
Dialogue: 0,0:21:43.45,0:21:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai aku meraup\Ncukup keuntungan di kota ini.
Dialogue: 0,0:21:52.79,0:21:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:23:31.54,0:23:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode 10.
Dialogue: 0,0:23:33.43,0:23:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan Paksa Bersama Dewa Murka.
