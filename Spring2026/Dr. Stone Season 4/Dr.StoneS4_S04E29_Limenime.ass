Dialogue: 0,0:00:33.86,0:00:34.33,tanda,,0000,0000,0000,,AHLI BEDAH - AHLI JAM - KLUB KERAJINAN
Dialogue: 0,0:01:00.03,0:01:03.54,tanda,,0000,0000,0000,,OLIMPIADE MATEMATIKA DISELENGGARAKAN
Dialogue: 0,0:01:39.47,0:01:43.79,tanda,,0000,0000,0000,,DR. STONE SEASON 4
Dialogue: 0,0:02:57.03,0:03:02.03,tanda,,0000,0000,0000,,KEBENARAN TENTANG ROKET
Dialogue: 0,0:07:36.66,0:07:36.90,tanda,,0000,0000,0000,,OLIMPIADE MATEMATIKA DUNIA BARU
Dialogue: 0,0:08:10.51,0:08:12.78,tanda,,0000,0000,0000,,OLIMPIADE MATEMATIKA DUNIA BARU
Dialogue: 0,0:08:39.71,0:08:53.59,tanda,,0000,0000,0000,,827.401.136.058
Dialogue: 0,0:09:42.66,0:09:45.56,tanda,,0000,0000,0000,,MENDAPATKAN KALKULATOR!
Dialogue: 0,0:10:32.34,0:10:35.03,tanda,,0000,0000,0000,,MENDAPATKAN BANK!
Dialogue: 0,0:10:35.03,0:10:40.03,tanda,,0000,0000,0000,,DR. STONE SEASON 4
Dialogue: 0,0:23:52.05,0:23:55.03,tanda,,0000,0000,0000,,SELANJUTNYA: BATU KE LUAR ANGKASA
Dialogue: 0,0:23:55.03,0:23:56.19,tanda,,0000,0000,0000,,KARYA INI MURNI BERSIFAT FIKSI.
Dialogue: 0,0:23:56.19,0:23:57.26,tanda,,0000,0000,0000,,HEWAN, TUMBUHAN, BENDA,\NDAN METODE PEMBUATAN YANG MUNCUL ITU NYATA.
Dialogue: 0,0:23:57.26,0:23:58.39,tanda,,0000,0000,0000,,JANGAN MENGAMBIL ATAU MEMBUAT\NATAS PENILAIAN PRIBADI, BISA BERBAHAYA.
Dialogue: 0,0:23:58.39,0:24:02.28,tanda,,0000,0000,0000,,SELAIN ITU, BISA MELANGGAR HUKUM,\NJADI JANGAN DITIRU.
Dialogue: 0,0:00:01.75,0:00:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat semua itu.
Dialogue: 0,0:00:03.21,0:00:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini persiapan untuk menyerahkan\Npekerjaan manual ke Kota Jagung, 'kan?
Dialogue: 0,0:00:06.65,0:00:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti gambar rangkaian begitu.
Dialogue: 0,0:00:08.31,0:00:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku dan Sai terlihat bersemangat sekali.
Dialogue: 0,0:00:10.29,0:00:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan mereka buat?
Dialogue: 0,0:00:13.01,0:00:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu!
Dialogue: 0,0:00:14.15,0:00:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita membuat ponsel, 'kan?
Dialogue: 0,0:00:16.50,0:00:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sekali tidak mendengarnya.
Dialogue: 0,0:00:18.25,0:00:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau suka sekali dengan ponsel, ya.
Dialogue: 0,0:00:21.95,0:00:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, langsung ke sana itu mustahil.
Dialogue: 0,0:00:24.35,0:00:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai dari melilit kabel\Nuntuk membuat komputer.
Dialogue: 0,0:00:28.18,0:00:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlahan, selangkah demi selangkah.
Dialogue: 0,0:00:34.38,0:00:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bertiga benar-benar\Nmelakukannya dengan serius.
Dialogue: 0,0:00:39.51,0:00:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kita harus melakukan\Npekerjaan yang merepotkan ini?
Dialogue: 0,0:00:44.51,0:00:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendarat di Bulan dari Bumi itu\Nseperti mencetak hole-in-one dalam golf.
Dialogue: 0,0:00:50.65,0:00:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk perhitungan orbit, kita benar-benar\Nbutuh komputer di Dunia Batu ini.
Dialogue: 0,0:00:55.53,0:00:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali tidak mungkin.
Dialogue: 0,0:01:04.15,0:01:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Olimpiade Matematika Boleh Memakai Alat."
Dialogue: 0,0:01:07.92,0:01:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, tuh...
Dialogue: 0,0:01:09.18,0:01:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ini pasti ulah Gen agar kita\Ntermotivasi membuat kalkulator.
Dialogue: 0,0:01:13.95,0:01:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kita bukan anak kecil.
Dialogue: 0,0:01:16.85,0:01:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu turnamen segala\Nuntuk membuat kami semangat.
Dialogue: 0,0:01:19.97,0:01:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, tim pemenang dapat hadiah\Nsebesar 100 juta Dragos.
Dialogue: 0,0:03:14.95,0:03:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, dengan memakai taktik\Ntenaga manusia secara penuh...
Dialogue: 0,0:03:18.72,0:03:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya membuat memori!
Dialogue: 0,0:03:22.78,0:03:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memori?
Dialogue: 0,0:03:23.91,0:03:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memori, alias alat penyimpanan.
Dialogue: 0,0:03:27.41,0:03:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa itu, mesin bahkan\Ntidak bisa mengingat angka.
Dialogue: 0,0:03:30.65,0:03:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mustahil melakukan\Nperhitungan yang rumit.
Dialogue: 0,0:03:34.38,0:03:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sirkuit berpikir dan sirkuit mengingat.
Dialogue: 0,0:03:37.05,0:03:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dua sirkuit itu digabungkan,
Dialogue: 0,0:03:39.21,0:03:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa menciptakan komputer\Ndengan daya hitung luar biasa.
Dialogue: 0,0:03:45.38,0:03:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin itu...
Dialogue: 0,0:03:46.78,0:03:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengingat angka?
Dialogue: 0,0:03:48.51,0:03:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?
Dialogue: 0,0:03:49.85,0:03:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu aku juga tidak tahu.
Dialogue: 0,0:03:52.41,0:03:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, tanpa semikonduktor,\Nbagaimana caranya?
Dialogue: 0,0:03:56.65,0:03:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyimpan data memakai magnet.
Dialogue: 0,0:04:00.55,0:04:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatian!
Dialogue: 0,0:04:02.01,0:04:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku mengirimkan cara membuat\Nmemori melalui faks.
Dialogue: 0,0:04:05.98,0:04:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panjang banget!
Dialogue: 0,0:04:15.65,0:04:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita alirkan arus listrik kuat\Nke oksida besi yang dibakar Brody...
Dialogue: 0,0:04:21.91,0:04:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda itu akan menjadi magnet.
Dialogue: 0,0:04:23.98,0:04:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau arusnya dibalik...
Dialogue: 0,0:04:27.61,0:04:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung nilainya 1 atau 0,
Dialogue: 0,0:04:29.95,0:04:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa menukar kutub selatan dan utara.
Dialogue: 0,0:04:32.38,0:04:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, satu butir magnet\Nbisa menyimpan nilai 1 atau 0.
Dialogue: 0,0:04:38.71,0:04:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konyol sekali.
Dialogue: 0,0:04:40.11,0:04:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekadar 1 atau 0,\Nsiapa pun bisa mengingatnya.
Dialogue: 0,0:04:43.77,0:04:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa repot-repot\Nmembuat hal seperti itu?
Dialogue: 0,0:04:46.81,0:04:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma satu, iya.
Dialogue: 0,0:04:48.61,0:04:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika kekuatannya digabung,\Nbisa jadi sesuatu yang luar biasa.
Dialogue: 0,0:04:51.95,0:04:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah melihat buktinya\Ndi Kerajaan Sains, 'kan?
Dialogue: 0,0:04:58.61,0:05:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, kalau kita mau\Nmenyimpan data di magnet ini...
Dialogue: 0,0:05:01.91,0:05:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita alirkan listrik ke kabel\Nkolom ketiga dan baris kedua.
Dialogue: 0,0:05:07.41,0:05:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.
Dialogue: 0,0:05:09.95,0:05:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di titik persilangan,\Nlistriknya jadi sangat kuat.
Dialogue: 0,0:05:13.33,0:05:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, hanya butir magnet itu yang merekam\Ngaya magnet selatan atau utara.
Dialogue: 0,0:05:19.58,0:05:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawaban sempurna, nilai 10 miliar poin!
Dialogue: 0,0:05:22.71,0:05:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sangat primitif, tetapi kuat.
Dialogue: 0,0:05:26.41,0:05:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan pesawat ulang alik\Ndan jet tempur F-15 memakainya.
Dialogue: 0,0:05:30.35,0:05:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aslinya, para penjahit ahli menjahitnya\Nsemalaman penuh dengan tangan.
Dialogue: 0,0:05:37.51,0:05:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, misi kita adalah menjahit\Nsejumlah besar magnet ini bersama-sama?
Dialogue: 0,0:05:44.01,0:05:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya "jumlah besar" itu\Nseberapa banyak?
Dialogue: 0,0:05:47.55,0:05:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tadi dibilang sekitar 200 ribu?
Dialogue: 0,0:05:50.31,0:05:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau sebanyak itu, aku masih sanggup.
Dialogue: 0,0:05:54.16,0:05:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, 200 ribu itu untuk\Npekerjaan melilit kumparan donat.
Dialogue: 0,0:05:57.98,0:06:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, syukurlah.
Dialogue: 0,0:06:00.91,0:06:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau yang untuk menjahit magnet ini...
Dialogue: 0,0:06:04.85,0:06:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}30 juta.
Dialogue: 0,0:06:07.43,0:06:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:06:20.18,0:06:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:06:20.94,0:06:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu berarti sudah selesai?
Dialogue: 0,0:06:23.25,0:06:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum. Garis vertikal dan horizontal\Nitu untuk menyimpan data.
Dialogue: 0,0:06:27.11,0:06:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kita juga harus memasang kabel\Ndiagonal untuk proses memuat data.
Dialogue: 0,0:06:36.25,0:06:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, layar untuk menampilkan angka.\NDengan kata lain, display.
Dialogue: 0,0:06:40.05,0:06:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menggunakan tabung Nixie.
Dialogue: 0,0:06:42.35,0:06:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk angka akan dibuat dari kawat,
Dialogue: 0,0:06:44.95,0:06:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu dialiri listrik dalam gas\Nsampai menyala.
Dialogue: 0,0:06:48.58,0:06:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pekerjaan presisi\Nseperti ini kepadaku.
Dialogue: 0,0:06:51.71,0:06:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan membuat jam,\Nini semudah membalik telapak tangan.
Dialogue: 0,0:07:10.81,0:07:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di India, bahan bakarnya melimpah.
Dialogue: 0,0:07:15.58,0:07:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, kita bisa berlayar.
Dialogue: 0,0:07:27.91,0:07:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah kita menyeberangi Samudra Hindia.
Dialogue: 0,0:07:30.81,0:07:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya Olimpiade Matematika Dunia Baru!
Dialogue: 0,0:07:33.85,0:07:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tiba-tiba memulai sesuatu lagi.
Dialogue: 0,0:07:36.95,0:07:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peserta lombanya adalah\NChrome, Senku, dan Sai!
Dialogue: 0,0:07:40.96,0:07:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pesertanya begini, hasilnya jelas,\Npasti antara Senku atau Sai.
Dialogue: 0,0:07:45.61,0:07:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan juga...
Dialogue: 0,0:07:47.38,0:07:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peserta online dari Kota Jagung\Nadalah Magma!
Dialogue: 0,0:07:51.91,0:07:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:07:55.75,0:07:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Magma?
Dialogue: 0,0:07:57.35,0:07:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang paling tidak cocok\Nuntuk hitung-hitungan.
Dialogue: 0,0:08:00.21,0:08:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena dia yang paling tidak cocok,
Dialogue: 0,0:08:02.45,0:08:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itulah alasannya.
Dialogue: 0,0:08:05.58,0:08:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pertandingannya adalah ini!
Dialogue: 0,0:08:08.61,0:08:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menyelesaikannya!
Dialogue: 0,0:08:55.06,0:08:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:56.41,0:08:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.
Dialogue: 0,0:08:59.78,0:09:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam sekejap, itu melampaui otak\Nluar biasa milik Senku dan yang lainnya.
Dialogue: 0,0:09:05.11,0:09:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini wujud komputer.
Dialogue: 0,0:09:12.05,0:09:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini akan menjadi titik bersejarah\Nbagi sains di Dunia Baru.
Dialogue: 0,0:09:17.91,0:09:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa, bahkan di Dunia Batu\Nseperti ini...
Dialogue: 0,0:09:21.91,0:09:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:23.31,0:09:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang diciptakan manusia dari nol,
Dialogue: 0,0:09:26.31,0:09:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang bisa melampaui otak manusia.
Dialogue: 0,0:09:39.05,0:09:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar menyulut semangatku.
Dialogue: 0,0:09:45.56,0:09:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam ini ada 30 juta magnet?
Dialogue: 0,0:09:48.61,0:09:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin.
Dialogue: 0,0:09:50.24,0:09:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang baru beberapa ribu.
Dialogue: 0,0:09:52.01,0:09:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, versi jadinya\Npasti akan lebih hebat lagi!
Dialogue: 0,0:09:55.18,0:09:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setara dengan ponsel!
Dialogue: 0,0:09:57.35,0:09:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih punya pekerjaan berat\Nke depannya.
Dialogue: 0,0:10:00.51,0:10:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini disebut hadiah lomba, sih...
Dialogue: 0,0:10:02.85,0:10:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya, ini adalah gaji\Nuntuk semua orang.
Dialogue: 0,0:10:07.05,0:10:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, hadiah 100 juta Dragos\Nuntuk tim pemenang!
Dialogue: 0,0:10:10.51,0:10:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Ryusui tidak ada di sini.
Dialogue: 0,0:10:12.58,0:10:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir,\Nkami akan mentransfernya.
Dialogue: 0,0:10:16.31,0:10:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bank Ryusui resmi dibuka!
Dialogue: 0,0:10:18.51,0:10:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya\Nmembuat tempat seperti itu?
Dialogue: 0,0:10:21.01,0:10:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mengatakannya dengan mudah,\Ntetapi membuat bank itu mustahil.
Dialogue: 0,0:10:25.06,0:10:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita butuh cara untuk\Nmerekam dan menghitung saldo.
Dialogue: 0,0:10:44.61,0:10:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:45.54,0:10:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembuatan mesin kita serahkan\Nkepada Xeno dan timnya.
Dialogue: 0,0:10:47.92,0:10:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, pembuatan komputer diserahkan\Nkepada Yuzuriha dan yang lainnya.
Dialogue: 0,0:10:51.81,0:10:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akhirnya
Dialogue: 0,0:10:53.78,0:10:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memulai rencana perjalanan ke Bulan.
Dialogue: 0,0:10:55.65,0:10:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan membuat badan utama roket.
Dialogue: 0,0:11:01.95,0:11:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu bagian utama roket\Ntempat manusia akan naik.
Dialogue: 0,0:11:06.21,0:11:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbuat dari apa?
Dialogue: 0,0:11:07.81,0:11:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, besi?
Dialogue: 0,0:11:09.85,0:11:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mau terbang sampai ke luar angkasa,\Nterlalu berat kalau memakai besi.
Dialogue: 0,0:11:13.01,0:11:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Material utamanya adalah\Naluminium yang super ringan.
Dialogue: 0,0:11:18.51,0:11:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan tinggalkan India dan pergi\Nmencari bahan untuk membuat roket.
Dialogue: 0,0:11:22.49,0:11:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kita adalah
Dialogue: 0,0:11:25.01,0:11:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Australia.
Dialogue: 0,0:11:27.61,0:11:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Australia, tepatnya di area ujung ini,
Dialogue: 0,0:11:31.13,0:11:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terdapat sumber bauksit terbesar di dunia,\Nbahan baku untuk aluminium.
Dialogue: 0,0:11:53.35,0:11:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kalau soal mencari batu,\Naku tidak akan kalah.
Dialogue: 0,0:11:56.59,0:12:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ahli geografi Chelsea,\Nmelawan aku si ahli eksplorasi!
Dialogue: 0,0:12:00.71,0:12:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sama sekali bukan pertandingan.
Dialogue: 0,0:12:04.35,0:12:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, tumben sekali.
Dialogue: 0,0:12:06.11,0:12:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menantangku, ya, Chelsea?
Dialogue: 0,0:12:07.91,0:12:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:12:10.35,0:12:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak perlu mencarinya, kok.
Dialogue: 0,0:12:16.58,0:12:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh tanah di sini itu bauksit,\Nbahan baku untuk aluminium.
Dialogue: 0,0:12:19.98,0:12:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya gila banget, lucu malah.
Dialogue: 0,0:12:21.98,0:12:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seriusan?
Dialogue: 0,0:12:23.41,0:12:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila banget!
Dialogue: 0,0:12:24.95,0:12:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja tempat ini menjadi\Npenghasil nomor satu di dunia.
Dialogue: 0,0:12:28.71,0:12:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa menakjubkan!
Dialogue: 0,0:12:30.98,0:12:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar Kota Aluminium!
Dialogue: 0,0:12:33.64,0:12:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:34.98,0:12:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu merah biasa yang kita gali di sini
Dialogue: 0,0:12:38.31,0:12:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan berubah menjadi badan roket.
Dialogue: 0,0:12:51.71,0:12:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, aku ingin langsung punya\Nbucket-wheel excavator sekarang juga.
Dialogue: 0,0:12:56.95,0:13:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Apa itu bucket Excalibur?
Dialogue: 0,0:13:01.91,0:13:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mesin tambang terbuka raksasa.
Dialogue: 0,0:13:04.39,0:13:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat berat terbesar dalam sejarah manusia.
Dialogue: 0,0:13:08.71,0:13:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau Ryusui, tidak aneh dia\Npunya satu untuk berbelanja di dekat rumah.
Dialogue: 0,0:13:14.85,0:13:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah mengoperasikan\Nmilik Konglomerat Nanami.
Dialogue: 0,0:13:18.35,0:13:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya luar biasa!
Dialogue: 0,0:13:20.51,0:13:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar punya!
Dialogue: 0,0:13:22.85,0:13:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mungkin nanti.
Dialogue: 0,0:13:25.15,0:13:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, kita memakai metode\Ntenaga manusia untuk menambang.
Dialogue: 0,0:13:28.71,0:13:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau menggali sebanyak itu\Ndengan kekuatan setara Excalibur tadi,
Dialogue: 0,0:13:33.75,0:13:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berapa banyak orang\Nyang harus kita bangkitkan?
Dialogue: 0,0:13:36.18,0:13:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa pun juga,\Nkita akan kehabisan makanan.
Dialogue: 0,0:13:39.75,0:13:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cairan kebangkitan juga\Nsudah hampir habis, 'kan?
Dialogue: 0,0:13:42.96,0:13:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk hal itu, tidak perlu khawatir.
Dialogue: 0,0:13:48.65,0:13:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, kenapa kita membangun\NKota Jagung dari awal?
Dialogue: 0,0:13:52.51,0:13:56.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu demi menyiapkan makanan\Ndan bahan dasar cairan kebangkitan.
Dialogue: 0,0:14:04.03,0:14:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wei!
Dialogue: 0,0:14:05.78,0:14:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengiriman jagung telah datang\Ndari Kota Jagung Amerika!
Dialogue: 0,0:14:10.18,0:14:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:14:16.16,0:14:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, makanan dari jagung!
Dialogue: 0,0:14:26.05,0:14:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukyo sih memang\Noperator radar kapal, tapi...
Dialogue: 0,0:14:29.01,0:14:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Yo ikut juga?
Dialogue: 0,0:14:37.75,0:14:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suika, kau jadi lebih besar, ya.
Dialogue: 0,0:14:40.58,0:14:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut juga.
Dialogue: 0,0:14:42.98,0:14:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya jelas, karena
Dialogue: 0,0:14:45.58,0:14:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah dibayar\Ndan melilit donat itu merepotkan!
Dialogue: 0,0:14:49.71,0:14:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bukan! Aku di sini sebagai pengawal.
Dialogue: 0,0:14:52.25,0:14:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku ini mantan polisi.
Dialogue: 0,0:14:54.65,0:14:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,
Dialogue: 0,0:14:56.11,0:14:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Ukyo membawa sesuatu\Nyang kelihatannya sangat penting.
Dialogue: 0,0:14:59.65,0:15:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang penting?
Dialogue: 0,0:15:16.25,0:15:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah
Dialogue: 0,0:15:17.65,0:15:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}alat petrifikasi Medusa dalam\Nkondisi sempurna dengan baterai baru.
Dialogue: 0,0:15:25.25,0:15:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu meter, tiga detik.
Dialogue: 0,0:15:32.15,0:15:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu dia.
Dialogue: 0,0:15:34.51,0:15:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya mengerikan
Dialogue: 0,0:15:37.04,0:15:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dulu terpatri di mataku.
Dialogue: 0,0:15:41.31,0:15:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:15:43.91,0:15:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berusaha keras,\Ntetapi tetap gagal.
Dialogue: 0,0:15:47.41,0:15:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, baterai berlian buatan Joel\Nmemang hebat.
Dialogue: 0,0:15:50.75,0:15:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:15:52.38,0:15:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang barusan menyala adalah Medusa dari\NPulau Harta dengan baterai buatan Kaseki.
Dialogue: 0,0:15:57.91,0:15:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:15:59.61,0:16:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua baterai yang kubuat gagal total.
Dialogue: 0,0:16:03.48,0:16:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, yang ini justru Medusa lama yang\Nbanyak kita kumpulkan dari pusat ledakan.
Dialogue: 0,0:16:08.86,0:16:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ini dipasangi baterai buatan Joel.
Dialogue: 0,0:16:12.31,0:16:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu meter, satu detik.
Dialogue: 0,0:16:19.31,0:16:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dengan baterai Joel pun\Nalat ini tidak bekerja.
Dialogue: 0,0:16:23.18,0:16:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, Medusa tua dari ribuan tahun\Nlalu itu sudah lama rusak karena degradasi.
Dialogue: 0,0:16:29.81,0:16:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya yang dari Pulau Harta ini yang masih\Nbaru karena terus dipakai sampai sekarang.
Dialogue: 0,0:16:34.72,0:16:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, baterai kesayanganku bukan\Ngagal karena jelek, melainkan karena...
Dialogue: 0,0:16:42.61,0:16:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Unit Medusanya sendiri yang sudah rusak.
Dialogue: 0,0:16:46.55,0:16:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjelasannya terlalu rumit.
Dialogue: 0,0:16:49.18,0:16:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, intinya bagaimana?
Dialogue: 0,0:16:51.42,0:16:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, intinya begini.
Dialogue: 0,0:16:53.98,0:16:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita memakai Medusa\Nyang masih berfungsi ini,
Dialogue: 0,0:16:56.01,0:16:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu dipasangi baterai buatan Kaseki,
Dialogue: 0,0:16:58.71,0:17:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa memetrifikasi diri sesuka hati.
Dialogue: 0,0:17:02.75,0:17:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:03.78,0:17:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita punya Medusa\Nyang bisa dipakai.
Dialogue: 0,0:17:06.98,0:17:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa melancarkan\Nserangan bunuh diri ke Bulan.
Dialogue: 0,0:17:09.95,0:17:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah komponen paling penting\Ndari roket perjalanan Bulan kita.
Dialogue: 0,0:17:17.15,0:17:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak tahu kapan Why-Man akan
Dialogue: 0,0:17:21.31,0:17:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melancarkan serangan\Npetrifikasi massal lagi.
Dialogue: 0,0:17:24.38,0:17:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus pergi ke Bulan secepatnya\Ndan menghadapi dia secara langsung.
Dialogue: 0,0:17:28.98,0:17:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam perjalanan ke Bulan ini,
Dialogue: 0,0:17:31.35,0:17:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada waktu untuk bersantai\Nmerancang perjalanan pulang.
Dialogue: 0,0:17:37.81,0:17:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa pun hasil misinya\Nmelawan Why-Man,
Dialogue: 0,0:17:41.15,0:17:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anggota yang pergi ke Bulan
Dialogue: 0,0:17:46.15,0:17:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan kembali ke Bumi.
Dialogue: 0,0:17:49.81,0:17:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah aku salah?
Dialogue: 0,0:18:01.25,0:18:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke depannya,\Numat manusia akan terus berkembang
Dialogue: 0,0:18:05.05,0:18:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai bisa bolak-balik ke Bulan\Ndengan bebas.
Dialogue: 0,0:18:08.18,0:18:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sampai hari itu tiba,
Dialogue: 0,0:18:10.71,0:18:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiga orang yang mendarat di Bulan...
Dialogue: 0,0:18:12.75,0:18:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmuwan, Petarung, dan Pilot
Dialogue: 0,0:18:17.91,0:18:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan memakai kekuatan Medusa\Nuntuk memetrifikasi diri mereka sendiri.
Dialogue: 0,0:18:23.05,0:18:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan terus menunggu penyelamatan\Ndi permukaan Bulan selamanya.
Dialogue: 0,0:18:28.51,0:18:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahun-tahun, puluhan tahun,\Nratusan tahun.
Dialogue: 0,0:18:34.65,0:18:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roket perjalanan Bulan yang kita buat\Ndengan alat petrifikasi ini adalah
Dialogue: 0,0:18:39.58,0:18:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiket sekali jalan.
Dialogue: 0,0:18:51.55,0:18:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:18:52.69,0:18:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai roket selesai,\NMedusa akan disegel rapat.
Dialogue: 0,0:18:56.35,0:18:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecuali kalau ada yang terluka parah.
Dialogue: 0,0:18:59.71,0:19:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau memakainya\Nuntuk hal sepele seperti luka ringan
Dialogue: 0,0:19:02.85,0:19:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuat semua orang tahu\Ntentang fungsi penyembuhannya.
Dialogue: 0,0:19:06.31,0:19:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama bagi mayoritas orang abad ke-21\Nyang akan kita bangkitkan nanti.
Dialogue: 0,0:19:14.21,0:19:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau sampai ingin\Nmenyembunyikannya sejauh itu...
Dialogue: 0,0:19:18.38,0:19:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Insting pelautku mengatakan bahwa
Dialogue: 0,0:19:21.01,0:19:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medusa bisa menghidupkan orang mati.
Dialogue: 0,0:19:23.50,0:19:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumber kehidupan abadi.\NApakah aku salah?
Dialogue: 0,0:19:28.61,0:19:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beri nilai 10 miliar poin!
Dialogue: 0,0:19:32.21,0:19:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, begitu Why-Man di Bulan meluncurkan\Nserangan petrifikasi massal,
Dialogue: 0,0:19:39.31,0:19:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehidupan abadi pun tidak ada artinya.
Dialogue: 0,0:19:43.35,0:19:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi bisa menyerang secepat mungkin,
Dialogue: 0,0:19:46.28,0:19:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}satu alat petrifikasi ini adalah
Dialogue: 0,0:19:49.45,0:19:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiket sekali jalan ke Bulan.
Dialogue: 0,0:19:55.71,0:19:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roket sekali jalan.
Dialogue: 0,0:19:59.01,0:20:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tiga kru itu?
Dialogue: 0,0:20:01.38,0:20:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilotnya pasti Ryusui.
Dialogue: 0,0:20:04.31,0:20:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bertarung siapa?
Dialogue: 0,0:20:05.75,0:20:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukasa atau Hyoga?
Dialogue: 0,0:20:08.55,0:20:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmuwannya?
Dialogue: 0,0:20:10.61,0:20:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mungkin takkan pernah bertemu lagi\Ndengan kru yang pergi ke Bulan.
Dialogue: 0,0:20:16.85,0:20:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desain roket dibuat oleh Senku dan Xeno.
Dialogue: 0,0:20:21.51,0:20:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xeno juga tipe yang mengejar efisiensi.
Dialogue: 0,0:20:23.91,0:20:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pemikirannya pasti sama dengan Senku.
Dialogue: 0,0:20:25.78,0:20:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memilih perjalanan sekali jalan.
Dialogue: 0,0:20:28.38,0:20:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu jalan yang terbaik.
Dialogue: 0,0:20:30.75,0:20:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau para ahli bilang begitu,\Nitu pasti benar.
Dialogue: 0,0:20:33.85,0:20:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang amatir sepertiku\Ntidak punya hak untuk protes.
Dialogue: 0,0:20:41.91,0:20:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang amatir sepertiku...
Dialogue: 0,0:20:50.25,0:20:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan menerima itu!
Dialogue: 0,0:20:53.65,0:20:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali jalan? Bukankah di akhir\Nkita semua seharusnya berkumpul
Dialogue: 0,0:20:57.41,0:20:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bilang, "Kita berhasil!",
Dialogue: 0,0:20:58.81,0:21:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu bersulang bersama?
Dialogue: 0,0:21:01.81,0:21:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru kemenangan sejati!
Dialogue: 0,0:21:06.45,0:21:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tinggal buat saja, 'kan?
Dialogue: 0,0:21:08.55,0:21:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roket yang bisa membawa kita kembali\Nke Bumi dengan kecepatan gila.
Dialogue: 0,0:21:12.91,0:21:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suika!
Dialogue: 0,0:21:14.62,0:21:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin cuma bisa omong besar.
Dialogue: 0,0:21:17.25,0:21:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyedihkan sekali.
Dialogue: 0,0:21:18.58,0:21:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak tahu\Ncara mengeja kata "roket".
Dialogue: 0,0:21:22.44,0:21:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa apa-apa.
Dialogue: 0,0:21:25.05,0:21:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kau sendiri berhasil membuat\Ncairan kebangkitan, 'kan?
Dialogue: 0,0:21:28.85,0:21:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ini dua pengguna sains pemula\Ndari Desa Ishigami.
Dialogue: 0,0:21:32.85,0:21:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita berdua buat roket untuk pulang!
Dialogue: 0,0:21:39.41,0:21:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:21:40.61,0:21:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita harus merahasiakannya\Ndari Senku dan yang lainnya, ya.
Dialogue: 0,0:21:43.75,0:21:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:21:48.85,0:21:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:50.15,0:21:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita bisa membuatnya.
Dialogue: 0,0:21:52.71,0:21:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan membuatnya!
Dialogue: 0,0:21:55.85,0:21:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melawan Why-Man.
Dialogue: 0,0:21:58.11,0:22:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roket tercepat satu arah ke Bulan.
Dialogue: 0,0:22:02.58,0:22:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melawan Why-Man.
Dialogue: 0,0:22:04.75,0:22:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roket pulang-pergi agar kita semua\Nbisa menang bersama!
