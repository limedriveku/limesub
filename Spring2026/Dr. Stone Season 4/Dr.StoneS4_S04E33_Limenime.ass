Dialogue: 0,0:00:43.12,0:00:44.62,sign,,0000,0000,0000,,{\an8}TEH EUCOMMIA
Dialogue: 0,0:01:11.48,0:01:15.57,sign,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:02:44.03,0:02:45.37,sign,,0000,0000,0000,,{\an8}INNOSHIMA, PREFEKTUR HIROSHIMA
Dialogue: 0,0:02:57.05,0:02:58.67,sign,,0000,0000,0000,,{\an8}TEH EUCOMMIA DIPEROLEH!
Dialogue: 0,0:03:59.36,0:04:00.28,sign,,0000,0000,0000,,{\an8}KABEL TEMBAGA
Dialogue: 0,0:04:00.28,0:04:01.24,sign,,0000,0000,0000,,{\an8}ALOI KROMIUM & BAJA & NIKEL
Dialogue: 0,0:04:01.24,0:04:02.24,sign,,0000,0000,0000,,{\an8}BAJA
Dialogue: 0,0:04:02.24,0:04:04.66,sign,,0000,0000,0000,,{\an8}EUCOMMIA ELASTOMER
Dialogue: 0,0:04:09.29,0:04:12.04,sign,,0000,0000,0000,,{\an8}KABEL BAWAH LAUT DIPEROLEH!
Dialogue: 0,0:04:27.51,0:04:29.97,sign,,0000,0000,0000,,{\an8}KOPI DIPEROLEH!
Dialogue: 0,0:04:34.27,0:04:35.60,sign,,0000,0000,0000,,PERSEUS AMERIKA
Dialogue: 0,0:04:40.40,0:04:43.44,sign,,0000,0000,0000,,PERSEUS INDONESIA
Dialogue: 0,0:05:23.23,0:05:24.57,sign,,0000,0000,0000,,INTERNET DIPEROLEH!
Dialogue: 0,0:12:23.82,0:12:25.28,sign,,0000,0000,0000,,{\an8}LATIHAN KONSENTRASI
Dialogue: 0,0:12:25.28,0:12:27.03,sign,,0000,0000,0000,,{\an8}UJIAN 01
Dialogue: 0,0:12:48.93,0:12:49.97,sign,,0000,0000,0000,,{\an8}PROGRAM PEMBUAT LABIRIN
Dialogue: 0,0:12:49.97,0:12:52.39,sign,,0000,0000,0000,,{\an8}LATIHAN KESEIMBANGAN
Dialogue: 0,0:15:34.01,0:15:35.30,sign,,0000,0000,0000,,{\an8}MISI LUNA
Dialogue: 0,0:15:51.03,0:15:53.61,sign,,0000,0000,0000,,LABORATORIUM
Dialogue: 0,0:17:22.33,0:17:23.41,sign,,0000,0000,0000,,PERMAINAN BERAKHIR
Dialogue: 0,0:18:33.65,0:18:35.36,sign,,0000,0000,0000,,LABORATORIUM
Dialogue: 0,0:21:50.01,0:21:51.43,sign,,0000,0000,0000,,HATI-HATI
Dialogue: 0,0:23:53.34,0:23:56.05,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:56.05,0:23:57.30,sign,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA,
Dialogue: 0,0:23:57.31,0:23:58.43,sign,,0000,0000,0000,,MATERIAL, DAN METODENYA\NDIDASARKAN PADA KENYATAAN
Dialogue: 0,0:23:58.43,0:23:59.68,sign,,0000,0000,0000,,MOHON JANGAN DICOBA
Dialogue: 0,0:23:59.68,0:24:01.06,sign,,0000,0000,0000,,KARENA BISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:03.71,0:00:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal antariksa yang akan kita bawa\Nke bulan membutuhkan jutaan komponen.
Dialogue: 0,0:00:08.09,0:00:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan internet,
Dialogue: 0,0:00:10.38,0:00:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan buat semua komponennya\Ndengan insinyur di seluruh dunia.
Dialogue: 0,0:00:13.68,0:00:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, benar-benar "internet"\Nyang kita pakai di ponsel kita?
Dialogue: 0,0:00:17.22,0:00:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya!\NAkhirnya kita sampai di titik ini!
Dialogue: 0,0:00:20.18,0:00:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini akan menjadi\Nproyek terbesar dan terakhir kita
Dialogue: 0,0:00:23.64,0:00:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum kita pergi ke bulan.
Dialogue: 0,0:00:26.27,0:00:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar… Kita memakai internet\Nuntuk media sosial dan segalanya…
Dialogue: 0,0:00:29.73,0:00:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi kita memang normal,\Ntapi sebenarnya juga kurang jelas…
Dialogue: 0,0:00:35.20,0:00:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini pertanyaan\Nyang sangat mendasar, tapi…
Dialogue: 0,0:00:37.95,0:00:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya membuat "internet"?
Dialogue: 0,0:00:41.45,0:00:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teh Eucommia.
Dialogue: 0,0:00:44.62,0:00:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Teh Eucommia.{\i0}
Dialogue: 0,0:00:46.00,0:00:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teh sehat
Dialogue: 0,0:00:48.92,0:00:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bagus untuk tubuh itu?
Dialogue: 0,0:00:51.30,0:00:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:52.21,0:00:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham!
Dialogue: 0,0:00:53.97,0:00:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita menikmati teh bersama,
Dialogue: 0,0:00:55.76,0:00:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan dapat motivasi\Nuntuk membuat internet!
Dialogue: 0,0:00:58.76,0:01:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:01:02.10,0:01:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita mulai.
Dialogue: 0,0:01:04.23,0:01:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kelahiran internet!
Dialogue: 0,0:02:45.37,0:02:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tiram…
Dialogue: 0,0:02:48.41,0:02:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiram? Tiram!
Dialogue: 0,0:02:58.67,0:03:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sungguh harum. Rasanya yang manis dan\Nsegar sangat cocok dengan permen Jepang.
Dialogue: 0,0:03:04.18,0:03:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pohon Eucommia
Dialogue: 0,0:03:05.81,0:03:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}luar biasa edan dan bahkan\Ntahan terhadap hama. HAHA!
Dialogue: 0,0:03:09.85,0:03:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja sudah ada\Nsejak Zaman Dinosaurus!
Dialogue: 0,0:03:13.77,0:03:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pohonnya mengandung zat yang lengket.
Dialogue: 0,0:03:18.23,0:03:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda apa ini?\NLengket dan mirip jaring laba-laba.
Dialogue: 0,0:03:21.74,0:03:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tehnya cuma bonus.\NKita akan mengumpulkan zat lengket itu.
Dialogue: 0,0:03:25.99,0:03:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya "Eucommia elastomer."
Dialogue: 0,0:03:28.66,0:03:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip karet, tapi kuat\Ndan luar biasa tahan lama.
Dialogue: 0,0:03:32.54,0:03:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zat ini bahkan kebal\Nterhadap air dan listrik,
Dialogue: 0,0:03:34.92,0:03:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi digunakan untuk bola golf\Ndan filamen percetakan 3D
Dialogue: 0,0:03:40.09,0:03:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kita mau membuat internet?
Dialogue: 0,0:03:42.22,0:03:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kita memakai zat\Nyang kuat dan lengket ini untuk internet?
Dialogue: 0,0:03:46.47,0:03:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebal terhadap air dan listrik…
Dialogue: 0,0:03:50.64,0:03:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila! Kau mau memasang kabel\Nbawah laut dan menghubungkan semua orang
Dialogue: 0,0:03:55.23,0:03:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di seluruh dunia?
Dialogue: 0,0:04:12.83,0:04:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa langsung pergi\Ndari Jepang ke daratan Amerika Serikat,
Dialogue: 0,0:04:17.42,0:04:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kita akan manfaatkan
Dialogue: 0,0:04:19.09,0:04:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hawaii, pulau musim panas abadi,\Nsebagai stasiun relai.
Dialogue: 0,0:04:29.97,0:04:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aloha.{\i0}
Dialogue: 0,0:04:31.35,0:04:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau cuma mau mampir ke Hawaii, 'kan?
Dialogue: 0,0:05:01.50,0:05:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}TiDAK ADA SINYAL
Dialogue: 0,0:05:14.77,0:05:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertemuan virtual!
Dialogue: 0,0:05:25.65,0:05:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Luar biasa…{\i0}
Dialogue: 0,0:05:27.49,0:05:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Walau terpisah jarak yang jauh,{\i0}
Dialogue: 0,0:05:29.32,0:05:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kita bisa berbicara\Nseakan kita sedang bersama.{\i0}
Dialogue: 0,0:05:34.33,0:05:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini artinya kita tak perlu lagi\Nmemakai kode Morse
Dialogue: 0,0:05:37.00,0:05:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang merepotkan itu, 'kan?
Dialogue: 0,0:05:39.29,0:05:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ginro, kenapa malah itu\Nyang membuatmu emosional?{\i0}
Dialogue: 0,0:05:44.30,0:05:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, pengguna sains\Ndari seluruh dunia
Dialogue: 0,0:05:47.22,0:05:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar saling terhubung.
Dialogue: 0,0:05:51.55,0:05:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, halo. Aku Dr. Xeno,
Dialogue: 0,0:05:55.81,0:05:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantan insinyur roket NASA.
Dialogue: 0,0:05:57.02,0:05:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Senku.
Dialogue: 0,0:05:58.44,0:06:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita lewati perkenalan\Ndan langsung ke intinya saja.
Dialogue: 0,0:06:02.32,0:06:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai lagi dia.
Dialogue: 0,0:06:03.86,0:06:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, dia selalu cuek.
Dialogue: 0,0:06:09.95,0:06:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas untuk merancang\Njutaan komponen kapal antariksa
Dialogue: 0,0:06:14.16,0:06:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan dibagikan di antara\Nsemua insinyur di seluruh dunia.
Dialogue: 0,0:06:18.25,0:06:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?
Dialogue: 0,0:06:19.96,0:06:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menggambar\Ndiagram di atas kertas
Dialogue: 0,0:06:22.42,0:06:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan setiap kali diubah, kita akan kirim\Nulang dan rundingkan dengan semuanya.
Dialogue: 0,0:06:26.34,0:06:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merepotkan sekali…
Dialogue: 0,0:06:28.55,0:06:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, menurutmu kenapa\Nkita repot-repot membuat internet?
Dialogue: 0,0:06:33.76,0:06:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Proses perancangannya\Nakan dilakukan secara daring.
Dialogue: 0,0:06:36.68,0:06:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:38.14,0:06:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin itu bisa dilakukan!
Dialogue: 0,0:06:40.69,0:06:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak dengan\Nspesifikasi komputer saat ini.
Dialogue: 0,0:06:45.61,0:06:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kita akan pakai kertas elektronik.
Dialogue: 0,0:06:48.95,0:06:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau lebih tepatnya, pendahulunya.
Dialogue: 0,0:06:52.41,0:06:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ambil berkas elektron TV
Dialogue: 0,0:06:54.53,0:06:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kita ganti dengan dua berkas,\Nyang kuat dan yang lemah.
Dialogue: 0,0:06:57.95,0:06:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian yang tersentuh pulpen digital
Dialogue: 0,0:07:00.41,0:07:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan tetap menyala,\Njadi kita bisa menggambar di layar.
Dialogue: 0,0:07:04.75,0:07:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa?
Dialogue: 0,0:07:05.88,0:07:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita pasang pelat logam\Nuntuk membaca data,
Dialogue: 0,0:07:09.47,0:07:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa mengirim\Ngaris apa pun yang tertulis di TV.
Dialogue: 0,0:07:13.51,0:07:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beginilah cara kerja\Nsistem CAD komersial generasi awal.
Dialogue: 0,0:07:18.18,0:07:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Begitu, ya! Tidak terpikirkan olehku.{\i0}
Dialogue: 0,0:07:20.39,0:07:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku tak paham\Nkenapa mereka mengangguk-angguk setuju.
Dialogue: 0,0:07:24.81,0:07:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya para insinyur\Nyang merasa takjub dan bersemangat.
Dialogue: 0,0:07:30.07,0:07:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada dasarnya,\Npara insinyur di seluruh dunia
Dialogue: 0,0:07:33.49,0:07:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa menggambar diagram di layar mereka
Dialogue: 0,0:07:36.08,0:07:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan saling berbagi layar secara langsung.
Dialogue: 0,0:07:41.41,0:07:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya mulai terbentuk…
Dialogue: 0,0:07:43.92,0:07:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal antariksa kita.
Dialogue: 0,0:07:51.55,0:07:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:07:53.43,0:07:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempat duduk para astronaut\Ndalam perjalanan ke bulan.
Dialogue: 0,0:07:56.85,0:07:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jadi? Kerja sama\Nseluruh dunia memang luar biasa.
Dialogue: 0,0:07:59.85,0:08:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila!
Dialogue: 0,0:08:04.31,0:08:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya?
Dialogue: 0,0:08:06.44,0:08:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur, ini sempit sekali!\NPerlu latihan untuk membiasakan diri.
Dialogue: 0,0:08:11.32,0:08:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sungguh terjadi, ya?
Dialogue: 0,0:08:13.40,0:08:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menaiki benda ini sampai\Nke bulan yang berada jauh di atas sana.
Dialogue: 0,0:08:17.07,0:08:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dan perjalanannya pulang pergi.\NKita pastikan semuanya pulang hidup-hidup!
Dialogue: 0,0:08:21.58,0:08:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:23.12,0:08:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya kita menghadapi\Nsang bos terakhir, Why-Man.
Dialogue: 0,0:08:27.00,0:08:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan pilih\Nsiapa yang akan pergi ke bulan.
Dialogue: 0,0:08:29.42,0:08:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya memulai pelatihan astronaut.
Dialogue: 0,0:08:32.63,0:08:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya aku mau naik!
Dialogue: 0,0:08:35.80,0:08:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roketnya bisa menampung tiga orang.
Dialogue: 0,0:08:38.22,0:08:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para astronaut\Nyang akan mendarat di bulan…
Dialogue: 0,0:08:41.06,0:08:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tiga orang yang akan berangkat?
Dialogue: 0,0:08:43.10,0:08:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hei, kalau kau memaksa,\Nakan kupertimbangkan.
Dialogue: 0,0:08:46.31,0:08:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak ada yang memintamu.
Dialogue: 0,0:08:48.27,0:08:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Karena kau ahlinya, sebaiknya kau pilih\Nsiapa yang akan berangkat, Xeno.
Dialogue: 0,0:08:52.61,0:08:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan menjadi\Npenerbangan antariksa dunia baru
Dialogue: 0,0:08:55.28,0:08:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari Dunia Batu.
Dialogue: 0,0:08:57.41,0:09:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan jauh berbeda dari\Npenerbangan antariksa di dunia lama.
Dialogue: 0,0:09:01.12,0:09:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, selama sebagian besar\Npenerbangan, anggota kru bisa
Dialogue: 0,0:09:04.33,0:09:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetap membatu,\Ntermasuk pada saat peluncuran.
Dialogue: 0,0:09:08.54,0:09:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Benar! Selama mereka dibangkitkan\Ndi saat yang diperlukan…
Dialogue: 0,0:09:12.46,0:09:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Benar.
Dialogue: 0,0:09:13.51,0:09:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Merancang sistem penunjang kehidupan\Ndengan mempertimbangkan itu
Dialogue: 0,0:09:16.76,0:09:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}membuat semuanya lebih mudah.
Dialogue: 0,0:09:18.18,0:09:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu salah satu keuntungan di dunia baru.
Dialogue: 0,0:09:21.14,0:09:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Di sisi lain, yang mempersulit keadaan
Dialogue: 0,0:09:24.02,0:09:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}adalah fakta bahwa\Nkita tak tahu apa pun soal misi ini.
Dialogue: 0,0:09:27.73,0:09:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya Why-Man?
Dialogue: 0,0:09:29.81,0:09:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sains kita bisa\Nberdampak pada musuh kita?
Dialogue: 0,0:09:33.61,0:09:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang bisa kita andalkan
Dialogue: 0,0:09:34.78,0:09:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya pengalaman kita berurusan\Ndengan Why-Man dan Sinar Pembatu.
Dialogue: 0,0:09:38.95,0:09:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tak banyak, tapi itu akan\Nmenentukan masa depan umat manusia.
Dialogue: 0,0:09:43.08,0:09:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, daripada\Nmencari astronaut dari dunia lama,
Dialogue: 0,0:09:46.54,0:09:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan mencari dan melatih\Norang dari anggota kita.
Dialogue: 0,0:09:52.75,0:09:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga anggota yang terpilih
Dialogue: 0,0:09:54.80,0:09:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menjadi pilot, ilmuwan, dan petarung.
Dialogue: 0,0:09:59.55,0:10:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kursi pertama adalah milikku!\NApa aku salah?
Dialogue: 0,0:10:02.68,0:10:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada yang keberatan\Nkalau kau yang menjadi pilotnya.
Dialogue: 0,0:10:06.52,0:10:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya adalah memilih ilmuwannya…
Dialogue: 0,0:10:09.52,0:10:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengatur pusat kendali.\NLebih tepatnya, tak ada pilihan lain.
Dialogue: 0,0:10:14.23,0:10:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nsudah jelas siapa ilmuwannya.
Dialogue: 0,0:10:16.90,0:10:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masalahnya?
Dialogue: 0,0:10:19.74,0:10:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang akan membatu\Nhampir di seluruh penerbangan,
Dialogue: 0,0:10:22.20,0:10:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sejumlah kekuatan fisik\Ndan latihan masih diperlukan.
Dialogue: 0,0:10:27.58,0:10:29.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan fisik…
Dialogue: 0,0:10:29.29,0:10:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku…
Dialogue: 0,0:10:34.09,0:10:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Senku!
Dialogue: 0,0:10:36.26,0:10:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau selemah kutu,
Dialogue: 0,0:10:37.92,0:10:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi itu bukan alasan menyerah\Ndi ujian berenang memakai pakaian!
Dialogue: 0,0:10:41.14,0:10:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tak sebanding dengan berenang\Nmemakai pakaian antariksa!
Dialogue: 0,0:10:44.89,0:10:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, itu Nikki dan yang lain!
Dialogue: 0,0:10:47.06,0:10:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan mereka pulang ke Jepang?
Dialogue: 0,0:10:49.81,0:10:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku juga tak sadar\Nmereka sudah di sini.
Dialogue: 0,0:10:52.48,0:10:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena kita bertemu\Nsecara virtual setiap hari.
Dialogue: 0,0:10:56.78,0:10:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita sudah punya internet,
Dialogue: 0,0:10:58.78,0:11:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita tak perlu mengirim\Norang untuk berkomunikasi.
Dialogue: 0,0:11:02.03,0:11:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sains akan dibagikan\Nke seluruh dunia secara daring
Dialogue: 0,0:11:04.95,0:11:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kita akan memasuki fase
Dialogue: 0,0:11:06.54,0:11:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ketika orang-orang bisa mulai\Nmemulihkan negara mereka masing-masing.
Dialogue: 0,0:11:14.63,0:11:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuzuriha!
Dialogue: 0,0:11:16.92,0:11:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taiju!
Dialogue: 0,0:11:21.22,0:11:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ginro!
Dialogue: 0,0:11:24.18,0:11:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohaku!
Dialogue: 0,0:11:31.94,0:11:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xeno, fakta bahwa semuanya\Nberkumpul di sini pasti artinya…
Dialogue: 0,0:11:36.77,0:11:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, kau memang jeli, Gen.\NSungguh deduksi yang elegan.
Dialogue: 0,0:11:40.61,0:11:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk memilih astronaut petarung.
Dialogue: 0,0:11:53.12,0:11:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Desa Ishigami juga hebat!
Dialogue: 0,0:11:55.58,0:11:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, mereka besar di dekat air!
Dialogue: 0,0:11:57.17,0:12:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian tak ada bedanya.\NBerenang adalah rutinitas sehari-hari.
Dialogue: 0,0:12:03.84,0:12:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berenang memakai pakaian\Nadalah kelemahan terbesarmu, 'kan?
Dialogue: 0,0:12:18.23,0:12:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Mengejutkan…
Dialogue: 0,0:12:19.90,0:12:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku juga berusaha sekuat tenaga!
Dialogue: 0,0:12:27.03,0:12:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah mendengar ini.
Dialogue: 0,0:12:29.33,0:12:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memakai\Nteka-teki yang seluruhnya putih
Dialogue: 0,0:12:31.70,0:12:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berlatih melakukan\Ntugas yang sangat merepotkan.
Dialogue: 0,0:12:42.34,0:12:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal berpikir, dia tak tertandingi!
Dialogue: 0,0:12:45.22,0:12:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Lagi pula, siapa yang membuat\Nteka-teki labirin yang gila itu?
Dialogue: 0,0:13:04.61,0:13:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi sekali!
Dialogue: 0,0:13:06.07,0:13:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukasa!
Dialogue: 0,0:13:07.82,0:13:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mengejutkan.\NPerforma dia selalu baik.
Dialogue: 0,0:13:10.91,0:13:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Kita semua tahu\Nsejak awal kalau dia kandidat terkuat!
Dialogue: 0,0:13:16.21,0:13:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita akan pilih Tsukasa?
Dialogue: 0,0:13:18.71,0:13:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, dari yang kulihat\Nsejauh ini, semuanya elegan.
Dialogue: 0,0:13:22.25,0:13:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku hanya bisa\Nmembandingkan statistiknya,
Dialogue: 0,0:13:25.38,0:13:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi pertarungan kita melawan\NWhy-Man lebih dari sekadar angka.
Dialogue: 0,0:13:28.59,0:13:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita bukan ahli dalam pertarungan.
Dialogue: 0,0:13:52.41,0:13:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Tsukasa?
Dialogue: 0,0:13:54.50,0:13:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau memintaku ke sini?
Dialogue: 0,0:14:05.26,0:14:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sudah gila? Apa yang kau…
Dialogue: 0,0:14:09.05,0:14:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya! Tsukasa, jangan bilang
Dialogue: 0,0:14:12.10,0:14:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau mau mengkhianati kami!
Dialogue: 0,0:14:20.73,0:14:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kohaku.
Dialogue: 0,0:14:22.65,0:14:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku sudah menguji kemampuanmu.
Dialogue: 0,0:14:28.20,0:14:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku teringat masa lalu.
Dialogue: 0,0:14:30.61,0:14:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pertama kita bertemu,
Dialogue: 0,0:14:32.70,0:14:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita mengacungkan senjata\Npada satu sama lain, seperti ini.
Dialogue: 0,0:14:35.49,0:14:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, setelah melakukan\Nbanyak pertarungan nyata,
Dialogue: 0,0:14:37.91,0:14:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau sudah sama kuatnya\Ndengan aku dan Hyoga.
Dialogue: 0,0:14:46.21,0:14:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu bicara manis.\NAku bisa tahu dari pertarungan barusan
Dialogue: 0,0:14:50.09,0:14:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kemampuan bertarungku\Nmasih jauh di bawahmu.
Dialogue: 0,0:14:55.89,0:14:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi kau akan mencapainya,
Dialogue: 0,0:14:58.14,0:15:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa lagi dengan\Nsenjata dari Kerajaan Sains.
Dialogue: 0,0:15:02.31,0:15:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya…
Dialogue: 0,0:15:03.77,0:15:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sains menyetarakan semua orang.
Dialogue: 0,0:15:12.36,0:15:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:15:13.57,0:15:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan mempertimbangkan hal itu,
Dialogue: 0,0:15:15.58,0:15:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}petarung yang ringan adalah pilihan\Nterbaik untuk pertarungan di bulan.
Dialogue: 0,0:15:18.79,0:15:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga bisa mengurangi\Nlusinan kilogram dari berat roket.
Dialogue: 0,0:15:22.83,0:15:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesimpulanku sebagai ahli pertarungan.
Dialogue: 0,0:15:36.10,0:15:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tiga astronaut perkasa\Nyang akan melawan Why-Man adalah{\i0}
Dialogue: 0,0:15:40.73,0:15:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ryusui, Senku, dan Kohaku.{\i0}
Dialogue: 0,0:15:59.20,0:16:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai!
Dialogue: 0,0:16:00.62,0:16:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak Ryusui terpilih\Npergi ke luar angkasa…
Dialogue: 0,0:16:04.75,0:16:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat bersemangat!
Dialogue: 0,0:16:07.25,0:16:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, karena dia menginginkan semuanya.
Dialogue: 0,0:16:10.63,0:16:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dibuat sesuai skala secara akurat?\NEdan sekali!
Dialogue: 0,0:16:13.59,0:16:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya,
Dialogue: 0,0:16:14.51,0:16:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berkat ini, jauh lebih mudah\Nuntuk melihat banyak hal.
Dialogue: 0,0:16:17.14,0:16:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir lagi,
Dialogue: 0,0:16:18.72,0:16:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perseus juga cuma model kapal Ryusui\Nyang skalanya ditingkatkan.
Dialogue: 0,0:16:22.60,0:16:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti membuat\Nkapal antariksa dalam botol.
Dialogue: 0,0:16:26.31,0:16:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku teringat, dulu saat dia\Nmembuat kapal dalam botol,
Dialogue: 0,0:16:30.53,0:16:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusui selalu membuatku\Nmelakukan perhitungan untuk rancangannya.
Dialogue: 0,0:16:39.28,0:16:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat suka membuat model, ya?
Dialogue: 0,0:16:43.46,0:16:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kubuat bukan cuma model.
Dialogue: 0,0:16:46.17,0:16:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:47.33,0:16:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah kapal masa depan.
Dialogue: 0,0:16:48.96,0:16:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan ini\Ncuma menjadi model.
Dialogue: 0,0:16:51.67,0:16:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berlayar di atas\Nkapal sungguhan, apa pun yang terjadi.
Dialogue: 0,0:16:55.13,0:16:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menuju laut lepas!
Dialogue: 0,0:17:00.89,0:17:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa memrogram\Nsimulator kapal layar, Sai?
Dialogue: 0,0:17:05.31,0:17:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:12.40,0:17:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Program simulator penerbangan antariksa!
Dialogue: 0,0:17:37.68,0:17:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skor tinggi lagi!
Dialogue: 0,0:17:39.51,0:17:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang profesional.
Dialogue: 0,0:17:42.51,0:17:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak boleh kalah\Ndari siapa pun dalam simulator.
Dialogue: 0,0:17:46.64,0:17:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak tahu apa yang akan terjadi\Nsaat terbang dengan sains dunia baru.
Dialogue: 0,0:17:51.40,0:17:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mengandalkan\Ninsting dan pengalaman kita di Dunia Batu.
Dialogue: 0,0:17:55.03,0:17:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah?
Dialogue: 0,0:17:55.94,0:17:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal pengalaman di dunia ini…
Dialogue: 0,0:17:59.07,0:18:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas tak ada pilot lain
Dialogue: 0,0:18:00.82,0:18:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang lebih baik darimu, Ryusui.
Dialogue: 0,0:18:05.45,0:18:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di Dunia Batu ini…{\i0}
Dialogue: 0,0:18:08.04,0:18:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Pilot yang berpengalaman…{\i0}
Dialogue: 0,0:18:21.30,0:18:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:18:23.26,0:18:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa di luar angkasa\Nbiasa terjadi adu tembak?
Dialogue: 0,0:18:26.60,0:18:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak.\N- Ini cuma bonus.
Dialogue: 0,0:18:28.77,0:18:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, mungkin akan ada adu tembak.
Dialogue: 0,0:18:32.44,0:18:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa!
Dialogue: 0,0:18:37.53,0:18:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang tahu apa yang akan terjadi
Dialogue: 0,0:18:40.70,0:18:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat pertarungan di bulan.
Dialogue: 0,0:18:42.49,0:18:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa senjata terkuat Why-Man
Dialogue: 0,0:18:45.95,0:18:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sepuluh miliar persen\Nampuh melawan kita?
Dialogue: 0,0:18:49.00,0:18:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:52.84,0:18:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medusa!
Dialogue: 0,0:18:53.79,0:18:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Kau dapat satu triliun poin.
Dialogue: 0,0:18:57.34,0:18:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bodoh.
Dialogue: 0,0:18:58.51,0:19:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin kita menyerang tanpa rencana.
Dialogue: 0,0:19:01.84,0:19:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan menggunakan sains, kami sudah\Nmembuat dua benda khusus anti-Medusa.
Dialogue: 0,0:19:07.10,0:19:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini yang pertama.{\i0}
Dialogue: 0,0:19:09.69,0:19:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pembuat arloji, aku bangga\Nmenunjukkan mahakaryaku pada kalian.
Dialogue: 0,0:19:13.31,0:19:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini bisa disebut
Dialogue: 0,0:19:15.90,0:19:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arloji Pembangkit.
Dialogue: 0,0:19:18.90,0:19:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arloji ini berisi\Ncairan pembangkit untuk satu orang.
Dialogue: 0,0:19:23.16,0:19:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebelum terkena Sinar Pembatu,{\i0}
Dialogue: 0,0:19:25.33,0:19:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}atur saja waktunya untuk\Ntiga detik atau menit, terserah kalian.{\i0}
Dialogue: 0,0:19:33.08,0:19:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:19:34.92,0:19:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila. Kalau semuanya memakai ini,
Dialogue: 0,0:19:38.30,0:19:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan baik-baik saja bahkan\Nkalau seluruh Bumi dibatukan!
Dialogue: 0,0:19:41.72,0:19:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lihat gunungan Medusa\Ndi pusat ledakan di Manaus, 'kan?
Dialogue: 0,0:19:46.85,0:19:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus apa
Dialogue: 0,0:19:48.06,0:19:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau diserang Sinar Pembatu\Nsecara beruntun? Kita tak berdaya!
Dialogue: 0,0:19:53.35,0:19:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi serangan beruntun juga\Npunya kelemahan sendiri.
Dialogue: 0,0:19:57.90,0:20:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Why-Man menembakkan\NSinar Pembatu secara beruntun,
Dialogue: 0,0:20:02.40,0:20:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti ada jeda waktu di antara\Nsetiap pendaran cahayanya.
Dialogue: 0,0:20:07.20,0:20:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam kata lain, setelah pendaran pertama,
Dialogue: 0,0:20:09.08,0:20:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan ada hitungan mundur\Nsampai serangan berikutnya.
Dialogue: 0,0:20:12.71,0:20:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum cahaya dari serangan
Dialogue: 0,0:20:15.38,0:20:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medusa berikutnya bersinar…
Dialogue: 0,0:20:17.13,0:20:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa…\N- Ini…
Dialogue: 0,0:20:18.67,0:20:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda khusus kedua, dan terakhir.
Dialogue: 0,0:20:38.90,0:20:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini senjata pamungkas anti-Medusa.
Dialogue: 0,0:20:42.40,0:20:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Granat senapan jaring.
Dialogue: 0,0:21:01.96,0:21:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti tak sabar\Npergi ke luar angkasa, Ryusui.
Dialogue: 0,0:21:05.09,0:21:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bersemangat sekali.
Dialogue: 0,0:21:08.14,0:21:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai kapten, dia pasti\Nbekerja lebih keras karena tahu
Dialogue: 0,0:21:11.22,0:21:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tak bisa mengandalkan bidikan kita.
Dialogue: 0,0:21:13.81,0:21:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga harus berusaha keras!
Dialogue: 0,0:21:30.53,0:21:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan pura-pura tak tahu.{\i0}
Dialogue: 0,0:21:34.83,0:21:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada seseorang…{\i0}
Dialogue: 0,0:21:36.87,0:21:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seseorang yang lebih ahli\Ndaripada aku sebagai pilot,{\i0}
Dialogue: 0,0:21:40.54,0:21:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan ditambah lagi,\Npenembak jitu terbaik di dunia.{\i0}
Dialogue: 0,0:21:45.22,0:21:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada tempat rahasia yang\Nhanya diketahui oleh kita yang bertarung{\i0}
Dialogue: 0,0:21:48.55,0:21:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}untuk Kerajaan Sains.{\i0}
Dialogue: 0,0:21:51.43,0:21:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tempat di mana pria terkuat\Ndi dunia pernah bersemayam.{\i0}
Dialogue: 0,0:22:08.03,0:22:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Stanley Snyder.{\i0}
Dialogue: 0,0:24:01.06,0:24:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
