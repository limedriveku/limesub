Dialogue: 0,0:02:24.85,0:02:29.81,sign,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:11:32.31,0:11:36.44,sign,,0000,0000,0000,,{\an8}BEBERAPA TAHUN KEMUDIAN
Dialogue: 0,0:16:19.56,0:16:22.02,sign,,0000,0000,0000,,BAHAGIA
Dialogue: 0,0:18:32.27,0:18:33.15,sign,,0000,0000,0000,,DILARANG MASUK
Dialogue: 0,0:20:53.33,0:20:55.96,sign,,0000,0000,0000,,{\an8}WHY-MAN, PENGENDALI MEDAN HIGGS,\NSUPERKOMPUTER, SEMIKONDUKTOR
Dialogue: 0,0:20:56.04,0:21:00.25,sign,,0000,0000,0000,,{\an8}MOTOR SIKLOTRON BERKECEPATAN CAHAYA,\NALAT VAKUM ULTRA TINGGI, MESIN WAKTU
Dialogue: 0,0:23:17.93,0:23:19.06,sign,,0000,0000,0000,,SELESAI DAN BERSAMBUNG
Dialogue: 0,0:23:22.73,0:23:25.52,sign,,0000,0000,0000,,PAMERAN
Dialogue: 0,0:23:28.82,0:23:31.49,sign,,0000,0000,0000,,{\an8}KAPAK BATU
Dialogue: 0,0:23:50.97,0:23:55.89,sign,,0000,0000,0000,,{\an8}TERIMA KASIH BANYAK ATAS ANIME YANG HEBAT!\NTERIMA KASIH BANYAK ATAS KASIH SAYANGNYA!!
Dialogue: 0,0:23:55.97,0:23:57.35,sign,,0000,0000,0000,,{\an8}KISAH INI FIKTIF TAPI FLORA/FAUNA,
Dialogue: 0,0:23:57.43,0:23:58.72,sign,,0000,0000,0000,,{\an8}MATERIAL, DAN METODENYA\NDIDASARKAN PADA KENYATAAN
Dialogue: 0,0:23:58.81,0:24:00.85,sign,,0000,0000,0000,,{\an8}MOHON JANGAN DICOBA\NKARENA BISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:05.08,0:00:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, Why-Man,
Dialogue: 0,0:00:08.25,0:00:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau bernegosiasi\Nempat mata dengan kalian.
Dialogue: 0,0:00:22.64,0:00:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:00:32.78,0:00:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku!
Dialogue: 0,0:00:34.70,0:00:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku!
Dialogue: 0,0:00:39.74,0:00:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Why-Man berkomunikasi\Nmelalui gelombang radio.
Dialogue: 0,0:00:43.25,0:00:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permukaan mereka terbuat\Ndari bahan yang bisa menyerap radiasi.
Dialogue: 0,0:00:48.54,0:00:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pada dasarnya,\Nsaat mereka membentuk diri menjadi kubah,
Dialogue: 0,0:00:52.38,0:00:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagian dalamnya benar-benar\Nterisolasi dari dunia luar, ya?
Dialogue: 0,0:01:06.60,0:01:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian bebas mengapung\Nke mana pun sesuka kalian?
Dialogue: 0,0:01:10.90,0:01:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu bagaimana cara kerjanya.
Dialogue: 0,0:01:14.61,0:01:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:01:17.41,0:01:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai contoh,
Dialogue: 0,0:01:20.49,0:01:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami bisa memindai tubuhmu…
Dialogue: 0,0:01:26.83,0:01:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuat patung kaummu.
Dialogue: 0,0:01:39.64,0:01:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengabaikan hukum gravitasi, ya?\NKalau begitu…
Dialogue: 0,0:02:01.32,0:02:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang kau rencanakan, Senku?{\i0}
Dialogue: 0,0:02:06.25,0:02:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian meminjamkan tubuh kalian,
Dialogue: 0,0:02:09.58,0:02:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin kita bisa\Nmelakukan sesuatu yang gila.
Dialogue: 0,0:02:13.75,0:02:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu dengan\N"meminjamkan tubuh kami"?
Dialogue: 0,0:02:17.80,0:02:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Seisi dunia akan merasa tergoda!
Dialogue: 0,0:04:00.32,0:04:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tak tahu apa yang terjadi.
Dialogue: 0,0:04:02.45,0:04:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang mereka bicarakan di dalam sana?
Dialogue: 0,0:04:05.28,0:04:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini agak terlalu lama.
Dialogue: 0,0:04:08.83,0:04:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus bersiap\Nuntuk kemungkinan terburuk.{\i0}
Dialogue: 0,0:04:12.16,0:04:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Misalnya, mungkin Senku sudah\Nmembatu di dalam sana…{\i0}
Dialogue: 0,0:04:18.17,0:04:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaum kalian tak memiliki kecerdasan
Dialogue: 0,0:04:21.01,0:04:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan maka itu tak bisa mereplikasi kami.
Dialogue: 0,0:04:24.22,0:04:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan meninggalkan kalian\Ndan pergi ke planet lain.
Dialogue: 0,0:04:26.93,0:04:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebelum pergi, kami akan\Nmemberi kalian berkah pembatuan.
Dialogue: 0,0:04:30.64,0:04:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lari.
Dialogue: 0,0:04:49.83,0:04:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalur tembakan yang sempurna.
Dialogue: 0,0:04:52.87,0:04:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak dari kami yang akan mati.
Dialogue: 0,0:04:55.62,0:05:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kalian mundur,\Naku tak berniat menembak.
Dialogue: 0,0:05:05.30,0:05:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu apa\Nyang Senku bilang pada kalian,
Dialogue: 0,0:05:08.30,0:05:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kami butuh kalian\Ntetap ada di meja perundingan.
Dialogue: 0,0:05:12.52,0:05:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya bisa memastikan itu.
Dialogue: 0,0:05:17.65,0:05:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian adalah parasit.
Dialogue: 0,0:05:20.19,0:05:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kalian tak cukup bodoh\Nuntuk melawan inang kalian.
Dialogue: 0,0:05:23.23,0:05:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,\Nkembali ke pembicaraan kita tadi…
Dialogue: 0,0:05:25.65,0:05:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian bekerja sama dengan kami,\Ndaripada pergi ke planet lain,
Dialogue: 0,0:05:30.99,0:05:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}umat manusia bisa bekerja dengan Why-Man
Dialogue: 0,0:05:34.25,0:05:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mungkin menciptakan\Nsesuatu yang luar biasa.
Dialogue: 0,0:05:38.96,0:05:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluang itu akan berhasil
Dialogue: 0,0:05:41.13,0:05:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemungkinan besar mendekati nol persen.
Dialogue: 0,0:05:44.96,0:05:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mungkin memang mendekati nol persen,\Ntapi tak akan pernah mencapai nol
Dialogue: 0,0:05:50.14,0:05:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama itu melibatkan kami.
Dialogue: 0,0:05:53.18,0:05:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monyet berkulit mulus\Nmemulai dari nol di Dunia Batu ini
Dialogue: 0,0:05:56.81,0:05:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berhasil
Dialogue: 0,0:06:00.90,0:06:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencapai bulan hanya dalam sepuluh tahun.
Dialogue: 0,0:06:09.32,0:06:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak bisa memenuhi permintaanmu.
Dialogue: 0,0:06:15.33,0:06:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan tinggalkan kaummu\Ndan pergi menuju planet lain.
Dialogue: 0,0:06:21.71,0:06:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mencari organisme yang lebih cerdas.
Dialogue: 0,0:06:31.80,0:06:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau begitu,\Naku sendiri akan ikut denganmu.
Dialogue: 0,0:06:36.81,0:06:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan tubuhku kalau kau mau.
Dialogue: 0,0:06:39.39,0:06:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh aku kalau mau.\NWahana sains luar biasa
Dialogue: 0,0:06:42.77,0:06:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kau sebutkan membuatku tertarik.
Dialogue: 0,0:06:47.53,0:06:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun mendekati nol persen,
Dialogue: 0,0:06:50.20,0:06:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan bertaruh pada kaum kalian.
Dialogue: 0,0:06:54.62,0:06:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian terima?
Dialogue: 0,0:06:57.37,0:06:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:20.39,0:07:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Why-Man sudah tak lagi menumpangi kita{\i0}
Dialogue: 0,0:07:23.31,0:07:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan menghilang ke luar angkasa{\i0}
Dialogue: 0,0:07:25.86,0:07:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan tak akan pernah menyinari\NSinar Pembatu pada kita lagi.{\i0}
Dialogue: 0,0:07:30.03,0:07:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu, hadiah kita{\i0}
Dialogue: 0,0:07:32.78,0:07:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah sepotong sains masa depan.{\i0}
Dialogue: 0,0:07:47.46,0:07:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:07:53.68,0:07:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:07:55.18,0:07:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadikan kapsul itu vakum
Dialogue: 0,0:07:58.81,0:08:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}justru membantumu\Ntetap sadar dan bisa bergerak, ya?
Dialogue: 0,0:08:02.02,0:08:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Itu benar.
Dialogue: 0,0:08:05.86,0:08:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian parasit mekanis, 'kan?
Dialogue: 0,0:08:10.36,0:08:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi siapa yang menciptakan kalian?
Dialogue: 0,0:08:13.36,0:08:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana asal kalian?
Dialogue: 0,0:08:15.32,0:08:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak tahu.
Dialogue: 0,0:08:18.16,0:08:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian tahu siapa yang pertama kali\Nmenciptakan spesies kalian
Dialogue: 0,0:08:22.25,0:08:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau dari mana asal kalian?
Dialogue: 0,0:08:26.17,0:08:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawaban yang pintar.
Dialogue: 0,0:08:28.17,0:08:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kalau dipikir-pikir,\Nhal itu masih misteri.
Dialogue: 0,0:08:33.88,0:08:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kehidupan itu apa?
Dialogue: 0,0:08:37.05,0:08:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kehidupan adalah untuk hidup.
Dialogue: 0,0:08:40.93,0:08:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa kalian tak suka dibatukan?
Dialogue: 0,0:08:44.56,0:08:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tak mau, walaupun itu\Nberarti bisa hidup selamanya? Kenapa?
Dialogue: 0,0:08:49.07,0:08:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak membuatku tergoda.
Dialogue: 0,0:08:52.24,0:08:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil bersenang-senang\Nsaat membatu. Apa aku salah?
Dialogue: 0,0:08:55.66,0:08:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung tertidur.
Dialogue: 0,0:08:58.62,0:09:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak paham.
Dialogue: 0,0:09:00.20,0:09:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai suatu organisme, itu bukan\Nkeputusan yang menguntungkan. Kenapa?
Dialogue: 0,0:09:04.41,0:09:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja dirimu.
Dialogue: 0,0:09:06.37,0:09:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kau Why-Man yang ikut dengan kami\Nkarena merasa tergoda.
Dialogue: 0,0:09:12.13,0:09:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak penting menguntungkan atau tidak.
Dialogue: 0,0:09:14.92,0:09:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bertemu hal yang tak dikenal, kami\Nbertanya "Kenapa?" dan merasa tergoda.
Dialogue: 0,0:09:18.76,0:09:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang aneh yang berpikir begitu\Nakan selalu muncul, sepuluh miliar persen.
Dialogue: 0,0:09:23.43,0:09:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dengan usaha keras, mereka memajukan
Dialogue: 0,0:09:26.89,0:09:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sains.
Dialogue: 0,0:09:29.98,0:09:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka melakukannya selama ribuan tahun
Dialogue: 0,0:09:32.94,0:09:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan akan melakukan itu\Nselama ribuan tahun mendatang.
Dialogue: 0,0:11:49.79,0:11:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali.
Dialogue: 0,0:11:51.66,0:11:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang kau minta.
Dialogue: 0,0:11:57.80,0:12:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang merasa\Nlebih nyaman memakai baju ini.
Dialogue: 0,0:12:03.09,0:12:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, parah sekali!\NSudah bertahun-tahun aku tak pulang!
Dialogue: 0,0:12:07.72,0:12:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mentalis, bukan diplomat!
Dialogue: 0,0:12:10.47,0:12:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan Anda penting dalam menjelaskan\Ndan berunding dengan negara lain
Dialogue: 0,0:12:15.48,0:12:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi menyatukan dunia baru, Tuan Gen.
Dialogue: 0,0:12:18.44,0:12:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma kau, Gen!
Dialogue: 0,0:12:21.74,0:12:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ryusui sudah mendirikan\NRyusui Corp secara resmi
Dialogue: 0,0:12:25.74,0:12:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sedang membantu memperbaiki dunia.
Dialogue: 0,0:12:28.99,0:12:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia juga sedang mengamankan\Nhak eksklusif untuk berbagai hal.
Dialogue: 0,0:12:34.17,0:12:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!\NAku menginginkan segalanya di dunia ini!
Dialogue: 0,0:12:40.46,0:12:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tsukasa terbang ke berbagai negara,
Dialogue: 0,0:12:44.01,0:12:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pergi ke mana pun dia dipanggil.
Dialogue: 0,0:12:47.97,0:12:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin banyak yang dibangkitkan,\Nkeamanan juga mulai menjadi persoalan.
Dialogue: 0,0:12:53.60,0:12:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma dengan satu lambaian tangannya
Dialogue: 0,0:12:55.10,0:12:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan entah kenapa, semua orang\Nyang berniat tak baik langsung kabur.
Dialogue: 0,0:12:59.69,0:13:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ahli bela diri terhebat\Ndi dunia sungguh hebat!
Dialogue: 0,0:13:04.70,0:13:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ukyo sedang bekerja tanpa lelah\Nsebagai pejabat Pemerintah Restorasi.
Dialogue: 0,0:13:09.24,0:13:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bekerja keras…
Dialogue: 0,0:13:11.79,0:13:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Berhenti!
Dialogue: 0,0:13:14.79,0:13:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti atau kutembak!
Dialogue: 0,0:13:19.42,0:13:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar payah! Kau mau membunuhku?\N- Andai saja aku berhasil!
Dialogue: 0,0:13:26.09,0:13:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau imut, ya. Ikutlah denganku.
Dialogue: 0,0:13:32.35,0:13:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ginro! Kau bermalas-malasan lagi?
Dialogue: 0,0:14:26.11,0:14:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuzuriha memulai\Nusaha mode dengan Taiju, 'kan?
Dialogue: 0,0:14:30.74,0:14:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya mereka berdua,\Ntapi dengan Nona Mirai dan Nona Ruri juga.
Dialogue: 0,0:14:35.20,0:14:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taiju bertanggung jawab atas\Npekerjaan fisik dan dukungan moral.
Dialogue: 0,0:14:39.67,0:14:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan\Ntim sains Kerajaan Sains kita?
Dialogue: 0,0:14:44.25,0:14:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja,\Nkita membuat proyek sains setiap hari.
Dialogue: 0,0:14:49.88,0:14:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, semuanya sibuk bekerja, ya?
Dialogue: 0,0:14:53.68,0:14:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi walau begitu,\Nkita tak boleh melewatkan ini.
Dialogue: 0,0:14:59.02,0:15:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pernikahan Taiju dan Yuzuriha!\N- Selamat!
Dialogue: 0,0:15:10.36,0:15:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pernikahan hari kedua?
Dialogue: 0,0:15:13.07,0:15:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang mau membuatnya\Nlebih mudah dihadiri oleh semua orang.
Dialogue: 0,0:15:17.95,0:15:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini acara yang bahagia,\Nmakin ramai makin seru!
Dialogue: 0,0:15:21.37,0:15:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking sibuknya tim sains,
Dialogue: 0,0:15:23.96,0:15:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku menyuruh semuanya\Npulang setelah hari pertama.
Dialogue: 0,0:15:28.30,0:15:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kurasa itu normal…\NBiasanya pernikahan cuma sehari, 'kan?
Dialogue: 0,0:15:33.80,0:15:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat.
Dialogue: 0,0:15:36.31,0:15:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau imut, ya.\NBagaimana kalau kau ikut denganku?
Dialogue: 0,0:15:42.56,0:15:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, lama tak bertemu!
Dialogue: 0,0:15:46.44,0:15:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini!
Dialogue: 0,0:15:52.20,0:15:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:15:56.95,0:15:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung kita di sini…
Dialogue: 0,0:15:58.54,0:16:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau lebih tepatnya,\Nkarena kita di sini, aku mau bertanya…
Dialogue: 0,0:16:02.54,0:16:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hubunganmu dengan Chrome?
Dialogue: 0,0:16:06.04,0:16:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:08.63,0:16:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku gadis yang keren, tahu?{\i0}
Dialogue: 0,0:16:10.80,0:16:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Bukannya aku sangat mau dapat kiat\Nuntuk mendapat pasangan ilmuwan, ya.{\i0}
Dialogue: 0,0:16:14.68,0:16:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Luna…
Dialogue: 0,0:16:16.55,0:16:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebenarnya…
Dialogue: 0,0:16:22.10,0:16:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ruri.
Dialogue: 0,0:16:24.35,0:16:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku menyelesaikan proyek sains\Ngila ini, ayo kita menikah juga.
Dialogue: 0,0:16:30.65,0:16:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah…
Dialogue: 0,0:16:35.74,0:16:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}- Itu tak membantu sama sekali!{\i0}\N- Nona Luna!
Dialogue: 0,0:16:39.74,0:16:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Proyek sains gila"?
Dialogue: 0,0:16:46.04,0:16:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali sains membuat\Nkemajuan yang besar,
Dialogue: 0,0:16:48.67,0:16:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aturan dunia berubah secara drastis.
Dialogue: 0,0:16:52.38,0:16:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyoga, Xeno, dan aku
Dialogue: 0,0:16:55.38,0:16:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dulu mengotori tangan kami untuk\Nmencegah kembalinya aturan dunia lama.
Dialogue: 0,0:16:59.85,0:17:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang, tampaknya kemungkinan itu\Nterjadi hampir tak ada.
Dialogue: 0,0:17:05.23,0:17:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,
Dialogue: 0,0:17:06.85,0:17:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah kerangka hukum\Ndunia baru ditetapkan,
Dialogue: 0,0:17:10.36,0:17:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kitalah yang akan diadili.
Dialogue: 0,0:17:16.53,0:17:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tergantung bagaimana\Nhasil dari proyek tim sains,
Dialogue: 0,0:17:21.58,0:17:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada kemungkinan semuanya akan…
Dialogue: 0,0:17:26.46,0:17:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, yang kita bisa lakukan untuk
Dialogue: 0,0:17:28.54,0:17:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tim sains yang bekerja keras\Nadalah mengantar kue hari ini!
Dialogue: 0,0:17:31.25,0:17:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diantarkan secara pribadi oleh\Nmempelai pria dan wanita? Santai sekali.
Dialogue: 0,0:17:35.97,0:17:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku!
Dialogue: 0,0:17:40.26,0:17:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?
Dialogue: 0,0:17:42.51,0:17:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tim ilmuwan dari seluruh dunia\Nyang sedang mempelajari alat pembatuan.
Dialogue: 0,0:17:47.19,0:17:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ternyata orang asing.{\i0}
Dialogue: 0,0:17:49.52,0:17:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Materi memiliki massa
Dialogue: 0,0:17:50.86,0:17:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena sedang tenggelam\Ndalam "kolam" yang disebut Medan Higgs.
Dialogue: 0,0:17:55.11,0:17:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat pembatu adalah alat yang mengubah\Ntekanan air dari "kolam" tersebut.
Dialogue: 0,0:17:59.41,0:18:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa mengubah massa, atau beratnya,\Nmenjadi nol, materinya bisa mengapung.
Dialogue: 0,0:18:02.91,0:18:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meningkatkan jumlah hambatan\Nyang dialami suatu molekul dari
Dialogue: 0,0:18:06.00,0:18:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}medan Higgs akan berakibat pada pembatuan.
Dialogue: 0,0:18:07.71,0:18:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah…
Dialogue: 0,0:18:09.96,0:18:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sampai sekarang,\Nsaat Senku memberi penjelasan,{\i0}
Dialogue: 0,0:18:12.59,0:18:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ternyata dia memberi kami\Ntingkat yang mudah, ya?{\i0}
Dialogue: 0,0:18:18.47,0:18:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medu… Maksudku, Why-Man\Nyang dibawa dari bulan
Dialogue: 0,0:18:22.47,0:18:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya dibongkar dan dipelajari?
Dialogue: 0,0:18:25.02,0:18:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak.\NItu hanya salah satu dari yang rusak.
Dialogue: 0,0:18:29.19,0:18:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang masih hidup dan berharga\Nada di ruang belakang.
Dialogue: 0,0:18:33.23,0:18:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ruang proyek khusus\NDr. Senku dan timnya.
Dialogue: 0,0:18:37.78,0:18:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu untuk "proyek sains gila"\Nyang dibicarakan Chrome?
Dialogue: 0,0:18:43.95,0:18:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku, coba tebak!
Dialogue: 0,0:18:45.58,0:18:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah harinya!\NAku baru saja menikahi Yuzuriha!
Dialogue: 0,0:18:49.67,0:18:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin kau juga bilang begitu.
Dialogue: 0,0:18:54.59,0:18:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat amat menarik.
Dialogue: 0,0:18:57.92,0:19:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking kerasnya aku menyoraki kalian\Ndari lab ini, pita suaraku hampir putus.
Dialogue: 0,0:19:03.60,0:19:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita sudah berbicara begini?
Dialogue: 0,0:19:07.98,0:19:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Begitukah?\N- Semuanya dari tim sains,
Dialogue: 0,0:19:10.85,0:19:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- mari makan kue.\N- Asyik!
Dialogue: 0,0:19:14.94,0:19:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat yang tampak gila ini\Nadalah "proyek sains gila" itu?
Dialogue: 0,0:19:19.82,0:19:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Benar!\N- Kami sedang membuat hal yang luar biasa!
Dialogue: 0,0:19:24.28,0:19:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah terlihat keren?\NKami mulai dari desainnya.
Dialogue: 0,0:19:28.45,0:19:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya memamerkan\Nkemampuanku sebagai pengrajin.
Dialogue: 0,0:19:31.79,0:19:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita kembali ke masa lalu\Ndan mencegah invasi kami ke Bumi,
Dialogue: 0,0:19:35.79,0:19:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kaumku juga bisa mencegah\Njatuhnya banyak korban.
Dialogue: 0,0:19:39.21,0:19:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali ke masa lalu?
Dialogue: 0,0:19:41.59,0:19:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan…
Dialogue: 0,0:19:44.51,0:19:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil…
Dialogue: 0,0:19:47.89,0:19:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang membuat mesin waktu.
Dialogue: 0,0:19:57.90,0:20:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini abad ke-21,\Nkita pasti berpikir ini mustahil.
Dialogue: 0,0:20:02.70,0:20:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau…\NKalau ini memang bisa berhasil…
Dialogue: 0,0:20:07.95,0:20:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, kalau kita menembakkan\NSinar Pembatu ke masa lalu
Dialogue: 0,0:20:12.04,0:20:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membatukan para korban,
Dialogue: 0,0:20:15.50,0:20:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin kita bisa menyelamatkan mereka.
Dialogue: 0,0:20:18.67,0:20:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin
Dialogue: 0,0:20:21.01,0:20:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita sungguh bisa menyelamatkan\Ntujuh miliar umat manusia.
Dialogue: 0,0:20:34.81,0:20:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau setidaknya,\Nkita bisa mengirim informasi,
Dialogue: 0,0:20:36.98,0:20:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa mengirimkan AI untuk\Nmenyelamatkan umat manusia.
Dialogue: 0,0:20:39.82,0:20:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga pilihan. Bukankah itu elegan?
Dialogue: 0,0:20:46.37,0:20:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap sudut sains dimulai dari hasrat.
Dialogue: 0,0:20:48.66,0:20:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya dicemooh dan dikira "mustahil,"\Ntapi akhirnya jadi nyata. Apa aku salah?
Dialogue: 0,0:21:02.34,0:21:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan Senku…
Dialogue: 0,0:21:05.01,0:21:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan. Dengan seluruh umat manusia,\Nini sangat mungkin dicapai.
Dialogue: 0,0:21:09.47,0:21:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa membuat mesin waktu
Dialogue: 0,0:21:13.68,0:21:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedikit demi sedikit,\Nselangkah demi selangkah.
Dialogue: 0,0:21:17.44,0:21:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun puluhan tahun
Dialogue: 0,0:21:19.44,0:21:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau ratusan tahun berlalu…
Dialogue: 0,0:21:21.73,0:21:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, walaupun ribuan tahun berlalu…
Dialogue: 0,0:21:32.62,0:21:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan sains, akan kita taklukkan waktu
Dialogue: 0,0:21:36.83,0:21:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menemukan aturan baru\Nyang menguasai semesta ini.
Dialogue: 0,0:21:45.51,0:21:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggoda sekali!
Dialogue: 0,0:23:31.57,0:23:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku Ishigami.
Dialogue: 0,0:23:34.70,0:23:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmuwan yang membangun kembali\Nperadaban dari nol di Dunia Batu.
Dialogue: 0,0:23:40.46,0:23:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia baru yang sudah pulih,
Dialogue: 0,0:23:43.13,0:23:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang-orang memanggilnya
Dialogue: 0,0:23:47.34,0:23:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dr. Stone.
Dialogue: 0,0:24:00.93,0:24:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
