Dialogue: 0,0:01:04.43,0:01:09.02,tanda,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:03:06.01,0:03:06.93,tanda,,0000,0000,0000,,BATUAN MERAH - BAUKSIT, NATRIUM HIDROKSIDA
Dialogue: 0,0:03:06.93,0:03:07.85,tanda,,0000,0000,0000,,ALUMINA\NLISTRIK YANG SUNGGUH LUAR BIASA GILA
Dialogue: 0,0:03:07.85,0:03:08.77,tanda,,0000,0000,0000,,ALUMINIUM
Dialogue: 0,0:03:08.77,0:03:09.77,tanda,,0000,0000,0000,,FLUORIT
Dialogue: 0,0:03:09.77,0:03:10.68,tanda,,0000,0000,0000,,TEMBAGA, MAGNESIUM
Dialogue: 0,0:03:10.69,0:03:11.77,tanda,,0000,0000,0000,,DURALUMIN
Dialogue: 0,0:03:11.77,0:03:12.73,tanda,,0000,0000,0000,,ROKET
Dialogue: 0,0:05:58.27,0:06:01.69,tanda,,0000,0000,0000,,KOTA KARET DIDIRIKAN!
Dialogue: 0,0:09:18.05,0:09:20.81,tanda,,0000,0000,0000,,{\an8}BERAS DIPEROLEH!
Dialogue: 0,0:11:52.16,0:11:54.12,tanda,,0000,0000,0000,,FOSFORIT, ASAM NITRAT, ABU KAYU
Dialogue: 0,0:11:56.92,0:11:58.71,tanda,,0000,0000,0000,,KUAT!
Dialogue: 0,0:12:07.64,0:12:10.22,tanda,,0000,0000,0000,,{\an8}BERAS YANG MELIMPAH DIPEROLEH!
Dialogue: 0,0:20:23.13,0:20:25.80,tanda,,0000,0000,0000,,{\an8}SUSYI DIPEROLEH!
Dialogue: 0,0:23:53.14,0:23:55.97,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:55.97,0:23:57.18,tanda,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA,
Dialogue: 0,0:23:57.18,0:23:58.47,tanda,,0000,0000,0000,,MATERIAL, DAN METODENYA\NDIDASARKAN PADA KENYATAAN
Dialogue: 0,0:23:58.47,0:23:59.72,tanda,,0000,0000,0000,,MOHON JANGAN DICOBA
Dialogue: 0,0:23:59.72,0:24:00.98,tanda,,0000,0000,0000,,KARENA BISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:04.37,0:00:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bilang apa?
Dialogue: 0,0:00:08.80,0:00:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus belajar rahasia\Npembangunan roket, dimulai dari hal dasar.
Dialogue: 0,0:00:12.80,0:00:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus belajar macam-macam\Nrumus matematika yang rumit!
Dialogue: 0,0:00:19.22,0:00:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tolonglah, ajari kami berhitung.
Dialogue: 0,0:00:24.44,0:00:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar\Naku mengajar matematika di universitas
Dialogue: 0,0:00:27.48,0:00:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku tak memrogram, agar bisa makan…
Dialogue: 0,0:00:31.90,0:00:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mulai dari nol tak akan mudah.
Dialogue: 0,0:00:37.66,0:00:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua serius, 'kan?
Dialogue: 0,0:00:40.70,0:00:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Serius gila!
Dialogue: 0,0:00:43.96,0:00:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimanapun,{\i0}
Dialogue: 0,0:00:45.75,0:00:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sebelum Senku menyelesaikan\Nroket satu arah itu,{\i0}
Dialogue: 0,0:00:50.38,0:00:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kita harus mendahului dia\Ndan membangun roket pulang-pergi,{\i0}
Dialogue: 0,0:00:53.42,0:00:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}agar kita bisa merayakan kemenangan\Nkita bersama dan mendapat akhir bahagia!{\i0}
Dialogue: 0,0:02:39.90,0:02:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:02:41.66,0:02:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan semua itu agar bisa lari\Ndan tak perlu membangun komputer,
Dialogue: 0,0:02:45.54,0:02:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi membangun roket sama susahnya!
Dialogue: 0,0:02:48.41,0:02:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih agak bingung.
Dialogue: 0,0:02:51.83,0:02:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, kita bisa membuat
Dialogue: 0,0:02:54.17,0:02:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebuah roket dari bebatuan merah ini?
Dialogue: 0,0:02:56.71,0:02:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang perlu\Nproses pengolahan yang panjang.
Dialogue: 0,0:02:59.42,0:03:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini peta jalan kasar
Dialogue: 0,0:03:01.34,0:03:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal bagaimana kita akan membuat
Dialogue: 0,0:03:03.64,0:03:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}material untuk kerangka roketnya.
Dialogue: 0,0:03:14.69,0:03:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat sulit dan membingungkan,
Dialogue: 0,0:03:17.19,0:03:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku menjadi bersemangat!
Dialogue: 0,0:03:18.94,0:03:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:03:20.45,0:03:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, di sinilah kita akan memakai\Nfluorit yang kita dapat di Spanyol.
Dialogue: 0,0:03:23.70,0:03:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa,\Nprosesnya pasti akan sungguh lama…
Dialogue: 0,0:03:27.83,0:03:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi daripada itu… Apa ini?
Dialogue: 0,0:03:30.96,0:03:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}"Listrik yang sungguh luar biasa gila"?
Dialogue: 0,0:03:34.29,0:03:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:35.79,0:03:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada yang menyebut\Naluminium "listrik kalengan,"
Dialogue: 0,0:03:39.88,0:03:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena pembuatannya perlu\Ntenaga listrik dalam jumlah luar biasa.
Dialogue: 0,0:03:43.55,0:03:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya, saat mereka membuat\Naluminium untuk membangun Apollo,
Dialogue: 0,0:03:47.64,0:03:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tagihan listriknya saja\Nmencapai tiga miliar yen.
Dialogue: 0,0:03:54.23,0:03:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Dunia Batu ini,
Dialogue: 0,0:03:55.94,0:03:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memproduksi tenaga listrik
Dialogue: 0,0:03:58.23,0:04:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam jumlah yang sangat besar,\Nkita akan membutuhkan…
Dialogue: 0,0:04:01.65,0:04:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, pembangkit tenaga hidroelektrik.
Dialogue: 0,0:04:07.74,0:04:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka itu, kita harus membawa\Nbatuan merah dalam jumlah besar
Dialogue: 0,0:04:11.04,0:04:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke negara yang ideal\Nuntuk pembangkit tenaga hidroelektrik.
Dialogue: 0,0:04:14.46,0:04:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negara mana yang ideal\Nuntuk "tenaga air" ini?
Dialogue: 0,0:04:20.76,0:04:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya familier bagi kalian semua.
Dialogue: 0,0:04:23.13,0:04:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negeri dengan perbedaan elevasi\Nyang besar dan sungai di mana-mana.
Dialogue: 0,0:04:26.05,0:04:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali! Sudah ada markas\Nyang dibangun lengkap dengan sumber daya.
Dialogue: 0,0:04:30.77,0:04:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu tempat yang sangat cocok?
Dialogue: 0,0:04:38.06,0:04:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jepang!
Dialogue: 0,0:04:42.61,0:04:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kota di dunia akan bekerja sama…
Dialogue: 0,0:04:46.74,0:04:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, membawa semuanya ke tanah air kita
Dialogue: 0,0:04:50.03,0:04:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengumpulkan semuanya, ya?
Dialogue: 0,0:04:54.04,0:04:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan membangun roket kita di Jepang!
Dialogue: 0,0:05:14.14,0:05:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanan kita keliling dunia\Nuntuk mengumpulkan material roket kita…
Dialogue: 0,0:05:17.94,0:05:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah pemberhentian kita berikutnya…
Dialogue: 0,0:05:20.40,0:05:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini pemberhentian terakhir\Ndalam tur pembangunan kota kita
Dialogue: 0,0:05:24.57,0:05:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di seluruh dunia.
Dialogue: 0,0:05:26.28,0:05:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:05:27.61,0:05:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik! Mantap!
Dialogue: 0,0:05:31.16,0:05:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlihat!
Dialogue: 0,0:05:33.91,0:05:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kita ada di bawah khatulistiwa!
Dialogue: 0,0:05:37.12,0:05:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indonesia!
Dialogue: 0,0:05:44.51,0:05:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pohon karet di mana-mana! HAHA!
Dialogue: 0,0:05:46.76,0:05:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga mengumpulkan\Nsedikit di Amerika Latin,
Dialogue: 0,0:05:50.22,0:05:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku paham kenapa\Ntempat ini dikenal akan karetnya.
Dialogue: 0,0:05:53.81,0:05:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking senangnya aku sampai mau menangis.\NKita akan butuh banyak.
Dialogue: 0,0:06:04.69,0:06:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanannya memang panjang…
Dialogue: 0,0:06:07.70,0:06:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita berpamitan dengan Jepang,{\i0}
Dialogue: 0,0:06:09.86,0:06:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}melintasi Samudra Pasifik,\Ndan mendarat di Amerika.{\i0}
Dialogue: 0,0:06:14.20,0:06:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita sudah melalui berbagai rintangan{\i0}
Dialogue: 0,0:06:16.41,0:06:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan berhasil mendirikan Kota Jagung.{\i0}
Dialogue: 0,0:06:21.17,0:06:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dari situ, kita membangkitkan\Norang ke mana pun kita pergi,{\i0}
Dialogue: 0,0:06:24.96,0:06:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan Kota Aloi Super,{\i0}
Dialogue: 0,0:06:26.96,0:06:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kota Fluorit,{\i0}
Dialogue: 0,0:06:28.84,0:06:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kota Matematika dan Bahan Bakar,{\i0}
Dialogue: 0,0:06:31.22,0:06:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan Kota Aluminium sudah didirikan.{\i0}
Dialogue: 0,0:06:37.85,0:06:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang terakhir, kita mendirikan Kota Karet.{\i0}
Dialogue: 0,0:06:40.94,0:06:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, akhirnya,
Dialogue: 0,0:06:44.94,0:06:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan pulang dengan\Ngemilang ke tanah air kita, Jepang,
Dialogue: 0,0:06:47.90,0:06:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berkumpul kembali dengan semuanya!
Dialogue: 0,0:06:55.08,0:06:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya di seluruh dunia\Nbersatu dan bekerja sama.
Dialogue: 0,0:06:59.00,0:07:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini kali pertamanya\Nini terjadi dalam sejarah manusia.
Dialogue: 0,0:07:02.50,0:07:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul! "Semuanya bersama"!
Dialogue: 0,0:07:07.46,0:07:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita akan membuat roket pulang-pergi\Nagar semuanya bisa menang melawan{\i0}
Dialogue: 0,0:07:11.38,0:07:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Why-Man bersama-sama.{\i0}
Dialogue: 0,0:07:14.97,0:07:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kita membutuhkan semuanya,
Dialogue: 0,0:07:18.10,0:07:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kita akan segera bangkitkan\Nmereka dari pembatuan.
Dialogue: 0,0:07:21.48,0:07:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga, kita akan\Nmembangun roketnya di Jepang.
Dialogue: 0,0:07:24.23,0:07:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan butuh\Nsemuanya bekerja mati-matian.
Dialogue: 0,0:07:28.73,0:07:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau tak bisa sedikit lebih pengertian?
Dialogue: 0,0:07:32.45,0:07:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar memberi tahu\NRuri dan semuanya
Dialogue: 0,0:07:34.78,0:07:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sedang membatu kalau kita akan\Nsegera bebas dari situasi mengerikan ini.
Dialogue: 0,0:07:38.95,0:07:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada beban kerja mengerikan\Nyang menanti mereka.
Dialogue: 0,0:07:42.92,0:07:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya kita bisa membawa oleh-oleh\Ndari perjalanan kita keliling dunia.
Dialogue: 0,0:07:48.55,0:07:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah merencanakan itu.
Dialogue: 0,0:07:50.59,0:07:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Oleh-oleh?
Dialogue: 0,0:07:52.34,0:07:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik sekali.\NAku suka melihat semuanya sangat akur.
Dialogue: 0,0:07:54.93,0:07:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Senku bertingkah begini, dia selalu
Dialogue: 0,0:07:59.06,0:08:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}punya maksud tersembunyi.
Dialogue: 0,0:08:01.85,0:08:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal apa yang selalu\Nkita lakukan di kota-kota
Dialogue: 0,0:08:04.73,0:08:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kita dirikan di seluruh dunia?
Dialogue: 0,0:08:06.98,0:08:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita selalu memasak hidangan lokal\Nsegera setelah mendarat, 'kan?
Dialogue: 0,0:08:11.07,0:08:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Makanan rumahan akan membantu orang yang\Nbangkit mengerahkan seluruh tenaga mereka.{\i0}
Dialogue: 0,0:08:15.70,0:08:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar!
Dialogue: 0,0:08:17.49,0:08:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa memakan makanan yang kita kenal\Nbisa memengaruhi kinerja kita!
Dialogue: 0,0:08:22.71,0:08:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau membuat hidangan itu\Nkarena sekadar menginginkannya.
Dialogue: 0,0:08:25.96,0:08:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau aku, aku memang menginginkannya.\N- Kami tahu.
Dialogue: 0,0:08:30.17,0:08:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan rumahan dari Jepang…
Dialogue: 0,0:08:48.61,0:08:50.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sangat beruntung!
Dialogue: 0,0:08:50.73,0:08:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tiba tepat\Nsaat berasnya siap dipanen!
Dialogue: 0,0:08:55.11,0:08:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan soal keberuntungan.
Dialogue: 0,0:08:57.20,0:09:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mengandalkan keberuntungan,\NSenku pasti akan selalu kalah.
Dialogue: 0,0:09:01.70,0:09:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indonesia pasti dijadikan pilihan terakhir\Nagar kita bisa sampai pada bulan April,
Dialogue: 0,0:09:05.25,0:09:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat musim hujan berakhir\Ndan berasnya siap dipanen.
Dialogue: 0,0:09:22.10,0:09:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ini yang kita bisa dapatkan, ya?
Dialogue: 0,0:09:24.06,0:09:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yang mengherankan, jumlahnya sedikit.\N- Ya,
Dialogue: 0,0:09:27.19,0:09:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kita hanya memakai\Napa yang sudah ada di sini.
Dialogue: 0,0:09:30.57,0:09:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mulai sekarang, kita akan\Ngunakan sawah buatan manusia
Dialogue: 0,0:09:35.19,0:09:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan meningkatkan\Nproduksi kita dengan drastis!
Dialogue: 0,0:09:41.53,0:09:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah!
Dialogue: 0,0:09:45.91,0:09:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Selanjutnya!
Dialogue: 0,0:09:49.50,0:09:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:09:53.17,0:09:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, selama kalian tahu panjang\Ndari ketiga sisi segitiga,
Dialogue: 0,0:09:57.63,0:10:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian bisa menghitung luas wilayahnya.
Dialogue: 0,0:10:03.06,0:10:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dengan membaginya menjadi banyak segitiga,
Dialogue: 0,0:10:05.52,0:10:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}kita bisa mengukur luas wilayah
Dialogue: 0,0:10:07.27,0:10:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}lahan apa pun, seperti apa pun bentuknya.
Dialogue: 0,0:10:22.66,0:10:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit ke kanan lagi.
Dialogue: 0,0:10:27.54,0:10:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian bisa menggali\Nparit mengikuti garis ini?
Dialogue: 0,0:10:31.46,0:10:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah!
Dialogue: 0,0:10:39.22,0:10:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, sudah sempurna!
Dialogue: 0,0:10:59.65,0:11:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kukira kita tak boleh\Nlangsung menanam beras.
Dialogue: 0,0:11:04.62,0:11:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah biasanya harus\Nmenunggu tahun depan?
Dialogue: 0,0:11:06.49,0:11:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh miliar persen tak apa-apa.
Dialogue: 0,0:11:09.25,0:11:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini tak ada musim dingin.
Dialogue: 0,0:11:12.04,0:11:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Ya, kita ada di bawah khatulistiwa.
Dialogue: 0,0:11:16.50,0:11:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak paham.\NMana mungkin bisa tak ada musim dingin?
Dialogue: 0,0:11:21.13,0:11:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita lakukan tumpang sari, artinya kita\Nakan tanam dan panen tiga kali setahun,
Dialogue: 0,0:11:26.10,0:11:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan kekuatan sains.
Dialogue: 0,0:11:29.39,0:11:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah tanahnya melemah\Nsetelah setiap panen,
Dialogue: 0,0:11:31.77,0:11:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita hanya perlu\Nbangkitkan lagi dengan pupuk.
Dialogue: 0,0:11:35.06,0:11:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasrat bersifat mulia.
Dialogue: 0,0:11:39.15,0:11:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bukankah ini\Nbatu merah muda yang kita harus gali
Dialogue: 0,0:11:44.12,0:11:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di pulau aneh itu sebelum\Nkita sampai di Australia?
Dialogue: 0,0:11:47.74,0:11:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, fosforit dari Nauru terbuat\Ndari kotoran burung albatros.
Dialogue: 0,0:11:54.13,0:11:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini bisa dijadikan pupuk yang kuat.{\i0}
Dialogue: 0,0:12:13.52,0:12:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya, varian beras ini
Dialogue: 0,0:12:15.44,0:12:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengandung amilopektin yang relatif\Nlebih banyak dari beras indica biasa.
Dialogue: 0,0:12:18.94,0:12:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya itu lebih mirip\Ndengan beras Jepang. Karena itu…
Dialogue: 0,0:12:54.02,0:12:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa… Entah kenapa…
Dialogue: 0,0:12:58.48,0:13:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku juga tak makan\Nonigiri setiap hari
Dialogue: 0,0:13:02.82,0:13:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di abad ke-21…
Dialogue: 0,0:13:11.99,0:13:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada oleh-oleh yang akan menyenangkan\Nmereka lebih dari ini! Apa aku salah?
Dialogue: 0,0:13:15.54,0:13:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya kita kembali ke negeri asal kita.
Dialogue: 0,0:13:20.25,0:13:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke Jepang!
Dialogue: 0,0:13:47.28,0:13:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, Soyuz.\N- Senku!
Dialogue: 0,0:13:54.37,0:13:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohaku!
Dialogue: 0,0:13:57.50,0:13:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amaryllis!
Dialogue: 0,0:14:01.84,0:14:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kenapa ada om-om Jepang yang belum\Npernah kulihat sebelumnya di Pulau Harta?
Dialogue: 0,0:14:06.97,0:14:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kami memang "om-om Jepang."
Dialogue: 0,0:14:09.18,0:14:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?
Dialogue: 0,0:14:10.59,0:14:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau Senku yang terkenal itu, ya?
Dialogue: 0,0:14:13.39,0:14:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra-putraku sudah\Ncerita banyak tentang kau!
Dialogue: 0,0:14:19.98,0:14:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ada apa dengan orang-orang itu?
Dialogue: 0,0:14:22.52,0:14:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka punya misi spesial.
Dialogue: 0,0:14:25.86,0:14:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi spesial?
Dialogue: 0,0:14:27.95,0:14:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana perkembangannya?
Dialogue: 0,0:14:30.74,0:14:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:14:32.32,0:14:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bilang berjalan lancar,\Nkarena kami membatu…
Dialogue: 0,0:14:36.04,0:14:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pekerja dan material\Ndari daratan utama sangat membantu.
Dialogue: 0,0:14:39.25,0:14:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soyuz sudah bisa\Nberperan sebagai Master, ya?
Dialogue: 0,0:14:45.46,0:14:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu,
Dialogue: 0,0:14:46.88,0:14:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku khawatir pada Nona Ruri… Maksudku,\NRuri dan semuanya di daratan utama.
Dialogue: 0,0:14:51.39,0:14:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah mereka lebih besar, jadi aku\Ntak tahu kabar mereka setelah pembatuan.
Dialogue: 0,0:14:55.76,0:14:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, agar bisa menengok mereka,
Dialogue: 0,0:15:00.60,0:15:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari cepat pulang ke Jepang!
Dialogue: 0,0:15:03.77,0:15:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya orang-orang yang tak pergi\Njuga diberikan misi yang sulit.
Dialogue: 0,0:15:07.86,0:15:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sangat kesulitan,\Ntapi kurasa kita sama saja.
Dialogue: 0,0:15:10.91,0:15:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira mereka tak melakukan apa-apa,\Njadi aku iri pada mereka.
Dialogue: 0,0:15:16.16,0:15:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak.
Dialogue: 0,0:15:30.13,0:15:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sepuluh tahun sudah berlalu sejak\Npembatuan global oleh Medusa yang baru…{\i0}
Dialogue: 0,0:15:35.80,0:15:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Perjalanan keliling dunia kita\Nsudah selesai…{\i0}
Dialogue: 0,0:15:38.72,0:15:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saatnya pulang ke Jepang!{\i0}
Dialogue: 0,0:16:24.69,0:16:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohaku! Syukurlah kau baik-baik saja!
Dialogue: 0,0:16:28.11,0:16:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lebih mengkhawatirkan aku\Ndaripada dirimu sendiri?
Dialogue: 0,0:16:30.65,0:16:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar tak berubah, ya?
Dialogue: 0,0:16:32.40,0:16:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa cuma aku, atau kekuatan\Nlengan Ruri memang sungguh luar biasa?
Dialogue: 0,0:16:36.78,0:16:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga kakak\Ndari monster gorila bernama Kohaku itu.
Dialogue: 0,0:16:44.29,0:16:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya nostalgia.
Dialogue: 0,0:16:46.33,0:16:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu orang tumbang.
Dialogue: 0,0:16:50.25,0:16:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chrome!
Dialogue: 0,0:16:52.17,0:16:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila. Saat kau membatu,
Dialogue: 0,0:16:57.72,0:17:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri, aku sudah seumuran denganmu.
Dialogue: 0,0:17:03.48,0:17:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kau sudah sangat dewasa, Chrome.
Dialogue: 0,0:17:09.98,0:17:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:11.32,0:17:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begitu!
Dialogue: 0,0:17:13.44,0:17:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chrome dan Ruri saling menyukai…
Dialogue: 0,0:17:17.32,0:17:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar! Semua orang\Ndi desa kami menyukai Ruri!
Dialogue: 0,0:17:22.04,0:17:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Aku merasa terhormat…
Dialogue: 0,0:17:27.21,0:17:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, alasan hubungan\Nmereka tak berkembang
Dialogue: 0,0:17:30.17,0:17:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah karena Chrome\Nmasih kekanak-kanakan, ya.
Dialogue: 0,0:17:33.80,0:17:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usianya sudah dewasa,\Ntapi hatinya masih bocah, ya?
Dialogue: 0,0:17:36.84,0:17:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sebaiknya kita biarkan\NChelsea yang blak-blakan
Dialogue: 0,0:17:39.72,0:17:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengatakan semuanya saja?
Dialogue: 0,0:17:42.31,0:17:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Ruri, kau benar-benar hebat.
Dialogue: 0,0:17:44.81,0:17:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kau membangun\Npagar penahan angin batu yang gila ini?
Dialogue: 0,0:17:48.56,0:17:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada pohon\Ndan sebagainya terbang ke arah ini
Dialogue: 0,0:17:52.32,0:17:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merusak patung-patungnya,\Nhabislah sudah.
Dialogue: 0,0:17:56.61,0:17:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, tembok ini tak ada sebelumnya…
Dialogue: 0,0:17:59.99,0:18:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:18.26,0:18:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Chalk! Sagara!
Dialogue: 0,0:18:29.02,0:18:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga…\NChalk dan Sagara bukan manusia,
Dialogue: 0,0:18:33.36,0:18:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi mereka tak terpengaruh Sinar Pembatu.
Dialogue: 0,0:18:37.15,0:18:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bertahan hidup\Nselama sepuluh tahun. Luar biasa.
Dialogue: 0,0:18:49.79,0:18:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembok batu ini…
Dialogue: 0,0:18:52.54,0:18:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini…
Dialogue: 0,0:18:54.38,0:18:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini,\Nkalian sudah melindungi semuanya…
Dialogue: 0,0:19:06.60,0:19:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya… Kalian berdua sudah\Npunya keluarga masing-masing, ya?
Dialogue: 0,0:19:20.65,0:19:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal, Chalk, Sagara.
Dialogue: 0,0:19:30.04,0:19:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena kalian sudah\Nmembangunkan semua orang ini,
Dialogue: 0,0:19:33.21,0:19:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa makanan kita akan cukup?
Dialogue: 0,0:19:36.71,0:19:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah gunanya oleh-oleh dari kami!
Dialogue: 0,0:19:41.13,0:19:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Apa mereka kembali\Nhanya untuk makanan?
Dialogue: 0,0:19:44.55,0:19:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa ada\Nperpisahan manis nan pahit tadi?
Dialogue: 0,0:19:47.76,0:19:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah mereka hidup bersama kita,\Nmereka bisa bantu mencari bahan makanan.
Dialogue: 0,0:19:52.10,0:19:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau membantu semuanya,\Ndengan membuat hidangan nasi.
Dialogue: 0,0:19:56.06,0:19:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yaitu…\N- Apa?
Dialogue: 0,0:19:57.82,0:19:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak membuat onigiri?
Dialogue: 0,0:19:59.61,0:20:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sudah lupa?
Dialogue: 0,0:20:01.53,0:20:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa makanan rumahan ikonik\Ndari Jepang yang terbuat dari nasi?
Dialogue: 0,0:20:25.80,0:20:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lezatnya!
Dialogue: 0,0:20:31.27,0:20:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap ini bisa memotivasi semuanya untuk\Nbekerja keras dalam misi spesial mereka.
Dialogue: 0,0:20:35.65,0:20:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu? Orang-orang\Ndari Pulau Harta juga membicarakan itu.
Dialogue: 0,0:20:39.19,0:20:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, di daratan utama Jepang,
Dialogue: 0,0:20:42.03,0:20:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami juga mengerjakan proyek
Dialogue: 0,0:20:44.15,0:20:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang didesain oleh Senku,\Nsaat kalian semua menjelajahi dunia.
Dialogue: 0,0:20:53.87,0:20:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be… Bendungan?
Dialogue: 0,0:20:58.38,0:21:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini akan menghasilkan\Ntenaga hidroelektrik
Dialogue: 0,0:21:00.75,0:21:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang akan dipakai untuk membuat\Naluminium untuk kerangka roket, ya?
Dialogue: 0,0:21:04.68,0:21:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strukturnya luar biasa sederhana.
Dialogue: 0,0:21:07.26,0:21:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hanya perlu memblokir air\Ndengan beton.
Dialogue: 0,0:21:10.39,0:21:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, sebuah bendungan\Nyang dibangun pada 1.000 SM
Dialogue: 0,0:21:12.85,0:21:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih digunakan di abad ke-21.
Dialogue: 0,0:21:15.35,0:21:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chalk dan Sagara\Npasti melihat ini dan menirunya.
Dialogue: 0,0:21:20.86,0:21:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik sekali!
Dialogue: 0,0:21:23.78,0:21:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memasukkan bambu ke dalam batu?
Dialogue: 0,0:21:26.57,0:21:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini beton bertulang,\Ntapi kita memakai bambu.
Dialogue: 0,0:21:29.49,0:21:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendungan hanya perlu menahan\Ntekanan hidrolik, atau gaya dorong.
Dialogue: 0,0:21:34.00,0:21:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, menggunakan bambu\Ndengan sedikit besi beton sudah cukup.
Dialogue: 0,0:21:42.17,0:21:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang di seluruh dunia\Nsedang membuat komponen,
Dialogue: 0,0:21:45.34,0:21:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengumpulkan material…
Dialogue: 0,0:21:47.18,0:21:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Pulau Harta
Dialogue: 0,0:21:49.39,0:21:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memanfaatkan keuntungan geografisnya,\Nyaitu terletak dekat khatulistiwa…
Dialogue: 0,0:21:53.06,0:21:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hampir selesai! Misi spesial kami,\Nyaitu membangun situs peluncuran roket.
Dialogue: 0,0:21:59.23,0:22:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hanya punya satu musuh,\Nyaitu Why-Man yang misterius!
Dialogue: 0,0:22:02.52,0:22:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan pergi ke luar angkasa!
Dialogue: 0,0:22:06.11,0:22:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kerja sama\Ndari seluruh manusia di Bumi!
Dialogue: 0,0:22:11.20,0:22:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini menggiurkan!
Dialogue: 0,0:24:00.98,0:24:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
