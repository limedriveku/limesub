Dialogue: 0,0:01:40.68,0:01:43.52,sign,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:13:05.11,0:13:06.07,sign,,0000,0000,0000,,{\an8}RODA REAKSI
Dialogue: 0,0:17:36.18,0:17:38.30,sign,,0000,0000,0000,,TIGA HARI KEMUDIAN
Dialogue: 0,0:23:53.43,0:23:55.93,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:55.93,0:23:57.51,sign,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA,
Dialogue: 0,0:23:57.51,0:23:59.01,sign,,0000,0000,0000,,MATERIAL, DAN METODENYA\NDIDASARKAN PADA KENYATAAN
Dialogue: 0,0:23:59.02,0:24:00.93,sign,,0000,0000,0000,,MOHON JANGAN DICOBA KARENA\NBISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:12.09,0:00:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Hasrat" adalah tenaga penggerak sains.{\i0}
Dialogue: 0,0:00:18.26,0:00:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setiap kali ada hal baru yang dibuat,{\i0}
Dialogue: 0,0:00:21.22,0:00:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}itu membangun jalan\Nuntuk hal lainnya di masa depan.{\i0}
Dialogue: 0,0:00:27.02,0:00:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau kau bersungguh-sungguh,\Nkau bisa mewujudkan apa pun{\i0}
Dialogue: 0,0:00:31.11,0:00:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}melalui penerapan sains yang tekun.{\i0}
Dialogue: 0,0:00:34.86,0:00:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita bisa membangun peradaban dari nol\Ndan menyelamatkan seluruh umat manusia.{\i0}
Dialogue: 0,0:00:41.87,0:00:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Senku, Ayah tahu kau bisa melakukannya.{\i0}
Dialogue: 0,0:00:48.50,0:00:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Umat manusia akan kembali pada titik\Nkita makan ramen di luar angkasa.{\i0}
Dialogue: 0,0:00:54.22,0:00:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pasti!{\i0}
Dialogue: 0,0:01:33.21,0:01:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sendirian, di luar angkasa…{\i0}
Dialogue: 0,0:03:15.48,0:03:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa hanya aku yang dibangkitkan?{\i0}
Dialogue: 0,0:03:18.44,0:03:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita perlu pilot kita, Stanley,\Nuntuk melakukan proses doking.{\i0}
Dialogue: 0,0:03:21.57,0:03:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa Arloji Pembangkitnya\Nmengalami malafungsi?{\i0}
Dialogue: 0,0:03:24.16,0:03:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selamat pagi, Senku.\NSekarang kau sudah bangkit, 'kan?{\i0}
Dialogue: 0,0:03:30.29,0:03:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bukan malafungsi?\NXeno, ini perbuatanmu?
Dialogue: 0,0:03:36.54,0:03:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam lingkungan tanpa bobot,
Dialogue: 0,0:03:38.84,0:03:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cairan tak bisa mengalir.
Dialogue: 0,0:03:40.97,0:03:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kemungkinan cairan pembangkit\Ntak akan berfungsi,
Dialogue: 0,0:03:45.43,0:03:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi untuk jaga-jaga,\Naku membangkitkanmu lebih dulu, Senku.
Dialogue: 0,0:03:48.81,0:03:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya!
Dialogue: 0,0:03:50.52,0:03:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau bisa…
Dialogue: 0,0:03:56.94,0:04:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ya sudah… Baiklah, terserah kau saja.
Dialogue: 0,0:04:03.99,0:04:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Toh, dulu Xeno{\i0}
Dialogue: 0,0:04:05.99,0:04:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah teman Byakuya dan krunya.{\i0}
Dialogue: 0,0:04:09.79,0:04:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pasti dia mau memberi Senku{\i0}
Dialogue: 0,0:04:12.46,0:04:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sedikit waktu pribadi di luar angkasa\Ndan dia bisa menangis sendirian.{\i0}
Dialogue: 0,0:04:33.35,0:04:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan tak terkejut\Nmelihatku sudah bangkit.
Dialogue: 0,0:04:36.52,0:04:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stanley, kau tahu soal ini, 'kan?
Dialogue: 0,0:04:39.90,0:04:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua orang tua\Nyang berusaha pengertian, ya?
Dialogue: 0,0:04:43.44,0:04:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menjadi merasa geli.
Dialogue: 0,0:04:47.07,0:04:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Berusaha pengertian"?\NJangan naif begitu, Senku.
Dialogue: 0,0:04:51.16,0:04:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah seorang prajurit.\NAku hanya menjalankan misiku.
Dialogue: 0,0:04:57.17,0:04:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, terserah kau saja.
Dialogue: 0,0:05:00.50,0:05:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, di abad ke-20,
Dialogue: 0,0:05:02.55,0:05:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka merancang\Nsejumlah kapal antariksa tanpa jendela.
Dialogue: 0,0:05:06.30,0:05:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi para pilot justru memboikotnya,\Nsetidaknya begitulah kabarnya.
Dialogue: 0,0:05:10.14,0:05:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat luar angkasa dengan mata telanjang
Dialogue: 0,0:05:12.39,0:05:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepenting itu untuk\Nkesehatan mental para astronaut.
Dialogue: 0,0:05:16.44,0:05:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana persediaan oksigen kita?
Dialogue: 0,0:05:18.98,0:05:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Banyak yang tak kita ketahui soal\Nproses doking bagian kapal antariksa,{\i0}
Dialogue: 0,0:05:22.28,0:05:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}jadi kami memberi kalian lebih dari cukup.{\i0}
Dialogue: 0,0:05:25.32,0:05:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malahan, kalian bisa\Nmembangkitkan satu orang lagi.
Dialogue: 0,0:05:36.58,0:05:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini… Ini "luar angkasa"?
Dialogue: 0,0:05:41.34,0:05:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada "atas" atau "bawah"!\NTubuhku juga terasa sangat ringan!
Dialogue: 0,0:05:45.63,0:05:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah, Singa Betina.
Dialogue: 0,0:05:54.97,0:05:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ramen luar angkasa buatan Francois
Dialogue: 0,0:05:57.14,0:06:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dikemas dalam vinil.
Dialogue: 0,0:06:04.78,0:06:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lezat sekali!
Dialogue: 0,0:06:07.53,0:06:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini makanan astronaut abad ke-21\Ndi Stasiun Antariksa Internasional.
Dialogue: 0,0:06:14.37,0:06:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ribuan tahun lalu, ayahmu,
Dialogue: 0,0:06:17.96,0:06:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byakuya, juga makan ini, ya?
Dialogue: 0,0:06:20.33,0:06:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita makan makanan yang sama,\Ndi luar angkasa yang sama.
Dialogue: 0,0:06:25.09,0:06:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa "stasiun antariksa"\Natau apalah itu tempat mereka tinggal,
Dialogue: 0,0:06:28.38,0:06:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih mengapung di luar angkasa?
Dialogue: 0,0:06:31.68,0:06:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:06:33.10,0:06:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa ada yang mengendalikannya,
Dialogue: 0,0:06:35.93,0:06:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}stasiun itu pasti sudah meluncur\Nseperti bintang jatuh ribuan tahun lalu.
Dialogue: 0,0:06:41.85,0:06:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya…
Dialogue: 0,0:06:45.15,0:06:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:47.61,0:06:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingat apa kata kami?\NStasiun antariksa itu
Dialogue: 0,0:06:51.24,0:06:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga diluncurkan dalam beberapa bagian\Ndan disambungkan di luar angkasa.
Dialogue: 0,0:06:56.08,0:06:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, giliran kita membuat
Dialogue: 0,0:06:59.50,0:07:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}produk peradaban dengan menggunakan
Dialogue: 0,0:07:02.17,0:07:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sains luar angkasa Dunia Batu,
Dialogue: 0,0:07:04.50,0:07:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan menyambungkan semua bagiannya\Ndan meninggalkan Bumi yang kecil ini.
Dialogue: 0,0:07:25.44,0:07:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, Stanley!
Dialogue: 0,0:07:27.98,0:07:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berhasil menyambungkan\Nporos kedua kapal
Dialogue: 0,0:07:30.74,0:07:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di luar angkasa,\Ndi mana atas dan bawah tak terasa!
Dialogue: 0,0:07:33.87,0:07:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih terlalu cepat untuk merayakan.\NKita baru menyambungkan dua modul.
Dialogue: 0,0:07:37.87,0:07:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sampai\Nkita menyambungkan kelima modul.
Dialogue: 0,0:07:41.50,0:07:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, kita berhasil.
Dialogue: 0,0:07:44.21,0:07:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sepuluh miliar persen berhasil.{\i0}
Dialogue: 0,0:07:47.25,0:07:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:07:51.01,0:07:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lebih senang lagi!\NKau selalu saja santai, Senku.
Dialogue: 0,0:07:54.80,0:07:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu karena\Nreaksi dari tim darat agak kurang.
Dialogue: 0,0:07:59.97,0:08:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berhasil, Senku!
Dialogue: 0,0:08:02.39,0:08:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira saat ini Taiju akan menangis hebat
Dialogue: 0,0:08:05.90,0:08:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjerit sangat kencang.
Dialogue: 0,0:08:09.23,0:08:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa dengar\Nteriakannya yang gila sekarang?
Dialogue: 0,0:08:13.20,0:08:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda.
Dialogue: 0,0:08:17.41,0:08:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Kita tak bisa\Nmendengar apa pun lewat radio?{\i0}
Dialogue: 0,0:08:30.67,0:08:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Modul ketiga sedang menuju ke sini!
Dialogue: 0,0:08:33.01,0:08:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, itu penglihatan 20/20-mu\Nyang terkenal itu, ya? Boleh juga.{\i0}
Dialogue: 0,0:08:37.47,0:08:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal penglihatan,\Nserahkan saja padaku!
Dialogue: 0,0:08:43.06,0:08:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya monitor dokingnya juga…
Dialogue: 0,0:08:46.94,0:08:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!\NAku memegangnya terlalu keras!
Dialogue: 0,0:08:50.23,0:08:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, Kohaku. Itu bukan gara-gara kau.
Dialogue: 0,0:08:54.28,0:08:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ada masalah dengan\Nsistem kelistrikan kapal antariksa ini.
Dialogue: 0,0:09:03.16,0:09:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Separuh layarnya tak terlihat.
Dialogue: 0,0:09:05.92,0:09:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, bagaimana kita bisa\Nmenyambungkan modul ketiga?
Dialogue: 0,0:09:09.17,0:09:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stanley, apa kau bisa melakukannya\Ndengan keahlianmu saja?
Dialogue: 0,0:09:16.51,0:09:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku bisa.
Dialogue: 0,0:09:37.11,0:09:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sial… Hal seremeh ini!
Dialogue: 0,0:09:43.54,0:09:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batangan tipis apa itu?
Dialogue: 0,0:09:46.16,0:09:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu pecahan batu?
Dialogue: 0,0:09:48.17,0:09:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu satu helai rambut manusia.
Dialogue: 0,0:09:52.13,0:09:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal sudah tersangkut dalam sirkuit.
Dialogue: 0,0:09:55.80,0:09:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sehelai rambut bisa\Ntiba-tiba membatu?
Dialogue: 0,0:10:04.81,0:10:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima meter, satu detik.
Dialogue: 0,0:10:07.89,0:10:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terjadi saat kita\Nmenggunakan Sinar Pembatu
Dialogue: 0,0:10:11.19,0:10:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dalam roket sebelum peluncuran…
Dialogue: 0,0:10:14.57,0:10:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uji coba berulang kali.\NItulah cara bagaimana sains berkembang.
Dialogue: 0,0:10:19.57,0:10:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kita membatukan diri\Nsebelum masuk ke dalam roket.
Dialogue: 0,0:10:24.16,0:10:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyebab kegagalan selalu terlihat jelas\Nsetelah kita melihat ke belakang.
Dialogue: 0,0:10:35.71,0:10:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monitor dokingnya tak menunjukkan apa pun!
Dialogue: 0,0:10:51.19,0:10:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Modul keempat mendekat.\NApa bisa diperbaiki?
Dialogue: 0,0:10:55.57,0:11:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapasitornya hangus.\NAku tak tahu apa saja yang terdampak.
Dialogue: 0,0:11:00.78,0:11:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus ganti\Nseluruh sirkuit distribusi tenaga.
Dialogue: 0,0:11:04.70,0:11:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sudah pasti kita tak akan\Nmenemukan penggantinya di luar angkasa.
Dialogue: 0,0:11:15.29,0:11:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mustahil!
Dialogue: 0,0:11:17.46,0:11:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa\Nmenyambungkan dua poros kapal
Dialogue: 0,0:11:19.97,0:11:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam keadaan gelap gulita, tanpa kamera.
Dialogue: 0,0:11:29.85,0:11:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi? Barusan, kukira
Dialogue: 0,0:11:32.60,0:11:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku melihat modul keempat\Nyang tak memiliki awak bergerak sendiri.
Dialogue: 0,0:11:37.69,0:11:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, mungkin
Dialogue: 0,0:11:40.28,0:11:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada orang di dalam sana.
Dialogue: 0,0:11:43.66,0:11:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Modul keempat adalah modul lunar,
Dialogue: 0,0:11:46.45,0:11:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi secara teknis,\Nseseorang bisa masuk ke dalamnya.
Dialogue: 0,0:11:50.08,0:11:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang seceroboh itu?
Dialogue: 0,0:11:53.96,0:11:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hanya ada satu orang\Ndi seluruh Dunia Batu ini
Dialogue: 0,0:11:58.00,0:12:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sepuluh miliar persen\Ncukup bodoh untuk melakukan hal itu.
Dialogue: 0,0:12:04.55,0:12:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku ada di sini!\NAlam semesta akan menjadi milikku!
Dialogue: 0,0:12:21.40,0:12:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Akhirnya aku ada di sini!\NAlam semesta akan menjadi milikku!{\i0}
Dialogue: 0,0:12:26.70,0:12:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kata-kata pertamanya di luar angkasa?\NBegitulah Ryusui…
Dialogue: 0,0:12:31.62,0:12:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka akan sadar kalau Ryusui\Nyang akan melakukan proses doking?
Dialogue: 0,0:12:36.08,0:12:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa mendengar mereka lewat radio,
Dialogue: 0,0:12:38.25,0:12:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kru Senku tak bisa\Nmendengar kita, 'kan?
Dialogue: 0,0:12:40.67,0:12:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir. Mereka bertiga\Nadalah astronaut paling elegan di dunia.
Dialogue: 0,0:12:48.26,0:12:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berusaha menyambungkan\Ndari modul keempat akan sangat sulit.
Dialogue: 0,0:12:52.98,0:12:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, soalnya modul itu\Ntak memiliki roda reaksi.
Dialogue: 0,0:12:56.81,0:12:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rea… Roda?
Dialogue: 0,0:12:59.40,0:13:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah mesin yang memutar\Nroda di dalam kapal antariksa
Dialogue: 0,0:13:02.78,0:13:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}untuk mendapat kontrol posisi\Ndengan efek giroskopik.
Dialogue: 0,0:13:06.07,0:13:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan mustahil
Dialogue: 0,0:13:07.78,0:13:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengendalikannya secara paksa\Ndengan memacu mesinnya,
Dialogue: 0,0:13:11.62,0:13:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi itu akan menghabiskan bahan bakar.
Dialogue: 0,0:13:17.46,0:13:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku bisa melihatnya…
Dialogue: 0,0:13:19.88,0:13:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusui sedang menyesuaikan\Norientasi modulnya.
Dialogue: 0,0:13:23.84,0:13:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membuat mesin pengendali posisi\Ndi saat terakhir, Xeno?
Dialogue: 0,0:13:28.43,0:13:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu tak akan mungkin.
Dialogue: 0,0:13:31.89,0:13:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengendalikan wahana antariksa\Ndi luar angkasa
Dialogue: 0,0:13:34.89,0:13:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa menggunakan roda reaksi…\NBagaimana cara Ryusui melakukannya?
Dialogue: 0,0:13:43.07,0:13:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau yang kau inginkan tak ada,\Nbuat saja sendiri! Apa aku salah?
Dialogue: 0,0:13:46.61,0:13:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri yang akan menjadi roda gila!\NAku adalah roda reaksi manusia!
Dialogue: 0,0:13:52.33,0:13:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking tamaknya, dia menjadi gila!
Dialogue: 0,0:13:56.12,0:13:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sungguh gila.
Dialogue: 0,0:14:17.06,0:14:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh luar biasa.
Dialogue: 0,0:14:19.06,0:14:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah semua itu, pada akhirnya\NRyusui tetap pergi ke luar angkasa.
Dialogue: 0,0:14:23.11,0:14:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang beruntung.
Dialogue: 0,0:14:26.19,0:14:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi aku yakin sebenarnya
Dialogue: 0,0:14:28.28,0:14:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak sesederhana mengandalkan\Nhal supernatural seperti itu.
Dialogue: 0,0:14:32.32,0:14:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Untuk berjaga-jaga\Nkalau hal seperti ini terjadi,
Dialogue: 0,0:14:36.20,0:14:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ryusui melanjutkan\Npelatihannya yang keras
Dialogue: 0,0:14:39.08,0:14:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan setelah diputuskan kalau dia\Ntak akan ikut masuk ke dalam roket.
Dialogue: 0,0:14:44.17,0:14:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasrat bersifat mulia!
Dialogue: 0,0:14:49.43,0:14:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benda yang hangus dan rusak…
Dialogue: 0,0:14:52.64,0:14:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sirkuit distribusi tenaga.
Dialogue: 0,0:14:58.64,0:15:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:15:00.73,0:15:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa memperbaikinya dengan\Nmengganti suku cadangnya. Kerja bagus,
Dialogue: 0,0:15:04.40,0:15:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tim pendukung kendali darat.
Dialogue: 0,0:15:08.49,0:15:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu hadiah yang elegan?
Dialogue: 0,0:15:11.28,0:15:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, kami bisa mendengar suara kalian.
Dialogue: 0,0:15:16.45,0:15:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini berarti…
Dialogue: 0,0:15:17.83,0:15:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ryusui akan tetap di sana…
Dialogue: 0,0:15:20.00,0:15:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Lalu, ikut mereka ke Bulan? Gila!
Dialogue: 0,0:15:23.58,0:15:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku membatukan diri\Ndan menjadi sepotong kargo,
Dialogue: 0,0:15:26.80,0:15:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak akan ada dampaknya\Npada sistem penunjang hidup.
Dialogue: 0,0:15:29.38,0:15:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau hanya akan memakan tempat.
Dialogue: 0,0:15:32.55,0:15:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku harus\Nmenghitung ulang semuanya dari nol.
Dialogue: 0,0:15:45.81,0:15:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Proses doking sudah selesai.
Dialogue: 0,0:15:52.91,0:15:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya kita meluncur…
Dialogue: 0,0:16:02.96,0:16:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menuju Bulan.
Dialogue: 0,0:16:11.34,0:16:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk perjalanan mereka ke Bulan,
Dialogue: 0,0:16:13.38,0:16:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan pindahkan pusat kendali\Ndari Pulau Harta ke Kerajaan Sains.
Dialogue: 0,0:16:17.93,0:16:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menggunakan\Nsistem navigasi yang ada di sini.
Dialogue: 0,0:16:23.94,0:16:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mengirim gelombang\Nelektromagnetik bolak-balik ke kapal,
Dialogue: 0,0:16:26.94,0:16:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa mengukur jaraknya\Nberdasarkan waktu transmisi.
Dialogue: 0,0:16:31.40,0:16:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya itu, tapi berkat efek Doppler,
Dialogue: 0,0:16:34.15,0:16:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita juga bisa menghitung kecepatan kapal.
Dialogue: 0,0:16:36.41,0:16:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek Doppelganger?
Dialogue: 0,0:16:38.45,0:16:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ada ambulans yang mendekat,
Dialogue: 0,0:16:40.20,0:16:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bunyinya seperti, "ni-nu ni-nu,"\Ntapi setelah melewatimu
Dialogue: 0,0:16:43.58,0:16:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}talanya turun menjadi,\N"wi-wo wi-wo," 'kan?
Dialogue: 0,0:16:46.88,0:16:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya efek Doppler!
Dialogue: 0,0:16:49.38,0:16:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan mengetahui posisi\Ndan kecepatan mereka, kita bisa melacak{\i0}
Dialogue: 0,0:16:53.17,0:16:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Senku dan semuanya dengan tepat,\Nwalaupun mereka sangat jauh.{\i0}
Dialogue: 0,0:16:57.14,0:16:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang elektromagnetik muncul lagi.
Dialogue: 0,0:16:59.93,0:17:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat berguna, ya?
Dialogue: 0,0:17:01.77,0:17:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita memakainya\Nuntuk ponsel dan microwave juga.
Dialogue: 0,0:17:05.56,0:17:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, Senku dan yang lain sedang\Nmelaju dengan kecepatan 38.000 km/jam.
Dialogue: 0,0:17:10.65,0:17:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga puluh apa?
Dialogue: 0,0:17:11.78,0:17:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesawat melaju dengan\Nkecepatan sekitar 100 km/jam, 'kan?
Dialogue: 0,0:17:15.82,0:17:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal antariksa memang kendaraan tercepat\Nyang diciptakan oleh manusia.
Dialogue: 0,0:17:59.70,0:18:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu Bulan… Bulan yang asli…{\i0}
Dialogue: 0,0:18:03.79,0:18:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita sangat dekat…{\i0}
Dialogue: 0,0:18:10.58,0:18:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekstan di kapal antariksa?
Dialogue: 0,0:18:13.38,0:18:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat yang digunakan\Nuntuk memastikan lokasi kita di laut?
Dialogue: 0,0:18:16.17,0:18:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:18:17.42,0:18:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir mereka juga bisa\Nmenggunakan ini di luar angkasa,
Dialogue: 0,0:18:20.34,0:18:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memastikan lokasi mereka\Nrelatif terhadap posisi bintang!
Dialogue: 0,0:18:23.56,0:18:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ide cemerlang Chrome!
Dialogue: 0,0:18:25.68,0:18:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Suika yang memikirkannya.
Dialogue: 0,0:18:27.43,0:18:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu penemuan oleh\Nduo ilmuwan ahli pemula!
Dialogue: 0,0:18:30.52,0:18:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah teknologi rendah elegan\Nyang bahkan digunakan
Dialogue: 0,0:18:33.32,0:18:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam wahana antariksa Apollo pertama.
Dialogue: 0,0:18:35.61,0:18:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja sudah ditemukan!
Dialogue: 0,0:18:37.36,0:18:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini luar biasa.
Dialogue: 0,0:18:38.78,0:18:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka kita bisa bernavigasi\Nke Bulan dengan alat primitif ini.
Dialogue: 0,0:18:42.91,0:18:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat penting di sisi jauh Bulan,
Dialogue: 0,0:18:45.58,0:18:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ketika komunikasi dengan Bumi\Nakan terpotong. Mulai titik itu,
Dialogue: 0,0:18:49.08,0:18:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tak punya pilihan\Nselain mengandalkan
Dialogue: 0,0:18:52.00,0:18:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mata dan perhitungan mereka\Nuntuk mengarungi semesta yang luas.
Dialogue: 0,0:18:57.13,0:18:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini sisi jauh Bulan?
Dialogue: 0,0:18:59.93,0:19:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permukaannya sangat tak rata!
Dialogue: 0,0:19:01.59,0:19:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya,
Dialogue: 0,0:19:02.80,0:19:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sisi Bulan yang sama\Nselalu menghadap Bumi.
Dialogue: 0,0:19:05.97,0:19:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi Bulan yang lain\Ntampak luar biasa berantakan.
Dialogue: 0,0:19:09.10,0:19:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sisa-sisa meteorit
Dialogue: 0,0:19:11.60,0:19:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diadang berkali-kali oleh Bulan.
Dialogue: 0,0:19:17.65,0:19:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita semua yang tinggal di Bumi
Dialogue: 0,0:19:20.07,0:19:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dilindungi oleh Bulan sejak dulu,\Ntanpa kita ketahui.
Dialogue: 0,0:19:26.20,0:19:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang soal anggota yang akan\Nmendarat di Bulan pelindung kita.
Dialogue: 0,0:19:30.41,0:19:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau-kalau terjadi hal buruk\Ndan kita tak bisa pulang,
Dialogue: 0,0:19:33.79,0:19:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}modul lunar ini muat untuk tiga orang.
Dialogue: 0,0:19:37.21,0:19:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya, sebagai ahli sains, aku akan tetap…\N- Tidak.
Dialogue: 0,0:19:42.18,0:19:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan tetap di modul kendali.
Dialogue: 0,0:19:44.68,0:19:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai ilmuwan dunia baru\Nyang mewakili Dunia Batu,
Dialogue: 0,0:19:48.43,0:19:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku, kau harus mendarat di Bulan.
Dialogue: 0,0:19:54.40,0:19:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ryusui, kukira kau mau\Nkehormatan mendarat di Bulan.
Dialogue: 0,0:20:00.36,0:20:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jangan lupa, aku pelaut.
Dialogue: 0,0:20:02.32,0:20:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga orang akan mendarat di Bulan.
Dialogue: 0,0:20:04.20,0:20:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu orang akan menjalankan modul kendali.
Dialogue: 0,0:20:06.74,0:20:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya menarik, tapi kalau bisa memilih,\Naku pilih piala yang tak ada duanya.
Dialogue: 0,0:20:11.58,0:20:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah?
Dialogue: 0,0:20:17.84,0:20:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, terserah kau saja.
Dialogue: 0,0:20:34.48,0:20:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kau menginjakkan kaki di Bulan,
Dialogue: 0,0:20:37.19,0:20:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kata-kata pertamamu\Nuntuk semuanya di Bumi?
Dialogue: 0,0:20:45.28,0:20:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, tapi ada kalimat luar biasa\Nyang tiba-tiba terpikirkan olehku!
Dialogue: 0,0:20:50.66,0:20:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Satu langkah kecil bagi satu orang,
Dialogue: 0,0:20:52.96,0:20:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}satu lompatan besar bagi umat manusia."
Dialogue: 0,0:20:56.21,0:20:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, gila! Kedengarannya keren sekali!
Dialogue: 0,0:20:59.42,0:21:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kata-kata pertama yang diucapkan
Dialogue: 0,0:21:02.30,0:21:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh Armstrong, orang pertama\Nyang berjalan di Bulan.
Dialogue: 0,0:21:04.93,0:21:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:21:06.76,0:21:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja tiba-tiba muncul di kepalaku!
Dialogue: 0,0:21:10.76,0:21:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata-kata pertamamu harus sederhana!\N"Bulan itu gila!"
Dialogue: 0,0:21:14.94,0:21:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Semua gadis imut di dunia,\Naku lajang dan sedang mencari pasangan."
Dialogue: 0,0:21:18.40,0:21:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Trofi didapatkan!\NPendaratan Pertama di Bulan."
Dialogue: 0,0:21:21.57,0:21:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian malah bercanda.
Dialogue: 0,0:21:25.49,0:21:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa kalian sudah memikirkan sesuatu?
Dialogue: 0,0:21:30.49,0:21:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terpikir saja tidak.
Dialogue: 0,0:21:32.66,0:21:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tentu saja…{\i0}
Dialogue: 0,0:21:37.50,0:21:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau begitu,
Dialogue: 0,0:21:39.54,0:21:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makna di balik pendaratan di Bulan kita\Nberbeda dengan abad ke-20.
Dialogue: 0,0:21:46.47,0:21:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak bisa menang melawan Why-Man,\Numat manusia akan dibantai habis.
Dialogue: 0,0:21:51.47,0:21:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menang melawan Why-Man,\Nrahasia pembatuan menjadi milik kita.
Dialogue: 0,0:21:59.02,0:22:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dengan masa depan manusia sebagai taruhan,\Nkita melangkah menuju sains yang baru.
Dialogue: 0,0:22:05.86,0:22:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lompatan perjuangan habis-habisan!
Dialogue: 0,0:22:11.07,0:22:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini menggoda sekali!
Dialogue: 0,0:24:00.93,0:24:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
