Dialogue: 0,0:00:27.06,0:00:29.55,tanda,,0000,0000,0000,,DR. XENO TELAH BERGABUNG DENGAN TIM!
Dialogue: 0,0:00:49.54,0:00:50.70,tanda,,0000,0000,0000,,GEDEBUK
Dialogue: 0,0:02:15.13,0:02:16.10,tanda,,0000,0000,0000,,BIJIH ILMENIT - MOLIBDENIT - BIJIH KROM
Dialogue: 0,0:03:54.90,0:03:56.42,tanda,,0000,0000,0000,,SUPERALLOY
Dialogue: 0,0:04:20.17,0:04:21.82,tanda,,0000,0000,0000,,GYAAAAAAAAH!
Dialogue: 0,0:04:38.19,0:04:40.59,tanda,,0000,0000,0000,,MENDAPATKAN STAINLESS STEEL
Dialogue: 0,0:04:53.23,0:04:54.97,tanda,,0000,0000,0000,,STAINLESS STEEL
Dialogue: 0,0:05:22.93,0:05:23.80,tanda,,0000,0000,0000,,STAINLESS STEEL
Dialogue: 0,0:08:41.17,0:08:44.37,tanda,,0000,0000,0000,,KOTA SUPERALLOY DIDIRIKAN!
Dialogue: 0,0:13:08.14,0:13:08.74,tanda,,0000,0000,0000,,NIKEL - KROM - MOLIBDENUM - BESI -\NTITANIUM - NIOBIUM
Dialogue: 0,0:13:44.32,0:13:48.03,tanda,,0000,0000,0000,,BULAN MARET
Dialogue: 0,0:13:48.03,0:13:54.54,tanda,,0000,0000,0000,,BULAN APRIL
Dialogue: 0,0:13:54.54,0:13:58.23,tanda,,0000,0000,0000,,BULAN MEI
Dialogue: 0,0:14:36.62,0:14:39.23,tanda,,0000,0000,0000,,DAPAT MESIN ROKET LV. 1
Dialogue: 0,0:17:05.52,0:17:08.33,tanda,,0000,0000,0000,,DAPAT NEW PERSEUS
Dialogue: 0,0:18:23.81,0:18:25.79,tanda,,0000,0000,0000,,WAKTU MENYEBERANGI ATLANTIK: 1 MINGGU
Dialogue: 0,0:18:59.00,0:18:59.50,tanda,,0000,0000,0000,,DAPAT AC
Dialogue: 0,0:21:43.11,0:21:45.65,tanda,,0000,0000,0000,,D-O...
Dialogue: 0,0:21:46.91,0:21:50.62,tanda,,0000,0000,0000,,Y-O-U...
Dialogue: 0,0:23:52.05,0:23:55.03,tanda,,0000,0000,0000,,EPISODE BERIKUTNYA: API
Dialogue: 0,0:23:55.03,0:23:58.10,tanda,,0000,0000,0000,,KARYA INI MURNI BERSIFAT FIKSI. HEWAN, TUMBUHAN,\NBENDA, DAN METODE PEMBUATAN YANG MUNCUL ITU NYATA.
Dialogue: 0,0:23:58.10,0:24:01.93,tanda,,0000,0000,0000,,JANGAN MENGAMBIL ATAU MEMBUAT ATAS PENILAIAN PRIBADI, BISA\NBERBAHAYA. SELAIN ITU, BISA MELANGGAR HUKUM, JADI JANGAN DITIRU.
Dialogue: 0,0:00:01.05,0:00:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh umat manusia memang abadi sekarang.
Dialogue: 0,0:00:04.75,0:00:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, mereka terkurung selamanya\Ndalam penjara batu ciptaan Why-Man.
Dialogue: 0,0:00:10.75,0:00:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak puas dengan kesepakatan itu...
Dialogue: 0,0:00:15.65,0:00:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya cara adalah pergi ke Bulan\Ndan bicara langsung dengannya.
Dialogue: 0,0:00:31.05,0:00:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini ide buruk?
Dialogue: 0,0:00:32.98,0:00:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita benar-benar bisa\Nbekerja sama dengan orang seperti Xeno?
Dialogue: 0,0:00:36.35,0:00:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Xeno...
Dialogue: 0,0:00:38.78,0:00:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin super mencurigakan ini apa?
Dialogue: 0,0:00:41.61,0:00:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma mendinginkan udara.
Dialogue: 0,0:00:43.56,0:00:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya ini seperti AC?
Dialogue: 0,0:00:46.05,0:00:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengambil argon dari atmosfer.
Dialogue: 0,0:00:48.23,0:00:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ar... apa?
Dialogue: 0,0:00:50.71,0:00:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Suika mulai belajar sains,
Dialogue: 0,0:00:53.18,0:00:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suika ingin tahu cara kerjanya.
Dialogue: 0,0:00:56.18,0:00:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup berikan tegangan pada gas argon\Ndi dalam tabung kaca.
Dialogue: 0,0:01:01.31,0:01:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, listrik tak bisa\Nasal mengalir di udara.
Dialogue: 0,0:01:04.84,0:01:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suika juga sudah belajar soal itu.
Dialogue: 0,0:01:07.50,0:01:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Dr. Suika.
Dialogue: 0,0:01:10.41,0:01:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembelajaran yang sangat elegan.
Dialogue: 0,0:01:13.15,0:01:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:01:14.78,0:01:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daripada menjelaskan,\Nlebih cepat kalau langsung dicoba.
Dialogue: 0,0:01:19.38,0:01:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di bagian itu, Senku dan Xeno mirip banget.\NLayaknya mentor dan murid.
Dialogue: 0,0:01:24.25,0:01:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endapan bijihnya
Dialogue: 0,0:01:25.98,0:01:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada di sekitar sini.
Dialogue: 0,0:01:33.71,0:01:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, arus pulsa mengalir melalui gas.
Dialogue: 0,0:01:37.18,0:01:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebab endapan logam langka biasanya\Nmengandung unsur radioaktif.
Dialogue: 0,0:01:41.99,0:01:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Radioaktif?!
Dialogue: 0,0:01:44.45,0:01:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti itu...
Dialogue: 0,0:01:46.85,0:01:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pencacah Geiger?
Dialogue: 0,0:01:49.15,0:01:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak seram, ya?
Dialogue: 0,0:01:50.35,0:01:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru aman, kok.
Dialogue: 0,0:01:52.55,0:01:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama bisa diukur.
Dialogue: 0,0:01:53.98,0:01:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmunya Xeno agak bernuansa gelap, ya.
Dialogue: 0,0:01:57.25,0:02:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini metode pencarian bijih\Nyang benar-benar dipakai di abad ke-21.
Dialogue: 0,0:02:02.11,0:02:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ada gas dari korek,\Nanak SMP pun bisa membuatnya.
Dialogue: 0,0:02:13.52,0:02:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:02:16.11,0:02:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa ini?
Dialogue: 0,0:02:18.15,0:02:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ini terasa seperti bijih misterius\Ndi gim "Monster Hunter"?
Dialogue: 0,0:02:23.85,0:02:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sungguhan logam langka\Nuntuk pesawat luar angkasa?
Dialogue: 0,0:02:26.91,0:02:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun semua!
Dialogue: 0,0:02:28.71,0:02:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Tim Penambang!
Dialogue: 0,0:02:31.25,0:02:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar bisa disebut\NStone Sanctuary yang elegan.
Dialogue: 0,0:02:37.05,0:02:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, sisa bijih\Nyang kita butuhkan adalah...
Dialogue: 0,0:02:39.38,0:02:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sedang diangkat sekarang.
Dialogue: 0,0:02:50.95,0:02:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal Perseus kesayanganku...
Dialogue: 0,0:02:56.85,0:03:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah membuatmu menunggu tujuh tahun
Dialogue: 0,0:03:00.31,0:03:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai jadi begini.
Dialogue: 0,0:03:01.95,0:03:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, merah semua!
Dialogue: 0,0:03:03.58,0:03:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja sudah berkarat total.
Dialogue: 0,0:03:06.31,0:03:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ditinggalkan,
Dialogue: 0,0:03:07.78,0:03:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti kehilangan fungsi drainasenya,\Nlalu akhirnya tenggelam.
Dialogue: 0,0:03:11.75,0:03:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menghidupkanmu kembali!
Dialogue: 0,0:03:19.41,0:03:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan?
Dialogue: 0,0:03:23.31,0:03:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daur ulang besi.
Dialogue: 0,0:03:27.55,0:03:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Amerika Selatan sini,\Nserius, deh, tidak ada besi.
Dialogue: 0,0:03:30.91,0:03:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parah banget.
Dialogue: 0,0:03:31.91,0:03:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa memodifikasinya jadi New Perseus\Nyang jauh lebih kuat.
Dialogue: 0,0:03:36.85,0:03:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:03:42.03,0:03:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan material baru hasil penggabungan\Nlogam dengan sains.
Dialogue: 0,0:03:52.50,0:03:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu superalloy, paduan super.
Dialogue: 0,0:03:58.95,0:04:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuat superalloy\Nsebanyak-banyaknya!
Dialogue: 0,0:04:02.41,0:04:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku benar-benar tahu\Ncara menangani Kaseki.
Dialogue: 0,0:04:14.61,0:04:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masukkan bijih krom yang sudah dihancurkan\Nke dalam besi.
Dialogue: 0,0:04:17.61,0:04:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chrome dimasukkan begitu saja?
Dialogue: 0,0:04:22.21,0:04:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Dengan menambahkan kekuatan krom,
Dialogue: 0,0:04:25.65,0:04:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penggabungan berbagai sifat\Nakan membuatnya jadi lebih kuat.
Dialogue: 0,0:04:29.58,0:04:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga merupakan hukum sains.
Dialogue: 0,0:04:32.25,0:04:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak berkarat, tidak berkorosi.
Dialogue: 0,0:04:34.21,0:04:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lahirlah superalloy yang tak terkalahkan!
Dialogue: 0,0:04:40.59,0:04:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi dengan superalloy\Nbernama stainless steel itu...
Dialogue: 0,0:04:44.91,0:04:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa kita buat?
Dialogue: 0,0:04:47.15,0:04:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kalau sudah punya stainless steel,\Nakhirnya...
Dialogue: 0,0:04:52.01,0:04:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya?
Dialogue: 0,0:04:54.98,0:04:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa membuat makanan kaleng!
Dialogue: 0,0:04:57.15,0:04:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa banget!
Dialogue: 0,0:05:04.25,0:05:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dunia tempat bijih langka super mahal\Nbisa ditambang gratis sepuasnya.
Dialogue: 0,0:05:09.18,0:05:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditambah zirkonium dan tantalum,
Dialogue: 0,0:05:11.61,0:05:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa membuat makanan kaleng elegan\Nyang awet hingga 3.700 tahun.
Dialogue: 0,0:05:16.78,0:05:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia lama,\Nharga per kalengnya bisa sekitar 1 juta yen.
Dialogue: 0,0:05:21.75,0:05:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}1 juta yen?!
Dialogue: 0,0:05:23.81,0:05:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya...
Dialogue: 0,0:05:25.81,0:05:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:05:27.31,0:05:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan superalloy stainless steel,
Dialogue: 0,0:05:29.21,0:05:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanan kita jadi lebih baik,
Dialogue: 0,0:05:31.11,0:05:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kita bisa membangkitkan orang-orang\Ndi kota di seluruh dunia.
Dialogue: 0,0:05:35.51,0:05:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, itu mungkin benar.
Dialogue: 0,0:05:38.38,0:05:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu bahan untuk roket\Natau kapal, 'kan?
Dialogue: 0,0:06:07.65,0:06:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membuat pesawat luar angkasa ke Bulan,
Dialogue: 0,0:06:10.51,0:06:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak bahan yang kurang\Nmasih tersebar di seluruh Bumi.
Dialogue: 0,0:06:15.81,0:06:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:06:18.01,0:06:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus membuat kapal baru secepatnya
Dialogue: 0,0:06:20.35,0:06:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengumpulkannya dari seluruh dunia.
Dialogue: 0,0:06:23.15,0:06:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita bagi peran.
Dialogue: 0,0:06:25.98,0:06:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menangani mesin roket.
Dialogue: 0,0:06:27.85,0:06:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku, kau menangani kapal baru,\NNew Perseus.
Dialogue: 0,0:06:32.65,0:06:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:33.95,0:06:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak punya waktu santai\Nuntuk dua ilmuwan bekerja bersama.
Dialogue: 0,0:06:40.98,0:06:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, stainless steel\Nyang kita buat sekarang masih level 1.
Dialogue: 0,0:06:47.38,0:06:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pesawat luar angkasa\Nmenuju Why-Man di Bulan,
Dialogue: 0,0:06:50.41,0:06:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita butuh superalloy\Nyang jauh lebih unggul.
Dialogue: 0,0:06:54.71,0:06:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:06:55.85,0:06:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya berbahaya.
Dialogue: 0,0:06:57.91,0:07:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikel dipisahkan dengan diubah menjadi gas.
Dialogue: 0,0:07:00.45,0:07:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya, ini fasilitas untuk\Nmeningkatkan level superalloy, tapi...
Dialogue: 0,0:07:05.11,0:07:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini menghasilkan racun paling mematikan.
Dialogue: 0,0:07:07.71,0:07:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Racun ini bisa terserap kulit,\Nmasker gas pun takkan cukup
Dialogue: 0,0:07:11.21,0:07:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyebabkan kematian dengan cepat.
Dialogue: 0,0:07:14.75,0:07:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menutupnya agar tidak bocor,
Dialogue: 0,0:07:17.41,0:07:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langkah pertama adalah\Nmembuat stainless steel level 1.
Dialogue: 0,0:07:22.35,0:07:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram banget...
Dialogue: 0,0:07:24.81,0:07:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila.
Dialogue: 0,0:07:28.11,0:07:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menjelajah ruang angkasa,
Dialogue: 0,0:07:30.65,0:07:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita perlu menambang bijih\Ndan melanjutkan peta jalan sains.
Dialogue: 0,0:07:34.71,0:07:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi negatif seperti racun\Ntak bisa dihindari.
Dialogue: 0,0:07:38.31,0:07:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan ada yang mengecam.
Dialogue: 0,0:07:41.21,0:07:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peran sebagai penjahat itu...
Dialogue: 0,0:07:43.58,0:07:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar aku saja yang menanggung semuanya.
Dialogue: 0,0:07:47.15,0:07:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai Ilmuwan Kegelapan.
Dialogue: 0,0:07:50.21,0:07:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, aku bisa mengabaikan\Nsemua gangguan tingkat rendah,
Dialogue: 0,0:07:55.01,0:07:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bebas memajukan sains.
Dialogue: 0,0:07:59.55,0:08:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku akan menjadi Ilmuwan Cahaya
Dialogue: 0,0:08:02.31,0:08:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memimpin semua orang menuju masa depan.
Dialogue: 0,0:08:06.21,0:08:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sungguh elegan.
Dialogue: 0,0:08:08.61,0:08:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembagian peran yang tepat sesuai kemampuan.
Dialogue: 0,0:08:15.21,0:08:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalau orang-orang berbeda digabung,\Nmereka bisa jadi yang terkuat.
Dialogue: 0,0:08:19.91,0:08:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti superalloy itu.
Dialogue: 0,0:08:47.29,0:08:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umat manusia yang hidup di Bumi\Nakhirnya bersatu.
Dialogue: 0,0:08:55.65,0:08:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita hadapi fantasi dengan sains.
Dialogue: 0,0:08:59.61,0:09:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan Ilmuwan Kegelapan dan Ilmuwan Cahaya.
Dialogue: 0,0:09:22.27,0:09:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dr. STONE Season 4
Dialogue: 0,0:10:39.03,0:10:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dr. STONE Season 4
Dialogue: 0,0:10:44.35,0:10:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, gawat, ini parah!
Dialogue: 0,0:10:46.29,0:10:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan bahan bakar kapal,\Nyaitu minyak?
Dialogue: 0,0:10:48.69,0:10:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekitar Amazon sini\Nbenar-benar tidak ada minyak.
Dialogue: 0,0:10:51.85,0:10:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini benar-benar yang terburuk.\N- Kita harus mulai lagi dari membuat kapal layar.
Dialogue: 0,0:10:56.01,0:10:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kapal masa depan, New Perseus.
Dialogue: 0,0:10:59.51,0:11:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menjalankannya\Npakai energi masa depan.
Dialogue: 0,0:11:04.31,0:11:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi masa depan?
Dialogue: 0,0:11:07.38,0:11:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, yaitu sampah organik.
Dialogue: 0,0:11:13.38,0:11:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya biofuel, bahan bakar hayati.\NSampah organik apa pun bisa dipakai.
Dialogue: 0,0:11:17.81,0:11:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun, sisa makanan, bahkan kotoran.\NMasukkan semuanya.
Dialogue: 0,0:11:20.91,0:11:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan membusuk,\Nlalu kumpulkan gas yang dihasilkan.
Dialogue: 0,0:11:23.35,0:11:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotoran? Kotoran lagi?!
Dialogue: 0,0:11:33.38,0:11:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku, meski gas keluar dari sampah,
Dialogue: 0,0:11:37.55,0:11:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau dibiarkan bocor begitu saja,\Nberbahaya, 'kan?
Dialogue: 0,0:11:40.61,0:11:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, makanya...
Dialogue: 0,0:11:42.98,0:11:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita membuat tangki untuk menampung gasnya.
Dialogue: 0,0:11:45.25,0:11:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sepertinya aku\Npernah melihatnya di pabrik.
Dialogue: 0,0:11:49.65,0:11:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi membuat bentuk bulat yang rapi\Npasti susah banget.
Dialogue: 0,0:11:57.55,0:11:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jadi.
Dialogue: 0,0:11:58.71,0:12:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Itu bahkan tidak bulat sama sekali.
Dialogue: 0,0:12:01.55,0:12:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, asal jadi.
Dialogue: 0,0:12:03.85,0:12:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi dengan air,
Dialogue: 0,0:12:05.98,0:12:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu ledakkan dari tengah.
Dialogue: 0,0:12:11.38,0:12:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, jadi bulat.
Dialogue: 0,0:12:13.15,0:12:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:12:14.15,0:12:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu cara membuat tangki bulat itu...
Dialogue: 0,0:12:17.25,0:12:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:12:23.35,0:12:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus ini apa lagi, Xeno?
Dialogue: 0,0:12:26.45,0:12:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas tungku tak cukup\Nuntuk meleburkan superalloy.
Dialogue: 0,0:12:30.01,0:12:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita melelehkannya dengan kompor\NIH, Induction Heater, listrik.
Dialogue: 0,0:12:34.11,0:12:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kabelnya seperti selang?
Dialogue: 0,0:12:36.98,0:12:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sistem pendingin air.
Dialogue: 0,0:12:38.75,0:12:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, panasnya akan membuat\Nkabelnya sendiri meleleh.
Dialogue: 0,0:12:46.98,0:12:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus ini apa lagi, Senku?
Dialogue: 0,0:12:50.15,0:12:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini metode Fischer-Tropsch.
Dialogue: 0,0:12:52.31,0:12:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kurasa kau takkan paham.
Dialogue: 0,0:12:53.98,0:12:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku tidak paham.
Dialogue: 0,0:12:56.25,0:12:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik yang dikembangkan tentara Jerman\Nsaat kekurangan minyak.
Dialogue: 0,0:12:59.81,0:13:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mengubah gas dari sampah organik\Nmenjadi bahan bakar cair.
Dialogue: 0,0:13:03.36,0:13:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku tetap tidak paham.
Dialogue: 0,0:13:08.75,0:13:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dengan mencampurkan semua logam\Nyang diekstrak dari berbagai batu ini,
Dialogue: 0,0:13:14.98,0:13:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita menciptakan logam tak terkalahkan\Nuntuk mesin roket.
Dialogue: 0,0:13:20.15,0:13:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan panas tinggi, suhu rendah, oksidasi,\Nkorosi, dan deformasi permanen.
Dialogue: 0,0:13:24.53,0:13:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, apa katamu?
Dialogue: 0,0:13:26.58,0:13:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Superalloy di atas semua superalloy.
Dialogue: 0,0:13:29.91,0:13:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pada dasarnya ini sangat kuat, 'kan?
Dialogue: 0,0:13:34.11,0:13:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila, sih.
Dialogue: 0,0:13:35.79,0:13:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setengah tahun kita menggabungkannya\Npakai sains.
Dialogue: 0,0:13:39.31,0:13:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal awalnya cuma batu biasa\Nyang berserakan di Bumi.
Dialogue: 0,0:14:08.95,0:14:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan mesinnya?
Dialogue: 0,0:14:10.81,0:14:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah.
Dialogue: 0,0:14:12.41,0:14:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bahan bakar cair di pihakmu?
Dialogue: 0,0:14:15.21,0:14:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kurasa tak perlu ditanya.
Dialogue: 0,0:14:17.58,0:14:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tidak ada masalah.
Dialogue: 0,0:14:20.51,0:14:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya kita mulai uji perdana!
Dialogue: 0,0:14:39.23,0:14:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, itu jet roket!
Dialogue: 0,0:14:42.65,0:14:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu mesin turbin gas.
Dialogue: 0,0:14:45.75,0:14:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk benar-benar menerbangkan\Npesawat luar angkasa,
Dialogue: 0,0:14:48.55,0:14:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita masih butuh peningkatan lebih jauh\Nhingga level 99.
Dialogue: 0,0:14:53.45,0:14:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dengan ini,
Dialogue: 0,0:14:55.31,0:14:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya kita bisa berhadapan langsung\Ndengan Why-Man.
Dialogue: 0,0:14:57.91,0:15:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini langkah pertama\Nmenuju perjalanan ke Bulan.
Dialogue: 0,0:15:08.38,0:15:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kerja sama singkat\Nyang terwujud usai ribuan tahun...
Dialogue: 0,0:15:13.45,0:15:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Senku...
Dialogue: 0,0:15:15.41,0:15:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai besok, kita akan menempuh jalan\Nyang berbeda lagi.
Dialogue: 0,0:15:20.71,0:15:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:15:28.26,0:15:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan dibagi menjadi tiga tim.
Dialogue: 0,0:15:31.65,0:15:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:15:33.78,0:15:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph, sekarang kota sudah stabil.
Dialogue: 0,0:15:36.55,0:15:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar kalau ingin santai dan menetap.
Dialogue: 0,0:15:40.11,0:15:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi semua orang di dunia masih membatu.
Dialogue: 0,0:15:42.98,0:15:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jepang, Pulau Harta,\Nsampai Kota Jagung juga.
Dialogue: 0,0:15:45.65,0:15:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali!
Dialogue: 0,0:15:47.41,0:15:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu kami, Yuzuriha dan yang lain.
Dialogue: 0,0:15:51.35,0:15:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembagian timnya adalah...
Dialogue: 0,0:15:53.71,0:15:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim yang tinggal di Kota Superalloy.
Dialogue: 0,0:15:56.55,0:16:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inti sains yang mengumpulkan bijih\Ndan mengembangkan mesin roket.
Dialogue: 0,0:16:01.25,0:16:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim yang kembali ke Kota Jagung.
Dialogue: 0,0:16:04.25,0:16:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyelamatkan semua orang\Ndi daratan Amerika,
Dialogue: 0,0:16:06.51,0:16:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghidupkan produksi jagung,\Nsumber kebangkitan umat manusia.
Dialogue: 0,0:16:10.28,0:16:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!\NKenapa aku harus terpisah dari Senku?!
Dialogue: 0,0:16:14.78,0:16:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beri tahu rahasia, ya.
Dialogue: 0,0:16:17.35,0:16:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe idaman Senku itu wanita\Nyang kompeten dalam bekerja, lo.
Dialogue: 0,0:16:21.71,0:16:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku jelas bisa, dong!
Dialogue: 0,0:16:25.65,0:16:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir...
Dialogue: 0,0:16:26.30,0:16:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim yang maju ke kota baru.
Dialogue: 0,0:16:29.58,0:16:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari sini, menyeberangi Samudra Atlantik,\Nmenjelajahi dunia,
Dialogue: 0,0:16:32.72,0:16:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengumpulkan bahan pesawat luar angkasa\Nsampai tiba di Jepang,
Dialogue: 0,0:16:35.77,0:16:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai para pelopor masa depan.
Dialogue: 0,0:16:38.05,0:16:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh banget!\NBerapa tahun sampai ke Jepang?
Dialogue: 0,0:16:44.29,0:16:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:16:46.21,0:16:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin roket yang kita buat\Ndengan susah payah ini,
Dialogue: 0,0:16:50.38,0:16:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian pikir cuma\Nuntuk pesawat luar angkasa?
Dialogue: 0,0:17:08.84,0:17:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:17:10.18,0:17:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:17:11.21,0:17:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau bikin perpisahan yang mengharukan,
Dialogue: 0,0:17:13.91,0:17:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sudah tidak kelihatan lagi.
Dialogue: 0,0:17:16.01,0:17:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kita masih bisa komunikasi\Nlewat radio tiap hari.
Dialogue: 0,0:17:20.98,0:17:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin Perseus lama: 300 daya kuda,\Nkecepatan 4 knot.
Dialogue: 0,0:17:26.25,0:17:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin masa depan superalloy ini:\N10.000 daya kuda, kecepatan 20 knot.
Dialogue: 0,0:17:31.85,0:17:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh 40 hari untuk menyeberangi Pasifik,
Dialogue: 0,0:17:35.15,0:17:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dengan New Perseus ini,
Dialogue: 0,0:17:37.37,0:17:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa menyeberangi Atlantik\Nhanya dalam seminggu.
Dialogue: 0,0:17:44.56,0:17:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:17:46.05,0:17:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bahkan tak terasa\Nseperti kecepatan kapal.
Dialogue: 0,0:17:48.45,0:17:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar lima kali lebih cepat!
Dialogue: 0,0:17:51.45,0:17:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila!
Dialogue: 0,0:17:52.75,0:17:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mesin sehebat ini,
Dialogue: 0,0:17:54.65,0:17:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin kita benar-benar bisa\Nsampai ke Bulan!
Dialogue: 0,0:18:00.51,0:18:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari batu biasa...
Dialogue: 0,0:18:08.05,0:18:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chrome, apa itu air mata?
Dialogue: 0,0:18:10.21,0:18:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:12.71,0:18:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.
Dialogue: 0,0:18:15.05,0:18:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit untuk dijelaskan.
Dialogue: 0,0:18:28.75,0:18:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:18:30.91,0:18:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdiri di dek terasa sangat sejuk\Ndan nyaman.
Dialogue: 0,0:18:38.25,0:18:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak sejuk.
Dialogue: 0,0:18:39.91,0:18:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas banget sampai rasanya mau meleleh!
Dialogue: 0,0:18:41.91,0:18:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matahari tepat di atas kita.
Dialogue: 0,0:18:43.78,0:18:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita di tengah Atlantik dekat khatulistiwa.
Dialogue: 0,0:18:48.15,0:18:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur, mundur!
Dialogue: 0,0:18:52.18,0:18:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang rasanya dingin dan segar.
Dialogue: 0,0:18:54.05,0:18:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keringat langsung hilang seketika,\Nseperti membeku.
Dialogue: 0,0:18:57.31,0:18:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:18:59.51,0:19:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita punya kulkas, 'kan?
Dialogue: 0,0:19:01.05,0:19:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prinsipnya sama.
Dialogue: 0,0:19:03.98,0:19:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mesin baru, New Perseus sekarang\Nsepenuhnya bertenaga listrik.
Dialogue: 0,0:19:10.11,0:19:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren, keren, keren!
Dialogue: 0,0:19:11.75,0:19:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti perjalanan kelas mewah.
Dialogue: 0,0:19:14.11,0:19:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sains gila banget, keren maksimal!
Dialogue: 0,0:19:16.15,0:19:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti kita mendapatkan kembali\Nperadaban dalam sekejap.
Dialogue: 0,0:19:20.31,0:19:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, sekarang Senku dan Xeno\Njadi duo ilmuwan dengan kekuatan ganda.
Dialogue: 0,0:19:26.31,0:19:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sebagian, sih.
Dialogue: 0,0:19:28.91,0:19:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi masih jauh dari cukup.
Dialogue: 0,0:19:31.55,0:19:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya?
Dialogue: 0,0:19:33.25,0:19:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, kita akan bekerja terpisah\Ndi seluruh dunia sambil terus berkomunikasi.
Dialogue: 0,0:19:40.01,0:19:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena kita tidak punya\Nsatelit komunikasi,
Dialogue: 0,0:19:42.31,0:19:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk jarak jauh, panggilan takkan sampai.
Dialogue: 0,0:19:45.53,0:19:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya cara komunikasi\Nadalah kode Morse.
Dialogue: 0,0:19:49.51,0:19:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, semua orang harus rajin latihan Morse.
Dialogue: 0,0:19:55.81,0:19:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kami juga, ya?
Dialogue: 0,0:19:58.21,0:20:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti harus mulai dari belajar huruf.
Dialogue: 0,0:20:00.45,0:20:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau huruf, Suika bisa mengajari.
Dialogue: 0,0:20:08.85,0:20:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:20:11.51,0:20:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu Why-Man pertama kali muncul,
Dialogue: 0,0:20:15.41,0:20:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu karena kita mengirim\Ngelombang radio besar banget, 'kan?
Dialogue: 0,0:20:18.51,0:20:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah cara dia menyadari kami.
Dialogue: 0,0:20:21.85,0:20:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sekarang kita memakai\Ngelombang radio segitu banyak,
Dialogue: 0,0:20:25.75,0:20:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa tidak akan ketahuan lagi oleh Why-Man
Dialogue: 0,0:20:29.01,0:20:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau manusia sudah mulai bergerak lagi?
Dialogue: 0,0:20:35.25,0:20:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukyo.
Dialogue: 0,0:20:36.58,0:20:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Leonard, aku juga dengar.
Dialogue: 0,0:20:39.58,0:20:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinyal barusan...
Dialogue: 0,0:20:42.01,0:20:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu dari Bulan.
Dialogue: 0,0:20:44.41,0:20:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat banget.
Dialogue: 0,0:20:45.95,0:20:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dapat pesan dari Why-Man?
Dialogue: 0,0:20:50.38,0:20:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sejak tadi.
Dialogue: 0,0:20:52.92,0:20:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:54.01,0:20:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kita memang sudah lama\Nmemancarkan komunikasi terus-menerus.
Dialogue: 0,0:20:57.85,0:20:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:20:58.85,0:21:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali kita melakukannya,\Ndia terus teriak "Why, why".
Dialogue: 0,0:21:03.91,0:21:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebiasaan Why-Man bereaksi terhadap\Ngelombang radio itu sudah jadi rahasia umum.
Dialogue: 0,0:21:08.21,0:21:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa saja tak memakai radio sama sekali\Ndan bergerak diam-diam seperti gerilya,
Dialogue: 0,0:21:12.38,0:21:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi begitu kita memakai kompor induksi,\Ngelombang radio juga pasti bocor.
Dialogue: 0,0:21:18.61,0:21:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peradaban modern dan gelombang radio itu\Ntak bisa dipisahkan.
Dialogue: 0,0:21:23.41,0:21:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu.
Dialogue: 0,0:21:25.65,0:21:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku sudah belajar Morse,\Njadi aku tahu.
Dialogue: 0,0:21:28.85,0:21:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Huruf yang dia kirim ini\Nbukan W-H-Y seperti biasanya.
Dialogue: 0,0:21:36.31,0:21:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesannya berbahasa Inggris,\Njadi aku tidak mengerti artinya.
Dialogue: 0,0:21:56.48,0:21:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Do you wanna die?
Dialogue: 0,0:21:59.57,0:22:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Do you wanna die?
Dialogue: 0,0:22:02.17,0:22:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Do you wanna die?
Dialogue: 0,0:22:04.66,0:22:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Do you wanna die?
Dialogue: 0,0:22:07.01,0:22:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau ingin mati?
