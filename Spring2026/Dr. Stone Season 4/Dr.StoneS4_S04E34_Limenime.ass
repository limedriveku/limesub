Dialogue: 0,0:06:52.45,0:06:56.79,sign,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:08:44.19,0:08:45.10,sign,,0000,0000,0000,,GARAM, LISTRIK, PETROLEUM
Dialogue: 0,0:08:45.10,0:08:46.69,sign,,0000,0000,0000,,KLORIN, NAFTA, PASIR SILIKA, FLUORIT
Dialogue: 0,0:08:48.27,0:08:49.19,sign,,0000,0000,0000,,{\an8}TUJUAN - BAJU LUAR ANGKASA
Dialogue: 0,0:10:06.48,0:10:08.89,sign,,0000,0000,0000,,{\an8}MICROWAVE DIPEROLEH!
Dialogue: 0,0:10:37.13,0:10:39.59,sign,,0000,0000,0000,,BUNGKUS PLASTIK DIPEROLEH!
Dialogue: 0,0:10:56.03,0:10:56.86,sign,,0000,0000,0000,,{\an8}MESIN CUCI DIPEROLEH!
Dialogue: 0,0:10:59.28,0:11:00.20,sign,,0000,0000,0000,,{\an8}FORMAT VIDEO 8MM DIPEROLEH!
Dialogue: 0,0:13:10.16,0:13:11.16,sign,,0000,0000,0000,,INTERNET, GIM, TELEPON
Dialogue: 0,0:13:14.16,0:13:15.66,sign,,0000,0000,0000,,PONSEL PINTAR DIPEROLEH!
Dialogue: 0,0:14:20.02,0:14:22.31,sign,,0000,0000,0000,,{\an8}KOKPIT KAPAL ANTARIKSA DIPEROLEH!
Dialogue: 0,0:14:29.45,0:14:30.45,sign,,0000,0000,0000,,BATU, PERKAKAS BATU, POHON
Dialogue: 0,0:14:30.45,0:14:32.24,sign,,0000,0000,0000,,API, PASIR BESI,\NGERGAJI BESI, GIR, RODA AIR
Dialogue: 0,0:14:34.83,0:14:37.16,sign,,0000,0000,0000,,PETROLEUM, BAJU LUAR ANGKASA VINIL,\NKAPAL ANTARIKSA, MESIN ROKET
Dialogue: 0,0:14:50.97,0:14:53.93,sign,,0000,0000,0000,,{\an8}ROKET PENDARATAN DI BULAN SELESAI!
Dialogue: 0,0:23:20.85,0:23:22.56,sign,,0000,0000,0000,,TERKONFIRMASI
Dialogue: 0,0:23:53.51,0:23:56.01,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:56.01,0:23:57.51,sign,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA,
Dialogue: 0,0:23:57.51,0:23:59.35,sign,,0000,0000,0000,,MATERIAL, DAN METODENYA\NDIDASARKAN PADA KENYATAAN
Dialogue: 0,0:23:59.35,0:24:01.02,sign,,0000,0000,0000,,MOHON JANGAN DICOBA\NKARENA BISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:05.00,0:00:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untuk pertarungan kita melawan Why-Man…{\i0}
Dialogue: 0,0:00:08.29,0:00:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang yang paling memenuhi syarat\Nuntuk menjadi pilot pesawat antariksa{\i0}
Dialogue: 0,0:00:12.38,0:00:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bukanlah aku.{\i0}
Dialogue: 0,0:00:20.02,0:00:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Senku.\N- Ya?
Dialogue: 0,0:00:22.48,0:00:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya dongeng. Bayangkan kalau kau
Dialogue: 0,0:00:25.69,0:00:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang kesatria yang mengabdi\Npada suatu negara.
Dialogue: 0,0:00:29.11,0:00:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:31.15,0:00:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai seorang kesatria muda,\Nkau jatuh cinta pada sang putri
Dialogue: 0,0:00:34.99,0:00:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kalian membicarakan\Nmasa depan bersama.
Dialogue: 0,0:00:37.45,0:00:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada pria lain\Nyang lebih cocok untuk sang putri.
Dialogue: 0,0:00:41.24,0:00:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran dari negara tetangga.
Dialogue: 0,0:00:43.33,0:00:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernikahan mereka akan\Nmembawa kedamaian ke negara itu.
Dialogue: 0,0:00:48.92,0:00:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kau lakukan?
Dialogue: 0,0:00:51.34,0:00:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai seorang ahli sains.
Dialogue: 0,0:00:53.84,0:00:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bicara apa, tiba-tiba begitu?
Dialogue: 0,0:01:15.15,0:01:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para ahli sains mengutamakan efisiensi.
Dialogue: 0,0:01:18.70,0:01:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada seseorang yang\Nsepuluh miliar persen lebih cocok dariku,
Dialogue: 0,0:01:22.83,0:01:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan percayakan padanya.
Dialogue: 0,0:01:28.88,0:01:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bertanya padaku,\Npadahal sudah tahu jawabannya, 'kan?
Dialogue: 0,0:01:33.38,0:01:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai aku jawab itu.
Dialogue: 0,0:01:38.05,0:01:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang orang terbaik untuk peran itu.
Dialogue: 0,0:01:41.47,0:01:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku tak keberatan.
Dialogue: 0,0:01:43.97,0:01:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selalu saja berlagak santai{\i0}
Dialogue: 0,0:01:45.77,0:01:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan menyembunyikan ekspresinya\Nsaat dia merasa emosional.{\i0}
Dialogue: 0,0:01:49.19,0:01:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Sebagai gurunya,\Ndia sangat mirip dengan Senku.{\i0}
Dialogue: 0,0:01:53.61,0:01:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau begitu, aku terkejut\Nmendengar keputusan kalian.
Dialogue: 0,0:01:57.74,0:02:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau prajurit terhebat, Stan,\Ndan aku bersatu,
Dialogue: 0,0:02:00.95,0:02:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa saja kami berusaha\Nmenguasai dunia lagi.
Dialogue: 0,0:02:06.12,0:02:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat sejauh mana dunia\Nsudah dipulihkan, itu bukan langkah logis.
Dialogue: 0,0:02:09.62,0:02:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah?
Dialogue: 0,0:02:10.96,0:02:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ahli sains adalah ahli efisiensi.
Dialogue: 0,0:02:13.13,0:02:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu kami bisa memercayaimu.
Dialogue: 0,0:02:16.92,0:02:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun aku yakin pasti ada\Nyang ribut-ribut karena takut.
Dialogue: 0,0:02:22.01,0:02:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang saja kalau aku mengancam kalian.
Dialogue: 0,0:02:25.01,0:02:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku mengancam\Nakan mengambil jalan pintas
Dialogue: 0,0:02:26.98,0:02:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada mesin roket kalau kalian\Ntak membangkitkan Stan.
Dialogue: 0,0:02:30.15,0:02:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, akan aku beri tahu sendiri.
Dialogue: 0,0:02:33.23,0:02:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xeno, kau tak perlu\Nselalu berperan sebagai penjahat.
Dialogue: 0,0:02:37.94,0:02:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka atau tidak,
Dialogue: 0,0:02:40.36,0:02:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau sudah menjadi anggota Kerajaan Sains
Dialogue: 0,0:02:43.99,0:02:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan salah satu pemimpinnya.
Dialogue: 0,0:02:47.45,0:02:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Stanley Snyder…
Dialogue: 0,0:02:50.21,0:02:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Akan dibangkitkan…\N- Lalu, dipilih sebagai pilot?
Dialogue: 0,0:02:53.04,0:02:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jreng!
Dialogue: 0,0:02:54.84,0:02:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukasa akan mengikuti Xeno ke mana-mana.
Dialogue: 0,0:02:58.97,0:03:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara resmi,\Naku akan menjadi pengawal untuk VIP.
Dialogue: 0,0:03:02.51,0:03:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau-kalau Stan memberontak,
Dialogue: 0,0:03:05.64,0:03:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukasa akan menghajarku.
Dialogue: 0,0:03:08.81,0:03:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam kata lain, aku adalah sandera.
Dialogue: 0,0:03:11.06,0:03:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:03:12.56,0:03:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa saja langsung\Nmenembak kita setelah bangun!
Dialogue: 0,0:03:15.19,0:03:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir soal itu.\NStanley adalah seorang prajurit.
Dialogue: 0,0:03:18.99,0:03:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya melakukan\Nyang diperlukan demi misi.
Dialogue: 0,0:03:22.28,0:03:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah sifatnya dari dulu\Ndan sampai nanti pun begitu.
Dialogue: 0,0:03:25.41,0:03:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut! Kurung saja dia di penjara!
Dialogue: 0,0:03:30.04,0:03:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita harus mengirim dia.
Dialogue: 0,0:03:32.71,0:03:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan pergi ke bulan,\Ntempat yang paling berbahaya
Dialogue: 0,0:03:35.29,0:03:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyelamatkan seluruh umat manusia.
Dialogue: 0,0:03:38.00,0:03:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada penebusan dosa yang lebih baik.
Dialogue: 0,0:03:42.88,0:03:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak keberatan, Ryusui?
Dialogue: 0,0:03:47.22,0:03:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuanku sebagai pilot setara,\Ntapi kemampuan menembakku…
Dialogue: 0,0:03:50.64,0:03:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudku.\NKau benar-benar mau ikut, 'kan?
Dialogue: 0,0:04:00.07,0:04:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memastikan orang dengan kemampuan,\Nterbaik melakukan tugas sebaik mungkin.
Dialogue: 0,0:04:04.78,0:04:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sesuatu yang…\NItulah yang aku inginkan.
Dialogue: 0,0:04:08.28,0:04:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\Nakulah lelaki paling tamak di dunia!
Dialogue: 0,0:04:32.89,0:04:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaanku?
Dialogue: 0,0:04:36.06,0:04:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kalau kau langsung ke intinya.
Dialogue: 0,0:04:38.77,0:04:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Stanley bilang bisa,\Napa pun bisa dilakukan.
Dialogue: 0,0:04:42.36,0:04:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling baik meminta pada ahli.
Dialogue: 0,0:04:44.70,0:04:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggaplah kau menembakkan\Npeluru dengan berat 1 pon
Dialogue: 0,0:04:47.41,0:04:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan kecepatan peluru\N600 meter per detik.
Dialogue: 0,0:04:50.79,0:04:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percepatan gravitasi di bulan\Nadalah seperenam dari Bumi
Dialogue: 0,0:04:54.58,0:04:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa hambatan udara.
Dialogue: 0,0:04:56.75,0:05:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sasaranmu, Medusa, berjarak 1 kilometer.
Dialogue: 0,0:05:02.96,0:05:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa sudut penembakannya 0,13.
Dialogue: 0,0:05:08.55,0:05:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hitungannya benar.{\i0}
Dialogue: 0,0:05:10.64,0:05:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia tahu dari insting, ya? Gila, Stanley…{\i0}
Dialogue: 0,0:05:14.52,0:05:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa, Stan?
Dialogue: 0,0:05:22.94,0:05:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku bisa.
Dialogue: 0,0:05:33.83,0:05:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku tak ikut ke luar angkasa lagi,
Dialogue: 0,0:05:36.33,0:05:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sebaiknya aku tetap\Nberlatih menjadi pilot cadangan.
Dialogue: 0,0:05:39.54,0:05:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tugas astronaut, apa aku salah?
Dialogue: 0,0:05:43.05,0:05:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ryusui memang hebat.
Dialogue: 0,0:05:45.05,0:05:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda menginginkan sesuatu\Nyang melampaui hasrat pribadi Anda.
Dialogue: 0,0:05:48.55,0:05:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda menginginkan kemenangan\Nbagi umat manusia, dan demi itu
Dialogue: 0,0:05:51.26,0:05:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda menyerahkan kursi Anda ke bulan
Dialogue: 0,0:05:53.31,0:05:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada Tuan Stanley tanpa ragu.
Dialogue: 0,0:05:57.60,0:05:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak perlu dihibur.
Dialogue: 0,0:06:07.61,0:06:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ikut!
Dialogue: 0,0:06:10.32,0:06:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:06:14.95,0:06:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial…
Dialogue: 0,0:06:31.59,0:06:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sasaran dalam jarak ini?
Dialogue: 0,0:06:34.47,0:06:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:06:37.56,0:06:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan…
Dialogue: 0,0:08:34.22,0:08:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang mereka membuat apa?
Dialogue: 0,0:08:39.64,0:08:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku, Stanley, dan Kohaku? Itu pasti…
Dialogue: 0,0:08:46.69,0:08:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Baju luar angkasa mereka!{\i0}
Dialogue: 0,0:08:49.19,0:08:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat dia menyebut\Ntiga pusaka untuk pendaratan di bulan.
Dialogue: 0,0:08:53.11,0:08:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal antariksa, mesin roket,\Ndan baju luar angkasa.
Dialogue: 0,0:08:56.78,0:08:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya hampir selesai.
Dialogue: 0,0:08:58.12,0:09:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini berarti kita akhirnya\Nakan melawan Why-Man, ya?
Dialogue: 0,0:09:02.91,0:09:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa benda yang disebut "vinil" ini?
Dialogue: 0,0:09:04.96,0:09:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, penduduk Desa Ishigami\Ntak tahu ini apa, ya?
Dialogue: 0,0:09:09.54,0:09:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali
Dialogue: 0,0:09:11.05,0:09:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa membangun roket\Nbahkan sebelum membuat vinil.
Dialogue: 0,0:09:14.26,0:09:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah manfaat punya\Npabrik produksi minyak.
Dialogue: 0,0:09:16.93,0:09:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urutannya sepertinya berantakan.
Dialogue: 0,0:09:21.72,0:09:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, seluruh umat manusia fokus\Npada teknik roket
Dialogue: 0,0:09:24.81,0:09:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengabaikan semuanya.
Dialogue: 0,0:09:31.77,0:09:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo lakukan beberapa proyek akhir\Nsebelum kami pergi ke bulan.
Dialogue: 0,0:09:35.32,0:09:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang saja kalian mau apa, aku buatkan.
Dialogue: 0,0:09:39.78,0:09:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mesin cuci!\N- Perekam video!
Dialogue: 0,0:09:41.37,0:09:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Konsol gim!\N- Protein!
Dialogue: 0,0:09:42.99,0:09:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Robot pelayan!\N- Aku mau…
Dialogue: 0,0:09:45.66,0:09:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin slot, microwave,\Njacuzzi, lemari anggur!
Dialogue: 0,0:09:48.96,0:09:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku tak bisa membuat itu.\N- Aku menginginkan semuanya!
Dialogue: 0,0:09:53.63,0:09:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah membuat ponsel dan radar,
Dialogue: 0,0:09:57.05,0:09:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi gelombang elektromagnetiknya\Nbisa dipakai.
Dialogue: 0,0:09:59.68,0:10:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantulkan saja gelombangnya
Dialogue: 0,0:10:01.18,0:10:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}secara gila-gilaan\Ndalam kotak logam dan kita dapat…
Dialogue: 0,0:10:09.48,0:10:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Panas!\N- Hebat.
Dialogue: 0,0:10:11.77,0:10:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tadi nasinya dingin.
Dialogue: 0,0:10:13.65,0:10:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa? Padahal tak ada api!
Dialogue: 0,0:10:16.15,0:10:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombangnya menggetarkan\Nkandungan air dalam makanan.
Dialogue: 0,0:10:19.99,0:10:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu sinyal TV\Nmenjadi buruk saat hujan.
Dialogue: 0,0:10:23.33,0:10:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang TV-nya sedang\Nmemanaskan tetesan air hujan.
Dialogue: 0,0:10:27.29,0:10:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong soal memanaskan\Nmakanan dalam microwave!
Dialogue: 0,0:10:30.46,0:10:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat vinil yang kita buat\Nuntuk baju luar angkasa?
Dialogue: 0,0:10:33.59,0:10:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tarik sampai tipis\Ndan kita dapat bungkus plastik!
Dialogue: 0,0:10:40.18,0:10:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyangkut makanan,\Nseolah kita kembali ke abad ke-21.
Dialogue: 0,0:10:44.47,0:10:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku heran melihat cepatnya kita membuat\Nproduk yang terkait dengan pangan.
Dialogue: 0,0:10:47.81,0:10:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini berkat Ryusui
Dialogue: 0,0:10:50.35,0:10:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang punya moto "hasrat bersifat mulia."
Dialogue: 0,0:10:53.40,0:10:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Berikutnya! Mesin cuci!\N- Hore!
Dialogue: 0,0:10:57.78,0:10:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Film!\N- Asyik!
Dialogue: 0,0:11:00.20,0:11:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Penghangat tangan!\N- Baiklah,
Dialogue: 0,0:11:02.70,0:11:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}besi yang berkarat\Nmenghasilkan panas, jadi…
Dialogue: 0,0:11:05.41,0:11:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kalau sederhana begitu,\Naku pun juga bisa buat!
Dialogue: 0,0:11:08.50,0:11:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau menggunakan\Nserbuk besi dan air laut?
Dialogue: 0,0:11:11.33,0:11:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku! Yang aku mau adalah…
Dialogue: 0,0:11:14.17,0:11:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ponsel pintar, 'kan?\N- Mulai lagi dia.
Dialogue: 0,0:11:18.67,0:11:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Jangan-jangan…
Dialogue: 0,0:11:22.01,0:11:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa membuatnya?
Dialogue: 0,0:11:23.93,0:11:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya? Benarkah?
Dialogue: 0,0:11:27.60,0:11:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita buat layar sentuh\Nkristal cair untuk ponsel pintar.
Dialogue: 0,0:11:30.60,0:11:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?
Dialogue: 0,0:11:32.27,0:11:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, "kristal cair" itu apa?
Dialogue: 0,0:11:36.02,0:11:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kristal cair" bukan nama\Nsuatu bahan tertentu.
Dialogue: 0,0:11:39.03,0:11:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebutan untuk wujud zat yang aneh,
Dialogue: 0,0:11:41.74,0:11:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kristal, yang biasanya padat,\Nmengalir seperti cairan.
Dialogue: 0,0:11:44.45,0:11:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, "kristal" dan "cair."
Dialogue: 0,0:11:47.03,0:11:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak cara untuk membuatnya.
Dialogue: 0,0:11:49.04,0:11:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya,
Dialogue: 0,0:11:50.37,0:11:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa pakai N-butilanilina\Nyang kita sintesiskan dari Anilina
Dialogue: 0,0:11:53.71,0:11:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan toluena dari petroleum…
Dialogue: 0,0:11:55.42,0:11:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NKau tak perlu memberi contoh.
Dialogue: 0,0:12:00.88,0:12:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil sepotong kaca\Ndengan alur vertikal yang halus
Dialogue: 0,0:12:03.84,0:12:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tuang kristal cair ke atasnya.
Dialogue: 0,0:12:07.10,0:12:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alur vertikalnya akan terisi dengan pas.
Dialogue: 0,0:12:11.18,0:12:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kita ambil sepotong kaca\Ndengan alur horizontal.
Dialogue: 0,0:12:15.06,0:12:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena terjepit di antara\Nalur vertikal dan horizontal,
Dialogue: 0,0:12:17.82,0:12:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kristal cair di dalamnya\Nakan memuntir sendiri.
Dialogue: 0,0:12:21.78,0:12:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situlah cahaya akan lewat.
Dialogue: 0,0:12:23.82,0:12:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan terbuat jalur spiral\Ndari vertikal ke horizontal.
Dialogue: 0,0:12:26.41,0:12:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mari kita alirkan arus listrik.
Dialogue: 0,0:12:29.83,0:12:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pop.
Dialogue: 0,0:12:31.79,0:12:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aliran listrik menyetrum\Nkristal cair, kristalnya menjadi lurus
Dialogue: 0,0:12:35.58,0:12:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan cahaya tak bisa\Nlewat jalur spiral itu lagi.
Dialogue: 0,0:12:38.38,0:12:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,
Dialogue: 0,0:12:39.80,0:12:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}begitulah caranya membuat\Nsuatu area tampak gelap.
Dialogue: 0,0:12:42.51,0:12:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, benar-benar berhasil!
Dialogue: 0,0:12:44.80,0:12:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak paham,\Ntapi di saat yang sama, aku tak paham.
Dialogue: 0,0:12:49.56,0:12:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak paham,\Npadahal aku yang membuatnya.
Dialogue: 0,0:12:52.68,0:12:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang kutahu cuma
Dialogue: 0,0:12:54.69,0:12:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kristal cair tampak hitam\Nsaat dialirkan arus listrik.
Dialogue: 0,0:12:57.90,0:13:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang tinggal pasang dua lapisan vinil\Ndi atas layar kristal cair.
Dialogue: 0,0:13:02.65,0:13:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah kegunaan vinil ini gila.
Dialogue: 0,0:13:05.91,0:13:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita buat
Dialogue: 0,0:13:07.91,0:13:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}arus mengalir di mana pun\Nyang kita sentuh…
Dialogue: 0,0:13:11.16,0:13:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dapat layar sentuh\Npenampil kristal cair, atau LCD.
Dialogue: 0,0:13:15.66,0:13:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini… Ini luar biasa!
Dialogue: 0,0:13:19.34,0:13:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini ponsel pintar sungguhan!
Dialogue: 0,0:13:21.17,0:13:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukurannya juga kecil!
Dialogue: 0,0:13:26.05,0:13:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali!
Dialogue: 0,0:13:28.05,0:13:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponsel pintar pun\Nsebenarnya hanyalah komputer.
Dialogue: 0,0:13:32.35,0:13:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ponsel pintar 40 kg.
Dialogue: 0,0:13:34.48,0:13:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah! Yang penting\Nbagian yang dipegang kecil!
Dialogue: 0,0:13:38.65,0:13:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang, kita bisa pakai\NLCD untuk mengirim surel
Dialogue: 0,0:13:41.98,0:13:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}dan bahkan bermain gim.
Dialogue: 0,0:13:45.36,0:13:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang ponsel pintar.
Dialogue: 0,0:13:48.24,0:13:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju!
Dialogue: 0,0:13:49.49,0:13:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia repot-repot membuat LCD\Nhanya untuk sahabatnya, Taiju.
Dialogue: 0,0:13:53.79,0:13:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku baik sekali.
Dialogue: 0,0:13:55.83,0:13:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak, aku yakin sebenarnya bukan begitu.
Dialogue: 0,0:13:59.54,0:14:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentu saja tidak.\N- Sudah kuduga.
Dialogue: 0,0:14:02.96,0:14:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan muat LCD ini\Nke pesawat antariksa.
Dialogue: 0,0:14:06.01,0:14:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, TV CRT rentan terhadap guncangan.
Dialogue: 0,0:14:10.55,0:14:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa menghemat ruang dan muatan.
Dialogue: 0,0:14:14.68,0:14:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bisa menjadi ringan,\Nyang menjadi kunci
Dialogue: 0,0:14:17.60,0:14:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pembuatan roket pulang-pergi\Ndengan banyak bagian.
Dialogue: 0,0:14:23.27,0:14:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita terus bekerja mati-matian
Dialogue: 0,0:14:24.98,0:14:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyambungkan semuanya,\Nsedikit demi sedikit…
Dialogue: 0,0:14:32.24,0:14:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}…di peta jalan sains\Nyang tak ada habisnya itu.{\i0}
Dialogue: 0,0:14:38.91,0:14:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita sampai sejauh ini\Ndan semuanya dimulai dari sebuah batu.
Dialogue: 0,0:14:43.63,0:14:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudah saatnya berangkat…
Dialogue: 0,0:14:47.67,0:14:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke pertarungan kita di bulan!
Dialogue: 0,0:15:17.66,0:15:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohaku…
Dialogue: 0,0:15:19.75,0:15:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ceroboh, ya.
Dialogue: 0,0:15:21.79,0:15:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, kau harus pulang dengan selamat.
Dialogue: 0,0:15:25.54,0:15:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:15:29.55,0:15:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kau tak tiba-tiba gugup,\NDr. Senku.
Dialogue: 0,0:15:35.10,0:15:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang bicara sembarangan.
Dialogue: 0,0:15:37.56,0:15:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya pertarungan kita\Ndengan Why-Man tiba.
Dialogue: 0,0:15:40.48,0:15:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak dikira,
Dialogue: 0,0:15:42.52,0:15:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sainsku dan Stanley, kemampuan tarungmu,
Dialogue: 0,0:15:45.73,0:15:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kembali bersatu untuk berperang bersama.
Dialogue: 0,0:15:49.40,0:15:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak diduga, bukan cuma kita berdua.
Dialogue: 0,0:15:56.70,0:15:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Senku dan semuanya…
Dialogue: 0,0:16:00.20,0:16:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, seluruh dunia ada bersama kita.
Dialogue: 0,0:16:06.88,0:16:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, di luar angkasa\Ntak boleh merokok.
Dialogue: 0,0:16:11.09,0:16:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini tembakau kunyah spesial\Nyang berbentuk seperti rokok.
Dialogue: 0,0:16:14.09,0:16:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Seharusnya bisa dipakai sementara.
Dialogue: 0,0:16:18.60,0:16:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohaku, ilmu bela dirimu,
Dialogue: 0,0:16:21.93,0:16:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Stanley, keahlian menembakmu…
Dialogue: 0,0:16:25.27,0:16:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pertarungan di bulan\Nkita hanya bisa mengirim dua orang,
Dialogue: 0,0:16:28.36,0:16:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada tim yang lebih baik.
Dialogue: 0,0:16:31.61,0:16:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau mencuri tiketku\Nke luar angkasa,
Dialogue: 0,0:16:34.41,0:16:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stanley, tugasmu adalah menang
Dialogue: 0,0:16:36.78,0:16:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melawan Why-Man dan pulang,\Napa pun yang terjadi. Apa aku salah?
Dialogue: 0,0:16:41.66,0:16:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan…
Dialogue: 0,0:16:45.04,0:16:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa?
Dialogue: 0,0:16:50.55,0:16:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku bisa.
Dialogue: 0,0:16:53.72,0:16:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak bisa!
Dialogue: 0,0:16:56.14,0:17:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku tak bisa! Akhirnya aku bisa\Nbertemu Senku setelah lama sekali!
Dialogue: 0,0:17:00.26,0:17:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Terlalu berbahaya!\NJangan pergi ke luar angkasa!
Dialogue: 0,0:17:02.93,0:17:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi bukannya aku takut atau apa pun.
Dialogue: 0,0:17:05.56,0:17:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Justru aku khawatir\Nkalau agak terlalu tenang.
Dialogue: 0,0:17:10.73,0:17:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku, kau bisa kembali\Ntanpa ada masalah, 'kan?
Dialogue: 0,0:17:14.24,0:17:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, jangan khawatir.
Dialogue: 0,0:17:16.45,0:17:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdasarkan sejarah, tingkat kematian\Ndi luar angkasa sebesar lima persen.
Dialogue: 0,0:17:20.66,0:17:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana itu bisa membuatku tenang?
Dialogue: 0,0:17:23.66,0:17:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya… Benar juga…
Dialogue: 0,0:17:26.83,0:17:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sedang senang,\Nkarena akhirnya kita bisa pergi ke bulan.
Dialogue: 0,0:17:30.67,0:17:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana kalau terjadi hal buruk,\Nseperti roket-roket sebelumnya?
Dialogue: 0,0:17:39.76,0:17:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa! Sungguh!
Dialogue: 0,0:17:43.89,0:17:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka akan\Nmembatu selama di dalam sana, 'kan?
Dialogue: 0,0:17:47.77,0:17:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun peluncurannya gagal\Ndan mereka hancur berkeping-keping,
Dialogue: 0,0:17:51.44,0:17:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa mengumpulkan pecahannya,\Nmenempelnya, dan membangkitkan mereka.
Dialogue: 0,0:17:58.07,0:18:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali tak terdengar realistis.
Dialogue: 0,0:18:00.24,0:18:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Taiju yang berotak dangkal\Ntak merasa yakin.
Dialogue: 0,0:18:04.87,0:18:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:18:07.29,0:18:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa…
Dialogue: 0,0:18:12.42,0:18:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan gagal!
Dialogue: 0,0:18:14.71,0:18:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun gagal,\Nakan kukumpulkan pecahan batunya,
Dialogue: 0,0:18:18.18,0:18:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}walau perlu puluhan tahun!
Dialogue: 0,0:18:20.14,0:18:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuzuriha akan menempelkan semuanya,\Napa pun yang terjadi!
Dialogue: 0,0:18:24.52,0:18:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ahli dalam tugas merepotkan,\Njadi mungkin kau bisa berhasil.
Dialogue: 0,0:18:28.48,0:18:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan "mungkin," Senku.
Dialogue: 0,0:18:30.98,0:18:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti. Pasti kami bisa,\Napa pun yang terjadi.
Dialogue: 0,0:18:36.28,0:18:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mungkin kau benar.
Dialogue: 0,0:18:40.70,0:18:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang tinggal di Bumi\Nhanya bisa memberi dukungan.
Dialogue: 0,0:18:44.70,0:18:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengandalkan kalian.
Dialogue: 0,0:18:46.25,0:18:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku!
Dialogue: 0,0:18:49.79,0:18:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Stanley!\N- Kohaku!
Dialogue: 0,0:18:54.67,0:18:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau Kaseki?
Dialogue: 0,0:18:57.17,0:18:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:00.93,0:19:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Joel?
Dialogue: 0,0:19:04.68,0:19:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, kita bisa\Nbersulang untuk hari ini,
Dialogue: 0,0:19:07.68,0:19:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai sesama insinyur di Dunia Batu ini.
Dialogue: 0,0:19:16.69,0:19:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasang baterai pertama kali\Ndalam beberapa tahun!
Dialogue: 0,0:19:19.24,0:19:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya bangkit, Medusa.
Dialogue: 0,0:19:22.74,0:19:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Telaten sekali!\N- Mereka cepat sekali saat bekerja sama!
Dialogue: 0,0:19:28.54,0:19:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari peradaban Zaman Batu
Dialogue: 0,0:19:30.71,0:19:32.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Dunia Batu ini
Dialogue: 0,0:19:32.88,0:19:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai membangun roket\Ndan mengincar bulan.
Dialogue: 0,0:19:36.09,0:19:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, proyek yang amat besar ini
Dialogue: 0,0:19:38.55,0:19:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memasuki tahap akhirnya.
Dialogue: 0,0:19:42.43,0:19:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menaiki roket
Dialogue: 0,0:19:44.30,0:19:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah pemimpin ilmiah kita,\NSenku Ishigami.
Dialogue: 0,0:19:48.27,0:19:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petarung terkuat\Ndan tercepat kita, Kohaku.
Dialogue: 0,0:19:51.69,0:19:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta pilot hebat dan ahli menembak kita,
Dialogue: 0,0:19:54.48,0:19:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stanley Snyder.
Dialogue: 0,0:20:08.16,0:20:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima meter, satu detik.
Dialogue: 0,0:20:12.41,0:20:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu cahaya Medusa.
Dialogue: 0,0:20:14.83,0:20:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya keji yang dulu\Nhampir memunahkan umat manusia
Dialogue: 0,0:20:18.63,0:20:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}digunakan sebagai sumber tenaga yang vital
Dialogue: 0,0:20:21.88,0:20:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sangat penting untuk\Nkeberangkatan kita dari Bumi.
Dialogue: 0,0:20:26.47,0:20:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sebelumnya Medusa\Npernah menyala sendiri. Ingat, 'kan?
Dialogue: 0,0:20:30.89,0:20:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau itu terulang lagi?
Dialogue: 0,0:20:33.56,0:20:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak tahu penyebabnya\Ndan tak bisa mengulang situasi itu.
Dialogue: 0,0:20:37.48,0:20:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa adanya pilihan alternatif,
Dialogue: 0,0:20:39.23,0:20:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus mengambil risiko\Nmengaktifkannya selama beberapa hari.
Dialogue: 0,0:20:43.24,0:20:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita hanya bisa berdoa.
Dialogue: 0,0:20:47.49,0:20:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya.
Dialogue: 0,0:20:49.24,0:20:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengganti ke tenaga internal.
Dialogue: 0,0:20:52.12,0:20:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tekanan tangki, normal.\N- Mulai pelepasan air.
Dialogue: 0,0:21:00.63,0:21:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh sistem siap.
Dialogue: 0,0:21:03.42,0:21:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam puluh detik sampai peluncuran.
Dialogue: 0,0:21:07.43,0:21:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang menunggu mereka di bulan?
Dialogue: 0,0:21:11.72,0:21:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hampir waktu peluncuran!
Dialogue: 0,0:21:19.11,0:21:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyalakan mesin utama.
Dialogue: 0,0:21:22.07,0:21:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sepuluh, sembilan, delapan, tujuh, enam…{\i0}
Dialogue: 0,0:21:27.99,0:21:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mesin pendorong dinyalakan.{\i0}
Dialogue: 0,0:21:30.74,0:21:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dunia sangat sunyi saat kita membatu.{\i0}
Dialogue: 0,0:21:34.45,0:21:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita tak bisa mendengar\Napa pun yang terjadi di luar sana.{\i0}
Dialogue: 0,0:21:37.50,0:21:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Getaran pun tak terasa.{\i0}
Dialogue: 0,0:21:41.17,0:21:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau Xeno mengatur\Nsemuanya sesuai rencana…{\i0}
Dialogue: 0,0:21:44.21,0:21:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, pasti dia sedang melakukannya.{\i0}
Dialogue: 0,0:21:47.43,0:21:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang artinya kita punya{\i0}
Dialogue: 0,0:21:49.51,0:21:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lima detik.{\i0}
Dialogue: 0,0:21:52.47,0:21:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku teringat masa lalu.{\i0}
Dialogue: 0,0:21:54.89,0:21:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sejak hari saat aku terkena Sinar Pembatu,{\i0}
Dialogue: 0,0:22:00.06,0:22:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku terus menerus{\i0}
Dialogue: 0,0:22:02.27,0:22:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menghitung detik selama 3.700 tahun.{\i0}
Dialogue: 0,0:22:05.86,0:22:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sekarang, aku menghitung mundur.{\i0}
Dialogue: 0,0:22:10.91,0:22:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tiga, dua, satu.{\i0}
Dialogue: 0,0:22:15.50,0:22:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan pengetahuan umat manusia,{\i0}
Dialogue: 0,0:22:17.87,0:22:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan sains,{\i0}
Dialogue: 0,0:22:21.79,0:22:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kita sudah membalikkan pembatuan dunia,{\i0}
Dialogue: 0,0:22:24.92,0:22:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan sekarang kita akan meluncur{\i0}
Dialogue: 0,0:22:28.68,0:22:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dari Bumi yang sama.{\i0}
Dialogue: 0,0:22:31.26,0:22:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luncurkan.
Dialogue: 0,0:23:23.52,0:23:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua perhitungan tak ada masalah.
Dialogue: 0,0:23:25.98,0:23:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih dalam batas kesalahan.\NPeluncurannya berhasil!
Dialogue: 0,0:23:34.07,0:23:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Periksa ulang perhitungan lintasannya.
Dialogue: 0,0:23:36.79,0:23:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganti layar ke mode monitor.
Dialogue: 0,0:24:01.02,0:24:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
