Dialogue: 0,0:00:33.19,0:00:36.66,sign,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:03:24.87,0:03:25.78,sign,,0000,0000,0000,,{\an8}LABORATORIUM
Dialogue: 0,0:03:38.50,0:03:39.46,sign,,0000,0000,0000,,ASAM SULFAT, FLUORIT, AIR LAUT, MAGNESIUM
Dialogue: 0,0:03:51.27,0:03:52.60,sign,,0000,0000,0000,,PANEL SURYA DIPEROLEH!
Dialogue: 0,0:04:22.88,0:04:25.05,sign,,0000,0000,0000,,LANDASAN PELUNCURAN DIPEROLEH!
Dialogue: 0,0:04:33.10,0:04:35.60,sign,,0000,0000,0000,,ROKET NIRAWAK DIPEROLEH!
Dialogue: 0,0:04:44.49,0:04:46.91,sign,,0000,0000,0000,,MESIN ROKET LEVEL 99 DIPEROLEH!
Dialogue: 0,0:06:29.01,0:06:31.43,sign,,0000,0000,0000,,{\an8}MINGGU, SENIN, SELASA,\NRABU, KAMIS, JUMAT, SABTU
Dialogue: 0,0:07:46.38,0:07:47.38,sign,,0000,0000,0000,,SEPTEMBER 5753 M
Dialogue: 0,0:07:47.38,0:07:48.80,sign,,0000,0000,0000,,OCTOBER 5753 M
Dialogue: 0,0:09:45.45,0:09:48.04,sign,,0000,0000,0000,,SATELIT BUATAN DIPEROLEH!
Dialogue: 0,0:11:37.94,0:11:40.49,sign,,0000,0000,0000,,PERSEUS INDIA, PERSEUS SPANYOL
Dialogue: 0,0:11:59.63,0:12:02.09,sign,,0000,0000,0000,,TELESKOP LUAR ANGKASA DIPEROLEH!
Dialogue: 0,0:15:14.87,0:15:16.95,sign,,0000,0000,0000,,LABORATORIUM
Dialogue: 0,0:16:01.54,0:16:03.79,sign,,0000,0000,0000,,PUSAT KONFERENSI SAINS
Dialogue: 0,0:16:03.79,0:16:05.67,sign,,0000,0000,0000,,{\an8}ILMUWAN PEMULA VS ILMUWAN SUPER
Dialogue: 0,0:20:25.59,0:20:26.80,sign,,0000,0000,0000,,{\an8}PUSAT KONFERENSI SAINS
Dialogue: 0,0:20:38.82,0:20:40.07,sign,,0000,0000,0000,,{\an8}MENANG - 2 WAY
Dialogue: 0,0:20:53.91,0:20:56.29,sign,,0000,0000,0000,,PUSAT KONFERENSI SAINS
Dialogue: 0,0:23:53.34,0:23:56.01,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:56.01,0:23:57.51,sign,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA,
Dialogue: 0,0:23:57.51,0:23:59.27,sign,,0000,0000,0000,,MATERIAL, DAN METODENYA\NDIDASARKAN PADA KENYATAAN
Dialogue: 0,0:23:59.27,0:24:01.02,sign,,0000,0000,0000,,MOHON JANGAN DICOBA\NKARENA BISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:02.62,0:00:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat melihat bintang lewat teleskop,
Dialogue: 0,0:00:05.08,0:00:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}halangan terbesarnya adalah
Dialogue: 0,0:00:08.00,0:00:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atmosfer
Dialogue: 0,0:00:10.21,0:00:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan cuaca Bumi.
Dialogue: 0,0:00:13.97,0:00:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi, maksudmu, kita harus\Nmengirim teleskopnya ke luar angkasa
Dialogue: 0,0:00:17.01,0:00:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}untuk menemukan lokasi Why-Man di bulan?
Dialogue: 0,0:00:20.10,0:00:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Kita akan\Nmeluncurkan satelit buatan
Dialogue: 0,0:00:24.35,0:00:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke langit,
Dialogue: 0,0:00:26.44,0:00:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar bisa menatap langsung ke bulan.
Dialogue: 0,0:02:05.54,0:02:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Satelit…\N- Buatan?
Dialogue: 0,0:02:08.08,0:02:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa akan terbang\Ndi langit seperti pesawat?
Dialogue: 0,0:02:11.25,0:02:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia akan selalu terbang\Nsambil mencari Why-Man?
Dialogue: 0,0:02:14.96,0:02:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah bahan bakarnya akan cepat habis?
Dialogue: 0,0:02:17.97,0:02:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara teknis,\Nsatelit buatan tak "terbang."
Dialogue: 0,0:02:22.60,0:02:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi "jatuh" ke Bumi.\N- Apa?
Dialogue: 0,0:02:27.18,0:02:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak! Aku jatuh ke Bumi!{\i0}
Dialogue: 0,0:02:30.94,0:02:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa? Tidak!{\i0}
Dialogue: 0,0:02:33.15,0:02:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sekarang aku jatuh ke sisi Bumi yang lain!{\i0}
Dialogue: 0,0:02:37.78,0:02:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya akan jatuh dan memutar-mutar?
Dialogue: 0,0:02:40.61,0:02:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya…
Dialogue: 0,0:02:41.74,0:02:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satelit buatan sangat edan\Ndan tak butuh bahan bakar.
Dialogue: 0,0:02:44.41,0:02:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren sekali!
Dialogue: 0,0:02:45.66,0:02:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi bukan berarti
Dialogue: 0,0:02:47.62,0:02:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu tak memerlukan energi.
Dialogue: 0,0:02:50.79,0:02:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengirim gambar dari bulan\Nke Bumi dan mengatur posisinya
Dialogue: 0,0:02:54.04,0:02:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membutuhkan tenaga listrik.
Dialogue: 0,0:02:56.42,0:02:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kita hanya perlu\Nmengisinya dengan baterai.
Dialogue: 0,0:02:59.22,0:03:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pasti baterainya\Njuga akan langsung habis.
Dialogue: 0,0:03:02.72,0:03:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, yang kita butuhkan adalah persediaan\Nenergi tak terbatas yang tak akan habis
Dialogue: 0,0:03:07.39,0:03:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di luar angkasa.
Dialogue: 0,0:03:09.23,0:03:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Untungnya,
Dialogue: 0,0:03:11.35,0:03:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}di luar angkasa, ada persediaan energi
Dialogue: 0,0:03:14.27,0:03:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}yang hampir tak terbatas\Nyang dikeluarkan matahari.
Dialogue: 0,0:03:17.86,0:03:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Energi…\N- Matahari?
Dialogue: 0,0:03:22.45,0:03:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sel surya!
Dialogue: 0,0:03:25.78,0:03:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Material baru yang digali\NKohaku dan lainnya di Kagoshima,
Dialogue: 0,0:03:29.12,0:03:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bernama selenium,\Nakan menjadi penyelamat lagi.
Dialogue: 0,0:03:34.00,0:03:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menempelkan lapisan-lapisan tipis ini\Nbisa mengubah cahaya menjadi energi.
Dialogue: 0,0:03:39.46,0:03:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini purwarupa awal,\Njadi efisiensinya luar biasa rendah,{\i0}
Dialogue: 0,0:03:43.34,0:03:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi kalau kita buat cukup besar,\Npasti bisa dipakai.{\i0}
Dialogue: 0,0:03:47.26,0:03:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Bisa menyala!
Dialogue: 0,0:03:52.60,0:03:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat… Hanya dengan kekuatan matahari…
Dialogue: 0,0:03:55.94,0:03:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, bagaimana saat hujan atau berawan?
Dialogue: 0,0:04:01.36,0:04:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak berpengaruh di luar angkasa.
Dialogue: 0,0:04:03.82,0:04:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, letaknya jauh di atas awan.
Dialogue: 0,0:04:07.45,0:04:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda besar ini
Dialogue: 0,0:04:08.95,0:04:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan mengapung di luar angkasa\Ndi mana matahari terus bersinar?
Dialogue: 0,0:04:12.58,0:04:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satelit buatan dengan\Npersediaan tenaga tak terbatas. Gila!
Dialogue: 0,0:04:54.33,0:04:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku,
Dialogue: 0,0:04:55.87,0:04:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sungguh roket yang elegan.
Dialogue: 0,0:05:01.21,0:05:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xeno, aku tak percaya
Dialogue: 0,0:05:02.84,0:05:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau menyelesaikan mesinnya\Nhanya dalam tiga tahun.
Dialogue: 0,0:05:06.88,0:05:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat khawatir kau kehilangan\Nkemampuanmu setelah tidur ribuan tahun.
Dialogue: 0,0:05:14.14,0:05:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, di sini, di Pulau Harta,
Dialogue: 0,0:05:16.48,0:05:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}roket pertama di dunia baru
Dialogue: 0,0:05:18.52,0:05:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan meluncurkan satelit buatan!
Dialogue: 0,0:05:20.94,0:05:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kau siarkan ini di TV,
Dialogue: 0,0:05:22.40,0:05:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sinyalnya tak akan\Nsampai ke dataran Jepang.
Dialogue: 0,0:05:25.53,0:05:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, 'kan? Ini sesuatu\Nyang aku sangat mau lakukan!
Dialogue: 0,0:05:29.16,0:05:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Insinyur roket terbaik di dunia,
Dialogue: 0,0:05:31.37,0:05:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dr. Xeno dari NASA.
Dialogue: 0,0:05:33.87,0:05:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, siswa SMA terbaik di dunia
Dialogue: 0,0:05:35.33,0:05:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan satu-satunya yang mengirim\Nroket buatan ke luar angkasa, Senku.
Dialogue: 0,0:05:45.88,0:05:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua kartu terkuat yang dimiliki dunia ini!
Dialogue: 0,0:05:48.93,0:05:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi pasangan guru dan murid ini,\Nmeluncurkan roket nirawak
Dialogue: 0,0:05:52.64,0:05:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangatlah mudah!
Dialogue: 0,0:06:13.62,0:06:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gas menyebabkan erosi\Npada lapisan insulasinya.
Dialogue: 0,0:06:17.29,0:06:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulut pipanya berlubang.
Dialogue: 0,0:06:18.83,0:06:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara teori, seharusnya tak ada masalah.
Dialogue: 0,0:06:22.34,0:06:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi komponen-komponen ini\Ndibuat di Dunia Batu,
Dialogue: 0,0:06:24.84,0:06:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi masalahnya ada pada presisi.
Dialogue: 0,0:06:43.15,0:06:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kesalahan pada perkabelan.
Dialogue: 0,0:06:45.32,0:06:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Yang benar saja? Sayang sekali…
Dialogue: 0,0:06:48.36,0:06:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serumit itulah perkabelannya.
Dialogue: 0,0:06:50.74,0:06:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecelakaan ini terjadi di dunia nyata,
Dialogue: 0,0:06:52.87,0:06:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan di abad ke-21.
Dialogue: 0,0:06:54.70,0:06:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah dengar,\Npernah terjadi kegagalan karena programnya
Dialogue: 0,0:06:58.25,0:07:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya kurang satu tanda hubung.
Dialogue: 0,0:07:11.05,0:07:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, gelembung dari\Nbahan bakar yang menguap
Dialogue: 0,0:07:13.72,0:07:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mematahkan sayap yang ada di dalam.
Dialogue: 0,0:07:51.38,0:07:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial… Aku mulai putus asa…
Dialogue: 0,0:07:55.34,0:07:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berapa tahun\Nkita mengerjakan roket ini?
Dialogue: 0,0:07:58.81,0:08:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mereka berdua bisa tahan?
Dialogue: 0,0:08:15.87,0:08:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi ke luar angkasa memang gila…
Dialogue: 0,0:08:18.45,0:08:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ahli roket terbaik di Bumi,\NSenku dan Xeno,
Dialogue: 0,0:08:22.83,0:08:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencoba tanpa henti,\Nterus menguji dan gagal berulang kali
Dialogue: 0,0:08:26.96,0:08:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama bertahun-tahun!
Dialogue: 0,0:08:28.59,0:08:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita memperhatikannya
Dialogue: 0,0:08:29.96,0:08:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mempelajari kemampuan mereka.
Dialogue: 0,0:08:32.72,0:08:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mempelajari apa kesalahannya\Ndan bagaimana cara memperbaikinya…
Dialogue: 0,0:08:37.01,0:08:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, inilah nasib seorang pengguna sains…
Dialogue: 0,0:08:40.01,0:08:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begini\Nsejak hari pertama aku bertemu Senku.
Dialogue: 0,0:08:43.89,0:08:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin banyak yang kupelajari,
Dialogue: 0,0:08:46.23,0:08:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makin aku menyadari\Nseberapa banyak yang tak kuketahui.
Dialogue: 0,0:09:33.07,0:09:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, peluncuran sukses kita\Nyang pertama!
Dialogue: 0,0:09:35.57,0:09:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sekarang kita bisa menatap
Dialogue: 0,0:09:37.11,0:09:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}ke bulan dan mencari Why-Man, 'kan?
Dialogue: 0,0:09:39.49,0:09:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Sebenarnya, tidak.\N- Kita mulai dengan satelit pengintai
Dialogue: 0,0:09:42.99,0:09:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sederhana, tapi elegan.
Dialogue: 0,0:09:48.04,0:09:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bahkan saat menyangkut luar angkasa,
Dialogue: 0,0:09:49.92,0:09:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}kita akan jalani selangkah demi selangkah.
Dialogue: 0,0:09:51.38,0:09:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sudah pasti…
Dialogue: 0,0:09:53.46,0:09:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sungguh gila kalau kita\Nmulai dengan manusia.
Dialogue: 0,0:09:55.84,0:09:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa orang yang akan mati\Ndalam semua roket yang kita ledakkan?
Dialogue: 0,0:10:00.80,0:10:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, karena itu
Dialogue: 0,0:10:02.85,0:10:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Dunia Batu ini,
Dialogue: 0,0:10:04.56,0:10:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melakukan peluncuran\Ndan membangun roket yang tak terhitung,
Dialogue: 0,0:10:08.52,0:10:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada pilihan selain\Nmembuatnya berukuran kecil.
Dialogue: 0,0:10:12.52,0:10:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jenis roket yang Chrome\Ndan Suika mau bangun
Dialogue: 0,0:10:15.32,0:10:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bisa pergi ke bulan dan kembali
Dialogue: 0,0:10:18.15,0:10:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus dibuat lima kali lebih besar,
Dialogue: 0,0:10:21.07,0:10:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu kata Sai terakhir kali\Ndia memperhitungkannya.
Dialogue: 0,0:10:38.80,0:10:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambar satelit!
Dialogue: 0,0:10:40.59,0:10:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini planet Bumi kita\Nkalau dilihat dari luar angkasa, ya?
Dialogue: 0,0:10:45.64,0:10:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang terlihat\Nselama kita keliling dunia,
Dialogue: 0,0:10:48.02,0:10:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}geografinya sudah berubah\Nselama 3.700 tahun terakhir.
Dialogue: 0,0:10:51.19,0:10:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa kau dapat informasi dari ini?
Dialogue: 0,0:10:53.11,0:10:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali informasi!\NGila! Edan sekali!
Dialogue: 0,0:10:55.94,0:10:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terusan Panama tertutup rapat! Asyik!
Dialogue: 0,0:11:01.07,0:11:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya kita tak lewat sana.
Dialogue: 0,0:11:02.91,0:11:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gurun-gurun di Afrika
Dialogue: 0,0:11:04.58,0:11:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah menjadi padang rumput dan hutan.
Dialogue: 0,0:11:07.66,0:11:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang berarti bisa\Ndijadikan ladang yang luas!
Dialogue: 0,0:11:12.25,0:11:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kurasa tak semua\Nperubahan geografis itu buruk!
Dialogue: 0,0:11:15.67,0:11:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk eksplorasi antariksa\Nkita nanti, kita akan butuh
Dialogue: 0,0:11:18.63,0:11:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebanyak tenaga manusia\Nyang bisa kita dapatkan.
Dialogue: 0,0:11:20.76,0:11:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Dengan menggunakan\Nbola dunia baru yang akurat,
Dialogue: 0,0:11:24.47,0:11:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita perlu kalian mengoordinasikan\Njadwal untuk membangkitkan
Dialogue: 0,0:11:28.35,0:11:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tujuh miliar orang.
Dialogue: 0,0:11:31.02,0:11:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusui, yang terlatih\Ndalam soal kepemimpinan,
Dialogue: 0,0:11:33.48,0:11:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Chelsea, sang ahli geografi,\Nakan mengerjakannya bersama.
Dialogue: 0,0:12:02.68,0:12:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini aku bisa\Nmelihat permukaan bulan!
Dialogue: 0,0:12:06.14,0:12:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan penglihatanku yang bagus,
Dialogue: 0,0:12:08.60,0:12:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa menemukan Why-Man…
Dialogue: 0,0:12:10.14,0:12:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sayangnya, gambar-gambar itu\Ndikirim hanya sebagai data.
Dialogue: 0,0:12:14.56,0:12:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Penglihatan bagus tak akan ada bedanya.
Dialogue: 0,0:12:18.52,0:12:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, itu tak benar.
Dialogue: 0,0:12:20.82,0:12:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, dia pernah berhasil\Nmenemukan titik hitam
Dialogue: 0,0:12:24.57,0:12:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di foto udara dan menemukan ladang minyak.
Dialogue: 0,0:12:27.78,0:12:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsentrasi dan sifat telaten Kohaku
Dialogue: 0,0:12:30.66,0:12:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah yang membuat matanya begitu kuat.
Dialogue: 0,0:12:34.25,0:12:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:12:36.42,0:12:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang keturunan Byakuya\Ndan para astronaut.
Dialogue: 0,0:12:40.88,0:12:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia punya bakat\Ndalam eksplorasi luar angkasa.
Dialogue: 0,0:12:47.47,0:12:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita bisa\Nmenemukan Why-Man. Baguslah.
Dialogue: 0,0:12:51.72,0:12:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau Kohaku menemukan Why-Man,
Dialogue: 0,0:12:54.81,0:12:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rancangan roket satu arah akan dijalankan.
Dialogue: 0,0:12:58.06,0:13:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan Why-Man!\NAyo kita serang sekarang!
Dialogue: 0,0:13:01.03,0:13:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:13:03.74,0:13:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:13:05.57,0:13:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}artinya sekarang kita punya\Nbatas waktu yang tetap.
Dialogue: 0,0:13:08.62,0:13:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hanya perlu menyelesaikan\Nrancangan roket pulang pergi kita
Dialogue: 0,0:13:12.16,0:13:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum saat itu tiba.
Dialogue: 0,0:13:16.83,0:13:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Walau begitu, kita harus\Nmembangun roket pulang pergi{\i0}
Dialogue: 0,0:13:19.59,0:13:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang berukuran lima kali lebih besar\Ndan mengujinya berulang kali…{\i0}
Dialogue: 0,0:13:24.17,0:13:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berapa puluh tahun\Nyang akan kita habiskan?{\i0}
Dialogue: 0,0:13:27.26,0:13:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gila. Kita harus bagaimana?{\i0}
Dialogue: 0,0:13:49.11,0:13:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku! Xeno!
Dialogue: 0,0:13:54.91,0:13:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini!
Dialogue: 0,0:13:58.46,0:13:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku,
Dialogue: 0,0:13:59.83,0:14:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini tampak seperti bentuk\Nyang selalu sedikit berubah-ubah
Dialogue: 0,0:14:04.92,0:14:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu apa ini tepatnya,
Dialogue: 0,0:14:08.63,0:14:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sebagai ilmuwan NASA, aku bisa jamin
Dialogue: 0,0:14:12.14,0:14:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini bukan ciri alami dari permukaan bulan.
Dialogue: 0,0:14:16.68,0:14:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh elegan…
Dialogue: 0,0:14:20.52,0:14:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, kami menemukanmu.
Dialogue: 0,0:14:26.65,0:14:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Why-Man.
Dialogue: 0,0:14:30.45,0:14:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini dalang misterius yang memegang\Nkunci pembatuan umat manusia.
Dialogue: 0,0:14:41.38,0:14:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggulah, Why-Man!
Dialogue: 0,0:14:44.46,0:14:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini artinya kita bisa lebih dulu\Nmelancarkan serangan terhadap Why-Man
Dialogue: 0,0:14:48.13,0:14:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan langsung bertindak, 'kan?
Dialogue: 0,0:14:50.55,0:14:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kalau kita pakai roket satu arah\Ndan membatukan diri sesuai rencana.
Dialogue: 0,0:14:55.06,0:14:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lega rasanya…
Dialogue: 0,0:14:56.43,0:14:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berhasil menemukan Why-Man.
Dialogue: 0,0:14:59.69,0:15:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, mereka akan\Nmeluncurkan roket satu arah.
Dialogue: 0,0:15:03.81,0:15:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua gagal menyelesaikan
Dialogue: 0,0:15:07.82,0:15:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}roket pulang pergi kita tepat waktu.
Dialogue: 0,0:15:16.95,0:15:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya sekarang kita akan
Dialogue: 0,0:15:18.37,0:15:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuat roket yang bisa dinaiki orang?
Dialogue: 0,0:15:21.71,0:15:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan perlu menyatukan
Dialogue: 0,0:15:23.96,0:15:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua orang secara global,\Nmenggunakan bola dunia yang baru.
Dialogue: 0,0:15:26.96,0:15:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini akan
Dialogue: 0,0:15:30.34,0:15:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memerlukan semua orang\Nuntuk bersatu secara universal!
Dialogue: 0,0:15:33.72,0:15:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah keahlian Kerajaan Sains.
Dialogue: 0,0:15:35.89,0:15:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah hasil akhir dari semua usaha kita!
Dialogue: 0,0:15:40.89,0:15:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bersatu secara universal"?
Dialogue: 0,0:15:43.81,0:15:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:46.23,0:15:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku dapat ide! Akhirnya!
Dialogue: 0,0:15:50.15,0:15:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide untuk roket pulang pergi
Dialogue: 0,0:15:52.95,0:15:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan semuanya bisa kembali\Nke Bumi hidup-hidup!
Dialogue: 0,0:16:05.67,0:16:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa-apaan ini?
Dialogue: 0,0:16:07.67,0:16:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Baiklah, semuanya dengar!
Dialogue: 0,0:16:09.13,0:16:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kami mau buat
Dialogue: 0,0:16:10.97,0:16:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan roket satu arah\Nuntuk serangan khusus!
Dialogue: 0,0:16:14.43,0:16:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi roket pulang pergi
Dialogue: 0,0:16:15.84,0:16:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk akhir bahagia semua orang!
Dialogue: 0,0:16:21.43,0:16:24.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Begini… Chrome, Suika…
Dialogue: 0,0:16:24.94,0:16:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku yakin kita semua\Nlebih memilih itu, tapi…
Dialogue: 0,0:16:28.86,0:16:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua paham, 'kan?
Dialogue: 0,0:16:31.24,0:16:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roket pulang pergi harus\Nberukuran luar biasa besar
Dialogue: 0,0:16:34.49,0:16:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kita harus mengulang\Nsemua uji peluncuran kita.
Dialogue: 0,0:16:37.32,0:16:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risiko dan waktu yang diperlukan\Njuga akan menjadi lima kali lipat.
Dialogue: 0,0:16:39.70,0:16:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, akan butuh beberapa dekade.
Dialogue: 0,0:16:43.00,0:16:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu Chrome sudah menghabiskan
Dialogue: 0,0:16:44.75,0:16:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setahun ini dengan berpikir\Nsangat amat keras tentang
Dialogue: 0,0:16:47.92,0:16:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kita bisa\Npergi ke bulan dan kembali
Dialogue: 0,0:16:50.17,0:16:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam roket kecil\Nyang saat ini kita gunakan.
Dialogue: 0,0:16:52.63,0:16:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, lihatlah trik gila yang kami,
Dialogue: 0,0:16:56.55,0:16:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tim Ilmuwan Pemula, pikirkan!
Dialogue: 0,0:16:59.97,0:17:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ambil pesawat antariksa gila
Dialogue: 0,0:17:01.89,0:17:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang cukup besar\Nuntuk pulang pergi ke bulan
Dialogue: 0,0:17:04.73,0:17:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kita luncurkan\Ndalam lima bagian terpisah.
Dialogue: 0,0:17:07.06,0:17:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Lalu, kita gabungkan
Dialogue: 0,0:17:08.73,0:17:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}semuanya di luar angkasa!
Dialogue: 0,0:17:12.86,0:17:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin itu bisa dilakukan…\NYang benar saja…
Dialogue: 0,0:17:17.66,0:17:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu apa-apa soal luar angkasa,
Dialogue: 0,0:17:21.37,0:17:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku pun tahu kalau ini\Nsalah satu dari ide gila Chrome.
Dialogue: 0,0:17:25.62,0:17:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Benar, Senku dan Xeno?
Dialogue: 0,0:17:30.54,0:17:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stasiun antariksa\Nyang ditempati Byakuya dan krunya
Dialogue: 0,0:17:34.38,0:17:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diluncurkan dalam komponen terpisah
Dialogue: 0,0:17:36.68,0:17:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan disusun di luar angkasa,\Nseperti katamu.
Dialogue: 0,0:17:38.76,0:17:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa! Jadi, kau sudah tahu soal ini? Sial!
Dialogue: 0,0:17:42.72,0:17:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bukan trik baru…
Dialogue: 0,0:17:45.93,0:17:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak ada bedanya\Nkalau kami tahu atau tidak.
Dialogue: 0,0:17:49.15,0:17:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide gila seperti itu sepuluh miliar persen
Dialogue: 0,0:17:52.98,0:17:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mustahil bagi Xeno dan aku.
Dialogue: 0,0:17:55.44,0:17:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, ide meluncurkan\Nkapal antariksa dalam bagian terpisah
Dialogue: 0,0:17:59.07,0:18:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sempat dipertimbangkan oleh NASA.
Dialogue: 0,0:18:01.95,0:18:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada kecacatan fatal dalam desainnya.
Dialogue: 0,0:18:06.21,0:18:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal antariksa yang bisa pulang pergi\Nke luar angkasa cukup rumit.
Dialogue: 0,0:18:09.29,0:18:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merancang kapal\Nyang bisa dibagi dan disusun kembali.
Dialogue: 0,0:18:12.34,0:18:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membutuhkan jutaan komponen.
Dialogue: 0,0:18:17.93,0:18:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi sebaliknya, itu berarti
Dialogue: 0,0:18:21.47,0:18:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau semua orang\Ndi dunia baru bersungguh-sungguh
Dialogue: 0,0:18:25.02,0:18:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merancang\Njutaan komponen bersama-sama,
Dialogue: 0,0:18:27.43,0:18:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu mungkin dilakukan.
Dialogue: 0,0:18:30.90,0:18:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa aku salah?
Dialogue: 0,0:18:32.19,0:18:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusui mulai lagi, menginginkan segalanya.
Dialogue: 0,0:18:36.78,0:18:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Untuk jaga-jaga, perhitungan\Nuntuk peluncurannya sudah kulakukan.
Dialogue: 0,0:18:39.78,0:18:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara teori, itu mungkin dilakukan…
Dialogue: 0,0:18:42.12,0:18:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang ide yang elegan,\Ntapi aku tak bisa bilang ini realistis.
Dialogue: 0,0:18:46.29,0:18:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kita semua bekerja keras…
Dialogue: 0,0:18:48.83,0:18:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kita semua adalah teman!
Dialogue: 0,0:18:51.08,0:18:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kita tanya\Npada semuanya mana yang mereka pilih.
Dialogue: 0,0:18:55.84,0:18:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita lakukan itu,\Nsemua orang akan tahu soal rahasia
Dialogue: 0,0:18:58.92,0:19:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di balik alat pembatuan.
Dialogue: 0,0:19:00.80,0:19:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tanya pada orang\Nyang menjadi bagian rapat ini sekarang!
Dialogue: 0,0:19:08.48,0:19:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ini cuma tim Ilmuwan Pemula… Sial…
Dialogue: 0,0:19:13.77,0:19:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sepuluh miliar persen\Nmustahil bagiku untuk tahu semuanya.
Dialogue: 0,0:19:17.78,0:19:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau benar-benar tak ada pilihan
Dialogue: 0,0:19:19.44,0:19:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selain membuat roket satu arah\Ntanpa cara untuk kembali, aku akan diam.
Dialogue: 0,0:19:23.87,0:19:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau ada sedikit pun kemungkinannya…
Dialogue: 0,0:19:27.70,0:19:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lakukan voting untuk
Dialogue: 0,0:19:29.37,0:19:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}roket satu arah dan roket pulang pergi\Ndan lihat mana yang menang!
Dialogue: 0,0:19:33.33,0:19:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu arti dari\Nmenyatukan Kerajaan Sains
Dialogue: 0,0:19:36.46,0:19:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berhasil sebagai tim?
Dialogue: 0,0:19:53.02,0:19:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini voting demokratis\Npertama di Dunia Batu, ya?
Dialogue: 0,0:19:56.40,0:19:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memrogram sistem voting.
Dialogue: 0,0:19:58.98,0:20:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:20:01.45,0:20:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sistem voting.
Dialogue: 0,0:20:04.41,0:20:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"1 way"{\i0} untuk roket satu arah,\N{\i1}"2 way"{\i0} untuk roket pulang pergi.
Dialogue: 0,0:20:07.58,0:20:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau menekan tombol mana pun,\Nsuara anonim akan dihasilkan.
Dialogue: 0,0:20:12.04,0:20:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan curang, ya.
Dialogue: 0,0:20:15.04,0:20:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir soal itu. Senku,
Dialogue: 0,0:20:17.88,0:20:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama sepertimu\Nyang tak pernah tak jujur pada sains,
Dialogue: 0,0:20:21.42,0:20:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai juga tak akan pernah\Ntak jujur pada pemrograman.
Dialogue: 0,0:20:26.80,0:20:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hasilnya sudah keluar!
Dialogue: 0,0:20:28.68,0:20:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita akan\Nmembuat kapal antariksa {\i1}"1 way"{\i0}
Dialogue: 0,0:20:33.31,0:20:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kapal antariksa {\i1}"2 way"{\i0}?
Dialogue: 0,0:20:40.07,0:20:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenangnya adalah
Dialogue: 0,0:20:41.69,0:20:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"2 way"{\i0} untuk roket pulang pergi!
Dialogue: 0,0:20:45.91,0:20:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah diputuskan!
Dialogue: 0,0:20:47.95,0:20:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan coba-coba batalkan hasilnya, ya!
Dialogue: 0,0:20:51.12,0:20:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tak akan.
Dialogue: 0,0:20:56.88,0:20:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dapat pekerjaan\Nyang luar biasa besar.
Dialogue: 0,0:20:59.63,0:21:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan bekerja sangat keras
Dialogue: 0,0:21:01.38,0:21:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membantu sebisa mungkin!
Dialogue: 0,0:21:08.35,0:21:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:21:09.64,0:21:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun anonim, seharusnya aku\Nmenunjukkan jumlah suaranya.
Dialogue: 0,0:21:41.80,0:21:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan
Dialogue: 0,0:21:44.05,0:21:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mendengar sesuatu yang sangat gila.
Dialogue: 0,0:21:49.51,0:21:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau dengar, ya?\NTelingamu memang hebat.
Dialogue: 0,0:21:54.18,0:21:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau merancang roket yang bisa\Ndigabung dengan semua orang di dunia,
Dialogue: 0,0:21:57.85,0:22:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada sesuatu yang kita perlukan.
Dialogue: 0,0:22:00.36,0:22:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang…
Dialogue: 0,0:22:02.86,0:22:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Benar, di Dunia Batu ini,
Dialogue: 0,0:22:09.11,0:22:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan membuat internet!
Dialogue: 0,0:22:11.66,0:22:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudah kuduga! Akhirnya waktunya tiba!
Dialogue: 0,0:24:01.02,0:24:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
