Dialogue: 0,0:00:45.21,0:00:49.50,tanda,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:09:01.37,0:09:04.50,tanda,,0000,0000,0000,,{\an8}SIRKUIT ADDER DIPEROLEH!
Dialogue: 0,0:10:35.34,0:10:37.84,tanda,,0000,0000,0000,,PARAMETRON - SIRKUIT ADDER - KALKULATOR
Dialogue: 0,0:10:37.92,0:10:40.51,tanda,,0000,0000,0000,,{\an8}PEMROGRAMAN - NES - TUJUAN\NSUPERKOMPUTER PARAMETRON
Dialogue: 0,0:13:47.40,0:13:48.24,tanda,,0000,0000,0000,,‎NERAKA
Dialogue: 0,0:16:01.00,0:16:03.62,tanda,,0000,0000,0000,,MESIN FAKS SUNGGUHAN DIPEROLEH!
Dialogue: 0,0:22:05.49,0:22:09.82,tanda,,0000,0000,0000,,SAI BERGABUNG DENGAN TIM!
Dialogue: 0,0:23:53.26,0:23:55.93,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:56.01,0:23:58.43,tanda,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA, BAHAN,\NDAN METODENYA BERDASARKAN KENYATAAN
Dialogue: 0,0:23:58.52,0:24:00.93,tanda,,0000,0000,0000,,MOHON JANGAN DICOBA KARENA\NBISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:06.08,0:00:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kurasa sudah sekitar\Ndelapan tahun sejak aku membatu.{\i0}
Dialogue: 0,0:00:12.42,0:00:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak seperti Senku,{\i0}
Dialogue: 0,0:00:14.97,0:00:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku tak bisa\Nmenghitung detik yang berlalu,{\i0}
Dialogue: 0,0:00:18.22,0:00:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi aku mau tetap terjaga{\i0}
Dialogue: 0,0:00:20.31,0:00:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sampai akhir…{\i0}
Dialogue: 0,0:00:23.73,0:00:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena Senku{\i0}
Dialogue: 0,0:00:25.81,0:00:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan Taiju…{\i0}
Dialogue: 0,0:00:27.69,0:00:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukan…{\i0}
Dialogue: 0,0:00:29.73,0:00:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukan cuma mereka, tapi semuanya{\i0}
Dialogue: 0,0:00:33.53,0:00:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}pasti akan…{\i0}
Dialogue: 0,0:00:37.70,0:00:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}datang untuk membangkitkanku.{\i0}
Dialogue: 0,0:02:20.97,0:02:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Cepatnya! Dengan begini,\Ntak lama lagi kita akan sampai!
Dialogue: 0,0:02:26.31,0:02:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:02:28.60,0:02:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin semuanya menunggu kita.
Dialogue: 0,0:03:07.02,0:03:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sering dibahas saat kelas IPA…
Dialogue: 0,0:03:11.44,0:03:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap saat,\Nsebuah jeritan radio yang besar
Dialogue: 0,0:03:15.86,0:03:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus mengalir dari surga menuju Bumi!
Dialogue: 0,0:04:05.91,0:04:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:04:08.95,0:04:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:04:10.70,0:04:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membangun kapal antariksa
Dialogue: 0,0:04:12.58,0:04:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku dan Dr. Xeno\Nmemutuskan untuk bekerja sama.
Dialogue: 0,0:04:15.25,0:04:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Why-Man\Nmengirim pesan aneh dan seram
Dialogue: 0,0:04:17.59,0:04:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang berkata, "Apa kau mau mati?"
Dialogue: 0,0:04:19.84,0:04:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak takut sama sekali.
Dialogue: 0,0:04:22.80,0:04:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami menyimpulkan kalau kita harus\Nmeluncurkan kapal antariksa
Dialogue: 0,0:04:25.93,0:04:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke bulan sebelum Why-Man\Nmembatukan umat manusia lagi.
Dialogue: 0,0:04:31.22,0:04:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau merayakannya\Ndengan sesama insinyur.
Dialogue: 0,0:04:35.14,0:04:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kaseki di sini?
Dialogue: 0,0:04:36.85,0:04:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaseki sedang di India\Nbersama Senku dan yang lain.
Dialogue: 0,0:04:39.61,0:04:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}India?
Dialogue: 0,0:04:41.03,0:04:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka membuat sesuatu di sana?
Dialogue: 0,0:04:43.53,0:04:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Jangan kaget\Nsaat kau dengar ini, tapi…
Dialogue: 0,0:04:49.45,0:04:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita buat komputer.
Dialogue: 0,0:04:51.37,0:04:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:54.21,0:04:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas kami akan kaget.
Dialogue: 0,0:04:57.92,0:05:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sungguh sudah mencapai puncak
Dialogue: 0,0:05:02.71,0:05:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}produksi absurd Kerajaan Sains.
Dialogue: 0,0:05:07.09,0:05:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana caranya?
Dialogue: 0,0:05:09.76,0:05:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi macam apa itu, Sai?\NKau yang paling menginginkan komputer.
Dialogue: 0,0:05:14.23,0:05:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa aku salah?\N- Itu memang benar, tapi…
Dialogue: 0,0:05:18.02,0:05:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama-tama, apa yang kita perlukan
Dialogue: 0,0:05:21.07,0:05:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bagaimana cara\Nkita mulai membuat komputer?
Dialogue: 0,0:05:23.65,0:05:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku saja tak tahu mulai dari mana.
Dialogue: 0,0:05:25.65,0:05:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komputer
Dialogue: 0,0:05:28.45,0:05:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak lebih dari sakelar mati dan nyala,\Ndalam kata lain, 1 dan 0.
Dialogue: 0,0:05:33.91,0:05:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, selama bisa menetapkan 1 dan 0,
Dialogue: 0,0:05:37.08,0:05:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa membuat komputer dari apa pun.
Dialogue: 0,0:05:40.29,0:05:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik membalik kartu,\Natau mengangkat dan menurunkan bendera.
Dialogue: 0,0:05:44.21,0:05:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengangkat dan menurunkan bendera\Nbisa menjadi komputer?
Dialogue: 0,0:05:46.76,0:05:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya itu?
Dialogue: 0,0:05:54.89,0:05:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendera putih para lelaki\Nmelambangkan angka.
Dialogue: 0,0:05:57.64,0:06:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengangkat berarti 1\Ndan menurunkan berarti 0?
Dialogue: 0,0:06:01.40,0:06:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendera merah para perempuan\Nmelambangkan jawaban.
Dialogue: 0,0:06:04.53,0:06:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suika, tugasmu adalah mengangkat
Dialogue: 0,0:06:07.45,0:06:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bendera merahmu kalau kedua bendera putih\Nmenunjuk arah yang berlawanan.
Dialogue: 0,0:06:18.50,0:06:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudah saja.
Dialogue: 0,0:06:20.12,0:06:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku harus apa?
Dialogue: 0,0:06:22.84,0:06:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benderaku agak lebih besar\Ndaripada milik yang lain.
Dialogue: 0,0:06:25.88,0:06:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau angkat bendera merahmu
Dialogue: 0,0:06:27.80,0:06:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya saat kedua bendera putih terangkat.
Dialogue: 0,0:06:32.85,0:06:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah dapat mekanisme dasar komputer.\NSekarang, ayo kita coba penjumlahan.
Dialogue: 0,0:06:37.64,0:06:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Penjumlahan?\N- Dengan bendera ini?
Dialogue: 0,0:06:41.27,0:06:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}0 tambah 0 sama dengan 0.
Dialogue: 0,0:06:44.57,0:06:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}1 tambah 0 sama dengan 1.
Dialogue: 0,0:06:47.94,0:06:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}1 tambah 1 sama dengan 2.
Dialogue: 0,0:06:52.41,0:06:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bendera besar Kohaku melambangkan 2.
Dialogue: 0,0:06:55.28,0:07:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sempurna!\N- Kita melakukan penjumlahan otomatis!
Dialogue: 0,0:07:01.08,0:07:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa dibilang sederhana.
Dialogue: 0,0:07:04.21,0:07:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan tugas "sederhana" itu\Ndengan tepat adalah tugas sirkuit.
Dialogue: 0,0:07:08.17,0:07:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, ada banyak cara untuk membuatnya.
Dialogue: 0,0:07:11.26,0:07:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, kita bisa membuat {\i1}half-adder{\i0}\Nkalau punya gerbang XOR dan gerbang AND…
Dialogue: 0,0:07:16.89,0:07:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku kembali\Ntak paham perkataan mereka.
Dialogue: 0,0:07:20.64,0:07:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, kami dari abad ke-21\Ndan kami juga bingung.
Dialogue: 0,0:07:25.15,0:07:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sia-sia kalau tak dilakukan secara\Nelektronik dengan kecepatan super tinggi.
Dialogue: 0,0:07:29.74,0:07:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang bilang butuh sepuluh tahun\Nuntuk membuat semikonduktor.
Dialogue: 0,0:07:33.03,0:07:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau akan\Nmembuatnya di Dunia Batu ini…
Dialogue: 0,0:07:37.20,0:07:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita buat dengan donat.
Dialogue: 0,0:07:39.50,0:07:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Donat?
Dialogue: 0,0:07:41.58,0:07:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murah, cepat, dan awet.
Dialogue: 0,0:07:44.04,0:07:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komputer berbentuk donat buatan Jepang,\Nnegara yang terkenal atas keterampilannya,
Dialogue: 0,0:07:47.42,0:07:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}muncul sebentar dalam sejarah.
Dialogue: 0,0:07:50.80,0:07:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parametron.
Dialogue: 0,0:07:55.47,0:07:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Campur dan panggang tembaga\Ndan seng untuk membuat donat logam.
Dialogue: 0,0:07:58.68,0:08:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, lilitkan dengan kabel.
Dialogue: 0,0:08:01.81,0:08:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah selesai.\N- Cepat sekali!
Dialogue: 0,0:08:04.65,0:08:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutebak, kau akan butuh 800 buah…
Dialogue: 0,0:08:07.86,0:08:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Untuk sekarang, kita buat lima.\N- Mudah sekali!
Dialogue: 0,0:08:11.49,0:08:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Mecha Senku.
Dialogue: 0,0:08:14.20,0:08:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sederhananya, cara kerja parametron\Nseperti ayunan elektrik.
Dialogue: 0,0:08:19.08,0:08:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayunan elektrik berayun maju dan mundur.
Dialogue: 0,0:08:23.66,0:08:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ada banyak orang di ayunan\Nyang mau ke arah yang berbeda.
Dialogue: 0,0:08:27.04,0:08:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}arah ayunannya ditentukan\Noleh suara mayoritas.
Dialogue: 0,0:08:30.00,0:08:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah sifat dari parametron.
Dialogue: 0,0:08:32.97,0:08:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak begitu paham logika di baliknya,
Dialogue: 0,0:08:36.43,0:08:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi pada dasarnya,\Nkalau menambahkan 1, kita dapat 1, 'kan?
Dialogue: 0,0:08:39.43,0:08:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang berarti ia bisa melakukan\Ntugas seperti penjumlahan.
Dialogue: 0,0:09:05.16,0:09:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mau kita membuatnya juga,\Njadi dia akan mengajarkan caranya.
Dialogue: 0,0:09:08.71,0:09:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komputer? Itu mustahil!
Dialogue: 0,0:09:11.17,0:09:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini bicara apa?\NKita berhasil membuat berlian, tahu.
Dialogue: 0,0:09:15.88,0:09:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Siapa pun bisa melakukan sains," ingat?
Dialogue: 0,0:09:23.10,0:09:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku mencobanya?
Dialogue: 0,0:09:28.56,0:09:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlukah kau bertanya?\NKalau soal komputer,
Dialogue: 0,0:09:32.11,0:09:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kaulah pemimpinnya, Sai.
Dialogue: 0,0:09:54.76,0:09:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun begitu, kita tak begitu perlu\Nkomputer atau apalah itu
Dialogue: 0,0:09:58.51,0:10:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melakukan perhitungan sederhana\Nseperti "0+1" dan "1+1."
Dialogue: 0,0:10:03.26,0:10:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa membuat banyak sirkuit {\i1}adder{\i0}\Nparametron ini dan menyambungkannya.
Dialogue: 0,0:10:09.27,0:10:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, sedikit demi sedikit,
Dialogue: 0,0:10:12.36,0:10:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa menangani\Nangka yang lebih besar.
Dialogue: 0,0:10:15.69,0:10:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:10:18.53,0:10:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada akhirnya,\Nia akan melampaui kecerdasan manusia.
Dialogue: 0,0:10:26.91,0:10:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuwujudkan itu…
Dialogue: 0,0:10:29.83,0:10:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini langkah pertama menuju pembuatan\Nbenda yang paling kusukai, komputer!
Dialogue: 0,0:10:41.34,0:10:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bilang, "sambungkan yang banyak"?
Dialogue: 0,0:10:45.31,0:10:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak suka kedengarannya…
Dialogue: 0,0:10:48.89,0:10:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, pasti dia akan bilang\Ndia butuh 800 atau semacamnya.
Dialogue: 0,0:10:54.57,0:10:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua ratus ribu.
Dialogue: 0,0:10:57.78,0:11:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Akan kita bangun\Npembuat donat logam otomatis.{\i0}
Dialogue: 0,0:11:01.28,0:11:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita memasuki zaman teknik otomasi.{\i0}
Dialogue: 0,0:11:04.78,0:11:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi kita masih harus mengandalkan\NYuzuriha dan tim kerajinan{\i0}
Dialogue: 0,0:11:08.83,0:11:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}untuk tugas melelahkan,\Nyaitu melilit kabel.{\i0}
Dialogue: 0,0:11:11.04,0:11:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terus bangkitkan orang di Kota Jagung,\Nkarena kita akan perlu{\i0}
Dialogue: 0,0:11:14.17,0:11:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mengandalkan jumlah yang besar.{\i0}
Dialogue: 0,0:11:16.38,0:11:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mencapai klimaks\Nproduksi umat manusia
Dialogue: 0,0:11:19.05,0:11:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membangun komputer,\Nkita akan butuh tenaga mesin dan manusia.
Dialogue: 0,0:11:22.68,0:11:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bekerja sama\Ndan berusaha sekuat tenaga.
Dialogue: 0,0:11:28.14,0:11:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian bisa?
Dialogue: 0,0:11:32.65,0:11:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:11:44.49,0:11:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita panggang donat\Ndalam jumlah besar
Dialogue: 0,0:11:47.62,0:11:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan buat komputer dari nol!
Dialogue: 0,0:11:49.87,0:11:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, donat "logam."
Dialogue: 0,0:11:53.37,0:11:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tenaga manusia Kota Jagung…
Dialogue: 0,0:11:56.29,0:11:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita tunjukkan kesabaran, tekad\Ndan kerja sama kita.
Dialogue: 0,0:12:04.30,0:12:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun sirkuit {\i1}adder{\i0} hanya bisa\Nmenjumlahkan 1, kalau disambungkan begini…
Dialogue: 0,0:12:12.44,0:12:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gila!\N- Mirip tentakel edan!
Dialogue: 0,0:12:15.90,0:12:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Sekarang ayo cepat buat Dragon Que…\NMungkin itu terlalu canggih.
Dialogue: 0,0:12:20.11,0:12:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau gim sederhana?\NBagaimana dengan catur?
Dialogue: 0,0:12:22.74,0:12:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan terburu-buru.\NKomputer ini masih level 1.
Dialogue: 0,0:12:26.57,0:12:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua terlalu bersemangat.
Dialogue: 0,0:12:29.33,0:12:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang bisa menjumlahkan sampai 255.
Dialogue: 0,0:12:33.37,0:12:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diagram sirkuit ini menunjukkan\Nbagaimana aku menyambungkannya.
Dialogue: 0,0:12:36.75,0:12:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaan, aku bingung.
Dialogue: 0,0:12:40.46,0:12:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana cara kita memberi tahu\Norang-orang di Kota Jagung
Dialogue: 0,0:12:43.84,0:12:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cara membuat sesuatu serumit ini?
Dialogue: 0,0:12:47.60,0:12:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin kita menyampaikannya\Ndengan kode Morse, 'kan?
Dialogue: 0,0:12:50.85,0:12:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti mudah kalau kita bisa\Nmenunjukkan foto pada mereka.
Dialogue: 0,0:12:55.64,0:13:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan ada cara elegan\Nuntuk melakukannya.
Dialogue: 0,0:13:00.57,0:13:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirim saja foto\Ndan diagram sirkuitnya secara daring.
Dialogue: 0,0:13:03.28,0:13:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak!{\i0}
Dialogue: 0,0:13:04.74,0:13:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan faks bertenaga manusia\Nyang sungguh mengerikan itu!
Dialogue: 0,0:13:07.95,0:13:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin kita bisa\Nmelakukannya dengan foto…
Dialogue: 0,0:13:15.50,0:13:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kali ini, kita pakai mesin faks sungguhan.{\i0}
Dialogue: 0,0:13:18.67,0:13:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena sekarang kita harus\Nterhubung secara global,{\i0}
Dialogue: 0,0:13:21.09,0:13:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sudah jelas kalau nantinya\Nkita akan membutuhkan ini.{\i0}
Dialogue: 0,0:13:24.72,0:13:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, aku beri instruksinya pada tim Taiju\Nyang pergi ke Amerika Utara.{\i0}
Dialogue: 0,0:13:29.01,0:13:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku,
Dialogue: 0,0:13:31.14,0:13:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kau mau ikut kelas kecilku yang seru\Ntentang cara membuat mesin faks?
Dialogue: 0,0:13:36.73,0:13:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda. Beri tahu saja sistem apa\Nyang kau gunakan. Itu sudah cukup.
Dialogue: 0,0:13:44.65,0:13:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sfalerit yang kutemukan.
Dialogue: 0,0:13:48.32,0:13:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini yang kupakai\Nuntuk layangan berpendarku.{\i0}
Dialogue: 0,0:13:51.03,0:13:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau direbus dan semprotkan pada kertas,\Nkita dapat kertas cetak.
Dialogue: 0,0:13:56.16,0:13:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa mencetak\Ndengan membakarnya dengan listrik.
Dialogue: 0,0:14:00.04,0:14:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat mesin "membacanya"\Nagak lebih sulit.
Dialogue: 0,0:14:03.17,0:14:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin menyorotkan cahaya dan tergantung\Napa titiknya putih atau hitam.
Dialogue: 0,0:14:06.55,0:14:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ia mengirim sinyal elektrik.
Dialogue: 0,0:14:08.93,0:14:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinyal itu akan dikirim
Dialogue: 0,0:14:11.22,0:14:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke mesin satunya, yang membakar kertas\Ndan mencetak gambarnya.
Dialogue: 0,0:14:16.39,0:14:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita bisa memercayakan\Nproduksi fisik komputer pada Kota Jagung
Dialogue: 0,0:14:20.65,0:14:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan segera pergi\Nuntuk mendirikan kota berikutnya.
Dialogue: 0,0:14:23.65,0:14:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah waktunya berangkat?
Dialogue: 0,0:14:25.82,0:14:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terdengar bagus.\NMari berangkat secepat mungkin.
Dialogue: 0,0:14:29.15,0:14:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar tak suka\Nbuang-buang waktu, ya?
Dialogue: 0,0:14:38.33,0:14:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang kau tak bisa tinggal lebih lama.\NAku akan tetap di India
Dialogue: 0,0:14:43.21,0:14:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memetakan diagram sirkuit\Nuntuk komputernya.
Dialogue: 0,0:14:45.88,0:14:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah selesai, akan aku kirim…
Dialogue: 0,0:14:47.55,0:14:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bicara apa? Sai, kau ikut dengan kami.
Dialogue: 0,0:14:55.10,0:14:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Yang mana? Maksudku,\Nakan bagus kalau kau bisa ikut kami.
Dialogue: 0,0:14:59.44,0:15:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kami akan butuh\Npengetahuan matematikamu di kota lain.
Dialogue: 0,0:15:03.02,0:15:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Aku tak akan\Npernah pergi denganmu, Ryusui!
Dialogue: 0,0:15:14.49,0:15:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selalu… Selalu begini!\NRyusui selalu bilang,{\i0}
Dialogue: 0,0:15:18.95,0:15:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Aku menginginkan semuanya!\NAku menginginkan kekuatan!"{\i0}
Dialogue: 0,0:15:21.62,0:15:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia selalu menyuruhku\Nmelakukan berbagai hal.{\i0}
Dialogue: 0,0:15:24.29,0:15:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku pergi jauh-jauh ke India sendirian\Nuntuk lari darinya,{\i0}
Dialogue: 0,0:15:27.13,0:15:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}jadi kenapa ini terjadi…{\i0}
Dialogue: 0,0:15:38.22,0:15:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencocokkan pengaturan waktu\Nantara pemindai dan pencetak sangat sulit.
Dialogue: 0,0:15:43.31,0:15:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak benar, tak akan sejajar\Ndan fotonya akan terdistorsi.
Dialogue: 0,0:15:49.65,0:15:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengirimkan sesuatu!
Dialogue: 0,0:15:51.40,0:15:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari semuanya di Kota Jagung!
Dialogue: 0,0:16:03.71,0:16:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini foto kelompok!
Dialogue: 0,0:16:06.04,0:16:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya mereka mengambil\Nfoto kenang-kenangan bersama,
Dialogue: 0,0:16:09.09,0:16:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan tim Jepang dan tim Amerika.
Dialogue: 0,0:16:11.97,0:16:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya kabar mereka baik.
Dialogue: 0,0:16:16.01,0:16:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Foto kelompok…{\i0}
Dialogue: 0,0:16:19.52,0:16:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎- Gila!\N‎- Suika juga mau berfoto.
Dialogue: 0,0:16:21.98,0:16:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ayo kita lakukan!
Dialogue: 0,0:16:28.19,0:16:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tergoda memakai trikku untuk mengorek{\i0}
Dialogue: 0,0:16:31.07,0:16:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}informasi mengenai Ryusui dan Sai…{\i0}
Dialogue: 0,0:16:33.45,0:16:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi mereka berdua tampak\Nterpengaruh oleh foto itu{\i0}
Dialogue: 0,0:16:36.37,0:16:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan kurasa itu bukan hal\Nyang bisa kujadikan bahan candaan.{\i0}
Dialogue: 0,0:16:39.49,0:16:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa ada cara tak langsung agar aku bisa…{\i0}
Dialogue: 0,0:16:43.75,0:16:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kau punya masalah apa\Ndengan foto kelompok?
Dialogue: 0,0:16:46.75,0:16:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian Nanami bersaudara harus akur!
Dialogue: 0,0:16:50.30,0:16:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikutlah dengan kami, Sai!
Dialogue: 0,0:16:59.51,0:17:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya teringat…
Dialogue: 0,0:17:02.27,0:17:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Perusahaan Nanami\Nmengambil foto kelompok,
Dialogue: 0,0:17:05.31,0:17:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya Ryusui dan aku\Nyang tak pernah diikutsertakan.
Dialogue: 0,0:17:12.19,0:17:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ryusui dan aku bukan termasuk keluarga…\NKami bukan anak-anak Ibu.
Dialogue: 0,0:17:17.91,0:17:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Maksudmu apa? Ibumu bukan ibumu?
Dialogue: 0,0:17:23.16,0:17:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku dan seluruh keluargaku\Ntanpa henti memaksaku
Dialogue: 0,0:17:26.83,0:17:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk berfokus hanya pada matematika.
Dialogue: 0,0:17:29.13,0:17:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seakan aku prajurit bermanfaat\Nyang tak akan memberontak.
Dialogue: 0,0:17:33.21,0:17:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya, tak ada anggota keluarga\Nyang bisa mengendalikan Ryusui.
Dialogue: 0,0:17:37.34,0:17:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia…
Dialogue: 0,0:17:38.68,0:17:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai, aku menginginkan kemampuanmu!
Dialogue: 0,0:17:41.22,0:17:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terima kasih!
Dialogue: 0,0:17:44.85,0:17:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusui hanya berpikir tentang\Nbagaimana cara memanfaatkan orang lain.
Dialogue: 0,0:17:49.90,0:17:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan matematikawan!
Dialogue: 0,0:17:53.78,0:17:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai, ajari aku bermain catur!
Dialogue: 0,0:17:56.36,0:17:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo…
Dialogue: 0,0:18:14.34,0:18:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sudah kurang ajar…\NKalian berdua sungguh anak-anak baik…
Dialogue: 0,0:18:18.97,0:18:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak baik?\NRyusui sama sekali bukan anak baik!
Dialogue: 0,0:18:22.22,0:18:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia egois dan manja\Ndan memperlakukan orang…
Dialogue: 0,0:18:28.14,0:18:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusui hanya mau melakukan sesuatu\Nbersama denganmu.
Dialogue: 0,0:18:33.40,0:18:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa hanya itu yang dia mau.
Dialogue: 0,0:18:36.99,0:18:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusui menginginkan semuanya.
Dialogue: 0,0:18:40.61,0:18:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk seseorang\Nyang bisa dia panggil saudara sejatinya.
Dialogue: 0,0:18:44.08,0:18:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Ryusui pernah\Nmemaksamu melakukan sesuatu?
Dialogue: 0,0:18:57.01,0:18:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sai! Aku menginginkan kemampuanmu.{\i0}
Dialogue: 0,0:19:00.26,0:19:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo buat sirkuit balap bersama.
Dialogue: 0,0:19:02.55,0:19:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita buat kapal layar bersama!
Dialogue: 0,0:19:06.06,0:19:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ikut dengan kami.
Dialogue: 0,0:19:12.19,0:19:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai!
Dialogue: 0,0:19:14.61,0:19:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada waktu sebelum kami berangkat!\NAjari aku!
Dialogue: 0,0:19:18.15,0:19:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo main catur!
Dialogue: 0,0:19:19.86,0:19:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang tidak terima…
Dialogue: 0,0:19:30.71,0:19:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:40.59,0:19:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru Sai yang kukenal!
Dialogue: 0,0:19:43.22,0:19:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tertandingi kalau soal\Npermainan logis seperti catur!
Dialogue: 0,0:19:53.15,0:19:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sai!{\i0}
Dialogue: 0,0:19:57.77,0:19:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sai!{\i0}
Dialogue: 0,0:20:01.07,0:20:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sai!{\i0}
Dialogue: 0,0:20:03.07,0:20:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sai!{\i0}
Dialogue: 0,0:20:06.33,0:20:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sai!{\i0}
Dialogue: 0,0:20:15.63,0:20:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan membosankan…
Dialogue: 0,0:20:18.05,0:20:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginginkan lawan kuat\Nyang bisa kuajak main saat di laut nanti.
Dialogue: 0,0:20:52.45,0:20:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ini yang terakhir!
Dialogue: 0,0:20:55.25,0:20:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah selesai memuat semuanya.
Dialogue: 0,0:20:58.63,0:21:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa semuanya sudah naik?
Dialogue: 0,0:21:08.55,0:21:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berangkat.
Dialogue: 0,0:21:56.18,0:21:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berangkat, Ryusui.
Dialogue: 0,0:22:00.02,0:22:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama.
Dialogue: 0,0:24:01.02,0:24:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
