Dialogue: 0,0:01:46.85,0:01:51.27,tanda,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:04:37.61,0:04:38.73,tanda,,0000,0000,0000,,{\an8}TV DIPEROLEH!
Dialogue: 0,0:07:09.09,0:07:11.38,tanda,,0000,0000,0000,,KOMPUTER DIPEROLEH!
Dialogue: 0,0:08:09.69,0:08:14.24,tanda,,0000,0000,0000,,TEKAN MULAI
Dialogue: 0,0:08:14.24,0:08:16.32,tanda,,0000,0000,0000,,NILAI - NYAWA
Dialogue: 0,0:08:16.32,0:08:18.20,tanda,,0000,0000,0000,,PERINGKAT - POIN GIM
Dialogue: 0,0:09:13.92,0:09:20.30,tanda,,0000,0000,0000,,KAU KALAH
Dialogue: 0,0:18:04.20,0:18:05.16,tanda,,0000,0000,0000,,SELENIUM DIPEROLEH!
Dialogue: 0,0:18:12.34,0:18:13.29,tanda,,0000,0000,0000,,{\an8}SELENIUM, ARSENIK
Dialogue: 0,0:18:29.02,0:18:29.90,tanda,,0000,0000,0000,,{\an8}SELENIUM
Dialogue: 0,0:18:52.04,0:18:54.46,tanda,,0000,0000,0000,,{\an8}KAMERA TELEVISI DIPEROLEH!
Dialogue: 0,0:19:58.61,0:20:00.53,tanda,,0000,0000,0000,,{\an8}JEPANG - AS
Dialogue: 0,0:23:53.18,0:23:55.93,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:55.93,0:23:57.35,tanda,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA,
Dialogue: 0,0:23:57.35,0:23:58.64,tanda,,0000,0000,0000,,MATERIAL, DAN METODENYA\NDIDASARKAN PADA KENYATAAN
Dialogue: 0,0:23:58.64,0:24:00.93,tanda,,0000,0000,0000,,MOHON JANGAN DICOBA\NKARENA BISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:04.33,0:00:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya gila!
Dialogue: 0,0:00:07.59,0:00:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukurannya besar sekali!
Dialogue: 0,0:00:12.05,0:00:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka kita akan buat bendungan
Dialogue: 0,0:00:15.09,0:00:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan pembangkit hidroelektrik raksasa!
Dialogue: 0,0:00:17.80,0:00:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan membuat listrik menggunakan ini?
Dialogue: 0,0:00:21.43,0:00:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku teringat saat Ginro dan yang lain\Nharus memutar benda itu terus-terusan!{\i0}
Dialogue: 0,0:00:25.85,0:00:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini semua berkat
Dialogue: 0,0:00:28.69,0:00:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kerja keras Ruri\Ndan semuanya dalam proyek ini.
Dialogue: 0,0:00:36.45,0:00:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk misi sebesar ini,
Dialogue: 0,0:00:38.95,0:00:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan butuh semua tenaga\Nyang bisa kita dapatkan.
Dialogue: 0,0:00:43.54,0:00:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itu, kita harus\Nmembangkitkan orang dengan gila-gilaan.
Dialogue: 0,0:00:55.05,0:00:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tuna sirip biru pesanan Anda.
Dialogue: 0,0:00:57.97,0:01:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Rakyat Jepang yang Baru Bangkit!
Dialogue: 0,0:01:02.02,0:01:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian mengenaliku dari TV?\NTerima kasih!
Dialogue: 0,0:01:06.35,0:01:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi\Npada dunia setelah pembatuan?
Dialogue: 0,0:01:08.98,0:01:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ringkasannya.
Dialogue: 0,0:01:10.98,0:01:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jreng.
Dialogue: 0,0:01:12.28,0:01:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mendapatkan alat misterius\Nyang membatukan semuanya,
Dialogue: 0,0:01:16.53,0:01:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ternyata, Why-Man,\Nsi pelaku, berada di bulan.
Dialogue: 0,0:01:19.70,0:01:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebelum kita membatu lagi,\Nkita akan membangun roket
Dialogue: 0,0:01:23.08,0:01:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan pergi ke bulan!
Dialogue: 0,0:01:25.58,0:01:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk melakukannya,\Nkita perlu material untuk roket
Dialogue: 0,0:01:28.25,0:01:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan pengetahuan untuk membangunnya.
Dialogue: 0,0:01:31.13,0:01:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaan,\Nsemua orang terlihat bingung.
Dialogue: 0,0:01:35.09,0:01:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena populasinya sudah\Nbertambah sebanyak ini,
Dialogue: 0,0:01:37.84,0:01:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita perlu sesuatu\Nyang bisa menyatukan semua orang.
Dialogue: 0,0:01:41.93,0:01:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginginkan media hiburan!
Dialogue: 0,0:03:23.36,0:03:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Media…
Dialogue: 0,0:03:24.91,0:03:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiburan?
Dialogue: 0,0:03:28.87,0:03:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:03:29.87,0:03:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin banyak orang,\Nmakin sulit mengendalikan mereka.
Dialogue: 0,0:03:34.17,0:03:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang akan bertindak sendiri.
Dialogue: 0,0:03:36.84,0:03:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itulah kita butuh media hiburan\Nuntuk menyatukan semua orang!
Dialogue: 0,0:03:41.76,0:03:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:03:44.80,0:03:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham maksudmu, Ryusui.
Dialogue: 0,0:03:50.52,0:03:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tak bisa hidup tanpa ada\Nhal yang memberikan kebahagiaan.
Dialogue: 0,0:03:54.77,0:03:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, saat aku harus berhitung seharian,
Dialogue: 0,0:03:56.86,0:03:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gimlah yang menyelamatkan hidupku.
Dialogue: 0,0:04:00.69,0:04:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu salah satu alasannya,\Ntapi aku membicarakan hal yang berbeda.
Dialogue: 0,0:04:05.16,0:04:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya dikuasai oleh
Dialogue: 0,0:04:06.82,0:04:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka yang mengendalikan media.\NApa aku salah?
Dialogue: 0,0:04:10.45,0:04:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, semua bergantung pada stasiun TV,
Dialogue: 0,0:04:12.33,0:04:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mesin pencari, dan siaran video daring.
Dialogue: 0,0:04:15.79,0:04:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku adalah,
Dialogue: 0,0:04:17.75,0:04:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita sudah sampai\Npada titik itu di dunia baru ini.
Dialogue: 0,0:04:20.92,0:04:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dua bersaudara ini berbeda sekali?
Dialogue: 0,0:04:34.02,0:04:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini dia. Apa ini yang kau sebut "media"?
Dialogue: 0,0:04:38.73,0:04:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Lagi pula, kita sudah membuat\Ntabung Braun saat membuat radar.
Dialogue: 0,0:04:43.24,0:04:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Proses garis pemindaian dari atas ke bawah\Ndan sisa cahayanya menghasilkan gambar.
Dialogue: 0,0:04:51.66,0:04:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan, televisi elektronik pertama\Ndi dunia dibuat di Jepang.
Dialogue: 0,0:04:55.92,0:04:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pada dasarnya,\Nkita mengulang sejarah!
Dialogue: 0,0:04:58.50,0:05:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap! Berapa saluran yang kita dapat?
Dialogue: 0,0:05:12.27,0:05:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Aku lupa dunia ini\Ntak punya stasiun televisi.
Dialogue: 0,0:05:15.98,0:05:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja?
Dialogue: 0,0:05:17.98,0:05:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, pasti kau sudah tahu itu\Nsebelum membuatnya.
Dialogue: 0,0:05:21.61,0:05:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini tak dibuat\Nuntuk menyiarkan acara TV.
Dialogue: 0,0:05:25.86,0:05:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, untuk apa?
Dialogue: 0,0:05:27.99,0:05:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barangnya akan datang bersama\Npengiriman rutin dari Amerika ke Jepang.
Dialogue: 0,0:05:32.83,0:05:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai, ini yang sudah kau tunggu-tunggu!
Dialogue: 0,0:06:16.66,0:06:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah menyelesaikan\Nsesuatu yang hebat!
Dialogue: 0,0:06:26.88,0:06:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan, dasar otak otot.
Dialogue: 0,0:06:30.68,0:06:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila… Ada berapa kabel\Nyang tersambung ke benda ini?
Dialogue: 0,0:06:34.18,0:06:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak salah,\Nkami memakai sekitar 10.000 donat
Dialogue: 0,0:06:37.18,0:06:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ratusan ribu magnet.
Dialogue: 0,0:06:39.69,0:06:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambigu sekali…
Dialogue: 0,0:06:41.19,0:06:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otaknya adalah CPU 16-bit\Nyang berkecepatan 60 kilohertz.
Dialogue: 0,0:06:45.48,0:06:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan 129 unit memori inti
Dialogue: 0,0:06:48.36,0:06:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ROM sebesar 512 kilobit
Dialogue: 0,0:06:51.57,0:06:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan SRAM sebesar 16 kilobit.
Dialogue: 0,0:06:54.20,0:06:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat banyak informasi,\Ntapi malah tambah bingung.
Dialogue: 0,0:06:58.29,0:07:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada dasarnya kalau soal performa,
Dialogue: 0,0:07:01.87,0:07:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini setara dengan NES.
Dialogue: 0,0:07:12.01,0:07:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memrogam dengan ini\Nakan agak membingungkan.
Dialogue: 0,0:07:15.22,0:07:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan melubangi kertas
Dialogue: 0,0:07:17.10,0:07:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang disebut "kartu tebuk"\Ndan memindainya.
Dialogue: 0,0:07:27.73,0:07:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secarik kertas itu\Nadalah program untuk gim?
Dialogue: 0,0:07:30.74,0:07:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya\Nkita bermain gim dengan ini?
Dialogue: 0,0:07:37.37,0:07:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:07:38.29,0:07:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:40.96,0:07:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo kita mulai.
Dialogue: 0,0:08:18.20,0:08:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Kita benar-benar\Nbermain gim di dunia ini!
Dialogue: 0,0:08:22.91,0:08:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gim jenis balok berjatuhan ini
Dialogue: 0,0:08:24.50,0:08:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya sangat sederhana
Dialogue: 0,0:08:26.42,0:08:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bisa ditulis dengan satu baris kode.
Dialogue: 0,0:08:29.30,0:08:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membuat\Nbanyak gim lain seperti ini.
Dialogue: 0,0:08:34.38,0:08:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai, hanya kau yang bisa\Nmelakukan hal seperti itu.
Dialogue: 0,0:09:20.30,0:09:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah.
Dialogue: 0,0:09:22.85,0:09:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}AI catur ini
Dialogue: 0,0:09:24.64,0:09:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah melampaui tingkat kecerdasanku.
Dialogue: 0,0:09:29.44,0:09:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu sekali,
Dialogue: 0,0:09:31.32,0:09:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juara Catur Dunia, Kasparov
Dialogue: 0,0:09:34.44,0:09:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertanding melawan AI Deep Blue.
Dialogue: 0,0:09:38.53,0:09:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pertandingan terbesar abad itu,\Nantara manusia dan komputer.
Dialogue: 0,0:09:46.87,0:09:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langkah ke-36 yang legendaris…
Dialogue: 0,0:09:49.25,0:09:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat jelas kalau AI harus\Nmenggerakkan ratunya.
Dialogue: 0,0:09:53.17,0:09:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu sebenarnya perangkap dari
Dialogue: 0,0:09:55.92,0:09:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pemain terkuat manusia, Kasparov.
Dialogue: 0,0:09:59.89,0:10:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}AI Deep Blue tiba-tiba berpikir panjang.
Dialogue: 0,0:10:06.43,0:10:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada apa?\N- Apa yang terjadi?
Dialogue: 0,0:10:09.48,0:10:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, ia menggerakan satu pion.
Dialogue: 0,0:10:18.95,0:10:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:10:23.08,0:10:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, itu tampak seperti kesalahan,
Dialogue: 0,0:10:25.12,0:10:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ternyata itu langkah cemerlang\Npenentu kemenangan yang tak disangka
Dialogue: 0,0:10:29.75,0:10:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh siapa pun, termasuk Kasparov.
Dialogue: 0,0:10:34.46,0:10:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah saat sains menghasilkan sesuatu
Dialogue: 0,0:10:37.59,0:10:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang asing dan di luar pemahaman manusia.
Dialogue: 0,0:10:41.34,0:10:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:10:42.85,0:10:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segala hal yang asing\Ndan di luar pemahaman manusia…
Dialogue: 0,0:10:45.26,0:10:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau mengetahui semuanya!\NAku menginginkan semuanya!
Dialogue: 0,0:10:49.06,0:10:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bisa dibilang kalau sains lebih tamak\Ndari pada apa pun di dunia ini!
Dialogue: 0,0:10:53.90,0:10:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kekuatan terlarang
Dialogue: 0,0:10:56.48,0:10:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari alat pembatu dari Why-Man…
Dialogue: 0,0:11:06.04,0:11:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa ini?\N- Ruang vakum untuk Medusa?
Dialogue: 0,0:11:10.54,0:11:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita tahu itu\Nakan rusak saat usang,
Dialogue: 0,0:11:14.25,0:11:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus mengamankannya.
Dialogue: 0,0:11:25.89,0:11:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa benda itu akan aktif
Dialogue: 0,0:11:27.68,0:11:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kita teriak,\N"seberapa meter" dari luar brankas?
Dialogue: 0,0:11:31.89,0:11:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tak sedekat ini.
Dialogue: 0,0:11:45.49,0:11:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Suara apa itu?
Dialogue: 0,0:11:47.87,0:11:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, mungkin sebaiknya kita buka.
Dialogue: 0,0:11:51.54,0:11:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kuncinya…
Dialogue: 0,0:11:55.71,0:11:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara "klik" itu…
Dialogue: 0,0:11:58.17,0:12:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa?\NTidak ada yang berbuat apa-apa…
Dialogue: 0,0:12:07.64,0:12:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Alat pembatunya bersinar sendiri!
Dialogue: 0,0:12:28.87,0:12:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin! Cahaya itu!
Dialogue: 0,0:12:30.66,0:12:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:32.71,0:12:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Why-Man sedang menyerang kita?
Dialogue: 0,0:12:35.83,0:12:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila! Tamatlah kita!
Dialogue: 0,0:12:39.59,0:12:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membatu sekarang,\Nkita tak akan punya kesempatan…
Dialogue: 0,0:12:50.72,0:12:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini cukup jauh.
Dialogue: 0,0:12:52.14,0:12:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya…
Dialogue: 0,0:12:53.64,0:12:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untuk jaga-jaga,\Nayo mundur dua meter lagi.
Dialogue: 0,0:13:06.57,0:13:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin luas jarak Sinar Pembatu,\Nmakin cepat pergerakannya.
Dialogue: 0,0:13:12.33,0:13:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tahu itu setelah berkali-kali\Nmelihatnya. Pada kecepatan ini…
Dialogue: 0,0:13:16.00,0:13:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, radiusnya 20 meter.
Dialogue: 0,0:13:35.23,0:13:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih hidup…
Dialogue: 0,0:13:36.98,0:13:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu… Ke mana rambutku?
Dialogue: 0,0:13:41.82,0:13:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuka.
Dialogue: 0,0:13:43.48,0:13:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:55.04,0:13:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kita perlu menginterogasi\Nkedua saksi yang ada di sini.
Dialogue: 0,0:14:00.08,0:14:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:14:01.00,0:14:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aku!
Dialogue: 0,0:14:03.21,0:14:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, aku memang berada
Dialogue: 0,0:14:04.96,0:14:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sini sampai selesai dan bercanda\Nsoal berteriak dari luar brankas, tapi…
Dialogue: 0,0:14:08.93,0:14:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:14:10.51,0:14:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo sungguh tak melakukan apa-apa.
Dialogue: 0,0:14:14.64,0:14:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku paparkan apa\Nyang tepatnya kami alami
Dialogue: 0,0:14:17.48,0:14:19.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa menambahkan opini atau kesimpulan.
Dialogue: 0,0:14:22.02,0:14:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terdengar suara dari dalam brankas.
Dialogue: 0,0:14:25.36,0:14:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara kaca pecah.
Dialogue: 0,0:14:28.15,0:14:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klik. Menyala.
Dialogue: 0,0:14:33.74,0:14:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang mereka dengar
Dialogue: 0,0:14:35.91,0:14:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin hanya suara\Nruang vakum yang pecah, tapi…
Dialogue: 0,0:14:40.33,0:14:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada saat itu, tak seorang pun\Nmenyentuh atau berbicara
Dialogue: 0,0:14:44.50,0:14:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke arah brankas atau alat pembatu.
Dialogue: 0,0:14:52.55,0:14:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, alat itu menyala sendiri?
Dialogue: 0,0:14:56.22,0:14:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, Why-Man yang ada di bulan
Dialogue: 0,0:14:58.39,0:15:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah mulai membatukan manusia lagi?
Dialogue: 0,0:15:01.73,0:15:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa alatnya aktif dari jauh?
Dialogue: 0,0:15:04.27,0:15:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mungkin dengan gelombang radio?
Dialogue: 0,0:15:06.90,0:15:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau itu mungkin, Why-Man pasti\Nsudah melakukannya sejak awal.
Dialogue: 0,0:15:10.07,0:15:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya, Why-Man cukup baik
Dialogue: 0,0:15:11.78,0:15:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena tak membatukan seluruh Bumi.\NTapi kenapa?
Dialogue: 0,0:15:14.70,0:15:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada terlalu banyak\Nhal yang tak kita ketahui.
Dialogue: 0,0:15:18.12,0:15:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini sudah terjadi, kita tak tahu\Napa lagi yang Why-Man bisa lakukan.
Dialogue: 0,0:15:21.96,0:15:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera menyerang\NWhy-Man secepat mungkin.
Dialogue: 0,0:15:25.42,0:15:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu begitu? Kurasa…
Dialogue: 0,0:15:28.59,0:15:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kohaku benar-benar suka bertindak cepat.{\i0}
Dialogue: 0,0:15:31.13,0:15:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi…
Dialogue: 0,0:15:33.93,0:15:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepatnya, kita akan\Nmenyerang bulan bagian mana?
Dialogue: 0,0:15:36.89,0:15:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bahkan belum tahu lokasinya.
Dialogue: 0,0:15:39.14,0:15:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gila sekali! Kalau kita terlalu\Nmenekankan bertindak cepat,{\i0}
Dialogue: 0,0:15:42.65,0:15:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka akan memilih untuk\Nmembangun roket satu arah!{\i0}
Dialogue: 0,0:15:47.82,0:15:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mulai dari situ.\NKita harus mencari tahu
Dialogue: 0,0:15:52.82,0:15:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di mana lokasi Why-Man\Ndi bulan yang besar itu.
Dialogue: 0,0:15:58.83,0:16:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa asal mendarat\Ndan mencari setelah kita sampai?
Dialogue: 0,0:16:02.92,0:16:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin bisa.
Dialogue: 0,0:16:04.54,0:16:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diameter bulan lebih besar\Ndari seperempat diameter Bumi.
Dialogue: 0,0:16:08.21,0:16:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Sebesar itu?
Dialogue: 0,0:16:11.38,0:16:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan terlihat sangat kecil…
Dialogue: 0,0:16:14.93,0:16:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira seukuran dengan danau\Nyang mengelilingi Desa Ishigami.
Dialogue: 0,0:16:18.72,0:16:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,
Dialogue: 0,0:16:21.35,0:16:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}situasi kita sudah berubah,\Ntapi kita masih kekurangan informasi.
Dialogue: 0,0:16:25.69,0:16:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau bereksperimen dengan Medusa\Ndan melakukan reka ulang kejadian, tapi…
Dialogue: 0,0:16:29.82,0:16:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu berbahaya.
Dialogue: 0,0:16:34.53,0:16:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, sebaiknya kita copot baterainya\Nsampai kita membutuhkannya.
Dialogue: 0,0:16:44.62,0:16:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, Yo.\N- Apa?
Dialogue: 0,0:16:47.25,0:16:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau membawa Medusa dari Amerika,
Dialogue: 0,0:16:50.17,0:16:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kau menyentuhnya?
Dialogue: 0,0:16:51.96,0:16:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang aku tak melakukan apa-apa!
Dialogue: 0,0:16:54.76,0:16:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Ukyo yang membawanya.
Dialogue: 0,0:16:58.39,0:17:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku, mungkin kau sudah tahu ini,
Dialogue: 0,0:17:01.56,0:17:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ada kemungkinan\Nitu dilakukan lebih dulu…
Dialogue: 0,0:17:05.14,0:17:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:17:06.23,0:17:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dulu? Aku paham!
Dialogue: 0,0:17:09.82,0:17:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau bilang pada Medusa lebih dulu,
Dialogue: 0,0:17:11.94,0:17:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"3 bulan, 20 meter" atau semacamnya,
Dialogue: 0,0:17:14.78,0:17:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bisa dapat kejahatan sempurna!
Dialogue: 0,0:17:17.11,0:17:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila sekali! Deduksi yang hebat, Gen!
Dialogue: 0,0:17:24.46,0:17:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi siapa yang akan berbuat begitu?\NItu tak ada untungnya.
Dialogue: 0,0:17:29.88,0:17:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kita semua berteman.
Dialogue: 0,0:17:31.59,0:17:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, aku hanya bilang\Nkalau itu mungkin dilakukan.
Dialogue: 0,0:17:35.80,0:17:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tanpa cara mencari\Ntahu apa yang terjadi,
Dialogue: 0,0:17:39.30,0:17:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus mempertimbangkan\Nsegala kemungkinan.
Dialogue: 0,0:17:43.97,0:17:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus simpan Medusa\Ndi tempat yang tak tercapai
Dialogue: 0,0:17:46.52,0:17:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menaruhnya dalam pengawasan tetap.
Dialogue: 0,0:17:49.35,0:17:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?
Dialogue: 0,0:17:58.74,0:18:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selenida perak bisa ditemukan\Ndi tambang di Kagoshima.
Dialogue: 0,0:18:05.16,0:18:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selenium diperoleh!
Dialogue: 0,0:18:06.87,0:18:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?\NMendengarnya saja aku belum pernah.
Dialogue: 0,0:18:13.30,0:18:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sekarang kita hanya perlu
Dialogue: 0,0:18:14.84,0:18:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}arsenik dan telurium yang kita dapat
Dialogue: 0,0:18:16.72,0:18:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}dari cadangan taktit, atau yang dikenal
Dialogue: 0,0:18:18.80,0:18:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}sebagai kotak harta alam.
Dialogue: 0,0:18:20.59,0:18:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku tak pernah mendengar semua ini…
Dialogue: 0,0:18:22.97,0:18:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tunggu, arsenik adalah racun, 'kan?
Dialogue: 0,0:18:25.72,0:18:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini semua racun.
Dialogue: 0,0:18:26.73,0:18:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini jauh lebih berbahaya dari yang kukira!
Dialogue: 0,0:18:34.44,0:18:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fotokatoda, yang dilapisi campuran racun,
Dialogue: 0,0:18:38.53,0:18:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengubah cahaya, atau gambar yang terlihat\Nmelalui lensa, menjadi sinyal listrik.
Dialogue: 0,0:18:43.24,0:18:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kirim sinyal itu\Nke layar TV yang baru kita buat…
Dialogue: 0,0:19:01.05,0:19:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamera pengawas!\N- Benar!
Dialogue: 0,0:19:03.97,0:19:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tak bisa merekam,\Ntapi cukup untuk pengawasan.
Dialogue: 0,0:19:10.81,0:19:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, kamera ini bisa dipakai\Nuntuk siaran langsung.
Dialogue: 0,0:19:14.44,0:19:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang…
Dialogue: 0,0:19:16.36,0:19:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat kataku?
Dialogue: 0,0:19:17.90,0:19:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita gunakan media hiburan\Nuntuk menyatukan semua orang.
Dialogue: 0,0:19:22.03,0:19:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, bukan cuma Kerajaan Sains ini,
Dialogue: 0,0:19:25.74,0:19:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi seluruh dunia!
Dialogue: 0,0:19:44.60,0:19:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya dikuasai
Dialogue: 0,0:19:46.76,0:19:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh mereka yang mengendalikan media,\Nbahkan di dunia batu ini.
Dialogue: 0,0:19:50.35,0:19:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Rakyat Amerika.
Dialogue: 0,0:19:52.35,0:19:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini siaran langsung pertandingan bisbol
Dialogue: 0,0:19:55.52,0:19:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}antara Jepang dan Amerika Serikat.
Dialogue: 0,0:20:31.27,0:20:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mantap!\N- Banzai!
Dialogue: 0,0:20:49.41,0:20:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stasiun TV di Dunia Batu?
Dialogue: 0,0:20:53.66,0:20:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang pasti tak ada\Nyang akan melawan mereka!
Dialogue: 0,0:21:12.43,0:21:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat luar biasa!
Dialogue: 0,0:21:13.98,0:21:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sungguh menjadi konglomerat media.
Dialogue: 0,0:21:17.27,0:21:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar memegang perkataannya.
Dialogue: 0,0:21:19.48,0:21:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ryusui,
Dialogue: 0,0:21:20.98,0:21:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita tak membuat kamera TV\Nhanya agar kau bisa bersenang-senang.
Dialogue: 0,0:21:24.15,0:21:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pengawasan, 'kan?
Dialogue: 0,0:21:25.90,0:21:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kita akan gunakan untuk sesuatu
Dialogue: 0,0:21:28.95,0:21:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sepuluh miliar kali lebih penting.
Dialogue: 0,0:21:33.58,0:21:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana lokasi Why-Man di bulan saat ini?
Dialogue: 0,0:21:38.88,0:21:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun kita memakai\Nteleskop semaksimal mungkin,
Dialogue: 0,0:21:41.80,0:21:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jarak pandang kita dari Bumi terbatas.
Dialogue: 0,0:21:45.76,0:21:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kita bisa\Nmerekamnya dari luar angkasa
Dialogue: 0,0:21:48.55,0:21:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengirim rekamannya\Nke Bumi lewat siaran langsung,
Dialogue: 0,0:21:52.06,0:21:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa menyelidiki\Napa yang ada di bulan.
Dialogue: 0,0:21:57.27,0:21:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan bilang…\N- Maksudmu…
Dialogue: 0,0:22:00.40,0:22:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Dengan kata lain,
Dialogue: 0,0:22:03.69,0:22:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengetahui lokasi Why-Man,
Dialogue: 0,0:22:06.90,0:22:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dunia baru yang diselimuti batu ini,
Dialogue: 0,0:22:11.12,0:22:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan meluncurkan satelit buatan!
Dialogue: 0,0:24:00.93,0:24:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
