Dialogue: 0,0:00:15.34,0:00:16.39,tanda,,0000,0000,0000,,MESIN JET XENO
Dialogue: 0,0:03:43.05,0:03:46.51,tanda,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:05:24.36,0:05:26.99,tanda,,0000,0000,0000,,1 OKTOBER, 5750
Dialogue: 0,0:05:26.99,0:05:29.91,tanda,,0000,0000,0000,,PERSEUS BARU TIBA DI INDIA
Dialogue: 0,0:05:34.79,0:05:36.66,tanda,,0000,0000,0000,,JINTEN
Dialogue: 0,0:05:37.87,0:05:39.79,tanda,,0000,0000,0000,,{\an8}BIJI JINTEN DIPEROLEH
Dialogue: 0,0:05:41.46,0:05:43.25,tanda,,0000,0000,0000,,{\an8}KAPULAGA
Dialogue: 0,0:05:44.42,0:05:46.26,tanda,,0000,0000,0000,,{\an8}BIJI KAPULAGA DIPEROLEH
Dialogue: 0,0:05:48.01,0:05:49.43,tanda,,0000,0000,0000,,KETUMBAR
Dialogue: 0,0:05:50.51,0:05:52.43,tanda,,0000,0000,0000,,{\an8}BIJI KETUMBAR DIPEROLEH
Dialogue: 0,0:05:58.56,0:06:00.73,tanda,,0000,0000,0000,,{\an8}KUNYIT DIPEROLEH
Dialogue: 0,0:13:13.79,0:13:18.21,tanda,,0000,0000,0000,,29.599.820.
Dialogue: 0,0:13:18.21,0:13:23.88,tanda,,0000,0000,0000,,374.402.244.953.
Dialogue: 0,0:14:37.71,0:14:39.62,tanda,,0000,0000,0000,,PENGENALAN TERHADAP ALJABAR LINEAR
Dialogue: 0,0:15:09.03,0:15:11.61,tanda,,0000,0000,0000,,{\an8}PEMROGRAMAN UNTUK PEMULA
Dialogue: 0,0:15:16.54,0:15:17.83,tanda,,0000,0000,0000,,{\an8}RUSAK
Dialogue: 0,0:15:32.47,0:15:35.43,tanda,,0000,0000,0000,,PEMROGRAMAN UNTUK PEMULA
Dialogue: 0,0:21:58.27,0:21:59.19,tanda,,0000,0000,0000,,KOMPUTER SENKU
Dialogue: 0,0:23:53.39,0:23:55.93,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:55.93,0:23:57.43,tanda,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA,
Dialogue: 0,0:23:57.43,0:23:59.18,tanda,,0000,0000,0000,,MATERIAL, DAN METODENYA\NDIDASARKAN PADA KENYATAAN
Dialogue: 0,0:23:59.18,0:24:00.93,tanda,,0000,0000,0000,,MOHON JANGAN DICOBA KARENA\NBISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:04.75,0:00:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan… Sungguh?
Dialogue: 0,0:00:08.63,0:00:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?
Dialogue: 0,0:00:10.96,0:00:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benar.{\i0}
Dialogue: 0,0:00:12.42,0:00:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita mengalihfungsikan\Nminiatur roket dan membangun ini.{\i0}
Dialogue: 0,0:00:18.85,0:00:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama dengan Dr. Xeno, akhirnya\Naku menyelesaikan roket pertama kami.
Dialogue: 0,0:00:24.94,0:00:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!
Dialogue: 0,0:00:34.95,0:00:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:00:42.12,0:00:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita gunakan kekuatan sains
Dialogue: 0,0:00:45.21,0:00:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membuka jalan masa depan kita!
Dialogue: 0,0:00:58.64,0:01:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil membuka\Ndan melewati Terusan Suez!
Dialogue: 0,0:01:12.28,0:01:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Matematika adalah bahasa yang dipakai\NTuhan untuk menuliskan alam semesta."
Dialogue: 0,0:01:15.65,0:01:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah kata-kata Galileo Galilei.
Dialogue: 0,0:01:19.20,0:01:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita ambil bahasa universal itu,
Dialogue: 0,0:01:22.37,0:01:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam kata lain,\Nkearifan manusia itu sendiri!
Dialogue: 0,0:01:27.42,0:01:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata-katanya terdengar keren…
Dialogue: 0,0:01:30.42,0:01:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak tahu apa artinya.
Dialogue: 0,0:01:33.84,0:01:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi, aku mengarahkan\Nrudal itu secara manual.
Dialogue: 0,0:01:38.43,0:01:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi kalau soal mengirim roket\Nmenuju alam semesta yang luas,{\i0}
Dialogue: 0,0:01:42.01,0:01:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kita harus menghitung\Nlintasannya secara tepat.{\i0}
Dialogue: 0,0:01:45.43,0:01:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghitung? Senku, kau tak bisa\Nmelakukan yang biasa kau lakukan?
Dialogue: 0,0:01:50.86,0:01:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, biasanya aku mementingkan kecepatan,
Dialogue: 0,0:01:53.73,0:01:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku memakai nilai pendekatan\Nuntuk mendapat perkiraan kasar.
Dialogue: 0,0:01:58.07,0:02:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak akan bisa dilakukan dengan roket.
Dialogue: 0,0:02:00.62,0:02:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau perhitungan lintasannya\Nmeleset sedikit saja,
Dialogue: 0,0:02:03.58,0:02:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu akan berujung pada kesalahan besar\Ndan semua di dalam kapal akan mati.
Dialogue: 0,0:02:07.41,0:02:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar…\NKalau sudutnya meleset sedikit saja,
Dialogue: 0,0:02:12.21,0:02:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ribuan kilometer kemudian,
Dialogue: 0,0:02:15.17,0:02:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lintasannya akan meleset sangat jauh.{\i0}
Dialogue: 0,0:02:17.88,0:02:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alam semesta sungguh bukan main.
Dialogue: 0,0:02:20.43,0:02:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}NASA menggunakan 15 bilangan desimal pi.
Dialogue: 0,0:02:25.97,0:02:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:02:27.52,0:02:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, saat roketnya terbang,
Dialogue: 0,0:02:29.48,0:02:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus terus-terusan\Nmelakukan perhitungan edan itu?
Dialogue: 0,0:02:34.19,0:02:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, karena itu, kita menuju India!
Dialogue: 0,0:02:37.94,0:02:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendidikan matematika\Ndi India itu brilian!
Dialogue: 0,0:02:40.86,0:02:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa menghafal tabel perkalian\Nuntuk semua angka dua digit.
Dialogue: 0,0:02:43.99,0:02:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Aku pasti langsung gagal.
Dialogue: 0,0:02:49.33,0:02:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginginkan kemampuan matematika itu!
Dialogue: 0,0:02:51.88,0:02:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasrat bersifat mulia.
Dialogue: 0,0:02:54.96,0:02:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perusahaan Nanami\Nmendirikan sebuah universitas di India
Dialogue: 0,0:02:58.13,0:03:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengembangkan sumber daya manusia.
Dialogue: 0,0:03:00.47,0:03:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Perusahaan Nanami memang mendunia, ya?{\i0}
Dialogue: 0,0:03:03.97,0:03:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan pergi ke lokasi universitas itu,\Ndan membangkitkan
Dialogue: 0,0:03:07.77,0:03:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ratusan pelajar dan profesor, dalam\Nkata lain, komputer manusia yang ahli!
Dialogue: 0,0:03:13.94,0:03:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Program Apollo,\Nyang mendaratkan manusia pertama di bulan,
Dialogue: 0,0:03:17.86,0:03:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menggunakan komputer manusia\Nyang menghitung secara manual.
Dialogue: 0,0:03:23.78,0:03:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita beruntung,\Nmungkin kita bisa menemukan Sai.
Dialogue: 0,0:03:28.58,0:03:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai?
Dialogue: 0,0:03:29.62,0:03:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama India yang populer.
Dialogue: 0,0:03:33.96,0:03:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna matematika genius\Nyang menghasilkan kecerdasan
Dialogue: 0,0:03:37.34,0:03:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejuta orang sekaligus.
Dialogue: 0,0:06:36.72,0:06:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga! Aku tahu kau akan segera\Nmembuat ini saat kita sampai di India!
Dialogue: 0,0:06:45.57,0:06:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Terusan Suez, kita bisa\Nmakan kari lebih cepat dari perkiraan.
Dialogue: 0,0:06:50.66,0:06:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghemat setahun adalah hal luar biasa\Ndan kari ini sama luar biasanya.
Dialogue: 0,0:06:55.79,0:06:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kalau kita menunggu satu tahun,
Dialogue: 0,0:06:58.08,0:07:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti sudah lebih tua dari Ruri,\Nkarena dia membatu.
Dialogue: 0,0:07:03.13,0:07:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak mengkhawatirkan\NRuri dan semuanya.
Dialogue: 0,0:07:07.09,0:07:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan banyaknya waktu yang sudah berlalu,\Nkuharap mereka tak patah.
Dialogue: 0,0:07:12.68,0:07:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:07:14.93,0:07:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka patah dan terkikis,\Nkita tak bisa menempelkan mereka kembali!
Dialogue: 0,0:07:20.69,0:07:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir.
Dialogue: 0,0:07:25.36,0:07:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin, sebagai syaman,
Dialogue: 0,0:07:27.48,0:07:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruri membuat semuanya mengambil\Nposisi yang kokoh untuk tetap aman.
Dialogue: 0,0:07:31.49,0:07:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang perlu dikhawatirkan.
Dialogue: 0,0:07:33.36,0:07:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun kami jauh dari satu sama lain,
Dialogue: 0,0:07:36.62,0:07:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tetap tahu karena kami bersaudara.
Dialogue: 0,0:07:40.54,0:07:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar! Kita bisa mengandalkan Ruri!\NAku juga tahu itu!
Dialogue: 0,0:07:45.71,0:07:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chrome, aku yakin alasanmu\Npercaya pada Ruri berbeda dariku.
Dialogue: 0,0:07:56.51,0:08:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik. Jadi, kalau kau\Nmengenal orang itu dengan baik,
Dialogue: 0,0:08:01.52,0:08:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lokasi terkuburnya patung mereka\Nakan datang padamu dengan sendirinya.
Dialogue: 0,0:08:06.06,0:08:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupercaya instingku sebagai pelaut.
Dialogue: 0,0:08:09.82,0:08:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Sinar Pembatu yang mengerikan itu\Npertama kali menghantam ribuan tahun lalu.
Dialogue: 0,0:08:14.53,0:08:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktunya kira-kira pukul 09.30 di India.
Dialogue: 0,0:08:18.87,0:08:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir sebelum kelas dimulai.
Dialogue: 0,0:08:22.00,0:08:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat sedang senggang,\NSai selalu menggunakan laptopnya.
Dialogue: 0,0:08:27.13,0:08:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat di mana dia bisa dapat sinyal bagus\Ndan sendirian… Dalam kata lain,
Dialogue: 0,0:08:32.42,0:08:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai berada di atap sekolah\Nsaat dia membatu!
Dialogue: 0,0:08:36.26,0:08:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh tahu banyak soal si Sai ini.
Dialogue: 0,0:08:47.44,0:08:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita tak tahu\Nsaat ini sekolahnya ada di mana.
Dialogue: 0,0:08:53.28,0:08:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah khawatir.
Dialogue: 0,0:08:56.95,0:08:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kita tahu titik awal sasaran kita,
Dialogue: 0,0:08:59.62,0:09:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa bandingkan\Nlokasi patung lain yang ditemukan…
Dialogue: 0,0:09:02.75,0:09:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan topografi dari masa itu…
Dialogue: 0,0:09:10.92,0:09:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dengan mudah\Nmenaksir lokasi sasaran.
Dialogue: 0,0:09:16.43,0:09:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ada apa ini?
Dialogue: 0,0:09:19.05,0:09:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita tentukan\Nkuat geser tanah dari strata
Dialogue: 0,0:09:22.18,0:09:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghitung faktor keamanan\Ndengan metode Fellenius.
Dialogue: 0,0:09:26.31,0:09:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan melihat tampilan peta awalnya,\Nkita bisa tahu di mana terjadi longsor.
Dialogue: 0,0:09:30.48,0:09:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah… Saat dua pengguna sains bekerja sama,
Dialogue: 0,0:09:33.94,0:09:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita menjadi dua kali lebih bingung.
Dialogue: 0,0:09:42.66,0:09:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya itu cukup.
Dialogue: 0,0:09:52.00,0:09:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini…
Dialogue: 0,0:09:57.63,0:10:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai, sang genius yang menghasilkan\Nkecerdasan sejuta orang?
Dialogue: 0,0:10:01.55,0:10:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat seperti\Nblasteran orang India dan Jepang.
Dialogue: 0,0:10:05.47,0:10:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya tampan gila!
Dialogue: 0,0:10:12.06,0:10:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang seperti apa dia?
Dialogue: 0,0:10:13.94,0:10:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademikus genius biasanya
Dialogue: 0,0:10:16.65,0:10:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sungguh sulit diajak bergaul…
Dialogue: 0,0:10:27.96,0:10:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa…
Dialogue: 0,0:10:31.29,0:10:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah kalian menyelamatkanku?
Dialogue: 0,0:10:35.59,0:10:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:10:36.76,0:10:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untunglah dia tampaknya\Nbisa berkomunikasi dengan normal.{\i0}
Dialogue: 0,0:10:42.05,0:10:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih! Terima kasih banyak!
Dialogue: 0,0:11:02.03,0:11:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar sekali\Nkau lari setelah melihatku!
Dialogue: 0,0:11:06.33,0:11:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkap dia!
Dialogue: 0,0:11:10.16,0:11:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau mau aku menangkapnya?
Dialogue: 0,0:11:12.25,0:11:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu cepat!
Dialogue: 0,0:11:14.88,0:11:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:11:18.05,0:11:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:11:19.17,0:11:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jauh-jauh pergi ke India untuk lari!\NAku tak akan pernah kembali
Dialogue: 0,0:11:23.80,0:11:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke Perusahaan Nanami!
Dialogue: 0,0:11:25.97,0:11:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya,\Nkembali ke tempatmu berada!
Dialogue: 0,0:11:31.31,0:11:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Nama pria ini Sai Nanami.
Dialogue: 0,0:11:35.11,0:11:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunlah!
Dialogue: 0,0:11:36.69,0:11:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergabunglah dengan kami dan gunakan\Nkecerdasan setara sejuta orang itu!
Dialogue: 0,0:11:41.20,0:11:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tetap tahu karena kami bersaudara.
Dialogue: 0,0:11:44.91,0:11:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh tahu banyak soal si Sai ini.
Dialogue: 0,0:11:52.54,0:11:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusui adalah adikku!
Dialogue: 0,0:11:57.55,0:12:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:11.52,0:12:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai, sang genius yang menghasilkan\Nkecerdasan sejuta orang…
Dialogue: 0,0:12:15.69,0:12:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adalah kakak Ryusui, ya?
Dialogue: 0,0:12:21.99,0:12:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak bilang kalau dia kakakmu?
Dialogue: 0,0:12:26.12,0:12:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu detail tak penting.
Dialogue: 0,0:12:28.62,0:12:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria ini, Sai Nanami, sangat ahli.
Dialogue: 0,0:12:31.62,0:12:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka itu, aku menginginkannya.\NItu saja. Apa aku salah?
Dialogue: 0,0:12:35.08,0:12:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus berapa kali kuberi tahu
Dialogue: 0,0:12:36.75,0:12:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau aku bukan orang genius!
Dialogue: 0,0:12:39.13,0:12:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang terus\Nbilang begitu sejak kita kecil.
Dialogue: 0,0:12:42.84,0:12:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik! Jadi, kau bukan genius edan\Nseperti yang dia katakan?
Dialogue: 0,0:12:47.39,0:12:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:12:49.56,0:12:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}HAHA! Lucu sekali! Kalau begitu,\Nselamat datang sebagai teman biasa!
Dialogue: 0,0:12:54.69,0:12:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Tidak apa-apa?
Dialogue: 0,0:12:58.06,0:12:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:13:01.28,0:13:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bersaudara, jadi aku tahu
Dialogue: 0,0:13:05.40,0:13:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakat yang kau sembunyikan\Nsejak kau berusia empat tahun!
Dialogue: 0,0:13:25.88,0:13:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Kukira itu tanda perkalian.
Dialogue: 0,0:13:28.68,0:13:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan!
Dialogue: 0,0:13:30.30,0:13:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Sai sangat hebat! Luar biasa! Tuan!
Dialogue: 0,0:13:36.35,0:13:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akyu menginginkan ichu!
Dialogue: 0,0:13:37.90,0:13:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhitungan mental tak ada gunanya!
Dialogue: 0,0:13:41.15,0:13:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah komputer bisa\Nmelakukannya dalam sekejap.
Dialogue: 0,0:13:43.94,0:13:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang bisa\Nmengalikan bilangan 10 digit
Dialogue: 0,0:13:47.03,0:13:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kau memikirkannya cukup lama,\Nseperti yang kulakukan.
Dialogue: 0,0:13:50.41,0:13:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Menurutmu begitu?{\i0}
Dialogue: 0,0:13:55.50,0:13:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untuk mendapat angka yang akurat,\Nakan butuh waktu…{\i0}
Dialogue: 0,0:14:00.13,0:14:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun pendapatmu, bakatmu dalam sains\Ndan matematika sudah jelas.
Dialogue: 0,0:14:05.21,0:14:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pasti Perusahaan Nanami…\Natau lebih tepatnya aku
Dialogue: 0,0:14:08.30,0:14:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menginginkan bakat itu!
Dialogue: 0,0:14:10.68,0:14:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja…
Dialogue: 0,0:14:15.31,0:14:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Sai sudah memiliki\Npemahaman yang baik
Dialogue: 0,0:14:18.35,0:14:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas aljabar linear, topologi,\Ndan teori himpunan.
Dialogue: 0,0:14:21.40,0:14:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat dia memfokuskan\Nseluruh waktunya untuk matematika.
Dialogue: 0,0:14:25.23,0:14:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kita besarkan dia menjadi\Naktuaris milik Perusahaan Nanami.
Dialogue: 0,0:14:50.72,0:14:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan Sai menghilang!\N- Ke mana dia?
Dialogue: 0,0:16:01.12,0:16:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini perintah dari Tuan.
Dialogue: 0,0:16:04.12,0:16:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini, kami akan\Nmenggandakan waktu belajar Anda.
Dialogue: 0,0:16:07.42,0:16:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda hanya akan diperbolehkan\Nmenggunakan komputer Anda untuk belajar.
Dialogue: 0,0:16:14.22,0:16:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik…
Dialogue: 0,0:16:27.94,0:16:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai.
Dialogue: 0,0:16:29.36,0:16:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bicara apa? Lakukan saja semuanya.
Dialogue: 0,0:16:35.45,0:16:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajarlah, kuasailah matematika,\Njadilah seorang aktuaris,
Dialogue: 0,0:16:39.91,0:16:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan buat pria itu senang demi kemudahan.
Dialogue: 0,0:16:42.50,0:16:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara itu, kau bisa bermain\Ndan membuat gim juga.
Dialogue: 0,0:16:47.17,0:16:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau menginginkannya, ambil saja.
Dialogue: 0,0:16:50.34,0:16:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun, apa pun yang kau mau!\NBahkan Perusahaan Nanami itu sendiri!
Dialogue: 0,0:16:54.38,0:16:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku bisa melakukan itu!
Dialogue: 0,0:16:59.47,0:17:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kuinginkan hanya\Nmemprogram gim-gim yang kusukai.
Dialogue: 0,0:17:05.85,0:17:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai! Aku menginginkan kemampuanmu.\NAyo buat sirkuit balap bersama.
Dialogue: 0,0:17:10.65,0:17:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hitungkan garis balap yang optimal!\N- Aku tak mau!
Dialogue: 0,0:17:14.03,0:17:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita buat kapal layar bersama!
Dialogue: 0,0:17:16.86,0:17:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gunakan dinamika fluida komputasi untuk…\N- Aku tak mau!
Dialogue: 0,0:17:20.66,0:17:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sai!\N- Sudah kuberi tahu…
Dialogue: 0,0:17:22.45,0:17:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sai!\N- Aku…
Dialogue: 0,0:17:23.87,0:17:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sai!\N- …bukan matematikawan!
Dialogue: 0,0:17:27.29,0:17:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku seorang pemrogram!
Dialogue: 0,0:17:32.42,0:17:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk lari dari Perusahaan Nanami\Ndan Ryusui, yang terus memaksaku bekerja,
Dialogue: 0,0:17:35.84,0:17:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku datang jauh-jauh\Nke sebuah universitas di India.
Dialogue: 0,0:17:39.34,0:17:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mau memprogram…
Dialogue: 0,0:17:54.07,0:17:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh berapa lama\Nuntuk membangun komputer yang layak
Dialogue: 0,0:17:59.70,0:18:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Dunia Batu ini?
Dialogue: 0,0:18:02.58,0:18:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semikonduktornya akan\Nsangat menyulitkan kita.
Dialogue: 0,0:18:04.95,0:18:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau lebih tepatnya,\Npada saat ini, itu mustahil.
Dialogue: 0,0:18:09.25,0:18:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya butuh lima tahun,\Nmungkin sepuluh.
Dialogue: 0,0:18:13.34,0:18:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat?
Dialogue: 0,0:18:16.92,0:18:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau membangunkan orang sepertiku…
Dialogue: 0,0:18:21.60,0:18:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibangkitkan di dunia\Nyang bahkan tak punya kalkulator…
Dialogue: 0,0:18:25.72,0:18:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa dilakukan\Npemrogram seperti aku?
Dialogue: 0,0:18:34.65,0:18:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai bicara begitu, tapi pada akhirnya\Ndia selalu menyelesaikan tugasnya.
Dialogue: 0,0:18:38.78,0:18:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tampaknya matematika bukan bidangnya.\NAku merasa tak enak memaksanya.
Dialogue: 0,0:18:42.37,0:18:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang dia juga\Ntak secepat itu dalam berhitung.
Dialogue: 0,0:18:45.37,0:18:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesalahan terkecil bisa berujung\Npada kematian semuanya, 'kan?
Dialogue: 0,0:18:49.21,0:18:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga tak akan membuat Sai\Nmenangani semua perhitungannya.
Dialogue: 0,0:18:54.00,0:18:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak seperti Program Apollo, kita harus\Nmenghadapi Why-Man yang tak bisa ditebak.
Dialogue: 0,0:18:58.92,0:19:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan keadaan yang berubah setiap menit,\Nkita harus siap
Dialogue: 0,0:19:02.30,0:19:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk langsung merespons, setiap saat.
Dialogue: 0,0:19:06.85,0:19:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena harus menghitung\Nsemuanya secara manual,
Dialogue: 0,0:19:09.27,0:19:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}walaupun kita menambah anggota,\Nkita masih akan ada dalam bahaya.
Dialogue: 0,0:19:28.91,0:19:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lima sampai sepuluh tahun\Nsampai aku bisa mendapat komputer.{\i0}
Dialogue: 0,0:19:32.96,0:19:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang bisa kulakukan sampai saat itu?{\i0}
Dialogue: 0,0:19:36.50,0:19:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak bisa melakukan pemrograman…\Nselama lima tahun… sepuluh tahun…{\i0}
Dialogue: 0,0:19:42.84,0:19:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hanya hidup dan tak berbuat apa pun…{\i0}
Dialogue: 0,0:20:01.15,0:20:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak…{\i0}
Dialogue: 0,0:20:03.53,0:20:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukannya aku tak bisa…{\i0}
Dialogue: 0,0:20:05.99,0:20:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebenarnya, pemrograman adalah\Nsatu-satunya hal yang bisa kulakukan.{\i0}
Dialogue: 0,0:20:18.42,0:20:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh. Seharusnya tak ada\Nyang bisa menolak aroma kari.
Dialogue: 0,0:20:23.34,0:20:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu agak berlebihan.
Dialogue: 0,0:20:26.64,0:20:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku khawatir.
Dialogue: 0,0:20:30.10,0:20:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai.
Dialogue: 0,0:20:40.65,0:20:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini…
Dialogue: 0,0:20:46.41,0:20:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kode mesin.\NBahasa pemrograman paling mendasar
Dialogue: 0,0:20:50.95,0:20:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang langsung dimasukkan\Nke dalam komputer.
Dialogue: 0,0:20:54.46,0:20:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Tunggu! Jangan lihat!
Dialogue: 0,0:20:56.54,0:21:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa tak lihat?\NItu agak sulit dilewatkan.
Dialogue: 0,0:21:00.30,0:21:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada komputer di dunia ini,
Dialogue: 0,0:21:04.22,0:21:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku hanya bisa\Nmenulisnya untuk nanti…
Dialogue: 0,0:21:09.01,0:21:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak bisa membaca ini.\NIni pemrograman?
Dialogue: 0,0:21:15.31,0:21:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Semua angka ini…
Dialogue: 0,0:21:26.70,0:21:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membentuk {\i1}Dragon Quest.{\i0}
Dialogue: 0,0:21:30.78,0:21:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam kata lain,\Nseprimitif apa pun mesinnya,
Dialogue: 0,0:21:36.08,0:21:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan pemrogramanmu kau bisa\Nmembuat semesta dalam komputer, Sai?
Dialogue: 0,0:21:41.71,0:21:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya.
Dialogue: 0,0:21:42.88,0:21:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa. Aku bisa memprogram apa pun.
Dialogue: 0,0:21:48.47,0:21:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti itu mengubah rencana kita.
Dialogue: 0,0:21:51.10,0:21:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sai, dengan kemampuanmu yang hebat,
Dialogue: 0,0:21:54.77,0:21:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa melawan dengan komputer kuno.
Dialogue: 0,0:21:59.19,0:22:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa meluncurkan roket\Ndengan Nintendo Entertainment System.
Dialogue: 0,0:22:04.19,0:22:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah klimaks perakitan ilmiah,\Nkeunikan teknologis umat manusia!
Dialogue: 0,0:22:10.07,0:22:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan membuat\Nkomputer di Dunia Batu ini!
Dialogue: 0,0:24:00.93,0:24:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
