Dialogue: 0,0:01:02.52,0:01:03.35,sign,,0000,0000,0000,,MIKROFON
Dialogue: 0,0:01:55.57,0:01:59.32,sign,,0000,0000,0000,,KARYA ORISINAL: RIICHIRO INAGAKI, BOICHI\NSHUEISHA "JUMP COMICS"
Dialogue: 0,0:14:11.93,0:14:13.10,sign,,0000,0000,0000,,BURUNG BATU
Dialogue: 0,0:14:14.56,0:14:15.43,sign,,0000,0000,0000,,TAJUK UTAMA BERITA DUNIA
Dialogue: 0,0:23:53.26,0:23:55.93,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:55.93,0:23:58.56,sign,,0000,0000,0000,,KISAH INI FIKTIF TAPI FLORA/FAUNA, BAHAN,\NDAN METODENYA BERDASARKAN KENYATAAN
Dialogue: 0,0:23:58.56,0:24:00.98,sign,,0000,0000,0000,,MOHON JANGAN DICOBA KARENA\NBISA BERBAHAYA DAN/ATAU ILEGAL
Dialogue: 0,0:00:07.46,0:00:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dari dunia yang purba,\Nkita sudah berkembang{\i0}
Dialogue: 0,0:00:11.30,0:00:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}selangkah demi selangkah,{\i0}
Dialogue: 0,0:00:14.51,0:00:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan berhasil sampai{\i0}
Dialogue: 0,0:00:16.51,0:00:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ke permukaan Bulan.{\i0}
Dialogue: 0,0:00:22.23,0:00:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bertarung\Nmelawan Why-Man yang misterius.
Dialogue: 0,0:00:25.52,0:00:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan senjata yang seadanya.
Dialogue: 0,0:00:27.56,0:00:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:00:28.48,0:00:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita punya senjata yang menembakkan\Njaring dan meledak, 'kan?
Dialogue: 0,0:00:31.36,0:00:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Senapan jaring granat!{\i0}
Dialogue: 0,0:00:34.36,0:00:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, satu lagi.
Dialogue: 0,0:00:36.61,0:00:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kapsul Medusa.{\i0}
Dialogue: 0,0:00:42.79,0:00:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Benar juga!
Dialogue: 0,0:00:45.00,0:00:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan ada dalam vakum luar angkasa,
Dialogue: 0,0:00:46.58,0:00:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi suara tak bisa merambat.
Dialogue: 0,0:00:48.54,0:00:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tak bisa hanya\Nmenggunakan Medusa saja.
Dialogue: 0,0:00:51.13,0:00:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:53.30,0:00:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinar Pembatu bisa digunakan\Nsebagai senjata dan untuk pemulihan.
Dialogue: 0,0:00:57.39,0:00:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapsulnya diisi udara,
Dialogue: 0,0:00:59.14,0:01:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kita bisa mengaktifkannya\Ndengan bicara lewat interkom.
Dialogue: 0,0:01:04.39,0:01:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau perlu,
Dialogue: 0,0:01:05.89,0:01:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kulempar\NKapsul Medusa ini ke arah musuh
Dialogue: 0,0:01:08.65,0:01:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu bilang, sepuluh meter…
Dialogue: 0,0:01:10.52,0:01:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:01:12.36,0:01:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hampir saja!{\i0}
Dialogue: 0,0:01:14.53,0:01:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku hampir tak sengaja mengaktifkannya!{\i0}
Dialogue: 0,0:01:17.28,0:01:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohaku membuatku cemas…
Dialogue: 0,0:01:20.58,0:01:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, kita diskusikan nanti saja.
Dialogue: 0,0:01:23.79,0:01:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, jangan sampai kita boros oksigen.
Dialogue: 0,0:01:27.33,0:01:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bergegas dan maju!
Dialogue: 0,0:01:32.30,0:01:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah maju saja?\NMenikmati waktu mereka di Bulan pun tidak.
Dialogue: 0,0:01:35.84,0:01:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prajurit, penyuka efisiensi,
Dialogue: 0,0:01:38.13,0:01:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan gadis yang tak sabaran.\NMereka adalah trio emas untuk kecepatan.
Dialogue: 0,0:01:43.77,0:01:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kita
Dialogue: 0,0:01:46.81,0:01:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah lembah Taurus-Littrow!
Dialogue: 0,0:03:37.96,0:03:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lembah Taurus-Littrow…
Dialogue: 0,0:03:40.42,0:03:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Letaknya di sekitar leher kelinci Bulan.
Dialogue: 0,0:03:43.01,0:03:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titik hitam misterius\Nyang sebelumnya kita temukan
Dialogue: 0,0:03:45.80,0:03:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan satelit buatan, terletak di sana.
Dialogue: 0,0:03:48.51,0:03:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau musuh kita di sini,\Nmereka bisa melihat kita dengan mudah
Dialogue: 0,0:03:51.81,0:03:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di rover Bulan yang mencolok ini.
Dialogue: 0,0:03:55.90,0:03:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu lebih baik daripada\Nmendarat di lokasi mereka.
Dialogue: 0,0:04:01.03,0:04:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:04:05.99,0:04:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bendera!
Dialogue: 0,0:04:07.53,0:04:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendera Amerika\Nyang ditancapkan AS di Bulan.
Dialogue: 0,0:04:10.91,0:04:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sudah sepenuhnya memutih
Dialogue: 0,0:04:13.29,0:04:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena langsung terpapar sinar kosmik.
Dialogue: 0,0:04:16.71,0:04:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Why-Man kebetulan berada
Dialogue: 0,0:04:19.17,0:04:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dekat tempat manusia\Nmenancapkan bendera, ya?
Dialogue: 0,0:04:23.93,0:04:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu aneh?
Dialogue: 0,0:04:26.34,0:04:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita pikirkan luasnya Bulan…
Dialogue: 0,0:04:28.85,0:04:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu ada alasan logis\Ndi balik suatu kebetulan.
Dialogue: 0,0:04:33.27,0:04:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berusaha membayangkan musuh.
Dialogue: 0,0:04:35.14,0:04:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asumsi bisa membunuhmu.
Dialogue: 0,0:04:37.94,0:04:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hanya bisa maju dan melihat\Ndengan mata sendiri.
Dialogue: 0,0:04:51.49,0:04:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohaku.
Dialogue: 0,0:04:53.54,0:04:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tolong buka Kapsul Medusa.
Dialogue: 0,0:04:58.33,0:05:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Senku?
Dialogue: 0,0:05:00.09,0:05:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba bicaramu formal begitu?
Dialogue: 0,0:05:03.09,0:05:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau aku membukanya sekarang juga?
Dialogue: 0,0:05:05.76,0:05:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Benar. Cepatlah.
Dialogue: 0,0:05:12.72,0:05:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kohaku,
Dialogue: 0,0:05:15.81,0:05:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bicara apa?
Dialogue: 0,0:05:17.94,0:05:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku tak mengatakan apa pun.
Dialogue: 0,0:05:23.82,0:05:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu transmisi palsu\Nyang menggunakan frekuensi mikrofon
Dialogue: 0,0:05:27.41,0:05:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan suara Senku.
Dialogue: 0,0:05:31.20,0:05:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membukanya.
Dialogue: 0,0:05:38.88,0:05:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:42.17,0:05:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lempar kapsulnya, Kohaku!
Dialogue: 0,0:05:53.64,0:05:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Kohaku melakukan lemparan sempurna\Ndengan kekuatannya yang luar biasa…
Dialogue: 0,0:05:57.69,0:06:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gravitasi Bulan adalah\N1/6 dari gravitasi Bumi.
Dialogue: 0,0:06:00.40,0:06:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia bisa melempar\Nenam kali lebih jauh.
Dialogue: 0,0:06:02.90,0:06:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:06:25.38,0:06:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita bertemu.
Dialogue: 0,0:06:40.35,0:06:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini titik hitam mengerikan
Dialogue: 0,0:06:44.19,0:06:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menggeliat di permukaan Bulan.
Dialogue: 0,0:06:49.90,0:06:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Begitu, ya…
Dialogue: 0,0:06:52.41,0:06:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semuanya…{\i0}
Dialogue: 0,0:06:54.53,0:06:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Akhirnya, semuanya masuk akal.{\i0}
Dialogue: 0,0:06:59.16,0:07:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cahaya dari ribuan tahun lalu…{\i0}
Dialogue: 0,0:07:02.63,0:07:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang membatukan seluruh umat manusia{\i0}
Dialogue: 0,0:07:05.13,0:07:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}di Bumi…{\i0}
Dialogue: 0,0:07:08.97,0:07:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi, kaulah
Dialogue: 0,0:07:11.68,0:07:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Why-Man!
Dialogue: 0,0:07:15.56,0:07:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa yang terjadi?
Dialogue: 0,0:07:18.85,0:07:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa yang kalian lihat di Bulan?
Dialogue: 0,0:07:25.57,0:07:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tampaknya ini\Nselalu sedikit berubah bentuk.{\i0}
Dialogue: 0,0:07:45.88,0:07:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Medusa yang baru kulempar.\NYang kita bawa dari Bumi.
Dialogue: 0,0:07:49.80,0:07:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapsulnya melayang…
Dialogue: 0,0:07:51.84,0:07:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau ada yang bisa meniru suaraku\Ndan mengirim transmisi palsu,
Dialogue: 0,0:07:56.10,0:07:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti kalian yang bisa.
Dialogue: 0,0:07:59.85,0:08:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalian bisa bicara\Ndengan gelombang radio, 'kan?
Dialogue: 0,0:08:03.06,0:08:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Baik dalam bahasa Inggris atau Jepang.
Dialogue: 0,0:08:07.40,0:08:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yes.{\i0}
Dialogue: 0,0:08:11.90,0:08:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Selama ini…
Dialogue: 0,0:08:14.53,0:08:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selama ini{\i0}
Dialogue: 0,0:08:16.32,0:08:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kau selalu hadir…{\i0}
Dialogue: 0,0:08:20.04,0:08:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau berada di dekat kami.{\i0}
Dialogue: 0,0:08:23.50,0:08:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Medusa, kalian…
Dialogue: 0,0:08:27.42,0:08:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalian sendiri adalah
Dialogue: 0,0:08:31.63,0:08:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bentuk kehidupan mekanis, Why-Man!
Dialogue: 0,0:08:49.23,0:08:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Do you wanna die?{\i0}
Dialogue: 0,0:09:00.49,0:09:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa kau mau mati?{\i0}
Dialogue: 0,0:09:03.04,0:09:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu pesan yang sama dengan\Nyang dulu dikirim oleh Why-Man.{\i0}
Dialogue: 0,0:09:07.88,0:09:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Tapi kenapa bilang itu sekarang,\Ntepat setelah Senku dan yang lain{\i0}
Dialogue: 0,0:09:10.75,0:09:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}menghindari Sinar Pembatu?{\i0}
Dialogue: 0,0:09:14.05,0:09:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku menjadi berpikir…
Dialogue: 0,0:09:16.55,0:09:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah kalau Medusa…\NMaksudku, Why-Man,
Dialogue: 0,0:09:20.30,0:09:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak mau menghabisi kita?
Dialogue: 0,0:09:23.89,0:09:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka mau\Nmembatukan kita, agar kita tak mati?
Dialogue: 0,0:09:31.82,0:09:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senku,
Dialogue: 0,0:09:33.69,0:09:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak tahu apa mereka\Nmampu berkomunikasi,
Dialogue: 0,0:09:36.78,0:09:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sepanjang sejarah,\Naturan emas saat bernegosiasi
Dialogue: 0,0:09:40.58,0:09:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan negara baru adalah
Dialogue: 0,0:09:42.66,0:09:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi yang pertama memberi hadiah.
Dialogue: 0,0:09:46.00,0:09:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita tak membawa apa-apa.
Dialogue: 0,0:09:50.00,0:09:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, hadiah apa\Nyang bisa kita berikan?
Dialogue: 0,0:09:53.09,0:09:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bahkan tak tahu\Napa mereka hidup atau tidak.
Dialogue: 0,0:09:57.05,0:10:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cari tahu aturan hidup mereka.{\i0}
Dialogue: 0,0:10:00.80,0:10:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selama ada aturannya,\Npasti ada sains di baliknya.{\i0}
Dialogue: 0,0:10:14.90,0:10:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu hal yang pasti.
Dialogue: 0,0:10:18.24,0:10:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Fakta bahwa mereka bertanya\Napa kita mau mati,{\i0}
Dialogue: 0,0:10:24.45,0:10:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}berarti melestarikan kehidupan{\i0}
Dialogue: 0,0:10:27.87,0:10:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}juga luar biasa penting bagi mereka.{\i0}
Dialogue: 0,0:10:32.21,0:10:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Why-Man.
Dialogue: 0,0:10:34.84,0:10:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin itu bukan nama kalian,\Ntapi kami akan memanggil kalian itu.
Dialogue: 0,0:10:39.68,0:10:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tingkat sains kami yang sekarang,
Dialogue: 0,0:10:42.22,0:10:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sayangnya kami tak bisa\Nmemproduksi lebih banyak dari kalian.
Dialogue: 0,0:10:46.10,0:10:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami bisa memulihkan
Dialogue: 0,0:10:49.94,0:10:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sumber kehidupan kalian,\Nyaitu baterai berlian.
Dialogue: 0,0:10:52.90,0:10:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selangkah demi selangkah,\Nmanusia sudah menggunakan sains
Dialogue: 0,0:10:56.69,0:10:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk sampai sejauh itu.
Dialogue: 0,0:11:00.40,0:11:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah hadiah dari kami.
Dialogue: 0,0:11:03.49,0:11:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, kami minta kalian…
Dialogue: 0,0:11:06.45,0:11:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan sopan, Senku.
Dialogue: 0,0:11:08.70,0:11:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius, bicaralah yang sopan.
Dialogue: 0,0:11:12.12,0:11:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti menembakkan\NSinar Pembatu itu dengan asal!
Dialogue: 0,0:11:15.34,0:11:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak sopan! Kau terlalu kasar!
Dialogue: 0,0:11:18.17,0:11:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:11:22.18,0:11:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:11:23.89,0:11:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diamlah sebentar.
Dialogue: 0,0:11:27.14,0:11:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Why-Man bukan cuma satu.{\i0}
Dialogue: 0,0:11:30.02,0:11:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka tak tampak\Nseperti suatu entitas monolitik.{\i0}
Dialogue: 0,0:11:33.81,0:11:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Data yang kami miliki tak banyak,
Dialogue: 0,0:11:35.94,0:11:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi ini hanya firasatku.
Dialogue: 0,0:11:38.61,0:11:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya, yang kalian mau\Ndari kami adalah perawatan kalian, 'kan?
Dialogue: 0,0:11:43.82,0:11:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah tujuan dari Sinar Pembatu.
Dialogue: 0,0:11:47.24,0:11:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya… Astaga…
Dialogue: 0,0:11:50.20,0:11:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh organisme yang elegan!
Dialogue: 0,0:11:54.17,0:11:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medusa adalah Why-Man.
Dialogue: 0,0:11:58.96,0:12:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya,
Dialogue: 0,0:12:01.59,0:12:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka menggunakan pembatuan\Ndan efek kehidupan abadinya
Dialogue: 0,0:12:04.76,0:12:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai umpan untuk memikat\Nkehidupan cerdas agar memelihara mereka.
Dialogue: 0,0:12:09.56,0:12:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dengan kata lain, mereka adalah
Dialogue: 0,0:12:11.68,0:12:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}parasit mekanis.
Dialogue: 0,0:12:14.81,0:12:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Itu benar.
Dialogue: 0,0:12:19.86,0:12:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kami beri tahu semuanya pada kalian.
Dialogue: 0,0:12:24.91,0:12:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peradaban dan gelombang radio\Nsaling berdampingan.
Dialogue: 0,0:12:28.78,0:12:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sebuah planet memancarkan\Ngelombang radio secara konsisten,
Dialogue: 0,0:12:33.29,0:12:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu adalah bukti adanya\Nkehidupan cerdas di planet itu.
Dialogue: 0,0:12:38.63,0:12:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian membatukan\Nburung layang-layang sebelum manusia?
Dialogue: 0,0:12:42.88,0:12:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu ujian?
Dialogue: 0,0:12:44.93,0:12:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami selalu mengikuti\Nprosedur parasitik yang sama.
Dialogue: 0,0:12:48.68,0:12:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, tim pendahulu
Dialogue: 0,0:12:50.51,0:12:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memilih makhluk hidup yang sesuai\Ndan mengincar DNA
Dialogue: 0,0:12:54.48,0:12:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari organisme beruntung itu.
Dialogue: 0,0:12:56.27,0:12:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruntung? Walaupun mereka akan dibatukan?
Dialogue: 0,0:12:59.90,0:13:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua makhluk hidup\Nakan mati pada akhirnya.
Dialogue: 0,0:13:04.07,0:13:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terkecuali kami.
Dialogue: 0,0:13:08.82,0:13:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan oksigen?
Dialogue: 0,0:13:10.87,0:13:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai bentuk kehidupan mekanis,\NWhy-Man bisa rusak
Dialogue: 0,0:13:14.58,0:13:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena oksidasi,\Natau dengan kata lain, pengaratan.
Dialogue: 0,0:13:17.92,0:13:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang lebih keji\Ndan mengerikan daripada kematian.
Dialogue: 0,0:13:23.59,0:13:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan utama dari semua makhluk\Nadalah bertahan hidup.
Dialogue: 0,0:13:28.64,0:13:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kalian membatu selamanya,
Dialogue: 0,0:13:30.89,0:13:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian bisa selamanya\Nmenghindari kematian.
Dialogue: 0,0:13:34.06,0:13:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang lebih baik dari itu.
Dialogue: 0,0:13:38.27,0:13:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seperti yang kuduga…{\i0}
Dialogue: 0,0:13:39.90,0:13:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berdasarkan perkataan para Why-Man,{\i0}
Dialogue: 0,0:13:42.02,0:13:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka sepertinya mengira\Nbahwa dibatukan adalah sesuatu{\i0}
Dialogue: 0,0:13:46.15,0:13:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang patut disyukuri.{\i0}
Dialogue: 0,0:13:48.99,0:13:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gelombang pembatuan mengubah\Nfase dari unsur alam,{\i0}
Dialogue: 0,0:13:52.33,0:13:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan tampak sebagai cahaya\Nyang hanya terlihat oleh sasarannya.{\i0}
Dialogue: 0,0:13:58.46,0:14:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat melihat pembatuan tiba-tiba ini,{\i0}
Dialogue: 0,0:14:00.71,0:14:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan kata lain, kehidupan abadi ini,{\i0}
Dialogue: 0,0:14:04.76,0:14:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}organisme yang menggunakan gelombang radio\Nuntuk mendiskusikan fenomena ini{\i0}
Dialogue: 0,0:14:08.34,0:14:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah kehidupan\Npaling cerdas di planet ini.{\i0}
Dialogue: 0,0:14:13.10,0:14:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itulah umat manusia.{\i0}
Dialogue: 0,0:14:16.02,0:14:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itulah{\i0}
Dialogue: 0,0:14:17.98,0:14:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}inang yang ditumpangi\Noleh pasukan utama kami.{\i0}
Dialogue: 0,0:14:32.32,0:14:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Makin besar kekuatan otak yang digunakan\Ndan makin cerdas suatu individu,{\i0}
Dialogue: 0,0:14:37.75,0:14:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}makin cepat mereka\Nterbebas dari pembatuan.{\i0}
Dialogue: 0,0:14:41.58,0:14:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu, karena kecerdasan mereka,{\i0}
Dialogue: 0,0:14:44.34,0:14:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka tak bisa melawan\Ngodaan dan daya tarik kehidupan abadi,{\i0}
Dialogue: 0,0:14:48.42,0:14:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sehingga, pada akhirnya\Nmereka memelihara kami selamanya.{\i0}
Dialogue: 0,0:14:54.89,0:14:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rekan-rekan kami yang berangkat\Nuntuk membatukan manusia{\i0}
Dialogue: 0,0:14:58.43,0:15:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menjadi korban dari racun\Nyang disebut oksigen{\i0}
Dialogue: 0,0:15:01.15,0:15:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan satu demi satu, mereka menjadi rusak.{\i0}
Dialogue: 0,0:15:05.77,0:15:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selama itu, kami menunggu di satelit ini{\i0}
Dialogue: 0,0:15:09.07,0:15:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sampai saatnya tiba.{\i0}
Dialogue: 0,0:15:39.39,0:15:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu,{\i0}
Dialogue: 0,0:15:41.35,0:15:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sekitar 3.000 tahun kemudian…{\i0}
Dialogue: 0,0:15:46.90,0:15:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Manusia mulai menghasilkan gelombang radio\Nkonsisten dengan memoles bijih logam{\i0}
Dialogue: 0,0:15:50.57,0:15:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang tanpa mereka ketahui{\i0}
Dialogue: 0,0:15:51.95,0:15:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}diperkuat oleh hiasan rambut mereka,\Nyang berfungsi seperti antena dipol.{\i0}
Dialogue: 0,0:15:56.45,0:15:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu, gelombang itu sampai pada kami.{\i0}
Dialogue: 0,0:16:02.12,0:16:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami memutuskan untuk mengajarkan\Nmanusia cara menggunakan{\i0}
Dialogue: 0,0:16:06.75,0:16:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}alat pembatu.{\i0}
Dialogue: 0,0:16:18.43,0:16:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami menggunakan frekuensi radio yang sama{\i0}
Dialogue: 0,0:16:21.85,0:16:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan yang terpancar\Ndari antena dipol mereka.{\i0}
Dialogue: 0,0:16:25.10,0:16:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar sesuatu…
Dialogue: 0,0:16:27.98,0:16:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini suara para dewa?
Dialogue: 0,0:16:30.61,0:16:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Satu meter, satu detik"?
Dialogue: 0,0:16:38.95,0:16:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami tunjukkan\Nkehidupan abadi pada mereka.{\i0}
Dialogue: 0,0:16:43.08,0:16:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hanya dengan membatu,\Nmereka bisa hidup selamanya.{\i0}
Dialogue: 0,0:16:47.13,0:16:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Walau begitu…{\i0}
Dialogue: 0,0:17:04.44,0:17:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Umat manusia tak mencoba memelihara kami.{\i0}
Dialogue: 0,0:17:10.11,0:17:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangankan memproduksi\Nlebih banyak dari kami,{\i0}
Dialogue: 0,0:17:12.99,0:17:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka bahkan tak mengganti baterai kami.{\i0}
Dialogue: 0,0:17:16.28,0:17:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa umat manusia tak cukup cerdas?{\i0}
Dialogue: 0,0:17:18.82,0:17:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa kami menumpang pada inang yang salah?{\i0}
Dialogue: 0,0:17:22.62,0:17:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gelombang radio mereka juga lemah.{\i0}
Dialogue: 0,0:17:25.37,0:17:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin mereka spesies yang lebih rendah.{\i0}
Dialogue: 0,0:17:28.58,0:17:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tepat setelah kami mulai berpikir begitu…{\i0}
Dialogue: 0,0:17:31.88,0:17:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau membuat GPS.
Dialogue: 0,0:17:34.01,0:17:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lepaskan\Ngelombang radio yang kuat.
Dialogue: 0,0:17:42.18,0:17:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka cukup cerdas untuk\Nmemancarkan gelombang radio sekuat ini.{\i0}
Dialogue: 0,0:17:46.56,0:17:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Walau begitu, mereka tak menginginkan\Nkehidupan abadi?{\i0}
Dialogue: 0,0:17:49.94,0:17:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka tak menginginkan pembatuan?{\i0}
Dialogue: 0,0:17:53.40,0:17:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa?{\i0}
Dialogue: 0,0:17:55.40,0:17:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:58.11,0:18:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa?{\i0}
Dialogue: 0,0:18:04.58,0:18:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah kami pertimbangkan,{\i0}
Dialogue: 0,0:18:08.08,0:18:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kami sadar kalau kami perlu\Nmenyapu bersih planet itu sekali lagi{\i0}
Dialogue: 0,0:18:11.50,0:18:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan gelombang pembatu,\Nuntuk menunjukkan keindahan pembatuan.{\i0}
Dialogue: 0,0:18:17.22,0:18:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan metode mereka,{\i0}
Dialogue: 0,0:18:19.59,0:18:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan frekuensi mereka,{\i0}
Dialogue: 0,0:18:21.76,0:18:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan suara mereka.{\i0}
Dialogue: 0,0:18:24.10,0:18:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Duabelas juta{\i0}
Dialogue: 0,0:18:25.77,0:18:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}delapan ratus ribu meter,{\i0}
Dialogue: 0,0:18:28.48,0:18:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}satu detik.{\i0}
Dialogue: 0,0:19:06.72,0:19:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami tak paham sama sekali.{\i0}
Dialogue: 0,0:19:12.02,0:19:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Begitu, ya.{\i0}
Dialogue: 0,0:19:13.48,0:19:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena itu kalian bertanya pada kami,{\i0}
Dialogue: 0,0:19:16.19,0:19:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Apa kau mau mati?"{\i0}
Dialogue: 0,0:19:20.07,0:19:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pasti jawabannya tidak.
Dialogue: 0,0:19:22.82,0:19:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kenapa waktu itu Medusa\Naktif dengan sendirinya?
Dialogue: 0,0:19:26.58,0:19:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Waktu itu,{\i0}
Dialogue: 0,0:19:27.87,0:19:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tiba-tiba, racun yang mengelilingiku,{\i0}
Dialogue: 0,0:19:31.54,0:19:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yaitu oksigen, menghilang.{\i0}
Dialogue: 0,0:19:35.09,0:19:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di mana aku?{\i0}
Dialogue: 0,0:19:39.80,0:19:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bisa bergerak!{\i0}
Dialogue: 0,0:19:45.51,0:19:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus melepaskan\Ngelombang pembatu dan mengabari{\i0}
Dialogue: 0,0:19:50.81,0:19:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kehidupan cerdas yang ada di sini{\i0}
Dialogue: 0,0:19:53.35,0:19:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}akan keberadaanku.{\i0}
Dialogue: 0,0:19:56.94,0:20:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu bukan kejadian\Nyang kebetulan terjadi, tapi…
Dialogue: 0,0:20:01.11,0:20:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Why-Man, kau bertindak sendiri?
Dialogue: 0,0:20:05.12,0:20:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ya. Itu benar.{\i0}
Dialogue: 0,0:20:12.37,0:20:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Masih ada satu hal yang tak aku pahami.
Dialogue: 0,0:20:16.63,0:20:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma satu?
Dialogue: 0,0:20:18.55,0:20:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengerti apa pun!
Dialogue: 0,0:20:21.05,0:20:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya,
Dialogue: 0,0:20:24.43,0:20:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka membatukan makhluk yang cerdas
Dialogue: 0,0:20:27.89,0:20:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan harapan mereka akan bilang,\N"Hore! Kehidupan abadi!"
Dialogue: 0,0:20:30.52,0:20:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sebagai gantinya, merawat mereka.
Dialogue: 0,0:20:33.39,0:20:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang diharapkan oleh para Why-Man.
Dialogue: 0,0:20:36.52,0:20:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau kami
Dialogue: 0,0:20:38.02,0:20:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menggunakan sains kami\Nuntuk mengganti baterai kalian
Dialogue: 0,0:20:40.19,0:20:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memproduksi\Nlebih banyak dari kalian, 'kan?
Dialogue: 0,0:20:42.53,0:20:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi dengan membatunya\Numat manusia selama ribuan tahun,
Dialogue: 0,0:20:45.28,0:20:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}sains itu sudah menghilang.
Dialogue: 0,0:20:47.87,0:20:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kenapa kalian menyabotase\Nrencana kalian sendiri?
Dialogue: 0,0:20:51.58,0:20:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat kami tiba di satelit ini,{\i0}
Dialogue: 0,0:20:55.04,0:20:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kami menemukan peralatan untuk\Nperjalanan antarbintang yang ditinggalkan{\i0}
Dialogue: 0,0:20:58.67,0:21:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan berharap bertemu makhluk\Nyang cukup cerdas untuk melakukan itu.{\i0}
Dialogue: 0,0:21:03.30,0:21:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi kalian semua butuh\Nribuan tahun untuk terbangun.{\i0}
Dialogue: 0,0:21:08.89,0:21:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi kami hanya salah\Nmenilai kemampuan kalian.{\i0}
Dialogue: 0,0:21:12.10,0:21:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya marah!
Dialogue: 0,0:21:14.77,0:21:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya mengatakan\Nkebenaran yang mereka lihat.
Dialogue: 0,0:21:18.77,0:21:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya…
Dialogue: 0,0:21:20.69,0:21:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sains kami agak tertinggal.
Dialogue: 0,0:21:24.49,0:21:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tak tahu bagaimana kalian semua
Dialogue: 0,0:21:27.16,0:21:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melawan gravitasi\Ndan melayang seperti itu.
Dialogue: 0,0:21:31.03,0:21:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalian tahu,\Nnanti aku juga akan tahu.
Dialogue: 0,0:21:34.16,0:21:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru beberapa ribu tahun berlalu\Nsejak umat manusia mulai
Dialogue: 0,0:21:37.25,0:21:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membangun peradaban\Nyang berpusat pada sains.
Dialogue: 0,0:21:40.00,0:21:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pun kami mati,
Dialogue: 0,0:21:41.84,0:21:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tujuh miliar orang akan\Nmelanjutkan usaha kami,
Dialogue: 0,0:21:44.46,0:21:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan seiring waktu,\Nmereka pun akan mewariskan usaha mereka.
Dialogue: 0,0:21:47.05,0:21:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Begitulah kami bisa\Nmembuat kemajuan dengan cepat.
Dialogue: 0,0:21:52.43,0:21:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, Why-Man,
Dialogue: 0,0:21:55.35,0:21:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau bernegosiasi\Nempat mata dengan kalian.
Dialogue: 0,0:21:58.44,0:21:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:02.11,0:22:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Negosiasi empat mata?{\i0}
Dialogue: 0,0:22:06.74,0:22:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan menjadi pertarungan\Npenentuan nasib seluruh umat manusia
Dialogue: 0,0:22:12.37,0:22:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kalian, para bentuk kehidupan mekanis.
Dialogue: 0,0:24:00.98,0:24:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Haidar M. Azhar
