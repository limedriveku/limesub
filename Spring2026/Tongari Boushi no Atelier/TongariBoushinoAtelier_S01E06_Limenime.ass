Dialogue: 0,0:01:44.89,0:01:47.23,tanda,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:03:15.27,0:03:17.94,tanda,,0000,0000,0000,,{\an8}CAHAYA DALAM HUJAN
Dialogue: 0,0:23:36.74,0:23:38.95,tanda,,0000,0000,0000,,EPISODE 7\NSIHIR UNTUK SESEORANG
Dialogue: 0,0:00:47.92,0:00:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku terlalu berisik?
Dialogue: 0,0:01:13.19,0:01:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cahayanya redup.{\i0}
Dialogue: 0,0:01:14.99,0:01:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak stabil juga.{\i0}
Dialogue: 0,0:03:08.93,0:03:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Masih berantakan.
Dialogue: 0,0:03:11.44,0:03:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku tak sempat memilih pena{\i0}
Dialogue: 0,0:03:13.35,0:03:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}yang cocok untukku di Kalhn.{\i0}
Dialogue: 0,0:03:21.36,0:03:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bisa menggambar garis lurus\Nmenggunakan batu pigmen,{\i0}
Dialogue: 0,0:03:25.37,0:03:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi ini tak cocok\Nuntuk kertas kecil seperti ini.{\i0}
Dialogue: 0,0:03:34.88,0:03:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dulu, aku sama sekali\Ntak bisa menggambar mantra.{\i0}
Dialogue: 0,0:03:39.30,0:03:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Guru bilang bahwa ide juga penting\Nuntuk sihir, tapi…{\i0}
Dialogue: 0,0:03:43.38,0:03:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh! Makin dipikirkan,\Nmakin sedih rasanya!
Dialogue: 0,0:03:46.10,0:03:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya perlu membiasakan diri!
Dialogue: 0,0:03:48.31,0:03:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta rajin berlatih!
Dialogue: 0,0:03:49.64,0:03:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha!
Dialogue: 0,0:03:50.64,0:03:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:03:57.48,0:03:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku mengantuk.
Dialogue: 0,0:04:06.57,0:04:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau tidur di sini,
Dialogue: 0,0:04:08.70,0:04:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nanti masuk angin.
Dialogue: 0,0:04:13.08,0:04:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak berencana untuk tidur,
Dialogue: 0,0:04:15.79,0:04:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tiba-tiba mengantuk.
Dialogue: 0,0:04:17.46,0:04:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:04:21.21,0:04:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, aku tak akan bisa\Nmelewati ujian Menara Makam
Dialogue: 0,0:04:25.30,0:04:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menemukan buku bergambar itu.
Dialogue: 0,0:04:29.60,0:04:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersikap negatif lagi!
Dialogue: 0,0:04:32.39,0:04:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu! Aku pasti bisa!
Dialogue: 0,0:04:34.60,0:04:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku benar-benar menyukai sihir…
Dialogue: 0,0:04:37.73,0:04:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Coco.
Dialogue: 0,0:04:42.53,0:04:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ikut aku sebentar.
Dialogue: 0,0:04:48.74,0:04:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapur?
Dialogue: 0,0:04:51.74,0:04:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya sedap.
Dialogue: 0,0:04:54.16,0:04:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berencana membersihkan\Npanci-panci yang ada di sini.
Dialogue: 0,0:05:00.63,0:05:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini. Coba kau cicipi.
Dialogue: 0,0:05:10.31,0:05:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:05:14.35,0:05:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, ya? Aku masak semur ini\Ndua tahun lalu.
Dialogue: 0,0:05:18.02,0:05:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panci sihir itu terus memutar waktu\Nke waktu matang agar tetap lezat.
Dialogue: 0,0:05:22.61,0:05:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:05:24.53,0:05:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap saja,\Nsegelnya sesekali harus digambar ulang
Dialogue: 0,0:05:28.28,0:05:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau nanti pancinya bisa rusak.
Dialogue: 0,0:05:32.49,0:05:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang keras!
Dialogue: 0,0:05:35.20,0:05:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang ini rasanya lezat.
Dialogue: 0,0:05:37.79,0:05:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bantu aku memasak kentang keras itu?
Dialogue: 0,0:05:41.88,0:05:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah bisa menggambar\NSegel Bola Api, bukan?
Dialogue: 0,0:06:10.70,0:06:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:12.16,0:06:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang itu berat,\Njadi, buat panah yang lebih panjang.
Dialogue: 0,0:06:19.62,0:06:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Pastikan apinya cukup besar dan merata.
Dialogue: 0,0:06:25.46,0:06:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, lambangnya terlalu besar.
Dialogue: 0,0:06:28.26,0:06:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kau terus mencoba?
Dialogue: 0,0:06:59.12,0:07:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini berhasil!
Dialogue: 0,0:07:05.09,0:07:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, matang sempurna.
Dialogue: 0,0:07:09.59,0:07:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:07:11.26,0:07:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih mengantuk?
Dialogue: 0,0:07:14.89,0:07:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu?
Dialogue: 0,0:07:16.47,0:07:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir pertama yang kukuasai
Dialogue: 0,0:07:18.64,0:07:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah sihir air.
Dialogue: 0,0:07:24.02,0:07:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebagian karena aku tak pandai berenang,{\i0}
Dialogue: 0,0:07:26.57,0:07:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi aku juga tak suka basah.{\i0}
Dialogue: 0,0:07:29.44,0:07:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu berlatih\Nagar tak perlu mencuci piring.
Dialogue: 0,0:07:35.45,0:07:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau merasa gelisah
Dialogue: 0,0:07:37.91,0:07:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ingin cepat menguasainya,
Dialogue: 0,0:07:40.62,0:07:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cara terbaik adalah menjadikan itu
Dialogue: 0,0:07:43.96,0:07:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagian hidupmu.
Dialogue: 0,0:07:45.96,0:07:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengalaman adalah guru\Nyang paling berharga.
Dialogue: 0,0:07:52.76,0:07:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadikan sihir
Dialogue: 0,0:07:54.72,0:07:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagian dari hidup…
Dialogue: 0,0:07:56.72,0:07:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasak itu seru.\NBisa berlatih, dan hasilnya enak.
Dialogue: 0,0:08:00.10,0:08:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Benar!\N- Hei!
Dialogue: 0,0:08:01.98,0:08:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin aku mencium aroma sedap.
Dialogue: 0,0:08:04.06,0:08:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian membuat sesuatu yang lezat!
Dialogue: 0,0:08:06.73,0:08:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah! Aku yang akan melelehkan kejunya!
Dialogue: 0,0:08:10.19,0:08:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memberi bekas bakaran\Ndengan sihir itu sangat keren.
Dialogue: 0,0:08:12.74,0:08:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Anak-Anak.
Dialogue: 0,0:08:14.49,0:08:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin Coco mencobanya hari ini.
Dialogue: 0,0:08:17.41,0:08:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau mencoba?
Dialogue: 0,0:08:19.41,0:08:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:42.14,0:08:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai!
Dialogue: 0,0:08:43.64,0:08:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya lezat!
Dialogue: 0,0:08:46.02,0:08:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu! Bagaimana\Nkalau kita makan di luar?
Dialogue: 0,0:08:49.44,0:08:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus. Seperti piknik.
Dialogue: 0,0:08:53.11,0:08:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan bersiap.
Dialogue: 0,0:08:56.53,0:08:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:08:57.78,0:09:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga harus ikut.\NMari makan siang di luar!
Dialogue: 0,0:09:00.79,0:09:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan makan sambil bekerja.
Dialogue: 0,0:09:03.62,0:09:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku makan di sini saja.
Dialogue: 0,0:09:05.54,0:09:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula…
Dialogue: 0,0:09:09.09,0:09:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujan.
Dialogue: 0,0:09:10.29,0:09:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Padahal tadi masih cerah.
Dialogue: 0,0:09:14.34,0:09:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi?
Dialogue: 0,0:09:15.55,0:09:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru tadi bilang kalau dia tak suka basah.
Dialogue: 0,0:09:18.59,0:09:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Anak-Anak.\N- Ya?
Dialogue: 0,0:09:20.30,0:09:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian tampak begitu kecewa?
Dialogue: 0,0:09:29.86,0:09:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita adalah penyihir?
Dialogue: 0,0:09:33.07,0:09:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ambil barang-barang kita\Ndan berangkat.
Dialogue: 0,0:10:09.56,0:10:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:10:11.02,0:10:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Langitnya mulai cerah.
Dialogue: 0,0:10:25.58,0:10:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:10:26.70,0:10:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sebaiknya mengajak Agott!
Dialogue: 0,0:10:29.37,0:10:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama lebih seru.
Dialogue: 0,0:10:31.29,0:10:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat sihir yang ditunjukkan langit.
Dialogue: 0,0:10:45.93,0:10:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott?
Dialogue: 0,0:10:51.56,0:10:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau siapa?
Dialogue: 0,0:10:53.44,0:10:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengenalmu.
Dialogue: 0,0:10:55.90,0:10:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa seseorang mengutusmu? Alaira?
Dialogue: 0,0:11:00.70,0:11:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku…
Dialogue: 0,0:11:02.70,0:11:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:11:04.58,0:11:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badai akan datang, jadi…
Dialogue: 0,0:11:09.91,0:11:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah murid Guru Qifrey.
Dialogue: 0,0:11:15.25,0:11:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:17.05,0:11:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid?
Dialogue: 0,0:11:19.26,0:11:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey.
Dialogue: 0,0:11:21.18,0:11:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Olruggio. Pekerjaanmu sudah selesai?
Dialogue: 0,0:11:24.18,0:11:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir masih lama…
Dialogue: 0,0:11:25.60,0:11:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau punya murid lagi?
Dialogue: 0,0:11:28.18,0:11:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada penjelasan untuk ini.
Dialogue: 0,0:11:30.27,0:11:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia korban sihir terlarang…
Dialogue: 0,0:11:33.02,0:11:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir terlarang?
Dialogue: 0,0:11:36.98,0:11:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikut aku.
Dialogue: 0,0:11:38.48,0:11:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Olruggio!
Dialogue: 0,0:11:42.49,0:11:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau terlibat\Ndengan Penyihir Bertopeng.
Dialogue: 0,0:11:45.57,0:11:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyerahkannya\Nke Ksatria Moralis.
Dialogue: 0,0:11:48.41,0:11:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku mohon! Aku…
Dialogue: 0,0:11:59.00,0:12:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan membiarkan itu terjadi.
Dialogue: 0,0:12:01.80,0:12:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau adalah teman baikku.
Dialogue: 0,0:12:06.22,0:12:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan menyerangku dengan sihirmu?
Dialogue: 0,0:12:09.18,0:12:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa gadis ini?
Dialogue: 0,0:12:12.52,0:12:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya, kita masuk dulu.
Dialogue: 0,0:12:15.10,0:12:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjelaskan semuanya.
Dialogue: 0,0:12:20.99,0:12:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir hujan akan reda\Nbegitu langit mulai cerah,
Dialogue: 0,0:12:23.99,0:12:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi justru makin deras.
Dialogue: 0,0:12:28.45,0:12:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Astaga! Sepertinya, malam ini akan berat.
Dialogue: 0,0:12:31.75,0:12:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ya…
Dialogue: 0,0:12:33.50,0:12:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan ada badai.
Dialogue: 0,0:12:35.88,0:12:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau membuat pengecualian\Ndan menerima orang luar sebagai murid?
Dialogue: 0,0:12:40.34,0:12:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sopan menyebutnya "orang luar".
Dialogue: 0,0:12:43.13,0:12:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Coco.
Dialogue: 0,0:12:44.59,0:12:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Coco.
Dialogue: 0,0:12:46.89,0:12:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada sebutan lain\Nuntuk orang yang bukan penyihir.
Dialogue: 0,0:12:52.22,0:12:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baru bertemu, bukan?
Dialogue: 0,0:12:56.44,0:12:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Olruggio.
Dialogue: 0,0:12:58.36,0:13:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Mata Pengawas sanggar ini.
Dialogue: 0,0:13:02.28,0:13:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berbeda dari Kalhn atau Aula Besar,{\i0}
Dialogue: 0,0:13:04.45,0:13:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sanggar kecil di pelosok seperti kita{\i0}
Dialogue: 0,0:13:07.11,0:13:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bisa cukup terisolasi.{\i0}
Dialogue: 0,0:13:09.41,0:13:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Supaya tak ada masalah yang disembunyikan,\Npenyihir lain ditugaskan{\i0}
Dialogue: 0,0:13:13.50,0:13:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}untuk tinggal di sini\Nsebagai "Mata Pengawas".{\i0}
Dialogue: 0,0:13:16.42,0:13:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau sama sekali tidak kesulitan\Nmenyembunyikan masalah.
Dialogue: 0,0:13:23.51,0:13:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku menghapus ingatan Coco hari itu,
Dialogue: 0,0:13:26.97,0:13:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan kehilangan petunjuk\Nbuku bergambar sihir terlarang.
Dialogue: 0,0:13:30.93,0:13:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta agar dapat mengembalikan ibunya,
Dialogue: 0,0:13:33.93,0:13:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurutku, ini pilihan terbaik.
Dialogue: 0,0:13:36.77,0:13:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petunjuk?
Dialogue: 0,0:13:38.81,0:13:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan tugas kita\Nmenyelidiki sihir terlarang.
Dialogue: 0,0:13:43.19,0:13:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah tugas Ksatria Moralis.
Dialogue: 0,0:13:56.41,0:13:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Apa itu Ksatria Moralis\Nyang sejak tadi mereka sebut?"
Dialogue: 0,0:13:59.79,0:14:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mudah ditebak.
Dialogue: 0,0:14:02.21,0:14:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ksatria Pelindung Moralitas Sihir\Nalias Ksatria Moralis.{\i0}
Dialogue: 0,0:14:05.26,0:14:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka tunduk pada aturan Hari Perjanjian.{\i0}
Dialogue: 0,0:14:08.05,0:14:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka menghapus ingatan orang\Nyang menggunakan sihir terlarang{\i0}
Dialogue: 0,0:14:11.22,0:14:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}atau yang mengetahui rahasia sihir.{\i0}
Dialogue: 0,0:14:13.47,0:14:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka adalah penyihir\Nyang melindungi sihir.{\i0}
Dialogue: 0,0:14:16.23,0:14:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka tunduk pada aturan\Ntanpa pandang bulu dan tanpa pengecualian.{\i0}
Dialogue: 0,0:14:20.73,0:14:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyerahkannya\Nkepada orang seperti itu,
Dialogue: 0,0:14:23.69,0:14:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka juga akan menghapus\Nkecintaannya pada sihir.
Dialogue: 0,0:14:33.66,0:14:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco anak yang baik.
Dialogue: 0,0:14:36.08,0:14:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia pekerja keras dan menyayangi ibunya.{\i0}
Dialogue: 0,0:14:38.71,0:14:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terlebih lagi, dia mencintai sihir.{\i0}
Dialogue: 0,0:14:41.58,0:14:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku, dia jadi tahu kebenarannya.
Dialogue: 0,0:14:44.84,0:14:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingatan Coco tentang sihir dihapus,
Dialogue: 0,0:14:48.84,0:14:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka ingatanku juga harus dihapus.
Dialogue: 0,0:14:56.35,0:14:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:14:57.81,0:15:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau setuju\Nmenerima mereka sebagai murid,
Dialogue: 0,0:15:01.15,0:15:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pikir kau akhirnya sadar.
Dialogue: 0,0:15:05.94,0:15:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kau saja.
Dialogue: 0,0:15:09.49,0:15:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau terjadi sesuatu,\Naku akan segera melapor ke Aula Besar.
Dialogue: 0,0:15:14.70,0:15:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu adalah tugas Mata Pengawas.
Dialogue: 0,0:15:24.13,0:15:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey.
Dialogue: 0,0:15:25.75,0:15:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:15:27.63,0:15:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lulus ujian dengan sihirmu sendiri\Ndan menjadi murid secara resmi.
Dialogue: 0,0:15:33.97,0:15:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau boleh merasa bangga.
Dialogue: 0,0:15:40.56,0:15:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:41.48,0:15:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:44.23,0:15:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, Anak-Anak, mandi air hangat dulu\Nagar tidak masuk angin.
Dialogue: 0,0:15:48.07,0:15:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik!\N- Ya!
Dialogue: 0,0:15:55.32,0:15:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Kuas?
Dialogue: 0,0:15:57.99,0:15:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Kuas?
Dialogue: 0,0:16:00.70,0:16:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau di mana, Teman Kuas?
Dialogue: 0,0:16:06.25,0:16:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Teman Kuas, itu…
Dialogue: 0,0:16:09.63,0:16:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka! Dia masuk!
Dialogue: 0,0:16:25.02,0:16:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan ketuk. Kau akan dikutuk."
Dialogue: 0,0:16:35.70,0:16:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, permisi.
Dialogue: 0,0:16:39.66,0:16:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarlah, Teman Kuas.
Dialogue: 0,0:16:42.96,0:16:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari keringkan bulumu bersama.
Dialogue: 0,0:16:49.67,0:16:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:16:53.34,0:16:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana tertulis, "Jangan ketuk."
Dialogue: 0,0:16:57.34,0:16:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti dilarang masuk.
Dialogue: 0,0:17:06.40,0:17:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau dengar, Coco?
Dialogue: 0,0:17:09.48,0:17:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:10.73,0:17:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:11.82,0:17:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kau basah kuyup.\NKenapa sekarang kering?
Dialogue: 0,0:17:21.66,0:17:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hangat.{\i0}
Dialogue: 0,0:17:23.54,0:17:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rambutku juga jadi kering.{\i0}
Dialogue: 0,0:17:26.50,0:17:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa ini{\i0}
Dialogue: 0,0:17:28.33,0:17:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sihir Tuan Olruggio?{\i0}
Dialogue: 0,0:17:38.14,0:17:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:17:40.39,0:17:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai kau sakit.
Dialogue: 0,0:17:42.14,0:17:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah Mata Pengawas di sini.
Dialogue: 0,0:17:44.14,0:17:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia juga mengawasi kesehatan kami.{\i0}
Dialogue: 0,0:17:46.27,0:17:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu salahku karena lupa menutup pintu.
Dialogue: 0,0:17:49.77,0:17:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, keluar sana.
Dialogue: 0,0:17:51.73,0:17:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh apa pun…
Dialogue: 0,0:17:54.40,0:17:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh apa pun, kataku!
Dialogue: 0,0:17:58.28,0:18:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini… Sihir ini!
Dialogue: 0,0:18:02.20,0:18:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini sihir pertama\Nyang membuatku menyukai sihir!
Dialogue: 0,0:18:05.37,0:18:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Batu yang bersinar saat diinjak!
Dialogue: 0,0:18:08.33,0:18:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan Batu Pijar adalah mantra orisinalku.
Dialogue: 0,0:18:13.55,0:18:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu-batu ini disusun berlapis.
Dialogue: 0,0:18:16.13,0:18:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beratnya membuat lambang dan lingkaran\Ntumpang tindih. Mantra sederhana.
Dialogue: 0,0:18:20.05,0:18:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menemukannya di mana pun… Apa?
Dialogue: 0,0:18:22.81,0:18:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:18:24.68,0:18:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bersinar.
Dialogue: 0,0:18:27.77,0:18:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang begitu cara kerja mantranya.
Dialogue: 0,0:18:33.11,0:18:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, ini cahaya yang istimewa.
Dialogue: 0,0:18:41.78,0:18:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat aku berjalan,\Nbatu-batunya akan bersinar.{\i0}
Dialogue: 0,0:18:44.54,0:18:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seolah-olah aku punya kekuatan sihir.{\i0}
Dialogue: 0,0:18:49.12,0:18:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berjalan di setiap langkahnya saja\Nsudah terasa sangat menyenangkan.{\i0}
Dialogue: 0,0:18:55.50,0:18:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu juga kenangan yang menyedihkan.{\i0}
Dialogue: 0,0:19:00.80,0:19:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu…
Dialogue: 0,0:19:05.81,0:19:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}sihir ini memberiku impian.
Dialogue: 0,0:19:10.52,0:19:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi…
Dialogue: 0,0:19:12.90,0:19:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terima kasih banyak,
Dialogue: 0,0:19:14.69,0:19:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Olruggio.
Dialogue: 0,0:19:19.40,0:19:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:19:20.86,0:19:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan guru! Keluar dari sini.
Dialogue: 0,0:19:34.38,0:19:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan menghapus kecintaannya…
Dialogue: 0,0:19:37.71,0:19:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada sihir, ya?
Dialogue: 0,0:19:47.31,0:19:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujannya masih belum reda.
Dialogue: 0,0:19:50.02,0:19:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:51.52,0:19:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku akan belajar\Ndi ruang tengah hari ini.
Dialogue: 0,0:19:55.48,0:19:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ikut, Agott?
Dialogue: 0,0:19:57.02,0:19:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terima kasih.
Dialogue: 0,0:19:58.69,0:20:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih fokus di kamar.
Dialogue: 0,0:20:00.90,0:20:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:20:02.74,0:20:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, nanti aku panggil\Nsaat makan siang.
Dialogue: 0,0:20:28.72,0:20:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah!
Dialogue: 0,0:20:30.85,0:20:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berisik sekali.{\i0}
Dialogue: 0,0:20:32.94,0:20:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak bisa konsentrasi.{\i0}
Dialogue: 0,0:20:38.65,0:20:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak apa-apa.{\i0}
Dialogue: 0,0:20:39.73,0:20:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sedikit kebisingan bagus untuk latihan.{\i0}
Dialogue: 0,0:20:56.71,0:20:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Masih agak goyah, tapi sudah lebih stabil.{\i0}
Dialogue: 0,0:21:00.21,0:21:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau begini, aku bisa\Nmengikuti ujian berikutnya.{\i0}
Dialogue: 0,0:21:03.92,0:21:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bahkan bekerja!{\i0}
Dialogue: 0,0:21:07.47,0:21:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baiklah, sekali lagi.{\i0}
Dialogue: 0,0:21:12.52,0:21:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong! Aku mohon!
Dialogue: 0,0:21:14.31,0:21:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada penyihir di sini, bukan?
Dialogue: 0,0:21:16.06,0:21:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:21:17.19,0:21:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa berisik sekali?
Dialogue: 0,0:21:19.06,0:21:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti situasinya.\NDan tempat kejadiannya…
Dialogue: 0,0:21:22.11,0:21:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kami, Tuan Penyihir!
Dialogue: 0,0:21:24.07,0:21:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tolong!\N- Baik.
Dialogue: 0,0:21:25.82,0:21:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu. Kami akan segera bersiap.
Dialogue: 0,0:21:29.45,0:21:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:21:31.12,0:21:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujan menghancurkan jembatan\Ndi atas Sungai Tangga.
Dialogue: 0,0:21:34.58,0:21:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kereta yang terjebak di tengah sungai.
Dialogue: 0,0:21:38.13,0:21:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu berbahaya untuk didekati.
Dialogue: 0,0:21:41.96,0:21:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putraku
Dialogue: 0,0:21:43.71,0:21:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terjebak dalam kereta itu!
Dialogue: 0,0:21:46.22,0:21:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku mengerti.
Dialogue: 0,0:21:48.22,0:21:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kita jalan.\N- Mohon bantuannya!
Dialogue: 0,0:21:50.35,0:21:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pekerjaan sungguhan!{\i0}
Dialogue: 0,0:21:51.97,0:21:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawa satu orang lagi…
Dialogue: 0,0:21:54.02,0:21:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:21:55.10,0:21:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott, ini berbahaya,\Nkalian tetap di sini…
Dialogue: 0,0:21:57.73,0:22:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Tolong izinkan aku ikut denganmu.
Dialogue: 0,0:22:02.11,0:22:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti bisa membantumu.
Dialogue: 0,0:22:04.11,0:22:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jamin!
Dialogue: 0,0:23:38.95,0:23:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana
