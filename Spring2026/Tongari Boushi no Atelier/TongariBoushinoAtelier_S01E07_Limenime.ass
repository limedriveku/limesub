Dialogue: 0,0:02:39.99,0:02:42.24,tanda,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:04:01.99,0:04:05.82,tanda,,0000,0000,0000,,{\an8}SIHIR UNTUK SESEORANG
Dialogue: 0,0:23:36.83,0:23:39.04,tanda,,0000,0000,0000,,EPISODE 8\NDALAM KECURIGAAN KSATRIA MORALIS
Dialogue: 0,0:00:13.26,0:00:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegang erat barang-barangmu!
Dialogue: 0,0:00:15.09,0:00:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti.
Dialogue: 0,0:00:16.97,0:00:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Penyihir!
Dialogue: 0,0:00:18.51,0:00:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jembatannya di bawah pohon itu!
Dialogue: 0,0:00:26.48,0:00:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong izinkan aku ikut denganmu.
Dialogue: 0,0:00:28.48,0:00:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti bisa membantumu. Aku jamin!
Dialogue: 0,0:00:33.32,0:00:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott…
Dialogue: 0,0:00:35.36,0:00:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berbeda dari tugas yang biasa.
Dialogue: 0,0:00:38.53,0:00:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak orang biasa di luar sana.
Dialogue: 0,0:00:41.49,0:00:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan belum mengikuti\Nujian tahap kedua
Dialogue: 0,0:00:44.29,0:00:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memungkinkanmu\Nmenggunakan sihir di depan mereka.
Dialogue: 0,0:00:47.04,0:00:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sekarang…
Dialogue: 0,0:00:49.50,0:00:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan sekarang, lalu kapan?
Dialogue: 0,0:00:51.63,0:00:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah berlatih sendiri.
Dialogue: 0,0:00:53.88,0:00:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa pakai sihir di depan orang.
Dialogue: 0,0:00:56.38,0:00:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama mempersiapkan diri\Nuntuk ujian itu.
Dialogue: 0,0:00:59.76,0:01:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah guru harus memberi muridnya\Nlebih banyak pengalaman?
Dialogue: 0,0:01:05.35,0:01:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja…
Dialogue: 0,0:01:07.10,0:01:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah!
Dialogue: 0,0:01:09.19,0:01:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera kembali!
Dialogue: 0,0:01:12.11,0:01:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pergi duluan.
Dialogue: 0,0:01:14.03,0:01:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pasang jendela jalan di sana.
Dialogue: 0,0:01:18.78,0:01:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau siapkan obat dan alatnya.
Dialogue: 0,0:01:21.99,0:01:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawa Agott.
Dialogue: 0,0:01:25.04,0:01:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ambil jubah dan topiku.
Dialogue: 0,0:01:29.38,0:01:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:01:30.46,0:01:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga ikut!
Dialogue: 0,0:01:35.17,0:01:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berekspresi seperti itu.
Dialogue: 0,0:01:38.05,0:01:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal yang baru dipahami\Nketika melihat kenyataan.
Dialogue: 0,0:01:41.55,0:01:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir.
Dialogue: 0,0:01:44.06,0:01:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terutama soal Agott.{\i0}
Dialogue: 0,0:01:46.10,0:01:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia terlalu terpaku{\i0}
Dialogue: 0,0:01:48.10,0:01:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}pada ketidakmampuannya,\Nbukan kegembiraan atas kemampuannya.{\i0}
Dialogue: 0,0:01:54.15,0:01:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada salahnya kurang pengalaman.{\i0}
Dialogue: 0,0:01:57.57,0:01:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dalam usahanya untuk berkembang…{\i0}
Dialogue: 0,0:02:01.32,0:02:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}semoga dia tidak kehilangan pijakan.{\i0}
Dialogue: 0,0:02:10.63,0:02:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pijakannya tidak stabil.
Dialogue: 0,0:02:12.88,0:02:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihatnya! Itu dia!
Dialogue: 0,0:04:05.82,0:04:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu…
Dialogue: 0,0:04:08.95,0:04:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir!
Dialogue: 0,0:04:11.37,0:04:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah. Kita aman sekarang.
Dialogue: 0,0:04:13.83,0:04:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Penyihir sudah datang!
Dialogue: 0,0:04:16.29,0:04:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott.
Dialogue: 0,0:04:18.67,0:04:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu cara menggunakan ini, bukan?
Dialogue: 0,0:04:21.84,0:04:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keringkan pakaian mereka dengan itu.
Dialogue: 0,0:04:24.80,0:04:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap siaga begitu tugasmu selesai.
Dialogue: 0,0:04:28.30,0:04:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku hanya menggunakan alat ini?
Dialogue: 0,0:04:31.89,0:04:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak ada yang lain?\N- Itu saja cukup.
Dialogue: 0,0:04:35.14,0:04:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, kau butuh apa lagi?
Dialogue: 0,0:04:38.61,0:04:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu mudah? Kurang menantang?
Dialogue: 0,0:04:42.11,0:04:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja kalau Qifrey khawatir.
Dialogue: 0,0:04:45.78,0:04:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott,
Dialogue: 0,0:04:48.57,0:04:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau terlalu terburu-buru.
Dialogue: 0,0:04:52.41,0:04:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin membuktikan diri,\Nbukan ini tempatnya.
Dialogue: 0,0:04:56.83,0:05:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau memang ingin membantu,
Dialogue: 0,0:05:00.59,0:05:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pikirkan baik-baik\Nalasanmu menggunakan sihir.
Dialogue: 0,0:05:09.35,0:05:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lagi-lagi memperlakukanku\Nseperti anak tak berguna.{\i0}
Dialogue: 0,0:05:14.85,0:05:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Percuma aku bekerja keras\Nkalau tak bisa menunjukkan hasilnya.{\i0}
Dialogue: 0,0:05:20.15,0:05:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus segera membuktikan\Nkepada orang itu{\i0}
Dialogue: 0,0:05:24.36,0:05:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bahwa aku penyihir\Nyang lebih berharga daripada ini.{\i0}
Dialogue: 0,0:05:32.79,0:05:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey!
Dialogue: 0,0:05:49.47,0:05:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:05:50.93,0:05:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Coba lihat itu!
Dialogue: 0,0:05:52.76,0:05:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dia membelah sungai dengan pedang!
Dialogue: 0,0:05:54.85,0:05:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hei, mundur! Tebingnya berbahaya!
Dialogue: 0,0:05:58.06,0:06:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Olruggio! Ada berapa orang?
Dialogue: 0,0:06:00.73,0:06:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua! Aku akan membawa yang pertama!
Dialogue: 0,0:06:08.82,0:06:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, ini cukup berat.
Dialogue: 0,0:06:11.32,0:06:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sebabnya aku benci air.
Dialogue: 0,0:06:13.95,0:06:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah!
Dialogue: 0,0:06:15.08,0:06:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera kembali!
Dialogue: 0,0:06:19.00,0:06:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:06:20.04,0:06:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aman!\N- Baik!
Dialogue: 0,0:06:42.77,0:06:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil.
Dialogue: 0,0:06:44.94,0:06:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua selamat.
Dialogue: 0,0:06:46.40,0:06:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:06:51.70,0:06:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas!
Dialogue: 0,0:06:53.20,0:06:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dagda!
Dialogue: 0,0:06:57.75,0:06:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:06:59.00,0:07:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencoba melindungi kargonya, tapi…
Dialogue: 0,0:07:02.83,0:07:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah. Yang penting kau selamat.
Dialogue: 0,0:07:07.84,0:07:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:07:10.84,0:07:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama, aku senang kita tepat waktu.
Dialogue: 0,0:07:13.85,0:07:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid-muridku membawa obat.
Dialogue: 0,0:07:16.60,0:07:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan mengobati luka kalian…
Dialogue: 0,0:07:20.48,0:07:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:07:23.23,0:07:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gila.\N- Keren!
Dialogue: 0,0:07:24.81,0:07:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya penasaran.
Dialogue: 0,0:07:26.48,0:07:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang terbaik!
Dialogue: 0,0:07:28.48,0:07:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey, apa ini?
Dialogue: 0,0:07:32.99,0:07:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah Pedang Pembelah Hujan.
Dialogue: 0,0:07:38.41,0:07:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap pola yang terukir di bilahnya\Nadalah segel.
Dialogue: 0,0:07:42.54,0:07:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel kecil pun, kalau cukup banyak,
Dialogue: 0,0:07:45.29,0:07:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dapat membelah laut.
Dialogue: 0,0:07:49.13,0:07:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey, boleh aku memegangnya?
Dialogue: 0,0:07:53.22,0:07:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:55.14,0:07:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir pada senjata\Nharus ditangani dengan hati-hati.
Dialogue: 0,0:07:59.77,0:08:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini berbahaya.
Dialogue: 0,0:08:01.68,0:08:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian belum boleh menyentuhnya.
Dialogue: 0,0:08:06.11,0:08:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey.
Dialogue: 0,0:08:07.82,0:08:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memeriksa ke hulu\Nuntuk berjaga-jaga.
Dialogue: 0,0:08:11.32,0:08:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan periksa\Nkerusakan di hilir.
Dialogue: 0,0:08:14.82,0:08:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia, ikut aku.
Dialogue: 0,0:08:17.33,0:08:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:18.58,0:08:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Richeh, ikut aku.\N- Baik.
Dialogue: 0,0:08:22.33,0:08:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua jaga di sini.
Dialogue: 0,0:08:24.67,0:08:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami segera kembali.
Dialogue: 0,0:08:25.83,0:08:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:39.06,0:08:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini benar-benar canggung.{\i0}
Dialogue: 0,0:08:41.85,0:08:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus segera memperbaiki\Nsepatu sylph Agott dan mengembalikannya.{\i0}
Dialogue: 0,0:08:47.40,0:08:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, sudah selesai!
Dialogue: 0,0:08:49.48,0:08:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Nona Penyihir Kecil.
Dialogue: 0,0:08:54.95,0:08:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Nona Penyihir Kecil?{\i0}
Dialogue: 0,0:08:57.62,0:09:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Penyihir Kecil, ya?
Dialogue: 0,0:09:03.20,0:09:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap saja,
Dialogue: 0,0:09:04.87,0:09:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setengah kargonya terbawa arus.
Dialogue: 0,0:09:08.75,0:09:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas! Apa yang kau lakukan?
Dialogue: 0,0:09:11.42,0:09:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali ke sini, Custas!
Dialogue: 0,0:09:14.01,0:09:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Dagda.
Dialogue: 0,0:09:16.09,0:09:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepi sungainya menjorok ke dalam.
Dialogue: 0,0:09:18.26,0:09:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang kita tersangkut di sana.
Dialogue: 0,0:09:21.01,0:09:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengambilnya, lalu kembali.
Dialogue: 0,0:09:26.02,0:09:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:09:27.27,0:09:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menjorok ke dalam,\Nberarti itu pernah longsor.
Dialogue: 0,0:09:31.19,0:09:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali sekarang juga!
Dialogue: 0,0:09:32.40,0:09:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas!
Dialogue: 0,0:09:53.92,0:09:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak…
Dialogue: 0,0:09:54.88,0:09:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:09:56.97,0:09:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas…
Dialogue: 0,0:09:58.26,0:10:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak…\N- Jangan, Tuan Dagda!
Dialogue: 0,0:10:00.72,0:10:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti bisa longsor lagi!
Dialogue: 0,0:10:02.56,0:10:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan aku!
Dialogue: 0,0:10:04.06,0:10:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Custas!\N- Agott!
Dialogue: 0,0:10:10.15,0:10:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:10:12.52,0:10:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan-jangan dia terkubur…\N- Agott!
Dialogue: 0,0:10:15.65,0:10:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini! Di sebelah sini!
Dialogue: 0,0:10:19.91,0:10:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja? Apa kau terluka?
Dialogue: 0,0:10:23.41,0:10:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja!
Dialogue: 0,0:10:26.70,0:10:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:10:27.71,0:10:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas!
Dialogue: 0,0:10:29.42,0:10:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab aku!
Dialogue: 0,0:10:30.58,0:10:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas!
Dialogue: 0,0:10:34.09,0:10:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas!
Dialogue: 0,0:10:37.09,0:10:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin…
Dialogue: 0,0:10:40.59,0:10:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:10:43.76,0:10:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:10:46.39,0:10:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada penyihir di sini.
Dialogue: 0,0:10:49.60,0:10:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Tolong!
Dialogue: 0,0:10:51.73,0:10:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menyelamatkannya, bukan?
Dialogue: 0,0:10:54.98,0:10:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon. Selamatkan dia!
Dialogue: 0,0:11:01.41,0:11:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini kesempatanku!{\i0}
Dialogue: 0,0:11:04.95,0:11:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Guru sedang tidak ada di sini.{\i0}
Dialogue: 0,0:11:07.04,0:11:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Tanpa sepatu sylph,\Naku tak bisa memanggil mereka.{\i0}
Dialogue: 0,0:11:09.54,0:11:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Coco tak bisa bergerak.\NIni situasi darurat.{\i0}
Dialogue: 0,0:11:13.38,0:11:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau menyelamatkannya dengan sihirku,{\i0}
Dialogue: 0,0:11:15.75,0:11:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mungkin aku bisa membuktikan diriku\Nkepada orang itu.{\i0}
Dialogue: 0,0:11:18.88,0:11:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona?
Dialogue: 0,0:11:20.88,0:11:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau akan menggunakan sihirmu?
Dialogue: 0,0:11:24.39,0:11:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dia akan menyelamatkan mereka\Ndengan sihir.
Dialogue: 0,0:11:27.01,0:11:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kita akan melihat sihir apa, ya?
Dialogue: 0,0:11:29.27,0:11:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup. Custas dalam bahaya.
Dialogue: 0,0:11:34.23,0:11:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sekarang, tunjukkan kepadaku, Agott.{\i0}
Dialogue: 0,0:11:39.82,0:11:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini sihir gadis itu?
Dialogue: 0,0:11:45.83,0:11:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan anak-anak lain…
Dialogue: 0,0:11:48.54,0:11:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba menggambar lebih baik.
Dialogue: 0,0:11:50.41,0:11:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak buruk, tapi biasa saja.
Dialogue: 0,0:11:53.33,0:11:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil dia putrinya.
Dialogue: 0,0:11:54.75,0:11:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak berbakat seusia ini bisa lebih hebat.
Dialogue: 0,0:11:57.42,0:11:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau berlatih?
Dialogue: 0,0:11:58.92,0:12:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih anak-anak…
Dialogue: 0,0:12:02.05,0:12:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku sangat berharap kepadamu.\NAku kecewa, Agott.{\i0}
Dialogue: 0,0:12:06.60,0:12:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau tak bisa menjadi muridku.{\i0}
Dialogue: 0,0:12:08.18,0:12:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Keluarga kita tak membutuhkan\Npenyihir tak berbakat.{\i0}
Dialogue: 0,0:12:18.02,0:12:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa aku mengingat hal ini?{\i0}
Dialogue: 0,0:12:20.11,0:12:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa harus sekarang?{\i0}
Dialogue: 0,0:12:24.99,0:12:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:12:27.62,0:12:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa yang bisa kulakukan?
Dialogue: 0,0:12:30.49,0:12:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa kulakukan dari sini?
Dialogue: 0,0:12:37.50,0:12:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa kulakukan
Dialogue: 0,0:12:39.75,0:12:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyelamatkan Custas?
Dialogue: 0,0:12:45.26,0:12:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang ingin membantu,
Dialogue: 0,0:12:48.01,0:12:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pikirkan baik-baik\Nalasanmu menggunakan sihir.
Dialogue: 0,0:12:54.64,0:12:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco! Apa kau bisa bergerak?
Dialogue: 0,0:12:56.90,0:12:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus tahu situasinya!
Dialogue: 0,0:12:59.02,0:13:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini…
Dialogue: 0,0:13:01.78,0:13:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepi sungainya menjorok ke dalam,\Njadi arusnya lebih lambat.
Dialogue: 0,0:13:05.91,0:13:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, kami tak akan tersapu!
Dialogue: 0,0:13:08.37,0:13:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di sini berlumpur dan licin.
Dialogue: 0,0:13:12.50,0:13:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, aku tak bisa naik.
Dialogue: 0,0:13:14.91,0:13:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas tak sadarkan diri.
Dialogue: 0,0:13:17.46,0:13:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batunya terlalu besar\Nuntuk dipindahkan orang dewasa.
Dialogue: 0,0:13:22.96,0:13:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu…
Dialogue: 0,0:13:27.43,0:13:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami tak bisa membiarkan orang biasa{\i0}
Dialogue: 0,0:13:29.64,0:13:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}melihat kami menggambar sihir.{\i0}
Dialogue: 0,0:13:33.35,0:13:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana ini?{\i0}
Dialogue: 0,0:13:34.43,0:13:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:13:37.10,0:13:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus bagaimana?{\i0}
Dialogue: 0,0:13:47.66,0:13:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Easthies.
Dialogue: 0,0:13:49.07,0:13:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dapat laporan\Ndari desa di dekat Kalhn.
Dialogue: 0,0:13:51.95,0:13:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka melihat semburan air besar
Dialogue: 0,0:13:54.58,0:13:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di hulu Hutan Rawa.
Dialogue: 0,0:13:58.71,0:13:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berangkat.
Dialogue: 0,0:14:04.55,0:14:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia belum menyerah\Nbahkan dalam situasi seperti ini.{\i0}
Dialogue: 0,0:14:12.85,0:14:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Andai kami bisa menggunakan sihir.{\i0}
Dialogue: 0,0:14:16.81,0:14:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:14:18.81,0:14:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau punya itu? Benda itu!
Dialogue: 0,0:14:21.73,0:14:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda itu?
Dialogue: 0,0:14:22.69,0:14:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu, itu…
Dialogue: 0,0:14:25.11,0:14:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cincin Guru Olruggio!
Dialogue: 0,0:14:29.15,0:14:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:14:30.61,0:14:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cincin Taut!
Dialogue: 0,0:14:34.16,0:14:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan ini…{\i0}
Dialogue: 0,0:14:37.29,0:14:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau aku punya kertas,{\i0}
Dialogue: 0,0:14:39.12,0:14:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku bisa pakai mantra ambalang\Nyang baru kupelajari{\i0}
Dialogue: 0,0:14:41.58,0:14:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}untuk mengangkat batu\Ndan menyelamatkan Custas.{\i0}
Dialogue: 0,0:14:44.84,0:14:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Tapi Coco tak akan mampu melakukannya.{\i0}
Dialogue: 0,0:14:49.05,0:14:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat penyihir menggambar sihir\Ndi depan orang biasa,{\i0}
Dialogue: 0,0:14:53.05,0:14:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka harus menyembunyikan tangan\Ndi balik jubah panjang mereka.{\i0}
Dialogue: 0,0:14:57.85,0:15:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Butuh keahlian khusus\Nuntuk menggambar dengan ingatan otot.{\i0}
Dialogue: 0,0:15:09.07,0:15:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sedang apa dia?\N- Dia masih anak-anak…
Dialogue: 0,0:15:11.16,0:15:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia penyihir…
Dialogue: 0,0:15:12.07,0:15:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:15:17.04,0:15:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah murid terbaik Qifrey.
Dialogue: 0,0:15:19.33,0:15:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Agott Arklaum.
Dialogue: 0,0:15:22.83,0:15:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku menunjukkan sihir\Nyang diberikan kepadaku.
Dialogue: 0,0:15:29.88,0:15:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semua latihan yang kulakukan{\i0}
Dialogue: 0,0:15:32.18,0:15:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah agar aku tak ragu saat dibutuhkan.{\i0}
Dialogue: 0,0:15:38.35,0:15:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Coco tak bisa melakukannya,{\i0}
Dialogue: 0,0:15:41.60,0:15:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}tapi aku bisa!{\i0}
Dialogue: 0,0:16:00.58,0:16:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:16:10.84,0:16:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami baru saja melatih sihir ambalang\Ndengan kentang keras.{\i0}
Dialogue: 0,0:16:16.22,0:16:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pasti bisa melakukan ini!
Dialogue: 0,0:16:24.10,0:16:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja…
Dialogue: 0,0:16:26.36,0:16:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tahu karena sudah berlatih.{\i0}
Dialogue: 0,0:16:29.40,0:16:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Menggerakkan batu seberat ini\Nmenggunakan segel di bukuku{\i0}
Dialogue: 0,0:16:32.95,0:16:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tidak akan berhasil.{\i0}
Dialogue: 0,0:16:37.66,0:16:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas!
Dialogue: 0,0:16:39.37,0:16:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku…
Dialogue: 0,0:16:42.50,0:16:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah! Kau sudah sadar.
Dialogue: 0,0:16:44.87,0:16:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:16:46.71,0:16:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Coco, aku seorang penyihir.
Dialogue: 0,0:16:49.38,0:16:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita jatuh dari atas. Apa kau ingat?
Dialogue: 0,0:16:54.80,0:16:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku masih hidup?
Dialogue: 0,0:16:58.97,0:17:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melihat burung bercahaya,
Dialogue: 0,0:17:01.89,0:17:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, aku pikir aku sudah mati.
Dialogue: 0,0:17:03.81,0:17:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu? Itu adalah sihir!
Dialogue: 0,0:17:06.73,0:17:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sihir temanku!
Dialogue: 0,0:17:10.19,0:17:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir teman…
Dialogue: 0,0:17:12.48,0:17:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:17:16.36,0:17:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak bisa terlalu lama\Nmengalihkan perhatian dari Coco.{\i0}
Dialogue: 0,0:17:19.53,0:17:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cepat…{\i0}
Dialogue: 0,0:17:20.45,0:17:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:17:21.87,0:17:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir itu memang cantik,\Ntapi apa hanya begitu?
Dialogue: 0,0:17:25.79,0:17:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya menerangi langit.
Dialogue: 0,0:17:28.08,0:17:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya!
Dialogue: 0,0:17:30.38,0:17:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu bisa membawa orang terbang?\NAtau turun dan menolongnya?
Dialogue: 0,0:17:35.38,0:17:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu…
Dialogue: 0,0:17:37.13,0:17:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja. Aku akan turun sendiri\Ndan menolongnya.
Dialogue: 0,0:17:40.51,0:17:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau dia melihat sekarang…{\i0}
Dialogue: 0,0:17:43.14,0:17:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan! Kau tak boleh ke sana!
Dialogue: 0,0:17:55.78,0:17:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa…
Dialogue: 0,0:17:57.20,0:17:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa menarik kami?
Dialogue: 0,0:17:58.91,0:18:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa turun.
Dialogue: 0,0:18:02.70,0:18:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:18:05.04,0:18:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas!
Dialogue: 0,0:18:07.12,0:18:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas!
Dialogue: 0,0:18:09.17,0:18:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Custas…
Dialogue: 0,0:18:11.63,0:18:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau baik-baik saja?\N- Kau terluka?
Dialogue: 0,0:18:17.97,0:18:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak apa-apa?
Dialogue: 0,0:18:20.09,0:18:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti melayang!
Dialogue: 0,0:18:21.85,0:18:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco, kau…
Dialogue: 0,0:18:30.73,0:18:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Syukurlah!\N- Hei!
Dialogue: 0,0:18:33.23,0:18:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah berhasil!\NAku tak tahu harus bagaimana!
Dialogue: 0,0:18:37.15,0:18:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat
Dialogue: 0,0:18:40.03,0:18:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersyukur!
Dialogue: 0,0:18:41.91,0:18:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sudah cukup.
Dialogue: 0,0:18:44.20,0:18:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih penting,\Nbagaimana kau keluar dari situasi itu?
Dialogue: 0,0:18:50.08,0:18:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:18:52.58,0:18:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasir?
Dialogue: 0,0:18:54.67,0:18:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:56.00,0:19:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku teringat mantra penghancur batu\Nyang menyelamatkan kita.
Dialogue: 0,0:19:01.93,0:19:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:19:03.64,0:19:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan Segel Penghancur Dinding,{\i0}
Dialogue: 0,0:19:05.35,0:19:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bahkan segel kecil bisa mengubah batu{\i0}
Dialogue: 0,0:19:07.72,0:19:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menjadi pasir tanpa melukai siapa pun.{\i0}
Dialogue: 0,0:19:10.98,0:19:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benar. Saat itu,\Naku sama sekali tak bisa membantu,{\i0}
Dialogue: 0,0:19:15.73,0:19:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sihir temanku menyelamatkan kami.
Dialogue: 0,0:19:19.28,0:19:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melakukannya sendirian.
Dialogue: 0,0:19:22.87,0:19:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung bercahaya itu yang mengingatkanku.
Dialogue: 0,0:19:26.08,0:19:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyelamatkanku, Agott.
Dialogue: 0,0:19:29.50,0:19:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinyal cahaya itu\Nuntuk memanggil guru kita.
Dialogue: 0,0:19:32.96,0:19:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kira itu hanya untukmu.
Dialogue: 0,0:19:35.67,0:19:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku tak ingat\Nmenganggapmu sebagai teman…
Dialogue: 0,0:19:44.09,0:19:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat senang
Dialogue: 0,0:19:47.60,0:19:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa menyelamatkan Custas.
Dialogue: 0,0:19:51.52,0:19:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku juga, suatu hari nanti…
Dialogue: 0,0:19:56.15,0:19:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:57.77,0:20:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti menyelamatkannya.
Dialogue: 0,0:20:03.57,0:20:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco…
Dialogue: 0,0:20:21.59,0:20:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa ini?
Dialogue: 0,0:20:24.59,0:20:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panji Penangkap Putih Perak
Dialogue: 0,0:20:27.80,0:20:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan jubah merah tua\Ndengan topi berbulu itu…
Dialogue: 0,0:20:35.15,0:20:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jangan-jangan…
Dialogue: 0,0:20:36.65,0:20:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka Ksatria Moralis!
Dialogue: 0,0:20:39.15,0:20:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa di antara kalian
Dialogue: 0,0:20:41.94,0:20:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menggunakan sihir?
Dialogue: 0,0:20:43.95,0:20:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu kau?
Dialogue: 0,0:20:45.74,0:20:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kau?
Dialogue: 0,0:20:49.03,0:20:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian memang anak-anak,\Ntapi tak ada ampun.
Dialogue: 0,0:20:52.50,0:20:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:20:54.04,0:20:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kaki tangan Penyihir Bertopeng?
Dialogue: 0,0:20:56.42,0:20:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:57.42,0:21:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan! Kami bukan Penyihir Bertopeng!
Dialogue: 0,0:21:00.80,0:21:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak menggunakan sihir terlarang.
Dialogue: 0,0:21:03.05,0:21:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menggunakan sihir untuk menolong.
Dialogue: 0,0:21:06.51,0:21:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:21:08.30,0:21:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lihat ke bawah.
Dialogue: 0,0:21:19.40,0:21:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:21.07,0:21:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:21:25.03,0:21:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya batu,\Ntapi dasar sungainya juga.
Dialogue: 0,0:21:28.03,0:21:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berubah menjadi pasir…
Dialogue: 0,0:21:32.33,0:21:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sungainya berubah menjadi kabut.
Dialogue: 0,0:21:37.83,0:21:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:21:39.42,0:21:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:21:40.96,0:21:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan gambarku.
Dialogue: 0,0:21:42.30,0:21:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:21:44.09,0:21:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini adalah sihirmu?
Dialogue: 0,0:21:47.59,0:21:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil seorang murid sepertimu
Dialogue: 0,0:21:49.68,0:21:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mampu menggunakan sihir\Nyang begitu kuat tanpa melanggar tabu.
Dialogue: 0,0:21:56.85,0:21:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukum yang ditetapkan\Npada Hari Perjanjian adalah mutlak.
Dialogue: 0,0:22:00.36,0:22:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hukumanmu adalah penghapusan ingatan.
Dialogue: 0,0:23:39.04,0:23:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana
