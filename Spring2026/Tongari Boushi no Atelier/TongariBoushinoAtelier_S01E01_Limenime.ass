Dialogue: 0,0:02:18.51,0:02:19.93,tanda,,0000,0000,0000,,{\an8}SIHIR AWAL MULA
Dialogue: 0,0:23:36.49,0:23:38.91,tanda,,0000,0000,0000,,EPISODE 2\NSEKOLAH DI PADANG RUMPUT
Dialogue: 0,0:00:06.79,0:00:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apakah atlet terlahir sebagai atlet?{\i0}
Dialogue: 0,0:00:11.21,0:00:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana dengan astronaut\Natau bintang pop?{\i0}
Dialogue: 0,0:00:15.30,0:00:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada yang tahu ketika mereka lahir.{\i0}
Dialogue: 0,0:00:18.56,0:00:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu, bagaimana dengan penyihir?{\i0}
Dialogue: 0,0:01:23.08,0:01:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sudah mencemarinya.
Dialogue: 0,0:01:25.04,0:01:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah selesai mencuci.
Dialogue: 0,0:01:30.34,0:01:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini akan segera kembali normal.
Dialogue: 0,0:01:32.34,0:01:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mata air ini telah dimantrai!
Dialogue: 0,0:01:59.66,0:02:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak pernah membosankan. Indah sekali.
Dialogue: 0,0:02:01.99,0:02:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sihir memang luar biasa!
Dialogue: 0,0:02:08.16,0:02:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dunia ini penuh dengan sihir.{\i0}
Dialogue: 0,0:02:11.13,0:02:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini merupakan keajaiban praktis\Nyang sudah menjadi kebutuhan.{\i0}
Dialogue: 0,0:02:16.17,0:02:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Tapi kita tak tahu cara kerjanya.{\i0}
Dialogue: 0,0:02:19.93,0:02:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Hanya penyihir yang bisa merapal mantra.{\i0}
Dialogue: 0,0:02:25.06,0:02:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang biasa hanya bisa menerima sihir.{\i0}
Dialogue: 0,0:02:30.40,0:02:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita tak bisa menjadi penyihir.{\i0}
Dialogue: 0,0:02:35.61,0:02:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terlahir sebagai penyihir\Nsangat beruntung.
Dialogue: 0,0:02:46.49,0:02:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai Seprai, berubahlah\Nmenjadi jubah terbang!
Dialogue: 0,0:02:56.09,0:02:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:02:57.26,0:03:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu! Tidak!\NBukan terbang yang begitu maksudku!
Dialogue: 0,0:03:17.07,0:03:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kereta pegasus!
Dialogue: 0,0:03:32.33,0:03:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku melihatnya di darat!
Dialogue: 0,0:03:37.05,0:03:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu! Ada kereta pegasus di luar!
Dialogue: 0,0:03:41.42,0:03:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:03:44.26,0:03:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:03:53.60,0:03:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Aku tak melihatmu.
Dialogue: 0,0:03:56.36,0:03:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa. Aku yang salah\Nkarena berdiri di depan pintu.
Dialogue: 0,0:03:59.82,0:04:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya!
Dialogue: 0,0:04:01.78,0:04:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini! Aku tak percaya\Nmereka punya ini.
Dialogue: 0,0:04:04.78,0:04:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sulam bunga kupu-kupu sudah kuno?
Dialogue: 0,0:04:08.20,0:04:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan itu, lihat ini!\NIni renda rajut motif Harian!
Dialogue: 0,0:04:11.50,0:04:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:04:12.66,0:04:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat laris di ibu kota.
Dialogue: 0,0:04:16.50,0:04:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pelanggan itu pasti datang\Ndengan kereta pegasus!
Dialogue: 0,0:04:21.51,0:04:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan aku.
Dialogue: 0,0:04:23.63,0:04:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, Bu,\Napa masih ada renda seperti ini?
Dialogue: 0,0:04:26.80,0:04:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sebentar!
Dialogue: 0,0:04:29.56,0:04:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco, bantu Ibu kalau kau di sini.
Dialogue: 0,0:04:33.27,0:04:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang Tuan butuhkan?
Dialogue: 0,0:04:35.02,0:04:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh kain sewarna asap,\Naku bisa menunggu kalau kau sibuk.
Dialogue: 0,0:04:38.86,0:04:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membantumu.
Dialogue: 0,0:04:40.86,0:04:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau?
Dialogue: 0,0:04:41.86,0:04:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco cukup pandai.
Dialogue: 0,0:04:43.82,0:04:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:04:48.32,0:04:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku melihat kereta pegasusnya\Nkalau sudah selesai?
Dialogue: 0,0:04:50.95,0:04:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:52.29,0:04:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kereta pegasus!
Dialogue: 0,0:04:54.33,0:04:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta pegasus?
Dialogue: 0,0:04:55.54,0:04:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak akan main-main\Ndengan barang pelanggan, bukan?
Dialogue: 0,0:04:58.58,0:05:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, aku hanya melihat-lihat!
Dialogue: 0,0:05:02.80,0:05:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan bilang\Naku mau jadi penyihir lagi.
Dialogue: 0,0:05:10.60,0:05:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kalau selesai lebih cepat.
Dialogue: 0,0:05:13.06,0:05:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:05:15.60,0:05:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menunggu!\NMau beli berapa?
Dialogue: 0,0:05:18.23,0:05:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:05:19.44,0:05:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyiapkannya.
Dialogue: 0,0:06:03.52,0:06:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus sekali.
Dialogue: 0,0:06:05.40,0:06:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganmu juga stabil.
Dialogue: 0,0:06:06.82,0:06:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garis pola yang bersih\Ndan potongan yang mantap.
Dialogue: 0,0:06:09.95,0:06:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi, hasil kerjamu\Nsangat cermat dan akurat.
Dialogue: 0,0:06:13.53,0:06:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu\Nada perajin yang hebat di desa ini.
Dialogue: 0,0:06:18.21,0:06:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah sihir.
Dialogue: 0,0:06:20.96,0:06:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Hasil kerjaku\Nsama sekali tidak seperti itu!
Dialogue: 0,0:06:25.46,0:06:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir itu lebih misterius,\Nlebih berkilau, lebih berharga, dan indah.
Dialogue: 0,0:06:30.47,0:06:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lebih…
Dialogue: 0,0:06:32.85,0:06:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih…
Dialogue: 0,0:06:34.18,0:06:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lebih murni.
Dialogue: 0,0:06:38.18,0:06:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini bicara apa?
Dialogue: 0,0:06:40.90,0:06:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat menyukai sihir, ya?
Dialogue: 0,0:06:45.69,0:06:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku tahu alasannya?
Dialogue: 0,0:06:53.45,0:06:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat masih kecil,\Naku dibawa ke festival di ibu kota.{\i0}
Dialogue: 0,0:06:58.12,0:07:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bertemu penyihir bertopeng di sana.{\i0}
Dialogue: 0,0:07:19.02,0:07:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Nona Kecil.
Dialogue: 0,0:07:22.19,0:07:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau beli buku bergambar tentang sihir?
Dialogue: 0,0:07:27.44,0:07:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir? Aku suka buku bergambar,\Ntapi apa itu sihir?
Dialogue: 0,0:07:33.07,0:07:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir adalah keajaiban\Nyang memberi warna pada dunia.
Dialogue: 0,0:07:38.74,0:07:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta pegasus yang melayang di langit
Dialogue: 0,0:07:41.25,0:07:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mata air abadi\Nyang menjaga kemurnian airnya.
Dialogue: 0,0:07:44.21,0:07:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan
Dialogue: 0,0:07:45.33,0:07:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jalan batu susun yang bersinar\Nsaat kau menginjaknya.
Dialogue: 0,0:07:49.76,0:07:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua itu adalah sihir.
Dialogue: 0,0:07:54.14,0:07:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat cantik!
Dialogue: 0,0:07:55.72,0:07:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir sangat menakjubkan! Aku suka sihir!
Dialogue: 0,0:08:00.14,0:08:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beli sekarang, dapat tongkat gratis!
Dialogue: 0,0:08:05.98,0:08:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau ditipu untuk membeli itu?
Dialogue: 0,0:08:09.23,0:08:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katamu ingin makan stroberi bakar.
Dialogue: 0,0:08:11.78,0:08:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadi mengejar kupu-kupu,\Nlalu bertemu orang dengan topi runcing.
Dialogue: 0,0:08:16.37,0:08:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah mengatakannya.
Dialogue: 0,0:08:18.41,0:08:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini buku bergambar tentang sihir\Ndengan tongkat gratis!
Dialogue: 0,0:08:25.17,0:08:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Coco, waktunya pulang.\NMalam semakin larut.
Dialogue: 0,0:08:28.63,0:08:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ibu!\N- Ya?
Dialogue: 0,0:08:30.25,0:08:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat besar nanti, aku akan jadi penyihir\Nyang mewarnai dunia!
Dialogue: 0,0:08:36.01,0:08:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil.
Dialogue: 0,0:08:37.35,0:08:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:08:39.47,0:08:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:08:41.06,0:08:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa menjadi penyihir\Nkecuali kau lahir dengan kekuatan sihir.
Dialogue: 0,0:08:46.90,0:08:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang biasa tak punya bakat\Nuntuk menjadi penyihir.
Dialogue: 0,0:08:52.65,0:08:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari pulang, Coco.
Dialogue: 0,0:08:54.57,0:08:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Coba lihat!\N- Apa?
Dialogue: 0,0:08:55.78,0:08:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan ini bercahaya saat aku menginjaknya.
Dialogue: 0,0:09:01.66,0:09:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kalau masih bersinar\Nsampai kita tiba di rumah,
Dialogue: 0,0:09:06.42,0:09:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin Coco juga bisa menggunakan sihir.
Dialogue: 0,0:09:18.68,0:09:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu, aku terus mengamati bukunya…\NMungkin aku tak bisa merelakannya.
Dialogue: 0,0:09:23.98,0:09:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa ceritakan lebih banyak tentang…
Dialogue: 0,0:09:27.98,0:09:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:09:30.06,0:09:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:09:30.98,0:09:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berhenti. Jangan bergerak.
Dialogue: 0,0:09:34.40,0:09:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:09:45.37,0:09:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan? Astaga.
Dialogue: 0,0:09:47.58,0:09:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam. Sakit…
Dialogue: 0,0:09:49.58,0:09:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tak apa-apa?
Dialogue: 0,0:09:50.71,0:09:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Coco.\N- Apa yang terjadi?
Dialogue: 0,0:09:53.21,0:09:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan salahku. Itu tiba-tiba rusak.
Dialogue: 0,0:09:55.26,0:09:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bohong. Tanerl menyelinap ke bawahnya!
Dialogue: 0,0:09:58.47,0:09:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pengadu!
Dialogue: 0,0:09:59.93,0:10:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalanya membentur bagian bawahnya,\Nlalu terbalik.
Dialogue: 0,0:10:02.47,0:10:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Apa yang terjadi?
Dialogue: 0,0:10:05.22,0:10:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta pegasus kita…
Dialogue: 0,0:10:07.06,0:10:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita meminjamnya dari Ayah.
Dialogue: 0,0:10:09.31,0:10:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan kami.\NAnak-anak desa ini sudah berulah.
Dialogue: 0,0:10:13.52,0:10:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja minta maaf.
Dialogue: 0,0:10:15.36,0:10:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak bisa pulang tanpa kereta!
Dialogue: 0,0:10:17.45,0:10:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu harus bagaimana.
Dialogue: 0,0:10:20.53,0:10:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:10:23.78,0:10:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa memperbaikinya.
Dialogue: 0,0:10:27.04,0:10:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, kerusakannya tak terlalu parah.
Dialogue: 0,0:10:30.00,0:10:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi kau siapa?
Dialogue: 0,0:10:32.25,0:10:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku lupa tanda pengenalku.
Dialogue: 0,0:10:42.01,0:10:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey, sang penyihir, siap melayani.
Dialogue: 0,0:10:48.39,0:10:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi runcing.
Dialogue: 0,0:10:50.27,0:10:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa memperbaikinya?
Dialogue: 0,0:10:52.02,0:10:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:53.40,0:10:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Tuan Penyihir.
Dialogue: 0,0:10:55.94,0:10:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:10:57.65,0:11:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tinggal merapal ulang mantra\Ndi bagian bawah kereta.
Dialogue: 0,0:11:00.53,0:11:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:11:02.82,0:11:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan kepadaku.
Dialogue: 0,0:11:04.37,0:11:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak bisa melakukannya di luar.
Dialogue: 0,0:11:06.66,0:11:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pakai ruang kerja kami saja.\N- Coco!
Dialogue: 0,0:11:10.12,0:11:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, bukan, Bu?
Dialogue: 0,0:11:13.21,0:11:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Habisnya,{\i0}
Dialogue: 0,0:11:14.88,0:11:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia penyihir sungguhan.{\i0}
Dialogue: 0,0:11:18.26,0:11:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bahkan mungkin bisa melihatnya.{\i0}
Dialogue: 0,0:11:21.88,0:11:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ketika dia merapalkan mantra.{\i0}
Dialogue: 0,0:11:33.69,0:11:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi aku merapalkan mantra,
Dialogue: 0,0:11:35.52,0:11:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong berjaga di luar\Nagar tak ada yang mengintip.
Dialogue: 0,0:11:39.69,0:11:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan siapa pun masuk. Mengerti?
Dialogue: 0,0:11:46.37,0:11:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa, hidup tak semudah itu.
Dialogue: 0,0:11:50.00,0:11:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi kenapa aku tak boleh melihatnya, ya?{\i0}
Dialogue: 0,0:11:53.75,0:11:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada begitu banyak sihir di dunia ini,{\i0}
Dialogue: 0,0:11:57.17,0:11:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi kita tak tahu cara menggunakannya.{\i0}
Dialogue: 0,0:12:00.55,0:12:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hanya penyihir yang tahu…{\i0}
Dialogue: 0,0:12:03.43,0:12:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rahasianya.
Dialogue: 0,0:12:11.68,0:12:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:12.77,0:12:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Licin.
Dialogue: 0,0:12:15.81,0:12:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kalian sedang apa?
Dialogue: 0,0:12:17.65,0:12:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan!
Dialogue: 0,0:12:18.65,0:12:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, itu hanya Coco.
Dialogue: 0,0:12:20.32,0:12:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita bisa mengintip dari sini?
Dialogue: 0,0:12:23.32,0:12:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:12:24.41,0:12:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berisik!
Dialogue: 0,0:12:26.07,0:12:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir!
Dialogue: 0,0:12:40.05,0:12:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja. Payah.
Dialogue: 0,0:12:42.05,0:12:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Payah sekali.
Dialogue: 0,0:12:51.56,0:12:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:24.13,0:13:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, tidak boleh.{\i0}
Dialogue: 0,0:13:25.47,0:13:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi aku sangat penasaran. Tidak boleh.{\i0}
Dialogue: 0,0:13:55.91,0:13:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia menggambar…{\i0}
Dialogue: 0,0:14:01.42,0:14:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sihir dengan pena?{\i0}
Dialogue: 0,0:14:06.30,0:14:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti…
Dialogue: 0,0:14:08.93,0:14:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}itu bukan tongkat!{\i0}
Dialogue: 0,0:14:12.10,0:14:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sihir itu…{\i0}
Dialogue: 0,0:14:14.60,0:14:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bukan dirapal…{\i0}
Dialogue: 0,0:14:17.98,0:14:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi digambar!{\i0}
Dialogue: 0,0:14:20.77,0:14:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah. Coco.
Dialogue: 0,0:14:22.77,0:14:23.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selesai.
Dialogue: 0,0:14:32.53,0:14:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:14:33.53,0:14:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:14:53.22,0:14:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu lumayan lega.
Dialogue: 0,0:14:55.64,0:14:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:56.56,0:14:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau sangat menyukai sihir,
Dialogue: 0,0:14:59.60,0:15:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu pikir kau mungkin akan bilang\Ningin pergi bersama penyihir itu.
Dialogue: 0,0:15:07.23,0:15:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahmu sudah meninggal karena sakit.
Dialogue: 0,0:15:10.03,0:15:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau pergi juga, Ibu…
Dialogue: 0,0:15:14.58,0:15:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan! Aku tak bisa\Nmeninggalkan Ibu sendirian.
Dialogue: 0,0:15:21.37,0:15:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih. Coco putri yang baik, ya.
Dialogue: 0,0:15:43.48,0:15:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:15:45.11,0:15:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:15:46.61,0:15:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:15:50.82,0:15:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Selamat tidur.
Dialogue: 0,0:15:54.07,0:15:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:16:03.75,0:16:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}…kau mungkin akan bilang\Ningin pergi bersama penyihir itu.
Dialogue: 0,0:16:24.69,0:16:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semua pola yang digambar\Ndi buku bergambar…{\i0}
Dialogue: 0,0:16:28.11,0:16:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tongkat sihir ini bukan sekadar hadiah.{\i0}
Dialogue: 0,0:16:32.36,0:16:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pena ini adalah tongkat sihirnya!{\i0}
Dialogue: 0,0:16:49.04,0:16:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Maaf, Ibu. Aku tak akan ke mana-mana.{\i0}
Dialogue: 0,0:16:53.17,0:16:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi aku ingin coba.{\i0}
Dialogue: 0,0:17:44.31,0:17:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:47.73,0:17:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak berhasil.
Dialogue: 0,0:17:50.27,0:17:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja. Pasti tak semudah itu.
Dialogue: 0,0:18:20.01,0:18:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersinar! Aku baru saja menggunakan sihir!
Dialogue: 0,0:18:22.64,0:18:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa! Ini sihir!\NIni sihir sungguhan! Bagaimana ini?
Dialogue: 0,0:18:28.10,0:18:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, memang digambar.
Dialogue: 0,0:18:29.81,0:18:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak boleh melihatnya.\NApa aku dalam masalah?
Dialogue: 0,0:18:37.69,0:18:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi saja. Satu halaman lagi saja.
Dialogue: 0,0:18:54.63,0:18:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Buku bergambar, ya?{\i0}
Dialogue: 0,0:18:59.13,0:19:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak bisa melupakannya.{\i0}
Dialogue: 0,0:19:04.14,0:19:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:19:08.14,0:19:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah sihir api!\NTidak! Jangan terbakar!
Dialogue: 0,0:19:12.81,0:19:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris saja!
Dialogue: 0,0:19:15.90,0:19:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:19:18.74,0:19:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, aku mulai mengerti.
Dialogue: 0,0:19:21.32,0:19:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambar yang lebih besar lebih kuat\Ndaripada gambar yang lebih kecil,
Dialogue: 0,0:19:24.58,0:19:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang rapi lebih tahan lama\Ndaripada yang berantakan!
Dialogue: 0,0:19:28.83,0:19:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit membuat gambar besar dengan rapi.
Dialogue: 0,0:19:32.25,0:19:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey bisa menggambarnya dengan mudah.
Dialogue: 0,0:19:35.21,0:19:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:19:41.34,0:19:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seperti dugaanku.{\i0}
Dialogue: 0,0:19:42.84,0:19:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau aku menjiplak polanya,\Naku bisa menggambar dengan rapi!{\i0}
Dialogue: 0,0:19:56.15,0:19:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:20:18.17,0:20:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau gambar sesuatu.
Dialogue: 0,0:20:19.13,0:20:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambar apa? Sihir apa yang kau gambar?
Dialogue: 0,0:20:22.26,0:20:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu! Aku hanya menjiplak pola\Ndi buku bergambar!
Dialogue: 0,0:20:25.84,0:20:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:20:29.77,0:20:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:20:35.19,0:20:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:20:36.69,0:20:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:20:43.86,0:20:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Tidak mungkin…
Dialogue: 0,0:20:46.66,0:20:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:20:50.24,0:20:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini sihir terlarang…{\i0}
Dialogue: 0,0:20:52.12,0:20:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Lepaskan aku!
Dialogue: 0,0:20:53.37,0:20:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga akan terjebak…
Dialogue: 0,0:20:55.50,0:20:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menyelamatkan Ibu!
Dialogue: 0,0:20:56.88,0:20:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma! Ini sihir! Bahaya…
Dialogue: 0,0:20:59.96,0:21:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:21:06.59,0:21:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Coco!\N- Ibu!
Dialogue: 0,0:21:10.22,0:21:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:21:16.94,0:21:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:21:18.81,0:21:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:21:20.86,0:21:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:21:23.28,0:21:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dirahasiakan\Nuntuk mencegah hal seperti ini.
Dialogue: 0,0:21:26.70,0:21:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinta bertuah dan segel perintah.
Dialogue: 0,0:21:30.20,0:21:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan itu, siapa pun bisa\Nmenggunakan sihir.
Dialogue: 0,0:21:33.20,0:21:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rahasia terbesar para penyihir.
Dialogue: 0,0:21:36.62,0:21:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Karena kau mengetahuinya,\Naku harus menghapus ingatanmu.
Dialogue: 0,0:21:44.17,0:21:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jangan! Kalau ingatanku dihapus,\Nsiapa yang akan menyelamatkan Ibu?
Dialogue: 0,0:21:49.93,0:21:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi…
Dialogue: 0,0:21:52.26,0:21:54.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingat sihir yang kugambar,
Dialogue: 0,0:21:54.43,0:21:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku hafal isi buku bergambar itu!
Dialogue: 0,0:21:57.27,0:21:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku lupa, ibuku…
Dialogue: 0,0:22:01.11,0:22:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku bergambar…
Dialogue: 0,0:22:02.73,0:22:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tentu saja!{\i0}
Dialogue: 0,0:22:04.19,0:22:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau buku itu milik mereka,\Naku tak akan bisa melacak mereka.{\i0}
Dialogue: 0,0:22:08.78,0:22:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau aku menghapus ingatannya,\Njejaknya akan hilang.{\i0}
Dialogue: 0,0:22:12.99,0:22:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau ingat seperti apa bukunya?
Dialogue: 0,0:22:15.37,0:22:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ya.
Dialogue: 0,0:22:16.71,0:22:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau ingat halaman segel yang digambar?
Dialogue: 0,0:22:18.83,0:22:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ya.
Dialogue: 0,0:22:22.21,0:22:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau aku menemukan buku yang sama,\Nsegelnya akan ada di sana.
Dialogue: 0,0:22:28.05,0:22:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau kau tahu jenis segelnya,
Dialogue: 0,0:22:30.09,0:22:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}apa kau bisa menyelamatkan ibuku?
Dialogue: 0,0:22:34.93,0:22:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin…
Dialogue: 0,0:22:36.93,0:22:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa membantu.
Dialogue: 0,0:22:38.64,0:22:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Qifrey!
Dialogue: 0,0:22:40.94,0:22:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan hapus ingatanku!
Dialogue: 0,0:22:43.15,0:22:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melakukan apa pun\Nuntuk menyelamatkan Ibu!
Dialogue: 0,0:22:48.53,0:22:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menjaga rahasia?
Dialogue: 0,0:22:50.41,0:22:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:22:53.03,0:22:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa kau bersedia belajar?
Dialogue: 0,0:22:54.87,0:22:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Belajar?
Dialogue: 0,0:22:57.41,0:22:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin mengingat kebenaran\Nyang kau ketahui,
Dialogue: 0,0:23:00.37,0:23:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus berpihak\Nkepada para penjaga rahasia.
Dialogue: 0,0:23:04.50,0:23:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hanya ini cara agar ingatanmu tetap utuh!
Dialogue: 0,0:23:09.42,0:23:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco, mulai sekarang…
Dialogue: 0,0:23:13.64,0:23:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}kau akan menjadi penyihir.
Dialogue: 0,0:23:38.91,0:23:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana
