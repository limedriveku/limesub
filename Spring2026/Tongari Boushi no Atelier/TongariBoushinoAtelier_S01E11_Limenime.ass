Dialogue: 0,0:01:17.07,0:01:19.20,sign,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:23:36.49,0:23:39.12,sign,,0000,0000,0000,,EPISODE 12\NBAYANGAN ROMONON
Dialogue: 0,0:00:25.02,0:00:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini musim kawin serigala sisik.{\i0}
Dialogue: 0,0:00:28.40,0:00:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Agar tak menyakiti anak yang akan lahir,{\i0}
Dialogue: 0,0:00:31.28,0:00:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka meluruhkan bulu bersisik keras\Ndengan saling membenturkan tubuh.{\i0}
Dialogue: 0,0:00:36.70,0:00:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau mereka tak pernah kawin,{\i0}
Dialogue: 0,0:00:39.24,0:00:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka bisa tetap kuat.{\i0}
Dialogue: 0,0:00:44.91,0:00:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku pikir gadis sepertinya\Ntak bisa memberiku apa-apa.{\i0}
Dialogue: 0,0:00:49.50,0:00:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bahwa orang luar tetaplah orang luar{\i0}
Dialogue: 0,0:00:52.01,0:00:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan mereka tak punya tempat\Ndi dunia sihir.{\i0}
Dialogue: 0,0:00:56.76,0:00:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Tapi,{\i0}
Dialogue: 0,0:00:58.55,0:01:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}kalau dia mempelajari aturan dengan benar,{\i0}
Dialogue: 0,0:01:01.68,0:01:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}apa bedanya dia dengan kami?{\i0}
Dialogue: 0,0:02:44.58,0:02:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Aku berhasil!
Dialogue: 0,0:02:46.79,0:02:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu bagus!
Dialogue: 0,0:02:49.25,0:02:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau bisa menggambar mantra\Ndengan lebih stabil sekarang, Coco.
Dialogue: 0,0:02:52.67,0:02:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Terima kasih.
Dialogue: 0,0:02:55.13,0:02:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tetap saja,
Dialogue: 0,0:02:56.55,0:03:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}belum banyak mantra\Nyang bisa kugunakan dengan percaya diri.
Dialogue: 0,0:03:00.63,0:03:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Pada saat genting,\Naku selalu menggunakan mantra yang sama.
Dialogue: 0,0:03:06.06,0:03:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku,
Dialogue: 0,0:03:08.43,0:03:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra yang sering berhasil,
Dialogue: 0,0:03:10.48,0:03:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bisa kau gambar tanpa berpikir,
Dialogue: 0,0:03:13.69,0:03:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa jadi itulah kekuatanmu.
Dialogue: 0,0:03:19.69,0:03:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanku?
Dialogue: 0,0:03:22.70,0:03:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:24.70,0:03:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini, lihat mantra yang sering kau pakai.
Dialogue: 0,0:03:27.08,0:03:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat kau sering menggunakan\Ngaris lurus, bukan?
Dialogue: 0,0:03:30.37,0:03:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak seperti garis lengkung,\Ngaris lurusmu selalu stabil.
Dialogue: 0,0:03:35.63,0:03:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal pertama yang kau tunjukkan\Nketika kita bertemu
Dialogue: 0,0:03:38.09,0:03:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah betapa indahnya\Ngaris lurus yang kau gambar.{\i0}
Dialogue: 0,0:03:42.84,0:03:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika kau menyadari kekuatanmu,
Dialogue: 0,0:03:45.22,0:03:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu menjadi sandaran saat harus percaya\Nkepada dirimu sendiri.
Dialogue: 0,0:03:50.52,0:03:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ragu, katakan dengan lantang.\NBiarkan dirimu mendengarnya.
Dialogue: 0,0:03:56.73,0:03:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanku
Dialogue: 0,0:03:58.86,0:04:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah menggambar garis lurus.
Dialogue: 0,0:04:01.86,0:04:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kekuatanku\Nadalah menggambar garis lurus!
Dialogue: 0,0:04:05.74,0:04:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku hanya perlu berlatih!
Dialogue: 0,0:04:08.49,0:04:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambar lebih lurus. Aku akan terus maju!
Dialogue: 0,0:04:11.16,0:04:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:04:13.79,0:04:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra yang kau kuasai\Nakan membaik dengan sendirinya.
Dialogue: 0,0:04:18.00,0:04:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus melatih\Nyang tak biasa digunakan.
Dialogue: 0,0:04:21.63,0:04:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra yang masih belum bisa kau gambar.
Dialogue: 0,0:04:24.51,0:04:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mungkin menemukan kekuatan baru.
Dialogue: 0,0:04:28.76,0:04:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu?
Dialogue: 0,0:04:30.52,0:04:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah…
Dialogue: 0,0:04:37.36,0:04:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Entah kenapa,{\i0}
Dialogue: 0,0:04:38.52,0:04:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}segel terlihat lebih menakjubkan\Ndaripada sebelumnya.{\i0}
Dialogue: 0,0:04:48.03,0:04:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah aku tahu cara membuatnya,{\i0}
Dialogue: 0,0:04:50.24,0:04:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku tahu betapa sulitnya itu sebenanya.{\i0}
Dialogue: 0,0:04:53.87,0:04:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku mulai mengerti sekarang.{\i0}
Dialogue: 0,0:04:59.21,0:05:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:05:00.88,0:05:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini luar biasa.
Dialogue: 0,0:05:02.96,0:05:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra orang hebat itu luar biasa.
Dialogue: 0,0:05:04.84,0:05:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kosakata pujianmu sangat terbatas.
Dialogue: 0,0:05:08.59,0:05:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini begitu luar biasa\Nhingga membuatku agak ciut.
Dialogue: 0,0:05:11.81,0:05:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh, kau juga mau lihat?
Dialogue: 0,0:05:14.85,0:05:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:05:18.40,0:05:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka menggambarnya,\Ntapi tak suka melihatnya.
Dialogue: 0,0:05:22.98,0:05:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Kau tak mau lihat?
Dialogue: 0,0:05:25.11,0:05:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau. Gerakanmu juga menyebalkan.
Dialogue: 0,0:05:31.12,0:05:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir bukan hanya tentang menggambar\Ndi atas kertas, Richeh.
Dialogue: 0,0:05:37.12,0:05:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mempelajari sihir yang luar biasa\Nadalah cara melatih mata…
Dialogue: 0,0:05:41.21,0:05:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilang tak mau lihat!
Dialogue: 0,0:05:44.21,0:05:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh! Kau tak apa-apa?
Dialogue: 0,0:05:46.26,0:05:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau terluka?
Dialogue: 0,0:05:49.47,0:05:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggunakan sihir saat marah\Nbukan hal terpuji.
Dialogue: 0,0:05:52.39,0:05:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berbahaya.
Dialogue: 0,0:05:58.69,0:06:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Richeh.
Dialogue: 0,0:06:04.86,0:06:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus berpaling\Ndari hal yang bisa mengajarimu
Dialogue: 0,0:06:07.74,0:06:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berhenti mendengarkan\Nkata-kata gurumu,
Dialogue: 0,0:06:11.99,0:06:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak akan pernah maju.
Dialogue: 0,0:06:19.87,0:06:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh!
Dialogue: 0,0:06:22.13,0:06:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf soal tadi.
Dialogue: 0,0:06:25.09,0:06:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:06:30.47,0:06:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Richeh?
Dialogue: 0,0:06:33.93,0:06:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak ada?
Dialogue: 0,0:06:37.48,0:06:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia di kamarnya?
Dialogue: 0,0:06:44.65,0:06:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu di mana dia, Teman Kuas?
Dialogue: 0,0:06:52.70,0:06:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:54.03,0:06:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke mana, Teman Kuas?
Dialogue: 0,0:06:57.66,0:06:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:07.96,0:07:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Kuas?
Dialogue: 0,0:07:10.17,0:07:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:07:40.00,0:07:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bilang kau boleh masuk.
Dialogue: 0,0:07:42.08,0:07:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:07:43.58,0:07:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengikuti Teman Kuas.
Dialogue: 0,0:07:45.79,0:07:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra yang indah.
Dialogue: 0,0:07:47.67,0:07:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti pita dari kristal.
Dialogue: 0,0:07:53.59,0:07:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum ada namanya.
Dialogue: 0,0:07:55.85,0:07:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang membuat ini.
Dialogue: 0,0:07:57.10,0:07:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mantra buatanmu sendiri?
Dialogue: 0,0:07:59.97,0:08:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu. Itu luar biasa.
Dialogue: 0,0:08:03.31,0:08:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat indah. Mataku senang.
Dialogue: 0,0:08:06.40,0:08:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara yang unik untuk menghargai sesuatu.
Dialogue: 0,0:08:10.74,0:08:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menyukai mantra ini.
Dialogue: 0,0:08:21.41,0:08:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau mau, kau bisa memilikinya.\N- Apa?
Dialogue: 0,0:08:24.08,0:08:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya banyak.
Dialogue: 0,0:08:25.33,0:08:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Sungguh?
Dialogue: 0,0:08:29.55,0:08:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senangnya.
Dialogue: 0,0:08:30.88,0:08:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:08:34.30,0:08:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:08:36.68,0:08:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku bertanya?
Dialogue: 0,0:08:39.64,0:08:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak suka membaca buku?
Dialogue: 0,0:08:44.35,0:08:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu banyak tentang sihir,
Dialogue: 0,0:08:47.48,0:08:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku suka membaca buku tentangnya.
Dialogue: 0,0:08:51.15,0:08:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pencipta mantra itu?\NKapan diciptakan? Dan apa alasannya?
Dialogue: 0,0:08:55.78,0:08:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka membayangkan hal-hal itu\Nsaat membaca.
Dialogue: 0,0:09:04.12,0:09:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin fokus\Npada sihirku sendiri.
Dialogue: 0,0:09:10.63,0:09:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku membaca buku,
Dialogue: 0,0:09:12.42,0:09:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nanti mereka akan menyuruhku\Nmenggambar mantra yang sama.
Dialogue: 0,0:09:17.34,0:09:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memaksaku menggambar hal\Nyang tak ingin kugambar.
Dialogue: 0,0:09:20.18,0:09:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir yang bukan sihirku.
Dialogue: 0,0:09:23.27,0:09:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin melakukan itu.
Dialogue: 0,0:09:25.23,0:09:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh.
Dialogue: 0,0:09:27.52,0:09:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan urusanmu, Coco.
Dialogue: 0,0:09:30.65,0:09:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak butuh sihir orang lain.
Dialogue: 0,0:09:33.11,0:09:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau sihirku ternoda.
Dialogue: 0,0:09:37.95,0:09:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum Richeh datang ke sini,
Dialogue: 0,0:09:40.41,0:09:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia sudah berhenti\Njadi murid penyihir lain.
Dialogue: 0,0:09:44.54,0:09:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keras kepalanya adalah perisai\Nuntuk melindungi diri.
Dialogue: 0,0:09:48.79,0:09:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti serigala sisik\Nyang berbulu sekeras zirah…
Dialogue: 0,0:09:52.80,0:09:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit menentukan batasannya.
Dialogue: 0,0:09:56.47,0:10:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia jauh lebih rumit daripada sihir.
Dialogue: 0,0:10:02.43,0:10:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:10:03.51,0:10:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:10:07.31,0:10:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu?
Dialogue: 0,0:10:08.44,0:10:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra terbaruku, Batu Penghangat.
Dialogue: 0,0:10:12.69,0:10:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simpan di tempat tidurmu,
Dialogue: 0,0:10:14.73,0:10:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu akan menghangatkanmu\Ndan membantumu tidur nyenyak.
Dialogue: 0,0:10:18.82,0:10:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu tak banyak membantu,\Ntapi berikan kepada anak-anak.
Dialogue: 0,0:10:23.91,0:10:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:25.79,0:10:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirmu memang baik.
Dialogue: 0,0:10:28.91,0:10:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih bermakna daripada kata-kata.
Dialogue: 0,0:10:30.58,0:10:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya urusan pekerjaan!
Dialogue: 0,0:10:33.71,0:10:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini prototipe yang akan dijual.
Dialogue: 0,0:10:35.71,0:10:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya butuh masukan, itu saja!
Dialogue: 0,0:10:38.72,0:10:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, terserah kau saja.
Dialogue: 0,0:10:46.85,0:10:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, Olu.\N- Apa?
Dialogue: 0,0:10:48.98,0:10:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu banyak. Ada lima.
Dialogue: 0,0:10:53.27,0:10:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat untuk anak-anak.
Dialogue: 0,0:10:56.73,0:10:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terakhir untukmu.
Dialogue: 0,0:11:01.16,0:11:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, beri contoh\Ndan tidurlah saat malam.
Dialogue: 0,0:11:07.29,0:11:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau guru mereka.
Dialogue: 0,0:11:15.29,0:11:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan coba.
Dialogue: 0,0:11:20.51,0:11:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surat?
Dialogue: 0,0:11:22.39,0:11:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari siapa, ya?
Dialogue: 0,0:11:27.64,0:11:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:11:30.98,0:11:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott.
Dialogue: 0,0:11:33.02,0:11:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tiba tepat waktu.
Dialogue: 0,0:11:35.90,0:11:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru dapat kabar dari Aula Besar.
Dialogue: 0,0:11:38.28,0:11:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggal ujian tahap kedua\Nsudah ditetapkan.
Dialogue: 0,0:11:41.28,0:11:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan?
Dialogue: 0,0:11:43.16,0:11:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tiga hari lagi, saat fajar.{\i0}
Dialogue: 0,0:11:45.83,0:11:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gua Punggung Ular di Tanjung Romonon.{\i0}
Dialogue: 0,0:11:57.46,0:12:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin membuat pita kristal?
Dialogue: 0,0:12:02.13,0:12:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mantra yang menggemaskan, Richelitte.
Dialogue: 0,0:12:17.31,0:12:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Kak Riri.
Dialogue: 0,0:12:21.07,0:12:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkelip dan berkilauan. Cantik sekali!
Dialogue: 0,0:12:34.96,0:12:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Riri?
Dialogue: 0,0:12:37.50,0:12:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu?
Dialogue: 0,0:12:39.46,0:12:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku suka sihir yang membuatmu\Nmenjadi dirimu, Richeh.
Dialogue: 0,0:12:44.38,0:12:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tetaplah menjadi dirimu sendiri.
Dialogue: 0,0:12:50.47,0:12:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Riri?
Dialogue: 0,0:12:52.81,0:12:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke mana?
Dialogue: 0,0:12:54.73,0:12:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah tak mau melihat sihirku lagi?
Dialogue: 0,0:12:58.15,0:13:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan pergi, Kak Riri.{\i0}
Dialogue: 0,0:13:08.12,0:13:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi…
Dialogue: 0,0:13:11.95,0:13:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertidur lelap.
Dialogue: 0,0:13:14.91,0:13:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berencana berlatih\Nsampai detik terakhir sebelum ujian.
Dialogue: 0,0:13:19.38,0:13:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi karena batu penghangat\Nyang nyaman ini…
Dialogue: 0,0:13:22.92,0:13:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hore.
Dialogue: 0,0:13:24.38,0:13:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir, Agott.
Dialogue: 0,0:13:27.09,0:13:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebanyak apa pun persiapanmu,\Ntetap tak akan terasa cukup.
Dialogue: 0,0:13:32.06,0:13:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berusahalah dengan kemampuanmu\Nyang sekarang.
Dialogue: 0,0:13:35.23,0:13:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi dirimu di masa depan.
Dialogue: 0,0:13:41.11,0:13:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu membahas masa depan.
Dialogue: 0,0:13:49.74,0:13:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lulus pada percobaan pertama.
Dialogue: 0,0:13:51.95,0:13:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku anggota Keluarga Arklaum.
Dialogue: 0,0:13:54.54,0:13:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, sungguh meyakinkan.
Dialogue: 0,0:13:59.29,0:14:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jauh berbeda dengan anak didikku.
Dialogue: 0,0:14:02.63,0:14:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muridku, Euini,
Dialogue: 0,0:14:04.51,0:14:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah dua kali gagal\Ndalam Ujian Tahap Kedua
Dialogue: 0,0:14:08.05,0:14:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padahal hanya bisa ikut setahun sekali.
Dialogue: 0,0:14:11.51,0:14:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menukar tangan dominannya
Dialogue: 0,0:14:13.60,0:14:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan tangan nona\Ndari Keluarga Arklaum yang terhormat.
Dialogue: 0,0:14:16.31,0:14:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Kukrow!
Dialogue: 0,0:14:17.64,0:14:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid bukanlah benda.\NKau tak bisa menukarnya begitu saja.
Dialogue: 0,0:14:21.48,0:14:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah masalahnya.
Dialogue: 0,0:14:24.48,0:14:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tak bisa memperbaikinya.
Dialogue: 0,0:14:27.15,0:14:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara begitu…
Dialogue: 0,0:14:28.70,0:14:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:14:31.66,0:14:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu semua benar.
Dialogue: 0,0:14:33.91,0:14:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku murid yang tidak becus.
Dialogue: 0,0:14:35.87,0:14:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya menjadi beban bagi Guru Kukrow.
Dialogue: 0,0:14:38.62,0:14:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga…
Dialogue: 0,0:14:39.54,0:14:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tak becus,\Norang-orang jadi mencemooh guruku.
Dialogue: 0,0:14:43.54,0:14:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:14:44.55,0:14:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sepertiku mustahil…
Dialogue: 0,0:14:46.26,0:14:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini?
Dialogue: 0,0:14:48.17,0:14:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku terlambat. Maaf.
Dialogue: 0,0:14:51.05,0:14:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jendela jalan terdekat tidak berfungsi.
Dialogue: 0,0:14:54.51,0:14:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku harus jalan kaki ke sini.
Dialogue: 0,0:14:59.60,0:15:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Teman kuas raksasa itu bisa bicara!
Dialogue: 0,0:15:03.44,0:15:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba perhatikan lagi.
Dialogue: 0,0:15:04.94,0:15:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah seorang penyihir tulen.
Dialogue: 0,0:15:08.28,0:15:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa? Bukankah transformasi\Nadalah sihir terlarang?
Dialogue: 0,0:15:12.07,0:15:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubah Cermin Peminjam Bayangan.
Dialogue: 0,0:15:14.83,0:15:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau memakainya,
Dialogue: 0,0:15:16.20,0:15:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}alat ini memproyeksikan ilusi hewan\Nyang berdiri di depanmu.
Dialogue: 0,0:15:22.08,0:15:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu kalian. Aku Alaira.
Dialogue: 0,0:15:24.96,0:15:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku salah satu pengawas\Nyang mengawasi Ujian Tahap Kedua.
Dialogue: 0,0:15:29.59,0:15:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang menjadi pengawasnya?
Dialogue: 0,0:15:31.59,0:15:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali.
Dialogue: 0,0:15:33.30,0:15:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, kau membawa semua orang.\NBahkan yang tak ikut ujian.
Dialogue: 0,0:15:37.60,0:15:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujian tahap kedua,{\i0}
Dialogue: 0,0:15:38.93,0:15:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Kesetiaan Ksatria,"\Npersis seperti namanya.{\i0}
Dialogue: 0,0:15:41.64,0:15:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seperti ksatria, kalian harus melindungi\Npihak yang ditunjuk{\i0}
Dialogue: 0,0:15:44.56,0:15:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan mengawal mereka\Nmelewati gua dengan aman{\i0}
Dialogue: 0,0:15:46.98,0:15:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dari pintu masuk sampai pintu keluar.{\i0}
Dialogue: 0,0:15:49.61,0:15:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian gagal kalau kehilangan\Npihak yang kalian jaga.
Dialogue: 0,0:15:52.57,0:15:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya salah satu\Nyang sampai lebih dulu, itu juga gagal.
Dialogue: 0,0:15:56.53,0:16:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga pasti gagal kalau ada\Nyang melihat kalian menggambar sihir.
Dialogue: 0,0:16:01.04,0:16:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau ada yang melihat kami?
Dialogue: 0,0:16:04.21,0:16:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas soal rahasia terbongkar,
Dialogue: 0,0:16:06.84,0:16:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau akan gagal ujian.
Dialogue: 0,0:16:09.80,0:16:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka akan tahu kau manusia.
Dialogue: 0,0:16:11.88,0:16:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai jubah itu dan lihat dari sini.
Dialogue: 0,0:16:26.77,0:16:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu gryphon?
Dialogue: 0,0:16:29.15,0:16:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, mereka itu myrphon.
Dialogue: 0,0:16:32.03,0:16:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka spesies yang berbeda.
Dialogue: 0,0:16:34.70,0:16:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gua Punggung Ular\Nyang digunakan untuk ujian{\i0}
Dialogue: 0,0:16:37.24,0:16:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah reruntuhan sihir\Ndari Zaman Kekacauan.{\i0}
Dialogue: 0,0:16:40.12,0:16:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sihir labirin berpusar di sepanjang jalur.{\i0}
Dialogue: 0,0:16:42.54,0:16:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan menyimpang dari jalan,\Natau bahaya akan menanti.{\i0}
Dialogue: 0,0:16:46.63,0:16:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Ujian Tahap Kedua\Ntentang menggunakan sihir
Dialogue: 0,0:16:50.30,0:16:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melindungi mereka dari sihir?
Dialogue: 0,0:16:52.30,0:16:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat.
Dialogue: 0,0:16:53.84,0:16:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia jarang menginjakkan kaki\Ndi reruntuhan itu,
Dialogue: 0,0:16:56.43,0:16:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bagi para hewan,\Nitu sudah lama jadi jalur migrasi
Dialogue: 0,0:16:59.97,0:17:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke tempat berkembang biak\Ndan musim dingin mereka.
Dialogue: 0,0:17:02.31,0:17:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir bertanggung jawab\Nuntuk mengubah dunia mereka.
Dialogue: 0,0:17:09.65,0:17:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, setiap tahun,
Dialogue: 0,0:17:11.07,0:17:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita memandu dan mengawal\Nbayi yang baru meninggalkan sarang
Dialogue: 0,0:17:14.28,0:17:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar mereka tak tersesat dalam perjalanan.
Dialogue: 0,0:17:18.28,0:17:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan sihir pada jubah itu,
Dialogue: 0,0:17:20.33,0:17:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}myrphon akan melihat kalian\Nsebagai anggota kawanan mereka.
Dialogue: 0,0:17:23.66,0:17:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melepas jubahnya\Natau segelnya rusak,
Dialogue: 0,0:17:25.91,0:17:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka akan kabur, berhati-hatilah.
Dialogue: 0,0:17:29.25,0:17:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Begitu rupanya.{\i0}
Dialogue: 0,0:17:31.17,0:17:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dibandingkan menggambar sihir\Ntanpa diketahui manusia,{\i0}
Dialogue: 0,0:17:34.47,0:17:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ini justru lebih sulit.{\i0}
Dialogue: 0,0:17:37.43,0:17:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masing-masing dapat seekor.
Dialogue: 0,0:17:39.93,0:17:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini milikmu.
Dialogue: 0,0:17:44.02,0:17:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, dan yang terakhir
Dialogue: 0,0:17:46.44,0:17:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untukmu.
Dialogue: 0,0:17:47.98,0:17:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:50.69,0:17:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk Richeh?
Dialogue: 0,0:17:52.69,0:17:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, terjadi kesalahan.
Dialogue: 0,0:17:54.82,0:17:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ikut ujian.
Dialogue: 0,0:17:57.28,0:18:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aneh. Kami menerima pendaftaranmu.
Dialogue: 0,0:18:00.99,0:18:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan kesalahan.
Dialogue: 0,0:18:03.20,0:18:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga ikut ujian, Richeh.
Dialogue: 0,0:18:16.92,0:18:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembohong.
Dialogue: 0,0:18:18.76,0:18:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh…
Dialogue: 0,0:18:21.22,0:18:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey,
Dialogue: 0,0:18:23.10,0:18:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bilang aku bisa melakukan\Napa yang kuinginkan.
Dialogue: 0,0:18:26.81,0:18:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku mau menjadi muridmu.
Dialogue: 0,0:18:29.81,0:18:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tak peduli\Npada keinginanku, bukan?
Dialogue: 0,0:18:32.98,0:18:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan memaksaku\Nseperti orang dewasa lainya.
Dialogue: 0,0:18:36.74,0:18:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan berarti aku tak peduli.
Dialogue: 0,0:18:39.86,0:18:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena aku peduli,
Dialogue: 0,0:18:42.28,0:18:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin kau ikut ujian ini.
Dialogue: 0,0:18:44.99,0:18:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, apa yang kau pelajari di sini
Dialogue: 0,0:18:47.04,0:18:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membantumu\Nmenjalani hidup yang kau inginkan.
Dialogue: 0,0:18:50.42,0:18:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:18:52.84,0:18:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maukah kau percaya kepadaku kali ini?
Dialogue: 0,0:19:03.01,0:19:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ujian, aku akan menjalaninya\Nsesuai keinginanku.
Dialogue: 0,0:19:08.02,0:19:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu. Ya.
Dialogue: 0,0:19:10.14,0:19:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah.
Dialogue: 0,0:19:11.77,0:19:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku mencoba dan tidak suka,\Naku akan berhenti.
Dialogue: 0,0:19:15.57,0:19:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku berhenti menjadi diri sendiri,
Dialogue: 0,0:19:18.15,0:19:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak akan pernah memercayaimu lagi.
Dialogue: 0,0:19:25.83,0:19:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, kau juga kerepotan.
Dialogue: 0,0:19:29.33,0:19:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang kau katakan,\Nmereka tetap tak tertolong.
Dialogue: 0,0:19:32.75,0:19:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka selalu punya alasan. "Tapi…"
Dialogue: 0,0:19:37.59,0:19:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini melelahkan, bukan?
Dialogue: 0,0:19:40.47,0:19:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa anak-anak begitu…\N- Maaf.
Dialogue: 0,0:19:43.64,0:19:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau mengatakan sesuatu?
Dialogue: 0,0:19:46.22,0:19:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:48.60,0:19:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, sudah waktunya.
Dialogue: 0,0:19:50.23,0:19:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya, aku kembali ke Aula Besar.
Dialogue: 0,0:19:54.48,0:19:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:55.48,0:19:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau meninggalkan ujian muridmu?
Dialogue: 0,0:19:57.77,0:20:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Dia akan baik-baik saja\Ndengan kalian di sini.
Dialogue: 0,0:20:02.24,0:20:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serahkan sisanya kepada kalian.
Dialogue: 0,0:20:08.37,0:20:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin. Dia benar-benar pergi.
Dialogue: 0,0:20:12.62,0:20:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini.
Dialogue: 0,0:20:14.25,0:20:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha sebaik mungkin.
Dialogue: 0,0:20:16.79,0:20:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, semoga berhasil.
Dialogue: 0,0:20:25.59,0:20:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya.
Dialogue: 0,0:20:27.64,0:20:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Andai semua orang\Nbisa menemukan jalan melalui kegelapan.{\i0}
Dialogue: 0,0:20:32.02,0:20:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itulah gunanya sihir.{\i0}
Dialogue: 0,0:20:33.77,0:20:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untuk hal semacam itu.{\i0}
Dialogue: 0,0:20:46.37,0:20:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah bergerak.
Dialogue: 0,0:20:59.42,0:21:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo pergi!
Dialogue: 0,0:21:23.40,0:21:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah pergi.
Dialogue: 0,0:21:24.82,0:21:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, bagaimana kalau kita\Nmenikmati sarapan yang tertunda?
Dialogue: 0,0:21:28.78,0:21:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa membahas sejarah sambil makan.
Dialogue: 0,0:21:30.95,0:21:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejarah?
Dialogue: 0,0:21:32.70,0:21:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:34.20,0:21:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco masih belum tahu\Ntentang reruntuhan sihir
Dialogue: 0,0:21:36.92,0:21:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti Gua Punggung Ular, bukan?
Dialogue: 0,0:21:41.34,0:21:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sejarah sihir terlarang\Nyang diciptakan sebelum Hari Perjanjian…{\i0}
Dialogue: 0,0:21:46.97,0:21:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}meninggalkan bekas luka di dunia.{\i0}
Dialogue: 0,0:21:51.47,0:21:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus melewati jalan ini?
Dialogue: 0,0:21:54.47,0:21:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kukatakan,
Dialogue: 0,0:21:56.14,0:21:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini ujian tentang melindungi diri\Ndari sihir dengan sihir.
Dialogue: 0,0:21:59.77,0:22:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ksatria sihir muda sekalian,
Dialogue: 0,0:22:02.36,0:22:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana cara kalian menghadapinya?
Dialogue: 0,0:23:39.12,0:23:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana
