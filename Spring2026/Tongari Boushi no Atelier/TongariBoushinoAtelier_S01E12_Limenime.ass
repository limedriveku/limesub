Dialogue: 0,0:02:44.03,0:02:46.24,sign,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:23:36.58,0:23:38.99,sign,,0000,0000,0000,,EPISODE 13\NSIHIR TERLARANG
Dialogue: 0,0:00:02.58,0:00:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu kala, di dalam gua-gua\Ndi sepanjang tanjung ini,
Dialogue: 0,0:00:05.54,0:00:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berdirilah sebuah kerajaan makmur\Nbernama Romonon,
Dialogue: 0,0:00:08.25,0:00:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terkenal\Ndengan keindahan karya sihirnya.
Dialogue: 0,0:00:12.67,0:00:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka mengenakan hiasan emas sihir{\i0}
Dialogue: 0,0:00:14.84,0:00:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan tak berusaha menyembunyikan\Nkesombongan mereka.{\i0}
Dialogue: 0,0:00:18.22,0:00:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka memandang rendah tanah di luar gua\Ndan para penghuninya,{\i0}
Dialogue: 0,0:00:21.52,0:00:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menganggapnya lebih rendah\Ndan bukan dari golongan mereka.{\i0}
Dialogue: 0,0:00:25.73,0:00:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat kisah kekayaan Romonon menyebar luas,{\i0}
Dialogue: 0,0:00:28.61,0:00:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}semakin banyak\Norang permukaan berdatangan.{\i0}
Dialogue: 0,0:00:31.36,0:00:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka hanya menerima\Norang-orang yang dianggap layak,{\i0}
Dialogue: 0,0:00:34.95,0:00:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}jadi, mereka membangun Jalan Punggung Ular\Nyang hanya bisa dilalui orang terpilih.{\i0}
Dialogue: 0,0:00:39.78,0:00:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untuk memastikan mereka yang tak layak\Ntak akan bisa tiba di Romonon,{\i0}
Dialogue: 0,0:00:45.79,0:00:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka mengukir mantra labirin\Nke dalam gua.{\i0}
Dialogue: 0,0:00:49.84,0:00:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Romonon semakin indah dan makmur,{\i0}
Dialogue: 0,0:00:52.71,0:00:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi juga semakin sombong dan terisolasi.{\i0}
Dialogue: 0,0:00:55.30,0:00:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Suatu saat,{\i0}
Dialogue: 0,0:00:56.68,0:01:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}orang-orang Romonon\Nmulai menilai satu sama lain.{\i0}
Dialogue: 0,0:01:01.97,0:01:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka yang dianggap tak berharga{\i0}
Dialogue: 0,0:01:04.43,0:01:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}diubah menggunakan sihir{\i0}
Dialogue: 0,0:01:07.44,0:01:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menjadi karya emas yang menghiasi kota.{\i0}
Dialogue: 0,0:01:11.90,0:01:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Layaknya air tergenang yang menjadi keruh,{\i0}
Dialogue: 0,0:01:14.65,0:01:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Romonon, yang terisolasi, mulai tercemar.{\i0}
Dialogue: 0,0:01:18.16,0:01:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka berbalik melawan satu sama lain\Nhingga letih dan rapuh oleh kebencian.{\i0}
Dialogue: 0,0:01:22.83,0:01:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Akhirnya, kerajaan runtuh\Ndi bawah beban gunung emasnya sendiri.{\i0}
Dialogue: 0,0:01:27.58,0:01:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tersisa hanyalah Jalan Punggung Ular
Dialogue: 0,0:01:30.84,0:01:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan gua-gua yang berubah menjadi labirin.
Dialogue: 0,0:01:35.34,0:01:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia bisa sangat menakutkan.
Dialogue: 0,0:01:38.09,0:01:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dapat dengan mudah\Nmelakukan hal mengerikan,
Dialogue: 0,0:01:40.93,0:01:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hanya sedikit dari kita\Nyang menyadarinya.
Dialogue: 0,0:01:45.14,0:01:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi, Guru…\N- Ya?
Dialogue: 0,0:01:48.10,0:01:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sihir seharusnya\Nmembuat orang bahagia, bukan?
Dialogue: 0,0:01:51.82,0:01:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kekuatan untuk membantu orang\Ndan memberi warna pada dunia, bukan?
Dialogue: 0,0:01:58.40,0:02:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau penyihir masa depan\Nseperti kalian meyakini itu,
Dialogue: 0,0:02:01.83,0:02:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin…
Dialogue: 0,0:02:03.83,0:02:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar. Semua akan baik-baik saja.
Dialogue: 0,0:02:08.62,0:02:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:02:10.13,0:02:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra ini bisa membuat\Nmakan malam kita menjadi berantakan.
Dialogue: 0,0:02:15.17,0:02:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Ikannya hangus!
Dialogue: 0,0:02:19.22,0:02:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas!
Dialogue: 0,0:02:20.43,0:02:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa dimakan\Nkalau yang hangus dibuang! Enak!
Dialogue: 0,0:02:24.01,0:02:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sihir adalah kekuatan\Nuntuk memberi warna pada dunia…{\i0}
Dialogue: 0,0:02:28.39,0:02:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semoga itu benar.{\i0}
Dialogue: 0,0:02:32.27,0:02:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semoga begitu.{\i0}
Dialogue: 0,0:04:07.87,0:04:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana cara kalian menghadapinya?
Dialogue: 0,0:04:10.91,0:04:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku hanya pengawas.\NMulai sekarang, kalian sendirian.
Dialogue: 0,0:04:15.12,0:04:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Memang berliku,\Ntapi hanya ada satu jalan ke depan.
Dialogue: 0,0:04:18.92,0:04:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini mudah.
Dialogue: 0,0:04:21.80,0:04:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terbang dan menyelesai…
Dialogue: 0,0:04:31.18,0:04:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:04:37.27,0:04:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berdiri menyamping?
Dialogue: 0,0:04:39.69,0:04:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu sihirmu?
Dialogue: 0,0:04:41.65,0:04:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah sihir jalan ini.
Dialogue: 0,0:04:44.45,0:04:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ruang di dalam gua ini\Ntelah terdistorsi sepenuhnya.
Dialogue: 0,0:04:47.37,0:04:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Punggung Ular ini adalah satu-satunya rute\Ndi permukaan datar.
Dialogue: 0,0:04:51.95,0:04:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jika melangkah keluar,\Nkita akan jatuh ke labirin gua
Dialogue: 0,0:04:55.96,0:04:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kembali ke pintu masuk.
Dialogue: 0,0:04:59.46,0:05:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan batu-batu jalan\Nyang menyerupai sisik ular ini…
Dialogue: 0,0:05:04.59,0:05:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini semua segel sihir?
Dialogue: 0,0:05:08.26,0:05:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada yang sudah retak dan hancur.
Dialogue: 0,0:05:12.43,0:05:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku gagal ujian pertama.\NAku tak pernah tahu apa itu.
Dialogue: 0,0:05:17.48,0:05:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabannya tertulis\Ndi buku teks sihir dasar…
Dialogue: 0,0:05:20.86,0:05:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra itu.
Dialogue: 0,0:05:31.37,0:05:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Air mengalir mengikuti gravitasi.{\i0}
Dialogue: 0,0:05:34.00,0:05:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pada permukaan datar,\Nair menggenang dan tak bergerak.{\i0}
Dialogue: 0,0:05:37.92,0:05:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya bagian dengan segel utuh\Nyang permukaannya masih datar,
Dialogue: 0,0:05:41.92,0:05:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat air berkumpul
Dialogue: 0,0:05:44.21,0:05:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menandai jalan yang aman dilewati.
Dialogue: 0,0:05:47.18,0:05:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar sekali.
Dialogue: 0,0:05:49.18,0:05:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggota Keluarga Arklaum memang hebat.
Dialogue: 0,0:05:52.18,0:05:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan pada percobaan kedua, aku tak bisa…
Dialogue: 0,0:05:55.81,0:05:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jawaban yang benar.{\i0}
Dialogue: 0,0:05:58.10,0:05:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mantra yang tepat.{\i0}
Dialogue: 0,0:06:01.06,0:06:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jalan yang benar.{\i0}
Dialogue: 0,0:06:03.69,0:06:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Diberi tahu agar tak menyimpang,{\i0}
Dialogue: 0,0:06:06.24,0:06:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}itu hal yang paling aku benci.{\i0}
Dialogue: 0,0:06:09.86,0:06:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Richelitte.
Dialogue: 0,0:06:12.70,0:06:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menggambar mantra tak berguna lagi.
Dialogue: 0,0:06:15.91,0:06:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak akan menjadi penyihir\Nyang baik kalau begitu.
Dialogue: 0,0:06:20.17,0:06:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak mendengarkan\Ndan mengikuti kata gurumu?
Dialogue: 0,0:06:24.92,0:06:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang saja coretan-coretan ini.
Dialogue: 0,0:06:31.68,0:06:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak mau.{\i0}
Dialogue: 0,0:06:33.81,0:06:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu bukan coret-coretan.{\i0}
Dialogue: 0,0:06:35.97,0:06:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini adalah sihirku.{\i0}
Dialogue: 0,0:06:39.73,0:06:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak mau membuang diriku.{\i0}
Dialogue: 0,0:06:42.19,0:06:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau begitu…{\i0}
Dialogue: 0,0:06:46.07,0:06:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat sini. Ayo.
Dialogue: 0,0:06:50.66,0:06:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu jalan yang harus dilewati,\Ntapi myrphon tak mau mengikutiku.
Dialogue: 0,0:06:55.58,0:06:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah!
Dialogue: 0,0:06:56.79,0:07:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahaya kalau kau jatuh,\Ntetap di dekatku!
Dialogue: 0,0:07:06.38,0:07:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jangan harap dimaafkan\Nhanya karena bertingkah manis.
Dialogue: 0,0:07:09.59,0:07:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi
Dialogue: 0,0:07:12.09,0:07:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}justru tingkahnya yang penting.
Dialogue: 0,0:07:14.64,0:07:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Myrphon berkomunikasi\Ndengan saling berseru.
Dialogue: 0,0:07:17.52,0:07:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi, kalau kau ingin mereka mengikutimu,
Dialogue: 0,0:07:20.85,0:07:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}cara yang benar adalah menggunakan\Nmantra resonansi untuk meniru seruan…
Dialogue: 0,0:07:28.69,0:07:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jangan anggap sihir hanya punya\Nsatu cara yang benar.
Dialogue: 0,0:07:32.41,0:07:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada aturan\Nyang menetapkan cara melakukannya.
Dialogue: 0,0:07:35.91,0:07:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para myrphon itu…
Dialogue: 0,0:07:37.16,0:07:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mungkin pernah mengikuti\Nujian ini, Euini,
Dialogue: 0,0:07:41.04,0:07:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau terus membicarakan\N"jawaban yang benar".
Dialogue: 0,0:07:44.17,0:07:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjelaskan sebelum mencoba itu\Nsama saja ikut campur.
Dialogue: 0,0:07:47.71,0:07:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin jadi diriku sendiri.
Dialogue: 0,0:07:49.92,0:07:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau jadi penyihir\Nyang bukan diriku.
Dialogue: 0,0:07:53.93,0:07:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku akan keluar dari jalan ini
Dialogue: 0,0:07:56.93,0:07:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan menggunakan sihirku sendiri.
Dialogue: 0,0:07:59.18,0:08:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh.
Dialogue: 0,0:08:02.23,0:08:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu mustahil.
Dialogue: 0,0:08:05.61,0:08:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia tak berjalan seperti itu.
Dialogue: 0,0:08:08.57,0:08:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun, ini adalah ujian.
Dialogue: 0,0:08:10.57,0:08:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada jawaban yang benar.
Dialogue: 0,0:08:13.57,0:08:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih kurang berpengalaman.\NKita hanya murid.
Dialogue: 0,0:08:16.37,0:08:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih anak-anak,\Njadi, kita harus mengikuti buku teks.
Dialogue: 0,0:08:20.08,0:08:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau aku akan gagal lagi.
Dialogue: 0,0:08:22.33,0:08:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang begitu aturan ujian.
Dialogue: 0,0:08:25.08,0:08:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku benci disuruh tunduk pada aturan.
Dialogue: 0,0:08:27.71,0:08:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau itu mantra yang belum pernah dicoba,\Nitu bisa gagal.
Dialogue: 0,0:08:31.34,0:08:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau melakukannya agar berhasil.
Dialogue: 0,0:08:33.30,0:08:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu gila…
Dialogue: 0,0:08:34.22,0:08:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau bisa belajar dari kegagalanmu.
Dialogue: 0,0:08:37.60,0:08:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa jadi kekuatanmu.
Dialogue: 0,0:08:40.60,0:08:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kenal seseorang\Nyang belajar dengan cara itu.
Dialogue: 0,0:08:44.85,0:08:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan saja sesukamu, Richeh.
Dialogue: 0,0:08:47.61,0:08:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan urusanku.
Dialogue: 0,0:08:49.94,0:08:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak perlu memberitahuku, Agott.
Dialogue: 0,0:09:09.38,0:09:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa itu? Air?
Dialogue: 0,0:09:16.13,0:09:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:09:17.55,0:09:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guruku setiap hari selalu bilang,
Dialogue: 0,0:09:21.22,0:09:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kau tak akan mampu."
Dialogue: 0,0:09:22.64,0:09:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}"Kau tak bisa melakukan itu."
Dialogue: 0,0:09:25.14,0:09:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya kepadanya.
Dialogue: 0,0:09:27.65,0:09:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku mempelajari cara orang lain\Nmelakukan sesuatu.
Dialogue: 0,0:09:32.57,0:09:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tetap tak berhasil.
Dialogue: 0,0:09:36.15,0:09:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini Romonon.
Dialogue: 0,0:09:40.74,0:09:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan ini
Dialogue: 0,0:09:42.54,0:09:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dibuat untuk menghalangi\Nmereka yang tak terpilih.
Dialogue: 0,0:09:52.04,0:09:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco? Ada apa?
Dialogue: 0,0:09:54.38,0:09:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey,
Dialogue: 0,0:09:55.80,0:09:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa ada penyihir lain\Ndi sekitar sini hari ini?
Dialogue: 0,0:09:59.09,0:10:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukrow sudah pergi.
Dialogue: 0,0:10:01.05,0:10:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tidak ada.
Dialogue: 0,0:10:03.06,0:10:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:10:04.18,0:10:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku tadi melihat\Nseseorang berjubah di sana.
Dialogue: 0,0:10:08.81,0:10:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:10:22.07,0:10:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak mungkin ada orang di sini.{\i0}
Dialogue: 0,0:10:24.41,0:10:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:10:26.70,0:10:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Aku ke sana!
Dialogue: 0,0:10:41.05,0:10:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya mengalir ke bawah.
Dialogue: 0,0:10:42.89,0:10:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setelah itu,\Nair mengalir ke arah yang aneh.
Dialogue: 0,0:10:46.35,0:10:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jalannya hancur,
Dialogue: 0,0:10:48.39,0:10:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}segel di bagian bawah batu itu\Njuga tak akan berfungsi.
Dialogue: 0,0:10:52.73,0:10:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus cari cara untuk menyeberang.
Dialogue: 0,0:10:56.23,0:10:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh?
Dialogue: 0,0:10:57.36,0:11:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel hanya aktif\Nselama kau berdiri di atas batu.
Dialogue: 0,0:11:01.41,0:11:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita perpanjang batu\Nsampai ke jalan di sana.
Dialogue: 0,0:11:08.12,0:11:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini.
Dialogue: 0,0:11:18.84,0:11:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tetap berdiri di pita batu itu?
Dialogue: 0,0:11:25.43,0:11:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat?
Dialogue: 0,0:11:26.85,0:11:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sesuatu tak bisa dilakukan,
Dialogue: 0,0:11:28.39,0:11:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tinggal mengubahnya\Nagar bisa dilakukan.
Dialogue: 0,0:11:33.10,0:11:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mungkin benar.
Dialogue: 0,0:11:34.86,0:11:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:46.16,0:11:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati!
Dialogue: 0,0:11:47.33,0:11:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu…
Dialogue: 0,0:11:53.50,0:11:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kombinasi sihir rekreasi dan repetisi.
Dialogue: 0,0:11:56.25,0:11:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangkauannya terbatas, tapi ini berhasil.
Dialogue: 0,0:12:01.88,0:12:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:12:03.22,0:12:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa!
Dialogue: 0,0:12:09.39,0:12:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak bisa menggambar dengan baik\Ndi bawah jubah,{\i0}
Dialogue: 0,0:12:12.60,0:12:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}jadi, sihirnya tak bertahan lama\Ndan langsung hilang.{\i0}
Dialogue: 0,0:12:15.69,0:12:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku masih harus banyak belajar.{\i0}
Dialogue: 0,0:12:17.27,0:12:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus bekerja lebih keras.{\i0}
Dialogue: 0,0:12:19.78,0:12:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hebat juga.
Dialogue: 0,0:12:21.90,0:12:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mudah.
Dialogue: 0,0:12:24.86,0:12:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini giliranmu, bukan?
Dialogue: 0,0:12:31.79,0:12:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:12:35.29,0:12:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa!
Dialogue: 0,0:12:38.67,0:12:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melakukan ini!
Dialogue: 0,0:12:40.50,0:12:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya bakat, keberanian,
Dialogue: 0,0:12:42.13,0:12:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepercayaan diri,\Nkemampuan, atau keahlian!
Dialogue: 0,0:12:45.43,0:12:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalannya runtuh.\NAku benar-benar tak beruntung!
Dialogue: 0,0:12:48.14,0:12:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti gagal lagi!
Dialogue: 0,0:12:49.64,0:12:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah.
Dialogue: 0,0:12:51.31,0:12:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah memamerkan analisis\Ndan pengetahuanmu sejak awal.
Dialogue: 0,0:12:55.64,0:12:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gunanya dua kali mengikuti ujian\Nkalau tak dimanfaatkan?
Dialogue: 0,0:12:59.61,0:13:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambar saja sesuatu.
Dialogue: 0,0:13:14.79,0:13:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra suara?
Dialogue: 0,0:13:18.33,0:13:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra hujan untuk membuat genangan?
Dialogue: 0,0:13:22.13,0:13:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mantra untuk area\Nyang sudah kita lewati!
Dialogue: 0,0:13:25.72,0:13:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau butuh sesuatu yang baru\Nuntuk menyeberang.
Dialogue: 0,0:13:29.60,0:13:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menggambar.
Dialogue: 0,0:13:31.72,0:13:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:33.22,0:13:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:13:35.98,0:13:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku tak bisa berhenti gemetar.
Dialogue: 0,0:13:40.48,0:13:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat harus menggambar di depan orang lain,{\i0}
Dialogue: 0,0:13:44.07,0:13:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku tak pernah bisa melakukannya.{\i0}
Dialogue: 0,0:13:47.07,0:13:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau ada yang melihat,{\i0}
Dialogue: 0,0:13:48.66,0:13:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku mulai berkeringat.\NTanganku jadi licin.{\i0}
Dialogue: 0,0:13:50.74,0:13:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku gemetar. Garisnya jadi berantakan.{\i0}
Dialogue: 0,0:13:53.74,0:13:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setiap mantra berakhir buruk.{\i0}
Dialogue: 0,0:13:56.37,0:13:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku ingin memperbaikinya,{\i0}
Dialogue: 0,0:13:59.46,0:14:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi aku tak tahu caranya.{\i0}
Dialogue: 0,0:14:03.42,0:14:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selain itu,{\i0}
Dialogue: 0,0:14:06.05,0:14:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}saat orang melihatku panik dan gemetar,{\i0}
Dialogue: 0,0:14:08.09,0:14:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}itu hanya memperburuk keadaan.{\i0}
Dialogue: 0,0:14:12.05,0:14:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, kali ini, aku belajar\Ndan melakukan persiapan lebih awal.{\i0}
Dialogue: 0,0:14:16.93,0:14:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku menggambar semua mantra yang benar{\i0}
Dialogue: 0,0:14:19.40,0:14:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang mungkin kubutuhkan.{\i0}
Dialogue: 0,0:14:22.23,0:14:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku masih bisa fokus saat sendirian.{\i0}
Dialogue: 0,0:14:26.15,0:14:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan tak ada aturan\Nyang melarang membawa buku telapak.{\i0}
Dialogue: 0,0:14:30.24,0:14:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tinggal menutup lingkaran\Nuntuk mengaktifkannya.{\i0}
Dialogue: 0,0:14:33.53,0:14:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kupikir dengan cara ini,\Naku bisa terlihat kompeten.{\i0}
Dialogue: 0,0:14:37.54,0:14:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak menduga jalannya akan hancur.
Dialogue: 0,0:14:41.46,0:14:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dihukum karena tak melakukannya\Ndengan cara yang benar.
Dialogue: 0,0:14:45.21,0:14:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku selalu begini?
Dialogue: 0,0:14:48.30,0:14:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang kau ingin menjadi dirimu.
Dialogue: 0,0:14:51.30,0:14:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku? Kalau bisa,\Naku akan berhenti menjadi diriku sendiri.
Dialogue: 0,0:14:55.18,0:14:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka menjadi orang lain.
Dialogue: 0,0:15:00.02,0:15:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tujuan ujian ini{\i0}
Dialogue: 0,0:15:01.44,0:15:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah menguji apakah kau bisa{\i0}
Dialogue: 0,0:15:03.06,0:15:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menggunakan sihir tanpa ketahuan,\Nbahkan di depan orang luar.{\i0}
Dialogue: 0,0:15:06.32,0:15:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Maaf, tapi melihat situasinya,\Nsepertinya dia tak akan lulus.{\i0}
Dialogue: 0,0:15:10.28,0:15:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa.
Dialogue: 0,0:15:12.45,0:15:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa melakukannya sebagai Euini.
Dialogue: 0,0:15:15.62,0:15:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah punya jawabannya.
Dialogue: 0,0:15:17.95,0:15:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau tak sadar?
Dialogue: 0,0:15:19.71,0:15:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau bisa fokus saat sendirian,\Nbuat dirimu sendirian sekarang!
Dialogue: 0,0:15:24.46,0:15:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:28.30,0:15:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana caranya?
Dialogue: 0,0:15:30.38,0:15:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentukan sendiri caranya!
Dialogue: 0,0:15:32.01,0:15:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir bisa meregangkan batu.
Dialogue: 0,0:15:34.05,0:15:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir bisa membuat hujan.
Dialogue: 0,0:15:36.31,0:15:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau juga bisa membuat ruang\Nuntuk menyendiri.
Dialogue: 0,0:15:39.35,0:15:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak bisa menggambar mantra itu…
Dialogue: 0,0:15:42.35,0:15:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan tanpa sihir!
Dialogue: 0,0:15:43.85,0:15:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:45.48,0:15:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengatakan hal gila seperti itu…
Dialogue: 0,0:15:48.90,0:15:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:16:12.17,0:16:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:16:14.93,0:16:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur.
Dialogue: 0,0:16:18.81,0:16:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku benci ini. Ini yang terburuk!{\i0}
Dialogue: 0,0:16:22.27,0:16:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Kenapa aku bisa sepayah ini?{\i0}
Dialogue: 0,0:16:24.40,0:16:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Hanya ini yang terpikirkan olehku?{\i0}
Dialogue: 0,0:16:27.52,0:16:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku sampai ingin menangis.{\i0}
Dialogue: 0,0:16:30.11,0:16:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Gadis-gadis itu pasti muak melihatku.{\i0}
Dialogue: 0,0:16:33.86,0:16:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka mungkin tertawa.{\i0}
Dialogue: 0,0:16:35.53,0:16:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dari luar, aku pasti terlihat konyol.{\i0}
Dialogue: 0,0:16:39.45,0:16:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Membayangkan diriku sendiri saja,{\i0}
Dialogue: 0,0:16:41.91,0:16:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku juga berpikir ini konyol.{\i0}
Dialogue: 0,0:16:44.67,0:16:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Guru juga pasti kecewa.{\i0}
Dialogue: 0,0:16:51.13,0:16:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada yang tertawa.{\i0}
Dialogue: 0,0:16:53.22,0:16:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Tidak seorang pun tampak muak\Natau tertawa.{\i0}
Dialogue: 0,0:16:55.97,0:16:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada yang mengejekku.{\i0}
Dialogue: 0,0:16:58.47,0:17:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini hanya ada dalam pikiranku.{\i0}
Dialogue: 0,0:17:03.48,0:17:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cari cara untuk melakukannya, ya?{\i0}
Dialogue: 0,0:17:06.85,0:17:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Begitu.{\i0}
Dialogue: 0,0:17:08.48,0:17:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Satu-satunya yang mengutuk\Ndan berkata aku tak bisa{\i0}
Dialogue: 0,0:17:12.61,0:17:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah diriku yang kulihat di cermin.{\i0}
Dialogue: 0,0:17:18.74,0:17:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Cermin…
Dialogue: 0,0:17:22.66,0:17:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini.
Dialogue: 0,0:17:24.25,0:17:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, di sini.
Dialogue: 0,0:17:26.79,0:17:29.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel di Jubah Cermin Peminjam Bayangan…
Dialogue: 0,0:17:30.09,0:17:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan cermin,
Dialogue: 0,0:17:31.75,0:17:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi panah untuk menyembunyikan\Ndan memantulkan.
Dialogue: 0,0:17:34.01,0:17:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemakainya disembunyikan\Ndengan mengubahnya menjadi "bayangan".
Dialogue: 0,0:17:37.38,0:17:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu memproyeksikan hewan raksasa\Nyang dipantulkan di sisik.
Dialogue: 0,0:17:42.77,0:17:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:17:44.27,0:17:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak lapisan mantra yang terjalin.
Dialogue: 0,0:17:47.23,0:17:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau begitu, mungkin aku bisa…
Dialogue: 0,0:18:09.96,0:18:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:18:12.17,0:18:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini?
Dialogue: 0,0:18:14.17,0:18:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap di sana.
Dialogue: 0,0:18:15.63,0:18:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuat Dinding Angin.
Dialogue: 0,0:18:18.80,0:18:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini jebakan Romonon\Natau mantra kuno tak dikenal?
Dialogue: 0,0:18:22.55,0:18:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja!
Dialogue: 0,0:18:25.14,0:18:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah sihirku.
Dialogue: 0,0:18:27.94,0:18:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini!
Dialogue: 0,0:18:33.94,0:18:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau!
Dialogue: 0,0:18:36.28,0:18:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan pada jubahnya?
Dialogue: 0,0:18:39.28,0:18:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku di dalam,
Dialogue: 0,0:18:40.78,0:18:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku melihat segel\Ndi Jubah Cermin Peminjam Bayangan.
Dialogue: 0,0:18:43.70,0:18:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, aku menghapus bagian "cermin"{\i0}
Dialogue: 0,0:18:46.04,0:18:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan mengubahnya jadi jubah\Nyang hanya "meminjam bayangan".{\i0}
Dialogue: 0,0:18:49.46,0:18:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku bisa tetap bersembunyi\Ndalam kegelapan dan menggambar.
Dialogue: 0,0:18:53.46,0:18:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Myrphon juga tak akan melihatku.
Dialogue: 0,0:18:55.88,0:18:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang lebih sulit membawanya,
Dialogue: 0,0:18:57.97,0:19:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku punya mantra suara\Nyang meniru seruan mereka.
Dialogue: 0,0:19:00.59,0:19:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal mereka tak tahu aku manusia, bukan?
Dialogue: 0,0:19:03.47,0:19:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, secara teknis.
Dialogue: 0,0:19:05.76,0:19:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau aku bisa menyembunyikan diri,\Naku akan sendirian.
Dialogue: 0,0:19:08.52,0:19:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku bisa fokus.\NTidak perlu takut dilihat orang.
Dialogue: 0,0:19:11.60,0:19:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku bisa menggambar\Ndengan cara ini.
Dialogue: 0,0:19:29.71,0:19:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu menggunakan cara ini\Nmemang agak memalukan,
Dialogue: 0,0:19:33.58,0:19:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mungkin…
Dialogue: 0,0:19:37.30,0:19:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}inilah diriku.
Dialogue: 0,0:19:45.85,0:19:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sudah tak membenci dirimu lagi?
Dialogue: 0,0:19:49.77,0:19:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya…
Dialogue: 0,0:19:51.48,0:19:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terlalu.
Dialogue: 0,0:19:55.36,0:19:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, jangan langsung menyerah.
Dialogue: 0,0:19:58.28,0:20:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih punya kesempatan, Euini.
Dialogue: 0,0:20:00.49,0:20:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin masih mudah menyerah.
Dialogue: 0,0:20:02.57,0:20:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku akan berusaha\Ntidak berhenti di situ.
Dialogue: 0,0:20:07.49,0:20:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:20:11.58,0:20:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Richeh.
Dialogue: 0,0:20:15.96,0:20:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau bisa peduli\Npada orang lain juga, ya?
Dialogue: 0,0:20:19.13,0:20:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini sudah membantuku di awal.
Dialogue: 0,0:20:22.38,0:20:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kami impas.
Dialogue: 0,0:20:24.47,0:20:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:20:26.68,0:20:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin melakukan sesuatu, tapi tak bisa…
Dialogue: 0,0:20:30.72,0:20:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu rasanya.
Dialogue: 0,0:20:33.89,0:20:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja kau membenci\Nversi dirimu yang itu.
Dialogue: 0,0:20:37.52,0:20:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kau bisa berkembang.
Dialogue: 0,0:20:40.94,0:20:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melebihi diriku yang sekarang.
Dialogue: 0,0:20:43.61,0:20:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin aku mencintai diriku\Nyang belum dewasa.
Dialogue: 0,0:20:50.37,0:20:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan ujian adalah\Nagar kau mengenal dirimu.
Dialogue: 0,0:20:53.54,0:20:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalannya mungkin satu, tapi semua orang\Nmenggambar sihir yang berbeda.
Dialogue: 0,0:20:58.38,0:21:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap orang harus menemukan jalannya\Ndan memutuskan cara mereka menjalaninya.
Dialogue: 0,0:21:04.42,0:21:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kau terus mengulang prosesnya.
Dialogue: 0,0:21:06.72,0:21:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat? Ujian tidak terlalu buruk, bukan?
Dialogue: 0,0:21:13.77,0:21:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:21:16.02,0:21:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Guru Qifrey menjebakku\Nagar mengikuti ujian.
Dialogue: 0,0:21:18.73,0:21:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku tak akan memaafkannya\Nsampai dia minta maaf.
Dialogue: 0,0:21:21.36,0:21:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dia sudah punya satu poin Amarah Richeh.
Dialogue: 0,0:21:24.36,0:21:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Poin Amarah Richeh?
Dialogue: 0,0:21:27.03,0:21:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, bicara soal Qifrey,
Dialogue: 0,0:21:31.03,0:21:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah dia agak…
Dialogue: 0,0:21:37.33,0:21:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Alaira!
Dialogue: 0,0:21:39.33,0:21:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Bertopeng?
Dialogue: 0,0:21:43.21,0:21:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Bertopeng?
Dialogue: 0,0:21:49.26,0:21:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Anak-Anak! Jangan dengarkan\Nkata-kata Penyihir Bertopeng!
Dialogue: 0,0:21:52.64,0:21:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan mereka menipu kalian!\NLarilah secepat mungkin!
Dialogue: 0,0:21:56.31,0:21:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir terlarang adalah…
Dialogue: 0,0:22:02.73,0:22:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Alaira…
Dialogue: 0,0:23:39.00,0:23:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana
