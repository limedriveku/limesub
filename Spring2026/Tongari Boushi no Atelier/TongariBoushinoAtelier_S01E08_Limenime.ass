Dialogue: 0,0:04:29.01,0:04:31.22,tanda,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:05:50.55,0:05:54.35,tanda,,0000,0000,0000,,{\an8}DALAM KECURIGAAN KSATRIA MORALIS
Dialogue: 0,0:23:36.79,0:23:38.99,tanda,,0000,0000,0000,,EPISODE 9\NMIMPI BURUK DALAM KEGELAPAN
Dialogue: 0,0:00:07.67,0:00:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu takut.
Dialogue: 0,0:00:10.88,0:00:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ingatan tentang sihir hilang,\Nrasa takutnya pun akan sirna.
Dialogue: 0,0:00:16.59,0:00:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya akan menjadi orang luar.
Dialogue: 0,0:00:19.35,0:00:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan ulah kami, kataku!
Dialogue: 0,0:00:21.39,0:00:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak mendengarkan?
Dialogue: 0,0:00:24.14,0:00:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan. Aku mohon, jangan.
Dialogue: 0,0:00:44.16,0:00:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:00:45.54,0:00:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ranjang Pasir Ular?
Dialogue: 0,0:00:47.88,0:00:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mencoba menjelaskan,
Dialogue: 0,0:00:50.38,0:00:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau tak mendengarkan. Jahat!
Dialogue: 0,0:00:53.42,0:00:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa mereka?
Dialogue: 0,0:00:55.22,0:00:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka anak-anak.
Dialogue: 0,0:00:56.97,0:00:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka membakar panjinya.
Dialogue: 0,0:01:00.68,0:01:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:01:02.47,0:01:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang dewasa yang memperlakukan anak-anak\Nsebagai semacam spesies…
Dialogue: 0,0:01:07.48,0:01:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci itu.
Dialogue: 0,0:01:08.73,0:01:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan situasinya yang penting,
Dialogue: 0,0:01:12.07,0:01:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi fakta bahwa aturan telah dilanggar.
Dialogue: 0,0:01:15.82,0:01:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketertiban dan kedamaian dunia ini
Dialogue: 0,0:01:18.16,0:01:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa ditegakkan hanya karena\Nsetiap penyihir mematuhi kode etik.
Dialogue: 0,0:01:24.00,0:01:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu retakan saja bisa menghancurkannya.
Dialogue: 0,0:01:26.75,0:01:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, tidak boleh ada pengecualian.
Dialogue: 0,0:01:30.75,0:01:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menolak mendengarkan anak-anak,
Dialogue: 0,0:01:33.25,0:01:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau sendiri banyak bicara.
Dialogue: 0,0:01:38.26,0:01:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh murid-muridku, Easthies.
Dialogue: 0,0:01:43.01,0:01:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:01:44.47,0:01:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka muridmu.
Dialogue: 0,0:01:47.14,0:01:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak heran, kesombongan mereka\Nsetara dengan gurunya.
Dialogue: 0,0:01:51.40,0:01:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau murid teladan itu sepertimu,\Naku menolak.
Dialogue: 0,0:01:55.65,0:01:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi kalau ini yang dianggap tugas\Noleh Ksatria Moralis.
Dialogue: 0,0:02:01.16,0:02:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya ingin melindungi ketertiban.
Dialogue: 0,0:02:05.70,0:02:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sihir yang cukup kuat\Nuntuk membentuk ulang daratan,{\i0}
Dialogue: 0,0:02:09.21,0:02:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}seperti Pegunungan Dadah\Ndan Hutan Thristas,{\i0}
Dialogue: 0,0:02:12.17,0:02:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah sihir perang\Nsebelum Hari Perjanjian.{\i0}
Dialogue: 0,0:02:16.34,0:02:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sihir seperti itu\Ndigunakan pada era ini,
Dialogue: 0,0:02:19.47,0:02:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentu saja itu harus ditangani.
Dialogue: 0,0:02:22.68,0:02:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja,
Dialogue: 0,0:02:24.10,0:02:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak adil menghapus ingatan\Ntanpa mendengar alasannya.
Dialogue: 0,0:02:27.98,0:02:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:02:29.19,0:02:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak ingat pernah membekali mereka\Nketerampilan atau alat
Dialogue: 0,0:02:32.77,0:02:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk sihir berskala sebesar ini.
Dialogue: 0,0:02:36.07,0:02:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bukan darimu,
Dialogue: 0,0:02:37.82,0:02:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi itu mungkin ulah Penyihir Bertopeng.
Dialogue: 0,0:02:45.70,0:02:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian!
Dialogue: 0,0:02:47.83,0:02:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bisa berdebat sesuka hati,
Dialogue: 0,0:02:50.29,0:02:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi apa kalian lupa\Ntugas kalian sebagai penyihir?
Dialogue: 0,0:02:53.71,0:02:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Menyebarkan berkah sihir\Nkepada semua orang."
Dialogue: 0,0:02:56.71,0:02:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak itu lebih paham soal itu\Ndaripada kalian.
Dialogue: 0,0:03:02.47,0:03:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berdiri saja.\NKalian juga bantu mereka.
Dialogue: 0,0:03:05.64,0:03:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian punya panji serbaguna itu, bukan?
Dialogue: 0,0:03:16.19,0:03:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu akan menyembuhkannya?
Dialogue: 0,0:03:18.57,0:03:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku hanya menghentikan pendarahan.
Dialogue: 0,0:03:21.11,0:03:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawanya ke Kalhn.
Dialogue: 0,0:03:23.36,0:03:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau segera menemui dokter,\Nnyawanya bisa sela…
Dialogue: 0,0:03:26.33,0:03:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihatnya.\NKau memperbaiki panji itu dengan sihir!
Dialogue: 0,0:03:31.87,0:03:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menyembuhkannya, bukan?
Dialogue: 0,0:03:34.17,0:03:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir seharusnya punya kemampuan itu!
Dialogue: 0,0:03:38.80,0:03:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu tidak benar.
Dialogue: 0,0:03:41.59,0:03:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:03:43.43,0:03:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak mungkin!
Dialogue: 0,0:03:44.55,0:03:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan aku.
Dialogue: 0,0:03:49.47,0:03:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau aku tak perlu membawanya?
Dialogue: 0,0:03:57.32,0:03:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:00.07,0:04:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong rawat dia.
Dialogue: 0,0:04:04.82,0:04:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel area ini.
Dialogue: 0,0:04:06.07,0:04:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya penyihir yang boleh masuk.
Dialogue: 0,0:04:09.83,0:04:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu para orang luar itu pergi,
Dialogue: 0,0:04:13.00,0:04:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita lakukan penyelidikan menyeluruh.
Dialogue: 0,0:05:58.90,0:06:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sihir dasar yang fundamental.
Dialogue: 0,0:06:02.15,0:06:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak cukup untuk membuat\Nseluruh tepi sungai longsor.
Dialogue: 0,0:06:05.61,0:06:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:09.36,0:06:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan tanganmu.
Dialogue: 0,0:06:12.62,0:06:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Bertopeng kadang menggambar segel\Ndi tubuh mereka sebagai tato.
Dialogue: 0,0:06:17.91,0:06:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sihir terlarang yang meningkatkan
Dialogue: 0,0:06:20.54,0:06:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}atau mengubah tubuh\Nguna memperkuat kekuatan sihir.
Dialogue: 0,0:06:26.59,0:06:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapalannya masih baru\Ndan tangan yang masih ternoda tinta sihir.
Dialogue: 0,0:06:38.06,0:06:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, bukan?
Dialogue: 0,0:06:44.86,0:06:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan memulai penyelidikan\Nsetelah melapor ke Aula Besar.
Dialogue: 0,0:06:49.74,0:06:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ternyata memang kalian penyebabnya,
Dialogue: 0,0:06:53.12,0:06:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tak akan memberi ampun.
Dialogue: 0,0:06:55.20,0:06:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ingat apa yang baru kau pelajari.
Dialogue: 0,0:06:57.33,0:06:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sebaiknya, kau berhati-hati.
Dialogue: 0,0:07:08.80,0:07:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu menegangkan.
Dialogue: 0,0:07:10.47,0:07:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang semuanya baik-baik saja.
Dialogue: 0,0:07:16.31,0:07:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang dewasa\Nseharusnya tidak meninggalkan kalian.
Dialogue: 0,0:07:19.68,0:07:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:07:21.02,0:07:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru sama sekali tidak salah.
Dialogue: 0,0:07:23.48,0:07:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, Agatha dan Coco,
Dialogue: 0,0:07:28.28,0:07:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin kalian mengerti\Nbetapa berbahayanya itu.
Dialogue: 0,0:07:32.20,0:07:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada yang mengetahui rahasia sihir,
Dialogue: 0,0:07:35.74,0:07:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus menghapus ingatan\Nsemua orang yang kita bantu.
Dialogue: 0,0:07:40.58,0:07:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatan seseorang adalah hidupnya.
Dialogue: 0,0:07:43.17,0:07:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertimbangkan hal itu\Nsebelum kalian bertindak.
Dialogue: 0,0:07:46.75,0:07:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami minta maaf.
Dialogue: 0,0:07:48.25,0:07:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan lebih berhati-hati.
Dialogue: 0,0:07:50.88,0:07:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kejadian ini{\i0}
Dialogue: 0,0:07:52.80,0:07:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mungkin akan menunda ujianku.{\i0}
Dialogue: 0,0:07:55.89,0:07:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalian berhasil.
Dialogue: 0,0:07:58.56,0:07:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:07:59.89,0:08:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan mengajukan permohonan\Nujian tahap kedua untukmu, Agott.
Dialogue: 0,0:08:05.31,0:08:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lulus,
Dialogue: 0,0:08:06.40,0:08:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan diakui layak\Nuntuk ikut kerja lapangan sungguhan.
Dialogue: 0,0:08:11.57,0:08:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berjanji akan menyembunyikan sihirmu\Nsampai waktunya tiba?
Dialogue: 0,0:08:16.95,0:08:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:18.16,0:08:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Hanya Agott?
Dialogue: 0,0:08:20.62,0:08:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru! Bagaimana dengan kami?
Dialogue: 0,0:08:23.16,0:08:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian belum selesai menggambar\Nseluruh buku teks sihir dasar, bukan?
Dialogue: 0,0:08:28.75,0:08:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak suka ujian, jadi aku tak peduli.
Dialogue: 0,0:08:31.51,0:08:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada ujian lain?
Dialogue: 0,0:08:34.97,0:08:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Qifrey.
Dialogue: 0,0:08:37.26,0:08:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:08:38.51,0:08:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tadi kau cemas\Nkarena Agott terburu-buru?
Dialogue: 0,0:08:41.39,0:08:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:42.31,0:08:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:08:45.35,0:08:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah tidak lagi.
Dialogue: 0,0:08:48.31,0:08:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, menurutku, aku harus percaya\Nkepada mereka.
Dialogue: 0,0:08:52.82,0:08:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu lembek.
Dialogue: 0,0:08:54.28,0:08:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah kalau punya murid\Nyang keras terhadap dirinya.
Dialogue: 0,0:08:58.82,0:09:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey,
Dialogue: 0,0:09:01.04,0:09:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin segera pulang dan berlatih.
Dialogue: 0,0:09:03.45,0:09:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:09:10.67,0:09:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu hal lagi yang harus kita lakukan.
Dialogue: 0,0:09:14.34,0:09:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu murid baru Qifrey, bukan?
Dialogue: 0,0:09:18.01,0:09:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau rumor itu benar…
Dialogue: 0,0:09:21.10,0:09:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa membuktikan rumor itu?
Dialogue: 0,0:09:24.35,0:09:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:09:25.56,0:09:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa menemukan bukti\Ndi rumah yang membatu itu.
Dialogue: 0,0:09:30.11,0:09:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita harus\Nmembuatnya mengaku. Lihat.
Dialogue: 0,0:09:35.28,0:09:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sihir itu,\Nsungai di hilir mulai mengering.
Dialogue: 0,0:09:39.74,0:09:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu batu jatuh bisa mengakibatkan longsor\Ndi tepi sungai, mengubah arus,
Dialogue: 0,0:09:43.41,0:09:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memaksa semua\Nyang ada di hilir berubah.
Dialogue: 0,0:09:46.62,0:09:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam sekejap, lanskap yang tadinya indah
Dialogue: 0,0:09:49.71,0:09:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hilang untuk selamanya.
Dialogue: 0,0:09:54.55,0:09:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gadis itu adalah batu pertama yang jatuh.{\i0}
Dialogue: 0,0:09:57.47,0:10:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia akan memicunya jika ada kesempatan,{\i0}
Dialogue: 0,0:10:00.01,0:10:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bagaimanapun juga, dia harus disingkirkan.{\i0}
Dialogue: 0,0:10:07.14,0:10:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pena Olruggio itu istimewa.
Dialogue: 0,0:10:09.90,0:10:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Pena Jarum Api.
Dialogue: 0,0:10:11.98,0:10:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa mengukir segel\Nbaik di batu maupun kayu.
Dialogue: 0,0:10:17.07,0:10:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini perbaikan sementara.
Dialogue: 0,0:10:34.80,0:10:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air sungainya mulai mengalir lagi.
Dialogue: 0,0:10:37.38,0:10:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, mantra debu pasir\Nmulai memudar.
Dialogue: 0,0:10:46.68,0:10:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:10:53.27,0:10:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, ada yang terjatuh.
Dialogue: 0,0:10:56.28,0:10:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:10:57.65,0:11:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa topi dan tinta sihirmu.
Dialogue: 0,0:11:02.41,0:11:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Terima kasih.
Dialogue: 0,0:11:08.54,0:11:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aneh.
Dialogue: 0,0:11:12.21,0:11:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinta sihirku tak berkurang sama sekali!
Dialogue: 0,0:11:16.96,0:11:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa botol ini dibubuhi sihir?
Dialogue: 0,0:11:19.13,0:11:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini terus mengisi ulang sendiri?
Dialogue: 0,0:11:21.18,0:11:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco, boleh aku melihatnya sebentar?
Dialogue: 0,0:11:24.89,0:11:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Guru?
Dialogue: 0,0:11:38.44,0:11:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir adalah "kebohongan"\Nyang mewarnai dunia.
Dialogue: 0,0:11:43.99,0:11:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tangan yang melukis sihir indah itu
Dialogue: 0,0:11:46.99,0:11:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternoda tinta seperti ini.
Dialogue: 0,0:11:52.87,0:11:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebohongan…
Dialogue: 0,0:11:56.63,0:11:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan hancur jika dilihat dari dekat.
Dialogue: 0,0:12:08.31,0:12:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa lama kau bisa menyembunyikannya?
Dialogue: 0,0:12:16.02,0:12:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinta ini…
Dialogue: 0,0:12:18.82,0:12:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau dapat dari Pak Nolnoa di Kalhn, bukan?
Dialogue: 0,0:12:21.57,0:12:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:28.74,0:12:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Olruggio.
Dialogue: 0,0:12:29.87,0:12:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bawa anak-anak kembali ke sanggar dulu.
Dialogue: 0,0:12:33.91,0:12:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ke mana?
Dialogue: 0,0:12:36.17,0:12:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:12:39.13,0:12:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum sempat membelikan pena\Nuntuk Coco tempo hari.
Dialogue: 0,0:12:43.17,0:12:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya dekat,\Njadi aku akan mampir ke Kalhn dulu.
Dialogue: 0,0:12:46.34,0:12:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku mau anggur nektar perak.
Dialogue: 0,0:12:49.05,0:12:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu perasan pertama\Ndan satu simpanan lama.
Dialogue: 0,0:12:51.52,0:12:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik. Serahkan kepadaku.
Dialogue: 0,0:12:54.06,0:12:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maaf, ya?\N- Apa?
Dialogue: 0,0:12:58.23,0:13:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada sesuatu yang harus kupastikan.{\i0}
Dialogue: 0,0:13:08.12,0:13:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Pintunya menghilang.
Dialogue: 0,0:13:12.54,0:13:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:13:14.37,0:13:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, tokonya tutup.
Dialogue: 0,0:13:16.46,0:13:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa saat tutup\Nseluruh tokonya menghilang?
Dialogue: 0,0:13:23.05,0:13:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Qifrey!
Dialogue: 0,0:13:25.67,0:13:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan gadis tempo hari.
Dialogue: 0,0:13:28.14,0:13:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tartah.
Dialogue: 0,0:13:29.68,0:13:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:13:30.72,0:13:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menemui Pak Nolnoa.
Dialogue: 0,0:13:32.64,0:13:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu. Tunggu sebentar.
Dialogue: 0,0:13:52.74,0:13:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari, silakan masuk.
Dialogue: 0,0:14:01.50,0:14:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruangan ini berbeda dari yang tempo hari.
Dialogue: 0,0:14:05.59,0:14:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja. Ruangan berubah\Ntergantung gagang pintunya.
Dialogue: 0,0:14:10.18,0:14:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek mungkin di lantai tiga.
Dialogue: 0,0:14:12.68,0:14:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih. Maaf mengganggu.
Dialogue: 0,0:14:18.19,0:14:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu.
Dialogue: 0,0:14:19.81,0:14:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, namamu…
Dialogue: 0,0:14:23.32,0:14:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:14:24.73,0:14:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Coco.
Dialogue: 0,0:14:25.94,0:14:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:14:26.94,0:14:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka di kaki kananmu itu\Nsebaiknya segera dibersihkan.
Dialogue: 0,0:14:31.45,0:14:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, lewat sini.
Dialogue: 0,0:14:32.95,0:14:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya daun penenang. Biar kuobati.
Dialogue: 0,0:14:43.84,0:14:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada banyak alat yang tak kuketahui.{\i0}
Dialogue: 0,0:14:52.26,0:14:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik sekali.
Dialogue: 0,0:14:54.26,0:14:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubuk berwarna-warni ini apa?
Dialogue: 0,0:14:56.72,0:14:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan asal menyentuh barang-barang.
Dialogue: 0,0:14:58.98,0:15:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Repot kalau sampai berantakan.
Dialogue: 0,0:15:02.15,0:15:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pewarna sihir.
Dialogue: 0,0:15:04.27,0:15:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bahan tambahan\Nuntuk meningkatkan efek tinta sihir.
Dialogue: 0,0:15:10.03,0:15:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Nolnoa.
Dialogue: 0,0:15:11.91,0:15:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey.
Dialogue: 0,0:15:13.41,0:15:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko tutup hari ini.
Dialogue: 0,0:15:15.41,0:15:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:16.95,0:15:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:15:19.16,0:15:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bercanda.
Dialogue: 0,0:15:20.71,0:15:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu alasanmu ke sini.
Dialogue: 0,0:15:24.59,0:15:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tentang segel yang digambar\Ndi ubin gang, bukan?
Dialogue: 0,0:15:29.30,0:15:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum menemukan apa pun.
Dialogue: 0,0:15:32.34,0:15:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencoba mantra\Nuntuk memisahkan pewarna sihir,
Dialogue: 0,0:15:36.47,0:15:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi semuanya tercampur\Ndengan sangat baik.
Dialogue: 0,0:15:39.89,0:15:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sudah menemukan sesuatu?
Dialogue: 0,0:15:43.06,0:15:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku menemukan sesuatu.
Dialogue: 0,0:15:59.45,0:16:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tinta yang serupa.
Dialogue: 0,0:16:01.83,0:16:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, rona kebiruan tipisnya pun\Npersis sama.
Dialogue: 0,0:16:07.29,0:16:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana kau mendapatkan ini?
Dialogue: 0,0:16:12.05,0:16:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:16:13.84,0:16:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini botolku?
Dialogue: 0,0:16:17.10,0:16:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hari itu.{\i0}
Dialogue: 0,0:16:19.35,0:16:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penyihir Bertopeng itu\Npasti menggambar mantranya waktu itu.{\i0}
Dialogue: 0,0:16:25.19,0:16:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:16:27.44,0:16:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Periksa dulu tintanya sebelum menggambar.
Dialogue: 0,0:16:31.74,0:16:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey!
Dialogue: 0,0:16:35.28,0:16:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa nama pewarna pirus muda itu?
Dialogue: 0,0:16:40.08,0:16:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang besar di dekat langit-langit!
Dialogue: 0,0:16:42.58,0:16:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bubuk bunga bulan Azure.
Dialogue: 0,0:16:45.29,0:16:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan bubuk itu,\Nsihirmu akan bertahan lebih lama.
Dialogue: 0,0:16:50.34,0:16:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau botol kecil di rak seberangnya?
Dialogue: 0,0:16:53.09,0:16:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubuk putih yang berkilau itu?
Dialogue: 0,0:16:55.72,0:16:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bubuk sisik kupu-kupu pengantin.
Dialogue: 0,0:16:57.85,0:17:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan itu, tinta menjadi transparan
Dialogue: 0,0:17:00.68,0:17:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bisa menyembunyikan segelmu.
Dialogue: 0,0:17:02.85,0:17:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang di sebelahnya?
Dialogue: 0,0:17:04.64,0:17:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Botol tinggi ramping itu\Nbubuk kerang kelana.
Dialogue: 0,0:17:07.86,0:17:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bulat di sebelahnya\Nbubuk sisik naga api emas.
Dialogue: 0,0:17:15.95,0:17:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:17:17.99,0:17:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali, Tartah!
Dialogue: 0,0:17:20.49,0:17:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau hafal semua nama pewarna ini?
Dialogue: 0,0:17:24.08,0:17:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua itu produk kami.
Dialogue: 0,0:17:26.33,0:17:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau beruntung bisa tinggal\Ndi toko alat tulis sihir!
Dialogue: 0,0:17:29.75,0:17:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Melihat semua rak dan botol berjajar\Nmemenuhi dinding membuatku semangat!
Dialogue: 0,0:17:35.09,0:17:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iri padamu, Tartah!
Dialogue: 0,0:17:39.76,0:17:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sanggar jelas lebih baik.
Dialogue: 0,0:17:43.18,0:17:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seorang penyihir.\NAneh mendengarmu berkata begitu.
Dialogue: 0,0:17:47.10,0:17:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau juga murid, Tartah?
Dialogue: 0,0:17:51.61,0:17:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:17:56.28,0:17:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa nama bubuk merah itu?
Dialogue: 0,0:17:59.16,0:18:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mana?
Dialogue: 0,0:18:01.33,0:18:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu! Di rak itu!
Dialogue: 0,0:18:08.17,0:18:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ada di antara pirus muda\Ndan warna daun layu!
Dialogue: 0,0:18:11.42,0:18:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rak dan baris yang mana?
Dialogue: 0,0:18:17.17,0:18:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warnanya merah pekat. Pasti terlihat.
Dialogue: 0,0:18:29.56,0:18:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya apa itu tadi?
Dialogue: 0,0:18:32.06,0:18:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin kaget saja.
Dialogue: 0,0:18:34.40,0:18:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:18:39.91,0:18:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung botol-botolnya tidak pecah.
Dialogue: 0,0:18:46.79,0:18:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini buruk.
Dialogue: 0,0:18:48.83,0:18:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat buruk.
Dialogue: 0,0:18:51.46,0:18:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Labelnya terlepas.
Dialogue: 0,0:18:53.00,0:18:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya tercampur.
Dialogue: 0,0:18:55.25,0:18:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek melarangku menyentuhnya.
Dialogue: 0,0:18:58.55,0:18:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berantakan.
Dialogue: 0,0:18:59.88,0:19:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Aku akan membantu.\NMari kita kembalikan semuanya.
Dialogue: 0,0:19:04.14,0:19:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu ini bubuk apa?
Dialogue: 0,0:19:08.39,0:19:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna apa untuk bahan…
Dialogue: 0,0:19:09.89,0:19:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu!
Dialogue: 0,0:19:13.11,0:19:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tadi…
Dialogue: 0,0:19:14.77,0:19:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya menghafal nama dari letaknya,
Dialogue: 0,0:19:18.28,0:19:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan mengenalinya dari warna.
Dialogue: 0,0:19:28.12,0:19:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:19:29.75,0:19:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang saja sana.
Dialogue: 0,0:19:31.92,0:19:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:19:35.29,0:19:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf,
Dialogue: 0,0:19:38.13,0:19:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau tak bisa membantu, Coco.
Dialogue: 0,0:19:41.97,0:19:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal yang bisa dilakukan\Ndan ada yang tidak.
Dialogue: 0,0:19:45.89,0:19:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan penyakit selaput perak ini,
Dialogue: 0,0:19:48.39,0:19:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski aku giat belajar,\Naku tak akan bisa menjadi penyihir.
Dialogue: 0,0:19:56.57,0:19:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat? Apa kataku?
Dialogue: 0,0:19:59.99,0:20:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja, Qifrey?
Dialogue: 0,0:20:04.82,0:20:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey!
Dialogue: 0,0:20:07.45,0:20:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan sebesar itu\Ndari segel sekecil itu?
Dialogue: 0,0:20:13.46,0:20:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, ini adalah\Nmantra Botol Kembar.
Dialogue: 0,0:20:18.09,0:20:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dua wadah yang berbagi satu isi.{\i0}
Dialogue: 0,0:20:21.22,0:20:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin ada medali kecil\Ndengan segel terukir di dalamnya.{\i0}
Dialogue: 0,0:20:26.35,0:20:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Coco dipaksa menggunakan ini.{\i0}
Dialogue: 0,0:20:29.60,0:20:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tinta terus terisi{\i0}
Dialogue: 0,0:20:31.39,0:20:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan bahan tambahan tidak dikenal.{\i0}
Dialogue: 0,0:20:34.27,0:20:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Botol ini terhubung dengan mereka.{\i0}
Dialogue: 0,0:20:39.48,0:20:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya,
Dialogue: 0,0:20:41.69,0:20:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menemukan mereka.
Dialogue: 0,0:20:43.90,0:20:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:20:46.03,0:20:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinta sihir yang bisa menghasilkan
Dialogue: 0,0:20:48.12,0:20:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatan besar\Ndari lingkaran kecil berantakan itu?
Dialogue: 0,0:20:52.91,0:20:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti itu\Ntak boleh ada di dunia ini.
Dialogue: 0,0:20:56.67,0:20:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di luar kemampuanku.
Dialogue: 0,0:20:59.96,0:21:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus lapor ke Aula Besar…
Dialogue: 0,0:21:01.92,0:21:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:21:03.72,0:21:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan serahkan ini ke Ksatria Moralis\Nataupun Aula Besar.
Dialogue: 0,0:21:07.84,0:21:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik tak ada yang tahu\Nkita menemukan tinta ini.
Dialogue: 0,0:21:12.43,0:21:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey.
Dialogue: 0,0:21:15.31,0:21:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:21:18.36,0:21:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:21:20.23,0:21:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sadar dengan ucapanmu sendiri?
Dialogue: 0,0:21:24.70,0:21:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rencanakan?
Dialogue: 0,0:21:26.66,0:21:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rencanamu dengan tinta itu?
Dialogue: 0,0:21:31.79,0:21:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Pak Nolnoa.
Dialogue: 0,0:21:43.67,0:21:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:21:46.51,0:21:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu.
Dialogue: 0,0:21:48.01,0:21:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang botol tinta sihir itu,
Dialogue: 0,0:21:51.26,0:21:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tampaknya, dia tak sengaja\Nmemberikan barang berharga.
Dialogue: 0,0:21:55.14,0:21:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membelikan tas untukmu\Nsebagai gantinya.
Dialogue: 0,0:21:59.94,0:22:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:22:15.66,0:22:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru,
Dialogue: 0,0:22:18.17,0:22:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa itu penyakit selaput perak?
Dialogue: 0,0:22:22.09,0:22:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sindrom selaput perak
Dialogue: 0,0:22:23.67,0:22:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}adalah kondisi bawaan medis sejak lahir.{\i0}
Dialogue: 0,0:22:26.17,0:22:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Itu membuat dunia terlihat\Nseperti tertutup perak.{\i0}
Dialogue: 0,0:22:31.68,0:22:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Para penyihir cenderung\Nmengandalkan penglihatan,
Dialogue: 0,0:22:35.06,0:22:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}hal itu bisa merepotkan di dunia ini.
Dialogue: 0,0:22:38.19,0:22:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Terlalu keras pada kondisi khusus
Dialogue: 0,0:22:40.02,0:22:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}adalah salah satu tabiat buruk penyihir.
Dialogue: 0,0:22:45.28,0:22:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Coco.
Dialogue: 0,0:22:49.07,0:22:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pasang wajah cemas begitu.
Dialogue: 0,0:22:52.41,0:22:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:22:54.20,0:22:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kau masih murid sanggarku,
Dialogue: 0,0:22:56.87,0:22:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti akan melindungimu.
Dialogue: 0,0:22:59.62,0:23:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sama sekali tak perlu cemas.
Dialogue: 0,0:23:04.09,0:23:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali.
Dialogue: 0,0:23:08.84,0:23:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kakek.
Dialogue: 0,0:23:10.68,0:23:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Maaf. Cahaya tadi membuatku terkejut,
Dialogue: 0,0:23:14.35,0:23:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}jadi, aku menjatuhkan botol-botol di sini.
Dialogue: 0,0:23:18.06,0:23:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya terang tadi itu apa?
Dialogue: 0,0:23:20.85,0:23:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu sihir Tuan Qifrey?
Dialogue: 0,0:23:24.86,0:23:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Cahaya?
Dialogue: 0,0:23:29.61,0:23:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bercahaya.
Dialogue: 0,0:23:33.20,0:23:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek?
Dialogue: 0,0:23:39.00,0:23:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana
