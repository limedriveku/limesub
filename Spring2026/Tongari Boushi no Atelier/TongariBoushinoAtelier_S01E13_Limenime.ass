Dialogue: 0,0:00:10.05,0:00:12.22,sign,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:02:50.42,0:02:55.46,sign,,0000,0000,0000,,SIHIR TERLARANG
Dialogue: 0,0:01:31.92,0:01:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Kau cepat sekali, Coco!
Dialogue: 0,0:01:38.76,0:01:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang cepat.
Dialogue: 0,0:01:41.05,0:01:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja Agott terbang\Nbegitu cepat waktu itu.
Dialogue: 0,0:01:44.10,0:01:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata karena sepatu sylph buatanmu.
Dialogue: 0,0:01:49.10,0:01:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah apa yang kuberikan kepada Agott?
Dialogue: 0,0:01:51.06,0:01:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:01:52.90,0:01:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia masih menggunakannya,
Dialogue: 0,0:01:54.86,0:01:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pasti suka sihirmu.
Dialogue: 0,0:01:59.03,0:02:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pandai menggambar garis lurus, Coco.
Dialogue: 0,0:02:01.57,0:02:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bisa kau terapkan\Npada sihir lain juga.
Dialogue: 0,0:02:04.08,0:02:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma, Guru. Coco tak mendengarkan.
Dialogue: 0,0:02:06.54,0:02:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hebat…
Dialogue: 0,0:02:09.71,0:02:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey?
Dialogue: 0,0:02:16.01,0:02:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Guru?
Dialogue: 0,0:02:18.38,0:02:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buruk.
Dialogue: 0,0:02:20.39,0:02:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini topi Alaira.
Dialogue: 0,0:02:21.64,0:02:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:22.64,0:02:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi hal yang penting bagi penyihir.
Dialogue: 0,0:02:25.27,0:02:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia sampai mengirimkannya…
Dialogue: 0,0:02:32.56,0:02:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Golem?{\i0}
Dialogue: 0,0:02:34.27,0:02:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mustahil sihir terlarang kuno ini\Nmasih aktif.{\i0}
Dialogue: 0,0:02:37.44,0:02:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini pasti{\i0}
Dialogue: 0,0:02:39.15,0:02:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ulah Penyihir Bertopeng!{\i0}
Dialogue: 0,0:02:42.87,0:02:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey!
Dialogue: 0,0:02:56.55,0:02:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ki… Kita lari?
Dialogue: 0,0:02:59.92,0:03:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi lawan kita
Dialogue: 0,0:03:02.89,0:03:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Bertopeng!
Dialogue: 0,0:03:05.81,0:03:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak mungkin…
Dialogue: 0,0:03:09.68,0:03:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:03:21.95,0:03:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, sungguh mengesankan.
Dialogue: 0,0:03:25.33,0:03:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani bersembunyi dariku.
Dialogue: 0,0:03:29.95,0:03:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari dulu aku suka bermain petak umpet.
Dialogue: 0,0:03:34.00,0:03:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalian di sini.
Dialogue: 0,0:03:47.31,0:03:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:48.85,0:03:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubahku…
Dialogue: 0,0:03:52.19,0:03:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:03:53.10,0:03:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah!
Dialogue: 0,0:03:59.57,0:04:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang bersembunyi dalam kegelapan…
Dialogue: 0,0:04:02.36,0:04:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah penjahat\Nyang menyimpan rahasia kelam?
Dialogue: 0,0:04:06.62,0:04:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang lemah yang bersembunyi\Ndalam ketakutan?
Dialogue: 0,0:04:10.29,0:04:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau pemburu yang mengintai mangsanya?
Dialogue: 0,0:04:14.62,0:04:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau termasuk yang mana?
Dialogue: 0,0:04:20.13,0:04:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghilang?
Dialogue: 0,0:04:21.17,0:04:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu hal yang pasti. Kau bukan pemburu.
Dialogue: 0,0:04:24.84,0:04:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena akulah sang pemburu.
Dialogue: 0,0:04:31.39,0:04:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini!
Dialogue: 0,0:04:34.89,0:04:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:04:36.52,0:04:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Tutup matamu!\N- Richeh…
Dialogue: 0,0:04:40.61,0:04:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini!
Dialogue: 0,0:04:42.53,0:04:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa berdiri?
Dialogue: 0,0:04:44.53,0:04:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh, ayo lari!
Dialogue: 0,0:04:46.03,0:04:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kau tertimpa puing!
Dialogue: 0,0:04:53.04,0:04:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena mantra di gua ini,\Nkami tak bisa terbang untuk kabur.{\i0}
Dialogue: 0,0:04:57.29,0:05:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Memperpanjang jalan batu ini\Ntak akan menambah jarak.{\i0}
Dialogue: 0,0:05:01.00,0:05:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Dia bukan lawan yang bisa kami kelabui.{\i0}
Dialogue: 0,0:05:05.26,0:05:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Nona Alaira pun tak bisa mengalahkannya.{\i0}
Dialogue: 0,0:05:07.80,0:05:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku tak bisa…{\i0}
Dialogue: 0,0:05:17.69,0:05:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:05:19.56,0:05:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott?
Dialogue: 0,0:05:20.94,0:05:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Nona Alaira melewati\Njalan yang terputus itu,
Dialogue: 0,0:05:23.69,0:05:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia membekukan jalan lalu meluncur!
Dialogue: 0,0:05:28.28,0:05:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau kita membekukan seluruh jalan,\Ntak masalah batu mana yang jatuh.
Dialogue: 0,0:05:34.45,0:05:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kita bisa…
Dialogue: 0,0:05:47.13,0:05:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meluncur lebih cepat daripada berlari!
Dialogue: 0,0:05:54.47,0:05:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, Richeh.
Dialogue: 0,0:05:56.02,0:05:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik!
Dialogue: 0,0:05:57.73,0:05:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:06:13.41,0:06:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott! Kenapa sepatu sylph-mu\Nbisa begitu cepat?
Dialogue: 0,0:06:17.04,0:06:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin membahasnya.
Dialogue: 0,0:06:18.87,0:06:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekukan saja jalan di depan!
Dialogue: 0,0:06:21.04,0:06:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:35.14,0:06:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau begini, dia bisa mengejar!
Dialogue: 0,0:06:37.14,0:06:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dorong dengan sihir angin!
Dialogue: 0,0:06:41.81,0:06:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku…
Dialogue: 0,0:06:43.52,0:06:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku tak menguasai banyak sihir\Nselain sihirku sendiri.
Dialogue: 0,0:06:48.19,0:06:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini.
Dialogue: 0,0:06:51.03,0:06:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:52.32,0:06:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menggunakannya.
Dialogue: 0,0:06:55.58,0:06:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku sudah menggambarnya,\Nwalau agak memalukan.
Dialogue: 0,0:07:00.71,0:07:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya aku bisa membantumu.
Dialogue: 0,0:07:22.98,0:07:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Padahal akhirnya bisa ikut ujian ini,\Nbagaimana ini bisa terjadi?{\i0}
Dialogue: 0,0:07:27.48,0:07:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini bisa terjadi?
Dialogue: 0,0:07:31.24,0:07:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat kami melarikan diri dari naga,{\i0}
Dialogue: 0,0:07:33.70,0:07:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tetia mengatakan hal yang sama.{\i0}
Dialogue: 0,0:07:36.74,0:07:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Murid tidak seharusnya\Nmenghadapi bahaya sesering ini.{\i0}
Dialogue: 0,0:07:41.37,0:07:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada alasan Penyihir Bertopeng\Nterus mengejar kami.{\i0}
Dialogue: 0,0:07:45.67,0:07:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi itu bukan kami.{\i0}
Dialogue: 0,0:07:52.68,0:07:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott?
Dialogue: 0,0:07:54.89,0:07:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang kau cari tak ada di sini!
Dialogue: 0,0:07:58.31,0:08:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau tahu Ksatria Moralis\Nsudah dikerahkan?
Dialogue: 0,0:08:01.81,0:08:05.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah dipulangkan\Nsetelah ingatannya dihapus!
Dialogue: 0,0:08:05.69,0:08:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, percuma saja kau mengejar kami!
Dialogue: 0,0:08:10.03,0:08:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak ada orang luar\Ndi sanggar kami!
Dialogue: 0,0:08:18.70,0:08:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi yang bisa ditebak\Ndari murid Penyihir Topi Runcing
Dialogue: 0,0:08:22.62,0:08:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sudah turun-temurun membohongi dunia.
Dialogue: 0,0:08:26.21,0:08:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid pembohong\Npasti jadi pembohong ulung.
Dialogue: 0,0:08:30.63,0:08:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:08:34.34,0:08:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Agott?\N- Agott!
Dialogue: 0,0:08:38.05,0:08:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh menyedihkan.
Dialogue: 0,0:08:40.97,0:08:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di masa lalu,\NPenyihir Topi Runcing adalah penjahat,
Dialogue: 0,0:08:44.35,0:08:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan yang sekarang hanyalah orang lemah\Nyang takut pada kekuatan mereka sendiri.
Dialogue: 0,0:08:49.77,0:08:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Karena itu,
Dialogue: 0,0:08:52.61,0:08:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}kalian terjebak oleh aturan yang kaku,
Dialogue: 0,0:08:54.74,0:08:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}tak mampu mengembangkan\Npotensi penuh kalian.
Dialogue: 0,0:09:02.04,0:09:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma ini…
Dialogue: 0,0:09:03.50,0:09:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinta sihir?
Dialogue: 0,0:09:05.29,0:09:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir terlarang adalah penyelamat.
Dialogue: 0,0:09:07.88,0:09:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak pernah memimpikannya?
Dialogue: 0,0:09:10.63,0:09:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia tempatmu bisa menjadi dewasa\Nkapan pun kau mau
Dialogue: 0,0:09:14.26,0:09:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau tetap menjadi anak-anak selamanya.
Dialogue: 0,0:09:18.26,0:09:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dunia tempatmu bebas menggambar sihir\Ntanpa harus bersembunyi
Dialogue: 0,0:09:21.39,0:09:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}dan bisa menjadi sosok yang kau impikan.
Dialogue: 0,0:09:25.52,0:09:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatmu bisa terbang ke mana pun sesukamu
Dialogue: 0,0:09:29.52,0:09:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa mengandalkan sepatu sylph.
Dialogue: 0,0:09:31.94,0:09:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan dibebaskan\Ndari belenggu jasmani yang membebani.
Dialogue: 0,0:09:37.03,0:09:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari, dunia akan mengingat
Dialogue: 0,0:09:40.20,0:09:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}topi mana yang seharusnya\Ndipakai oleh para penyihir.
Dialogue: 0,0:09:45.91,0:09:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami hanya berusaha{\i0}
Dialogue: 0,0:09:48.92,0:09:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mempercepat kedatangan hari itu.{\i0}
Dialogue: 0,0:09:53.42,0:09:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi hari itu, kami rela\Nmenempuh segala cara.
Dialogue: 0,0:09:57.09,0:09:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:09:59.76,0:10:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Saat seorang teman yang rela berbohong\Ndemi dirinya terluka,{\i0}
Dialogue: 0,0:10:04.81,0:10:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}lalu cara untuk menyelamatkannya\Nada di depan matanya…{\i0}
Dialogue: 0,0:10:08.31,0:10:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Gadis yang menyaksikan\Nkeajaiban sihir itu…{\i0}
Dialogue: 0,0:10:10.90,0:10:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Apa kau yakin dia tak akan tergoda\Nuntuk menggunakannya?{\i0}
Dialogue: 0,0:10:16.03,0:10:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan menghadapi ujian\Nyang mereka hindari,
Dialogue: 0,0:10:18.57,0:10:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak-anak akan belajar dan berkembang.
Dialogue: 0,0:10:21.32,0:10:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah ujianku untuknya.
Dialogue: 0,0:10:26.50,0:10:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan tampaknya kau akan menjadi
Dialogue: 0,0:10:30.33,0:10:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}pelajaran yang berharga.
Dialogue: 0,0:10:38.22,0:10:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penyihir Bertopeng{\i0}
Dialogue: 0,0:10:39.55,0:10:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kadang menggambar segel\Ndi tubuh mereka sebagai tato.{\i0}
Dialogue: 0,0:10:43.68,0:10:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan…
Dialogue: 0,0:10:45.97,0:10:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Aku tidak mau!
Dialogue: 0,0:10:48.23,0:10:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa kehilangan segalanya\Nkarena hal ini!
Dialogue: 0,0:10:52.52,0:10:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku belum membuktikan kepada mereka…{\i0}
Dialogue: 0,0:10:56.48,0:10:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:10:59.07,0:11:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau jatuh, berpeganganlah!
Dialogue: 0,0:11:02.32,0:11:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku jatuh?
Dialogue: 0,0:11:21.55,0:11:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ledakan apa itu tadi?
Dialogue: 0,0:11:23.47,0:11:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini menghancurkan jalan dari bawah.
Dialogue: 0,0:11:26.56,0:11:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau keluar dari jalan ini,\Nkau akan terjebak dalam labirin gua.{\i0}
Dialogue: 0,0:11:30.39,0:11:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, kami memutuskan\Nuntuk menghancurkan jalan di bawahnya.{\i0}
Dialogue: 0,0:11:35.36,0:11:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia…
Dialogue: 0,0:11:37.02,0:11:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Penyihir Bertopeng itu
Dialogue: 0,0:11:39.15,0:11:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak tadi terus melayang.
Dialogue: 0,0:11:43.66,0:11:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sepertinya Agott selamat.{\i0}
Dialogue: 0,0:11:46.33,0:11:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Syukurlah ini bisa berhasil.{\i0}
Dialogue: 0,0:11:51.66,0:11:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak menduga hal yang aku lakukan\Nuntuk menutupi kekuranganku{\i0}
Dialogue: 0,0:11:54.75,0:11:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}akan berguna seperti ini.{\i0}
Dialogue: 0,0:11:56.92,0:11:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku senang sekali.{\i0}
Dialogue: 0,0:11:58.75,0:12:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin aku bisa\Nsedikit lebih percaya diri.{\i0}
Dialogue: 0,0:12:02.55,0:12:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, tolong dengarkan aku.
Dialogue: 0,0:12:04.93,0:12:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin tak sepayah yang aku kira.
Dialogue: 0,0:12:08.93,0:12:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mungkin tak sepayah\Nyang kau kira.
Dialogue: 0,0:12:15.77,0:12:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru mungkin tak mengerti, tapi…
Dialogue: 0,0:12:19.44,0:12:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin tak bisa melakukan\Napa yang orang lain bisa
Dialogue: 0,0:12:21.86,0:12:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kesempatan melakukan\Nyang tak bisa mereka lakukan.
Dialogue: 0,0:12:24.61,0:12:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sekali.
Dialogue: 0,0:12:28.91,0:12:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau memanfaatkan bakat itu\Ndan tetap bersembunyi ketakutan,
Dialogue: 0,0:12:33.00,0:12:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mungkin akan melepaskanmu.
Dialogue: 0,0:12:36.54,0:12:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang yang diselimuti bayangan\Nmembutuhkan kegelapan tertentu,
Dialogue: 0,0:12:39.80,0:12:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kegelapanmu belum seberapa.
Dialogue: 0,0:12:43.42,0:12:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan memberikan wujud
Dialogue: 0,0:12:47.18,0:12:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membuatmu ingin bersembunyi.
Dialogue: 0,0:12:51.56,0:12:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melayang selama ini?
Dialogue: 0,0:12:54.31,0:12:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu aneh sekali.
Dialogue: 0,0:12:56.44,0:12:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau keluar dari jalan ini,
Dialogue: 0,0:12:58.77,0:13:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siapa pun dan sihir apa pun
Dialogue: 0,0:13:00.65,0:13:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan terpengaruh oleh mantra kuno Romonon.
Dialogue: 0,0:13:05.15,0:13:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Penyihir Bertopeng tak terpengaruh,\Ntetap di sini masih berbahaya.
Dialogue: 0,0:13:09.41,0:13:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mencari Euini\Ndan menemui Guru Qifrey sekarang.
Dialogue: 0,0:13:12.91,0:13:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini!
Dialogue: 0,0:13:14.21,0:13:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Euini!
Dialogue: 0,0:13:22.92,0:13:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini?
Dialogue: 0,0:14:07.97,0:14:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Agott…
Dialogue: 0,0:14:10.39,0:14:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Richeh…
Dialogue: 0,0:14:12.30,0:14:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tolong aku…
Dialogue: 0,0:14:17.35,0:14:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:14:19.23,0:14:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghilang…
Dialogue: 0,0:14:52.01,0:14:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Euini…
Dialogue: 0,0:15:00.48,0:15:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh!
Dialogue: 0,0:15:01.69,0:15:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kita lakukan, Agott?\NEuini! Euini…
Dialogue: 0,0:15:04.73,0:15:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:15:09.03,0:15:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh menarik!
Dialogue: 0,0:15:11.36,0:15:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terpengaruh kulit serigala sisik\Nyang digunakan pada jubah itu.
Dialogue: 0,0:15:16.58,0:15:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau!
Dialogue: 0,0:15:17.49,0:15:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak menghilang,\Npenelitian sihir terlarang pun berhenti.
Dialogue: 0,0:15:22.63,0:15:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak yang hanya bisa dipelajari\Njika menggunakannya sendiri.
Dialogue: 0,0:15:26.71,0:15:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang berjalan sesuai rencana,
Dialogue: 0,0:15:29.42,0:15:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hasil ini cukup bagus.
Dialogue: 0,0:15:31.84,0:15:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara begitu!
Dialogue: 0,0:15:33.84,0:15:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan Euini!
Dialogue: 0,0:15:35.76,0:15:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian ingin menyelamatkannya,
Dialogue: 0,0:15:39.48,0:15:42.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan mencobanya.
Dialogue: 0,0:15:42.52,0:15:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir punya kekuatan\Nuntuk mewujudkan keinginan.
Dialogue: 0,0:15:45.77,0:15:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga,\Npilihan ada di tangan kalian.
Dialogue: 0,0:16:03.54,0:16:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ke mana, Richeh?
Dialogue: 0,0:16:06.67,0:16:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah jelas?
Dialogue: 0,0:16:08.09,0:16:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menolong Euini.
Dialogue: 0,0:16:10.84,0:16:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:16:12.30,0:16:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau melakukan\Nhal yang tidak aku suka.
Dialogue: 0,0:16:15.34,0:16:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku lebih tidak mau\Nmeninggalkan teman-temanku.
Dialogue: 0,0:16:19.26,0:16:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott juga begitu, bukan?
Dialogue: 0,0:16:21.31,0:16:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:16:23.31,0:16:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita punya tanggung jawab.
Dialogue: 0,0:16:25.44,0:16:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan myrphon yang ketakutan?
Dialogue: 0,0:16:28.32,0:16:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya menyelesaikan ujian,\Ntapi kita harus mengantarkan mereka.
Dialogue: 0,0:16:33.32,0:16:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, harus ada\Nyang memperingatkan tentang bahaya ini.
Dialogue: 0,0:16:37.07,0:16:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga tentang Nona Alaira dan Euini.
Dialogue: 0,0:16:40.58,0:16:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berpencar.
Dialogue: 0,0:16:42.87,0:16:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengejar Euini.
Dialogue: 0,0:16:44.92,0:16:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bawa myrphon keluar dari sini.
Dialogue: 0,0:16:47.13,0:16:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Aku yang pergi.\NKenapa kau yang memutuskan?
Dialogue: 0,0:16:50.17,0:16:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu lebih banyak mantra.\NAku lebih baik dalam memodifikasinya.
Dialogue: 0,0:16:54.93,0:16:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir yang kau pelajari\Nterlalu dipengaruhi ketertarikanmu.
Dialogue: 0,0:16:59.10,0:17:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak cukup\Nuntuk menghadapi situasi tak terduga.
Dialogue: 0,0:17:02.98,0:17:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mungkin terdengar kejam,
Dialogue: 0,0:17:05.39,0:17:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau yang sekarang\Ntak bisa menolong Euini.
Dialogue: 0,0:18:21.39,0:18:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Kuas…
Dialogue: 0,0:18:50.58,0:18:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang terjadi?{\i0}
Dialogue: 0,0:18:52.75,0:18:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami diserang Gerbang Ular,{\i0}
Dialogue: 0,0:18:55.05,0:18:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lalu tanah di bawah kami amblas.{\i0}
Dialogue: 0,0:18:57.88,0:18:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kemudian…{\i0}
Dialogue: 0,0:18:59.80,0:19:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Guru melindungiku.{\i0}
Dialogue: 0,0:19:04.97,0:19:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey.
Dialogue: 0,0:19:07.22,0:19:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia…
Dialogue: 0,0:19:17.23,0:19:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Guru…{\i0}
Dialogue: 0,0:19:18.82,0:19:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia terluka.{\i0}
Dialogue: 0,0:19:21.28,0:19:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kacamatanya rusak dan dia berdarah.{\i0}
Dialogue: 0,0:19:36.25,0:19:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:19:38.59,0:19:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacamata Guru rusak.\NAku khawatir itu berbahaya…
Dialogue: 0,0:19:43.09,0:19:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:19:52.35,0:19:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu di sini.
Dialogue: 0,0:20:14.58,0:20:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir…
Dialogue: 0,0:20:17.38,0:20:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada penyihir.
Dialogue: 0,0:20:19.84,0:20:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang mengubah kita jadi begini.
Dialogue: 0,0:20:22.84,0:20:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar penyihir terkutuk.
Dialogue: 0,0:20:27.76,0:20:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, mungkinkah mereka…
Dialogue: 0,0:20:30.72,0:20:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:31.98,0:20:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penduduk Romonon
Dialogue: 0,0:20:34.60,0:20:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diubah menjadi emas hidup.
Dialogue: 0,0:20:38.19,0:20:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:20:41.24,0:20:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lukanya sangat parah.{\i0}
Dialogue: 0,0:20:45.61,0:20:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka…
Dialogue: 0,0:20:47.49,0:20:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sangat membenci penyihir.
Dialogue: 0,0:20:54.00,0:20:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita harus bersiap\Nuntuk serangan mendadak.
Dialogue: 0,0:21:02.42,0:21:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tetaplah di sini\Ndan jangan bergerak.
Dialogue: 0,0:21:05.51,0:21:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,\Nmereka tak akan menyadari kalian.
Dialogue: 0,0:21:08.76,0:21:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, sihir di jubahku\Nsudah tidak berfungsi.
Dialogue: 0,0:21:14.35,0:21:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau melindungi kami.
Dialogue: 0,0:21:21.73,0:21:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:21:24.11,0:21:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku guru kalian.
Dialogue: 0,0:21:35.37,0:21:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Anak-Anak.
Dialogue: 0,0:21:39.88,0:21:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah di dekatku…
Dialogue: 0,0:21:46.51,0:21:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa pun yang terjadi.
Dialogue: 0,0:23:32.53,0:23:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Terjemahan subtitle oleh Nola Mardiana
