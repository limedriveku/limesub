Dialogue: 0,0:23:36.70,0:23:39.04,sign,,0000,0000,0000,,EPISODE 11\NUJIAN DI GUA PUNGGUNG NAGA
Dialogue: 0,0:00:02.04,0:00:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya mata yang tajam.
Dialogue: 0,0:00:05.50,0:00:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pengamat yang sangat baik, ya?
Dialogue: 0,0:00:08.88,0:00:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cahaya yang sangat terang waktu itu,{\i0}
Dialogue: 0,0:00:11.51,0:00:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mungkin Tuan Qifrey tahu sesuatu.{\i0}
Dialogue: 0,0:00:15.01,0:00:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Begini, Tuan Qifrey.
Dialogue: 0,0:00:18.22,0:00:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku ingin menanyakan sesuatu kepadamu.
Dialogue: 0,0:00:27.40,0:00:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu…
Dialogue: 0,0:00:29.27,0:00:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}membuatku senang!
Dialogue: 0,0:00:30.90,0:00:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa?
Dialogue: 0,0:00:31.82,0:00:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau bisa menanyakan apa pun.
Dialogue: 0,0:00:34.28,0:00:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjawabnya\Nkalau itu tentang sihir.
Dialogue: 0,0:00:37.28,0:00:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang ingin kau ketahui, Tartah?
Dialogue: 0,0:00:40.29,0:00:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:42.29,0:00:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sulit memberitahunya\Nbahwa bukan itu yang kumaksud.{\i0}
Dialogue: 0,0:00:45.50,0:00:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia tampak begitu senang,\Nsulit menjelaskannya.{\i0}
Dialogue: 0,0:00:47.88,0:00:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi…
Dialogue: 0,0:00:49.63,0:00:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang barusan datang?
Dialogue: 0,0:00:51.63,0:00:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk.
Dialogue: 0,0:00:53.67,0:00:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lewat sini.
Dialogue: 0,0:00:57.68,0:01:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini demam yang disebabkan\Nkelelahan dan kurang tidur.
Dialogue: 0,0:01:04.23,0:01:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, dia sudah lama\Ntidak tidur nyenyak.
Dialogue: 0,0:01:07.85,0:01:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan pulih dengan istirahat\Ndan makan yang teratur.
Dialogue: 0,0:01:11.61,0:01:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk jaga-jaga,\Nbiarkan dia istirahat di sini malam ini.
Dialogue: 0,0:01:15.70,0:01:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:01:17.70,0:01:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:01:19.82,0:01:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu sekeras apa\Npelatihan yang dijalani penyihir,
Dialogue: 0,0:01:24.00,0:01:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia masih anak-anak.
Dialogue: 0,0:01:26.08,0:01:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang dewasa di sekitarnya\Nharus menjaganya dengan baik.
Dialogue: 0,0:01:35.17,0:01:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang benar.
Dialogue: 0,0:01:37.47,0:01:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Coco.
Dialogue: 0,0:01:59.82,0:02:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga ini bisa sedikit membantu.
Dialogue: 0,0:02:02.91,0:02:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak perlu memaksakan diri\Nsampai pingsan kalau memang berat.
Dialogue: 0,0:02:07.79,0:02:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang tubuh, hati, dan tindakanmu
Dialogue: 0,0:02:10.21,0:02:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berhenti mendengarkan perintahmu.
Dialogue: 0,0:02:13.71,0:02:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai baru-baru ini,\NCoco tak tahu apa-apa tentang dunia sihir.
Dialogue: 0,0:02:18.59,0:02:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dia bertingkah ceria,
Dialogue: 0,0:02:20.47,0:02:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin sebenarnya dia sangat cemas.
Dialogue: 0,0:02:26.77,0:02:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak tahu apa-apa?{\i0}
Dialogue: 0,0:02:28.85,0:02:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa dia orang luar itu?{\i0}
Dialogue: 0,0:02:31.27,0:02:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gadis ini?{\i0}
Dialogue: 0,0:02:32.69,0:02:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tartah.
Dialogue: 0,0:02:34.48,0:02:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, ada yang ingin kau tanyakan,
Dialogue: 0,0:02:37.90,0:02:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi apa bisa ditunda dulu?
Dialogue: 0,0:02:40.91,0:02:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya tidak tepat.
Dialogue: 0,0:02:47.37,0:02:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:02:49.50,0:02:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu dipikirkan.
Dialogue: 0,0:02:54.00,0:02:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku permisi.
Dialogue: 0,0:02:55.96,0:02:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih. Jaga dirimu.
Dialogue: 0,0:03:12.44,0:03:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat itu,{\i0}
Dialogue: 0,0:03:14.02,0:03:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku yakin sempat merasakan\Ntatapan dingin yang menusuk.{\i0}
Dialogue: 0,0:03:19.57,0:03:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Atau mungkin itu hanya perasaanku, ya?{\i0}
Dialogue: 0,0:03:23.74,0:03:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:03:24.87,0:03:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya penyihir yang boleh naik feri ini.
Dialogue: 0,0:03:27.95,0:03:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau dari pulau itu,\Nmana topi runcingmu?
Dialogue: 0,0:03:31.08,0:03:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak boleh ada yang lewat\Ntanpa bukti mereka penyihir.
Dialogue: 0,0:03:34.79,0:03:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ada di sini.
Dialogue: 0,0:03:37.30,0:03:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:38.76,0:03:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Hilang!
Dialogue: 0,0:03:40.59,0:03:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:41.67,0:03:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyeberang pagi ini…
Dialogue: 0,0:03:43.76,0:03:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak peduli!
Dialogue: 0,0:03:44.84,0:03:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak anak nakal\Nyang mencoba menyelinap dengan cerita itu.
Dialogue: 0,0:03:49.18,0:03:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kembali ke sini!
Dialogue: 0,0:03:54.44,0:03:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak bisa pulang tanpa topiku.{\i0}
Dialogue: 0,0:03:57.07,0:03:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus menemukannya.{\i0}
Dialogue: 0,0:03:59.03,0:04:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Napasnya sudah kembali stabil.
Dialogue: 0,0:04:04.78,0:04:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa istirahat begini,\Ndia akan cepat pulih.
Dialogue: 0,0:04:08.33,0:04:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:04:10.04,0:04:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi harus kuakui,
Dialogue: 0,0:04:11.96,0:04:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}udara di area ini memang sejuk\Ndan menyegarkan.
Dialogue: 0,0:04:15.38,0:04:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir memang luar biasa.
Dialogue: 0,0:04:17.71,0:04:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter juga luar biasa.
Dialogue: 0,0:04:20.21,0:04:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir tak bisa menyembuhkan penyakit,\Nhanya ini yang kubisa.
Dialogue: 0,0:04:23.22,0:04:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja, ini akan membantunya pulih.
Dialogue: 0,0:04:26.64,0:04:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai kami juga bisa menggunakan sihir.
Dialogue: 0,0:04:32.48,0:04:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:35.48,0:04:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter, kau di sini?
Dialogue: 0,0:04:37.48,0:04:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terjadi kebakaran di kedai minum di utara!{\i0}
Dialogue: 0,0:04:41.48,0:04:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mencoba membantu,
Dialogue: 0,0:04:43.15,0:04:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi terlalu banyak yang mabuk,\Njadi tak bisa…
Dialogue: 0,0:04:48.24,0:04:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau penyihir?
Dialogue: 0,0:04:49.91,0:04:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kau seorang penyihir air? Sempurna.
Dialogue: 0,0:04:53.25,0:04:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikut aku dan bantu padamkan api.
Dialogue: 0,0:04:55.46,0:04:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir harus membantu warga, bukan?
Dialogue: 0,0:04:58.00,0:05:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku tak bisa!
Dialogue: 0,0:05:00.84,0:05:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa pergi sekarang.
Dialogue: 0,0:05:02.76,0:05:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:05:04.88,0:05:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikut saja dengan mereka.
Dialogue: 0,0:05:06.63,0:05:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah tugas penyihir.
Dialogue: 0,0:05:11.56,0:05:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Aku akan segera kembali.
Dialogue: 0,0:05:14.35,0:05:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat yang cukup, ya?
Dialogue: 0,0:05:17.44,0:05:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berangkat.
Dialogue: 0,0:05:18.98,0:05:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:20.40,0:05:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberapa parah?
Dialogue: 0,0:05:22.07,0:05:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apinya masih kecil saat aku pergi,\Ntapi kalau tidak bergegas bisa gawat.
Dialogue: 0,0:05:28.87,0:05:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku pura-pura kuat.{\i0}
Dialogue: 0,0:05:31.20,0:05:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebenarnya, aku takut sendirian.{\i0}
Dialogue: 0,0:05:40.29,0:05:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku sudah mencari ke mana-mana,\Ntapi tak menemukannya.{\i0}
Dialogue: 0,0:05:43.21,0:05:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hanya tempat ini yang tersisa…\N- Ayo!
Dialogue: 0,0:05:48.80,0:05:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu.
Dialogue: 0,0:06:05.40,0:06:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topiku…
Dialogue: 0,0:06:08.20,0:06:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:06:12.58,0:06:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah. Sekarang, aku bisa pulang.
Dialogue: 0,0:06:23.34,0:06:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa dia mimpi buruk?{\i0}
Dialogue: 0,0:06:26.76,0:06:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau baik-baik saja?
Dialogue: 0,0:06:31.84,0:06:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tartah?
Dialogue: 0,0:06:35.64,0:06:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengejutkanku. Kenapa…
Dialogue: 0,0:06:39.85,0:06:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:06:42.40,0:06:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, kondisimu makin parah.
Dialogue: 0,0:06:45.27,0:06:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada orang di sini?
Dialogue: 0,0:06:48.61,0:06:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada dokter di sekitar sini.
Dialogue: 0,0:06:50.99,0:06:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Tuan Qifrey?
Dialogue: 0,0:06:52.74,0:06:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pergi ke utara. Terjadi kebakaran…
Dialogue: 0,0:06:55.33,0:06:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:57.04,0:06:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu sebabnya mereka keluar.
Dialogue: 0,0:06:59.46,0:07:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini? Kapan mereka kembali?
Dialogue: 0,0:07:01.92,0:07:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus memanggil mereka.
Dialogue: 0,0:07:08.55,0:07:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku harus melakukan sesuatu.
Dialogue: 0,0:07:10.88,0:07:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus minum obat penurun demam.
Dialogue: 0,0:07:13.59,0:07:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat daun penenang? Herba yang waktu itu.
Dialogue: 0,0:07:17.68,0:07:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa membantu demam dan batuk.
Dialogue: 0,0:07:21.10,0:07:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada satu di sekitar sini.
Dialogue: 0,0:07:33.32,0:07:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada labelnya!{\i0}
Dialogue: 0,0:07:36.12,0:07:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak mungkin!\NSiapa yang menyimpan obat tanpa label?{\i0}
Dialogue: 0,0:07:39.29,0:07:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana kalau salah ambil?\NItu akan berbahaya.{\i0}
Dialogue: 0,0:07:44.21,0:07:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semua warnanya tampak sedikit berbeda.{\i0}
Dialogue: 0,0:07:47.38,0:07:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang lain pasti bisa membedakannya\Nberdasarkan warna.{\i0}
Dialogue: 0,0:07:54.18,0:07:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini lagi.
Dialogue: 0,0:07:56.47,0:07:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang pikir\Nkita melihat dunia yang sama.
Dialogue: 0,0:07:59.56,0:08:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah itu hal yang pasti.
Dialogue: 0,0:08:02.60,0:08:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan sindrom selaput perak,{\i0}
Dialogue: 0,0:08:04.19,0:08:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mustahil membuat sihir rumit\Nmenggunakan pigmen.{\i0}
Dialogue: 0,0:08:07.65,0:08:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia hanya akan jadi\Npemasok alat sihir kelas teri.{\i0}
Dialogue: 0,0:08:10.69,0:08:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak masalah saat masih kecil, tapi…{\i0}
Dialogue: 0,0:08:13.32,0:08:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untung kau pandai mengukir pena.{\i0}
Dialogue: 0,0:08:17.62,0:08:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada hal yang bisa dilakukan\Ndan ada yang tidak.{\i0}
Dialogue: 0,0:08:22.16,0:08:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cukup lakukan yang bisa kau lakukan.{\i0}
Dialogue: 0,0:08:25.50,0:08:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:08:27.75,0:08:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Banyak herba yang digunakan\Ndalam pewarna sihir.{\i0}
Dialogue: 0,0:08:31.34,0:08:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Andai tahu jenisnya,\Naku tahu kegunaan masing-masing herba itu.{\i0}
Dialogue: 0,0:08:34.97,0:08:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak bisa apa-apa saat genting.{\i0}
Dialogue: 0,0:08:37.97,0:08:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di dunia yang segalanya tampak perak,{\i0}
Dialogue: 0,0:08:42.02,0:08:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku bahkan tak bisa melihat kemungkinan.{\i0}
Dialogue: 0,0:08:48.40,0:08:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tartah…
Dialogue: 0,0:08:53.69,0:08:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tak berguna.
Dialogue: 0,0:08:56.24,0:08:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kaulah yang sedang menderita.
Dialogue: 0,0:09:02.95,0:09:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga. Air.
Dialogue: 0,0:09:06.79,0:09:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau minum, bukan?
Dialogue: 0,0:09:09.04,0:09:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, diminum.
Dialogue: 0,0:09:14.63,0:09:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:19.76,0:09:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gelembung uap…{\i0}
Dialogue: 0,0:09:21.68,0:09:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau dipikir-pikir,{\i0}
Dialogue: 0,0:09:23.60,0:09:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kakek selalu menggunakan ini\Nsaat membuat tinta sihir.{\i0}
Dialogue: 0,0:09:27.27,0:09:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu dia!{\i0}
Dialogue: 0,0:09:28.44,0:09:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bisa memisahkan cairan\Ndari obatnya dengan ini.{\i0}
Dialogue: 0,0:09:31.69,0:09:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika aku menghilangkan kadar airnya,{\i0}
Dialogue: 0,0:09:34.94,0:09:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mungkin aku bisa tahu campurannya.{\i0}
Dialogue: 0,0:09:39.32,0:09:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Daun penenang adalah obat bubuk.{\i0}
Dialogue: 0,0:09:41.62,0:09:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dikeringkan dan digiling.{\i0}
Dialogue: 0,0:09:44.00,0:09:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, kalau aku mencari bubuk…{\i0}
Dialogue: 0,0:09:47.50,0:09:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan bahan yang mengkristal.
Dialogue: 0,0:09:50.96,0:09:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan yang bersinar\Ndi bawah cahaya bulan juga.
Dialogue: 0,0:09:55.72,0:09:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan bukan bahan yang mengering.
Dialogue: 0,0:09:59.93,0:10:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya tidak khas,
Dialogue: 0,0:10:02.47,0:10:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi bukan yang berbau menyengat.
Dialogue: 0,0:10:07.02,0:10:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tersisa…
Dialogue: 0,0:10:14.90,0:10:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga lagi.
Dialogue: 0,0:10:17.49,0:10:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Aku sudah sejauh ini.
Dialogue: 0,0:10:20.62,0:10:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah sampai sejauh ini…
Dialogue: 0,0:10:24.79,0:10:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa sampai sejauh ini.
Dialogue: 0,0:10:31.25,0:10:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Coco.
Dialogue: 0,0:10:34.75,0:10:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berusaha,
Dialogue: 0,0:10:36.76,0:10:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini di luar kemampuanku.
Dialogue: 0,0:10:41.05,0:10:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku berpikir bisa membantu?
Dialogue: 0,0:10:45.18,0:10:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu betul.
Dialogue: 0,0:10:47.60,0:10:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu aku tak mampu.
Dialogue: 0,0:10:53.36,0:10:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:10:56.36,0:11:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir ada untuk membantu orang melakukan
Dialogue: 0,0:11:01.41,0:11:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang tak bisa mereka lakukan sendiri.
Dialogue: 0,0:11:05.58,0:11:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya pena dan tinta?
Dialogue: 0,0:11:07.87,0:11:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya.
Dialogue: 0,0:11:09.25,0:11:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pena yang belum selesai aku ukir.
Dialogue: 0,0:11:32.60,0:11:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:11:34.65,0:11:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:37.65,0:11:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menggambar mantra apa?
Dialogue: 0,0:11:40.32,0:11:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu akan membuatmu merasa lebih baik?
Dialogue: 0,0:11:43.70,0:11:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan aku.
Dialogue: 0,0:11:47.12,0:11:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya aku.
Dialogue: 0,0:11:49.62,0:11:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dan aku, Tartah.
Dialogue: 0,0:11:51.62,0:11:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mantra untuk membantu kita berdua.
Dialogue: 0,0:11:56.04,0:11:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:57.59,0:11:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga?
Dialogue: 0,0:12:00.67,0:12:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra untuk membantuku juga?
Dialogue: 0,0:12:03.47,0:12:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra macam apa itu?
Dialogue: 0,0:12:06.89,0:12:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Lambang Sihir Tanah.
Dialogue: 0,0:12:09.06,0:12:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggali terowongan,\Nmenghancurkan batu menjadi pasir…
Dialogue: 0,0:12:12.73,0:12:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mantra yang berulang kali membantuku.
Dialogue: 0,0:12:16.31,0:12:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa yang itu?
Dialogue: 0,0:12:19.19,0:12:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Saat arah panah berubah, mantra berubah."
Dialogue: 0,0:12:22.32,0:12:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menggambar panah penghancur\Nsecara terbalik.
Dialogue: 0,0:12:26.24,0:12:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Biasanya, ini mantra\Nyang mengubah benda menjadi debu.{\i0}
Dialogue: 0,0:12:30.49,0:12:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panah terbalik…
Dialogue: 0,0:12:34.08,0:12:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra itu memberi bentuk\Npada material lepas.
Dialogue: 0,0:12:37.63,0:12:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:40.21,0:12:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kalau Tartah…
Dialogue: 0,0:12:43.26,0:12:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu bentuk asli dari banyak hal.
Dialogue: 0,0:12:47.09,0:12:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa mencari jawabannya
Dialogue: 0,0:12:49.89,0:12:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari semua yang telah kau pelajari.
Dialogue: 0,0:12:58.98,0:13:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, aku terlalu lelah.
Dialogue: 0,0:13:01.48,0:13:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garis-garisnya berantakan.
Dialogue: 0,0:13:03.15,0:13:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:13:05.03,0:13:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya perlu menggambar bentuk yang sama\Ndengan rapi, bukan?
Dialogue: 0,0:13:08.03,0:13:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, perbaiki juga\Nrasio keseimbangannya.
Dialogue: 0,0:13:12.54,0:13:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pandai menggambar,\Ntapi aku pandai menilai keseimbangan.
Dialogue: 0,0:13:17.37,0:13:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah jadi kebiasaanku.
Dialogue: 0,0:13:30.30,0:13:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, tentang panah ini.
Dialogue: 0,0:13:33.18,0:13:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku gambar dari kiri ke kanan,\Nbukan hanya dari atas ke bawah?
Dialogue: 0,0:13:37.94,0:13:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda tiga dimensi\Nharus dibentuk dari setiap sudut.
Dialogue: 0,0:13:42.32,0:13:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang sekarang, masih ada celah.{\i0}
Dialogue: 0,0:13:44.49,0:13:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kurasa titik itu tak akan terbentuk\Ndengan benar.{\i0}
Dialogue: 0,0:13:47.45,0:13:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mungkin…
Dialogue: 0,0:13:48.61,0:13:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:13:50.28,0:13:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengubah mantramu tanpa izin.
Dialogue: 0,0:13:52.62,0:13:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:13:54.45,0:13:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya mantra dasar. Lagi pula…
Dialogue: 0,0:13:58.08,0:14:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau idemu mengubah hasilnya,
Dialogue: 0,0:14:00.58,0:14:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti itu mantramu sekarang, Tartah.
Dialogue: 0,0:14:07.51,0:14:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah.
Dialogue: 0,0:14:09.59,0:14:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:11.05,0:14:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan coba.
Dialogue: 0,0:15:13.45,0:15:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil.
Dialogue: 0,0:15:17.29,0:15:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil…
Dialogue: 0,0:15:18.50,0:15:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sebentar, tapi aku berhasil.
Dialogue: 0,0:15:20.62,0:15:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil.
Dialogue: 0,0:15:22.37,0:15:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:15:23.96,0:15:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Kau butuh obat!
Dialogue: 0,0:15:26.84,0:15:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit lagi.
Dialogue: 0,0:15:28.88,0:15:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada satu pun\Nyang merupakan daun penenang.
Dialogue: 0,0:15:31.63,0:15:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir pasti ada di sini.
Dialogue: 0,0:15:34.80,0:15:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:38.14,0:15:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan gunakan mantra ini\Nuntuk mencari di ruang herba!
Dialogue: 0,0:15:41.52,0:15:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menemukannya dengan ini.
Dialogue: 0,0:15:56.41,0:15:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di sini agak mirip rumah kami.{\i0}
Dialogue: 0,0:16:04.79,0:16:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulit duri, bunga kincir,
Dialogue: 0,0:16:07.54,0:16:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mawar laut, dedalu tidur,
Dialogue: 0,0:16:10.30,0:16:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sarang lebah embun…
Dialogue: 0,0:16:12.93,0:16:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu semua itu.
Dialogue: 0,0:16:14.22,0:16:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuknya persis seperti\Nyang kupelajari dari buku.
Dialogue: 0,0:16:19.43,0:16:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa…
Dialogue: 0,0:16:21.98,0:16:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat aku mendekatkan segelnya,{\i0}
Dialogue: 0,0:16:24.10,0:16:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dunia menjadi lebih jelas.{\i0}
Dialogue: 0,0:16:28.57,0:16:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semua yang kupelajari{\i0}
Dialogue: 0,0:16:30.82,0:16:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menunjukkan jawabannya.{\i0}
Dialogue: 0,0:16:33.99,0:16:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bisa melakukan hal\Nyang dulu tak bisa kulakukan…{\i0}
Dialogue: 0,0:16:37.28,0:16:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rasanya begitu…{\i0}
Dialogue: 0,0:16:39.70,0:16:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Begitu…{\i0}
Dialogue: 0,0:16:43.25,0:16:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukannya.
Dialogue: 0,0:16:47.71,0:16:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini daun penenang!
Dialogue: 0,0:16:49.80,0:16:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bergegas.
Dialogue: 0,0:16:51.38,0:16:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau!
Dialogue: 0,0:16:52.46,0:16:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan di sini?
Dialogue: 0,0:16:57.22,0:16:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir tak ada orang di sini?
Dialogue: 0,0:16:59.72,0:17:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:17:01.72,0:17:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak akan membiarkan\Nrumah sakit kosong.
Dialogue: 0,0:17:05.69,0:17:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan obat-obatan ini tak punya label
Dialogue: 0,0:17:07.98,0:17:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar tak ada yang mengutak-atiknya.
Dialogue: 0,0:17:10.36,0:17:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa saja memberikan obat\Nyang tidak seharusnya diberikan.
Dialogue: 0,0:17:14.78,0:17:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:16.20,0:17:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku panik.
Dialogue: 0,0:17:17.99,0:17:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginanmu menolong temanmu\Nsangat terpuji.
Dialogue: 0,0:17:21.99,0:17:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi obat juga bisa menjadi racun.
Dialogue: 0,0:17:25.00,0:17:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau butuh pengetahuan yang tepat.
Dialogue: 0,0:17:28.29,0:17:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dalam kasus ini,\Ndaun penenang adalah jawaban yang benar.
Dialogue: 0,0:17:32.76,0:17:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau tahu banyak tentang herba?
Dialogue: 0,0:17:35.09,0:17:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tertarik dengan obat-obatan?
Dialogue: 0,0:17:37.13,0:17:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Soal itu, aku…
Dialogue: 0,0:17:39.76,0:17:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi itu…
Dialogue: 0,0:17:42.39,0:17:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau murid penyihir, ya?
Dialogue: 0,0:17:51.61,0:17:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah mengeluarkan yang terluka.
Dialogue: 0,0:17:54.40,0:17:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:17:56.36,0:17:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuannya.
Dialogue: 0,0:17:59.16,0:18:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apinya sudah berhasil dipadamkan.
Dialogue: 0,0:18:01.20,0:18:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah menyerahkan ini kepada kalian?
Dialogue: 0,0:18:04.16,0:18:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencemaskan muridku.
Dialogue: 0,0:18:05.87,0:18:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau mau ke mana?
Dialogue: 0,0:18:08.29,0:18:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih harus bersih-bersih!
Dialogue: 0,0:18:11.29,0:18:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para penyihir hanya menggunakan sihir\Ntanpa perlu bekerja keras, bukan?
Dialogue: 0,0:18:16.09,0:18:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam situasi begini,\Nkalian yang harus pertama turun tangan!
Dialogue: 0,0:18:19.22,0:18:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengandalkanmu.
Dialogue: 0,0:18:20.80,0:18:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, tidak semudah itu.
Dialogue: 0,0:18:25.27,0:18:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang luar tak akan mengerti.
Dialogue: 0,0:18:28.85,0:18:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa pergi.\NAku dan muridku yang akan mengurusnya.
Dialogue: 0,0:18:32.40,0:18:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:18:39.57,0:18:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu tak mudah atau sederhana.{\i0}
Dialogue: 0,0:18:42.62,0:18:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sama sekali tidak.{\i0}
Dialogue: 0,0:18:44.49,0:18:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau memang mudah,{\i0}
Dialogue: 0,0:18:46.62,0:18:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tidak akan ada yang kesulitan\Natau menderita.{\i0}
Dialogue: 0,0:19:11.44,0:19:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Napasku terasa lega.
Dialogue: 0,0:19:13.52,0:19:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:19:15.27,0:19:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, obatnya manjur.
Dialogue: 0,0:19:17.36,0:19:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Tartah.
Dialogue: 0,0:19:20.11,0:19:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak…
Dialogue: 0,0:19:21.66,0:19:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru aku yang seharusnya\Nberterima kasih.
Dialogue: 0,0:19:30.58,0:19:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir memang luar biasa.
Dialogue: 0,0:19:35.04,0:19:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir memang luar biasa, bukan?
Dialogue: 0,0:19:40.67,0:19:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membuatku khawatir\Nsaat kau tak pulang setelah gelap.
Dialogue: 0,0:19:45.01,0:19:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kakek.
Dialogue: 0,0:19:46.68,0:19:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengabariku, Qifrey.
Dialogue: 0,0:19:49.98,0:19:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama. Kau juga pasti melakukan itu.
Dialogue: 0,0:19:52.69,0:19:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga. Begini…
Dialogue: 0,0:19:55.40,0:19:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tanya soal cahaya\Nyang aku lihat di rumah tempo hari.
Dialogue: 0,0:20:00.19,0:20:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya?
Dialogue: 0,0:20:03.28,0:20:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:20:05.70,0:20:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga terlalu memaksakan diri.
Dialogue: 0,0:20:08.58,0:20:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga dirimu.
Dialogue: 0,0:20:11.16,0:20:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin aku salah.{\i0}
Dialogue: 0,0:20:14.21,0:20:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan menyelidiki sendiri{\i0}
Dialogue: 0,0:20:16.79,0:20:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}soal cahaya menyilaukan itu.{\i0}
Dialogue: 0,0:20:18.84,0:20:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tartah.
Dialogue: 0,0:20:20.09,0:20:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapalnya akan berangkat.
Dialogue: 0,0:20:23.09,0:20:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru.
Dialogue: 0,0:20:24.30,0:20:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu.
Dialogue: 0,0:20:27.30,0:20:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapalnya berangkat.
Dialogue: 0,0:20:35.52,0:20:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tartah.
Dialogue: 0,0:20:37.36,0:20:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:20:45.86,0:20:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga harus pergi.
Dialogue: 0,0:20:48.37,0:20:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:58.21,0:20:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:20:59.54,0:21:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuatkan pena untukmu!
Dialogue: 0,0:21:03.67,0:21:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku akan menyeberangi sungai ini\Ndengan sihirku sendiri
Dialogue: 0,0:21:07.55,0:21:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengantarnya sendiri! Aku janji!
Dialogue: 0,0:21:12.14,0:21:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:21:18.81,0:21:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menantikannya!
Dialogue: 0,0:21:24.28,0:21:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, kalian berdua\Njadi lebih akrab.
Dialogue: 0,0:21:27.66,0:21:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:29.45,0:21:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hebat.
Dialogue: 0,0:21:31.33,0:21:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti akan jadi orang hebat.
Dialogue: 0,0:21:38.71,0:21:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga.
Dialogue: 0,0:21:40.13,0:21:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga bisa jadi orang hebat.
Dialogue: 0,0:21:48.64,0:21:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:21:49.72,0:21:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mimpi buruk itu\Nyang membuatmu sulit tidur.
Dialogue: 0,0:21:53.60,0:21:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi memang sulit dihadapi.
Dialogue: 0,0:21:55.81,0:21:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra yang memaksa tidur\Nadalah sihir terlarang.
Dialogue: 0,0:21:58.98,0:22:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mari kita cari solusinya.
Dialogue: 0,0:22:01.77,0:22:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap inovasi lahir dari tantangan.
Dialogue: 0,0:22:05.15,0:22:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:22:06.90,0:22:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi kurasa aku akan baik-baik saja.
Dialogue: 0,0:22:10.74,0:22:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:22:12.41,0:22:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, karena
Dialogue: 0,0:22:15.33,0:22:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menemukan secercah harapan.
Dialogue: 0,0:22:20.13,0:22:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau membalikkan panah\Nbisa membalikkan efek mantra,{\i0}
Dialogue: 0,0:22:24.30,0:22:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}hal yang sama pasti berlaku\Nuntuk sihir terlarang.{\i0}
Dialogue: 0,0:22:30.34,0:22:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Kalau aku membalikkan panah di segel\Ndari buku bergambar itu,{\i0}
Dialogue: 0,0:22:34.56,0:22:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}mungkin aku bisa membalikkan mantra\Nyang mengubah Ibu menjadi batu.{\i0}
Dialogue: 0,0:22:38.31,0:22:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Coco!
Dialogue: 0,0:22:40.06,0:22:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:22:44.11,0:22:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat khawatir!
Dialogue: 0,0:22:46.32,0:22:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Kondisimu sudah lebih baik?\N- Ya!
Dialogue: 0,0:22:49.86,0:22:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Syukurlah! Aku lega sekali!
Dialogue: 0,0:22:58.08,0:23:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, hadiah darimu\Ntak membuahkan hasil yang diinginkan.
Dialogue: 0,0:23:03.34,0:23:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak semua Penyihir Bertopi\Nmelemah selama masa damai.
Dialogue: 0,0:23:06.09,0:23:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak semuanya bodoh.
Dialogue: 0,0:23:09.34,0:23:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa menunggu.
Dialogue: 0,0:23:11.59,0:23:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menjalankan\Nrencana selanjutnya.
Dialogue: 0,0:23:15.01,0:23:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau yang akan pergi berikutnya?
Dialogue: 0,0:23:18.64,0:23:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau? Sang penyihir\Nperwujudan sihir terlarang itu sendiri?
Dialogue: 0,0:23:23.06,0:23:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rencananya.
Dialogue: 0,0:23:25.94,0:23:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lagi pula, aku tak bisa melewatkan\Nujian murid itu.{\i0}
Dialogue: 0,0:23:30.82,0:23:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat mereka meninggalkan\Nperlindungan gurunya.{\i0}
Dialogue: 0,0:23:39.04,0:23:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subtitle diterjemahkan oleh Nola Mardiana
