Dialogue: 0,0:23:36.62,0:23:38.91,tanda,,0000,0000,0000,,EPISODE 6\NCAHAYA DALAM HUJAN
Dialogue: 0,0:00:23.52,0:00:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:00:25.02,0:00:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:26.40,0:00:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini lubang yang dibuat Richeh.
Dialogue: 0,0:00:28.48,0:00:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sudah berapa kali?
Dialogue: 0,0:00:30.11,0:00:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku sudah berhenti menghitung.
Dialogue: 0,0:00:32.15,0:00:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, mari kita bersembunyi\Ndi tempat tertutup dulu.
Dialogue: 0,0:00:35.91,0:00:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udara juga makin dingin.
Dialogue: 0,0:00:54.38,0:00:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia!
Dialogue: 0,0:00:58.85,0:01:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, kau menjatuhkannya.
Dialogue: 0,0:01:06.27,0:01:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:01:09.69,0:01:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa kau baik-baik saja?
Dialogue: 0,0:01:15.20,0:01:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin, ya?
Dialogue: 0,0:01:17.28,0:01:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Ini salahku.
Dialogue: 0,0:01:22.54,0:01:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:01:23.45,0:01:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubahmu! Pakai ini!\NNanti kau bisa kedinginan!
Dialogue: 0,0:01:26.41,0:01:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku akan tetap di sisimu!
Dialogue: 0,0:01:34.21,0:01:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Coco?
Dialogue: 0,0:01:37.22,0:01:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa aman saat memakai jubah itu.
Dialogue: 0,0:01:43.22,0:01:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat memakainya, tak ada yang tahu\Nmeski aku takut dan gemetar.{\i0}
Dialogue: 0,0:01:47.60,0:01:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setidaknya, dari luar,\Naku tetap seorang penyihir.{\i0}
Dialogue: 0,0:01:50.31,0:01:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu memberiku keberanian.{\i0}
Dialogue: 0,0:01:52.15,0:01:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, untuk saat ini,\Naku ingin kau memakainya, Tetia.
Dialogue: 0,0:01:55.57,0:01:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik kau yang memakainya\Ndaripada orang tak berguna sepertiku.
Dialogue: 0,0:02:02.37,0:02:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu… Apa?
Dialogue: 0,0:02:05.91,0:02:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan?
Dialogue: 0,0:02:10.83,0:02:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hangat.
Dialogue: 0,0:02:12.63,0:02:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awan?
Dialogue: 0,0:02:14.13,0:02:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:02:15.26,0:02:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah melihatmu\Ndengan tatapan menyalahkan.
Dialogue: 0,0:02:17.67,0:02:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:22.51,0:02:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa! Kau memang benar.
Dialogue: 0,0:02:24.89,0:02:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih\Nkarena tak mengatakan apa pun.
Dialogue: 0,0:02:29.19,0:02:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi aku tetap menyalahkanmu.
Dialogue: 0,0:02:31.27,0:02:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku melampiaskan ketakutanku\Nkepadamu, Coco.
Dialogue: 0,0:02:35.65,0:02:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah seniormu.
Dialogue: 0,0:02:37.44,0:02:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya, aku yang menjagamu.
Dialogue: 0,0:02:40.78,0:02:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia.
Dialogue: 0,0:02:43.91,0:02:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang menjagaku!
Dialogue: 0,0:02:45.54,0:02:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihirmu begitu hangat!\NAku sangat tenang dalam situasi ini!
Dialogue: 0,0:02:49.41,0:02:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Sihir memang luar biasa!
Dialogue: 0,0:02:53.04,0:02:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mantra buatanku sendiri.
Dialogue: 0,0:02:57.01,0:03:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat kecil, aku ingin tidur siang\Ndi atas awan.{\i0}
Dialogue: 0,0:03:01.01,0:03:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku terus bereksperimen sejak saat itu.{\i0}
Dialogue: 0,0:03:02.93,0:03:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi ini masih jauh dari sempurna.{\i0}
Dialogue: 0,0:03:05.43,0:03:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah sempurna, aku ingin\Nmengajukannya ke Ujian Sihir Komunal
Dialogue: 0,0:03:08.60,0:03:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar semua orang bisa menggunakannya.
Dialogue: 0,0:03:11.31,0:03:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mungkin tak berguna,\Ntapi ini impianku yang berharga.
Dialogue: 0,0:03:15.82,0:03:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau harus memakai jubahmu, Coco.
Dialogue: 0,0:03:19.44,0:03:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan melepas jubah murid ini\Nsaat kembali,
Dialogue: 0,0:03:22.41,0:03:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mari menjadi penyihir bersama.
Dialogue: 0,0:03:25.87,0:03:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:03:30.33,0:03:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:03:34.96,0:03:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau…
Dialogue: 0,0:03:36.46,0:03:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau ingin menaikinya,\Nciptakan sesuatu yang bisa menopangmu.
Dialogue: 0,0:03:40.30,0:03:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar dingin sekali.
Dialogue: 0,0:03:42.34,0:03:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau masuk.
Dialogue: 0,0:03:43.68,0:03:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau dipakai terbang juga,
Dialogue: 0,0:03:45.35,0:03:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gunakan pengganti yang mirip awan.
Dialogue: 0,0:03:47.81,0:03:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, kapas.
Dialogue: 0,0:03:48.72,0:03:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, itu hanya selimut biasa.
Dialogue: 0,0:03:51.31,0:03:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi memang indah,\Ntapi mari kembali ke kenyataan.
Dialogue: 0,0:03:55.90,0:03:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mencari cara keluar dari sini.
Dialogue: 0,0:03:59.69,0:04:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Fakta bahwa kita terus berlari,\Ntapi tetap kembali ke titik awal{\i0}
Dialogue: 0,0:04:02.90,0:04:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}membuatku sadar bahwa seluruh area ini\Ntelah dimantrai.{\i0}
Dialogue: 0,0:04:06.99,0:04:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa pun sihir terlarang itu,
Dialogue: 0,0:04:08.99,0:04:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}kalau itu sihir, pasti ada segelnya.
Dialogue: 0,0:04:12.37,0:04:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kita harus menemukan…
Dialogue: 0,0:04:14.21,0:04:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maaf…\N- Apa?
Dialogue: 0,0:04:17.09,0:04:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, aku sudah\Nmelihat segel itu. Mungkin?
Dialogue: 0,0:04:22.67,0:04:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:04:24.38,0:04:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas.
Dialogue: 0,0:04:27.18,0:04:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Itu memang segel.
Dialogue: 0,0:04:29.01,0:04:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:30.39,0:04:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa naganya terlihat lebih besar?
Dialogue: 0,0:04:33.18,0:04:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita yang mengecil.
Dialogue: 0,0:04:35.77,0:04:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersama ruang ini.\N- Apa?
Dialogue: 0,0:04:37.90,0:04:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang naga itu melindungi segelnya,\Nkita harus mengalahkannya.
Dialogue: 0,0:04:43.03,0:04:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tampaknya, sihir api…\N- Tunggu.
Dialogue: 0,0:04:46.11,0:04:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir api tak terlalu efektif tadi.
Dialogue: 0,0:04:50.74,0:04:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Maksudku…
Dialogue: 0,0:04:53.79,0:04:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Naga itu terkejut,\Ntapi tampaknya tak terluka.{\i0}
Dialogue: 0,0:04:57.46,0:05:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi, menurutku, api tak berguna\Nuntuk mengalahkannya.
Dialogue: 0,0:05:03.21,0:05:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, apa saranmu?
Dialogue: 0,0:05:05.80,0:05:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dikalahkan.
Dialogue: 0,0:05:12.97,0:05:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau masih memikirkan ucapanku tadi?
Dialogue: 0,0:05:16.02,0:05:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:05:17.23,0:05:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru memikirkan ini\Nkarena ucapanmu dan Tetia.
Dialogue: 0,0:05:20.36,0:05:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:22.28,0:05:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya rencana.
Dialogue: 0,0:05:24.07,0:05:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah ini akan berhasil atau tidak,
Dialogue: 0,0:05:26.36,0:05:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku ingin mencoba.
Dialogue: 0,0:05:35.62,0:05:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini…
Dialogue: 0,0:05:36.87,0:05:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:05:38.42,0:05:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasi Mari Sempurnakan Impian Tetia!
Dialogue: 0,0:05:43.30,0:05:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:05:44.63,0:05:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tahu di sini dingin, bukan?
Dialogue: 0,0:05:46.88,0:05:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi awan Tetia hangat dan nyaman.
Dialogue: 0,0:05:49.93,0:05:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi, kalau kita juga membuat selimut awan\Nuntuk naga itu,
Dialogue: 0,0:05:53.56,0:05:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}dia pasti tak mau bergerak
Dialogue: 0,0:05:55.43,0:05:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}dan mungkin tak akan menyerang kita.
Dialogue: 0,0:05:57.39,0:05:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu…
Dialogue: 0,0:05:58.60,0:05:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:00.61,0:06:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bisa menolak\Nselimut yang nyaman.
Dialogue: 0,0:06:03.57,0:06:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bahkan naga.
Dialogue: 0,0:06:05.53,0:06:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah begitu?
Dialogue: 0,0:06:07.03,0:06:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:08.53,0:06:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu…
Dialogue: 0,0:06:12.03,0:06:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu. Beri aku waktu\Nuntuk berpikir dulu.
Dialogue: 0,0:06:15.12,0:06:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar bagi manusia…
Dialogue: 0,0:06:20.83,0:06:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco, ada apa?
Dialogue: 0,0:06:24.38,0:06:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak apa-apa.
Dialogue: 0,0:06:26.09,0:06:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya penasaran\Napakah naga itu baik-baik saja.
Dialogue: 0,0:06:30.89,0:06:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga?
Dialogue: 0,0:06:32.22,0:06:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi, saat kita berlari,
Dialogue: 0,0:06:35.35,0:06:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia terhantam. Wajahnya menabrak pilar.
Dialogue: 0,0:06:38.73,0:06:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu,\Naku terlalu putus asa dan takut,
Dialogue: 0,0:06:42.11,0:06:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau dipikir-pikir,\Nitu pasti sakit sekali.
Dialogue: 0,0:06:47.69,0:06:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, maksudku…
Dialogue: 0,0:06:51.36,0:06:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku ingin mencoba\Nmelakukan rencana ini!
Dialogue: 0,0:06:58.25,0:07:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey bilang,
Dialogue: 0,0:07:00.42,0:07:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sihir yang tidak dilarang
Dialogue: 0,0:07:02.92,0:07:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih ada untuk membawa kebahagiaan.
Dialogue: 0,0:07:06.30,0:07:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia ingin\Naku belajar sihir yang baik.
Dialogue: 0,0:07:11.01,0:07:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini berhasil,\Ntak akan ada yang terluka,
Dialogue: 0,0:07:15.72,0:07:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik kita maupun naga itu.
Dialogue: 0,0:07:22.98,0:07:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:07:23.98,0:07:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kalau Agott ikut membantu,
Dialogue: 0,0:07:26.90,0:07:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurutku, hasilnya akan jauh lebih baik!
Dialogue: 0,0:07:29.86,0:07:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, kau punya ide.
Dialogue: 0,0:07:33.87,0:07:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bilang kalau tidak punya…
Dialogue: 0,0:07:37.49,0:07:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari lakukan bersama.
Dialogue: 0,0:07:41.50,0:07:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang paling pandai menggambar\Ndi antara kita semua, Agott.
Dialogue: 0,0:07:45.25,0:07:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami lebih tenang kalau kau bersama kami.
Dialogue: 0,0:07:58.47,0:07:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya…
Dialogue: 0,0:08:01.39,0:08:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:02.77,0:08:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya!\N- Hore!
Dialogue: 0,0:08:04.94,0:08:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hati-hati!
Dialogue: 0,0:08:09.65,0:08:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Agott!
Dialogue: 0,0:08:11.19,0:08:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak butuh ucapan terima kasih.\NMari membuat rencana.
Dialogue: 0,0:08:14.53,0:08:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:18.87,0:08:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia ingin bisa naik awan ini, bukan?
Dialogue: 0,0:08:21.04,0:08:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:08:22.16,0:08:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin ini seperti tempat tidur\Nyang empuk!
Dialogue: 0,0:08:24.96,0:08:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang empuk,
Dialogue: 0,0:08:26.75,0:08:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak tembus seperti awan.
Dialogue: 0,0:08:29.46,0:08:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan bahan yang tersedia di sini…
Dialogue: 0,0:08:31.71,0:08:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan cukup kuat untuk menopang naga.
Dialogue: 0,0:08:36.55,0:08:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Robekan kertas!
Dialogue: 0,0:08:37.93,0:08:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski merobek semua buku,\Nitu tak akan cukup.
Dialogue: 0,0:08:40.64,0:08:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kain!\N- Rambut…
Dialogue: 0,0:08:42.14,0:08:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak cukup.\NMemang kalian mau menghabiskan itu?
Dialogue: 0,0:08:48.31,0:08:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pasir…\N- Apa?
Dialogue: 0,0:08:51.19,0:08:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bagaimana kalau pasir?
Dialogue: 0,0:08:53.99,0:08:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Segel Penghancur Dinding!{\i0}
Dialogue: 0,0:08:55.36,0:08:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau menghancurkan dinding\Ndan lantai seperti tadi,{\i0}
Dialogue: 0,0:08:58.20,0:08:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kita bisa buat pasir halus.{\i0}
Dialogue: 0,0:08:59.62,0:09:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar! Pasir itu lembut dan halus\Nserta terasa nyaman!
Dialogue: 0,0:09:03.37,0:09:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus, Agott! Itu Agott kita!
Dialogue: 0,0:09:05.50,0:09:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menambah panah,\Nkita bisa buat partikel yang lebih kecil.
Dialogue: 0,0:09:09.34,0:09:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin kecil, makin bagus.
Dialogue: 0,0:09:10.92,0:09:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau segel kecil, serahkan kepadaku.
Dialogue: 0,0:09:14.55,0:09:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:09:15.47,0:09:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keahlian Richeh!
Dialogue: 0,0:09:17.51,0:09:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia, coba pikirkan mantra
Dialogue: 0,0:09:19.26,0:09:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mengumpulkan pasir di tengah\Ntanpa memadatkannya.
Dialogue: 0,0:09:22.22,0:09:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memikirkan mantra\Nyang melapisinya agar tidak hancur.
Dialogue: 0,0:09:25.60,0:09:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:09:26.73,0:09:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu…
Dialogue: 0,0:09:30.23,0:09:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tugasku?
Dialogue: 0,0:09:31.77,0:09:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau diam saja, Coco.
Dialogue: 0,0:09:34.44,0:09:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengikuti rencananya,
Dialogue: 0,0:09:36.20,0:09:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dengan kemampuanmu saat ini,\Naku tak bisa memercayakan mantra apa pun.
Dialogue: 0,0:09:40.41,0:09:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup selama kau tak mengganggu.
Dialogue: 0,0:09:54.21,0:09:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lingkarannya sangat rapi.\NBagaimana dia menggambarnya, ya?{\i0}
Dialogue: 0,0:10:15.74,0:10:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia gambar di udara beberapa kali,{\i0}
Dialogue: 0,0:10:18.03,0:10:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lalu mulai dari bagian depan.{\i0}
Dialogue: 0,0:10:21.24,0:10:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apakah Tetia dan Richeh\Njuga menggambar dengan cara itu?{\i0}
Dialogue: 0,0:10:31.46,0:10:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana caraku melakukannya?{\i0}
Dialogue: 0,0:10:34.67,0:10:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Titik awal dan bentuk akhirnya…{\i0}
Dialogue: 0,0:10:37.55,0:10:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku belum pernah memikirkannya.{\i0}
Dialogue: 0,0:10:42.39,0:10:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan mencoba!{\i0}
Dialogue: 0,0:10:44.31,0:10:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku ingin bisa melakukannya\Nseperti yang lain.{\i0}
Dialogue: 0,0:10:48.98,0:10:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku akan mencoba!{\i0}
Dialogue: 0,0:10:51.81,0:10:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini, lalu begini…
Dialogue: 0,0:11:10.71,0:11:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali.
Dialogue: 0,0:11:12.63,0:11:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi makin gelap, ya?
Dialogue: 0,0:11:14.63,0:11:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu menyalakan api?
Dialogue: 0,0:11:15.92,0:11:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kertasku habis.\N- Kertasku juga.
Dialogue: 0,0:11:20.01,0:11:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja.
Dialogue: 0,0:11:21.76,0:11:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panah konvergensi\Nakan membuatnya terlalu kaku…
Dialogue: 0,0:11:24.22,0:11:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau melapisinya\Ndengan lapisan udara?
Dialogue: 0,0:11:26.68,0:11:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak cukup kuat. Itu akan hancur.
Dialogue: 0,0:11:29.85,0:11:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau merobek kain\Nsebagai penguat?
Dialogue: 0,0:11:32.44,0:11:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melapisinya saja tidak akan cukup.
Dialogue: 0,0:11:35.02,0:11:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga makin dingin.
Dialogue: 0,0:11:36.57,0:11:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jadi.
Dialogue: 0,0:11:38.82,0:11:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada ide yang lebih baik…
Dialogue: 0,0:11:40.82,0:11:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ide…
Dialogue: 0,0:11:42.15,0:11:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Pasti ada.{\i0}
Dialogue: 0,0:11:43.91,0:11:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Sesuatu yang membuatnya sempurna.{\i0}
Dialogue: 0,0:11:52.50,0:11:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:11:54.33,0:11:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil!
Dialogue: 0,0:11:57.88,0:12:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa kau pakai\Nmantra itu sekarang?
Dialogue: 0,0:12:00.55,0:12:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu stabil.\N- Apa?
Dialogue: 0,0:12:02.84,0:12:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola apinya! Dulu langsung padam!
Dialogue: 0,0:12:06.14,0:12:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kau belajar menggambarnya?
Dialogue: 0,0:12:08.47,0:12:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya sedang berlatih\Nsambil memperhatikan kalian menggambar,
Dialogue: 0,0:12:13.10,0:12:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berulang kali mencobanya.
Dialogue: 0,0:12:18.36,0:12:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat. Kau berhasil, Coco!
Dialogue: 0,0:12:22.95,0:12:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun bisa menjadi lebih baik\Nkalau melakukan pengulangan…
Dialogue: 0,0:12:28.95,0:12:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengulangan…
Dialogue: 0,0:12:32.37,0:12:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengulangan! Itu dia!
Dialogue: 0,0:12:33.87,0:12:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:41.55,0:12:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian siap?
Dialogue: 0,0:12:42.76,0:12:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya.\N- Kami siap kapan saja.
Dialogue: 0,0:12:47.05,0:12:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Baiklah! Ayo!
Dialogue: 0,0:12:57.06,0:12:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:12:59.32,0:13:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:00.73,0:13:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Naga itu sudah makin besar.{\i0}
Dialogue: 0,0:13:03.24,0:13:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami harus segera menyelesaikannya.{\i0}
Dialogue: 0,0:13:05.49,0:13:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh, maju!
Dialogue: 0,0:13:06.57,0:13:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:44.32,0:13:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus. Coco!
Dialogue: 0,0:13:46.07,0:13:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:50.32,0:13:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri sinyal untuk menutup lingkaran.
Dialogue: 0,0:13:52.54,0:13:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:54.50,0:13:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga…
Dialogue: 0,0:13:55.50,0:13:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua…
Dialogue: 0,0:13:56.75,0:13:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu!
Dialogue: 0,0:14:06.05,0:14:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Richeh, selanjutnya!\N- Baik.
Dialogue: 0,0:14:32.37,0:14:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyadarinya!
Dialogue: 0,0:14:33.53,0:14:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berkumpul!
Dialogue: 0,0:14:34.87,0:14:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana status mereka?
Dialogue: 0,0:14:36.12,0:14:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah aktif.
Dialogue: 0,0:14:37.87,0:14:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:14:39.29,0:14:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pengulangan?{\i0}
Dialogue: 0,0:14:40.62,0:14:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Agar mantranya tidak hancur,
Dialogue: 0,0:14:44.50,0:14:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu harus dilapisi mantra pengulangan
Dialogue: 0,0:14:46.59,0:14:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar selalu kembali ke bentuk awal.
Dialogue: 0,0:14:49.26,0:14:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan kata lain, Penghancur Dinding\Ndan Gugus Gumpalan Awan.{\i0}
Dialogue: 0,0:14:52.26,0:14:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika kombinasi ini\Nkita lapisi mantra pengulangan,{\i0}
Dialogue: 0,0:14:54.93,0:14:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kita bisa membuat awan pasir.{\i0}
Dialogue: 0,0:14:57.18,0:14:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Mengingat ukuran naga itu,{\i0}
Dialogue: 0,0:14:59.35,0:15:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}kita butuh setidaknya lima mantra.{\i0}
Dialogue: 0,0:15:01.19,0:15:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan menyelaraskan posisi dan waktu{\i0}
Dialogue: 0,0:15:03.31,0:15:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}agar kelimanya aktif sebagai satu mantra,{\i0}
Dialogue: 0,0:15:06.19,0:15:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}meski bebannya membuatnya ambles,{\i0}
Dialogue: 0,0:15:07.82,0:15:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}awan pasir akan terus kembali\Nke bentuk awal.{\i0}
Dialogue: 0,0:15:10.99,0:15:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, itu tetap lembut dan nyaman\Nsepanjang waktu.{\i0}
Dialogue: 0,0:15:14.95,0:15:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita sebut…
Dialogue: 0,0:15:25.04,0:15:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantal Naga Pemalas!
Dialogue: 0,0:15:28.71,0:15:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ditolak. Ranjang Pasir Ular.
Dialogue: 0,0:15:30.84,0:15:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu lebih keren! Itu Agott kita!
Dialogue: 0,0:15:33.34,0:15:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu Agott kita.
Dialogue: 0,0:15:34.43,0:15:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Cukup mengobrolnya.\NMari menyelinap selagi bisa.
Dialogue: 0,0:15:42.14,0:15:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia?
Dialogue: 0,0:15:43.73,0:15:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:45.19,0:15:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak apa-apa.
Dialogue: 0,0:15:47.73,0:15:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mengamati.
Dialogue: 0,0:15:50.95,0:15:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga itu terlihat sangat bahagia.
Dialogue: 0,0:15:55.66,0:16:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, ini kali pertama\Naku memberi kebahagiaan dengan sihirku.
Dialogue: 0,0:16:05.25,0:16:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, bisa membuatku sebahagia ini!
Dialogue: 0,0:16:16.26,0:16:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bagaimana?\N- Ya.
Dialogue: 0,0:16:18.26,0:16:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, memang ini.
Dialogue: 0,0:16:20.22,0:16:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra apa ini?
Dialogue: 0,0:16:21.93,0:16:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihatnya.
Dialogue: 0,0:16:24.77,0:16:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Guru Qifrey tahu tidak, ya?{\i0}
Dialogue: 0,0:16:32.53,0:16:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka di sini?
Dialogue: 0,0:16:36.03,0:16:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak merasakan apa pun.\NApa mereka sudah pergi?
Dialogue: 0,0:16:39.49,0:16:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Bukankah jalan ini dipasangi ubin?
Dialogue: 0,0:16:44.16,0:16:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan mereka mengangkatnya?
Dialogue: 0,0:16:48.04,0:16:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teman kuas tertarik\Npada aroma tinta sihir.{\i0}
Dialogue: 0,0:16:52.13,0:16:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:16:56.39,0:16:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mundur!\N- Apa?
Dialogue: 0,0:17:07.56,0:17:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau asal menghapus segelnya?
Dialogue: 0,0:17:10.32,0:17:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segelnya jelas mencurigakan!
Dialogue: 0,0:17:11.94,0:17:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir mungkin ini penyebabnya!
Dialogue: 0,0:17:14.57,0:17:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-Teman, di atas!
Dialogue: 0,0:17:16.20,0:17:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa melihat langit!
Dialogue: 0,0:17:18.20,0:17:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita bisa keluar dari sana…
Dialogue: 0,0:17:20.66,0:17:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunduk!
Dialogue: 0,0:17:28.58,0:17:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ago…
Dialogue: 0,0:17:31.59,0:17:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus bagaimana?{\i0}
Dialogue: 0,0:17:33.30,0:17:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat ini,{\i0}
Dialogue: 0,0:17:35.51,0:17:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku tidak memakai sepatu sylph.{\i0}
Dialogue: 0,0:17:49.94,0:17:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:17:51.36,0:17:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga, rupanya.
Dialogue: 0,0:17:53.44,0:17:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, begini…
Dialogue: 0,0:17:54.86,0:17:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga itu datang. Pegangan.
Dialogue: 0,0:18:06.00,0:18:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengaktifkannya.\NPegangan yang erat.
Dialogue: 0,0:18:08.46,0:18:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:19:07.39,0:19:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah aman. Sepertinya, naga itu pingsan.
Dialogue: 0,0:19:12.56,0:19:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott?
Dialogue: 0,0:19:14.73,0:19:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya.\N- Guru!
Dialogue: 0,0:19:17.23,0:19:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tetia dan Richeh.\N- Aku ketakutan!
Dialogue: 0,0:19:19.57,0:19:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana Guru bisa ke sini?
Dialogue: 0,0:19:21.78,0:19:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang mencari kalian
Dialogue: 0,0:19:23.41,0:19:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat ruang tiba-tiba terbuka…
Dialogue: 0,0:19:28.62,0:19:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Coco?
Dialogue: 0,0:19:35.67,0:19:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Halo, Coco.{\i0}
Dialogue: 0,0:19:38.17,0:19:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sudah lama aku menunggu{\i0}
Dialogue: 0,0:19:40.63,0:19:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}agar benih yang kutanam akhirnya tumbuh.{\i0}
Dialogue: 0,0:19:44.93,0:19:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana tugas yang kusiapkan untukmu?{\i0}
Dialogue: 0,0:19:48.89,0:19:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu membantumu berkembang?
Dialogue: 0,0:19:52.06,0:19:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, aku akan memberimu hadiah.
Dialogue: 0,0:19:56.36,0:19:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang tak akan\Nkau pelajari dari Qifrey,
Dialogue: 0,0:19:59.03,0:20:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang akan mengajarimu.
Dialogue: 0,0:20:01.70,0:20:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat waktunya tiba, kau akan…
Dialogue: 0,0:20:05.66,0:20:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantikan hari itu.
Dialogue: 0,0:20:11.96,0:20:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Coco…{\i0}
Dialogue: 0,0:20:15.46,0:20:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:20:19.88,0:20:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey?
Dialogue: 0,0:20:22.42,0:20:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-Teman…
Dialogue: 0,0:20:27.30,0:20:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Agott!\N- Aku di sini.
Dialogue: 0,0:20:29.81,0:20:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Tartah.
Dialogue: 0,0:20:32.31,0:20:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu.
Dialogue: 0,0:20:33.94,0:20:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memanggil Kakek…
Dialogue: 0,0:20:35.77,0:20:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:20:37.44,0:20:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa kita di Kalhn?
Dialogue: 0,0:20:40.19,0:20:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kita semua selamat!
Dialogue: 0,0:20:43.36,0:20:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku menemukanmu.
Dialogue: 0,0:20:45.07,0:20:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pingsan di tangga menara.
Dialogue: 0,0:20:47.78,0:20:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangga?
Dialogue: 0,0:20:50.91,0:20:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Penyihir Bertopeng melakukan sesuatu?
Dialogue: 0,0:20:53.33,0:20:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:20:54.62,0:20:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya merasa sedikit linglung…
Dialogue: 0,0:21:04.22,0:21:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:21:06.72,0:21:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:21:08.80,0:21:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:10.72,0:21:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja…
Dialogue: 0,0:21:25.74,0:21:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Maafkan aku.
Dialogue: 0,0:21:30.78,0:21:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini salahku.
Dialogue: 0,0:21:32.79,0:21:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku melibatkan kalian…
Dialogue: 0,0:21:35.79,0:21:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku sungguh…
Dialogue: 0,0:21:38.83,0:21:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}minta maaf.
Dialogue: 0,0:21:44.84,0:21:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku sudah dengar dari Tetia
Dialogue: 0,0:21:46.84,0:21:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}tentang apa yang terjadi di sana.
Dialogue: 0,0:21:49.43,0:21:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hal yang kalian lakukan di sana.
Dialogue: 0,0:21:55.02,0:21:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dan bahwa kalian selamat berkat dirimu.
Dialogue: 0,0:21:57.89,0:21:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa?
Dialogue: 0,0:21:59.90,0:22:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ide itu
Dialogue: 0,0:22:01.23,0:22:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}seperti pena,\Nyang merupakan inti dari sihir.
Dialogue: 0,0:22:04.48,0:22:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mari kita kembangkan itu.
Dialogue: 0,0:22:20.50,0:22:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Baik!
Dialogue: 0,0:22:23.00,0:22:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Coco, aku senang kau baik-baik saja!
Dialogue: 0,0:22:26.21,0:22:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Maaf membuatmu khawatir.\NRicheh dan Agott juga.
Dialogue: 0,0:22:29.55,0:22:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Astaga.
Dialogue: 0,0:22:31.01,0:22:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau bukan sekadar baik-baik saja,\Nbahkan ceria.
Dialogue: 0,0:22:33.64,0:22:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ya, berkat Pak Nolnoa.
Dialogue: 0,0:22:35.77,0:22:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam sudah larut.
Dialogue: 0,0:22:37.81,0:22:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau menginap di…
Dialogue: 0,0:22:40.15,0:22:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pak Nolnoa.\N- Ya?
Dialogue: 0,0:22:41.69,0:22:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya permintaan penting.
Dialogue: 0,0:22:43.82,0:22:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:45.40,0:22:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Segel yang digambar di bawah ubin ini.
Dialogue: 0,0:22:48.49,0:22:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong periksa bahan tambahan\Nyang dicampur ke tinta sihir itu.
Dialogue: 0,0:22:53.91,0:22:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan tambahan, ya?
Dialogue: 0,0:22:56.66,0:22:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan tolong
Dialogue: 0,0:22:58.08,0:23:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan laporkan ini\Nkepada Ksatria Moralis.
Dialogue: 0,0:23:00.67,0:23:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tapi jika melihat sihir terlarang,
Dialogue: 0,0:23:03.79,0:23:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus melaporkannya.
Dialogue: 0,0:23:07.92,0:23:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan beri tahu siapa pun.
Dialogue: 0,0:23:10.68,0:23:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun.
Dialogue: 0,0:23:22.48,0:23:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, apa yang sedang terjadi?
Dialogue: 0,0:23:28.49,0:23:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:23:30.32,0:23:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya, apa yang akan terjadi, ya?
Dialogue: 0,0:23:38.91,0:23:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan Subtitle oleh Nola Mardiana
