Dialogue: 0,0:01:08.31,0:01:10.27,tanda,,0,0,0,,ATELIER OF WITCH HAT
Dialogue: 0,0:02:29.56,0:02:31.94,tanda,,0,0,0,,{\an8}SEKOLAH DI PADANG RUMPUT
Dialogue: 0,0:23:36.49,0:23:38.83,tanda,,0,0,0,,EPISODE 3\NUJIAN DI PEGUNUNGAN DADAH
Dialogue: 0,0:00:20.89,0:00:22.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Angin?
Dialogue: 0,0:00:25.69,0:00:26.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau sudah bangun?
Dialogue: 0,0:00:29.07,0:00:31.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku memanggil kereta yang lewat.
Dialogue: 0,0:00:31.78,0:00:32.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:33.45,0:00:36.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasti dingin di atas\Nkalau cuma pakai baju tidur.
Dialogue: 0,0:00:36.82,0:00:38.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita akan segera tiba.
Dialogue: 0,0:00:40.70,0:00:42.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat? Itu dia.
Dialogue: 0,0:00:53.30,0:00:54.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sanggarku.
Dialogue: 0,0:00:55.34,0:00:57.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat belajarmu yang baru.
Dialogue: 0,0:02:33.06,0:02:36.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}Aku menaburkan benih semak mawar\Ndi sekitar rumahmu.
Dialogue: 0,0:02:37.69,0:02:41.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu akan tumbuh dengan cepat\Nsebagai pagar pelindung.
Dialogue: 0,0:02:41.95,0:02:45.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena rumah itu diubah menjadi batu\Noleh sihir tak dikenal,
Dialogue: 0,0:02:46.54,0:02:49.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku memastikan tak akan ada yang mendekat.
Dialogue: 0,0:02:55.63,0:02:56.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sebabnya…
Dialogue: 0,0:02:58.51,0:02:59.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coco?
Dialogue: 0,0:03:04.64,0:03:05.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:03:06.81,0:03:10.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah berjanji\Ntak akan meninggalkan Ibu sendirian.
Dialogue: 0,0:03:11.39,0:03:12.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, aku…
Dialogue: 0,0:03:13.44,0:03:14.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coco…
Dialogue: 0,0:03:19.65,0:03:21.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan menyalahkan dirimu.
Dialogue: 0,0:03:21.57,0:03:23.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau tidak tahu apa-apa.
Dialogue: 0,0:03:36.29,0:03:38.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang, basuh wajahmu.
Dialogue: 0,0:03:38.92,0:03:41.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menangislah sepuasmu,\Nlalu tatap masa depan.
Dialogue: 0,0:03:44.64,0:03:47.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mulai hari ini, ini adalah rumah barumu.
Dialogue: 0,0:03:58.02,0:04:00.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, apa ini?
Dialogue: 0,0:04:01.36,0:04:02.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini air.
Dialogue: 0,0:04:05.57,0:04:06.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku lupa!
Dialogue: 0,0:04:06.66,0:04:09.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Air tidak bulat dan melayang.\N- Kau harus ganti baju.
Dialogue: 0,0:04:10.66,0:04:11.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:12.16,0:04:14.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana cara menggunakan ini?
Dialogue: 0,0:04:15.54,0:04:16.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Qifrey?
Dialogue: 0,0:04:19.42,0:04:22.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku takut menyentuh sihir\Nyang tidak aku tahu.
Dialogue: 0,0:04:22.92,0:04:24.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu tak menakutkan!
Dialogue: 0,0:04:25.47,0:04:27.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu bukan sihir yang rumit.
Dialogue: 0,0:04:30.60,0:04:32.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa perlu aku perlihatkan?
Dialogue: 0,0:04:36.52,0:04:38.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini disebut gelembung uap.
Dialogue: 0,0:04:39.02,0:04:42.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini sihir yang mengubah\Nkelembapan udara menjadi air.
Dialogue: 0,0:04:42.94,0:04:44.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti ini.
Dialogue: 0,0:04:44.36,0:04:45.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ulurkan tanganmu.
Dialogue: 0,0:04:46.82,0:04:50.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika kau angkat baki yang bawah,\Nfungsinya seperti cerat.
Dialogue: 0,0:04:50.79,0:04:54.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Luar biasa! Terima kasih!
Dialogue: 0,0:04:54.54,0:04:56.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Terima kasih!\N- Apa?
Dialogue: 0,0:04:56.67,0:04:59.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku suka saat ada orang\Nyang berterima kasih kepadaku!
Dialogue: 0,0:05:00.04,0:05:01.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, terima kasih!
Dialogue: 0,0:05:01.80,0:05:05.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya…
Dialogue: 0,0:05:05.63,0:05:06.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:06.88,0:05:09.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih sudah berterima kasih!
Dialogue: 0,0:05:09.76,0:05:13.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih sudah berterima kasih\Natas terima kasihku…
Dialogue: 0,0:05:13.14,0:05:15.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau Tetia mengganggu, abaikan saja.
Dialogue: 0,0:05:17.52,0:05:19.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia akan berhenti kalau kau abaikan.
Dialogue: 0,0:05:20.36,0:05:22.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa kau bilang begitu, Richeh?
Dialogue: 0,0:05:22.65,0:05:25.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya sedang mengajarinya.
Dialogue: 0,0:05:27.70,0:05:29.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Pena dan tinta.{\i0}
Dialogue: 0,0:05:30.58,0:05:32.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kalian berdua penyihir?
Dialogue: 0,0:05:32.74,0:05:34.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Murid.
Dialogue: 0,0:05:34.54,0:05:36.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami murid Guru Qifrey.
Dialogue: 0,0:05:36.83,0:05:39.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu, apa kau bukan muridnya?
Dialogue: 0,0:05:39.96,0:05:43.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku pikir kau ke sini untuk belajar\Nseperti kami.
Dialogue: 0,0:05:43.30,0:05:46.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa mungkin teman seumuran?\NKau dari sanggar mana?
Dialogue: 0,0:05:48.84,0:05:51.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku belum bisa disebut sebagai murid.
Dialogue: 0,0:05:51.89,0:05:55.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Habisnya, aku baru menggambar\Nmantra pertamaku kemarin.
Dialogue: 0,0:05:56.23,0:05:58.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tinggal di sini mulai hari ini.
Dialogue: 0,0:06:00.02,0:06:01.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:02.36,0:06:03.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa…
Dialogue: 0,0:06:03.61,0:06:06.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan-jangan kau orangnya?
Dialogue: 0,0:06:07.36,0:06:09.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang apa?
Dialogue: 0,0:06:17.08,0:06:18.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Kami mendengar rumor.{\i0}
Dialogue: 0,0:06:20.12,0:06:23.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Bahwa ada orang luar\Nyang menggunakan sihir terlarang{\i0}
Dialogue: 0,0:06:23.63,0:06:27.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}dan diizinkan menjadi murid\Ntanpa dihapus ingatannya.{\i0}
Dialogue: 0,0:06:29.26,0:06:30.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:06:32.30,0:06:33.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:06:33.55,0:06:35.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Qifrey.
Dialogue: 0,0:06:35.56,0:06:38.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya, kalian sudah berkenalan.
Dialogue: 0,0:06:38.39,0:06:41.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Richeh, Tetia, setelah selesai tugas pagi,
Dialogue: 0,0:06:41.31,0:06:43.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}kalian bisa belajar di kamar.
Dialogue: 0,0:06:43.27,0:06:44.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Baik!\N- Ya…
Dialogue: 0,0:06:45.61,0:06:46.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini pakaianmu.
Dialogue: 0,0:06:46.86,0:06:48.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua memakai ini di sini.
Dialogue: 0,0:06:51.16,0:06:54.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan takut.\NAku akan menjelaskan semuanya.
Dialogue: 0,0:06:57.29,0:06:59.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pas sekali.
Dialogue: 0,0:07:01.67,0:07:04.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang, mari kita bicara tentang sihir.
Dialogue: 0,0:07:06.09,0:07:07.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:07:08.51,0:07:09.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dahulu kala,
Dialogue: 0,0:07:10.30,0:07:12.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}sihir bukanlah hal yang istimewa.
Dialogue: 0,0:07:14.43,0:07:18.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau hanya membutuhkan segel yang tepat\Nserta tinta bertuah…
Dialogue: 0,0:07:24.77,0:07:26.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}dan siapa pun bisa menggunakannya.{\i0}
Dialogue: 0,0:07:27.32,0:07:29.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Sihir jauh lebih mudah diakses.{\i0}
Dialogue: 0,0:07:31.24,0:07:33.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, karena itu,
Dialogue: 0,0:07:33.16,0:07:35.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}perang terjadi berulang kali.
Dialogue: 0,0:07:37.91,0:07:42.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Manusia akan melakukan apa pun\Nketika punya kekuatan untuk mewujudkannya.{\i0}
Dialogue: 0,0:07:42.71,0:07:45.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Banyak mantra mengerikan yang digambar.{\i0}
Dialogue: 0,0:07:50.17,0:07:53.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Beberapa orang baik yang tersisa{\i0}
Dialogue: 0,0:07:53.09,0:07:56.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}menolak perang\Ndan bersatu sebagai penyihir.{\i0}
Dialogue: 0,0:07:57.01,0:07:59.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Mereka menghapus ingatan tentang sihir\Ndari masyarakat,{\i0}
Dialogue: 0,0:07:59.68,0:08:02.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}dan hanya mewariskan pengetahuan\Nkepada para murid{\i0}
Dialogue: 0,0:08:02.14,0:08:03.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}yang bisa merahasiakannya.{\i0}
Dialogue: 0,0:08:05.10,0:08:07.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Itu adalah "Hari Perjanjian".{\i0}
Dialogue: 0,0:08:08.11,0:08:08.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Sejak itu,{\i0}
Dialogue: 0,0:08:09.07,0:08:13.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}masyarakat percaya hanya orang istimewa\Nyang bisa menggunakan sihir.{\i0}
Dialogue: 0,0:08:13.65,0:08:15.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Kalau kebenaran itu tersebar,{\i0}
Dialogue: 0,0:08:15.91,0:08:18.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}kita akan kembali terjerumus\Ndalam kekacauan.{\i0}
Dialogue: 0,0:08:19.04,0:08:22.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua orang berusaha keras\Nuntuk menjaga rahasia ini.
Dialogue: 0,0:08:22.91,0:08:24.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sebabnya rumor tentangmu beredar.
Dialogue: 0,0:08:25.50,0:08:26.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, ya?
Dialogue: 0,0:08:26.92,0:08:30.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, itu salahku sendiri.
Dialogue: 0,0:08:31.09,0:08:34.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, apa itu sihir terlarang?
Dialogue: 0,0:08:35.72,0:08:40.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mantra yang dibuat selama masa perang\Ndilarang digunakan sejak Hari Perjanjian.
Dialogue: 0,0:08:41.31,0:08:43.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sihir yang menyakiti orang.
Dialogue: 0,0:08:45.81,0:08:47.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong ajari aku!
Dialogue: 0,0:08:47.98,0:08:49.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua sihir terlarang itu!
Dialogue: 0,0:08:49.94,0:08:51.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin tahu!
Dialogue: 0,0:08:52.86,0:08:56.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terlalu menakutkan\Nkalau aku terus tak tahu apa-apa.
Dialogue: 0,0:08:58.95,0:09:01.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku berniat menyuruhmu bersabar,
Dialogue: 0,0:09:01.87,0:09:03.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi situasimu berbeda.
Dialogue: 0,0:09:06.42,0:09:07.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ikut aku.
Dialogue: 0,0:09:12.55,0:09:15.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada banyak ragam sihir terlarang,
Dialogue: 0,0:09:15.80,0:09:19.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi semuanya bisa dijelaskan\Ndengan sederhana.
Dialogue: 0,0:09:19.72,0:09:24.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Sihir yang langsung memengaruhi tubuh\Natau pikiran manusia jelas dilarang.{\i0}
Dialogue: 0,0:09:24.68,0:09:27.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Misalnya, transformasi atau mengubah usia.{\i0}
Dialogue: 0,0:09:27.98,0:09:30.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Teleportasi tanpa pintu atau kendaraan.{\i0}
Dialogue: 0,0:09:31.69,0:09:33.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memanipulasi pikiran dan emosi.
Dialogue: 0,0:09:34.03,0:09:36.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menyakiti atau menyembuhkan orang.
Dialogue: 0,0:09:37.32,0:09:39.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi ada satu pengecualian.
Dialogue: 0,0:09:40.20,0:09:42.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mantra untuk menghapus ingatan.
Dialogue: 0,0:09:42.16,0:09:43.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tepat.
Dialogue: 0,0:09:45.96,0:09:48.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kebanyakan sihir dirapalkan pada alat.
Dialogue: 0,0:09:49.67,0:09:51.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti pada kereta atau lampu.
Dialogue: 0,0:09:59.68,0:10:02.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Atau jendela seperti ini.
Dialogue: 0,0:10:22.20,0:10:23.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Danau?
Dialogue: 0,0:10:24.74,0:10:27.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tadi pemandangannya masih bukit.
Dialogue: 0,0:10:28.04,0:10:29.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini jendela jalan.
Dialogue: 0,0:10:30.00,0:10:32.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini terhubung ke jendela lain\Ndengan desain yang sama.
Dialogue: 0,0:10:33.96,0:10:35.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat gedung di kejauhan itu?
Dialogue: 0,0:10:36.84,0:10:37.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu Menara Makam.
Dialogue: 0,0:10:38.55,0:10:40.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk melestarikan pengetahuan,
Dialogue: 0,0:10:40.26,0:10:44.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}setiap buku sihir\Ndisalin di sini saat ditulis.
Dialogue: 0,0:10:46.06,0:10:47.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buku bergambar itu juga!
Dialogue: 0,0:10:48.14,0:10:51.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita pergi sekarang!\NAku tak akan berhenti sampai menemukannya!
Dialogue: 0,0:10:51.15,0:10:51.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:11:10.04,0:11:11.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu Ujian Pustakawan.
Dialogue: 0,0:11:12.42,0:11:15.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menara Makam dijaga oleh empat pustakawan.
Dialogue: 0,0:11:15.67,0:11:19.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya penyihir yang lulus ujian\Nyang boleh masuk.
Dialogue: 0,0:11:20.13,0:11:22.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk masuk ke menara,\Nkau harus belajar dulu.
Dialogue: 0,0:11:24.05,0:11:24.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:11:25.64,0:11:27.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah senang
Dialogue: 0,0:11:28.18,0:11:30.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}mendengar bahwa kau mau belajar.
Dialogue: 0,0:11:31.14,0:11:33.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Merasa takut itu wajar.
Dialogue: 0,0:11:33.60,0:11:34.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:11:36.32,0:11:38.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}sihir yang masih digunakan…
Dialogue: 0,0:11:43.78,0:11:46.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}adalah cara untuk membawa kebahagiaan.
Dialogue: 0,0:11:48.12,0:11:49.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau ingin belajar,
Dialogue: 0,0:11:49.50,0:11:51.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}pelajarilah lebih banyak sihir yang baik.
Dialogue: 0,0:11:53.00,0:11:53.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekadar saran.
Dialogue: 0,0:11:55.08,0:11:56.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:11:57.42,0:11:59.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mau belajar! Guru Qifrey!
Dialogue: 0,0:12:03.97,0:12:05.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini kamarmu.
Dialogue: 0,0:12:09.10,0:12:10.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tampaknya, Agott sedang keluar.
Dialogue: 0,0:12:11.02,0:12:12.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Agott?
Dialogue: 0,0:12:12.44,0:12:14.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Teman sekamarmu.
Dialogue: 0,0:12:20.32,0:12:23.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada dua ruang kerja per kamar.
Dialogue: 0,0:12:23.11,0:12:24.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamar tidur masing-masing.
Dialogue: 0,0:12:27.32,0:12:31.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamarnya di bawah tangga bagian belakang.\NTenang, ada kuncinya.
Dialogue: 0,0:12:32.20,0:12:34.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau harus istirahat.
Dialogue: 0,0:12:34.58,0:12:37.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ada urusan,\Npanggil saja kalau butuh sesuatu.
Dialogue: 0,0:12:48.68,0:12:50.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini Qifrey.
Dialogue: 0,0:12:51.27,0:12:54.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih telah menerima Coco\Nsebagai murid.
Dialogue: 0,0:12:56.06,0:12:56.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:58.06,0:12:58.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:59.52,0:13:00.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belum saatnya membahas itu.
Dialogue: 0,0:13:01.03,0:13:03.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kondisinya belum stabil saat ini.
Dialogue: 0,0:13:05.95,0:13:09.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, ini kamar penyihir.
Dialogue: 0,0:13:10.53,0:13:12.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu mejaku.
Dialogue: 0,0:13:24.34,0:13:26.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mau turun, minggir.
Dialogue: 0,0:13:27.89,0:13:29.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:13:39.77,0:13:41.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau Agott, bukan?
Dialogue: 0,0:13:41.44,0:13:42.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Aku Coco…\N- Aku tahu.
Dialogue: 0,0:13:43.73,0:13:45.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang luar itu, bukan?
Dialogue: 0,0:13:46.36,0:13:49.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku dengar kau menjadi murid baru di sini.
Dialogue: 0,0:13:50.41,0:13:52.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku turut prihatin tentang situasi ibumu.
Dialogue: 0,0:13:54.62,0:13:55.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:55.83,0:13:57.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena ulahmu…
Dialogue: 0,0:14:00.25,0:14:02.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}ibumu sudah bukan manusia lagi.
Dialogue: 0,0:14:04.38,0:14:06.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ke sini untuk menyelamatkannya.
Dialogue: 0,0:14:07.59,0:14:08.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menjadi penyihir…
Dialogue: 0,0:14:11.51,0:14:13.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejak kecil,
Dialogue: 0,0:14:13.31,0:14:16.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku menggambar segel\Nhingga jariku ternoda tinta.
Dialogue: 0,0:14:16.23,0:14:18.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau bisa diterima setelah lulus ujian.
Dialogue: 0,0:14:18.77,0:14:21.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah itu, kau baru bisa menjadi murid.
Dialogue: 0,0:14:21.98,0:14:23.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau hanya orang bodoh biasa.
Dialogue: 0,0:14:24.44,0:14:27.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang luar sepertimu tak akan mampu.
Dialogue: 0,0:14:30.95,0:14:34.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku baru mencobanya\Ndan berhasil melakukannya.
Dialogue: 0,0:14:34.66,0:14:36.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku harus mencoba.
Dialogue: 0,0:14:36.25,0:14:38.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, buktikan.
Dialogue: 0,0:14:38.46,0:14:40.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Ikuti ujian besok.\N- Agott!
Dialogue: 0,0:14:40.62,0:14:41.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:14:41.83,0:14:43.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini waktunya
Dialogue: 0,0:14:44.34,0:14:46.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}untuk makan!
Dialogue: 0,0:14:52.05,0:14:53.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku lapar.
Dialogue: 0,0:14:53.68,0:14:54.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:14:55.26,0:14:58.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini pesta penyambutan Coco, bukan?
Dialogue: 0,0:14:58.23,0:14:59.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pesta…
Dialogue: 0,0:15:07.82,0:15:09.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sama seperti biasanya.
Dialogue: 0,0:15:10.40,0:15:12.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Guru! Bagaimana dengan pestanya?
Dialogue: 0,0:15:13.32,0:15:16.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini mendadak.\NKita akan merayakannya lain kali.
Dialogue: 0,0:15:17.29,0:15:18.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di mana Agott?
Dialogue: 0,0:15:18.45,0:15:20.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia mau makan di kamarnya.
Dialogue: 0,0:15:20.96,0:15:24.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan menyenangkan\Nkalau kita bisa makan bersama.
Dialogue: 0,0:15:24.75,0:15:26.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, mari makan.
Dialogue: 0,0:15:27.34,0:15:30.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar Coco yang memulainya.
Dialogue: 0,0:15:30.42,0:15:32.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa? Baiklah!
Dialogue: 0,0:15:33.47,0:15:34.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mari makan!
Dialogue: 0,0:15:35.14,0:15:36.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mari makan.
Dialogue: 0,0:15:44.15,0:15:45.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:15:45.36,0:15:48.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan begitu? Ini dipanggang di sini.
Dialogue: 0,0:15:49.15,0:15:50.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Guru koki yang hebat.
Dialogue: 0,0:15:50.99,0:15:51.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:15:52.70,0:15:54.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gandum lokalnya yang sangat bagus.
Dialogue: 0,0:16:03.83,0:16:06.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sayuran-sayuran lokalnya yang enak.
Dialogue: 0,0:16:07.34,0:16:09.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih atas makanannya.
Dialogue: 0,0:16:34.49,0:16:35.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ibu…
Dialogue: 0,0:16:45.50,0:16:49.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Diperlukan ujian untuk menjadi murid.
Dialogue: 0,0:16:50.34,0:16:55.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi tidak tertulis\Napa yang harus dilakukan.
Dialogue: 0,0:16:55.63,0:16:57.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang tidak tertulis?
Dialogue: 0,0:16:59.51,0:17:02.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Banyak hal tentang sihir\Nyang tak tertulis di buku.
Dialogue: 0,0:17:02.98,0:17:05.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk mempelajarinya,\Nkau harus mengalaminya.
Dialogue: 0,0:17:06.85,0:17:07.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:17:08.52,0:17:11.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bahan-bahannya.\NPeralatanmu untuk merapal mantra.
Dialogue: 0,0:17:14.78,0:17:17.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keren sekali!
Dialogue: 0,0:17:19.78,0:17:22.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tongkat sihir… pena.
Dialogue: 0,0:17:23.50,0:17:25.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku masih agak takut.
Dialogue: 0,0:17:25.71,0:17:26.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:17:27.46,0:17:30.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Aku akan mengembalikan Ibu seperti semula.{\i0}
Dialogue: 0,0:17:31.42,0:17:33.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku siap, Guru Qifrey.
Dialogue: 0,0:17:34.42,0:17:36.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, mari mulai.
Dialogue: 0,0:17:43.35,0:17:44.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:17:44.89,0:17:46.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita istirahat dulu?
Dialogue: 0,0:17:47.14,0:17:49.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, aku baik-baik saja.
Dialogue: 0,0:17:50.81,0:17:53.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coba ulangi apa saja yang kau pahami.
Dialogue: 0,0:17:54.03,0:17:55.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:17:56.28,0:17:57.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi…
Dialogue: 0,0:17:57.45,0:18:00.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mantra terdiri dari tiga elemen.
Dialogue: 0,0:18:01.83,0:18:03.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Sebuah "lambang sihir" di tengah{\i0}
Dialogue: 0,0:18:03.99,0:18:07.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}yang dikelilingi garis,\Nyang disebut "aksara,"{\i0}
Dialogue: 0,0:18:07.62,0:18:10.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}dan "lingkaran" yang melengkapi segel itu.{\i0}
Dialogue: 0,0:18:11.04,0:18:13.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Lambang sihir berbeda untuk api…{\i0}
Dialogue: 0,0:18:14.67,0:18:15.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}air,{\i0}
Dialogue: 0,0:18:16.38,0:18:17.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}cahaya,{\i0}
Dialogue: 0,0:18:18.55,0:18:19.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}dan angin…{\i0}
Dialogue: 0,0:18:19.59,0:18:22.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Itu yang menentukan jenis mantranya.{\i0}
Dialogue: 0,0:18:23.31,0:18:26.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aksara menentukan bentuk mantra,{\i0}
Dialogue: 0,0:18:26.48,0:18:28.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}{\i1}ukuran, dan arahnya.{\i0}
Dialogue: 0,0:18:29.94,0:18:32.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}Dengan melengkapi lingkaran luar,{\i0}
Dialogue: 0,0:18:33.02,0:18:36.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\i1}segel ditutup dan mantra diaktifkan.{\i0}
Dialogue: 0,0:18:37.44,0:18:40.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah kewalahan\Nhanya untuk menghafal itu.
Dialogue: 0,0:18:41.03,0:18:42.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kau berhasil!
Dialogue: 0,0:18:45.12,0:18:46.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan mencobanya.
Dialogue: 0,0:18:47.00,0:18:48.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagus. Itu baru semangat!
Dialogue: 0,0:19:05.22,0:19:07.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan dibuang!
Dialogue: 0,0:19:08.39,0:19:09.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:19:09.98,0:19:12.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tak bisa menunjukkan itu!
Dialogue: 0,0:19:12.48,0:19:16.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu jelek, semua garisnya\Ntampak bergelombang dan tidak rata.
Dialogue: 0,0:19:16.98,0:19:19.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu wajar. Kau baru saja mulai.
Dialogue: 0,0:19:19.99,0:19:23.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang lebih penting,\Nkau harus memperhatikan ini.
Dialogue: 0,0:19:23.87,0:19:26.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat? Lingkarannya terputus.
Dialogue: 0,0:19:26.74,0:19:29.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak terhubung,\Nmantra tidak akan aktif.
Dialogue: 0,0:19:33.25,0:19:36.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tangan cenderung tidak stabil\Nsaat menggunakan alat baru.
Dialogue: 0,0:19:36.96,0:19:39.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti anak kuda yang baru lahir.
Dialogue: 0,0:19:40.13,0:19:43.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau akan segera terbiasa\Ndan bisa berlarian dengan bebas.
Dialogue: 0,0:19:45.39,0:19:48.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang, tutup segel itu\Ndan coba aktifkan.
Dialogue: 0,0:20:03.74,0:20:06.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf! Aku tak sengaja.
Dialogue: 0,0:20:09.24,0:20:12.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf! Aku akan mengeringkannya!\NBiar kukeringkan!
Dialogue: 0,0:20:13.46,0:20:15.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tenang, Coco.\N- Sudah kering?
Dialogue: 0,0:20:15.50,0:20:16.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, Agott.
Dialogue: 0,0:20:16.67,0:20:17.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Kau tak apa-apa?\N- Belum?
Dialogue: 0,0:20:19.59,0:20:21.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:20:21.92,0:20:23.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak keberatan.
Dialogue: 0,0:20:24.38,0:20:27.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi bolehkah aku melihat segel Coco?
Dialogue: 0,0:20:27.60,0:20:29.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa? Tentu.
Dialogue: 0,0:20:31.35,0:20:32.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}Ini dia.
Dialogue: 0,0:20:37.19,0:20:38.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:20:39.23,0:20:41.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aksara yang ini lebih panjang.
Dialogue: 0,0:20:41.78,0:20:46.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tekanannya terlalu kuat\Ndan menyebabkan air menyembur.
Dialogue: 0,0:20:46.91,0:20:47.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti biasa,
Dialogue: 0,0:20:48.03,0:20:49.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}pengamatanmu tepat, Agott.
Dialogue: 0,0:20:51.25,0:20:54.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya, sepertinya, aku bisa\Nmenyerahkan Coco kepadamu.
Dialogue: 0,0:20:54.67,0:20:55.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:00.88,0:21:02.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan pergi beberapa hari.
Dialogue: 0,0:21:02.76,0:21:05.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan ke Aula Besar para penyihir.
Dialogue: 0,0:21:05.30,0:21:08.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Agott, tolong jaga Coco saat aku pergi.
Dialogue: 0,0:21:09.14,0:21:10.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik, Guru.
Dialogue: 0,0:21:12.14,0:21:13.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:21:13.56,0:21:15.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau bisa belajar banyak dari temanmu.
Dialogue: 0,0:21:16.02,0:21:18.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perhatikan dan pelajarilah sihir\Ndari Agott.
Dialogue: 0,0:21:20.19,0:21:22.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Guru…
Dialogue: 0,0:21:26.32,0:21:29.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maafkan aku. Aku…
Dialogue: 0,0:21:29.53,0:21:31.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berhentilah meminta maaf.
Dialogue: 0,0:21:31.54,0:21:33.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah bilang tidak keberatan.
Dialogue: 0,0:21:34.62,0:21:36.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang, Coco.
Dialogue: 0,0:21:37.71,0:21:41.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku memintamu membuktikan dirimu kemarin.
Dialogue: 0,0:21:41.80,0:21:44.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini waktunya untuk serius.
Dialogue: 0,0:21:45.34,0:21:47.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ujianmu dimulai sekarang.
Dialogue: 0,0:21:48.34,0:21:49.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:23:38.91,0:23:40.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana