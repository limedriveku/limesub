Dialogue: 0,0:03:11.94,0:03:14.19,tanda,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:23:36.66,0:23:38.95,tanda,,0000,0000,0000,,EPISODE 5\NLABIRIN NAGA
Dialogue: 0,0:00:03.62,0:00:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dari sekian banyak bentuk sihir,\Nada empat bentuk yang utama.{\i0}
Dialogue: 0,0:00:12.38,0:00:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Menyuburkan segala sesuatu\Ndan mengendalikan sumber kehidupan.{\i0}
Dialogue: 0,0:00:16.93,0:00:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lambang Sihir Air.{\i0}
Dialogue: 0,0:00:20.06,0:00:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mengubah batu menjadi pasir\Ndan pasir menjadi batu.{\i0}
Dialogue: 0,0:00:23.85,0:00:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penguasa perubahan dan gerak,{\i0}
Dialogue: 0,0:00:25.85,0:00:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lambang Sihir Tanah.{\i0}
Dialogue: 0,0:00:28.61,0:00:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Membawa ilmu melampaui batas,\Nmewujudkan perjalanan yang mustahil,{\i0}
Dialogue: 0,0:00:33.19,0:00:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan membawa kemajuan.{\i0}
Dialogue: 0,0:00:34.90,0:00:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lambang Sihir Ambalang.{\i0}
Dialogue: 0,0:00:37.82,0:00:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serta sebagai pedang\Ndan perisai bagi rakyat,{\i0}
Dialogue: 0,0:00:43.37,0:00:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lambang Sihir Api.{\i0}
Dialogue: 0,0:00:46.62,0:00:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Para penyihir mengenal\Nempat lambang sihir ini{\i0}
Dialogue: 0,0:00:48.96,0:00:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sebagai Empat Lambang Sihir Utama.{\i0}
Dialogue: 0,0:00:53.26,0:00:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa kau mau berlatih menggambarnya?
Dialogue: 0,0:01:16.86,0:01:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka! Bagaimana ini?
Dialogue: 0,0:01:24.20,0:01:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:01:26.75,0:01:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Tetia.
Dialogue: 0,0:01:28.54,0:01:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas terima kasihmu!
Dialogue: 0,0:01:30.75,0:01:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan, Coco?
Dialogue: 0,0:01:33.55,0:01:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menggambar sihir bola api\Nuntuk berlatih sihir ambalang.
Dialogue: 0,0:01:38.84,0:01:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambang Sihir Api bisa berbahaya
Dialogue: 0,0:01:41.35,0:01:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena ukuran dan keseimbangan sesuatu\Nyang tak berwujud harus dijaga.
Dialogue: 0,0:01:44.85,0:01:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus berhati-hati, ya.
Dialogue: 0,0:01:46.77,0:01:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berhati-hati.
Dialogue: 0,0:01:52.15,0:01:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menaklukkan ujian Pegunungan Dadah\Ndengan mudah,
Dialogue: 0,0:01:55.61,0:01:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, kenapa berlatih sihir ambalang?
Dialogue: 0,0:01:58.78,0:02:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terbang secepat kilat, bukan?
Dialogue: 0,0:02:00.41,0:02:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti anak panah yang memelesat!
Dialogue: 0,0:02:03.95,0:02:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merusak sepatu sylph\Nyang kupinjam dari Agott waktu itu.
Dialogue: 0,0:02:09.17,0:02:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku ingin memperbaikinya\Nsebelum mengembalikannya.{\i0}
Dialogue: 0,0:02:12.71,0:02:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tinggal menggambar ulang segelnya,
Dialogue: 0,0:02:15.76,0:02:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi garis-garis gambarku\Nmasih tidak rata.
Dialogue: 0,0:02:19.84,0:02:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin tongkat penamu tidak pas.
Dialogue: 0,0:02:24.68,0:02:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat dan rasanya di tanganmu\Nbisa sangat berpengaruh.
Dialogue: 0,0:02:29.10,0:02:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tongkat lamaku,
Dialogue: 0,0:02:31.94,0:02:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau mungkin ingin coba memegang\Nbeberapa tongkat untuk dipilih.
Dialogue: 0,0:02:39.07,0:02:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Coco! Kita ke toko alat tulis!
Dialogue: 0,0:02:41.53,0:02:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko alat tulis?
Dialogue: 0,0:02:42.74,0:02:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, toko alat tulis sihir\Nyang menjual semua alat sihir.
Dialogue: 0,0:02:47.83,0:02:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko alat tulis sihir?
Dialogue: 0,0:02:49.21,0:02:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita ke toko alat tulis.
Dialogue: 0,0:02:50.96,0:02:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko alat tulis sihir?
Dialogue: 0,0:02:53.71,0:02:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti mimpi yang jadi nyata!
Dialogue: 0,0:02:55.96,0:02:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Coco?
Dialogue: 0,0:02:57.71,0:03:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang menghayati momen ini,\Nberi aku waktu sebentar.
Dialogue: 0,0:04:47.99,0:04:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu Kalhn, sebuah kota di Hutan Rawa.
Dialogue: 0,0:04:50.37,0:04:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Pulau yang ada di gosong itu\Nadalah kota penyihir terbesar wilayah ini.
Dialogue: 0,0:05:05.09,0:05:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:05:06.72,0:05:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel untuk mengembangkan rok…
Dialogue: 0,0:05:08.97,0:05:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, tongkatku bisa dipakai\Ndengan tinta sihirku.
Dialogue: 0,0:05:11.47,0:05:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak penyihir!
Dialogue: 0,0:05:14.27,0:05:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi dari pulau sungai ini
Dialogue: 0,0:05:16.23,0:05:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mulanya menara pengawas yang dibangun\Noleh penyihir guna melindungi kota{\i0}
Dialogue: 0,0:05:20.48,0:05:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dari naga tahi lalat yang hidup\Ndi Hutan Rawa di seberang sungai.{\i0}
Dialogue: 0,0:05:24.36,0:05:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir berkumpul\Ndan tempat ini menjadi distrik sanggar,
Dialogue: 0,0:05:27.24,0:05:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan sekarang…
Dialogue: 0,0:05:28.16,0:05:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Qifrey, Coco tidak mendengarkan.
Dialogue: 0,0:05:30.20,0:05:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf,
Dialogue: 0,0:05:31.12,0:05:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau aku ikut jalan-jalan dengan Coco,
Dialogue: 0,0:05:33.66,0:05:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu akan buang-buang waktu,
Dialogue: 0,0:05:35.37,0:05:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, aku akan pergi duluan.\NAda toko yang ingin kulihat.
Dialogue: 0,0:05:38.83,0:05:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temui kami di toko alat tulis\Nsaat kembali, ya?
Dialogue: 0,0:05:43.38,0:05:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hubunganmu dengan Agott?
Dialogue: 0,0:05:47.13,0:05:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa,
Dialogue: 0,0:05:49.01,0:05:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin kami lebih dekat.
Dialogue: 0,0:06:05.36,0:06:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:06:07.99,0:06:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sini!
Dialogue: 0,0:06:16.54,0:06:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti mimpi…
Dialogue: 0,0:06:36.97,0:06:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco! Nanti kita bisa terpisah!
Dialogue: 0,0:06:46.32,0:06:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalhn memang selalu ramai, ya?
Dialogue: 0,0:06:48.65,0:06:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak lelah.
Dialogue: 0,0:06:51.99,0:06:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia toko alat tulisnya.
Dialogue: 0,0:06:53.87,0:06:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Bertabur Bintang.
Dialogue: 0,0:07:20.06,0:07:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pohon di dalam toko.
Dialogue: 0,0:07:22.73,0:07:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat itu.
Dialogue: 0,0:07:24.61,0:07:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang murid penyihir merasa terkejut\Nmelihat pohon perak?
Dialogue: 0,0:07:31.90,0:07:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal sederhana begini saja kau tak tahu?
Dialogue: 0,0:07:35.24,0:07:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu.
Dialogue: 0,0:07:36.95,0:07:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco baru saja menjadi murid.
Dialogue: 0,0:07:41.75,0:07:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia adalah gadis itu?
Dialogue: 0,0:07:46.42,0:07:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dia tak tahu!
Dialogue: 0,0:07:48.96,0:07:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, maaf, Nona.
Dialogue: 0,0:07:51.80,0:07:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak tahu tentangmu,\Njadi, kita impas.
Dialogue: 0,0:07:58.26,0:08:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Pak Nolnoa.
Dialogue: 0,0:08:00.02,0:08:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemilik toko alat tulis\NPedang Bertabur Bintang!
Dialogue: 0,0:08:03.44,0:08:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:04.85,0:08:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua komponen yang kau temukan di sini\Ndibuat olehku dan cucuku, Tartah.
Dialogue: 0,0:08:10.03,0:08:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat pena, tinta, kami punya semuanya.
Dialogue: 0,0:08:14.70,0:08:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan bisa mengekstrak tinta sihir\Ndengan konsentrasi yang kau suka.
Dialogue: 0,0:08:18.33,0:08:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengekstrak?
Dialogue: 0,0:08:23.00,0:08:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco, ya?
Dialogue: 0,0:08:24.21,0:08:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunjukkannya. Ikut aku.
Dialogue: 0,0:08:27.00,0:08:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:09:21.06,0:09:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi hitam!
Dialogue: 0,0:09:22.64,0:09:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu getah pohon perak.
Dialogue: 0,0:09:24.35,0:09:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahannya berwarna putih keperakan\Nsaat masih sehat,
Dialogue: 0,0:09:27.52,0:09:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi akan menghitam saat layu.
Dialogue: 0,0:09:30.61,0:09:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini beracun baik bagi pohon\Nmaupun manusia dalam bentuk ini,
Dialogue: 0,0:09:35.99,0:09:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi setelah direbus
Dialogue: 0,0:09:38.32,0:09:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ditiriskan sisa cairannya…
Dialogue: 0,0:09:42.66,0:09:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini menjadi sumber sihir.\NTinta sihir mentah.
Dialogue: 0,0:09:50.17,0:09:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinta biasa dibuat dengan mengumpulkan\Njelaga dari asap kayu yang dibakar,
Dialogue: 0,0:09:55.42,0:09:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tinta sihir berbeda.
Dialogue: 0,0:09:57.05,0:10:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini dibuat dengan mengambil getah\Ndari pohon itu.{\i0}
Dialogue: 0,0:10:01.05,0:10:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu sebabnya pohon perak{\i0}
Dialogue: 0,0:10:04.02,0:10:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sangat istimewa bagi penyihir.{\i0}
Dialogue: 0,0:10:06.31,0:10:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:07.94,0:10:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anehnya, kau tak bisa mendapatkannya\Ndari pohon lain.
Dialogue: 0,0:10:11.31,0:10:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pohon yang luar biasa.
Dialogue: 0,0:10:13.11,0:10:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat penting.
Dialogue: 0,0:10:14.36,0:10:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar! Bahkan ada legenda kuno tentangnya.
Dialogue: 0,0:10:18.11,0:10:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benar.{\i0}
Dialogue: 0,0:10:19.41,0:10:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dahulu kala, sebuah pohon perak\Njatuh cinta kepada seorang penyihir,{\i0}
Dialogue: 0,0:10:23.78,0:10:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}begitulah menurut legenda.{\i0}
Dialogue: 0,0:10:25.75,0:10:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Getahnya ditawarkan sebagai tinta sihir\Ndan dahannya sebagai tongkat…
Dialogue: 0,0:10:29.46,0:10:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tongkat!\N- Apa?
Dialogue: 0,0:10:32.17,0:10:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau datang untuk membeli tongkat?
Dialogue: 0,0:10:35.00,0:10:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:43.55,0:10:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:10:45.47,0:10:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencobanya…
Dialogue: 0,0:10:54.73,0:10:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memberikan ini.
Dialogue: 0,0:10:59.36,0:11:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti akan menemukan\Ntongkat yang sempurna.
Dialogue: 0,0:11:07.83,0:11:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat seperti apa yang cocok, ya?
Dialogue: 0,0:11:09.87,0:11:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka tongkat yang ringan.
Dialogue: 0,0:11:12.88,0:11:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang terbaik, ya?
Dialogue: 0,0:11:19.76,0:11:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:11:26.18,0:11:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:11:28.31,0:11:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:11:30.02,0:11:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu.
Dialogue: 0,0:11:31.10,0:11:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Coco akan tersesat kalau sendirian.
Dialogue: 0,0:11:33.85,0:11:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita kejar!
Dialogue: 0,0:11:47.41,0:11:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:49.16,0:11:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:11:51.00,0:11:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:55.33,0:11:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga ikut!
Dialogue: 0,0:11:56.88,0:11:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu…
Dialogue: 0,0:11:59.80,0:12:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:29.49,0:12:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco! Tunggu!
Dialogue: 0,0:12:34.67,0:12:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Coco!
Dialogue: 0,0:12:52.85,0:12:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan, Coco?
Dialogue: 0,0:12:54.19,0:12:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ke mana?
Dialogue: 0,0:12:55.64,0:12:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana? Aku melihatnya!\NOrang yang menjual buku sihir terlarang.
Dialogue: 0,0:12:59.69,0:13:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir itu!
Dialogue: 0,0:13:03.28,0:13:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:04.53,0:13:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini selalu membuat keributan.
Dialogue: 0,0:13:06.70,0:13:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku senang kita tak terpisah!
Dialogue: 0,0:13:09.20,0:13:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, bukan? Ayo kembali.
Dialogue: 0,0:13:10.95,0:13:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:13:12.83,0:13:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hanya berbelok satu gang,\Ntapi semuanya jadi sangat berbeda.
Dialogue: 0,0:13:17.42,0:13:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Kuas juga tak ada.
Dialogue: 0,0:13:19.67,0:13:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dilihat lagi,
Dialogue: 0,0:13:21.92,0:13:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pemandangannya benar-benar berbeda.
Dialogue: 0,0:13:28.09,0:13:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalhn tak punya dinding dan lantai\Ndari batu putih begini.
Dialogue: 0,0:13:33.31,0:13:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti
Dialogue: 0,0:13:35.06,0:13:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini bukan Kalhn.
Dialogue: 0,0:13:38.10,0:13:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:13:39.81,0:13:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak melewati jendela jalan\Natau melakukan teleportasi!
Dialogue: 0,0:13:43.69,0:13:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memeriksa situasi dari langit!
Dialogue: 0,0:13:47.82,0:13:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tetia mungkin ada benarnya.
Dialogue: 0,0:13:50.16,0:13:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa?
Dialogue: 0,0:13:51.83,0:13:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mungkin diteleportasi\Ntanpa kita sadari.
Dialogue: 0,0:13:55.58,0:13:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tapi bukankah sihir seperti itu\Ntidak diizinkan?
Dialogue: 0,0:13:59.79,0:14:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu adalah…
Dialogue: 0,0:14:01.96,0:14:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir terlarang.
Dialogue: 0,0:14:04.55,0:14:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Kita sama sekali bukan di Kalhn!
Dialogue: 0,0:14:07.84,0:14:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera kabur!
Dialogue: 0,0:14:09.26,0:14:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:14:10.59,0:14:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia! Ada apa?
Dialogue: 0,0:14:12.22,0:14:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia, tenanglah. Apa yang kau lihat?
Dialogue: 0,0:14:15.64,0:14:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya aku yang melihatnya.\NDia juga melihatku!
Dialogue: 0,0:14:20.98,0:14:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ada urusan dengan yang lain, tapi…
Dialogue: 0,0:14:37.79,0:14:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Coco, selamat datang{\i0}
Dialogue: 0,0:14:40.08,0:14:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}di dunia sihir.{\i0}
Dialogue: 0,0:14:46.34,0:14:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau satu-satunya harapan kami.{\i0}
Dialogue: 0,0:14:51.84,0:14:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pak Nolnoa.{\i0}
Dialogue: 0,0:14:53.30,0:14:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau melihat murid-muridku?
Dialogue: 0,0:14:55.93,0:14:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka bosan, lalu jalan-jalan?
Dialogue: 0,0:14:59.31,0:15:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bosan? Tidak mungkin!
Dialogue: 0,0:15:00.73,0:15:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini toko yang paling menyenangkan!
Dialogue: 0,0:15:03.15,0:15:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melihat-lihat seharian!
Dialogue: 0,0:15:04.77,0:15:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Cukup. Kau membuatku malu saja.
Dialogue: 0,0:15:07.69,0:15:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:15:08.94,0:15:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka bukan tipe anak-anak\Nyang pergi tanpa berterima kasih.
Dialogue: 0,0:15:12.70,0:15:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana mereka?
Dialogue: 0,0:15:14.37,0:15:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku mengawasi mereka,
Dialogue: 0,0:15:17.08,0:15:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mengejar penyihir\Nyang berpakaian aneh.
Dialogue: 0,0:15:21.08,0:15:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semacam topeng berbentuk bola mata.
Dialogue: 0,0:15:36.64,0:15:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak.
Dialogue: 0,0:15:38.35,0:15:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengalihkan pandanganmu.
Dialogue: 0,0:15:40.02,0:15:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur perlahan.
Dialogue: 0,0:15:42.69,0:15:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil kita mundur,\Naku akan memberi sinyal, lalu kita lari.
Dialogue: 0,0:15:57.74,0:15:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang…
Dialogue: 0,0:15:59.95,0:16:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap tenang…
Dialogue: 0,0:16:07.84,0:16:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:16:24.56,0:16:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan kita, lari!
Dialogue: 0,0:16:33.99,0:16:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott, tadi itu hebat! Apa itu sihir api?
Dialogue: 0,0:16:37.28,0:16:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir lambang api.\NPanah yang terbungkus angin.
Dialogue: 0,0:16:40.24,0:16:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menggambarnya secepat itu?
Dialogue: 0,0:16:42.50,0:16:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:16:44.16,0:16:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah menyiapkan segel\Ndi buku telapakmu,
Dialogue: 0,0:16:47.13,0:16:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tinggal menutup lingkarannya
Dialogue: 0,0:16:48.79,0:16:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengaktifkan sihirnya.
Dialogue: 0,0:16:50.63,0:16:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali, Agott! Kau keren!
Dialogue: 0,0:16:53.42,0:16:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau paham situasi kita saat ini?
Dialogue: 0,0:16:56.34,0:16:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:16:57.64,0:16:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, ini jalan buntu!
Dialogue: 0,0:17:00.68,0:17:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cari jalan lain…
Dialogue: 0,0:17:07.19,0:17:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:17:09.23,0:17:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga itu akan menangkap dan memakan kita!
Dialogue: 0,0:17:15.86,0:17:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau mati.
Dialogue: 0,0:17:18.24,0:17:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku masih belum menciptakan\Nsihir apa pun bagi dunia ini!
Dialogue: 0,0:17:21.87,0:17:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bagaimana ini bisa terjadi?
Dialogue: 0,0:17:33.42,0:17:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia, tenanglah.
Dialogue: 0,0:17:35.47,0:17:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita adalah murid penyihir.
Dialogue: 0,0:17:38.26,0:17:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kita akan mengatasi ini dengan sihir.
Dialogue: 0,0:17:41.64,0:17:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ya.
Dialogue: 0,0:17:45.18,0:17:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuat lubang\Ndengan segel penghancur dinding.
Dialogue: 0,0:17:48.23,0:17:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh dan Tetia, ulur waktu.
Dialogue: 0,0:17:50.31,0:17:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik.\N- Siap.
Dialogue: 0,0:17:51.98,0:17:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Di mana aku harus menggambarnya?
Dialogue: 0,0:17:54.74,0:17:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sebelah sana.
Dialogue: 0,0:17:55.90,0:17:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahkan panah…
Dialogue: 0,0:17:57.78,0:17:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Agott, kemarilah sebentar!
Dialogue: 0,0:17:59.99,0:18:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Matanya{\i0}
Dialogue: 0,0:18:01.37,0:18:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menunjukkan bahwa dia menyalahkanku.{\i0}
Dialogue: 0,0:18:04.66,0:18:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mari kita gunakan itu untuk saat ini.
Dialogue: 0,0:18:08.12,0:18:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan{\i0}
Dialogue: 0,0:18:09.63,0:18:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia memang benar.{\i0}
Dialogue: 0,0:18:18.47,0:18:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon…
Dialogue: 0,0:18:22.51,0:18:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbanglah!
Dialogue: 0,0:18:32.90,0:18:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu akan sedikit mengulur waktu!
Dialogue: 0,0:18:35.15,0:18:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kerja bagus, Tetia.
Dialogue: 0,0:18:36.90,0:18:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bagus.
Dialogue: 0,0:18:38.36,0:18:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia luar biasa.
Dialogue: 0,0:18:49.04,0:18:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu…
Dialogue: 0,0:18:51.00,0:18:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Agott!
Dialogue: 0,0:18:55.71,0:18:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Aku…
Dialogue: 0,0:18:57.92,0:19:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau pikirkan?\NKenapa kau menyentuhku saat menggambar?
Dialogue: 0,0:19:01.26,0:19:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Aku tak sengaja!
Dialogue: 0,0:19:03.26,0:19:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak sengaja?
Dialogue: 0,0:19:05.31,0:19:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:19:06.52,0:19:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat ibumu jadi batu,
Dialogue: 0,0:19:08.77,0:19:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyeret kami dalam bahaya…
Dialogue: 0,0:19:11.15,0:19:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan bilang\Nsemua itu tak sengaja, bukan?
Dialogue: 0,0:19:13.77,0:19:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua salahmu, Coco!
Dialogue: 0,0:19:16.53,0:19:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini tak berilmu dan tak berpendidikan.
Dialogue: 0,0:19:18.99,0:19:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, diam saja!
Dialogue: 0,0:19:24.78,0:19:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:19:27.20,0:19:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada waktu untuk menggambar ulang.
Dialogue: 0,0:19:29.54,0:19:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mencari jalan lain…
Dialogue: 0,0:19:31.58,0:19:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:19:39.88,0:19:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai!
Dialogue: 0,0:19:41.97,0:19:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah. Kerja bagus, Richeh.
Dialogue: 0,0:19:44.30,0:19:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari segera menyingkir dari semua ini.
Dialogue: 0,0:19:50.89,0:19:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, dari tempat ini.
Dialogue: 0,0:19:54.44,0:19:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kau saja\Ningin mengartikannya seperti apa.
Dialogue: 0,0:20:02.61,0:20:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetia.
Dialogue: 0,0:20:28.56,0:20:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Guru Qifrey,{\i0}
Dialogue: 0,0:20:30.89,0:20:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}apa yang harus aku lakukan?{\i0}
Dialogue: 0,0:20:39.65,0:20:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Qifrey!
Dialogue: 0,0:20:41.61,0:20:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau menemukan mereka?
Dialogue: 0,0:20:45.45,0:20:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Setidaknya, mereka tidak di luar…
Dialogue: 0,0:20:49.37,0:20:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak terduga.
Dialogue: 0,0:20:50.74,0:20:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Bertopeng\Nmelakukan kontak langsung.
Dialogue: 0,0:20:54.37,0:20:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:20:59.21,0:21:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi, itu Penyihir Bertopeng.
Dialogue: 0,0:21:01.38,0:21:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak kuduga mereka akan muncul di sini.
Dialogue: 0,0:21:06.51,0:21:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka menyembunyikan wajah mereka\Ndi balik topi dan topeng kuno.{\i0}
Dialogue: 0,0:21:10.64,0:21:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka kelompok berbahaya\Npengguna sihir terlarang.{\i0}
Dialogue: 0,0:21:14.94,0:21:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku pikir Coco bisa memberiku petunjuk,{\i0}
Dialogue: 0,0:21:18.36,0:21:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ternyata mereka melakukan kontak langsung.{\i0}
Dialogue: 0,0:21:22.86,0:21:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tartah.
Dialogue: 0,0:21:24.24,0:21:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau ingat hal lain? Apa pun?
Dialogue: 0,0:21:27.86,0:21:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, maaf,
Dialogue: 0,0:21:30.28,0:21:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak terlalu ingat.
Dialogue: 0,0:21:32.24,0:21:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:21:34.50,0:21:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:21:42.55,0:21:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman kuas yang dibawa Coco.
Dialogue: 0,0:21:45.09,0:21:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bersama mereka tadi?
Dialogue: 0,0:21:48.26,0:21:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu ke mana mereka?
