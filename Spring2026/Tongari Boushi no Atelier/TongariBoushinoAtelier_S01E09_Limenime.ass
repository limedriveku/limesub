Dialogue: 0,0:06:31.84,0:06:34.18,sign,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:23:36.58,0:23:39.25,sign,,0000,0000,0000,,EPISODE 10\NJANJI PERAK
Dialogue: 0,0:00:01.62,0:00:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hei, selamat datang.
Dialogue: 0,0:00:03.00,0:00:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ada perlu apa?\NMau ambil pesanan waktu itu?
Dialogue: 0,0:00:05.79,0:00:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ya, aku mau ambil pesanan tinta sihirku.
Dialogue: 0,0:00:09.38,0:00:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkatku juga retak.\NAku mau memperbaikinya.
Dialogue: 0,0:00:13.01,0:00:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cahaya itu sangat terang.{\i0}
Dialogue: 0,0:00:15.76,0:00:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aneh Kakek tidak melihatnya.{\i0}
Dialogue: 0,0:00:19.56,0:00:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin Tuan Qifrey tahu sesuatu.{\i0}
Dialogue: 0,0:00:23.94,0:00:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Atau mungkinkah dia…{\i0}
Dialogue: 0,0:00:34.65,0:00:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku… Aku minta maaf!
Dialogue: 0,0:00:38.78,0:00:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggunakan Pengumpul Angin\Nhanya untuk memetik apel gunung?
Dialogue: 0,0:00:42.66,0:00:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, segelmu agak terlalu besar, ya?
Dialogue: 0,0:00:46.17,0:00:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Awalnya, aku menggambar\Nlingkaran yang kecil.
Dialogue: 0,0:00:50.05,0:00:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apelnya hanya goyang, aku pikir\Nharus buat yang lebih kuat, tapi…
Dialogue: 0,0:00:54.30,0:00:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau menggambar panah tarik,\Nlalu memutarnya?
Dialogue: 0,0:00:57.80,0:01:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, waktu memetik apel,\Nkau memutarnya.
Dialogue: 0,0:01:00.93,0:01:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemikiran bagus.
Dialogue: 0,0:01:02.18,0:01:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mengubah panah\Nagar sesuai dengan tujuan,
Dialogue: 0,0:01:04.85,0:01:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sihir bisa dipakai untuk apa saja.
Dialogue: 0,0:01:09.94,0:01:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gagal, cari alasannya.
Dialogue: 0,0:01:12.65,0:01:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kalau berhasil,\Npertanyakan alasannya.
Dialogue: 0,0:01:15.53,0:01:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan rutin itu untuk mengenali\Ndan memperbaiki kekurangan.
Dialogue: 0,0:01:19.32,0:01:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Evaluasi itu bukan sekadar mengulang.\NBenar, Guru?
Dialogue: 0,0:01:22.70,0:01:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat.
Dialogue: 0,0:01:24.45,0:01:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pandai mengajar, Guru Tetia.
Dialogue: 0,0:01:29.08,0:01:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Tetia?
Dialogue: 0,0:01:32.21,0:01:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali! Aku malu!
Dialogue: 0,0:01:34.13,0:01:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba katakan sekali lagi!
Dialogue: 0,0:01:39.80,0:01:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau punya waktu\Nuntuk mengurus orang lain?
Dialogue: 0,0:01:43.31,0:01:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu masih kurang pengalaman,
Dialogue: 0,0:01:45.89,0:01:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa tidak melatih dirimu sendiri?
Dialogue: 0,0:01:52.69,0:01:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pasti berlatih, jadi ajari kami!
Dialogue: 0,0:01:55.44,0:01:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku tak memanggil kalian!
Dialogue: 0,0:01:57.86,0:02:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu sibuk belajar,\Njadi tak ada waktu bermain.
Dialogue: 0,0:02:06.33,0:02:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada ujian seperti Persetujuan Takhta\Ndari Pegunungan Dadah di tempat lain?
Dialogue: 0,0:02:12.34,0:02:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:02:15.09,0:02:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lima, tapi aku tak paham apa gunanya.
Dialogue: 0,0:02:17.59,0:02:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menggambar tanpa perlu ujian.
Dialogue: 0,0:02:19.97,0:02:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuannya untuk menguji\Ndan memahami dirimu sendiri.
Dialogue: 0,0:02:23.72,0:02:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu bermakna atau tidak\Ntergantung pada pendekatan kalian.
Dialogue: 0,0:02:28.98,0:02:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja, kalau bukan kemauan sendiri,\Nakan sulit menikmati apa pun.
Dialogue: 0,0:02:35.69,0:02:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, penyihir dulu\Njuga mengalami hal yang sama.
Dialogue: 0,0:02:39.11,0:02:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir ada untuk membuat orang bahagia.
Dialogue: 0,0:02:42.41,0:02:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau para murid menderita,\Nitu akan jadi percuma.
Dialogue: 0,0:02:45.70,0:02:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, Tiga Sage memutuskan
Dialogue: 0,0:02:47.62,0:02:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membuat ujian petualangan dunia luar\Nyang ingin diikuti semua orang.
Dialogue: 0,0:02:56.42,0:02:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dapatkan persetujuannya dan jadilah murid.{\i0}
Dialogue: 0,0:02:59.05,0:03:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujian tahap pertama, Persetujuan Takhta.{\i0}
Dialogue: 0,0:03:02.34,0:03:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Buktikan baktimu dan dampingi gurumu.{\i0}
Dialogue: 0,0:03:04.68,0:03:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujian tahap kedua, Kesetiaan Ksatria.{\i0}
Dialogue: 0,0:03:08.39,0:03:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ikuti jalan yang benar,\Nkunci dalam genggaman.{\i0}
Dialogue: 0,0:03:10.98,0:03:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujian tahap ketiga,\NPertanyaan Penjaga Gerbang.{\i0}
Dialogue: 0,0:03:14.52,0:03:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Wujudkan keinginanmu\Ndan berdirilah di atas kakimu.{\i0}
Dialogue: 0,0:03:16.98,0:03:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujian tahap keempat, Restu Sang Ratu.{\i0}
Dialogue: 0,0:03:20.57,0:03:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kaulah sang pengajar.{\i0}
Dialogue: 0,0:03:23.07,0:03:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujian tahap kelima, Ajaran Sage.{\i0}
Dialogue: 0,0:03:26.45,0:03:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah Ujian Pentagram penyihir.
Dialogue: 0,0:03:29.70,0:03:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap langkah menambah sihir\Ndan pekerjaan yang bisa kalian lakukan.
Dialogue: 0,0:03:35.71,0:03:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian tahap keempat\Nadalah kelulusan kalian
Dialogue: 0,0:03:38.55,0:03:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai penyihir mandiri.
Dialogue: 0,0:03:40.72,0:03:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baru bisa ikut Ujian Pustakawan\Nsetelah ujian tahap ketiga.
Dialogue: 0,0:03:48.10,0:03:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian yang terakhir\Nadalah memiliki murid sendiri.
Dialogue: 0,0:03:50.85,0:03:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan pikirkan kelulusan dulu.
Dialogue: 0,0:03:53.98,0:03:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:55.23,0:03:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sering memikirkan\Nkehidupan setelah lulus.
Dialogue: 0,0:03:59.40,0:04:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bepergian ke tempat yang jauh,\Nmembantu semua orang dengan sihir.
Dialogue: 0,0:04:05.70,0:04:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendengar semua orang\Ndari seluruh dunia berterima kasih padaku.
Dialogue: 0,0:04:10.12,0:04:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang berterima kasih\Ndan yang menerima ucapan terima kasih.
Dialogue: 0,0:04:14.62,0:04:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu mantra, dua jenis kebahagiaan.
Dialogue: 0,0:04:17.25,0:04:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu luar biasa?
Dialogue: 0,0:04:19.38,0:04:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil menyelam minum air.\NSama-sama diuntungkan!
Dialogue: 0,0:04:22.63,0:04:26.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebahagiaan itu\Nselalu datang berpasangan, tahu tidak?
Dialogue: 0,0:04:26.39,0:04:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi, aku ingin cepat dewasa\Ndan mendesain topi penyihir bertanduk dua.
Dialogue: 0,0:04:31.98,0:04:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jadi, itu arti gaya rambutmu!
Dialogue: 0,0:04:34.19,0:04:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Setelah jadi penyihir mandiri,\Nkau bisa memilih topimu sendiri.
Dialogue: 0,0:04:38.40,0:04:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak suka ujian.
Dialogue: 0,0:04:41.99,0:04:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu merepotkan.
Dialogue: 0,0:04:43.40,0:04:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau menggambar sihir\Nyang tak kusukai hanya karena disuruh.
Dialogue: 0,0:04:48.24,0:04:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya menggambar\Nsihir yang kau suka…
Dialogue: 0,0:04:52.66,0:04:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perbendaharaanmu tidak akan berkembang.
Dialogue: 0,0:05:02.46,0:05:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak peduli.
Dialogue: 0,0:05:04.76,0:05:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menjadi dewasa\Nberarti melakukan hal yang tak disukai,
Dialogue: 0,0:05:09.35,0:05:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan tetap seperti ini.
Dialogue: 0,0:05:12.14,0:05:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang duluan.
Dialogue: 0,0:05:15.52,0:05:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Richeh…
Dialogue: 0,0:05:16.73,0:05:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci kalau harus tetap seperti ini.
Dialogue: 0,0:05:20.73,0:05:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih punya banyak kelemahan.
Dialogue: 0,0:05:22.90,0:05:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin segera mengikuti setiap ujian.
Dialogue: 0,0:05:26.03,0:05:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan suatu hari,\Naku akan menjadi pustakawan Menara Makam.
Dialogue: 0,0:05:30.28,0:05:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin dewasa saat ini juga kalau bisa.
Dialogue: 0,0:05:34.79,0:05:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Agott adalah keturunan dari murid\Nyang menerima ingatan Tiga Sage.
Dialogue: 0,0:05:39.88,0:05:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pustakawan sejak dulu.
Dialogue: 0,0:05:41.79,0:05:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah,\Nnamanya keluarga Arklaum.
Dialogue: 0,0:05:46.42,0:05:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, Agott juga ingin ke Menara Makam.{\i0}
Dialogue: 0,0:05:51.01,0:05:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco bagaimana?
Dialogue: 0,0:05:53.14,0:05:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin menjadi penyihir seperti apa?
Dialogue: 0,0:05:55.89,0:05:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memulai dengan situasi yang berbeda.
Dialogue: 0,0:05:59.31,0:06:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tujuanku sudah ditetapkan.
Dialogue: 0,0:06:04.69,0:06:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku harus mempelajari\Nlebih banyak sihir untuk kugunakan dulu.
Dialogue: 0,0:06:09.20,0:06:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:10.45,0:06:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mari gambar Pengumpul Angin sekali lagi!\N- Ayo!
Dialogue: 0,0:06:13.45,0:06:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gambar dan kau akan belajar.\NPelajari dan kau akan menguasainya.{\i0}
Dialogue: 0,0:06:17.21,0:06:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kekuatan yang dibangun dengan cara itu\Npasti akan membuahkan hasil.{\i0}
Dialogue: 0,0:07:57.10,0:07:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Di mana yang lain?
Dialogue: 0,0:07:59.68,0:08:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah gelap. Sejak kapan malam tiba?
Dialogue: 0,0:08:03.02,0:08:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:08:10.15,0:08:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:08:13.57,0:08:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:08:15.41,0:08:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu! Maafkan aku.
Dialogue: 0,0:08:17.83,0:08:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua salahku.\NAku yang harus disalahkan.
Dialogue: 0,0:08:20.70,0:08:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bermaksud menyakiti siapa pun.
Dialogue: 0,0:08:22.79,0:08:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak bisa melupakan sihir…
Dialogue: 0,0:08:28.63,0:08:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Inilah alasan Ibu terus mengingatkanmu.{\i0}
Dialogue: 0,0:08:32.38,0:08:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sihir bukan untuk orang biasa.{\i0}
Dialogue: 0,0:08:36.39,0:08:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu…
Dialogue: 0,0:08:37.39,0:08:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau hanya orang bodoh biasa.{\i0}
Dialogue: 0,0:08:40.35,0:08:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini semua salahmu, Coco.{\i0}
Dialogue: 0,0:08:43.39,0:08:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Membuat ibumu jadi batu,\Nmenyeret kami dalam bahaya.{\i0}
Dialogue: 0,0:08:48.19,0:08:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau akan bilang\Nsemua itu tak sengaja, bukan?{\i0}
Dialogue: 0,0:08:52.53,0:08:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak mau terlibat\Ndengan Penyihir Bertopeng.{\i0}
Dialogue: 0,0:08:54.95,0:08:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada hal yang bisa dilakukan\Ndan ada yang tidak.{\i0}
Dialogue: 0,0:08:57.78,0:09:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak boleh ada pengecualian.{\i0}
Dialogue: 0,0:09:00.28,0:09:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu dirahasiakan\Nuntuk mencegah hal seperti ini.{\i0}
Dialogue: 0,0:09:15.88,0:09:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terjadi karena kau menginginkan sihir.
Dialogue: 0,0:09:19.30,0:09:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua salahmu.
Dialogue: 0,0:09:22.01,0:09:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dunia ini hancur berantakan\Nkarena kesalahanmu!{\i0}
Dialogue: 0,0:09:50.84,0:09:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru.
Dialogue: 0,0:09:51.79,0:09:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum tidur?
Dialogue: 0,0:09:53.30,0:09:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau buang waktu.
Dialogue: 0,0:09:55.05,0:09:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu. Jangan memaksakan diri.
Dialogue: 0,0:09:57.72,0:09:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Aku tidur dulu.
Dialogue: 0,0:10:08.02,0:10:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga belum tidur?
Dialogue: 0,0:10:10.48,0:10:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:11.44,0:10:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa tidur.
Dialogue: 0,0:10:13.73,0:10:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:10:18.99,0:10:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gambar dan kau akan belajar.\NPelajari dan kau akan menguasainya.{\i0}
Dialogue: 0,0:10:23.08,0:10:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berapa banyak yang harus kupelajari\Nuntuk menyelamatkan Ibu?{\i0}
Dialogue: 0,0:10:37.80,0:10:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah sekian lama
Dialogue: 0,0:10:40.43,0:10:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menantikan…
Dialogue: 0,0:10:45.06,0:10:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}momen ini tiba.
Dialogue: 0,0:10:48.77,0:10:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka yang menolak keputusan Tiga Sage\Nuntuk melarang sihir pada tubuh manusia{\i0}
Dialogue: 0,0:10:54.77,0:10:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah para dokter sihir\Nyang menggunakan sihir untuk penyembuhan.{\i0}
Dialogue: 0,0:10:59.40,0:11:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sihir Botol Kembar pun terlupakan\Nbersamaan dengan mereka,{\i0}
Dialogue: 0,0:11:03.57,0:11:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sihir penyembuhan\Nyang diciptakan untuk berbagi obat.{\i0}
Dialogue: 0,0:11:07.12,0:11:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Meski botol-botol itu saling berjauhan,{\i0}
Dialogue: 0,0:11:10.00,0:11:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}isinya akan disalurkan\Nmelalui medali berukir lingkaran,{\i0}
Dialogue: 0,0:11:14.34,0:11:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sehingga apa pun yang dibutuhkan\Ntak akan habis.{\i0}
Dialogue: 0,0:11:18.17,0:11:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak Hari Perjanjian,\Nsihir penyembuhan kuno ini telah hilang.
Dialogue: 0,0:11:23.68,0:11:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh ironis Penyihir Bertopeng\Nbisa menciptakannya kembali.
Dialogue: 0,0:11:27.47,0:11:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir yang indah,\Ntapi aku akan membongkarnya.
Dialogue: 0,0:11:30.69,0:11:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ini cara untuk menemui mereka.
Dialogue: 0,0:11:35.02,0:11:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak akan menyentuh tinta sihir dulu.\NKekuatan tak dikenal itu berbahaya.{\i0}
Dialogue: 0,0:11:40.28,0:11:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku mengincar medali berukir segel\Ndi dalam botol.{\i0}
Dialogue: 0,0:11:45.53,0:11:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa aku bisa mengambilnya tanpa disadari?{\i0}
Dialogue: 0,0:11:49.54,0:11:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini milik mereka.{\i0}
Dialogue: 0,0:11:52.58,0:11:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Letakkan medali ini\Nke dalam bola penuntun,{\i0}
Dialogue: 0,0:11:56.00,0:11:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan isinya, pemiliknya, tempat asalnya,{\i0}
Dialogue: 0,0:11:59.42,0:12:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}setiap jejak menjadi jarum\Nyang menunjuk ke mereka.{\i0}
Dialogue: 0,0:12:03.55,0:12:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Daripada mengandalkan petunjuk kecil,{\i0}
Dialogue: 0,0:12:05.55,0:12:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku bisa menemukan lokasi\Nyang jauh lebih pasti.{\i0}
Dialogue: 0,0:12:16.52,0:12:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mantra Sambaran Petir? Apa mereka sadar?{\i0}
Dialogue: 0,0:12:25.61,0:12:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air? Gawat!
Dialogue: 0,0:12:38.04,0:12:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku lengah.\NSihirku tak berguna di bawah air.{\i0}
Dialogue: 0,0:13:13.29,0:13:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:13:15.21,0:13:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola mata…
Dialogue: 0,0:13:22.88,0:13:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu…
Dialogue: 0,0:13:26.09,0:13:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:13:30.10,0:13:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:13:32.52,0:13:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum selesai.
Dialogue: 0,0:13:41.86,0:13:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial. Aku tak akan menyerah.
Dialogue: 0,0:13:45.61,0:13:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan merebut kembali\Napa yang kau curi dariku.
Dialogue: 0,0:13:56.12,0:13:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal, aku sudah memberikannya\Nkepada gadis itu…
Dialogue: 0,0:14:00.84,0:14:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang malah hancur.
Dialogue: 0,0:14:13.93,0:14:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompak sekali.
Dialogue: 0,0:14:15.14,0:14:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terus berlatih.\NApa kalian bergadang?
Dialogue: 0,0:14:19.60,0:14:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu! Setiap malam, kalian berubah\Njadi ksatria sihir dan menebas musuh!
Dialogue: 0,0:14:24.36,0:14:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Transformasi adalah sihir terlarang.
Dialogue: 0,0:14:26.94,0:14:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menguap terus,\Nmalamnya harus tidur yang cukup.
Dialogue: 0,0:14:31.66,0:14:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berlatih sampai larut malam\Nbeberapa hari ini, bukan?
Dialogue: 0,0:14:37.45,0:14:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, biasanya lebih lancar\Nkalau sudah larut malam…
Dialogue: 0,0:14:40.67,0:14:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Itu tidak baik, Coco!
Dialogue: 0,0:14:42.63,0:14:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti perasaanmu,\Ntapi tidak baik memaksakan diri.
Dialogue: 0,0:14:45.75,0:14:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir yang baik\Nberasal dari tidur yang cukup.
Dialogue: 0,0:14:48.05,0:14:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan juga.
Dialogue: 0,0:14:49.13,0:14:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Olu juga bilang begitu.
Dialogue: 0,0:14:51.18,0:14:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Perbanyak tidur selagi masih kecil\Natau kau akan sakit saat dewasa.{\i0}
Dialogue: 0,0:14:54.97,0:14:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:56.14,0:15:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuat teh herbal.\NApa Guru mau juga?
Dialogue: 0,0:15:04.06,0:15:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru?
Dialogue: 0,0:15:06.28,0:15:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kau bilang apa?
Dialogue: 0,0:15:08.15,0:15:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sekali.
Dialogue: 0,0:15:09.74,0:15:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melamun setelah makan.
Dialogue: 0,0:15:12.11,0:15:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan membuat teh.
Dialogue: 0,0:15:20.54,0:15:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Guru baik-baik saja?
Dialogue: 0,0:15:23.17,0:15:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku baik-baik saja.
Dialogue: 0,0:15:26.88,0:15:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mati rasa kemarin belum hilang.{\i0}
Dialogue: 0,0:15:30.05,0:15:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku menumpahkan teh herba\Nyang terakhir.
Dialogue: 0,0:15:34.35,0:15:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengumpulkan daun tehnya.
Dialogue: 0,0:15:36.51,0:15:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lanjutkan\Nbelajar buku mantra dasar.
Dialogue: 0,0:15:40.39,0:15:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang bersihkan nanti.
Dialogue: 0,0:15:48.48,0:15:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru tampak aneh hari ini.
Dialogue: 0,0:15:50.57,0:15:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang tidur memang berdampak besar.
Dialogue: 0,0:15:55.32,0:15:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam ini, dia harus minum teh herbal.
Dialogue: 0,0:15:57.37,0:15:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Agott.
Dialogue: 0,0:15:59.45,0:16:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau ada waktu?
Dialogue: 0,0:16:06.88,0:16:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, kukembalikan.
Dialogue: 0,0:16:08.46,0:16:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepatu sylph-ku.
Dialogue: 0,0:16:10.80,0:16:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku baru mengembalikannya.
Dialogue: 0,0:16:13.30,0:16:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menggambarnya dengan rapi,\Njadi agak makan waktu.
Dialogue: 0,0:16:18.22,0:16:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau mengerjakannya tadi malam?
Dialogue: 0,0:16:20.43,0:16:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:21.73,0:16:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi segelku tidak sebagus yang lain.
Dialogue: 0,0:16:25.23,0:16:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai dulu, gambar ulang saja\Nkalau tidak stabil.
Dialogue: 0,0:16:32.90,0:16:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:16:36.37,0:16:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rencanakan?
Dialogue: 0,0:16:39.74,0:16:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terus memikirkannya.
Dialogue: 0,0:16:41.62,0:16:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi saat Persetujuan Takhta?
Dialogue: 0,0:16:45.42,0:16:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak pernah bilang\Nkepada Guru Qifrey aku memaksamu, bukan?
Dialogue: 0,0:16:51.30,0:16:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan bisa membicarakannya\Ndengan Tuan Olruggio.
Dialogue: 0,0:16:55.05,0:17:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alih-alih menyalahkanku,\Nkau malah memperbaiki sepatu sylph-ku.
Dialogue: 0,0:17:01.56,0:17:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Aku tak paham\Ndengan jalan pikiranmu.
Dialogue: 0,0:17:09.27,0:17:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu…
Dialogue: 0,0:17:11.03,0:17:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau memang memaksaku.{\i0}
Dialogue: 0,0:17:13.03,0:17:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujian itu menakutkan\Ndan aku merasa kesepian.{\i0}
Dialogue: 0,0:17:17.78,0:17:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bisa menunggu dijemput\Ntanpa melakukan apa pun.{\i0}
Dialogue: 0,0:17:22.04,0:17:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi…{\i0}
Dialogue: 0,0:17:24.83,0:17:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdiri di kaki Pegunungan Dadah hari itu
Dialogue: 0,0:17:27.83,0:17:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memutuskan terus maju\Nadalah pilihanku sendiri.
Dialogue: 0,0:17:31.25,0:17:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kurasa aku ingin membuktikan\Nkepada diriku sendiri bahwa aku bisa.{\i0}
Dialogue: 0,0:17:37.22,0:17:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bahwa aku bisa mengatasi kesulitan\Ndan meraih harapan dengan sihirku sendiri.{\i0}
Dialogue: 0,0:17:44.14,0:17:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau tidak…{\i0}
Dialogue: 0,0:17:50.36,0:17:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, apa ini?
Dialogue: 0,0:17:52.23,0:17:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hanya aku\Nyang terus mengkhawatirkan ini?
Dialogue: 0,0:17:55.78,0:17:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti…
Dialogue: 0,0:17:59.74,0:18:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco!
Dialogue: 0,0:18:21.60,0:18:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, sudah kembali normal.
Dialogue: 0,0:18:26.02,0:18:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka curiga, ya?
Dialogue: 0,0:18:27.89,0:18:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka anak-anak yang cerdas,\Njadi mungkin sadar.
Dialogue: 0,0:18:30.65,0:18:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka tahu, tamatlah sudah.\NAku harus menyembunyikannya.
Dialogue: 0,0:18:35.19,0:18:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa menjaga rahasia, Bulbul?
Dialogue: 0,0:18:39.03,0:18:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, kau tak suka namamu.
Dialogue: 0,0:18:44.54,0:18:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal, menurutku itu manis.
Dialogue: 0,0:18:46.62,0:18:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulbul.
Dialogue: 0,0:18:47.62,0:18:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenci itu?
Dialogue: 0,0:18:49.96,0:18:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:19:01.47,0:19:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengejutkanku, Agott.\NKau terbang dengan sangat cepat.
Dialogue: 0,0:19:06.01,0:19:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panah tumitnya terlalu panjang,\Njadi segelnya tidak sempurna.
Dialogue: 0,0:19:10.14,0:19:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Aku ingin melihatnya.
Dialogue: 0,0:19:12.65,0:19:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan itu. Ini darurat.
Dialogue: 0,0:19:14.90,0:19:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Coco!\N- Apa?
Dialogue: 0,0:19:20.45,0:19:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawanya ke rumah sakit.
Dialogue: 0,0:19:22.36,0:19:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik. Serahkan urusan di sini kepadaku.
Dialogue: 0,0:19:25.62,0:19:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-Anak, bilang ke Olu\Nkalau ada apa-apa, ya?
Dialogue: 0,0:19:42.09,0:19:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah. Kita hampir sampai.
Dialogue: 0,0:19:46.31,0:19:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Demamnya makin tinggi.\NAku harus segera membawanya ke dokter.{\i0}
Dialogue: 0,0:19:57.65,0:20:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik, giliranku.\N- Jangan mengacau.
Dialogue: 0,0:20:00.19,0:20:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah!
Dialogue: 0,0:20:02.07,0:20:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu… Rasakan!
Dialogue: 0,0:20:07.78,0:20:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkap yang benar.
Dialogue: 0,0:20:10.00,0:20:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tartah, sudah mau pulang?
Dialogue: 0,0:20:12.29,0:20:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Aku harus mengejar feri.
Dialogue: 0,0:20:15.21,0:20:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Begitu, ya?\N- Kau tinggal di pulau sungai, ya?
Dialogue: 0,0:20:18.80,0:20:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh. Bukannya tinggal terbang pulang\Nkalau kau dari keluarga penyihir?
Dialogue: 0,0:20:23.80,0:20:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu?
Dialogue: 0,0:20:26.55,0:20:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami punya banyak aturan.
Dialogue: 0,0:20:29.81,0:20:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konyol.
Dialogue: 0,0:20:31.31,0:20:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sampai jumpa besok!\N- Sampai jumpa!
Dialogue: 0,0:20:38.11,0:20:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang yang tidak paham\Nmemang suka asal bicara.{\i0}
Dialogue: 0,0:20:43.11,0:20:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku…
Dialogue: 0,0:20:49.33,0:20:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tuan Qifrey?
Dialogue: 0,0:20:54.46,0:20:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa kau di sini?\N- Tartah.
Dialogue: 0,0:20:56.17,0:20:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah sakitnya di depan, bukan?
Dialogue: 0,0:20:58.34,0:21:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak yakin ini arah yang benar.
Dialogue: 0,0:21:01.09,0:21:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah sakit, ya? Lewat sini!\NAku tahu jalan pintas!
Dialogue: 0,0:21:05.88,0:21:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:26.07,0:21:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sembuhkan dia.
Dialogue: 0,0:21:27.20,0:21:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, kami akan mengobatinya.\NTunggu sebentar.
Dialogue: 0,0:21:34.41,0:21:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Semoga dia baik-baik saja.
Dialogue: 0,0:21:37.12,0:21:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat terbantu.
Dialogue: 0,0:21:39.08,0:21:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau tahu rute itu?
Dialogue: 0,0:21:41.46,0:21:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semua orang juga tahu.\N- Tidak, itu mengesankan.
Dialogue: 0,0:21:45.34,0:21:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya mata yang tajam.
Dialogue: 0,0:21:48.47,0:21:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pengamat yang sangat baik, ya?
Dialogue: 0,0:21:54.27,0:21:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Tuan Qifrey.
Dialogue: 0,0:21:57.52,0:22:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menanyakan sesuatu kepadamu.
Dialogue: 0,0:23:39.25,0:23:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana
