Dialogue: 0,0:01:56.19,0:01:58.24,tanda,,0000,0000,0000,,ATELIER OF WITCH HAT
Dialogue: 0,0:23:36.66,0:23:38.95,tanda,,0000,0000,0000,,EPISODE 4\NPERTEMUAN DI KALHN
Dialogue: 0,0:00:30.86,0:00:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tangga yang berfungsi dengan baik,\Ntapi tak ada yang pakai.
Dialogue: 0,0:00:34.65,0:00:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama kau tak menjejakkan kaki\Ndi dasar laut ini,
Dialogue: 0,0:00:38.53,0:00:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah Pembuat Onar Aula Besar.
Dialogue: 0,0:00:41.54,0:00:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah lama sekali, Alaira.
Dialogue: 0,0:00:44.37,0:00:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:00:46.71,0:00:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengar kau membuat onar lagi.
Dialogue: 0,0:00:50.63,0:00:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, kau punya murid baru.
Dialogue: 0,0:00:53.59,0:00:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah tahu?
Dialogue: 0,0:00:55.30,0:00:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumor cepat menyebar, ya?
Dialogue: 0,0:00:57.39,0:00:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mungkin terkait, bukan?
Dialogue: 0,0:01:00.14,0:01:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan para Penyihir Bertopeng?
Dialogue: 0,0:01:04.27,0:01:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah empat tahun\Nsejak sihir terlarang digunakan.
Dialogue: 0,0:01:07.02,0:01:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia petunjuk penting.
Dialogue: 0,0:01:09.48,0:01:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu alasannya.
Dialogue: 0,0:01:12.78,0:01:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia belum ikut ujian,\Njadi, dia belum resmi menjadi muridku.
Dialogue: 0,0:01:16.40,0:01:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Belum?
Dialogue: 0,0:01:18.28,0:01:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih terlalu cepat.
Dialogue: 0,0:01:20.03,0:01:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya juga tidak tepat.
Dialogue: 0,0:01:22.04,0:01:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:01:23.37,0:01:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, Pegunungan Dadah,\Ntempat ujian berlangsung…
Dialogue: 0,0:01:26.29,0:01:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisinya mencapai titik tertinggi.
Dialogue: 0,0:01:29.33,0:01:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa mengirimnya sekarang.
Dialogue: 0,0:01:32.46,0:01:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawanya akan terancam.
Dialogue: 0,0:03:19.24,0:03:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Agott.
Dialogue: 0,0:03:22.24,0:03:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita serius melakukan ini?\NGuru sedang tak ada.
Dialogue: 0,0:03:25.87,0:03:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kapan pun waktunya,\Nkau tetap sendirian saat ujian.
Dialogue: 0,0:03:28.95,0:03:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi aku baru tiba di sini.
Dialogue: 0,0:03:31.87,0:03:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lulus saat usiaku sepuluh tahun.
Dialogue: 0,0:03:34.83,0:03:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang ikut ujian untuk jadi murid.
Dialogue: 0,0:03:37.30,0:03:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syaratnya selalu sama.
Dialogue: 0,0:03:39.21,0:03:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:03:41.55,0:03:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujian pertama adalah "Persetujuan Takhta".{\i0}
Dialogue: 0,0:03:44.93,0:03:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau hanya boleh membawa\Ntiga alat dan bahan sihir.{\i0}
Dialogue: 0,0:03:48.72,0:03:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau harus mencapai puncak Pegunungan Dadah\Ntanpa bantuan siapa pun.{\i0}
Dialogue: 0,0:03:53.02,0:03:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serta membawa Rumput Mahkota\Nyang tumbuh di sana.{\i0}
Dialogue: 0,0:03:56.90,0:03:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola penuntun yang menunjukkan jalan\Nke tujuan mana pun
Dialogue: 0,0:03:59.94,0:04:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan gelembung uap untuk minum.
Dialogue: 0,0:04:02.40,0:04:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin hanya ini yang bisa kau bawa.
Dialogue: 0,0:04:06.28,0:04:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, pergilah.
Dialogue: 0,0:04:13.08,0:04:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lagi…
Dialogue: 0,0:04:14.04,0:04:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:15.63,0:04:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau punya sepatu?
Dialogue: 0,0:04:17.96,0:04:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sepatu?\N- Sepatu itu juga alat, bukan?
Dialogue: 0,0:04:21.55,0:04:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku melihat solnya bersinar\Nketika kau dan Guru Qifrey terbang.{\i0}
Dialogue: 0,0:04:26.30,0:04:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalau kau tak keberatan, sepatu itu,
Dialogue: 0,0:04:30.81,0:04:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisakah kau meminjamkannya kepadaku?
Dialogue: 0,0:04:34.73,0:04:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah kelewatan! Maaf!
Dialogue: 0,0:04:37.56,0:04:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja!
Dialogue: 0,0:04:44.82,0:04:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan meminjamkannya.
Dialogue: 0,0:04:47.07,0:04:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jadi, cepat.\N- Terima kasih…
Dialogue: 0,0:04:49.58,0:04:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, pergilah!
Dialogue: 0,0:04:53.58,0:04:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa bilang,
Dialogue: 0,0:04:55.04,0:04:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau hanya bisa ikut ujian sekali.
Dialogue: 0,0:04:58.00,0:05:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gagal, kau tak bisa\Nmenjadi murid Guru Qifrey lagi.
Dialogue: 0,0:05:02.71,0:05:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus meninggalkan sanggar.
Dialogue: 0,0:05:15.14,0:05:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tiba-tiba merasa kesepian,
Dialogue: 0,0:05:18.52,0:05:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku harus berusaha!
Dialogue: 0,0:05:20.44,0:05:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa mundur.
Dialogue: 0,0:05:23.90,0:05:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara menggunakan\Nbola penuntun ini, ya?
Dialogue: 0,0:05:38.12,0:05:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda ini menunjuk ke arah sini.
Dialogue: 0,0:05:43.42,0:05:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:05:44.59,0:05:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya mendaki. Aku pasti bisa.
Dialogue: 0,0:05:51.76,0:05:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa!
Dialogue: 0,0:05:53.01,0:05:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott bilang bahwa dia lulus
Dialogue: 0,0:05:56.18,0:05:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ketika berusia sepuluh tahun!
Dialogue: 0,0:06:01.98,0:06:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau anak sepuluh tahun saja bisa…
Dialogue: 0,0:06:09.16,0:06:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin ini mudah!
Dialogue: 0,0:06:19.71,0:06:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:06:22.63,0:06:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang…
Dialogue: 0,0:06:31.59,0:06:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Pegunungan Dadah?
Dialogue: 0,0:06:40.06,0:06:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola penuntun menunjuk ke atas.
Dialogue: 0,0:06:43.19,0:06:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pasti di sana.
Dialogue: 0,0:06:50.07,0:06:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menduga itu akan ada di langit.
Dialogue: 0,0:07:00.04,0:07:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:07:01.67,0:07:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepatu pinjaman dari Agott!
Dialogue: 0,0:07:07.63,0:07:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:18.89,0:07:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segelnya terbagi dua\Npada masing-masing kaki.
Dialogue: 0,0:07:30.65,0:07:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan tidak bergeser.
Dialogue: 0,0:07:32.36,0:07:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejajarkan dengan sempurna…
Dialogue: 0,0:07:42.42,0:07:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Aku benar-benar melayang!
Dialogue: 0,0:07:53.63,0:07:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kata Guru Qifrey,
Dialogue: 0,0:07:56.30,0:07:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku seperti anak kuda yang baru lahir.
Dialogue: 0,0:08:02.31,0:08:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:08:08.44,0:08:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku terbang.
Dialogue: 0,0:08:12.70,0:08:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa terbang,\Naku bisa cepat sampai ke puncak.
Dialogue: 0,0:08:16.70,0:08:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:08:18.20,0:08:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha!
Dialogue: 0,0:08:24.21,0:08:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau akan segera terbiasa\Ndan bisa berlarian dengan bebas.{\i0}
Dialogue: 0,0:08:29.96,0:08:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera terbiasa…
Dialogue: 0,0:08:56.03,0:08:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini formulir pendaftarannya. Terima kasih.
Dialogue: 0,0:08:58.20,0:08:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:08:59.74,0:09:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Totorei, nomor 12.
Dialogue: 0,0:09:01.74,0:09:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:09:02.87,0:09:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tinggal di Aula,\Nkau tak perlu menempuh perjalanan jauh.
Dialogue: 0,0:09:06.71,0:09:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa membawa muridmu.
Dialogue: 0,0:09:09.29,0:09:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aula Besar adalah markas penyihir.
Dialogue: 0,0:09:11.88,0:09:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kebutuhanmu ada di sini.
Dialogue: 0,0:09:14.38,0:09:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ke sini kalau butuh sesuatu.
Dialogue: 0,0:09:18.14,0:09:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membawanya.
Dialogue: 0,0:09:19.64,0:09:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:21.14,0:09:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat membenci Aula Besar, ya?
Dialogue: 0,0:09:24.52,0:09:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awasi murid-muridmu dengan baik.
Dialogue: 0,0:09:27.14,0:09:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak seusia itu…
Dialogue: 0,0:09:28.90,0:09:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa yang mereka perbuat\Ntanpa pengawasan orang dewasa.
Dialogue: 0,0:09:34.07,0:09:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelan-pelan…
Dialogue: 0,0:09:38.16,0:09:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keseimbanganku sudah jauh lebih baik.
Dialogue: 0,0:09:41.66,0:09:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, aku bisa terbang lebih tinggi.
Dialogue: 0,0:09:46.75,0:09:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:25.33,0:10:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu teman kuas!
Dialogue: 0,0:10:26.66,0:10:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru lihat!
Dialogue: 0,0:10:41.22,0:10:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepatunya penuh lumpur.
Dialogue: 0,0:10:52.48,0:10:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:53.90,0:10:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Segelnya terhapus!
Dialogue: 0,0:10:57.49,0:10:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Apa karena aku seka?
Dialogue: 0,0:10:58.99,0:11:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:11:00.61,0:11:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu! Aku akan menggambarnya!
Dialogue: 0,0:11:05.53,0:11:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua tintanya tumpah.
Dialogue: 0,0:11:14.04,0:11:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:11:17.92,0:11:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, aku akan gagal.
Dialogue: 0,0:11:21.93,0:11:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Agott, apa kau melihat Coco?
Dialogue: 0,0:11:25.39,0:11:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hampir waktunya makan malam.
Dialogue: 0,0:11:27.89,0:11:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Coco tak ada di sini.\N- Apa?
Dialogue: 0,0:11:30.06,0:11:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang ujian di Pegunungan Dadah.
Dialogue: 0,0:11:32.40,0:11:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Sendirian?
Dialogue: 0,0:11:33.98,0:11:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia baru saja tiba!
Dialogue: 0,0:11:36.32,0:11:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak mencegahnya?
Dialogue: 0,0:11:37.40,0:11:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Agott!
Dialogue: 0,0:11:38.90,0:11:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, ujian dulu baru jadi murid.
Dialogue: 0,0:11:41.65,0:11:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar, tapi…
Dialogue: 0,0:11:45.03,0:11:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak bisa lulus ujian sederhana,
Dialogue: 0,0:11:48.04,0:11:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tak pantas menjadi murid.
Dialogue: 0,0:11:51.50,0:11:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu?
Dialogue: 0,0:11:53.04,0:11:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci orang yang tak bisa\Nmengikuti kemampuanku.
Dialogue: 0,0:11:56.38,0:11:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada untungnya bersama mereka.
Dialogue: 0,0:11:59.30,0:12:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, dia orang luar.
Dialogue: 0,0:12:03.22,0:12:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, dia akan kembali sebelum mencoba.
Dialogue: 0,0:12:07.85,0:12:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini adalah waktu Pegunungan Dadah\Nberada di posisi tertinggi.{\i0}
Dialogue: 0,0:12:12.73,0:12:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sepatu sylph-ku\Ntak bisa terbang setinggi itu.
Dialogue: 0,0:12:16.77,0:12:19.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan tak tahu aturannya,\Ntak ada takutnya.
Dialogue: 0,0:12:21.90,0:12:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau ada orang luar di dunia kita.
Dialogue: 0,0:12:29.58,0:12:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak mau makan, Tetia?
Dialogue: 0,0:12:33.16,0:12:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau makan,
Dialogue: 0,0:12:35.04,0:12:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi entah kenapa, tubuhku terasa berat.
Dialogue: 0,0:12:42.72,0:12:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tambah.
Dialogue: 0,0:12:44.13,0:12:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hanya aku yang khawatir?
Dialogue: 0,0:12:47.85,0:12:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun khawatir,\Nkita hanya bisa menunggu Guru Qifrey.
Dialogue: 0,0:12:57.40,0:12:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo! Terbang!
Dialogue: 0,0:13:01.78,0:13:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa!
Dialogue: 0,0:13:03.32,0:13:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencoba menggunakan\Ntinta yang tersisa,
Dialogue: 0,0:13:06.11,0:13:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku sudah tak bisa terbang.
Dialogue: 0,0:13:10.28,0:13:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu basah, jadi berlepotan.
Dialogue: 0,0:13:20.42,0:13:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau aku gambar langsung\Ndi telapak kakiku?
Dialogue: 0,0:13:33.60,0:13:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh! Menggambar sihir pada tubuh\Nsecara langsung itu dilarang.
Dialogue: 0,0:13:40.11,0:13:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu harus menggunakan\Nsihir macam apa pada saat begini.
Dialogue: 0,0:13:49.28,0:13:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott benar.
Dialogue: 0,0:14:03.75,0:14:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Siapa pun bisa menggambar sihir,{\i0}
Dialogue: 0,0:14:06.76,0:14:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi tidak semua orang\Nbisa menggambarnya dengan baik.{\i0}
Dialogue: 0,0:14:09.76,0:14:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin memang benar hanya orang berbakat{\i0}
Dialogue: 0,0:14:13.31,0:14:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang bisa jadi penyihir.{\i0}
Dialogue: 0,0:14:22.65,0:14:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka sudah menggambar sihir{\i0}
Dialogue: 0,0:14:24.61,0:14:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sejak masih kecil.{\i0}
Dialogue: 0,0:14:27.82,0:14:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bisa apa?{\i0}
Dialogue: 0,0:14:42.88,0:14:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:14:49.34,0:14:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar begitu. Yang lurus.
Dialogue: 0,0:14:56.47,0:14:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, sini.
Dialogue: 0,0:14:59.69,0:15:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kemari!
Dialogue: 0,0:15:08.07,0:15:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu\Nada perajin yang hebat di desa ini.
Dialogue: 0,0:15:13.24,0:15:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah sihir.
Dialogue: 0,0:15:19.33,0:15:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:15:24.71,0:15:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memilikinya! Sihirku sendiri!
Dialogue: 0,0:15:49.82,0:15:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau aku membasahinya dengan sedikit air…{\i0}
Dialogue: 0,0:15:58.12,0:16:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubahku yang basah jadi kaku\Nkarena lumpur yang mengering.
Dialogue: 0,0:16:01.33,0:16:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menggambar di sini.
Dialogue: 0,0:16:29.98,0:16:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan cenderung tidak stabil\Nsaat menggunakan alat baru.
Dialogue: 0,0:16:36.24,0:16:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau begitu, aku ganti saja\Ndengan alat yang biasa aku pakai.{\i0}
Dialogue: 0,0:16:42.04,0:16:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jemariku akan bisa bergerak dengan bebas.{\i0}
Dialogue: 0,0:16:46.92,0:16:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bebas…{\i0}
Dialogue: 0,0:16:56.97,0:16:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:16:58.68,0:17:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Teman Kuas.\NKau kurang waspada, ya?
Dialogue: 0,0:17:03.02,0:17:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel ini tak terlalu bagus.
Dialogue: 0,0:17:05.94,0:17:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel yang layak itu
Dialogue: 0,0:17:07.44,0:17:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}punya lambang yang dikelilingi aksara\Nyang digambar dengan rapi.
Dialogue: 0,0:17:11.15,0:17:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku juga belajar
Dialogue: 0,0:17:12.82,0:17:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa ketidakseimbangan\Nakan memicu kekuatan yang berlebihan.
Dialogue: 0,0:17:15.65,0:17:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku coba membuat satu\Nyang sangat panjang.
Dialogue: 0,0:17:19.53,0:17:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah berhasil atau tidak.
Dialogue: 0,0:17:30.63,0:17:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ikut?
Dialogue: 0,0:17:32.88,0:17:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kau harus pegangan yang erat!
Dialogue: 0,0:17:36.76,0:17:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menutup segelnya!
Dialogue: 0,0:17:46.73,0:17:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kenapa?
Dialogue: 0,0:17:49.52,0:17:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah gambar aksara arahnya?
Dialogue: 0,0:18:25.85,0:18:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:18:27.02,0:18:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terbang dengan sihirku sendiri!
Dialogue: 0,0:18:30.81,0:18:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jubah terbang sungguhan!
Dialogue: 0,0:18:32.77,0:18:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpiku jadi nyata.
Dialogue: 0,0:18:46.58,0:18:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal-hal yang kupelajari saat membantu Ibu
Dialogue: 0,0:18:49.16,0:18:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membantuku menghasilkan sihirku.
Dialogue: 0,0:18:51.75,0:18:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kuduga.
Dialogue: 0,0:18:56.17,0:18:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumput Mahkota masih jauh di atas.
Dialogue: 0,0:19:12.15,0:19:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumput Mahkota!
Dialogue: 0,0:20:13.17,0:20:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu…
Dialogue: 0,0:20:21.63,0:20:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tunggu aku, Ibu!{\i0}
Dialogue: 0,0:20:24.97,0:20:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan bertanggung jawab.{\i0}
Dialogue: 0,0:20:27.14,0:20:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku berjanji!{\i0}
Dialogue: 0,0:20:32.23,0:20:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Coco ke Pegunungan Dadah sendirian\Nuntuk mengikuti ujian?
Dialogue: 0,0:20:36.48,0:20:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:20:38.48,0:20:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu berbahaya!\NKita harus menghentikannya!
Dialogue: 0,0:20:41.36,0:20:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita hentikan, dia gagal.
Dialogue: 0,0:20:43.49,0:20:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masih terlalu dini baginya.
Dialogue: 0,0:20:46.66,0:20:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berbeda dari kita\Nyang dibesarkan dengan sihir.
Dialogue: 0,0:20:51.04,0:20:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sesuatu terjadi kepada Coco…
Dialogue: 0,0:20:53.71,0:20:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukan hanya gadis itu yang hilang.{\i0}
Dialogue: 0,0:20:56.12,0:20:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:21:03.34,0:21:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:04.88,0:21:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Coco!
Dialogue: 0,0:21:06.59,0:21:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Syukurlah!
Dialogue: 0,0:21:08.14,0:21:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco! Kau baik-baik saja!
Dialogue: 0,0:21:10.76,0:21:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat mengkhawatirkanmu!
Dialogue: 0,0:21:15.69,0:21:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agott!
Dialogue: 0,0:21:18.31,0:21:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat "Persetujuan Takhta".
Dialogue: 0,0:21:24.03,0:21:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membuktikan diriku, bukan?
Dialogue: 0,0:21:36.46,0:21:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco.
Dialogue: 0,0:21:37.62,0:21:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggunakan sihir\Nsecara sembarangan tanpa persiapan
Dialogue: 0,0:21:40.84,0:21:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau pengetahuan dasar,\Nitu sangatlah berbahaya.
Dialogue: 0,0:21:44.30,0:21:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seharusnya sudah tahu itu.
Dialogue: 0,0:21:48.72,0:21:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kesalahan bisa berakibat fatal.
Dialogue: 0,0:21:52.01,0:21:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kau ulangi lagi.
Dialogue: 0,0:21:54.31,0:21:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Guru Qifrey.
Dialogue: 0,0:21:59.02,0:21:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:22:00.56,0:22:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak perlu menghadapi bahaya\Nuntuk membuktikan diri.
Dialogue: 0,0:22:03.57,0:22:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah menjadi muridku.
Dialogue: 0,0:22:20.13,0:22:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:22:25.84,0:22:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukti bahwa kau seorang penyihir.
Dialogue: 0,0:22:29.01,0:22:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumber kebanggaan
Dialogue: 0,0:22:30.59,0:22:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekaligus kekangan\Nyang dipakai di kepala untuk mencegahmu
Dialogue: 0,0:22:34.60,0:22:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyalahgunakan sihir.
Dialogue: 0,0:22:45.82,0:22:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kau memakai ini,
Dialogue: 0,0:22:48.11,0:22:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingatlah tanggung jawabnya.
Dialogue: 0,0:22:51.45,0:22:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi runcing akan senantiasa\Nmengawasi sihirmu.
Dialogue: 0,0:22:57.62,0:22:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga baik-baik.
Dialogue: 0,0:23:00.42,0:23:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:23:02.46,0:23:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bagus. Kalau begitu, mari kita naik.
Dialogue: 0,0:23:05.00,0:23:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Baik.
Dialogue: 0,0:23:10.09,0:23:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Pertama, kita makan malam dulu!
Dialogue: 0,0:23:13.10,0:23:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau juga harus mandi.
Dialogue: 0,0:23:33.45,0:23:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benihnya sudah tumbuh.
Dialogue: 0,0:23:38.95,0:23:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Nola Mardiana
