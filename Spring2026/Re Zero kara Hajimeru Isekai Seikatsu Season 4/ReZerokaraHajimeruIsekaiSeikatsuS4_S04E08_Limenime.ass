Dialogue: 0,0:23:58.64,0:24:01.87,sign,,0000,0000,0000,,KAU SIAPA?
Dialogue: 0,0:00:02.36,0:00:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi,\Nizinkan aku memperkenalkan diri!
Dialogue: 0,0:00:05.19,0:00:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Natsuki Subaru!
Dialogue: 0,0:00:07.65,0:00:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh dan tak tahu apa-apa,\Nakulah pengembara abadi berjiwa bebas!
Dialogue: 0,0:00:11.51,0:00:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski banyak kekurangan,
Dialogue: 0,0:00:13.07,0:00:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}salam kenal dan mohon bimbingannya.
Dialogue: 0,0:00:18.58,0:00:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, kita sudah saling kenal, 'kan?
Dialogue: 0,0:00:22.08,0:00:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalanmu telat banget, tahu.
Dialogue: 0,0:00:24.50,0:00:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah?
Dialogue: 0,0:00:27.18,0:00:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti,
Dialogue: 0,0:00:28.84,0:00:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita sudah kenal lebih dari setahun,
Dialogue: 0,0:00:32.09,0:00:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku melupakan semuanya?
Dialogue: 0,0:00:36.38,0:00:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, tangan ini
Dialogue: 0,0:00:38.56,0:00:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memang bukan tubuhku\Nyang baru keluar dari minimarket.
Dialogue: 0,0:00:41.73,0:00:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar tak ingat apa pun?
Dialogue: 0,0:00:44.11,0:00:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal menara ini, insiden di Pristella,
Dialogue: 0,0:00:48.33,0:00:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan tentang kami?
Dialogue: 0,0:00:51.56,0:00:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:00:53.84,0:00:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sepertinya begitu.
Dialogue: 0,0:00:57.36,0:00:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, pokoknya!
Dialogue: 0,0:00:59.46,0:01:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kalian pasti kecewa,
Dialogue: 0,0:01:01.50,0:01:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ayo ceria lagi!
Dialogue: 0,0:01:03.73,0:01:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdasarkan pengetahuanku,
Dialogue: 0,0:01:05.20,0:01:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}amnesia sementara biasanya\Nbisa sembuh oleh pemicu sepele.
Dialogue: 0,0:01:10.00,0:01:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di film, dua jam langsung beres
Dialogue: 0,0:01:12.56,0:01:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ingatan kembali seperti semula!
Dialogue: 0,0:01:14.68,0:01:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tak usah terlalu khawatir, oke?
Dialogue: 0,0:01:17.01,0:01:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tak paham maksudmu.
Dialogue: 0,0:01:19.43,0:01:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, duh. Begitu, ya?
Dialogue: 0,0:01:22.04,0:01:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Subaru tetaplah Subaru.
Dialogue: 0,0:01:25.67,0:01:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku jadi lega.
Dialogue: 0,0:01:31.18,0:01:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip! Sekarang aku sudah lebih baik!
Dialogue: 0,0:01:33.70,0:01:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Subaru yang sedang kesulitan,
Dialogue: 0,0:01:36.67,0:01:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku tak boleh ikut murung.
Dialogue: 0,0:01:39.04,0:01:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka secantik ini\Nternyata tangguh juga, ya.
Dialogue: 0,0:01:42.96,0:01:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Beatrice juga.
Dialogue: 0,0:01:44.79,0:01:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ya ampun!
Dialogue: 0,0:01:48.69,0:01:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru memang partner kontrak\Nyang merepotkan.
Dialogue: 0,0:01:52.60,0:01:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Partner kontrak?
Dialogue: 0,0:01:56.35,0:01:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai hal ini terulang lagi,
Dialogue: 0,0:01:59.01,0:02:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kesabaran Beti bisa habis.
Dialogue: 0,0:02:01.60,0:02:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengerti, 'kan?
Dialogue: 0,0:02:06.71,0:02:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Natsuki Subaru!
Dialogue: 0,0:02:09.09,0:02:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih tak tahu apa-apa,
Dialogue: 0,0:02:11.07,0:02:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mungkin aku ini teman kalian.
Dialogue: 0,0:02:13.45,0:02:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini agak lancang,\Ntapi aku punya satu permintaan.
Dialogue: 0,0:02:20.11,0:02:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri tahu nama kalian.
Dialogue: 0,0:02:25.82,0:02:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Emilia.
Dialogue: 0,0:02:27.93,0:02:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya Emilia.
Dialogue: 0,0:02:29.67,0:02:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beti adalah Roh Agung Beatrice.
Dialogue: 0,0:02:32.33,0:02:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau partner kontrak Beti.
Dialogue: 0,0:02:35.42,0:02:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya lagi, ya, Subaru.
Dialogue: 0,0:04:00.22,0:04:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Re:ZERO -Starting Life in Another World-\NSeason 4
Dialogue: 0,0:04:09.98,0:04:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelucon macam apa lagi ini, Barusu?
Dialogue: 0,0:04:13.67,0:04:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram.
Dialogue: 0,0:04:14.44,0:04:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu...?
Dialogue: 0,0:04:15.73,0:04:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok namaku jadi kayak mantra\Nyang bikin silau?
Dialogue: 0,0:04:19.82,0:04:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau kakak gadis yang tertidur itu?
Dialogue: 0,0:04:24.38,0:04:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, di saat ingin membangunkan adikmu,
Dialogue: 0,0:04:27.12,0:04:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah begini.
Dialogue: 0,0:04:29.62,0:04:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku juga tak tahu harus apa.
Dialogue: 0,0:04:33.46,0:04:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Protesnya nanti saja kalau ingatanku pulih.
Dialogue: 0,0:04:36.76,0:04:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara bicaramu itu sama sekali\Ntak terlihat seperti orang amnesia.
Dialogue: 0,0:04:40.69,0:04:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama menyebalkannya seperti biasa.
Dialogue: 0,0:04:42.43,0:04:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master.
Dialogue: 0,0:04:44.53,0:04:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Shaula.
Dialogue: 0,0:04:46.06,0:04:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid kesayangan Master
Dialogue: 0,0:04:48.14,0:04:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan penjaga bintang\NMenara Pengawas Pleiades!
Dialogue: 0,0:04:50.85,0:04:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Master itu maksudnya aku?
Dialogue: 0,0:04:53.36,0:04:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:04:54.48,0:04:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang ini benar-benar bikin repot, ya.
Dialogue: 0,0:04:58.65,0:05:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menatapku dengan lembut itu siapa?
Dialogue: 0,0:05:02.24,0:05:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Meili.
Dialogue: 0,0:05:04.20,0:05:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau keahlian menjahitmu\Ntak hilang bersama ingatanmu,
Dialogue: 0,0:05:08.67,0:05:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan senang kalau kau\Nmau membuatkanku boneka lagi.
Dialogue: 0,0:05:12.04,0:05:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu keahlianku,\Nberarti kita dekat banget, ya.
Dialogue: 0,0:05:16.47,0:05:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau juga adik perempuan,\Nseperti Beatrice?
Dialogue: 0,0:05:18.80,0:05:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu pembunuh bayaran yang datang\Nuntuk membunuhmu dan Beti.
Dialogue: 0,0:05:22.80,0:05:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?!
Dialogue: 0,0:05:25.27,0:05:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Ram, Shaula, dan Meili...
Dialogue: 0,0:05:29.27,0:05:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah selesai memperkenalkan diri.
Dialogue: 0,0:05:32.02,0:05:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, panggil aku Anastasia.
Dialogue: 0,0:05:35.29,0:05:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memberinya sedikit waktu.
Dialogue: 0,0:05:39.22,0:05:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, 'kan?
Dialogue: 0,0:05:41.47,0:05:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:05:42.96,0:05:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti kaget karena ini mendadak.
Dialogue: 0,0:05:46.66,0:05:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, sepertinya\Nbukan itu saja masalahnya.
Dialogue: 0,0:05:50.47,0:05:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau tak membuat\Npengakuan mengejutkan tadi,
Dialogue: 0,0:05:53.29,0:05:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tadinya aku yang mau\Nmembeberkan hal mengejutkan.
Dialogue: 0,0:05:59.24,0:06:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita selesaikan dulu\Npersiapan sarapannya.
Dialogue: 0,0:06:03.13,0:06:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Emilia.
Dialogue: 0,0:06:04.59,0:06:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh pinjam Barusu untuk ambil air?
Dialogue: 0,0:06:06.43,0:06:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:07.40,0:06:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ingatan Subaru belum pulih.
Dialogue: 0,0:06:10.39,0:06:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah lebih baik dia istirahat?
Dialogue: 0,0:06:13.36,0:06:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa,\Nlagi pula, badanku sehat-sehat saja.
Dialogue: 0,0:06:16.23,0:06:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ambil air sih bisa, Emilia.
Dialogue: 0,0:06:20.71,0:06:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:29.37,0:06:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlihat kelelahan.
Dialogue: 0,0:06:30.74,0:06:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:06:32.58,0:06:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tak pandai\Nmenjaga perasaan orang.
Dialogue: 0,0:06:37.09,0:06:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan sandiwara konyolmu, Barusu.
Dialogue: 0,0:06:40.91,0:06:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:41.92,0:06:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sampai pindah tempat, lo.
Dialogue: 0,0:06:44.02,0:06:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan permalukan seorang wanita.
Dialogue: 0,0:06:45.97,0:06:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum.
Dialogue: 0,0:06:46.80,0:06:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum apanya?
Dialogue: 0,0:06:48.35,0:06:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti akal-akalan konyolmu, 'kan?
Dialogue: 0,0:06:50.97,0:06:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa membodohi Nona Emilia yang polos,
Dialogue: 0,0:06:53.89,0:06:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi setidaknya katakan padaku\Napa rencanamu sebenarnya?
Dialogue: 0,0:06:56.81,0:06:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi...
Dialogue: 0,0:06:58.15,0:07:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan akting, sandiwara,\Natau rencana aneh-aneh.
Dialogue: 0,0:07:02.12,0:07:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keras kepala.
Dialogue: 0,0:07:03.04,0:07:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau memang sudah biasa\Nmemendam semuanya sendiri.
Dialogue: 0,0:07:05.78,0:07:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:07:07.20,0:07:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritakan semuanya.
Dialogue: 0,0:07:09.24,0:07:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan kurahasiakan.
Dialogue: 0,0:07:10.95,0:07:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia berdua memang agak menggoda, ya.
Dialogue: 0,0:07:16.07,0:07:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:07:19.07,0:07:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:07:21.21,0:07:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan.
Dialogue: 0,0:07:22.73,0:07:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, aku punya cara lain.
Dialogue: 0,0:07:24.97,0:07:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini tak mengerti, ya.
Dialogue: 0,0:07:26.72,0:07:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bohong!
Dialogue: 0,0:07:28.34,0:07:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku ini...\N- Cepat katakan semuanya!
Dialogue: 0,0:07:32.07,0:07:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan... semuanya.
Dialogue: 0,0:07:36.36,0:07:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon, katakan semuanya.
Dialogue: 0,0:07:39.56,0:07:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram.
Dialogue: 0,0:07:41.84,0:07:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon.
Dialogue: 0,0:07:43.71,0:07:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau sampai amnesia...
Dialogue: 0,0:07:46.24,0:07:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:07:49.03,0:07:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rem...
Dialogue: 0,0:07:53.40,0:07:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:07:57.62,0:07:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:08:01.59,0:08:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master, nanti daging keringnya habis, lo!
Dialogue: 0,0:08:04.92,0:08:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tunggu sebentar.
Dialogue: 0,0:08:07.13,0:08:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Emilia dan yang lain bisa khawatir,
Dialogue: 0,0:08:10.07,0:08:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi jangan bahas obrolan tadi.
Dialogue: 0,0:08:17.35,0:08:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal yang tadi.
Dialogue: 0,0:08:19.44,0:08:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kita bicara sebentar?
Dialogue: 0,0:08:21.15,0:08:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Oh, aku juga minta maaf...
Dialogue: 0,0:08:24.78,0:08:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, akan kudengarkan.
Dialogue: 0,0:08:27.60,0:08:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, aku Julius Juukulius.
Dialogue: 0,0:08:30.49,0:08:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesatria pribadi Nona Anastasia.
Dialogue: 0,0:08:34.33,0:08:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua bisa dibilang... teman.
Dialogue: 0,0:08:37.87,0:08:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Salam kenal.
Dialogue: 0,0:08:40.03,0:08:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa bicaramu ragu begitu?
Dialogue: 0,0:08:42.63,0:08:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu khawatir.
Dialogue: 0,0:08:44.71,0:08:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dan Julius sangat dekat.
Dialogue: 0,0:08:48.17,0:08:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan?
Dialogue: 0,0:08:48.97,0:08:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:50.34,0:08:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, masalah si Abang Kesatria itu
Dialogue: 0,0:08:53.22,0:08:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauh lebih rumit dari ini.
Dialogue: 0,0:08:56.27,0:09:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada kaitannya dengan Nona Anastasia\Nyang bersikap aneh sejak pagi?
Dialogue: 0,0:09:01.73,0:09:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sekali, Nona Ram.
Dialogue: 0,0:09:04.31,0:09:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mungkin menambah kebingungan\Nsetelah pengakuan Subaru.
Dialogue: 0,0:09:07.65,0:09:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bermaksud menambah kekacauan\Ndi tengah situasi membingungkan ini,
Dialogue: 0,0:09:11.57,0:09:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku percaya ikatan kita\Nselama melintasi gurun pasir.
Dialogue: 0,0:09:16.33,0:09:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gayamu bicara terdengar berlebihan.
Dialogue: 0,0:09:19.29,0:09:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubunganmu dengan Natsuki\Ntampak hangat dan ideal.
Dialogue: 0,0:09:24.00,0:09:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mendambakan hubungan\Nseperti itu bersama Ana.
Dialogue: 0,0:09:28.26,0:09:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyebut Anastasia layaknya orang lain.
Dialogue: 0,0:09:32.30,0:09:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kau bukan...
Dialogue: 0,0:09:36.22,0:09:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, yang ada di tubuh ini bukan Ana.
Dialogue: 0,0:09:43.36,0:09:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tertidur lelap di dalam tubuhnya.
Dialogue: 0,0:09:46.06,0:09:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang bertindak selama ini adalah aku,
Dialogue: 0,0:09:48.82,0:09:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Echidna, sebagai penggantinya.
Dialogue: 0,0:09:50.93,0:09:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Echidna?!
Dialogue: 0,0:09:52.49,0:09:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki juga bereaksi begitu.
Dialogue: 0,0:09:54.32,0:09:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya nama ini memang mengganjal, ya.
Dialogue: 0,0:09:57.24,0:09:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:09:58.42,0:10:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bukan Echidna yang kalian kenal.
Dialogue: 0,0:10:01.50,0:10:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf jika membuatmu tak nyaman.
Dialogue: 0,0:10:05.16,0:10:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Subaru juga sama sepertiku,
Dialogue: 0,0:10:07.63,0:10:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dulu pernah dijahili\Noleh penyihir bernama Echidna.
Dialogue: 0,0:10:11.42,0:10:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kena imbas gara-gara sama-sama\Nbernama Echidna, ya?
Dialogue: 0,0:10:14.82,0:10:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Echidna benar-benar merepotkan.
Dialogue: 0,0:10:17.64,0:10:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Echidna memang menyusahkan.
Dialogue: 0,0:10:20.56,0:10:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ketemu lagi, aku bakal protes.
Dialogue: 0,0:10:22.52,0:10:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lakukan.
Dialogue: 0,0:10:24.09,0:10:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi aku yang kena getahnya\Ngara-gara nama baiknya tercemar.
Dialogue: 0,0:10:28.82,0:10:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:10:29.78,0:10:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tujuan kalian ke menara ini\Nuntuk menolong orang, 'kan?
Dialogue: 0,0:10:33.53,0:10:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi malah...
Dialogue: 0,0:10:34.70,0:10:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu tiba di menara dan menaklukkannya,
Dialogue: 0,0:10:37.66,0:10:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu kehilangan ingatannya,
Dialogue: 0,0:10:40.04,0:10:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kesadaran Nona Anastasia\Ntenggelam di dalam tubuhnya.
Dialogue: 0,0:10:43.83,0:10:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya jadi kacau.
Dialogue: 0,0:10:46.09,0:10:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, anu...
Dialogue: 0,0:10:48.75,0:10:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, tak ada gunanya terus meratap.
Dialogue: 0,0:10:52.38,0:10:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia?
Dialogue: 0,0:10:53.69,0:10:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita datang memikul harapan banyak orang.
Dialogue: 0,0:10:57.39,0:10:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kita tak boleh berhenti.
Dialogue: 0,0:10:59.47,0:11:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah diberi tahu\Nuntuk jangan pernah menyerah.
Dialogue: 0,0:11:04.91,0:11:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar kata Emilia.
Dialogue: 0,0:11:07.80,0:11:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena aku amnesia\Ndan malah merepotkan kalian.
Dialogue: 0,0:11:10.98,0:11:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tergantung sudut pandang kita.
Dialogue: 0,0:11:12.94,0:11:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang sekarang tidak terikat\Ndengan keruwetan dunia ini,
Dialogue: 0,0:11:15.95,0:11:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi mungkin bisa menelurkan ide segar.
Dialogue: 0,0:11:19.20,0:11:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ubah krisis menjadi peluang!
Dialogue: 0,0:11:21.16,0:11:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar pendapat yang optimis, ya.
Dialogue: 0,0:11:24.58,0:11:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu terdengar sangat Subaru.
Dialogue: 0,0:11:27.96,0:11:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Subaru.
Dialogue: 0,0:11:30.38,0:11:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:11:31.63,0:11:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru tetaplah Subaru.
Dialogue: 0,0:11:34.71,0:11:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:11:36.22,0:11:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau hilang ingatan atau tidak,
Dialogue: 0,0:11:38.26,0:11:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sifatmu yang tak bisa membedakan\Nkeberanian dan kenekatan
Dialogue: 0,0:11:41.41,0:11:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak pernah berubah, ya.
Dialogue: 0,0:11:43.42,0:11:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Subaru,
Dialogue: 0,0:11:44.73,0:11:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin tahu kenapa kau hilang ingatan.
Dialogue: 0,0:11:47.93,0:11:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu aku sendiri juga tak tahu.
Dialogue: 0,0:11:52.07,0:11:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalian bisa menemukanku?
Dialogue: 0,0:11:54.94,0:11:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kamu pingsan\Ndi ruang arsip lantai tiga.
Dialogue: 0,0:11:59.29,0:12:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang arsip lantai tiga?
Dialogue: 0,0:12:04.87,0:12:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kami membawamu ke ruang hijau.
Dialogue: 0,0:12:08.47,0:12:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya,
Dialogue: 0,0:12:09.71,0:12:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemungkinan besar pemicunya\Nada di ruang arsip tersebut.
Dialogue: 0,0:12:13.42,0:12:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi,
Dialogue: 0,0:12:14.44,0:12:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu adalah ruang arsip\Nyang menyimpan Buku Orang Mati.
Dialogue: 0,0:12:17.67,0:12:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku Orang Mati?
Dialogue: 0,0:12:19.51,0:12:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa namanya kayak buatan\Ndelusi anak SMP?
Dialogue: 0,0:12:22.58,0:12:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku Orang Mati adalah
Dialogue: 0,0:12:23.72,0:12:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}buku yang memungkinkan pembaca\Nmengalami ingatan orang lain.
Dialogue: 0,0:12:28.02,0:12:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hal yang ingin kualami.
Dialogue: 0,0:12:30.06,0:12:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku pingsan karena membacanya?
Dialogue: 0,0:12:32.69,0:12:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu otakku kepanasan sampai amnesia?
Dialogue: 0,0:12:35.65,0:12:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sangat mungkin terjadi.
Dialogue: 0,0:12:37.99,0:12:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita harus ke sana.
Dialogue: 0,0:12:40.32,0:12:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, habis sarapan kita langsung ke TKP!
Dialogue: 0,0:12:43.91,0:12:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:44.70,0:12:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tapi akan gawat\Nkalau Subaru pingsan seperti kemarin.
Dialogue: 0,0:12:48.96,0:12:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kamu istirahat saja di sini\Nselagi kami menyelidikinya.
Dialogue: 0,0:12:52.71,0:12:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:58.42,0:13:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku kalah oleh tekanan sosial.
Dialogue: 0,0:13:01.80,0:13:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar aku pengecut.
Dialogue: 0,0:13:06.06,0:13:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status Open!
Dialogue: 0,0:13:10.14,0:13:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak muncul, ya.
Dialogue: 0,0:13:11.60,0:13:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal di dunia lain, aku harap bisa sihir.
Dialogue: 0,0:13:16.33,0:13:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak akan pernah\Nbisa lagi menggunakannya.
Dialogue: 0,0:13:19.28,0:13:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara sering pakai sihir dasar\Nyang sudah dilarang,
Dialogue: 0,0:13:22.99,0:13:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gerbangmu jadi rusak.
Dialogue: 0,0:13:25.03,0:13:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Payah banget rusak cuma karena sihir!
Dialogue: 0,0:13:27.99,0:13:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana dengan ini?!
Dialogue: 0,0:13:32.49,0:13:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya tubuhku bisa ingat\Nsecara refleks, 'kan?
Dialogue: 0,0:13:35.79,0:13:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya buatlah catatan\Ntentang hal yang sudah kulakukan.
Dialogue: 0,0:13:39.42,0:13:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak berguna sama sekali.
Dialogue: 0,0:13:45.18,0:13:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa. Pasti akan berhasil.
Dialogue: 0,0:13:47.89,0:13:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia ini pun aku...
Dialogue: 0,0:13:50.91,0:13:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, duh.
Dialogue: 0,0:13:52.48,0:13:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ke sini.
Dialogue: 0,0:14:01.86,0:14:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangga apa ini?\NTinggi banget.
Dialogue: 0,0:14:08.74,0:14:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:14:09.70,0:14:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu! Tunggu!
Dialogue: 0,0:14:10.45,0:14:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu! Tunggu! Tunggu! Tunggu!
Dialogue: 0,0:14:17.13,0:14:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, kamu tidak apa-apa?
Dialogue: 0,0:14:23.51,0:14:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia?
Dialogue: 0,0:14:26.11,0:14:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:14:27.68,0:14:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami benar-benar khawatir.
Dialogue: 0,0:14:29.76,0:14:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia, kau harus marahi lebih keras\Natau dia tidak akan jera.
Dialogue: 0,0:14:34.38,0:14:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:14:35.48,0:14:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, Beatrice juga bilang begitu.
Dialogue: 0,0:14:37.48,0:14:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat panik saat kamu tidak ada.
Dialogue: 0,0:14:39.61,0:14:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan hampir menangis saat menemukanmu\Ntergeletak tak sadarkan diri.
Dialogue: 0,0:14:43.16,0:14:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan katakan hal yang tidak perlu!
Dialogue: 0,0:14:46.87,0:14:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:48.38,0:14:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Mimpi?
Dialogue: 0,0:14:50.29,0:14:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?\N- Hm?
Dialogue: 0,0:14:52.62,0:14:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Eh?
Dialogue: 0,0:14:54.25,0:14:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku pingsan lagi di ruang arsip?
Dialogue: 0,0:14:57.27,0:14:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, lagi?
Dialogue: 0,0:14:58.93,0:15:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak, tadi kalian melarangku\Nuntuk pergi ke sana, 'kan?
Dialogue: 0,0:15:03.63,0:15:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melarangmu?
Dialogue: 0,0:15:05.62,0:15:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ucapan kita tak nyambung.
Dialogue: 0,0:15:08.98,0:15:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, bisa kau jelaskan situasi\Nyang sedang kau alami saat ini kepada Beti?
Dialogue: 0,0:15:14.14,0:15:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:15.14,0:15:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, seperti yang kubilang,
Dialogue: 0,0:15:17.10,0:15:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat bangun, aku amnesia.
Dialogue: 0,0:15:20.02,0:15:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tu-Tunggu dulu.\N- Ingatanku sejak tiba di dunia ini...
Dialogue: 0,0:15:22.78,0:15:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatan?
Dialogue: 0,0:15:23.57,0:15:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatan bagaimana?
Dialogue: 0,0:15:25.32,0:15:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:25.99,0:15:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kalian ribut soal bagian ini?
Dialogue: 0,0:15:28.53,0:15:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah cerita ke kalian.
Dialogue: 0,0:15:31.71,0:15:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:15:33.04,0:15:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percakapan ini, bahkan tadi...
Dialogue: 0,0:15:35.60,0:15:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini mimpi melihat masa depan?
Dialogue: 0,0:15:38.27,0:15:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru?
Dialogue: 0,0:15:39.79,0:15:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tenang dan dengarkanlah.
Dialogue: 0,0:15:42.24,0:15:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bermimpi melihat masa...
Dialogue: 0,0:15:46.71,0:15:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mungkin tidak percaya,
Dialogue: 0,0:15:49.73,0:15:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sepertinya aku amnesia.
Dialogue: 0,0:15:53.60,0:15:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip! Sekarang aku sudah lebih baik!
Dialogue: 0,0:15:55.98,0:15:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Subaru yang sedang kesulitan,
Dialogue: 0,0:15:58.89,0:16:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku tak boleh ikut murung.
Dialogue: 0,0:16:00.61,0:16:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ya ampun!
Dialogue: 0,0:16:03.02,0:16:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru memang partner kontrak\Nyang merepotkan.
Dialogue: 0,0:16:06.69,0:16:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai hal ini terulang lagi,
Dialogue: 0,0:16:09.20,0:16:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- atau kesabaran Beti bisa habis.\N- Di mimpiku, mereka tidak tahu.
Dialogue: 0,0:16:13.12,0:16:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:16:14.04,0:16:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki Subaru tak membahas\Nsoal kekuatan ini.
Dialogue: 0,0:16:18.62,0:16:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau pikirkan,
Dialogue: 0,0:16:21.88,0:16:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki Subaru?
Dialogue: 0,0:16:23.29,0:16:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelucon macam apa lagi ini, Barusu?
Dialogue: 0,0:16:25.55,0:16:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master.
Dialogue: 0,0:16:27.13,0:16:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Shaula.
Dialogue: 0,0:16:28.43,0:16:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid kesayangan Master
Dialogue: 0,0:16:30.55,0:16:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan penjaga bintang
Dialogue: 0,0:16:31.91,0:16:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Menara Pengawas Pleiades!\N- Ya ampun.
Dialogue: 0,0:16:32.97,0:16:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang ini benar-benar
Dialogue: 0,0:16:35.44,0:16:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- bikin repot, ya.\N- Aku ingin memberinya sedikit waktu.
Dialogue: 0,0:16:39.31,0:16:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, 'kan?
Dialogue: 0,0:16:43.22,0:16:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon, katakan semuanya.
Dialogue: 0,0:16:46.04,0:16:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persis seperti di mimpi, bikin muak.
Dialogue: 0,0:16:49.04,0:16:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi masalahnya...
Dialogue: 0,0:16:51.32,0:16:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Subaru, istirahatlah dulu.
Dialogue: 0,0:16:57.50,0:16:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan soal mereka,
Dialogue: 0,0:16:59.18,0:17:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi apa yang harus aku lakukan?
Dialogue: 0,0:17:00.92,0:17:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master, wajahmu menakutkan.
Dialogue: 0,0:17:03.33,0:17:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada masalah, aku siap dengar.
Dialogue: 0,0:17:06.17,0:17:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh, duh!
Dialogue: 0,0:17:07.76,0:17:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan, bocah nomor dua?!
Dialogue: 0,0:17:09.91,0:17:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya,
Dialogue: 0,0:17:10.97,0:17:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak mau dimarahi\Nkakak-kakak lain dan Beatrice.
Dialogue: 0,0:17:14.26,0:17:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih! Bikin kesal!
Dialogue: 0,0:17:16.64,0:17:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master, katakan sesuatu padanya, dong!
Dialogue: 0,0:17:19.69,0:17:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:20.51,0:17:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membantuku.
Dialogue: 0,0:17:23.24,0:17:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aneh berterima kasih ke pembunuh.
Dialogue: 0,0:17:26.10,0:17:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Master bodoh!
Dialogue: 0,0:17:28.03,0:17:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bego!
Dialogue: 0,0:17:29.24,0:17:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang ini benar-benar amnesia, ya?
Dialogue: 0,0:17:32.78,0:17:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sayangnya begitu.
Dialogue: 0,0:17:34.78,0:17:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku punya janji penting semacamnya?
Dialogue: 0,0:17:38.00,0:17:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin itu aku benar-benar ceroboh, ya.
Dialogue: 0,0:17:44.17,0:17:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Abang yang kemarin ceroboh itu...
Dialogue: 0,0:17:46.84,0:17:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga setuju.
Dialogue: 0,0:17:53.89,0:17:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus tahu pemicu sadar dari mimpi,
Dialogue: 0,0:17:56.76,0:17:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan apa yang terjadi setelahnya.
Dialogue: 0,0:18:03.19,0:18:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buset, tinggi banget.
Dialogue: 0,0:18:10.49,0:18:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada gunanya takut akan\Nmasa depan yang belum pasti.
Dialogue: 0,0:18:14.58,0:18:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, akan kuceritakan mimpiku.
Dialogue: 0,0:18:18.69,0:18:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu cara kerja mimpi itu,
Dialogue: 0,0:18:21.12,0:18:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti akan jadi senjata andalan.
Dialogue: 0,0:18:23.13,0:18:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:18:23.75,0:18:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidakkah bahaya membiarkan Natsuki ikut?
Dialogue: 0,0:18:27.80,0:18:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan mencemaskan nyawanya,
Dialogue: 0,0:18:30.26,0:18:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi menganggapnya sebagai beban,
Dialogue: 0,0:18:33.22,0:18:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti aku setuju.
Dialogue: 0,0:18:34.59,0:18:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram! Kau juga anggap Subaru beban?
Dialogue: 0,0:18:38.01,0:18:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bilang fakta secara objektif.
Dialogue: 0,0:18:40.22,0:18:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Emilia,
Dialogue: 0,0:18:41.31,0:18:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka hanya bilang banyak ketidakpastian
Dialogue: 0,0:18:45.85,0:18:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika kita mengandalkannya.
Dialogue: 0,0:18:48.27,0:18:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari perkataanmu itu...
Dialogue: 0,0:18:49.65,0:18:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa artinya kau setuju dengan roh itu?
Dialogue: 0,0:18:52.57,0:18:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai itu...
Dialogue: 0,0:18:54.28,0:18:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas mau cerita malah begini!\NSialan!
Dialogue: 0,0:19:03.27,0:19:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau situasinya begini,
Dialogue: 0,0:19:04.79,0:19:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa mereka bakal percaya mimpiku?
Dialogue: 0,0:19:13.16,0:19:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidakkah bahaya membiarkan Natsuki ikut?
Dialogue: 0,0:19:17.69,0:19:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju.
Dialogue: 0,0:19:19.13,0:19:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga anggap Subaru beban?
Dialogue: 0,0:19:22.06,0:19:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya bilang\Nbanyak ketidakpastian...
Dialogue: 0,0:19:25.19,0:19:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatanlah yang membentuk seseorang.
Dialogue: 0,0:19:30.90,0:19:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru tetaplah Subaru.
Dialogue: 0,0:19:34.29,0:19:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:19:38.62,0:19:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau siapa?
Dialogue: 0,0:19:46.37,0:19:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, kamu tidak apa-apa?
Dialogue: 0,0:19:48.62,0:19:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:19:52.91,0:19:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, tenanglah.
Dialogue: 0,0:19:55.53,0:19:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beatrice.
Dialogue: 0,0:20:20.31,0:20:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:20:21.96,0:20:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa kau pagi-pagi ke sini, hei?
Dialogue: 0,0:20:27.42,0:20:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei, jangan bilang kau menangis?
Dialogue: 0,0:20:31.29,0:20:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertengkar dengan temanmu di bawah, hah?
Dialogue: 0,0:20:34.60,0:20:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menangis karena kalah debat, hah?
Dialogue: 0,0:20:42.31,0:20:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau lari, hah?
Dialogue: 0,0:20:45.00,0:20:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelucon apa ini lari ke tempatku, hah?
Dialogue: 0,0:20:50.31,0:20:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri yang memilih kawanmu.
Dialogue: 0,0:20:54.02,0:20:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin mati, hah?
Dialogue: 0,0:20:56.22,0:20:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyahlah, keroco.
Dialogue: 0,0:21:01.41,0:21:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:21:11.12,0:21:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit.
Dialogue: 0,0:21:11.75,0:21:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit, sakit...
Dialogue: 0,0:21:13.62,0:21:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit banget.
Dialogue: 0,0:21:15.17,0:21:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:17.73,0:21:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal beberapa jam lalu
Dialogue: 0,0:21:19.67,0:21:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bersama ayah dan ibu.
Dialogue: 0,0:21:25.85,0:21:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati di jalan.
Dialogue: 0,0:21:29.68,0:21:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin mencuci gelas,
Dialogue: 0,0:21:33.62,0:21:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya aku diam saja pada ibu.
Dialogue: 0,0:21:37.76,0:21:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku bilang, "Aku pergi dulu."
Dialogue: 0,0:21:40.07,0:21:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah merepotkan mereka.
Dialogue: 0,0:21:42.36,0:21:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa membalas budi mereka.
Dialogue: 0,0:21:44.66,0:21:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mencuci gelasnya.
Dialogue: 0,0:21:46.78,0:21:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mati.
Dialogue: 0,0:21:50.76,0:21:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertawa.
Dialogue: 0,0:21:52.69,0:21:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertawa.
Dialogue: 0,0:21:54.38,0:21:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertawa!
Dialogue: 0,0:21:56.71,0:21:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertawa! Hentikan!
Dialogue: 0,0:21:58.89,0:22:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mati, tapi bukan olehmu!
Dialogue: 0,0:22:01.38,0:22:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan mati di tanganmu!
Dialogue: 0,0:22:03.63,0:22:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sudi dibunuh olehmu!
Dialogue: 0,0:22:07.35,0:22:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mati! Aku sudah mati!\NAku mati!
Dialogue: 0,0:22:10.27,0:22:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati! Aku sudah mati!
Dialogue: 0,0:22:12.60,0:22:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati... lalu kembali ke sini...
Dialogue: 0,0:22:14.98,0:22:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku akan...
Dialogue: 0,0:22:16.81,0:22:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:22:23.60,0:22:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:22:32.80,0:22:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik
Dialogue: 0,0:22:34.20,0:22:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bunuh saja aku.
Dialogue: 0,0:22:36.49,0:22:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru!
Dialogue: 0,0:22:45.36,0:22:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru.
Dialogue: 0,0:22:51.73,0:22:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan Rem.
Dialogue: 0,0:22:55.47,0:22:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, istirahatlah dulu di sini, ya.
Dialogue: 0,0:22:58.36,0:23:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beti pasti akan turun tangan.
Dialogue: 0,0:23:01.29,0:23:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beti takkan biarkan kau terpuruk sendiri.
Dialogue: 0,0:23:16.07,0:23:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dua kali...
Dialogue: 0,0:23:17.91,0:23:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua kali mati.
Dialogue: 0,0:23:20.16,0:23:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat jatuh dan mati,
Dialogue: 0,0:23:22.78,0:23:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku kembali ke ruangan itu.
Dialogue: 0,0:23:25.11,0:23:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengulang waktu yang sama.
Dialogue: 0,0:23:29.31,0:23:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan mimpi melihat masa depan.
Dialogue: 0,0:23:31.64,0:23:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melainkan Kembali dari Kematian.
Dialogue: 0,0:23:34.27,0:23:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang sudi mati?
Dialogue: 0,0:23:57.53,0:23:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master.
