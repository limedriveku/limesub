Dialogue: 0,0:23:35.10,0:23:36.20,tanda,,0000,0000,0000,,JULIUS JUUKULIUS
Dialogue: 0,0:00:02.36,0:00:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin tak ada yang akan percaya.
Dialogue: 0,0:00:09.24,0:00:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu kalian, Anggota Dewan Bijak.
Dialogue: 0,0:00:12.45,0:00:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Natsuki Subaru.
Dialogue: 0,0:00:14.54,0:00:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pelayan di kediaman Roswaal\Ndan kesatria pribadi
Dialogue: 0,0:00:18.21,0:00:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari kandidat kami, Nona Emilia!
Dialogue: 0,0:01:51.22,0:01:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Re:ZERO -Starting Life in Another World-\NSeason 4
Dialogue: 0,0:02:03.48,0:02:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya nama untuk dikenalkan.
Dialogue: 0,0:02:06.23,0:02:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanyalah pengayun tongkat.
Dialogue: 0,0:02:21.25,0:02:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kau?
Dialogue: 0,0:02:22.83,0:02:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melempar pedang ke arahku?\NMau mati?
Dialogue: 0,0:02:26.88,0:02:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerang lawan tak bersenjata\Nitu tindakan pengecut.
Dialogue: 0,0:02:29.96,0:02:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat memalukan bagi seorang kesatria.
Dialogue: 0,0:02:31.88,0:02:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halah, jangan bikin aku tertawa!
Dialogue: 0,0:02:35.34,0:02:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kau menyesal ucapkan itu!
Dialogue: 0,0:02:43.02,0:02:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang aku tak bersenjata?
Dialogue: 0,0:02:45.77,0:02:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat baik-baik!
Dialogue: 0,0:02:49.06,0:02:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ranting... pohon?
Dialogue: 0,0:02:51.03,0:02:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ini sumpit.
Dialogue: 0,0:02:53.82,0:02:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubawa ke mana-mana buat camilan.
Dialogue: 0,0:02:56.86,0:03:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan sudut terbaik, kecepatan terbaik,
Dialogue: 0,0:03:00.03,0:03:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sentuhan terbaik, dan ayunan terbaik.
Dialogue: 0,0:03:04.66,0:03:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dengan sumpit pun,
Dialogue: 0,0:03:06.17,0:03:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}segalanya bisa kupotong!
Dialogue: 0,0:03:32.90,0:03:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Julius!\N- Jiwald!
Dialogue: 0,0:03:38.91,0:03:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangku bahkan bisa membelah cahaya.
Dialogue: 0,0:03:43.12,0:03:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwald!
Dialogue: 0,0:03:56.76,0:03:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwald! Jiwald!
Dialogue: 0,0:03:59.05,0:04:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bidik yang benar!
Dialogue: 0,0:04:01.14,0:04:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, kau takkan bisa\Nrebut balik pria tampan ini!
Dialogue: 0,0:04:04.31,0:04:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwald! Jiwald!
Dialogue: 0,0:04:06.35,0:04:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwald! Jiwald!
Dialogue: 0,0:04:08.27,0:04:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwald!
Dialogue: 0,0:04:10.94,0:04:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anastasia! Sudah, hentikan...
Dialogue: 0,0:04:14.36,0:04:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwald...
Dialogue: 0,0:04:19.14,0:04:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Anastasia!
Dialogue: 0,0:04:26.58,0:04:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru seru.
Dialogue: 0,0:04:29.16,0:04:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin semangat aku jadinya.
Dialogue: 0,0:04:33.21,0:04:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir!
Dialogue: 0,0:04:45.72,0:04:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:04:47.22,0:04:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bikin aku tertawa.
Dialogue: 0,0:04:49.85,0:04:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau anggap ini serius,\Nberarti kau sangat mengecewakan.
Dialogue: 0,0:04:53.52,0:04:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membosankan.
Dialogue: 0,0:04:56.07,0:04:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...!
Dialogue: 0,0:04:57.48,0:05:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau ke wanitamu, silakan pergi.
Dialogue: 0,0:05:00.70,0:05:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menangis dan merengeklah di pangkuannya.
Dialogue: 0,0:05:04.24,0:05:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pendekar pedang jelek tak berguna.
Dialogue: 0,0:05:13.25,0:05:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidurlah.
Dialogue: 0,0:05:23.47,0:05:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, siapa berikutnya?
Dialogue: 0,0:05:28.35,0:05:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tanya satu hal.
Dialogue: 0,0:05:31.10,0:05:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kami sudah cukup\Nuntuk buatmu bergerak selangkah?
Dialogue: 0,0:05:34.02,0:05:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kamu berlarian ke sana-sini.
Dialogue: 0,0:05:35.65,0:05:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dianggap serius.
Dialogue: 0,0:05:37.32,0:05:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma biar kelihatan keren.
Dialogue: 0,0:05:39.78,0:05:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham, 'kan?\NOh, tidak, ya?
Dialogue: 0,0:05:43.03,0:05:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kau wanita.
Dialogue: 0,0:05:44.66,0:05:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi wanita bening.
Dialogue: 0,0:05:46.62,0:05:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mending nanti malam kita main.
Dialogue: 0,0:05:48.54,0:05:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak mengerti maksudmu.
Dialogue: 0,0:05:51.12,0:05:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku memang\Ntidak akan bisa mengalahkanmu.
Dialogue: 0,0:05:55.04,0:05:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Emilia?
Dialogue: 0,0:05:58.21,0:06:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat kuat.
Dialogue: 0,0:06:00.13,0:06:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah jelas terlihat.
Dialogue: 0,0:06:02.51,0:06:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami harus melewati ujian ini.
Dialogue: 0,0:06:05.97,0:06:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, tunjukkan cara\Nagar kami bisa menang.
Dialogue: 0,0:06:10.10,0:06:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa buatmu bergerak selangkah,\Nkami menang.
Dialogue: 0,0:06:13.56,0:06:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pertaruhkan itu.
Dialogue: 0,0:06:16.19,0:06:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh?
Dialogue: 0,0:06:19.65,0:06:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.\NAku suka kau.
Dialogue: 0,0:06:21.99,0:06:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau orang paling bodoh setelah Trisha.
Dialogue: 0,0:06:24.49,0:06:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka!
Dialogue: 0,0:06:26.07,0:06:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa membuatku bergerak selangkah,\Nkau kuanggap menang.
Dialogue: 0,0:06:31.45,0:06:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jaga mereka.
Dialogue: 0,0:06:33.00,0:06:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obati mereka.
Dialogue: 0,0:06:34.29,0:06:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu dulu!
Dialogue: 0,0:06:35.71,0:06:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lihat sendiri tadi, 'kan?\NMaju tanpa rencana itu...
Dialogue: 0,0:06:37.75,0:06:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ice Brand Arts.
Dialogue: 0,0:06:46.97,0:06:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Icicle Line.
Dialogue: 0,0:06:50.22,0:06:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:51.47,0:06:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan serius.
Dialogue: 0,0:06:53.18,0:06:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah bening tapi licik juga kau.
Dialogue: 0,0:06:57.15,0:06:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan segalanya sepenuh hati,
Dialogue: 0,0:06:59.27,0:07:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itulah yang diajarkan kesatriaku!
Dialogue: 0,0:07:25.22,0:07:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua aman, kurasa.
Dialogue: 0,0:07:27.30,0:07:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi...\N- Aku tahu.
Dialogue: 0,0:07:34.14,0:07:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bergerak.
Dialogue: 0,0:08:20.15,0:08:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena!
Dialogue: 0,0:08:26.65,0:08:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:28.49,0:08:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keuntungan melawan wanita.
Dialogue: 0,0:08:30.45,0:08:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan marah cuma soal beginian...
Dialogue: 0,0:08:42.28,0:08:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:08:44.63,0:08:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:08:45.75,0:08:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang kau lakukan?
Dialogue: 0,0:08:48.01,0:08:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya serangan begitu\Nbikin gerakan jadi kaku!
Dialogue: 0,0:08:52.05,0:08:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cuma menyentuh tubuhku, 'kan?
Dialogue: 0,0:08:53.97,0:08:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tadi kamu penuh celah.
Dialogue: 0,0:08:55.60,0:08:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:08:56.81,0:08:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dibesarkan seperti apa?
Dialogue: 0,0:08:58.56,0:09:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dilakukan orang tuamu?
Dialogue: 0,0:09:00.56,0:09:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah bicara?
Dialogue: 0,0:09:02.31,0:09:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Urus wanita bening ini!
Dialogue: 0,0:09:04.73,0:09:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali-kali ajaklah jalan!\NKau pendampingnya, 'kan?
Dialogue: 0,0:09:07.53,0:09:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri yang jangan main-main!\NApa-apaan itu?!
Dialogue: 0,0:09:11.32,0:09:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar cabul, bajingan,\NUskup Agung pendosa besar!
Dialogue: 0,0:09:14.12,0:09:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau juga akan kubunuh!\N- Subaru, tenanglah.
Dialogue: 0,0:09:16.54,0:09:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beti paham perasaanmu, tapi lihat.
Dialogue: 0,0:09:21.12,0:09:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bergerak lebih dari selangkah.
Dialogue: 0,0:09:23.83,0:09:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga!
Dialogue: 0,0:09:25.50,0:09:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Aku menang!
Dialogue: 0,0:09:27.75,0:09:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun caranya,\Nmenang tetaplah menang.
Dialogue: 0,0:09:31.17,0:09:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana?
Dialogue: 0,0:09:33.47,0:09:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halah, iya deh.
Dialogue: 0,0:09:35.80,0:09:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kukatakan, ya kukatakan.
Dialogue: 0,0:09:37.97,0:09:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau mengakuinya?
Dialogue: 0,0:09:40.18,0:09:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku ini siapa?
Dialogue: 0,0:09:43.40,0:09:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kutarik ucapanku,\Nreputasiku bisa hancur, tahu!
Dialogue: 0,0:09:47.77,0:09:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekalahanmu yang memalukan itu\Nsudah cukup menghancurkan reputasimu.
Dialogue: 0,0:09:52.24,0:09:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik, keroco!
Dialogue: 0,0:09:54.16,0:09:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya si bening itu yang menang.
Dialogue: 0,0:09:57.16,0:09:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubiarkan dia lewat.
Dialogue: 0,0:09:58.74,0:10:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada pilihan lain.
Dialogue: 0,0:10:06.17,0:10:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, berikutnya si keroco itu?
Dialogue: 0,0:10:10.63,0:10:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau salah satu dari dua bocah itu?
Dialogue: 0,0:10:14.51,0:10:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tujuh orang di dalam menara.
Dialogue: 0,0:10:17.55,0:10:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang sudah lolos baru wanitamu seorang.
Dialogue: 0,0:10:21.31,0:10:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:10:22.60,0:10:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa berikutnya yang akan melewatiku?
Dialogue: 0,0:10:27.15,0:10:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian.
Dialogue: 0,0:10:30.79,0:10:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu alasannya kau kabur\Ndengan muka merah?
Dialogue: 0,0:10:34.15,0:10:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menohok juga kata-katamu, Kakak.
Dialogue: 0,0:10:37.03,0:10:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, jangan begitu.
Dialogue: 0,0:10:38.95,0:10:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kesannya kau benar-benar\Nmaster dari gadis tidur itu.
Dialogue: 0,0:10:42.45,0:10:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, gawat. Harus lebih hati-hati.
Dialogue: 0,0:10:45.42,0:10:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalah telak, ya.
Dialogue: 0,0:10:46.79,0:10:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setidaknya Nona Emilia berhasil\Nmenarik perhatian lawan.
Dialogue: 0,0:10:50.34,0:10:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku menang.
Dialogue: 0,0:10:52.26,0:10:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku naik sendiri ke atas...
Dialogue: 0,0:10:53.97,0:10:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan.
Dialogue: 0,0:10:56.39,0:10:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, itu...
Dialogue: 0,0:10:58.26,0:10:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahaya.
Dialogue: 0,0:10:59.47,0:11:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan sangat berhati-hati.
Dialogue: 0,0:11:01.22,0:11:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahaya.
Dialogue: 0,0:11:02.39,0:11:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sangat berbahaya.\N- Berbahaya.
Dialogue: 0,0:11:06.14,0:11:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga Julius tidak terlalu murung.
Dialogue: 0,0:11:10.23,0:11:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khawatir?
Dialogue: 0,0:11:11.90,0:11:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:11:13.28,0:11:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin iya, aku khawatir.
Dialogue: 0,0:11:16.82,0:11:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak sesederhana itu.
Dialogue: 0,0:11:20.74,0:11:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:11:22.33,0:11:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia sampai rela
Dialogue: 0,0:11:24.66,0:11:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengorbankan diri demi Julius?
Dialogue: 0,0:11:26.87,0:11:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga khawatir soal mereka,
Dialogue: 0,0:11:28.79,0:11:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi urusan ujian juga penting.
Dialogue: 0,0:11:31.09,0:11:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak bisa lolos,
Dialogue: 0,0:11:32.46,0:11:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita takkan tahu cara membangunkan Rem.
Dialogue: 0,0:11:34.72,0:11:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang, pengujinya itu\Nmonster yang luar biasa kuat.
Dialogue: 0,0:11:38.84,0:11:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin setara Reinhard.
Dialogue: 0,0:11:40.76,0:11:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:41.76,0:11:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rasa memang sekuat itu.
Dialogue: 0,0:11:43.81,0:11:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa disebut setara dengannya
Dialogue: 0,0:11:46.89,0:11:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya ada satu orang di tiap negara.
Dialogue: 0,0:11:49.15,0:11:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Reinhard yang terkuat di kerajaan,
Dialogue: 0,0:11:51.82,0:11:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tiap negara punya satu orang terkuat?
Dialogue: 0,0:11:57.32,0:11:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Kekaisaran Vollachia,
Dialogue: 0,0:11:59.36,0:12:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cecilus Segmunt sang Kilat Biru.
Dialogue: 0,0:12:03.54,0:12:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Gila dari Kerajaan Suci Gusteko.
Dialogue: 0,0:12:07.33,0:12:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dari Negara Kota Kararagi,\NHalibel sang Pemuja.
Dialogue: 0,0:12:11.75,0:12:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak satu pun yang mirip si pengayun tongkat.
Dialogue: 0,0:12:14.21,0:12:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya pakaiannya mirip\Ngaya tradisional Kararagi.
Dialogue: 0,0:12:17.88,0:12:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan mahir menggunakan sumpit.
Dialogue: 0,0:12:20.26,0:12:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi penyebutan dan penggunaannya berbeda,
Dialogue: 0,0:12:22.47,0:12:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi rasanya kurang cocok...
Dialogue: 0,0:12:24.43,0:12:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kakak-Kakak, boleh minta waktu sebentar?
Dialogue: 0,0:12:31.27,0:12:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master, jangan tinggalkan aku sendirian.
Dialogue: 0,0:12:35.48,0:12:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau sendirian lagi.
Dialogue: 0,0:12:37.94,0:12:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang hal-hal menyedihkan begitu!
Dialogue: 0,0:12:41.03,0:12:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kau sudah bangun, 'kan?
Dialogue: 0,0:12:43.33,0:12:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Idih.
Dialogue: 0,0:12:47.50,0:12:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:12:49.08,0:12:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kita ada di sini?
Dialogue: 0,0:12:51.63,0:12:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak salah,\Nkita berhasil melewati ujian
Dialogue: 0,0:12:55.00,0:12:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berkat wawasan luar biasa Master...
Dialogue: 0,0:12:56.88,0:12:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini mimpi, 'kan?\N- Kenyataan.
Dialogue: 0,0:12:59.47,0:13:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus Master memelukku,
Dialogue: 0,0:13:02.76,0:13:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Takkan kulepaskan lagi."\NSambil senyum.
Dialogue: 0,0:13:04.93,0:13:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti mimpi!
Dialogue: 0,0:13:06.31,0:13:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pingsan begitu ujian kedua dimulai.
Dialogue: 0,0:13:09.77,0:13:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pingsan? Aku?
Dialogue: 0,0:13:12.15,0:13:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku melakukan\Nhal memalukan begitu.
Dialogue: 0,0:13:15.40,0:13:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak ingat?
Dialogue: 0,0:13:17.32,0:13:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik tangga panjang,\Nlalu masuk ke ruangan putih.
Dialogue: 0,0:13:21.95,0:13:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pedang dicabut,\Nsuasana berubah dan seseorang muncul.
Dialogue: 0,0:13:27.45,0:13:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok berambut merah bermata biru,
Dialogue: 0,0:13:29.50,0:13:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mengaku sebagai pengayun tongkat.
Dialogue: 0,0:13:32.67,0:13:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, sakit! Sakit! Sakit!
Dialogue: 0,0:13:35.46,0:13:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau ingat?
Dialogue: 0,0:13:37.00,0:13:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa dia ada di sini?
Dialogue: 0,0:13:39.51,0:13:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih hidup!
Dialogue: 0,0:13:40.67,0:13:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang susah mati dia itu!
Dialogue: 0,0:13:43.64,0:13:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:45.26,0:13:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengayun! Reid si Pengayun Tongkat!
Dialogue: 0,0:13:47.72,0:13:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu biadab! Iblis!
Dialogue: 0,0:13:49.93,0:13:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hidup lagi cuma buat\Nmeremas dadaku lagi!
Dialogue: 0,0:13:55.27,0:13:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reid? Kalau tak salah Reid itu...
Dialogue: 0,0:13:59.19,0:14:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reid Astrea.
Dialogue: 0,0:14:01.03,0:14:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Suci pertama.
Dialogue: 0,0:14:06.16,0:14:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, maaf mengganggu istirahatmu.
Dialogue: 0,0:14:09.04,0:14:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tahu identitasnya.
Dialogue: 0,0:14:10.75,0:14:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu...
Dialogue: 0,0:14:14.21,0:14:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si bodoh itu!
Dialogue: 0,0:14:23.09,0:14:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini aku tidak akan main-main.
Dialogue: 0,0:14:27.26,0:14:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah.
Dialogue: 0,0:14:30.89,0:14:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Pengawal Kerajaan Lugunica,\NJulius Juukulius.
Dialogue: 0,0:14:35.06,0:14:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kau masih menyandang\Ngelar membosankan itu,
Dialogue: 0,0:14:38.27,0:14:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak layak jadi lawan mainku.
Dialogue: 0,0:14:51.33,0:14:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membosankan.
Dialogue: 0,0:14:52.79,0:14:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu terpaku pada buku panduan!
Dialogue: 0,0:15:02.01,0:15:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan!
Dialogue: 0,0:15:13.60,0:15:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyedihkan sekali.
Dialogue: 0,0:15:15.73,0:15:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berapa lama kau pegang pedang?
Dialogue: 0,0:15:18.27,0:15:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku saja baru tiga bulan pegang pedang.
Dialogue: 0,0:15:34.45,0:15:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... di sini sekarang
Dialogue: 0,0:15:37.37,0:15:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan mengalahkanmu...
Dialogue: 0,0:15:38.29,0:15:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bodoh.
Dialogue: 0,0:15:40.00,0:15:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kau bisa?
Dialogue: 0,0:15:41.96,0:15:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak akan bisa mengalahkanku.
Dialogue: 0,0:15:48.39,0:15:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa menyentuhku,\Napalagi menyerangku.
Dialogue: 0,0:15:52.06,0:15:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak mampu.
Dialogue: 0,0:15:54.31,0:15:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan tempat untukmu!
Dialogue: 0,0:15:57.23,0:15:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelmu berbeda!
Dialogue: 0,0:15:59.31,0:16:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak diundang ke sini!
Dialogue: 0,0:16:06.86,0:16:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang mau melihatmu.
Dialogue: 0,0:16:10.16,0:16:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang berharap padamu.
Dialogue: 0,0:16:12.28,0:16:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan manja kira aku\Nsedang bermain-main denganmu!
Dialogue: 0,0:16:22.79,0:16:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa menahannya?
Dialogue: 0,0:16:24.30,0:16:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin membosankan saja kau ini.
Dialogue: 0,0:16:39.31,0:16:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, bagiku...
Dialogue: 0,0:16:43.86,0:16:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini
Dialogue: 0,0:16:48.15,0:16:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah satu-satunya...
Dialogue: 0,0:16:52.62,0:16:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keraguanmu tampak jelas dari pedangmu.
Dialogue: 0,0:16:57.20,0:16:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak layak meraih pedang surgawi.
Dialogue: 0,0:17:00.46,0:17:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan tak pantas jadi bawahanku.
Dialogue: 0,0:17:16.93,0:17:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat tahu kekuatanmu.
Dialogue: 0,0:17:19.68,0:17:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa maluku tahu itu!
Dialogue: 0,0:17:21.84,0:17:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun semua orang melupakanmu!
Dialogue: 0,0:17:25.35,0:17:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius!
Dialogue: 0,0:18:03.94,0:18:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goyangannya terasa sekali.
Dialogue: 0,0:18:07.44,0:18:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sadar?
Dialogue: 0,0:18:08.69,0:18:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang digendong olehmu?
Dialogue: 0,0:18:11.69,0:18:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:13.07,0:18:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal tahu saja,\Nini sudah yang kedua kalinya, lo.
Dialogue: 0,0:18:16.12,0:18:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru 30 menit bilang takkan mau lagi,\Ntapi malah melakukannya lagi.
Dialogue: 0,0:18:20.87,0:18:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu rasanya seperti apa?
Dialogue: 0,0:18:22.58,0:18:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja rasanya tak nyaman.
Dialogue: 0,0:18:25.71,0:18:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kujatuhkan?
Dialogue: 0,0:18:39.68,0:18:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Nona Anastasia baik-baik saja?
Dialogue: 0,0:18:42.68,0:18:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawanya tidak terancam.
Dialogue: 0,0:18:45.06,0:18:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru kau yang hampir tewas\Nmelawan orang itu.
Dialogue: 0,0:18:49.57,0:18:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, siapa kiranya\Nsi penutup mata bajingan itu...
Dialogue: 0,0:18:52.49,0:18:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reid Astrea.
Dialogue: 0,0:18:54.61,0:18:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau tahu juga.
Dialogue: 0,0:18:56.36,0:18:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu dari Shaula.
Dialogue: 0,0:18:58.32,0:19:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah curiga saat dia menyebut dirinya\N"pengayun tongkat".
Dialogue: 0,0:19:01.91,0:19:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku kurang yakin.
Dialogue: 0,0:19:03.87,0:19:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf tidak memberitahumu.
Dialogue: 0,0:19:05.83,0:19:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak...
Dialogue: 0,0:19:12.63,0:19:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius.
Dialogue: 0,0:19:14.67,0:19:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kau juga akan tahu,\Njadi kuberi tahu sekarang saja.
Dialogue: 0,0:19:18.76,0:19:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kau dan Anastasia tumbang,
Dialogue: 0,0:19:21.31,0:19:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia berhasil lolos ujian.
Dialogue: 0,0:19:24.64,0:19:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja...
Dialogue: 0,0:19:26.23,0:19:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak mengalahkannya secara langsung.
Dialogue: 0,0:19:29.31,0:19:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak kebetulan yang terjadi,
Dialogue: 0,0:19:31.77,0:19:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Emilia itu... spesial...
Dialogue: 0,0:19:35.40,0:19:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, maksudku...
Dialogue: 0,0:19:38.45,0:19:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terbebani.
Dialogue: 0,0:19:40.58,0:19:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbebani?
Dialogue: 0,0:19:42.20,0:19:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Nona Emilia bisa melewati ujiannya,
Dialogue: 0,0:19:44.95,0:19:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}artinya Reid sang Pedang Suci\Nbukanlah hal yang mustahil.
Dialogue: 0,0:19:48.37,0:19:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengetahui itu adalah keuntungan.
Dialogue: 0,0:19:50.63,0:19:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:19:53.17,0:19:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:19:55.05,0:19:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau kau mengerti.
Dialogue: 0,0:19:59.43,0:20:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sudah waktunya aku turun.
Dialogue: 0,0:20:02.26,0:20:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mual kalau terlalu lama\Ndigendong olehmu.
Dialogue: 0,0:20:06.27,0:20:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia bisa marah kalau tahu\Naku biarkan orang terluka jalan sendiri.
Dialogue: 0,0:20:10.27,0:20:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah sadar.\NBisa jalan sendiri.
Dialogue: 0,0:20:12.61,0:20:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlambat sok tegar.
Dialogue: 0,0:20:14.48,0:20:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua sudah melihatmu saat mau digendong.
Dialogue: 0,0:20:17.74,0:20:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya Shaula dan Anastasia\Nyang tidak melihatmu karena pingsan.
Dialogue: 0,0:20:21.37,0:20:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti itu alasannya.
Dialogue: 0,0:20:23.28,0:20:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau Nona Anastasia melihatku.
Dialogue: 0,0:20:25.12,0:20:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri begitu.
Dialogue: 0,0:20:27.62,0:20:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunkan aku.
Dialogue: 0,0:20:28.58,0:20:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, ya.
Dialogue: 0,0:20:30.04,0:20:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula...
Dialogue: 0,0:20:30.63,0:20:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilang turunkan aku!
Dialogue: 0,0:20:32.21,0:20:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bodoh!
Dialogue: 0,0:20:39.76,0:20:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini...
Dialogue: 0,0:20:41.26,0:20:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:20:42.51,0:20:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau pikirkan?
Dialogue: 0,0:20:43.47,0:20:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat!
Dialogue: 0,0:20:48.23,0:20:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa berdiri sendiri.
Dialogue: 0,0:20:51.81,0:20:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh
Dialogue: 0,0:20:55.94,0:20:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bantuanmu.
Dialogue: 0,0:21:07.95,0:21:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, 'kan?
Dialogue: 0,0:21:10.37,0:21:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdiri sendiri bukan hal yang sulit.
Dialogue: 0,0:21:15.25,0:21:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang butuh sedikit waktu,
Dialogue: 0,0:21:17.80,0:21:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak perlu bantuanmu.
Dialogue: 0,0:21:21.30,0:21:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memungkinkan,\Nbisa kau jelaskan dulu ke yang lain?
Dialogue: 0,0:21:25.68,0:21:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detailnya biar aku yang jelaskan.
Dialogue: 0,0:21:28.31,0:21:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang perlu kau lakukan
Dialogue: 0,0:21:29.77,0:21:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya sampaikan bahwa aku sudah ditemukan.
Dialogue: 0,0:21:36.69,0:21:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sial! Sial! Sial! Sial!
Dialogue: 0,0:21:39.61,0:21:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:21:40.65,0:21:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua sama-sama bodoh!
Dialogue: 0,0:21:44.28,0:21:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mau apa kau?\N- Berisik!
Dialogue: 0,0:21:45.95,0:21:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang bisa berdiri sendiri?
Dialogue: 0,0:21:47.79,0:21:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakimu jelas-jelas gemetaran!
Dialogue: 0,0:21:51.12,0:21:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tengah jalan pun kau tahu\Ntakkan bisa menang, 'kan?
Dialogue: 0,0:21:54.29,0:21:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipukul, ditendang, dijatuhkan.
Dialogue: 0,0:21:56.71,0:21:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau tak punya pilihan\Nselain terus maju, 'kan?
Dialogue: 0,0:21:59.42,0:22:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu satu-satunya cara\Nmeluapkan semuanya!
Dialogue: 0,0:22:03.18,0:22:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara seseorang,\Naku sudah merasakannya sampai ke hati!
Dialogue: 0,0:22:13.10,0:22:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan pura-pura tahu\Napa yang ada di pikiranmu.
Dialogue: 0,0:22:18.48,0:22:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang,\Nkau yang turun di tangga ini,
Dialogue: 0,0:22:22.36,0:22:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di tangga yang panjang ini,
Dialogue: 0,0:22:24.78,0:22:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak perlu melakukannya sendirian.
Dialogue: 0,0:22:27.99,0:22:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pinjamkan bahuku.
Dialogue: 0,0:22:30.20,0:22:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kuhitung ini sebagai utang budi.
Dialogue: 0,0:22:32.87,0:22:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu, aku...
Dialogue: 0,0:22:36.29,0:22:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, tak mungkin aku
Dialogue: 0,0:22:39.09,0:22:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membiarkanmu jalan sendirian di tangga ini.
Dialogue: 0,0:22:49.81,0:22:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru.
Dialogue: 0,0:22:51.27,0:22:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:53.52,0:22:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:22:55.94,0:22:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:23:04.32,0:23:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin...
Dialogue: 0,0:23:07.87,0:23:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada yang akan percaya.
Dialogue: 0,0:23:11.24,0:23:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu,
Dialogue: 0,0:23:13.12,0:23:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang pembual besar yang menjadikan\Nsemua orang di ruangan itu sebagai musuhnya.
Dialogue: 0,0:23:18.08,0:23:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan orang yang mengatakannya,
Dialogue: 0,0:23:20.29,0:23:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sadar bahwa itu adalah pernyataan
Dialogue: 0,0:23:22.30,0:23:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terlontar karena emosi sesaat\Ndan terbawa suasana.
Dialogue: 0,0:23:27.39,0:23:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:23:31.60,0:23:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:23:33.43,0:23:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya ada satu orang...
Dialogue: 0,0:23:36.23,0:23:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya pria yang terkesan\Noleh hal itu.
