Dialogue: 0,0:04:09.23,0:04:14.07,tanda,,0000,0000,0000,,RE:ZERO KARA HAJIMERU ISEKAI SEIKATSU
Dialogue: 0,0:22:08.01,0:22:09.31,tanda,,0000,0000,0000,,PENJAGA MENARA PENGAWAS
Dialogue: 0,0:00:09.22,0:00:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu.
Dialogue: 0,0:00:11.16,0:00:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sampai kapan kau tidur?
Dialogue: 0,0:00:12.85,0:00:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunlah, Barusu.
Dialogue: 0,0:00:17.62,0:00:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini...
Dialogue: 0,0:00:18.88,0:00:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada angin dan suhunya rendah.
Dialogue: 0,0:00:21.32,0:00:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita di bawah tanah.
Dialogue: 0,0:00:23.91,0:00:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram?
Dialogue: 0,0:00:25.69,0:00:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di bawah tanah?
Dialogue: 0,0:00:27.82,0:00:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepatnya di bawah gurun pasir.
Dialogue: 0,0:00:29.66,0:00:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ucapan Nona Beatrice bisa dipercaya,
Dialogue: 0,0:00:33.42,0:00:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini karena ruang yang terpelintir.
Dialogue: 0,0:00:35.69,0:00:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita terlempar ke sini?
Dialogue: 0,0:00:38.50,0:00:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, terpisah?
Dialogue: 0,0:00:39.88,0:00:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, di mana yang lain?
Dialogue: 0,0:00:42.61,0:00:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa hanya kita berdua...
Dialogue: 0,0:00:45.77,0:00:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menanyakannya padaku?
Dialogue: 0,0:01:04.78,0:01:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Emilia dan Nona Beatrice tak terlihat.
Dialogue: 0,0:01:08.13,0:01:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar gawat.
Dialogue: 0,0:01:10.33,0:01:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu!
Dialogue: 0,0:01:11.56,0:01:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera berkumpul...
Dialogue: 0,0:01:13.23,0:01:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, utamakan Rem.
Dialogue: 0,0:01:15.25,0:01:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu.
Dialogue: 0,0:01:16.47,0:01:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkumpul dengan yang lain memang penting,
Dialogue: 0,0:01:18.42,0:01:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Rem itu prioritas!
Dialogue: 0,0:01:19.91,0:01:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bisa bergerak sendiri!
Dialogue: 0,0:01:22.22,0:01:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus cepat menemukannya!
Dialogue: 0,0:01:24.58,0:01:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu, tenanglah sedikit.
Dialogue: 0,0:01:26.33,0:01:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang?
Dialogue: 0,0:01:27.61,0:01:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa aku tenang!
Dialogue: 0,0:01:29.55,0:01:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tega membiarkan Rem sendirian?!
Dialogue: 0,0:01:32.07,0:01:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak!
Dialogue: 0,0:01:37.56,0:01:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahku. Sungguh, aku minta maaf.
Dialogue: 0,0:01:40.79,0:01:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu gegabah dan kelewatan.
Dialogue: 0,0:01:45.18,0:01:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah biasa.
Dialogue: 0,0:01:47.05,0:01:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasakan\Nkoneksi samar dengan Rem.
Dialogue: 0,0:01:50.05,0:01:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah dia ada di mana sekarang,
Dialogue: 0,0:01:52.25,0:01:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi setidaknya dia masih hidup.
Dialogue: 0,0:01:54.60,0:01:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga! Ikatan batin saudara kembar!
Dialogue: 0,0:01:57.90,0:02:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah bangun rupanya, Natsuki.
Dialogue: 0,0:02:00.79,0:02:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anastasia dan...
Dialogue: 0,0:02:02.66,0:02:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...Patrasche?
Dialogue: 0,0:02:04.20,0:02:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf meminjam Patrasche tanpa izin.
Dialogue: 0,0:02:07.13,0:02:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berani keliling sendirian.
Dialogue: 0,0:02:12.09,0:02:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri tidak masalah, sih...
Dialogue: 0,0:02:14.85,0:02:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah bilang kita cuma berdua.
Dialogue: 0,0:02:18.53,0:02:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana keadaan di sekitar?
Dialogue: 0,0:02:20.12,0:02:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang bagus.
Dialogue: 0,0:02:21.31,0:02:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada jalan keluar atau anak yang lain.
Dialogue: 0,0:02:24.87,0:02:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya hanya kita bertiga yang di sini.
Dialogue: 0,0:02:28.17,0:02:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ditambah Patrasche juga.
Dialogue: 0,0:02:31.24,0:02:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kita?
Dialogue: 0,0:02:32.87,0:02:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada gunanya meratapi nasib.
Dialogue: 0,0:02:35.17,0:02:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Barusu yang payah ini sudah bangun,
Dialogue: 0,0:02:37.84,0:02:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari kita cari Rem dan Nona Emilia.
Dialogue: 0,0:02:40.44,0:02:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari ke mana?
Dialogue: 0,0:02:42.27,0:02:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembagian tim ini\Nrasanya seperti disengaja.
Dialogue: 0,0:02:45.22,0:02:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak satu pun dari kita bisa bertarung!
Dialogue: 0,0:02:55.36,0:02:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Membentuk rasa sakit\Ndan menulis ulang namamu ♪
Dialogue: 0,0:02:58.71,0:03:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kembali ke nol, terlahir kembali ♪
Dialogue: 0,0:03:01.87,0:03:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku tersesat dalam hampa ♪
Dialogue: 0,0:03:03.62,0:03:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Takdir berputar, parade abadi ♪
Dialogue: 0,0:03:07.36,0:03:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku tahu takdir yang menunggu ♪
Dialogue: 0,0:03:08.71,0:03:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ubah, tempa, jadikan aku baru ♪
Dialogue: 0,0:03:12.07,0:03:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jadikan aku mitos dan legenda ♪
Dialogue: 0,0:03:13.71,0:03:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mati dan memulai kembali ♪
Dialogue: 0,0:03:15.35,0:03:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Semua yang kulakukan untuk dirimu ♪
Dialogue: 0,0:03:18.30,0:03:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Gunakanlah aku seperti senjata ♪
Dialogue: 0,0:03:20.30,0:03:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Biarkan aku hadapi malapetaka ♪
Dialogue: 0,0:03:21.95,0:03:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, terbakar! Meski berulang kali ♪
Dialogue: 0,0:03:27.03,0:03:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lawanlah keputusasaan itu ♪
Dialogue: 0,0:03:31.56,0:03:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mainkan melodi kehidupanmu ♪
Dialogue: 0,0:03:34.12,0:03:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski hilang nama, aku tetap ada ♪
Dialogue: 0,0:03:37.70,0:03:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Di tengah kehancuran\Nmenggema sebuah aria ♪
Dialogue: 0,0:03:41.22,0:03:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jawaban cinta yang terputus\Ndan terhubung kembali ♪
Dialogue: 0,0:03:45.45,0:03:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hancurkan, bakar, selamatkan ♪
Dialogue: 0,0:03:46.44,0:03:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Terbelenggu ♪
Dialogue: 0,0:03:48.25,0:03:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Takkan pernah lagi ♪
Dialogue: 0,0:03:49.31,0:03:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Penghancur besar, dan kusiap melibas ♪
Dialogue: 0,0:03:51.60,0:03:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sekali lagi ♪
Dialogue: 0,0:03:52.61,0:03:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berdiri di tengah kehancuran ♪
Dialogue: 0,0:03:54.54,0:03:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Di momen ini ♪
Dialogue: 0,0:03:55.78,0:03:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sebut namaku, kita akhiri sekarang ♪
Dialogue: 0,0:03:57.86,0:03:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Awas! ♪
Dialogue: 0,0:03:58.47,0:04:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kau kan hadapi animaku ♪
Dialogue: 0,0:04:00.14,0:04:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mati dan jalanilah!\NAyo bangun dan berdiri! ♪
Dialogue: 0,0:04:02.22,0:04:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Robek struktur realitas ♪
Dialogue: 0,0:04:04.04,0:04:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Biarkan keajaiban menjahitnya kembali ♪
Dialogue: 0,0:04:20.67,0:04:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya ada angin...
Dialogue: 0,0:04:23.06,0:04:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi entahlah.
Dialogue: 0,0:04:27.14,0:04:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu, kau bisa bicara dengan roh?
Dialogue: 0,0:04:29.26,0:04:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta petunjuk jalan dari roh kecil?
Dialogue: 0,0:04:32.04,0:04:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya,
Dialogue: 0,0:04:33.06,0:04:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ikatanku dan Beako\Nmembuat mereka ketakutan.
Dialogue: 0,0:04:37.72,0:04:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maklum, penyihir amatir\Nberkat Nona Beatrice.
Dialogue: 0,0:04:42.18,0:04:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku juga tak berharap banyak.
Dialogue: 0,0:04:46.07,0:04:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki.
Dialogue: 0,0:04:48.11,0:04:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dia mungkin terlihat tegar,
Dialogue: 0,0:04:50.54,0:04:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sebelum kau bangun tadi,
Dialogue: 0,0:04:53.54,0:04:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram sangat panik karena tak menemukan Rem.
Dialogue: 0,0:04:58.92,0:05:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:00.25,0:05:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:05:01.53,0:05:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau sudah membantunya menenangkan diri.
Dialogue: 0,0:05:05.47,0:05:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lumayan berguna, kok.
Dialogue: 0,0:05:11.80,0:05:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalannya bercabang.
Dialogue: 0,0:05:13.71,0:05:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita sengaja dibuat kebingungan.
Dialogue: 0,0:05:16.66,0:05:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, bagaimana?
Dialogue: 0,0:05:17.84,0:05:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setahuku,
Dialogue: 0,0:05:19.45,0:05:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurut Freud,\Nkita harus pilih jalan kanan.
Dialogue: 0,0:05:22.43,0:05:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pula itu?
Dialogue: 0,0:05:23.57,0:05:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya manusia cenderung memilih kiri.
Dialogue: 0,0:05:28.23,0:05:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:05:29.27,0:05:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memilih kanan adalah prinsip keadilanku!
Dialogue: 0,0:05:32.39,0:05:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat memercayai Freud ini, ya.
Dialogue: 0,0:05:34.75,0:05:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, dia itu siapa?
Dialogue: 0,0:05:52.79,0:05:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu?
Dialogue: 0,0:05:54.67,0:05:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar dan tampak tebal.
Dialogue: 0,0:05:56.81,0:05:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bisa digeser?
Dialogue: 0,0:05:58.35,0:06:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertutup sangat rapat, sepertinya sulit.
Dialogue: 0,0:06:02.07,0:06:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Natsuki...
Dialogue: 0,0:06:04.30,0:06:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau yakin ini pintu?
Dialogue: 0,0:06:07.33,0:06:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mataku ini hanya dinding besi biasa.
Dialogue: 0,0:06:10.88,0:06:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:11.57,0:06:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:12.82,0:06:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku ini cuma rongsokan besi penghalang.
Dialogue: 0,0:06:16.22,0:06:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, entah kenapa\Nrasanya seperti pintu...
Dialogue: 0,0:06:28.48,0:06:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:06:29.99,0:06:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, kau melakukan sesuatu?
Dialogue: 0,0:06:32.09,0:06:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan apa?
Dialogue: 0,0:06:33.67,0:06:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lihat sendiri,\Naku hanya menyentuhnya.
Dialogue: 0,0:06:36.72,0:06:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak melakukan apa pun,\Naku juga bingung.
Dialogue: 0,0:06:40.02,0:06:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:06:42.62,0:06:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patrasche?
Dialogue: 0,0:06:45.94,0:06:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau ingin melindungi kami.
Dialogue: 0,0:06:49.72,0:06:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tak ada tempat aman\Ndi situasi begini.
Dialogue: 0,0:06:53.06,0:06:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus siap mengambil risiko\Ndi mana pun.
Dialogue: 0,0:06:56.09,0:06:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekaranglah saatnya.
Dialogue: 0,0:07:01.07,0:07:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau malah dikangkangi, ya.
Dialogue: 0,0:07:03.00,0:07:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada aku yang mengangkangi perempuan,
Dialogue: 0,0:07:06.29,0:07:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik aku yang dikangkangi.
Dialogue: 0,0:07:08.77,0:07:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum.
Dialogue: 0,0:07:09.44,0:07:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu maksudnya!
Dialogue: 0,0:07:17.62,0:07:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah yang kedua.
Dialogue: 0,0:07:19.58,0:07:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghilang lagi, pula.
Dialogue: 0,0:07:22.30,0:07:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gunanya pintu\Njika tak menghalangi jalan?
Dialogue: 0,0:07:26.83,0:07:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:28.34,0:07:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:07:29.25,0:07:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejauh ini belum ada apa-apa,\Njadi aku ragu.
Dialogue: 0,0:07:32.44,0:07:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin untuk menahan binatang iblis?
Dialogue: 0,0:07:35.53,0:07:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini terhubung\Nke sarang cacing pasir.
Dialogue: 0,0:07:40.14,0:07:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semacam pembatas\Nagar binatang iblis tertahan.
Dialogue: 0,0:07:42.69,0:07:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:07:43.85,0:07:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau benar begitu, ini sangat berbahaya.
Dialogue: 0,0:08:03.80,0:08:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tubuhku terasa berat?
Dialogue: 0,0:08:10.29,0:08:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini bukan waktunya mengeluh.
Dialogue: 0,0:08:13.80,0:08:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang agak sulit berjalan,
Dialogue: 0,0:08:16.24,0:08:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bukan masalah besar.
Dialogue: 0,0:08:18.25,0:08:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus,
Dialogue: 0,0:08:19.60,0:08:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tujuan kita sudah dekat...\N- Ck! Barusu.
Dialogue: 0,0:08:22.10,0:08:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:08:23.27,0:08:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ah, ya.
Dialogue: 0,0:08:25.17,0:08:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:26.59,0:08:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...rasanya canggung kalau kita diam saja.
Dialogue: 0,0:08:30.02,0:08:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berjalan untuk bersenang-senang?
Dialogue: 0,0:08:32.28,0:08:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah tujuan kita.
Dialogue: 0,0:08:33.86,0:08:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu...
Dialogue: 0,0:08:34.90,0:08:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, sudahlah.
Dialogue: 0,0:08:37.67,0:08:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya sedang begini.
Dialogue: 0,0:08:39.38,0:08:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika hati sedang gelisah,
Dialogue: 0,0:08:41.60,0:08:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bicara apa pun\Ntakkan menghasilkan hal baik.
Dialogue: 0,0:08:45.23,0:08:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham?
Dialogue: 0,0:08:57.05,0:08:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sialan!
Dialogue: 0,0:08:58.91,0:09:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang sejauh ini untuk apa?
Dialogue: 0,0:09:01.13,0:09:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di pintu ketiga kita dibiarkan lewat.
Dialogue: 0,0:09:03.71,0:09:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa sekarang tak bisa lewat?
Dialogue: 0,0:09:06.30,0:09:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Sial! Sial!
Dialogue: 0,0:09:10.94,0:09:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, sudah cukup.
Dialogue: 0,0:09:13.95,0:09:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah jalan buntu.
Dialogue: 0,0:09:16.35,0:09:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa diberi tahu pun aku sudah tahu!
Dialogue: 0,0:09:25.95,0:09:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ck!
Dialogue: 0,0:09:26.82,0:09:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa maumu dari tadi?
Dialogue: 0,0:09:30.86,0:09:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada.
Dialogue: 0,0:09:31.81,0:09:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada, apanya?!
Dialogue: 0,0:09:33.64,0:09:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutanya, maumu itu apa?
Dialogue: 0,0:09:36.19,0:09:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang lain sedang kesusahan,
Dialogue: 0,0:09:37.85,0:09:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau terus-terusan mendecak!
Dialogue: 0,0:09:40.83,0:09:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maumu, hah?
Dialogue: 0,0:09:42.77,0:09:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, kalian berdua tenanglah.
Dialogue: 0,0:09:45.51,0:09:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berdebat serius begitu...
Dialogue: 0,0:09:46.96,0:09:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:09:48.47,0:09:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang bicara dengan Ram!
Dialogue: 0,0:09:52.33,0:09:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan jika ada yang ingin kau sampaikan!
Dialogue: 0,0:09:55.95,0:09:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengarkan!
Dialogue: 0,0:09:57.89,0:10:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat bersemangat untuk maju, Barusu?
Dialogue: 0,0:10:01.58,0:10:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:10:03.40,0:10:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa aku datang sejauh ini?
Dialogue: 0,0:10:06.12,0:10:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Untuk menemui sang Bijak...\N- Bukan.
Dialogue: 0,0:10:07.98,0:10:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ke sini bukan menemui sang Bijak.
Dialogue: 0,0:10:11.35,0:10:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ke sini...
Dialogue: 0,0:10:12.77,0:10:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...untuk membangunkan Rem.
Dialogue: 0,0:10:16.87,0:10:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini demi Rem,
Dialogue: 0,0:10:18.19,0:10:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar aku ingat adikku.
Dialogue: 0,0:10:20.40,0:10:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang,
Dialogue: 0,0:10:21.58,0:10:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang kau lakukan?
Dialogue: 0,0:10:23.55,0:10:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rem menghilang,\Nkau malah bersantai di sini.
Dialogue: 0,0:10:26.99,0:10:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan main-main.
Dialogue: 0,0:10:28.49,0:10:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak main-main!
Dialogue: 0,0:10:30.72,0:10:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya situasi kita sudah begini!
Dialogue: 0,0:10:34.00,0:10:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kita jatuh ke tempat ini,
Dialogue: 0,0:10:35.81,0:10:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kau malah menangkapku, bukan Rem?
Dialogue: 0,0:10:40.04,0:10:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya memikirkan yang ada di depanmu.
Dialogue: 0,0:10:43.18,0:10:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu begitu, Barusu.
Dialogue: 0,0:10:45.37,0:10:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otakmu hanya berisi Nona Emilia\Ndan Beatrice.
Dialogue: 0,0:10:48.60,0:10:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria macam apa kau?
Dialogue: 0,0:10:50.44,0:10:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan Rem.
Dialogue: 0,0:10:51.97,0:10:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:10:52.93,0:10:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Rem memercayaimu, Barusu?
Dialogue: 0,0:10:55.75,0:10:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:10:57.02,0:10:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tak akan diam.
Dialogue: 0,0:10:58.54,0:11:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kau tak memedulikan Rem, 'kan?
Dialogue: 0,0:11:02.00,0:11:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:11:07.22,0:11:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Tak Terlihat.
Dialogue: 0,0:11:22.55,0:11:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan main-main kau!
Dialogue: 0,0:11:24.54,0:11:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahmu!
Dialogue: 0,0:11:26.47,0:11:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salahmu! Ini semua salahmu!
Dialogue: 0,0:11:30.51,0:11:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah kau, wanita sialan!
Dialogue: 0,0:11:32.81,0:11:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu...
Dialogue: 0,0:11:33.75,0:11:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...yang mirip Rem itu\Nbenar-benar membuatku muak!
Dialogue: 0,0:11:39.67,0:11:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Aku tidak dengar!
Dialogue: 0,0:11:42.51,0:11:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan dengan jelas jika ingin bicara!
Dialogue: 0,0:11:55.92,0:11:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir?
Dialogue: 0,0:11:57.30,0:11:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keparat.
Dialogue: 0,0:11:58.57,0:12:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlambat jika kau mau menangis!
Dialogue: 0,0:12:01.31,0:12:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku yang bilang begitu.
Dialogue: 0,0:12:04.48,0:12:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak pantas bertemu dengan Rem.
Dialogue: 0,0:12:07.12,0:12:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucincang kau, membusuklah di sini!
Dialogue: 0,0:12:09.93,0:12:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah!
Dialogue: 0,0:12:12.08,0:12:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, cukup sampai di sini.
Dialogue: 0,0:12:19.46,0:12:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tak bisa dihentikan, ya.
Dialogue: 0,0:12:21.30,0:12:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah bukti siapa yang lebih berguna.
Dialogue: 0,0:12:24.33,0:12:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:12:27.33,0:12:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau... kenapa?
Dialogue: 0,0:12:29.52,0:12:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kau serius bertanya begitu, Natsuki?
Dialogue: 0,0:12:33.25,0:12:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membantumu agar tidak timbul masalah.
Dialogue: 0,0:12:38.22,0:12:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kau marah karena mangsamu direbut...
Dialogue: 0,0:12:42.07,0:12:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...dan sekarang kau mengincarku?
Dialogue: 0,0:12:44.52,0:12:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:45.84,0:12:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini aku akan mengikuti permainanmu.
Dialogue: 0,0:12:49.00,0:12:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, begitu saja cukup.
Dialogue: 0,0:12:53.48,0:12:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak pintar.
Dialogue: 0,0:12:55.16,0:12:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi lega.
Dialogue: 0,0:12:57.71,0:12:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:12:59.24,0:13:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berjabat tangan sebagai tanda damai.
Dialogue: 0,0:13:04.97,0:13:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki?
Dialogue: 0,0:13:06.98,0:13:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:09.08,0:13:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:13:11.21,0:13:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:13:16.41,0:13:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:13:34.15,0:13:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Le-Lepaskan! Lepaskan!
Dialogue: 0,0:13:36.20,0:13:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:13:38.12,0:13:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... tidak mau mati!
Dialogue: 0,0:13:40.39,0:13:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah mati!
Dialogue: 0,0:13:42.80,0:13:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mungkin bisa diselamatkan!
Dialogue: 0,0:13:44.43,0:13:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:13:45.09,0:13:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar keparat!
Dialogue: 0,0:13:46.88,0:13:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah mati!
Dialogue: 0,0:14:10.60,0:14:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan... tinggalkan aku...
Dialogue: 0,0:14:23.17,0:14:25.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram... Ini pasti sihir milik Ram.
Dialogue: 0,0:14:26.07,0:14:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita sialan itu masih hidup.
Dialogue: 0,0:14:36.94,0:14:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patrasche?
Dialogue: 0,0:14:38.87,0:14:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selamat?
Dialogue: 0,0:14:41.54,0:14:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Ram sudah mati?
Dialogue: 0,0:14:44.64,0:14:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sudahlah.
Dialogue: 0,0:14:46.19,0:14:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku naik.
Dialogue: 0,0:14:48.43,0:14:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dengar atau tidak? Hei!
Dialogue: 0,0:14:50.97,0:14:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarilah!
Dialogue: 0,0:14:52.00,0:14:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bajingan!
Dialogue: 0,0:14:53.30,0:14:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku ini siapa?
Dialogue: 0,0:15:00.78,0:15:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya dia mau patuh juga.
Dialogue: 0,0:15:31.80,0:15:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu, Barusu.
Dialogue: 0,0:15:34.25,0:15:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak bangun juga,\Nkubakar kelopak matamu.
Dialogue: 0,0:15:41.30,0:15:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:15:43.99,0:15:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu?
Dialogue: 0,0:15:47.71,0:15:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyedihkan.
Dialogue: 0,0:15:49.88,0:15:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menggigit, ya.
Dialogue: 0,0:15:57.84,0:15:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sudah tidak apa-apa.
Dialogue: 0,0:16:00.21,0:16:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu?
Dialogue: 0,0:16:01.50,0:16:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kau sudah sadar.
Dialogue: 0,0:16:04.09,0:16:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini...
Dialogue: 0,0:16:05.61,0:16:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:16:07.21,0:16:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga sudah bangun rupanya, Natsuki.
Dialogue: 0,0:16:10.28,0:16:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga.
Dialogue: 0,0:16:11.77,0:16:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana keadaan sekitar?
Dialogue: 0,0:16:13.40,0:16:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang bagus.
Dialogue: 0,0:16:14.61,0:16:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada jalan keluar\Natau yang lain di sini.
Dialogue: 0,0:16:18.03,0:16:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki?
Dialogue: 0,0:16:20.39,0:16:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:16:22.72,0:16:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sebenarnya miasma itu apa?
Dialogue: 0,0:16:27.18,0:16:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini di bawah gurun pasir, 'kan?
Dialogue: 0,0:16:29.92,0:16:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada miasma yang menyebar di sini?
Dialogue: 0,0:16:32.72,0:16:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada dasarnya,
Dialogue: 0,0:16:34.16,0:16:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}miasma adalah mana tercemar.
Dialogue: 0,0:16:36.28,0:16:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang tercemar?
Dialogue: 0,0:16:37.83,0:16:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dibiarkan,
Dialogue: 0,0:16:39.13,0:16:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu bisa menggerogoti tubuh dan jiwa.
Dialogue: 0,0:16:42.49,0:16:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada cara mencegahnya?
Dialogue: 0,0:16:43.74,0:16:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerbang kita menyerap mana secara alami...
Dialogue: 0,0:16:48.82,0:16:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebisa mungkin,
Dialogue: 0,0:16:50.16,0:16:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauhi tempat dengan miasma yang pekat.
Dialogue: 0,0:16:56.42,0:16:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu efek miasma.
Dialogue: 0,0:16:58.41,0:17:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, jika kita terus maju, nanti...
Dialogue: 0,0:17:01.10,0:17:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:17:06.07,0:17:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu.
Dialogue: 0,0:17:07.21,0:17:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:17:19.43,0:17:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke kiri. Kita lewat kiri.
Dialogue: 0,0:17:26.10,0:17:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anastasia.
Dialogue: 0,0:17:27.60,0:17:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langit-langitnya rendah, berhati-hatilah.
Dialogue: 0,0:17:29.94,0:17:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku mengerti, terima kasih.
Dialogue: 0,0:17:32.57,0:17:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram, awas pijakannya kurang stabil.
Dialogue: 0,0:17:35.53,0:17:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:17:36.82,0:17:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku mengerti.
Dialogue: 0,0:17:38.57,0:17:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang saja jika kau kedinginan, ya.
Dialogue: 0,0:17:40.78,0:17:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa meminjamkan mantelku.
Dialogue: 0,0:17:44.44,0:17:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa? Ada apa?
Dialogue: 0,0:17:46.96,0:17:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru kau.
Dialogue: 0,0:17:48.14,0:17:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan perhatian menjijikkan itu?
Dialogue: 0,0:17:50.70,0:17:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rencanakan?
Dialogue: 0,0:17:52.22,0:17:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak merencanakan apa pun!
Dialogue: 0,0:17:54.36,0:17:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya...
Dialogue: 0,0:17:55.43,0:17:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...ingin kalian baik-baik saja.
Dialogue: 0,0:17:58.50,0:17:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum.
Dialogue: 0,0:17:59.11,0:18:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang mesum?!
Dialogue: 0,0:18:01.04,0:18:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkahku tak ada bedanya\Ndengan Julius, 'kan?
Dialogue: 0,0:18:03.78,0:18:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Julius, itu terasa alami.
Dialogue: 0,0:18:06.79,0:18:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kau, sangat tidak wajar...
Dialogue: 0,0:18:08.95,0:18:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencurigakan.
Dialogue: 0,0:18:09.94,0:18:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak wajar?
Dialogue: 0,0:18:14.16,0:18:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kenapa ada bau aneh?
Dialogue: 0,0:18:17.37,0:18:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya seperti ada yang terbakar.
Dialogue: 0,0:18:19.78,0:18:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau?
Dialogue: 0,0:18:21.42,0:18:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperiksa dulu.
Dialogue: 0,0:18:24.60,0:18:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kujadikan umpan jika terjadi apa-apa!
Dialogue: 0,0:18:27.23,0:18:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dendam!
Dialogue: 0,0:18:28.58,0:18:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukutuk kau jika itu terjadi!
Dialogue: 0,0:18:53.53,0:18:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Loh! Loh! Loh! Loh! Loh!
Dialogue: 0,0:19:54.30,0:19:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, bodoh!
Dialogue: 0,0:20:15.39,0:20:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Fula!
Dialogue: 0,0:20:19.86,0:20:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdirilah.
Dialogue: 0,0:20:20.89,0:20:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rem bisa menangis.
Dialogue: 0,0:20:23.31,0:20:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mati, Barusu!
Dialogue: 0,0:20:31.86,0:20:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Tak Terlihat!
Dialogue: 0,0:20:35.29,0:20:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Fula!
Dialogue: 0,0:20:44.85,0:20:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu!
Dialogue: 0,0:21:07.41,0:21:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:10.62,0:21:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rem bisa menangis.
Dialogue: 0,0:21:18.83,0:21:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergeraklah, bodoh!
Dialogue: 0,0:21:20.85,0:21:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya tidur!
Dialogue: 0,0:21:26.61,0:21:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdiri! Berdiri!
Dialogue: 0,0:21:28.58,0:21:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki Subaru!
Dialogue: 0,0:21:47.63,0:21:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram!
Dialogue: 0,0:22:08.01,0:22:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:22:13.73,0:22:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ujung yang jauh ♪
Dialogue: 0,0:22:15.90,0:22:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tersesat di gurun tanpa jalan\Nyang menuntun ke depan ♪
Dialogue: 0,0:22:21.44,0:22:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Badai perasaan berkecamuk dalam hatiku ♪
Dialogue: 0,0:22:25.08,0:22:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Namun, sebutir harapan\Nmasih ada di sini ♪
Dialogue: 0,0:22:29.01,0:22:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kegelapan yang tampak abadi ♪
Dialogue: 0,0:22:32.69,0:22:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kehampaan yang menyakitkan\Nkarena kesepian ♪
Dialogue: 0,0:22:36.40,0:22:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Suaramu yang merdu berayun padaku ♪
Dialogue: 0,0:22:39.86,0:22:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menjagaku tetap hidup di tengah malam ♪
Dialogue: 0,0:22:43.80,0:22:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Pemandangan tanpa ujung,\Nkenangan yang kurindukan ♪
Dialogue: 0,0:22:47.51,0:22:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hanya ada satu yang aku nantikan ♪
Dialogue: 0,0:22:52.14,0:22:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Biarkan aku sentuh tanganmu sekarang ♪
Dialogue: 0,0:22:57.12,0:23:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Melampaui waktu yang tak terbatas ♪
Dialogue: 0,0:23:00.41,0:23:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Perasaan gelap ini\Nadalah gairah yang menghubungkanmu ♪
Dialogue: 0,0:23:04.15,0:23:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Karena itu, cintailah semuanya ♪
Dialogue: 0,0:23:07.04,0:23:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ (Kehidupan)\NKarena itu, cintailah semuanya ♪
Dialogue: 0,0:23:08.28,0:23:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ yang terbatas ini ♪
Dialogue: 0,0:23:10.93,0:23:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ada agar kita bertemu kembali ♪
Dialogue: 0,0:23:15.32,0:23:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Inilah cinta sejati ♪
Dialogue: 0,0:23:17.13,0:23:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kamu adalah obsesiku ♪
Dialogue: 0,0:23:18.92,0:23:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Perasaan yang tak terbalas ini ♪
Dialogue: 0,0:23:20.67,0:23:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kupersembahkan hanya untukmu ♪
