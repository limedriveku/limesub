Dialogue: 0,0:00:02.49,0:00:04.45,sign,,0000,0000,0000,,NATSUKI SUBARU TELAH TIBA
Dialogue: 0,0:22:04.01,0:22:04.26,sign,,0000,0000,0000,,NATSUKI SUBARU TELAH TIBA
Dialogue: 0,0:22:12.12,0:22:13.31,sign,,0000,0000,0000,,MEMBUNUH ITU BISA MENJADI KEBIASAAN
Dialogue: 0,0:00:04.99,0:00:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:00:07.43,0:00:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:00:09.97,0:00:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kau ini apa-apaan?!
Dialogue: 0,0:00:14.91,0:00:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak pernah!
Dialogue: 0,0:00:16.25,0:00:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah punya luka ini!
Dialogue: 0,0:00:18.43,0:00:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak pernah!
Dialogue: 0,0:00:23.21,0:00:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:00:25.09,0:00:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku tak sadar,\NNatsuki Subaru yang asli telah kembali?
Dialogue: 0,0:00:32.31,0:00:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki Subaru membunuh Meili,
Dialogue: 0,0:00:35.35,0:00:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan meninggalkan bukti di lenganku?
Dialogue: 0,0:00:39.06,0:00:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang janggal!\NAku tak mengerti lagi!
Dialogue: 0,0:00:42.17,0:00:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau Natsuki Subaru...
Dialogue: 0,0:00:44.74,0:00:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku
Dialogue: 0,0:00:46.41,0:00:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kau
Dialogue: 0,0:00:48.42,0:00:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya siapa?
Dialogue: 0,0:00:51.05,0:00:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ReZERO -Starting Life in Another World-\NSeason 4
Dialogue: 0,0:00:56.74,0:01:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila kita bertemu lagi,\Naku takkan mencurigaimu,
Dialogue: 0,0:01:01.12,0:01:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meili.
Dialogue: 0,0:01:03.08,0:01:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, detektif yang ternyata pelakunya
Dialogue: 0,0:01:05.92,0:01:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kisah yang terlalu klasik.
Dialogue: 0,0:01:09.80,0:01:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, aku harus mengulur waktu.
Dialogue: 0,0:01:16.76,0:01:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Subaru, ternyata kamu ada di sini.
Dialogue: 0,0:01:20.39,0:01:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa aku mengagetkanmu?
Dialogue: 0,0:01:22.31,0:01:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku kaget.
Dialogue: 0,0:01:24.23,0:01:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hanya karena kau muncul mendadak,\Njadi tak apa-apa.
Dialogue: 0,0:01:26.98,0:01:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Emilia?
Dialogue: 0,0:01:28.98,0:01:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang keliling menara,\Nbarangkali menemukan sesuatu.
Dialogue: 0,0:01:34.53,0:01:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Subaru.
Dialogue: 0,0:01:36.58,0:01:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tadi kamu sedang iseng atau semacamnya?
Dialogue: 0,0:01:39.75,0:01:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, kamu benar-benar tak apa-apa?
Dialogue: 0,0:01:42.12,0:01:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kondisimu belum sepenuhnya pulih?
Dialogue: 0,0:01:44.54,0:01:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tak apa-apa, kok.
Dialogue: 0,0:01:46.75,0:01:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya melamun sebentar.
Dialogue: 0,0:01:48.88,0:01:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau sangat perhatian padaku, ya.
Dialogue: 0,0:01:51.63,0:01:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini,
Dialogue: 0,0:01:53.43,0:01:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}entah kenapa\Naku jadi sering memperhatikanmu.
Dialogue: 0,0:01:57.43,0:01:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, ya.
Dialogue: 0,0:01:59.60,0:02:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh iya, soal Meili...
Dialogue: 0,0:02:02.35,0:02:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin terlalu cepat dibicarakan,
Dialogue: 0,0:02:04.56,0:02:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jika kita selamat dari sini,\Naku ingin sungguh-sungguh mengurus Meili.
Dialogue: 0,0:02:09.94,0:02:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengurus?
Dialogue: 0,0:02:11.57,0:02:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, perbuatannya setahun yang lalu\Nmemanglah salah.
Dialogue: 0,0:02:15.99,0:02:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga paham\Nkita tak bisa langsung percaya.
Dialogue: 0,0:02:18.95,0:02:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita bisa melewati gurun itu\Nberkat Meili, 'kan?
Dialogue: 0,0:02:22.83,0:02:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya dia dimaafkan?
Dialogue: 0,0:02:25.08,0:02:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:26.29,0:02:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, aku ingin membebaskannya\Ndari penjara bawah tanah,
Dialogue: 0,0:02:29.92,0:02:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membiarkannya hidup bersama yang lain.
Dialogue: 0,0:02:32.88,0:02:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong.
Dialogue: 0,0:02:34.05,0:02:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:35.26,0:02:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilang omong kosong.
Dialogue: 0,0:02:37.14,0:02:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu cepat untuk dibahas?\NItu benar sekali!
Dialogue: 0,0:02:39.68,0:02:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kita bisa bahas masa depan\Ndi situasi seperti ini?
Dialogue: 0,0:02:43.10,0:02:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, kenapa tiba-tiba kamu begitu?
Dialogue: 0,0:02:45.52,0:02:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski suasana hatimu buruk,\Nkamu tak boleh bicara begitu.
Dialogue: 0,0:02:48.94,0:02:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada beban pikiran,\Nceritakanlah baik-baik.
Dialogue: 0,0:02:52.28,0:02:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu kesulitan,\Naku akan ikut menanggungnya.
Dialogue: 0,0:02:56.41,0:02:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan pendam sendiri,\Njangan merasa kesal sendiri,
Dialogue: 0,0:02:59.62,0:03:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan jangan akhiri semuanya sendirian.
Dialogue: 0,0:03:04.37,0:03:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mengerti?
Dialogue: 0,0:03:05.87,0:03:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku
Dialogue: 0,0:03:07.96,0:03:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama sekali tak marah.
Dialogue: 0,0:03:10.25,0:03:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak kecewa.
Dialogue: 0,0:03:12.46,0:03:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, ceritalah.
Dialogue: 0,0:03:15.51,0:03:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:03:19.26,0:03:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia, aku...
Dialogue: 0,0:03:21.64,0:03:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:22.93,0:03:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:03:23.64,0:03:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Emilia, Barusu.
Dialogue: 0,0:03:26.14,0:03:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Ram?
Dialogue: 0,0:03:27.85,0:03:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat ke ruang arsip di lantai tiga.
Dialogue: 0,0:03:30.48,0:03:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah datang?
Dialogue: 0,0:03:31.94,0:03:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kamu temukan sesuatu yang penting?
Dialogue: 0,0:03:34.03,0:03:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pastinya tidak bisa\Ndisebut sebagai kabar baik.
Dialogue: 0,0:03:37.57,0:03:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepat disebut pertanda buruk.
Dialogue: 0,0:03:40.16,0:03:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak usah bertele-tele, ada apa?
Dialogue: 0,0:03:43.99,0:03:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku di rak kedua dari atas,\Npaling ujung kanan.
Dialogue: 0,0:03:48.71,0:03:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mungkin.
Dialogue: 0,0:03:52.25,0:03:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meili Portroute.
Dialogue: 0,0:03:55.59,0:03:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beatrice, kamu sudah baca buku itu?
Dialogue: 0,0:03:57.76,0:03:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum dipastikan.
Dialogue: 0,0:03:59.68,0:04:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:04:00.97,0:04:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku Orang Mati harus ditangani hati-hati.
Dialogue: 0,0:04:04.68,0:04:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih, jika itu benar-benar\Nbuku Meili yang kita kenal...
Dialogue: 0,0:04:09.85,0:04:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti Meili di menara ini sudah...
Dialogue: 0,0:04:11.98,0:04:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, kita harus mencarinya.
Dialogue: 0,0:04:13.19,0:04:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:04:15.23,0:04:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika buku itu memang miliknya,
Dialogue: 0,0:04:18.07,0:04:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencarinya pun sudah terlambat.
Dialogue: 0,0:04:20.27,0:04:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipanggil, tapi kenapa ribut-ribut?\NAda apa ini?
Dialogue: 0,0:04:24.87,0:04:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shaula, kamu datang rupanya.
Dialogue: 0,0:04:26.70,0:04:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau melihat Meili\Nsetelah kita makan tadi?
Dialogue: 0,0:04:30.58,0:04:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak lihat.
Dialogue: 0,0:04:31.79,0:04:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang bocah nomor dua itu kenapa?
Dialogue: 0,0:04:33.88,0:04:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kami menemukan\Nbuku bernama Meili.
Dialogue: 0,0:04:38.01,0:04:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi begitu.
Dialogue: 0,0:04:39.97,0:04:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si nomor dua sudah mati, ya.
Dialogue: 0,0:04:41.84,0:04:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, apa boleh buat.
Dialogue: 0,0:04:43.39,0:04:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shaula, ucapanmu itu keterlaluan sekali.
Dialogue: 0,0:04:46.02,0:04:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Master, jangan marah, dong.
Dialogue: 0,0:04:48.85,0:04:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah lebih cepat jika langsung\Nmembaca buku si nomor dua?
Dialogue: 0,0:04:53.02,0:04:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih cepat, katamu?
Dialogue: 0,0:04:54.82,0:04:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Master membacanya,\Npasti akan tahu kenapa dia mati.
Dialogue: 0,0:05:00.74,0:05:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dikatakan Shaula memang ada benarnya.
Dialogue: 0,0:05:03.82,0:05:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru.
Dialogue: 0,0:05:05.08,0:05:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Buku Orang Mati itu asli,
Dialogue: 0,0:05:07.33,0:05:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan melihat seluruh kehidupannya.
Dialogue: 0,0:05:10.54,0:05:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berterima kasih,\Nkalian berdua telah mengkhawatirkanku.
Dialogue: 0,0:05:14.00,0:05:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, seseorang harus melakukannya.
Dialogue: 0,0:05:16.25,0:05:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, jangan Subaru, biar aku.
Dialogue: 0,0:05:18.46,0:05:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu, Beti menentangnya.
Dialogue: 0,0:05:21.34,0:05:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika memang harus ada yang membacanya,
Dialogue: 0,0:05:23.64,0:05:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru atau Julius adalah orang yang tepat.
Dialogue: 0,0:05:27.64,0:05:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja.
Dialogue: 0,0:05:29.02,0:05:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, siapa tahu ini hanya\Nsalah paham semata,
Dialogue: 0,0:05:31.89,0:05:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan nyatanya tak terjadi apa pun\Nmeski kita sudah panik.
Dialogue: 0,0:05:34.86,0:05:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika terjadi sesuatu,\Nakan kujauhkan kamu dari buku itu.
Dialogue: 0,0:05:37.94,0:05:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutarik rambutmu.
Dialogue: 0,0:05:39.74,0:05:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong yang santai saja.
Dialogue: 0,0:05:41.36,0:05:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka jika kau\Nhanya mengguncang bahuku.
Dialogue: 0,0:05:55.71,0:05:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai.
Dialogue: 0,0:06:10.27,0:06:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika menyadari awal kehidupannya,
Dialogue: 0,0:06:13.06,0:06:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perempuan itu tak memiliki apa pun.
Dialogue: 0,0:06:16.23,0:06:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada siapa pun di sekitarnya.
Dialogue: 0,0:06:18.86,0:06:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelap, gelap.
Dialogue: 0,0:06:20.61,0:06:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hitam, hitam, sendirian di hutan.
Dialogue: 0,0:06:23.53,0:06:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perempuan itu hanya sendirian.
Dialogue: 0,0:06:26.57,0:06:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tak mengenal bahasa,\Ndia tak tahu caranya meratap.
Dialogue: 0,0:06:30.70,0:06:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tak tahu cara berjalan,\Ndia tak tahu caranya melawan.
Dialogue: 0,0:06:52.64,0:06:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang tak mendapatkan apa pun,
Dialogue: 0,0:06:55.27,0:06:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya mati terkoyak\Noleh taring binatang buas.
Dialogue: 0,0:07:07.45,0:07:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mempelajari cara untuk hidup,\Ndia tak pernah berpikir untuk mati.
Dialogue: 0,0:07:14.29,0:07:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mempelajari hukum rimba\Ndengan bertaruh nyawa.
Dialogue: 0,0:07:26.68,0:07:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu akhirnya, perempuan itu
Dialogue: 0,0:07:33.52,0:07:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi ratu para binatang buas.
Dialogue: 0,0:07:54.33,0:07:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diperintahkan untuk membawamu.
Dialogue: 0,0:07:56.91,0:07:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kau harus ikut bersamaku.
Dialogue: 0,0:08:18.73,0:08:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara meratap, melawan,
Dialogue: 0,0:08:22.02,0:08:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan cara hidup pun tak tahu?
Dialogue: 0,0:08:26.49,0:08:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau punya berbagai alasan basi pun,
Dialogue: 0,0:08:30.74,0:08:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak peduli.
Dialogue: 0,0:08:36.65,0:08:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merataplah demi diriku.
Dialogue: 0,0:08:40.12,0:08:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melawanlah demi diriku.
Dialogue: 0,0:08:43.88,0:08:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiduplah demi mencintai diriku.
Dialogue: 0,0:08:48.30,0:08:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila semuanya hilang, terlupa,\Natau lenyap sama sekali,
Dialogue: 0,0:08:52.80,0:08:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka biar aku yang mengajarimu.
Dialogue: 0,0:08:58.14,0:08:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah
Dialogue: 0,0:08:59.39,0:09:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dinamakan tugas seorang "ibu".
Dialogue: 0,0:09:10.70,0:09:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhentilah menuruti perkataan orang itu.
Dialogue: 0,0:09:14.03,0:09:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain aku, punya banyak nyawa pun\Ntak akan pernah cukup.
Dialogue: 0,0:09:19.91,0:09:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benci.
Dialogue: 0,0:09:21.08,0:09:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:09:22.21,0:09:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:27.92,0:09:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benci.
Dialogue: 0,0:09:38.68,0:09:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini benci?
Dialogue: 0,0:09:40.39,0:09:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa benci itu sebenarnya apa?
Dialogue: 0,0:09:45.86,0:09:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyedihkan.
Dialogue: 0,0:09:51.99,0:09:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyedihkan.
Dialogue: 0,0:10:02.96,0:10:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini menyedihkan?
Dialogue: 0,0:10:06.34,0:10:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesedihan itu sebenarnya apa?
Dialogue: 0,0:10:10.71,0:10:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang selalu hidup mengikuti arus\Ndan meniru hal lain,
Dialogue: 0,0:10:15.34,0:10:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak tahu perasaannya yang sesungguhnya.
Dialogue: 0,0:10:18.14,0:10:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini setelah Elsa tiada,
Dialogue: 0,0:10:20.02,0:10:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siapa yang harus dia tiru,\Ndan apa yang harus dijadikan pedoman hidup?
Dialogue: 0,0:10:25.65,0:10:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika "ibu" menyuruhnya mati\Ndengan dalih mendidik,
Dialogue: 0,0:10:28.19,0:10:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pasti akan menuruti\Nperintah itu begitu saja.
Dialogue: 0,0:10:34.99,0:10:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau.
Dialogue: 0,0:10:42.70,0:10:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, aku ingin tahu jawabannya.
Dialogue: 0,0:10:56.34,0:10:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata kau juga di sini?
Dialogue: 0,0:10:59.68,0:11:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sedang mencari buku.
Dialogue: 0,0:11:04.18,0:11:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tidur terlalu larut, Meili!
Dialogue: 0,0:11:07.85,0:11:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kulakukan telah dilihat,\Ndiketahui, dan disadarinya.
Dialogue: 0,0:11:12.94,0:11:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin dia melihatnya.
Dialogue: 0,0:11:14.74,0:11:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin dia mengetahuinya.
Dialogue: 0,0:11:30.88,0:11:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dangkal sekali kau ini.
Dialogue: 0,0:11:34.67,0:11:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cari muka, menjijikkan.
Dialogue: 0,0:11:37.59,0:11:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang mengharapkan\Nhal seperti itu darimu.
Dialogue: 0,0:11:41.72,0:11:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok tenang begitu, boneka.
Dialogue: 0,0:11:44.68,0:11:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau tidak dengar keinginan sesungguhnya\Ndi dalam relung hatimu?
Dialogue: 0,0:11:49.15,0:11:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginan sesungguhnya?
Dialogue: 0,0:11:51.31,0:11:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkanlah keinginanmu.
Dialogue: 0,0:11:53.65,0:11:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, kau akan mulai\Nmemahami siapa dirimu.
Dialogue: 0,0:11:57.49,0:12:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan tahu apa yang ingin kau lakukan.
Dialogue: 0,0:12:00.07,0:12:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ingin aku lakukan...
Dialogue: 0,0:12:03.33,0:12:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginanku itu...
Dialogue: 0,0:12:05.62,0:12:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka ekspresimu.
Dialogue: 0,0:12:08.04,0:12:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuh cita rasa.
Dialogue: 0,0:12:10.71,0:12:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sudah tahu apa keinginanmu,\Nbertindaklah seperti dirimu sendiri.
Dialogue: 0,0:12:15.42,0:12:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegelisahanmu yang membosankan
Dialogue: 0,0:12:17.72,0:12:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan penderitaanmu yang tak berarti itu,\Nakan kuingat semuanya.
Dialogue: 0,0:12:31.52,0:12:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal semalam,
Dialogue: 0,0:12:33.98,0:12:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seberapa serius aku harus\Nmenanggapi ucapanmu?
Dialogue: 0,0:12:39.53,0:12:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan di sini, mari pindah tempat.
Dialogue: 0,0:12:49.08,0:12:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Meili.
Dialogue: 0,0:12:57.55,0:13:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertanya langsung itu melanggar aturan.
Dialogue: 0,0:13:01.13,0:13:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, apa yang bisa kulakukan?
Dialogue: 0,0:13:03.97,0:13:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi, ini akan menjadi cerita yang menarik.\N- Sejak sendirian di hutan itu,
Dialogue: 0,0:13:07.56,0:13:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kasus pembunuhan Natsuki Subaru!\N- tanpa bertindak apa pun, tanpa memiliki arti,
Dialogue: 0,0:13:11.14,0:13:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dibunuh.
Dialogue: 0,0:13:12.77,0:13:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibunuh.
Dialogue: 0,0:13:14.77,0:13:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibunuh.
Dialogue: 0,0:13:16.32,0:13:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibunuh.
Dialogue: 0,0:13:17.98,0:13:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibunuh.
Dialogue: 0,0:13:19.74,0:13:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dibunuh.
Dialogue: 0,0:13:27.24,0:13:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:13:29.00,0:13:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Eh?
Dialogue: 0,0:13:31.12,0:13:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:13:31.58,0:13:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik napas!\NTarik napas dalam-dalam!
Dialogue: 0,0:13:34.25,0:13:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan bicara.
Dialogue: 0,0:13:35.96,0:13:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia!
Dialogue: 0,0:13:36.88,0:13:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh bukunya.
Dialogue: 0,0:13:38.80,0:13:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatannya mulai bercampur.
Dialogue: 0,0:13:40.26,0:13:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercampur? Apa efek buku ini padanya?
Dialogue: 0,0:13:42.43,0:13:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, aku, itu aku.
Dialogue: 0,0:13:45.26,0:13:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aku...
Dialogue: 0,0:13:47.39,0:13:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku...\N- Dia telah menyelam terlalu dalam, kurasa.
Dialogue: 0,0:13:49.35,0:13:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Elsa menghilang...\N- Subaru, ingatlah!
Dialogue: 0,0:13:51.43,0:13:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak apa-apa?
Dialogue: 0,0:13:52.60,0:13:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu adalah Natsuki Subaru, kesatriaku!
Dialogue: 0,0:13:57.57,0:13:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tanya sekali lagi, Natsuki.
Dialogue: 0,0:14:00.15,0:14:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lihat dari buku itu?
Dialogue: 0,0:14:03.57,0:14:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatan Meili.
Dialogue: 0,0:14:07.62,0:14:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dicekik dengan sangat menyakitkan
Dialogue: 0,0:14:10.29,0:14:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga meronta-ronta.
Dialogue: 0,0:14:13.37,0:14:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah, Subaru.\NTenanglah.
Dialogue: 0,0:14:16.04,0:14:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokuslah untuk menenangkan dirimu dulu.
Dialogue: 0,0:14:19.50,0:14:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:14:20.51,0:14:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa.
Dialogue: 0,0:14:21.72,0:14:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat seperti ini,\Ntak masalah bersandar pada Beti.
Dialogue: 0,0:14:25.84,0:14:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ram, bagaimana menurutmu?
Dialogue: 0,0:14:28.97,0:14:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ucapan Barusu benar, berarti Meili...
Dialogue: 0,0:14:32.18,0:14:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua tenang sekali, ya?
Dialogue: 0,0:14:34.69,0:14:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena mereka\Nsudah mewaspadaiku sejak awal.
Dialogue: 0,0:14:39.19,0:14:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, tenanglah.
Dialogue: 0,0:14:41.15,0:14:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu tidak cerdik atau setega itu\Nuntuk berbohong di situasi seperti ini.
Dialogue: 0,0:14:45.66,0:14:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk memastikan, aku juga bisa membacanya.
Dialogue: 0,0:14:47.82,0:14:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keberatan.
Dialogue: 0,0:14:49.99,0:14:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi melihat Natsuki seperti ini.
Dialogue: 0,0:14:52.12,0:14:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jelas, kita tak bisa berdiam diri.
Dialogue: 0,0:14:54.46,0:14:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita cari Meili.
Dialogue: 0,0:14:55.83,0:14:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari?
Dialogue: 0,0:14:56.79,0:14:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ketemu pun mungkin sudah terlambat.
Dialogue: 0,0:14:59.25,0:15:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita tak bisa membiarkannya\Nsendirian lagi, 'kan?
Dialogue: 0,0:15:02.63,0:15:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sebelum mati,\Nkalian tak peduli padaku.
Dialogue: 0,0:15:07.30,0:15:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mengubah rencana hari ini.
Dialogue: 0,0:15:11.01,0:15:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita berpencar mencarinya.
Dialogue: 0,0:15:12.97,0:15:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, bagaimana?
Dialogue: 0,0:15:15.44,0:15:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau melihat saat-saat terakhir Meili?
Dialogue: 0,0:15:19.81,0:15:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:15:25.36,0:15:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak melihatnya sampai akhir.
Dialogue: 0,0:15:28.03,0:15:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, yang jelas telah terjadi\Nsesuatu di dalam menara.
Dialogue: 0,0:15:33.04,0:15:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:15:55.39,0:15:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:15:57.06,0:15:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang akan kau lakukan?
Dialogue: 0,0:15:59.65,0:16:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:16:01.82,0:16:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master.
Dialogue: 0,0:16:03.19,0:16:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, apa?
Dialogue: 0,0:16:05.24,0:16:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku harus mencari si nomor dua?
Dialogue: 0,0:16:09.61,0:16:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau...
Dialogue: 0,0:16:12.74,0:16:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia seperti tahu\Nhubungan kita berdua?
Dialogue: 0,0:16:17.37,0:16:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shaula, carilah Meili.
Dialogue: 0,0:16:20.33,0:16:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:16:21.67,0:16:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu yang Master inginkan,\Napa pun akan kulakukan.
Dialogue: 0,0:16:27.92,0:16:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tahu, kok.
Dialogue: 0,0:16:33.81,0:16:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia?
Dialogue: 0,0:16:35.68,0:16:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada gunanya jika terus dipikirkan.
Dialogue: 0,0:16:38.69,0:16:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan sentuh buku itu lagi.
Dialogue: 0,0:16:42.73,0:16:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau sangat baik?
Dialogue: 0,0:16:45.73,0:16:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi pertanyaanmu mendadak sekali.
Dialogue: 0,0:16:48.28,0:16:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ah, bukan begitu.
Dialogue: 0,0:16:50.32,0:16:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa orang yang menyembunyikan kematianku,
Dialogue: 0,0:16:53.49,0:16:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa disukai seperti ini?
Dialogue: 0,0:16:56.12,0:16:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:57.62,0:16:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penasaran.
Dialogue: 0,0:16:59.12,0:17:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tahu.
Dialogue: 0,0:17:00.75,0:17:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Kenapa? Kenapa? Kenapa?
Dialogue: 0,0:17:03.50,0:17:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Haruskah kuberi tahu alasannya?
Dialogue: 0,0:17:10.08,0:17:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Emilia dan yang lain itu sekutu,\Natau musuh yang membunuhku?
Dialogue: 0,0:17:14.72,0:17:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dicintai atau tidak?
Dialogue: 0,0:17:16.68,0:17:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibenci atau tidak?
Dialogue: 0,0:17:18.73,0:17:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah cara untuk mengetahuinya
Dialogue: 0,0:17:21.19,0:17:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada di dalam Buku Orang Mati?
Dialogue: 0,0:17:25.48,0:17:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, kondisimu sepertinya memburuk.
Dialogue: 0,0:17:29.36,0:17:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kau istirahat di ruang hijau.
Dialogue: 0,0:17:37.08,0:17:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka sebaik itu\Npada orang sepertiku?
Dialogue: 0,0:17:46.96,0:17:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diserang sedikit saja dia bisa tumbang.
Dialogue: 0,0:17:50.26,0:17:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dibanting ke lantai,\Ndia bisa langsung mati.
Dialogue: 0,0:17:54.05,0:17:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, apakah Buku Orang Mati akan muncul?
Dialogue: 0,0:17:58.31,0:17:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membacanya,
Dialogue: 0,0:17:59.64,0:18:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku bisa tahu kenapa mereka\Nsangat baik kepadaku?
Dialogue: 0,0:18:05.23,0:18:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru.
Dialogue: 0,0:18:09.78,0:18:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:18:18.66,0:18:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melihatku... dia menyadariku...
Dialogue: 0,0:18:22.87,0:18:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menggaruk tanganmu lagi.
Dialogue: 0,0:18:26.25,0:18:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebiasaan yang buruk.
Dialogue: 0,0:18:34.34,0:18:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak asyik, ah.
Dialogue: 0,0:18:36.26,0:18:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:18:37.01,0:18:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apanya?
Dialogue: 0,0:18:38.22,0:18:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:18:39.97,0:18:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru!
Dialogue: 0,0:18:41.64,0:18:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf. Aku tak apa-apa.
Dialogue: 0,0:18:44.64,0:18:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Abang.
Dialogue: 0,0:18:46.27,0:18:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau tahu membunuh itu\Nbisa menjadi kebiasaan?
Dialogue: 0,0:18:50.19,0:18:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, itu ucapan\Nseorang detektif terkenal,
Dialogue: 0,0:18:54.32,0:18:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa jika seseorang menyelesaikan\Nmasalah dengan membunuh,
Dialogue: 0,0:18:57.78,0:18:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat masalah berikutnya muncul,
Dialogue: 0,0:18:59.70,0:19:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia akan menyelesaikannya\Ndengan membunuh juga.
Dialogue: 0,0:19:03.66,0:19:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu siapa detektif itu,
Dialogue: 0,0:19:06.83,0:19:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi benar, seperti itulah.
Dialogue: 0,0:19:10.84,0:19:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kebiasaan" itu tak bisa dihilangkan.
Dialogue: 0,0:19:16.05,0:19:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tak ketemu?
Dialogue: 0,0:19:19.14,0:19:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah memeriksa\Nsemua ruangan yang bisa dimasuki.
Dialogue: 0,0:19:22.64,0:19:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bertanya pada Reid,\Nkatanya tak lihat.
Dialogue: 0,0:19:26.60,0:19:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu, ya.
Dialogue: 0,0:19:28.65,0:19:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini nihil, tapi besok...
Dialogue: 0,0:19:31.86,0:19:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf saja, tapi jika ingin lanjut mencari\Nbesok dan seterusnya,
Dialogue: 0,0:19:36.20,0:19:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menentangnya.
Dialogue: 0,0:19:38.28,0:19:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Echidna.
Dialogue: 0,0:19:39.32,0:19:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa begitu.
Dialogue: 0,0:19:40.87,0:19:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bahkan tak tahu\Nbagaimana perasaan Meili.
Dialogue: 0,0:19:43.45,0:19:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah tak memiliki\Nfungsi emosional lagi.
Dialogue: 0,0:19:47.67,0:19:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa membuang-buang waktu\Nseperti ini lagi.
Dialogue: 0,0:19:51.04,0:19:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tampak sangat terburu-buru.
Dialogue: 0,0:19:54.05,0:19:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persediaan makanan juga ada batasnya.
Dialogue: 0,0:19:56.59,0:19:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tubuh Nona Anastasia\Ndikendalikan orang lain,
Dialogue: 0,0:19:59.84,0:20:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ucapannya memang ada benarnya.
Dialogue: 0,0:20:01.55,0:20:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau ribut,\Nmenjauhlah dariku dan Master.
Dialogue: 0,0:20:06.18,0:20:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau membangun keluarga bahagia di sini.
Dialogue: 0,0:20:10.19,0:20:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu cewek dulu baru dua cowok.
Dialogue: 0,0:20:12.36,0:20:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diamlah sebentar.
Dialogue: 0,0:20:14.03,0:20:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan seperti ini saja,\Naku sudah menggerogoti nyawa Ana.
Dialogue: 0,0:20:18.57,0:20:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku ingin\Nsegera menaklukkan menara ini,
Dialogue: 0,0:20:21.70,0:20:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengembalikan tubuh Ana.
Dialogue: 0,0:20:23.99,0:20:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:20:25.41,0:20:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga tak keberatan, Subaru?
Dialogue: 0,0:20:27.62,0:20:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:28.96,0:20:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir Meili juga tak ingin\Nkita berdiam diri saja.
Dialogue: 0,0:20:32.96,0:20:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Abang ini memang luar biasa.
Dialogue: 0,0:20:36.30,0:20:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau tak memercayai dirimu sendiri.
Dialogue: 0,0:20:52.81,0:20:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau melakukan sesuatu pada mayatku?
Dialogue: 0,0:20:55.65,0:20:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita takkan puas\Nkalau tak dipastikan, bukan?
Dialogue: 0,0:20:59.15,0:21:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:21:20.88,0:21:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa?
Dialogue: 0,0:21:21.80,0:21:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau cari diam-diam\Nselarut ini, Barusu?
Dialogue: 0,0:21:27.97,0:21:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau haruskah aku menyebutmu palsu?
Dialogue: 0,0:21:31.10,0:21:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusu, versi gagal dari Natsuki Subaru.
Dialogue: 0,0:21:34.98,0:21:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku cuma jalan-jalan di tengah malam.
Dialogue: 0,0:21:37.40,0:21:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau memperlakukanku seperti penjahat?
Dialogue: 0,0:21:39.86,0:21:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir tak ada yang melihatmu?
Dialogue: 0,0:21:42.57,0:21:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku melihat semuanya.
Dialogue: 0,0:22:07.72,0:22:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuh itu...
Dialogue: 0,0:22:10.22,0:22:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menjadi kebiasaan.
