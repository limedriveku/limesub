Dialogue: 0,0:00:03.08,0:00:05.94,dialog,,0,0,0,,Siapa juga yang sudi mati?
Dialogue: 0,0:00:12.93,0:00:15.15,dialog,,0,0,0,,Ternyata benar-benar di gurun, ya.
Dialogue: 0,0:00:32.05,0:00:33.39,dialog,,0,0,0,,Makhluk apa ini?!
Dialogue: 0,0:00:41.44,0:00:42.56,dialog,,0,0,0,,Tidak.
Dialogue: 0,0:00:44.57,0:00:46.28,dialog,,0,0,0,,Tidak!
Dialogue: 0,0:01:02.54,0:01:04.04,dialog,,0,0,0,,Apa-apaan ini?
Dialogue: 0,0:01:04.71,0:01:07.84,dialog,,0,0,0,,Aku harus bagaimana?
Dialogue: 0,0:01:08.35,0:01:12.05,dialog,,0,0,0,,Jawab aku, Natsuki Subaru!
Dialogue: 0,0:01:16.26,0:01:17.98,dialog,,0,0,0,,Tidak! Tidak! Tidak!
Dialogue: 0,0:01:21.56,0:01:22.52,dialog,,0,0,0,,Tolong...
Dialogue: 0,0:01:22.52,0:01:24.61,dialog,,0,0,0,,Siapa saja, tolong!
Dialogue: 0,0:01:51.26,0:01:53.34,dialog,,0,0,0,,Di bawah gurun?
Dialogue: 0,0:02:05.19,0:02:06.11,dialog,,0,0,0,,Gawat.
Dialogue: 0,0:02:06.48,0:02:08.40,dialog,,0,0,0,,Gawat! Gawat! Gawat!
Dialogue: 0,0:02:08.40,0:02:10.32,dialog,,0,0,0,,Apa ini? Apa-apaan ini?!
Dialogue: 0,0:02:10.32,0:02:12.82,dialog,,0,0,0,,Apa sebenarnya ini?!
Dialogue: 0,0:03:50.67,0:03:53.25,dialog,,0,0,0,,Ini sudah ketiga kalinya.
Dialogue: 0,0:03:57.22,0:03:58.97,dialog,,0,0,0,,Sudah berapa lama?
Dialogue: 0,0:03:59.34,0:04:01.60,dialog,,0,0,0,,Tiga jam? Empat jam?
Dialogue: 0,0:04:16.65,0:04:17.61,dialog,,0,0,0,,Sialan!
Dialogue: 0,0:04:44.68,0:04:46.27,dialog,,0,0,0,,Jangan bercanda.
Dialogue: 0,0:04:46.27,0:04:50.10,dialog,,0,0,0,,Kenapa? Kenapa menghalangiku?!
Dialogue: 0,0:04:52.73,0:04:54.61,dialog,,0,0,0,,Hah? Jangan bercanda...
Dialogue: 0,0:04:54.85,0:04:55.98,dialog,,0,0,0,,Bajingan!
Dialogue: 0,0:04:55.98,0:04:57.53,dialog,,0,0,0,,Ini tidak lucu!
Dialogue: 0,0:05:10.83,0:05:13.71,dialog,,0,0,0,,Aku terus-terusan lari...
Dialogue: 0,0:05:14.46,0:05:16.38,dialog,,0,0,0,,Lari... dan terus lari...
Dialogue: 0,0:05:20.97,0:05:22.05,dialog,,0,0,0,,Sudah cukup.
Dialogue: 0,0:05:23.48,0:05:25.13,dialog,,0,0,0,,Akan kubunuh.
Dialogue: 0,0:05:35.61,0:05:38.11,dialog,,0,0,0,,Entah siapa pelakunya...
Dialogue: 0,0:05:39.86,0:05:41.86,dialog,,0,0,0,,Tapi akan kubunuh.
Dialogue: 0,0:05:41.86,0:05:44.82,dialog,,0,0,0,,Pasti akan kubunuh.
Dialogue: 0,0:05:45.53,0:05:47.48,dialog,,0,0,0,,Bunuh, bunuh.
Dialogue: 0,0:05:47.88,0:05:49.13,dialog,,0,0,0,,Akan kubunuh.
Dialogue: 0,0:05:49.91,0:05:50.87,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:05:51.25,0:05:52.41,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:05:52.58,0:05:53.46,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:05:53.71,0:05:54.63,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:05:54.79,0:05:55.79,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:05:55.96,0:05:56.96,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:05:57.09,0:05:58.25,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:05:58.92,0:05:59.88,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:06:00.01,0:06:00.84,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:06:00.96,0:06:01.80,dialog,,0,0,0,,Bunuh.
Dialogue: 0,0:06:01.80,0:06:04.47,dialog,,0,0,0,,Bunuh. Bunuh. Bunuh. Bunuh.
Dialogue: 0,0:06:04.47,0:06:07.51,dialog,,0,0,0,,Bunuh! Bunuh! Bunuh! Bunuh! Bunuh!
Dialogue: 0,0:06:38.38,0:06:39.63,dialog,,0,0,0,,Shaula.
Dialogue: 0,0:06:40.09,0:06:42.01,dialog,,0,0,0,,Ternyata kau bukan pelakunya.
Dialogue: 0,0:06:45.63,0:06:48.10,dialog,,0,0,0,,Beatrice dan Meili hanya anak-anak.
Dialogue: 0,0:06:48.43,0:06:49.72,dialog,,0,0,0,,Mereka mudah ditangani.
Dialogue: 0,0:06:50.14,0:06:52.93,dialog,,0,0,0,,Emilia tak terlalu waspada padaku.
Dialogue: 0,0:06:53.33,0:06:56.77,dialog,,0,0,0,,Jadi yang paling berbahaya\Nadalah Ram dan Echidna.
Dialogue: 0,0:06:57.45,0:06:59.15,dialog,,0,0,0,,Julius juga berbahaya.
Dialogue: 0,0:06:59.15,0:07:02.86,dialog,,0,0,0,,Andai dia mati di tempat\Nyang tak ada hubungannya denganku.
Dialogue: 0,0:07:46.61,0:07:49.45,dialog,,0,0,0,,Aku tak melihat Emilia dan Beatrice.
Dialogue: 0,0:07:49.70,0:07:51.66,dialog,,0,0,0,,Siapa di antara mereka yang membunuhku?
Dialogue: 0,0:07:56.04,0:07:57.16,dialog,,0,0,0,,Ternyata kau.
Dialogue: 0,0:08:10.78,0:08:12.60,dialog,,0,0,0,,Jangan ikuti aku!
Dialogue: 0,0:08:12.60,0:08:14.93,dialog,,0,0,0,,Aku tak punya waktu main-main denganmu!
Dialogue: 0,0:08:15.27,0:08:19.23,dialog,,0,0,0,,Aku harus membunuh mereka yang tersisa.
Dialogue: 0,0:08:21.19,0:08:23.94,dialog,,0,0,0,,Kalau kau menghalangiku...
Dialogue: 0,0:08:39.79,0:08:41.21,dialog,,0,0,0,,Berengsek! Berengsek!
Dialogue: 0,0:08:41.42,0:08:43.13,dialog,,0,0,0,,Berengsek! Berengsek! Berengsek!
Dialogue: 0,0:08:43.34,0:08:46.09,dialog,,0,0,0,,Apa ini? Apa-apaan ini?!
Dialogue: 0,0:08:46.09,0:08:47.17,dialog,,0,0,0,,Kau juga!
Dialogue: 0,0:08:47.17,0:08:48.80,dialog,,0,0,0,,Semua orang selain kau!
Dialogue: 0,0:08:48.80,0:08:51.05,dialog,,0,0,0,,Mayat-mayat! Mereka yang masih hidup!
Dialogue: 0,0:08:51.26,0:08:54.18,dialog,,0,0,0,,Apa mau kalian sebenarnya?!
Dialogue: 0,0:08:54.64,0:08:57.43,dialog,,0,0,0,,Aku tak peduli lagi pada kalian!
Dialogue: 0,0:08:57.89,0:09:01.40,dialog,,0,0,0,,Kalian seenaknya melimpahkan\Nmasalah padaku!
Dialogue: 0,0:09:01.40,0:09:04.40,dialog,,0,0,0,,Kalau kalian lelah dengan urusan kalian...
Dialogue: 0,0:09:04.40,0:09:06.07,dialog,,0,0,0,,Aku juga sama!
Dialogue: 0,0:09:07.03,0:09:10.53,dialog,,0,0,0,,Aku sudah lelah dengan masalahku sendiri!
Dialogue: 0,0:09:18.66,0:09:21.96,dialog,,0,0,0,,Jadi, biarkan aku sendiri.
Dialogue: 0,0:09:22.83,0:09:27.17,dialog,,0,0,0,,Tinggalkan aku sendiri.
Dialogue: 0,0:09:36.76,0:09:37.65,dialog,,0,0,0,,Aduh!
Dialogue: 0,0:09:37.65,0:09:38.58,dialog,,0,0,0,,Mau apa kau?!
Dialogue: 0,0:10:04.37,0:10:05.25,dialog,,0,0,0,,Tidak.
Dialogue: 0,0:10:05.33,0:10:06.42,dialog,,0,0,0,,Tidak!
Dialogue: 0,0:10:06.42,0:10:08.13,dialog,,0,0,0,,Aku tidak mau mati!
Dialogue: 0,0:10:11.01,0:10:13.76,dialog,,0,0,0,,Kadal!
Dialogue: 0,0:10:35.99,0:10:37.49,dialog,,0,0,0,,Siapa kau?
Dialogue: 0,0:10:39.78,0:10:43.12,dialog,,0,0,0,,Siapa kau sebenarnya?
Dialogue: 0,0:10:45.37,0:10:48.88,dialog,,0,0,0,,Coba tebak lagi,
Dialogue: 0,0:10:48.88,0:10:50.55,dialog,,0,0,0,,Pahlawan.
Dialogue: 0,0:10:57.39,0:10:58.35,dialog,,0,0,0,,Subaru.
Dialogue: 0,0:10:59.14,0:11:01.52,dialog,,0,0,0,,Hei, Subaru, kamu tak apa-apa?
Dialogue: 0,0:11:01.85,0:11:04.31,dialog,,0,0,0,,Emilia.
Dialogue: 0,0:11:04.65,0:11:06.23,dialog,,0,0,0,,Syukurlah.
Dialogue: 0,0:11:06.53,0:11:08.69,dialog,,0,0,0,,Kami sangat khawatir.
Dialogue: 0,0:11:13.19,0:11:13.99,dialog,,0,0,0,,Subaru?
Dialogue: 0,0:11:15.50,0:11:16.61,dialog,,0,0,0,,Ada apa?
Dialogue: 0,0:11:18.99,0:11:21.41,dialog,,0,0,0,,Sepertinya dia belum sadar penuh.
Dialogue: 0,0:11:21.41,0:11:25.12,dialog,,0,0,0,,Santai sekali, padahal sudah buat\NBeti dan yang lain cemas.
Dialogue: 0,0:11:27.38,0:11:28.63,dialog,,0,0,0,,Kau...!
Dialogue: 0,0:11:30.96,0:11:33.42,dialog,,0,0,0,,Rasanya tak adil, kurasa.
Dialogue: 0,0:11:33.42,0:11:37.09,dialog,,0,0,0,,Padahal yang menemukan Subaru\Nharusnya Beti dan Emilia.
Dialogue: 0,0:11:38.09,0:11:39.39,dialog,,0,0,0,,Jangan marah.
Dialogue: 0,0:11:39.39,0:11:43.64,dialog,,0,0,0,,Bukankah bagus Subaru dan Patrasche\Nsangat akrab begitu?
Dialogue: 0,0:11:47.00,0:11:48.40,dialog,,0,0,0,,Hei, Subaru.
Dialogue: 0,0:11:48.40,0:11:50.61,dialog,,0,0,0,,Kamu benar-benar tak apa-apa?
Dialogue: 0,0:11:50.61,0:11:52.82,dialog,,0,0,0,,Ya, aku baik-baik saja.
Dialogue: 0,0:11:52.82,0:11:54.36,dialog,,0,0,0,,Tak masalah.
Dialogue: 0,0:11:54.36,0:11:56.61,dialog,,0,0,0,,Mungkin karena aku sangat lelah.
Dialogue: 0,0:11:56.61,0:11:59.49,dialog,,0,0,0,,Ketiduran seperti itu sudah biasa.
Dialogue: 0,0:11:59.49,0:12:00.45,dialog,,0,0,0,,Begitu, ya.
Dialogue: 0,0:12:00.98,0:12:03.33,dialog,,0,0,0,,Tapi, kalau lelah, jujur saja, ya.
Dialogue: 0,0:12:03.66,0:12:05.50,dialog,,0,0,0,,Memaksakan diri itu tak baik.
Dialogue: 0,0:12:09.45,0:12:11.29,dialog,,0,0,0,,Ini akan sangat berisiko,
Dialogue: 0,0:12:11.59,0:12:14.67,dialog,,0,0,0,,tapi kali ini aku takkan bercerita\Nsoal amnesiaku.
Dialogue: 0,0:12:15.48,0:12:19.59,dialog,,0,0,0,,Apa alasanku dibunuh ada hubungannya\Ndengan ingatanku yang hilang?
Dialogue: 0,0:12:20.13,0:12:21.30,dialog,,0,0,0,,Jujur saja,
Dialogue: 0,0:12:21.30,0:12:25.47,dialog,,0,0,0,,masih masuk akal jika dibunuh karena\Nada hal yang merugikan mereka.
Dialogue: 0,0:12:25.78,0:12:29.81,dialog,,0,0,0,,Tapi jika dibunuh hanya karena lupa,\Nitu rasanya keterlaluan.
Dialogue: 0,0:12:32.53,0:12:33.69,dialog,,0,0,0,,Subaru.
Dialogue: 0,0:12:34.13,0:12:36.57,dialog,,0,0,0,,Dahimu berkerut lagi, tuh.
Dialogue: 0,0:12:38.45,0:12:42.37,dialog,,0,0,0,,Apa yang sebenarnya kulakukan\Nsampai dia sedekat ini?
Dialogue: 0,0:12:44.87,0:12:47.58,dialog,,0,0,0,,Aku tak menemukan jasad mereka berdua.
Dialogue: 0,0:12:47.88,0:12:49.08,dialog,,0,0,0,,Tapi...
Dialogue: 0,0:12:49.29,0:12:52.46,dialog,,0,0,0,,Coba tebak lagi,
Dialogue: 0,0:12:52.67,0:12:54.38,dialog,,0,0,0,,Pahlawan.
Dialogue: 0,0:12:54.90,0:12:57.71,dialog,,0,0,0,,Itu bukan suara mereka.
Dialogue: 0,0:12:57.71,0:13:00.13,dialog,,0,0,0,,Bahkan bukan suara siapa pun\Ndi antara mereka.
Dialogue: 0,0:13:00.13,0:13:01.01,dialog,,0,0,0,,Barusu.
Dialogue: 0,0:13:03.20,0:13:06.26,dialog,,0,0,0,,Jangan cuma melamun.\NBantu ambil air atau semacamnya.
Dialogue: 0,0:13:06.26,0:13:07.89,dialog,,0,0,0,,Oh, maaf.
Dialogue: 0,0:13:08.30,0:13:10.19,dialog,,0,0,0,,Kau tertidur di ruang arsip atas, ya.
Dialogue: 0,0:13:10.75,0:13:12.94,dialog,,0,0,0,,Berhentilah bertindak bodoh.
Dialogue: 0,0:13:13.36,0:13:15.27,dialog,,0,0,0,,Kau jadi merepotkan yang lain.
Dialogue: 0,0:13:15.55,0:13:17.63,dialog,,0,0,0,,Ya, maafkan aku.
Dialogue: 0,0:13:17.98,0:13:20.30,dialog,,0,0,0,,Maaf sudah membuatmu cemas.
Dialogue: 0,0:13:20.55,0:13:22.95,dialog,,0,0,0,,Aku mencemaskan Barusu?\NUntuk apa?
Dialogue: 0,0:13:22.95,0:13:24.87,dialog,,0,0,0,,Takut terjadi sesuatu padaku?
Dialogue: 0,0:13:25.48,0:13:27.79,dialog,,0,0,0,,Good morning, Master!
Dialogue: 0,0:13:27.79,0:13:30.35,dialog,,0,0,0,,Tidurmu nyenyak semalam?
Dialogue: 0,0:13:32.79,0:13:35.33,dialog,,0,0,0,,Kalau aku, sih, nyenyak.
Dialogue: 0,0:13:35.33,0:13:37.50,dialog,,0,0,0,,Bahkan sampai mimpi tentang masa lalu.
Dialogue: 0,0:13:37.75,0:13:41.63,dialog,,0,0,0,,Saat aku, Master, dan ibu...
Dialogue: 0,0:13:41.63,0:13:44.68,dialog,,0,0,0,,Iya, iya, nanti kudengarkan.
Dialogue: 0,0:13:45.20,0:13:49.31,dialog,,0,0,0,,Omong-omong, kau sadar sesuatu\Nsaat melihatku pagi ini?
Dialogue: 0,0:13:49.31,0:13:51.14,dialog,,0,0,0,,Master pagi ini?
Dialogue: 0,0:13:51.43,0:13:53.77,dialog,,0,0,0,,Menawan seperti biasa!
Dialogue: 0,0:13:53.77,0:13:55.90,dialog,,0,0,0,,Aku rela menanti 400 tahun untuk dilamar!
Dialogue: 0,0:13:56.15,0:13:58.28,dialog,,0,0,0,,Penantian yang sangat panjang.
Dialogue: 0,0:13:58.28,0:14:00.69,dialog,,0,0,0,,Ya sudah kalau tak ada yang beda.
Dialogue: 0,0:14:00.69,0:14:01.65,dialog,,0,0,0,,Begitukah?
Dialogue: 0,0:14:14.54,0:14:17.09,dialog,,0,0,0,,Shaula, aku minta tolong sesuatu.
Dialogue: 0,0:14:17.09,0:14:18.92,dialog,,0,0,0,,Eh, apa?
Dialogue: 0,0:14:20.67,0:14:21.72,dialog,,0,0,0,,Julius.
Dialogue: 0,0:14:23.63,0:14:25.93,dialog,,0,0,0,,Aku ingin bahas soal semalam.
Dialogue: 0,0:14:26.43,0:14:28.13,dialog,,0,0,0,,Berdua saja, empat mata.
Dialogue: 0,0:14:31.73,0:14:33.98,dialog,,0,0,0,,Soal semalam, ya?
Dialogue: 0,0:14:34.93,0:14:37.65,dialog,,0,0,0,,Kukira obrolannya sudah selesai.
Dialogue: 0,0:14:37.94,0:14:39.44,dialog,,0,0,0,,Bagimu belum?
Dialogue: 0,0:14:39.65,0:14:41.23,dialog,,0,0,0,,Ya, belum.
Dialogue: 0,0:14:41.23,0:14:44.74,dialog,,0,0,0,,Aku masih belum bisa menerimanya.
Dialogue: 0,0:14:48.20,0:14:50.33,dialog,,0,0,0,,Menerimanya, ya?
Dialogue: 0,0:14:50.70,0:14:53.04,dialog,,0,0,0,,Begitu, ya, memang kau sekali.
Dialogue: 0,0:14:53.80,0:14:56.83,dialog,,0,0,0,,Tapi, bukankah itu agak egois?
Dialogue: 0,0:14:56.83,0:14:59.96,dialog,,0,0,0,,Kau juga sepertinya\Nbelum bisa menerimanya, 'kan?
Dialogue: 0,0:14:59.96,0:15:03.59,dialog,,0,0,0,,Kita berdua sama-sama memendam\Nfrustrasi sampai muak,
Dialogue: 0,0:15:03.59,0:15:05.34,dialog,,0,0,0,,tapi kau menyuruhku tenang?
Dialogue: 0,0:15:05.58,0:15:06.88,dialog,,0,0,0,,Kau pikir aku bisa?
Dialogue: 0,0:15:07.22,0:15:10.64,dialog,,0,0,0,,Lalu, apa ada pilihan lain?
Dialogue: 0,0:15:11.38,0:15:14.13,dialog,,0,0,0,,Perasaanku sama seperti\Nyang kusampaikan semalam.
Dialogue: 0,0:15:14.40,0:15:17.15,dialog,,0,0,0,,Tak ada lagi yang perlu dibahas.
Dialogue: 0,0:15:17.69,0:15:21.43,dialog,,0,0,0,,Karena aku bahkan tak menyadari rahasiamu
Dialogue: 0,0:15:21.43,0:15:24.11,dialog,,0,0,0,,dengan Nona Anastasia, dengan Echidna.
Dialogue: 0,0:15:24.80,0:15:27.49,dialog,,0,0,0,,Rahasiaku dengan Echidna?
Dialogue: 0,0:15:27.66,0:15:30.37,dialog,,0,0,0,,Aku tahu kau tak berniat jahat.
Dialogue: 0,0:15:31.18,0:15:34.20,dialog,,0,0,0,,Aku sudah bicara dengan Echidna,\Nmeski rasanya belum cukup.
Dialogue: 0,0:15:34.80,0:15:36.53,dialog,,0,0,0,,Dia bisa dipercaya.
Dialogue: 0,0:15:36.98,0:15:40.43,dialog,,0,0,0,,Tidak, aku tak punya pilihan\Nselain memercayainya.
Dialogue: 0,0:15:41.10,0:15:43.23,dialog,,0,0,0,,Demi menyelamatkan Nona Anastasia,
Dialogue: 0,0:15:43.55,0:15:46.26,dialog,,0,0,0,,satu-satunya pilihan adalah\Nbertaruh pada kemungkinan itu.
Dialogue: 0,0:15:48.55,0:15:50.22,dialog,,0,0,0,,Bahkan jika dia kembali
Dialogue: 0,0:15:50.90,0:15:54.14,dialog,,0,0,0,,dan ternyata tak mengingatku lagi.
Dialogue: 0,0:15:54.90,0:15:56.78,dialog,,0,0,0,,Apa maksudnya?
Dialogue: 0,0:15:57.93,0:15:59.05,dialog,,0,0,0,,Kumohon.
Dialogue: 0,0:15:59.85,0:16:03.10,dialog,,0,0,0,,Jangan buatku terlihat makin\Nmenyedihkan di hadapanmu.
Dialogue: 0,0:16:07.75,0:16:11.16,dialog,,0,0,0,,Aku sedikit cemas saat kau bilang\Ningin bahas soal semalam.
Dialogue: 0,0:16:12.18,0:16:15.62,dialog,,0,0,0,,Apa yang harus kulakukan\Njika kau meminta maaf?
Dialogue: 0,0:16:16.15,0:16:19.46,dialog,,0,0,0,,Kalau aku... meminta maaf?
Dialogue: 0,0:16:19.98,0:16:24.08,dialog,,0,0,0,,Jika itu terjadi, entah apa\Nyang akan kukatakan padamu.
Dialogue: 0,0:16:24.95,0:16:28.03,dialog,,0,0,0,,Namun, aku sudah tak tahu lagi.
Dialogue: 0,0:16:43.57,0:16:46.44,dialog,,0,0,0,,Master, apa begitu sudah cukup?
Dialogue: 0,0:16:46.98,0:16:48.28,dialog,,0,0,0,,Ya.
Dialogue: 0,0:16:48.28,0:16:52.12,dialog,,0,0,0,,Dari reaksinya, dia tak ada kaitan\Ndengan ruang arsip itu.
Dialogue: 0,0:16:52.12,0:16:56.33,dialog,,0,0,0,,Tapi, rasa tidak percayanya padaku\Nmalah makin membesar.
Dialogue: 0,0:16:56.33,0:16:58.12,dialog,,0,0,0,,Aku tak mengerti, tapi...
Dialogue: 0,0:16:58.29,0:17:00.75,dialog,,0,0,0,,Apa aku sudah berguna bagi Master?
Dialogue: 0,0:17:01.03,0:17:02.75,dialog,,0,0,0,,Ya, kau sangat berguna.
Dialogue: 0,0:17:03.18,0:17:05.63,dialog,,0,0,0,,Berkat kehadiranmu di sisiku,
Dialogue: 0,0:17:05.63,0:17:07.88,dialog,,0,0,0,,aku bisa menghadapi Julius dengan tenang.
Dialogue: 0,0:17:09.83,0:17:11.80,dialog,,0,0,0,,Syukurlah kalau begitu.
Dialogue: 0,0:17:12.15,0:17:13.89,dialog,,0,0,0,,Kalau begitu, Master,
Dialogue: 0,0:17:14.76,0:17:18.52,dialog,,0,0,0,,sebagai hadiah,\Naku ingin dipeluk erat-erat!
Dialogue: 0,0:17:18.52,0:17:19.35,dialog,,0,0,0,,Tidak mau.
Dialogue: 0,0:17:19.35,0:17:21.39,dialog,,0,0,0,,Eh! Jahat!
Dialogue: 0,0:17:21.39,0:17:24.15,dialog,,0,0,0,,Katanya Master mau turuti permintaanku
Dialogue: 0,0:17:24.15,0:17:26.86,dialog,,0,0,0,,selama tak kelewatan batas!
Dialogue: 0,0:17:26.86,0:17:29.32,dialog,,0,0,0,,Permintaanmu melampaui batas\Nkesucian hatiku.
Dialogue: 0,0:17:31.32,0:17:36.33,dialog,,0,0,0,,Sebenarnya, apa yang kau lakukan\Nsampai diincar seseorang,
Dialogue: 0,0:17:36.62,0:17:38.24,dialog,,0,0,0,,Natsuki Subaru?
Dialogue: 0,0:17:39.08,0:17:41.37,dialog,,0,0,0,,Makin buntu saja.
Dialogue: 0,0:17:41.37,0:17:43.58,dialog,,0,0,0,,Rasanya ingin curhat ke Patrasche.
Dialogue: 0,0:17:43.58,0:17:46.00,dialog,,0,0,0,,Eh, ke naga darat?
Dialogue: 0,0:17:46.00,0:17:48.55,dialog,,0,0,0,,Aku tak suka karena dia selalu melototiku.
Dialogue: 0,0:17:48.55,0:17:51.84,dialog,,0,0,0,,Hei! Aku takkan maafkan siapa pun\Nyang menjelekkan Patrasche.
Dialogue: 0,0:17:51.84,0:17:54.89,dialog,,0,0,0,,Kalaupun dunia memperbolehkan\Nmenghina semua orang,
Dialogue: 0,0:17:54.89,0:17:57.56,dialog,,0,0,0,,aku tetap takkan maafkan\Norang yang menghina Patrasche.
Dialogue: 0,0:17:57.56,0:18:01.35,dialog,,0,0,0,,Master, seberapa cintanya, sih,\Nkau pada naga darat itu?
Dialogue: 0,0:18:01.35,0:18:05.36,dialog,,0,0,0,,Untuk sekarang, kita bubar dulu.
Dialogue: 0,0:18:05.36,0:18:06.56,dialog,,0,0,0,,Sampai nanti.
Dialogue: 0,0:18:06.86,0:18:10.23,dialog,,0,0,0,,Eh? Hadiahnya belum dikasih!
Dialogue: 0,0:18:10.49,0:18:12.58,dialog,,0,0,0,,Tapi, aku takkan menyerah!
Dialogue: 0,0:18:12.58,0:18:14.95,dialog,,0,0,0,,Menjadi wanita yang berguna bagi Master
Dialogue: 0,0:18:14.95,0:18:17.41,dialog,,0,0,0,,adalah arti keberadaanku!
Dialogue: 0,0:18:19.45,0:18:21.66,dialog,,0,0,0,,Sampai sebegitunya?
Dialogue: 0,0:18:21.66,0:18:24.08,dialog,,0,0,0,,Memangnya seberharga apa\NNatsuki Subaru itu?
Dialogue: 0,0:18:25.48,0:18:26.68,dialog,,0,0,0,,Master?
Dialogue: 0,0:18:26.68,0:18:28.21,dialog,,0,0,0,,Ah, sialan!
Dialogue: 0,0:18:34.10,0:18:38.10,dialog,,0,0,0,,Tak usah repot-repot memikirkan\Njadi wanita yang bisa dimanfaatkan.
Dialogue: 0,0:18:38.53,0:18:40.00,dialog,,0,0,0,,Aku yang salah.
Dialogue: 0,0:18:42.20,0:18:43.48,dialog,,0,0,0,,Master?
Dialogue: 0,0:18:47.44,0:18:49.60,dialog,,0,0,0,,Kehadiranmu sangat membantuku.
Dialogue: 0,0:18:50.05,0:18:51.28,dialog,,0,0,0,,Itu saja.
Dialogue: 0,0:18:52.83,0:18:53.98,dialog,,0,0,0,,Master.
Dialogue: 0,0:18:55.70,0:18:59.16,dialog,,0,0,0,,Akhirnya Master mulai...
Dialogue: 0,0:18:59.91,0:19:01.24,dialog,,0,0,0,,jatuh cinta padaku!
Dialogue: 0,0:19:02.04,0:19:03.83,dialog,,0,0,0,,Melampaui batas!
Dialogue: 0,0:19:16.78,0:19:19.28,dialog,,0,0,0,,Kalau ternyata sikap mereka cuma akting,
Dialogue: 0,0:19:19.28,0:19:22.08,dialog,,0,0,0,,aku sudah tak tahu\Nharus percaya pada siapa.
Dialogue: 0,0:19:25.63,0:19:29.36,dialog,,0,0,0,,Pada akhirnya yang bisa kupercaya\Nhanya Patrasche.
Dialogue: 0,0:19:30.57,0:19:34.93,dialog,,0,0,0,,Mungkin akan lebih bahagia jika hidup\Nberdua saja dengan Patrasche.
Dialogue: 0,0:19:34.93,0:19:36.91,dialog,,0,0,0,,Wah, aku tak sengaja dengar.
Dialogue: 0,0:19:39.95,0:19:43.90,dialog,,0,0,0,,Abang mau pergi jauh bareng Patrasche, ya.
Dialogue: 0,0:19:43.90,0:19:47.83,dialog,,0,0,0,,Kalau Beatrice dan kakak itu dengar,\Npasti bakal menangis.
Dialogue: 0,0:19:47.83,0:19:50.00,dialog,,0,0,0,,Itu cuma candaan receh.
Dialogue: 0,0:19:50.21,0:19:52.00,dialog,,0,0,0,,Anggap saja tak pernah dengar.
Dialogue: 0,0:19:52.33,0:19:53.68,dialog,,0,0,0,,Iya, iya.
Dialogue: 0,0:19:54.08,0:19:58.76,dialog,,0,0,0,,Tapi, aku takkan tertawa\Nkalaupun itu benar.
Dialogue: 0,0:19:59.10,0:20:03.47,dialog,,0,0,0,,Aku pernah cerita dulunya hidup\Nbareng binatang iblis, 'kan?
Dialogue: 0,0:20:03.47,0:20:04.93,dialog,,0,0,0,,Binatang iblis?
Dialogue: 0,0:20:05.78,0:20:08.27,dialog,,0,0,0,,Maksudnya semacam gadis serigala?
Dialogue: 0,0:20:09.63,0:20:12.23,dialog,,0,0,0,,Kemarin kau juga bilang begitu.
Dialogue: 0,0:20:12.48,0:20:14.58,dialog,,0,0,0,,Mama sangat keras.
Dialogue: 0,0:20:14.80,0:20:18.95,dialog,,0,0,0,,Lalu Elsa yang terus bersamaku\Njuga sangat ceroboh.
Dialogue: 0,0:20:18.95,0:20:21.82,dialog,,0,0,0,,Aku jadi sering mengurus segalanya sendiri.
Dialogue: 0,0:20:21.82,0:20:25.54,dialog,,0,0,0,,Tunggu dulu!\NKepalaku mau meledak diserbu informasi!
Dialogue: 0,0:20:25.54,0:20:27.33,dialog,,0,0,0,,Sekarang aku sedang sibuk.
Dialogue: 0,0:20:27.33,0:20:29.00,dialog,,0,0,0,,Main sana sama Shaula.
Dialogue: 0,0:20:29.25,0:20:31.03,dialog,,0,0,0,,Kakak setengah telanjang itu?
Dialogue: 0,0:20:31.03,0:20:35.21,dialog,,0,0,0,,Tak masalah,\Ntapi sekarang aku ada perlu dengan Abang.
Dialogue: 0,0:20:35.68,0:20:36.65,dialog,,0,0,0,,Denganku?
Dialogue: 0,0:20:45.93,0:20:48.05,dialog,,0,0,0,,Soal semalam,
Dialogue: 0,0:20:48.35,0:20:51.56,dialog,,0,0,0,,seberapa serius aku harus\Nmenanggapi ucapanmu?
Dialogue: 0,0:20:56.23,0:20:57.24,dialog,,0,0,0,,Aduh.
Dialogue: 0,0:21:01.20,0:21:02.85,dialog,,0,0,0,,Apa ini?
Dialogue: 0,0:21:12.75,0:21:13.95,dialog,,0,0,0,,Tak mungkin.
Dialogue: 0,0:21:15.13,0:21:16.09,dialog,,0,0,0,,Tak mungkin!
Dialogue: 0,0:21:16.09,0:21:17.84,dialog,,0,0,0,,Tidak! Tidak! Tak mungkin!
Dialogue: 0,0:21:18.23,0:21:19.08,dialog,,0,0,0,,Meili!
Dialogue: 0,0:21:19.38,0:21:21.05,dialog,,0,0,0,,Hei, Meili!
Dialogue: 0,0:21:22.80,0:21:24.39,dialog,,0,0,0,,Meili! Meili!
Dialogue: 0,0:21:24.39,0:21:25.65,dialog,,0,0,0,,Sial!
Dialogue: 0,0:21:29.18,0:21:30.77,dialog,,0,0,0,,Sial! Sial!
Dialogue: 0,0:21:36.19,0:21:37.15,dialog,,0,0,0,,Aku...
Dialogue: 0,0:21:41.03,0:21:42.18,dialog,,0,0,0,,yang membunuhnya?
Dialogue: 0,0:21:44.12,0:21:45.62,dialog,,0,0,0,,Kenapa aku...
Dialogue: 0,0:21:45.62,0:21:47.00,dialog,,0,0,0,,melakukannya?
