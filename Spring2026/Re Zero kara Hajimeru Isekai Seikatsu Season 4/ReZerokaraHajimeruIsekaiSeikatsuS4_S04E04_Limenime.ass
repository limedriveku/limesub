Dialogue: 0,0:19:06.70,0:19:09.00,5-normal,signs,0,0,0,,{\fad(700,0)\fs100\bord0\shad0\pos(960,51)}Asterisma di Langit Putih
Dialogue: 10,0:00:02.74,0:00:06.24,dialog,,0,0,0,,Dengar, ya. Jangan main-main.
Dialogue: 10,0:00:06.24,0:00:09.49,dialog,,0,0,0,,Cuma karena sedikit beruntung,\Nlangsung merasa menang.
Dialogue: 10,0:00:09.74,0:00:11.65,dialog,,0,0,0,,Biadab dan menjijikkan.
Dialogue: 10,0:00:12.04,0:00:16.04,dialog,,0,0,0,,Benar-benar pemikiran egois!
Dialogue: 10,0:00:16.04,0:00:17.25,dialog,,0,0,0,,Benar-benar, deh.
Dialogue: 10,0:00:17.54,0:00:20.80,dialog,,0,0,0,,Mau menghinaku sampai sejauh mana\Nagar kau merasa puas?
Dialogue: 10,0:00:20.80,0:00:24.67,dialog,,0,0,0,,Ah! Padahal aku sudah memohon\Ndengan sangat dan sungguh-sungguh!
Dialogue: 10,0:00:25.01,0:00:26.01,dialog,,0,0,0,,Kau ini
Dialogue: 10,0:00:26.01,0:00:28.39,dialog,,0,0,0,,benar-benar malas, ya!
Dialogue: 10,0:00:28.80,0:00:29.97,dialog,,0,0,0,,Bukankah itu
Dialogue: 10,0:00:29.97,0:00:34.18,dialog,,0,0,0,,sama saja melanggar hakku
Dialogue: 10,0:00:34.18,0:00:37.40,dialog,,0,0,0,,yang hanya ingin kebahagiaan sederhana...
Dialogue: 10,0:00:56.75,0:00:57.87,dialog,,0,0,0,,Aku mencintaimu.
Dialogue: 10,0:01:05.30,0:01:07.13,dialog,,0,0,0,,Di dalam kereta naga?
Dialogue: 10,0:01:10.85,0:01:11.93,dialog,,0,0,0,,Emilia?
Dialogue: 10,0:01:12.64,0:01:15.64,dialog,,0,0,0,,Ini bukan kembali dari kematian, 'kan?
Dialogue: 10,0:01:18.39,0:01:20.68,dialog,,0,0,0,,Lembut... hangat...
Dialogue: 10,0:01:22.32,0:01:24.53,dialog,,0,0,0,,Jangan iseng begitu.
Dialogue: 10,0:01:25.74,0:01:29.03,dialog,,0,0,0,,Emilia sampai tidak tidur dua malam\Nkarena khawatir.
Dialogue: 10,0:01:29.03,0:01:31.07,dialog,,0,0,0,,Syukurlah, kau selamat?
Dialogue: 10,0:01:31.41,0:01:32.37,dialog,,0,0,0,,Bagaimana yang lain?
Dialogue: 10,0:01:32.37,0:01:33.83,dialog,,0,0,0,,Tenang saja.
Dialogue: 10,0:01:33.83,0:01:36.33,dialog,,0,0,0,,Semuanya berkumpul dengan selamat.
Dialogue: 10,0:01:36.33,0:01:37.79,dialog,,0,0,0,,Syukurlah.
Dialogue: 10,0:01:37.79,0:01:39.54,dialog,,0,0,0,,Aku benar-benar khawatir, tahu.
Dialogue: 10,0:01:39.54,0:01:40.96,dialog,,0,0,0,,Biarkan aku memelukmu.
Dialogue: 10,0:01:49.26,0:01:50.39,dialog,,0,0,0,,Tempat ini...
Dialogue: 10,0:01:50.39,0:01:51.22,dialog,,0,0,0,,Begitulah.
Dialogue: 10,0:01:53.89,0:01:56.85,dialog,,0,0,0,,Di dalam Menara Pengawas Pleiades, kurasa?
Dialogue: 10,0:02:05.43,0:02:06.44,dialog,,0,0,0,,Kau...
Dialogue: 10,0:02:10.60,0:02:11.95,dialog,,0,0,0,,Kau siapa?
Dialogue: 10,0:02:12.49,0:02:13.95,dialog,,0,0,0,,Apa kau sang Bijak?
Dialogue: 10,0:02:13.95,0:02:15.54,dialog,,0,0,0,,Akhirnya aku menemukanmu,
Dialogue: 10,0:02:15.99,0:02:17.00,dialog,,0,0,0,,Master.
Dialogue: 10,0:02:21.00,0:02:23.00,dialog,,0,0,0,,Master!
Dialogue: 10,0:02:23.00,0:02:24.00,dialog,,0,0,0,,Dasar! Dasar! Dasar!
Dialogue: 10,0:02:24.25,0:02:26.13,dialog,,0,0,0,,Aku sudah menunggumu!
Dialogue: 10,0:02:27.15,0:02:29.48,dialog,,0,0,0,,Aduh! Apa-apaan ini?!
Dialogue: 10,0:02:29.48,0:02:30.45,dialog,,0,0,0,,Lama banget!
Dialogue: 10,0:02:30.45,0:02:31.84,dialog,,0,0,0,,- Aku kesepian!\N- Tunggu!
Dialogue: 10,0:02:31.84,0:02:32.89,dialog,,0,0,0,,Tunggu! Tunggu!
Dialogue: 10,0:02:32.89,0:02:34.30,dialog,,0,0,0,,Sakit!
Dialogue: 10,0:02:34.60,0:02:36.18,dialog,,0,0,0,,Kekuatan macam apa ini?!
Dialogue: 10,0:02:36.18,0:02:38.93,dialog,,0,0,0,,Sebenarnya kau ini siapa?
Dialogue: 10,0:02:39.23,0:02:40.73,dialog,,0,0,0,,Bicara apa kau ini?
Dialogue: 10,0:02:40.73,0:02:41.73,dialog,,0,0,0,,Aku Shaula!
Dialogue: 10,0:02:41.73,0:02:43.77,dialog,,0,0,0,,Penjaga bintang Menara Pengawas Pleiades!
Dialogue: 10,0:02:43.77,0:02:46.73,dialog,,0,0,0,,Shaula, murid imut kesayangan Master!
Dialogue: 10,0:02:49.28,0:02:49.94,dialog,,0,0,0,,Gawat!
Dialogue: 10,0:02:49.94,0:02:51.74,dialog,,0,0,0,,Waktu aku bangun, Subaru tiba-tiba hilang...
Dialogue: 10,0:02:55.41,0:02:57.85,dialog,,0,0,0,,Emilia, tolong aku.
Dialogue: 10,0:03:01.79,0:03:03.25,dialog,,0,0,0,,Lah, kenapa?
Dialogue: 10,0:03:03.25,0:03:04.46,dialog,,0,0,0,,Aku tidak tahu,
Dialogue: 10,0:03:04.67,0:03:07.00,dialog,,0,0,0,,tapi entah kenapa aku merasa sangat jengkel.
Dialogue: 10,0:03:09.75,0:03:10.46,dialog,,0,0,0,,Subaru.
Dialogue: 10,0:03:11.00,0:03:13.17,dialog,,0,0,0,,Tolong jangan buat aku kecewa.
Dialogue: 10,0:03:13.80,0:03:15.42,dialog,,0,0,0,,Hidungmu kembang-kempis.
Dialogue: 10,0:03:15.80,0:03:16.68,dialog,,0,0,0,,Barumesum.
Dialogue: 10,0:03:16.93,0:03:18.01,dialog,,0,0,0,,Mana ada!
Dialogue: 10,0:03:18.01,0:03:19.18,dialog,,0,0,0,,Jangan digabung-gabung!
Dialogue: 10,0:03:19.18,0:03:20.97,dialog,,0,0,0,,Master! Master!
Dialogue: 10,0:03:20.97,0:03:22.39,dialog,,0,0,0,,Takkan kulepaskan lagi.
Dialogue: 10,0:03:22.39,0:03:25.98,dialog,,0,0,0,,Yang jelas, aku ingin bicara dulu\Nsebelum tanganku putus.
Dialogue: 10,0:03:26.19,0:03:28.02,dialog,,0,0,0,,Kami juga bingung.
Dialogue: 10,0:03:28.35,0:03:30.86,dialog,,0,0,0,,Tadi orang ini tidak mau bicara apa-apa,
Dialogue: 10,0:03:30.86,0:03:33.28,dialog,,0,0,0,,sekarang malah menempel padamu, Natsuki.
Dialogue: 10,0:03:34.07,0:03:35.11,dialog,,0,0,0,,Dia?
Dialogue: 10,0:03:35.11,0:03:36.65,dialog,,0,0,0,,Master sendiri yang bilang.
Dialogue: 10,0:03:37.28,0:03:40.37,dialog,,0,0,0,,Jangan katakan hal yang tak perlu\Nkalau ada yang bertanya.
Dialogue: 10,0:03:40.37,0:03:42.03,dialog,,0,0,0,,Jangan bicara, jangan beri tahu.
Dialogue: 10,0:03:42.03,0:03:43.87,dialog,,0,0,0,,Bila perlu, hajar saja!
Dialogue: 10,0:03:44.04,0:03:46.54,dialog,,0,0,0,,Aku cuma menepati janji itu, kok.
Dialogue: 10,0:03:46.54,0:03:48.79,dialog,,0,0,0,,Mastermu parah juga, ya.
Dialogue: 10,0:03:49.58,0:03:52.50,dialog,,0,0,0,,Sudahlah, lupakan saja.\NBicaralah dengan yang lain juga.
Dialogue: 10,0:03:55.01,0:03:57.51,dialog,,0,0,0,,Asyik, akhirnya!
Dialogue: 10,0:03:57.72,0:04:00.30,dialog,,0,0,0,,Aku dapat izin dari Master!
Dialogue: 10,0:04:00.84,0:04:04.72,dialog,,0,0,0,,Jadi, kau ini sang Bijak\Nyang dirumorkan orang-orang, 'kan?
Dialogue: 10,0:04:06.48,0:04:10.27,dialog,,0,0,0,,Kalau yang Master cari itu Shaula,\Nberarti memang aku.
Dialogue: 10,0:04:10.27,0:04:11.98,dialog,,0,0,0,,Yang paling mencintai Master.
Dialogue: 10,0:04:11.98,0:04:14.73,dialog,,0,0,0,,Tapi, soal Shaula sang Bijak...
Dialogue: 10,0:04:14.73,0:04:16.61,dialog,,0,0,0,,Aku sendiri malah tidak tahu.
Dialogue: 10,0:04:16.61,0:04:19.45,dialog,,0,0,0,,Yang orang-orang anggap sebagai Shaula
Dialogue: 10,0:04:19.45,0:04:20.86,dialog,,0,0,0,,ya Shaula ini.
Dialogue: 10,0:04:23.58,0:04:25.37,dialog,,0,0,0,,Koin emas suci bergambar Naga Suci.
Dialogue: 10,0:04:25.58,0:04:27.37,dialog,,0,0,0,,Koin emas biasa bergambar Pedang Suci.
Dialogue: 10,0:04:27.37,0:04:28.79,dialog,,0,0,0,,Koin perak sang Bijak.
Dialogue: 10,0:04:29.04,0:04:31.83,dialog,,0,0,0,,Rasanya gadis itu sama sekali tak mirip.
Dialogue: 10,0:04:31.83,0:04:34.42,dialog,,0,0,0,,Wah, mirip banget, Master.
Dialogue: 10,0:04:34.75,0:04:36.30,dialog,,0,0,0,,Mirip denganku? Apanya?
Dialogue: 10,0:04:36.30,0:04:40.38,dialog,,0,0,0,,Menurutku orang ini dan Subaru\Nsama sekali tidak mirip, deh.
Dialogue: 10,0:04:40.38,0:04:44.85,dialog,,0,0,0,,Oh, aku menemukan Master\Nbukan dari penampilannya, kok.
Dialogue: 10,0:04:44.85,0:04:46.27,dialog,,0,0,0,,Jadi, tidak masalah.
Dialogue: 10,0:04:46.27,0:04:48.52,dialog,,0,0,0,,Belajar dari mana ucapan seperti itu?
Dialogue: 10,0:04:48.68,0:04:51.73,dialog,,0,0,0,,Kalau bukan dari penampilan,\Nbagaimana kau mengenaliku?
Dialogue: 10,0:04:51.73,0:04:52.81,dialog,,0,0,0,,Bau.
Dialogue: 10,0:04:52.98,0:04:57.40,dialog,,0,0,0,,Orang yang memancarkan bau hitam pekat\Ndan busuk menusuk hidung begini
Dialogue: 10,0:04:57.40,0:04:59.70,dialog,,0,0,0,,hanya Master seorang.
Dialogue: 10,0:04:59.70,0:05:02.41,dialog,,0,0,0,,Baru kali ini aku dihina sampai begitu!
Dialogue: 10,0:05:02.41,0:05:04.83,dialog,,0,0,0,,Tunggu, memangnya aku sebau itu?
Dialogue: 10,0:05:04.83,0:05:06.87,dialog,,0,0,0,,Te-Tenang saja, Subaru.
Dialogue: 10,0:05:06.87,0:05:08.66,dialog,,0,0,0,,Aku mengerti, kok.
Dialogue: 10,0:05:08.79,0:05:11.08,dialog,,0,0,0,,Nanti kita mandi sampai bersih, ya.
Dialogue: 10,0:05:11.08,0:05:12.83,dialog,,0,0,0,,Itu artinya kau tidak mengerti!
Dialogue: 10,0:05:14.08,0:05:16.38,dialog,,0,0,0,,Kau memang Shaula, tapi bukan sang Bijak.
Dialogue: 10,0:05:17.59,0:05:20.30,dialog,,0,0,0,,Apa kau tahu tentang\NPedang Suci atau Naga Suci?
Dialogue: 10,0:05:20.30,0:05:22.01,dialog,,0,0,0,,Idih.
Dialogue: 10,0:05:22.01,0:05:23.01,dialog,,0,0,0,,Jadi, kau tahu, ya?
Dialogue: 10,0:05:23.01,0:05:25.01,dialog,,0,0,0,,Tentu saja tahu.
Dialogue: 10,0:05:25.01,0:05:28.68,dialog,,0,0,0,,Reid si pengayun tongkat dan Volcanica\Nitu kenalan lamaku.
Dialogue: 10,0:05:28.85,0:05:30.77,dialog,,0,0,0,,Bukankah mereka baik-baik saja?
Dialogue: 10,0:05:30.93,0:05:32.23,dialog,,0,0,0,,Reid sudah meninggal.
Dialogue: 10,0:05:32.52,0:05:33.27,dialog,,0,0,0,,Sudah lama.
Dialogue: 10,0:05:33.27,0:05:34.52,dialog,,0,0,0,,Serius?
Dialogue: 10,0:05:34.52,0:05:37.78,dialog,,0,0,0,,Padahal dia itu susah mati\Nmeski dibunuh. Kok bisa?
Dialogue: 10,0:05:37.78,0:05:38.69,dialog,,0,0,0,,Karena usia.
Dialogue: 10,0:05:38.94,0:05:40.44,dialog,,0,0,0,,Oh, benar juga.
Dialogue: 10,0:05:40.44,0:05:42.86,dialog,,0,0,0,,Reid itu kan manusia, ya.
Dialogue: 10,0:05:42.86,0:05:44.20,dialog,,0,0,0,,Biar kutanya sekali lagi.
Dialogue: 10,0:05:44.49,0:05:46.74,dialog,,0,0,0,,Siapa Mastermu yang sebenarnya?
Dialogue: 10,0:05:47.49,0:05:49.29,dialog,,0,0,0,,Pertanyaan yang aneh.
Dialogue: 10,0:05:49.29,0:05:51.50,dialog,,0,0,0,,Kenapa kalian yang bersamanya\Nmalah tak tahu?
Dialogue: 10,0:05:51.87,0:05:52.92,dialog,,0,0,0,,Sayang sekali.
Dialogue: 10,0:05:53.12,0:05:57.04,dialog,,0,0,0,,Kepala Mastermu terbentur toilet\Nsampai kehilangan ingatan.
Dialogue: 10,0:05:57.04,0:05:59.34,dialog,,0,0,0,,Master terbentur lagi?
Dialogue: 10,0:05:59.34,0:06:00.30,dialog,,0,0,0,,"Lagi?"
Dialogue: 10,0:06:00.30,0:06:03.09,dialog,,0,0,0,,Kalau begitu,\Naku akan buat pengumuman besar.
Dialogue: 10,0:06:03.59,0:06:05.34,dialog,,0,0,0,,Nama Master adalah...
Dialogue: 10,0:06:05.34,0:06:08.06,dialog,,0,0,0,,Benar, dialah sang Maha Bijak!
Dialogue: 10,0:06:08.35,0:06:11.14,dialog,,0,0,0,,Di dunia ini,\Nyang pantas disebut sang Bijak...
Dialogue: 10,0:06:11.14,0:06:13.52,dialog,,0,0,0,,Tidak lain hanyalah Master seorang!
Dialogue: 10,0:06:13.52,0:06:15.27,dialog,,0,0,0,,Drrrr...!
Dialogue: 10,0:06:15.48,0:06:16.73,dialog,,0,0,0,,Tidak usah pakai intro.
Dialogue: 10,0:06:16.73,0:06:18.44,dialog,,0,0,0,,Jreng! Jreng! Jreng!
Dialogue: 10,0:06:19.07,0:06:20.11,dialog,,0,0,0,,Flugel!
Dialogue: 10,0:06:23.20,0:06:24.07,dialog,,0,0,0,,Hah?
Dialogue: 10,0:06:24.45,0:06:27.66,dialog,,0,0,0,,Nama Masterku adalah Flugel.
Dialogue: 10,0:06:28.20,0:06:30.62,dialog,,0,0,0,,Flugel sang Maha Bijak!
Dialogue: 10,0:06:37.46,0:06:38.29,dialog,,0,0,0,,Itu kan
Dialogue: 10,0:06:38.79,0:06:40.84,dialog,,0,0,0,,nama orang yang menanam Pohon Besar itu?
Dialogue: 10,0:06:44.84,0:06:46.09,dialog,,0,0,0,,Buset!
Dialogue: 10,0:06:46.09,0:06:48.10,dialog,,0,0,0,,Mengerikan! Tinggi sekali!
Dialogue: 10,0:06:48.47,0:06:51.06,dialog,,0,0,0,,Bikin merinding karena tak ada pegangan.
Dialogue: 10,0:06:51.06,0:06:51.97,dialog,,0,0,0,,Aduh.
Dialogue: 10,0:06:51.97,0:06:55.56,dialog,,0,0,0,,Kakak setengah telanjang,\Njangan banyak bergerak, dong.
Dialogue: 10,0:06:55.56,0:06:58.94,dialog,,0,0,0,,Si cebol ini menumpang tapi berlagak.
Dialogue: 10,0:07:00.19,0:07:02.03,dialog,,0,0,0,,Aduh! Jangan tarik rambutku!
Dialogue: 10,0:07:02.28,0:07:03.69,dialog,,0,0,0,,Hei, hei, Meili.
Dialogue: 10,0:07:03.69,0:07:05.20,dialog,,0,0,0,,Jangan buat keributan.
Dialogue: 10,0:07:05.20,0:07:06.91,dialog,,0,0,0,,Jangan mainkan ponytail-nya.
Dialogue: 10,0:07:06.91,0:07:09.91,dialog,,0,0,0,,Bukan ponytail, ini scorpiontail.
Dialogue: 10,0:07:11.79,0:07:13.58,dialog,,0,0,0,,Scorpiontail.
Dialogue: 10,0:07:13.95,0:07:15.41,dialog,,0,0,0,,Ya, aku mengerti.
Dialogue: 10,0:07:15.83,0:07:17.42,dialog,,0,0,0,,Ngotot sekali, deh.
Dialogue: 10,0:07:19.84,0:07:23.51,dialog,,0,0,0,,Inilah pintu masuk resmi menara, kurasa.
Dialogue: 10,0:07:23.51,0:07:26.68,dialog,,0,0,0,,Rem dan Patrasche ada\Nsatu tingkat di atas lagi.
Dialogue: 10,0:07:26.68,0:07:27.76,dialog,,0,0,0,,Masih naik lagi?
Dialogue: 10,0:07:27.93,0:07:30.22,dialog,,0,0,0,,Tunggu, kalau ini pintu masuk menaranya,
Dialogue: 10,0:07:30.22,0:07:32.72,dialog,,0,0,0,,bagaimana kalian membawa\Nkereta naga dan Patrasche?
Dialogue: 10,0:07:32.97,0:07:35.23,dialog,,0,0,0,,Shaula yang membawa semuanya.
Dialogue: 10,0:07:35.60,0:07:37.23,dialog,,0,0,0,,Dia mengangkatnya begitu saja.
Dialogue: 10,0:07:38.06,0:07:38.94,dialog,,0,0,0,,Apa?
Dialogue: 10,0:07:38.94,0:07:40.19,dialog,,0,0,0,,Ya...
Dialogue: 10,0:07:40.65,0:07:43.03,dialog,,0,0,0,,Hal seperti itu mudah bagiku.
Dialogue: 10,0:07:43.19,0:07:46.20,dialog,,0,0,0,,Saking terkejutnya,\Naku jadi bingung mau berterima kasih.
Dialogue: 10,0:07:46.20,0:07:48.49,dialog,,0,0,0,,Mau berterima kasih atau terkejut,
Dialogue: 10,0:07:48.49,0:07:51.20,dialog,,0,0,0,,terimalah perasaan tulusku ini...
Dialogue: 10,0:07:51.20,0:07:52.74,dialog,,0,0,0,,For you!
Dialogue: 10,0:07:52.74,0:07:53.62,dialog,,0,0,0,,- Muah, muah, muah!\N- Cuih.
Dialogue: 10,0:07:53.62,0:07:55.16,dialog,,0,0,0,,Malah dibuang!
Dialogue: 10,0:07:58.87,0:08:01.92,dialog,,0,0,0,,Flugel yang membuat ini juga, 'kan?
Dialogue: 10,0:08:02.21,0:08:05.09,dialog,,0,0,0,,Dipikir-pikir, aku pernah dengar\Ndia disebut sang Bijak.
Dialogue: 10,0:08:05.38,0:08:08.01,dialog,,0,0,0,,Tak disangka akan bertemu lagi di sini.
Dialogue: 10,0:08:08.01,0:08:12.30,dialog,,0,0,0,,Dia ini sang Bijak yang jasanya\Ncuma menanam pohon, 'kan?
Dialogue: 10,0:08:12.30,0:08:14.31,dialog,,0,0,0,,Omong-omong, ini besar sekali.
Dialogue: 10,0:08:14.31,0:08:16.31,dialog,,0,0,0,,Akhirnya aku bisa merasakannya.
Dialogue: 10,0:08:16.31,0:08:17.77,dialog,,0,0,0,,Merasakan apa?
Dialogue: 10,0:08:17.77,0:08:21.52,dialog,,0,0,0,,Merasakan ini benar-benar\NMenara Pengawas Pleiades tujuan kita.
Dialogue: 10,0:08:23.27,0:08:24.57,dialog,,0,0,0,,Kalau pemahamanmu seperti itu,
Dialogue: 10,0:08:24.57,0:08:27.53,dialog,,0,0,0,,nilaimu cuma 99 dari 100.
Dialogue: 10,0:08:27.53,0:08:29.03,dialog,,0,0,0,,Itu sudah hampir seratus.
Dialogue: 10,0:08:29.03,0:08:32.49,dialog,,0,0,0,,Itu dinilai berdasarkan\Nseberapa besar cintaku pada Master,
Dialogue: 10,0:08:32.49,0:08:35.74,dialog,,0,0,0,,ditambah bonus berkali-kali lipat.
Dialogue: 10,0:08:36.33,0:08:40.71,dialog,,0,0,0,,Menara Pengawas Pleiades hanyalah\Nnama dan peran sementara.
Dialogue: 10,0:08:40.96,0:08:43.38,dialog,,0,0,0,,Karena Master sudah kembali,
Dialogue: 10,0:08:43.38,0:08:45.80,dialog,,0,0,0,,tempat ini akan kembali ke peran aslinya.
Dialogue: 10,0:08:45.80,0:08:47.38,dialog,,0,0,0,,Peran aslinya?
Dialogue: 10,0:08:47.38,0:08:48.22,dialog,,0,0,0,,Benar!
Dialogue: 10,0:08:48.22,0:08:50.84,dialog,,0,0,0,,Apa pun yang ingin kau ketahui,
Dialogue: 10,0:08:50.84,0:08:53.68,dialog,,0,0,0,,semuanya ada di Perpustakaan Agung!
Dialogue: 10,0:08:55.14,0:08:57.18,dialog,,0,0,0,,Perpustakaan Agung Pleiades
Dialogue: 10,0:08:57.18,0:09:01.48,dialog,,0,0,0,,menyambut meriah\Nkeda-da-da-da-datangan Master!
Dialogue: 10,0:09:04.06,0:09:06.32,dialog,,0,0,0,,Di dalam sini, Rem dan Patrasche...
Dialogue: 10,0:09:08.65,0:09:10.36,dialog,,0,0,0,,Hei, Ram! Sulurnya bergerak!
Dialogue: 10,0:09:10.53,0:09:11.57,dialog,,0,0,0,,Kau terlalu ketakutan.
Dialogue: 10,0:09:11.91,0:09:13.41,dialog,,0,0,0,,Pemilik tempat ini bisa terkejut nanti.
Dialogue: 10,0:09:13.82,0:09:16.29,dialog,,0,0,0,,Pemilik tempat ini... maksudnya?
Dialogue: 10,0:09:17.04,0:09:18.04,dialog,,0,0,0,,Roh.
Dialogue: 10,0:09:26.92,0:09:29.34,dialog,,0,0,0,,Nuansa hutannya terasa sekali, ya.
Dialogue: 10,0:09:40.73,0:09:41.60,dialog,,0,0,0,,Rem.
Dialogue: 10,0:09:42.19,0:09:43.27,dialog,,0,0,0,,Patrasche juga.
Dialogue: 10,0:09:43.94,0:09:45.94,dialog,,0,0,0,,Saat berkumpul dengan Nona Emilia,
Dialogue: 10,0:09:46.19,0:09:48.32,dialog,,0,0,0,,katanya Patrasche terluka parah.
Dialogue: 10,0:09:48.90,0:09:51.32,dialog,,0,0,0,,Sekarang dia disembuhkan oleh kekuatan roh.
Dialogue: 10,0:09:52.86,0:09:55.62,dialog,,0,0,0,,Katanya, roh di sini tak berkehendak.
Dialogue: 10,0:09:56.24,0:10:00.58,dialog,,0,0,0,,Mereka hanya menyembuhkan luka\Natau penyakit makhluk yang masuk ke sini.
Dialogue: 10,0:10:00.58,0:10:02.16,dialog,,0,0,0,,Berarti Rem juga...
Dialogue: 10,0:10:03.17,0:10:04.88,dialog,,0,0,0,,Itu tidak berpengaruh pada Rem.
Dialogue: 10,0:10:05.38,0:10:07.71,dialog,,0,0,0,,Sesuatu selain luka atau penyakit\Ntidak bisa disembuhkan.
Dialogue: 10,0:10:07.96,0:10:09.80,dialog,,0,0,0,,Sepertinya para roh menilainya begitu.
Dialogue: 10,0:10:11.21,0:10:14.47,dialog,,0,0,0,,Pada akhirnya, kalau begini terus\Ntidak ada yang berubah, ya.
Dialogue: 10,0:10:14.97,0:10:18.76,dialog,,0,0,0,,Kalau ingin mengubahnya, kita harus\Ntuntaskan tujuan datang ke menara ini.
Dialogue: 10,0:10:19.35,0:10:22.48,dialog,,0,0,0,,Perpustakaan Agung Pleiades, ya.
Dialogue: 10,0:10:24.98,0:10:27.94,dialog,,0,0,0,,Aku akan mencari jawabannya\Nuntuk mengembalikan Rem!
Dialogue: 10,0:10:27.94,0:10:30.11,dialog,,0,0,0,,Tujuan itu takkan goyah!
Dialogue: 10,0:10:30.82,0:10:33.53,dialog,,0,0,0,,Baiklah! Aku akan kembali dengan yang lain.
Dialogue: 10,0:10:33.86,0:10:34.61,dialog,,0,0,0,,Kau sendiri?
Dialogue: 10,0:10:35.53,0:10:37.32,dialog,,0,0,0,,Kalau tak ada yang mengawasi Rem,
Dialogue: 10,0:10:37.62,0:10:39.33,dialog,,0,0,0,,kau pasti sangat cemas, 'kan?
Dialogue: 10,0:10:39.91,0:10:42.54,dialog,,0,0,0,,Kalau begitu, aku titipkan Rem padamu.
Dialogue: 10,0:10:42.91,0:10:45.25,dialog,,0,0,0,,Tapi yang kulakukan\Nhanya sebatas mengawasinya.
Dialogue: 10,0:10:46.83,0:10:49.84,dialog,,0,0,0,,Kehadiranmu sudah sangat berarti.
Dialogue: 10,0:11:01.01,0:11:03.81,dialog,,0,0,0,,Aku titip Rem dan Patrasche.
Dialogue: 10,0:11:07.73,0:11:10.77,dialog,,0,0,0,,Lantai ini seperti tempat tinggalku.
Dialogue: 10,0:11:10.77,0:11:13.65,dialog,,0,0,0,,Biasanya aku mengawasi gurun dari sini.
Dialogue: 10,0:11:13.65,0:11:17.57,dialog,,0,0,0,,Lalu, kalau ada yang mendekat,\Naku menembaki mereka.
Dialogue: 10,0:11:17.57,0:11:18.62,dialog,,0,0,0,,Sudah kuduga.
Dialogue: 10,0:11:19.20,0:11:20.78,dialog,,0,0,0,,Jadi itu ulahmu.
Dialogue: 10,0:11:20.78,0:11:23.62,dialog,,0,0,0,,Karena itu, kami mengalami\Nhal mengerikan, tahu.
Dialogue: 10,0:11:23.62,0:11:26.71,dialog,,0,0,0,,Tembakan jitu untuk menjauhkan\Npengganggu dari menara.
Dialogue: 10,0:11:26.92,0:11:28.42,dialog,,0,0,0,,Hell Snipe!
Dialogue: 10,0:11:29.58,0:11:31.42,dialog,,0,0,0,,Apa di dalam aman?
Dialogue: 10,0:11:31.42,0:11:32.80,dialog,,0,0,0,,Ya, aman.
Dialogue: 10,0:11:32.80,0:11:34.30,dialog,,0,0,0,,Ram sedang mengawasinya.
Dialogue: 10,0:11:36.88,0:11:40.72,dialog,,0,0,0,,Kalau dia tahu kau bukan Flugel,\Nentah apa yang akan dilakukannya.
Dialogue: 10,0:11:41.10,0:11:43.52,dialog,,0,0,0,,Mengoreksi atau memberitahunya\Nmalah berbahaya, ya.
Dialogue: 10,0:11:43.89,0:11:46.73,dialog,,0,0,0,,Rasanya melawan Regulus dan Petelgeuse\Njauh lebih mudah.
Dialogue: 10,0:11:46.73,0:11:49.35,dialog,,0,0,0,,Master, ada apa?
Dialogue: 10,0:11:49.35,0:11:50.81,dialog,,0,0,0,,Bukan apa-apa.
Dialogue: 10,0:11:51.31,0:11:53.94,dialog,,0,0,0,,Tapi aku ingin memastikan satu hal.
Dialogue: 10,0:11:54.23,0:11:57.15,dialog,,0,0,0,,Alasanmu menembaki orang\Nyang menuju menara itu...
Dialogue: 10,0:11:57.15,0:11:59.70,dialog,,0,0,0,,Tentu saja atas perintah Master!
Dialogue: 10,0:12:00.24,0:12:05.00,dialog,,0,0,0,,Selama 400 tahun, aku terus\Nmengawasi lautan pasir ini tiap hari.
Dialogue: 10,0:12:05.20,0:12:07.37,dialog,,0,0,0,,Melewati hari-hari kering dan menyedihkan,
Dialogue: 10,0:12:07.37,0:12:09.67,dialog,,0,0,0,,yang akan membuat\Nsiapa pun menangis mendengarnya.
Dialogue: 10,0:12:10.21,0:12:12.71,dialog,,0,0,0,,Sendirian selama 400 tahun?
Dialogue: 10,0:12:14.88,0:12:17.51,dialog,,0,0,0,,Kau akan mendengarkan perintahku, 'kan?
Dialogue: 10,0:12:17.51,0:12:20.51,dialog,,0,0,0,,A-Ada apa? Wajahmu serius sekali.
Dialogue: 10,0:12:20.51,0:12:22.60,dialog,,0,0,0,,Asal jangan yang mesum-mesum, ya.
Dialogue: 10,0:12:22.60,0:12:25.60,dialog,,0,0,0,,Jangan sakiti aku dan teman-temanku.
Dialogue: 10,0:12:27.77,0:12:31.98,dialog,,0,0,0,,Perintah Mastermu adalah menyerang\Nsiapa pun yang mendekati menara, 'kan?
Dialogue: 10,0:12:32.40,0:12:35.98,dialog,,0,0,0,,Berarti kami yang sudah di dalam\Ntidak perlu diserang lagi.
Dialogue: 10,0:12:36.49,0:12:38.99,dialog,,0,0,0,,Jangan sakiti kami.\NSama sekali.
Dialogue: 10,0:12:42.16,0:12:43.03,dialog,,0,0,0,,Oke!
Dialogue: 10,0:12:43.45,0:12:47.91,dialog,,0,0,0,,Sebagai perintah baru Master,\Naku akan mengingatnya dengan baik!
Dialogue: 10,0:12:47.91,0:12:49.87,dialog,,0,0,0,,Sip, janji, ya.
Dialogue: 10,0:12:50.12,0:12:51.42,dialog,,0,0,0,,Siap!
Dialogue: 10,0:12:51.79,0:12:53.04,dialog,,0,0,0,,Akan kutepati!
Dialogue: 10,0:12:53.04,0:12:54.92,dialog,,0,0,0,,Pasti akan kutepati!
Dialogue: 10,0:12:57.63,0:13:00.68,dialog,,0,0,0,,Sekali lagi, selamat datang, Master.
Dialogue: 10,0:13:00.97,0:13:02.80,dialog,,0,0,0,,Flugel sang Bijak,
Dialogue: 10,0:13:02.80,0:13:06.39,dialog,,0,0,0,,Aku, Shaula, menantikan kepulanganmu\Ndengan sepenuh hati.
Dialogue: 10,0:13:12.69,0:13:15.48,dialog,,0,0,0,,Setelah melewati lantai 6, 5, dan 4,
Dialogue: 10,0:13:15.77,0:13:19.95,dialog,,0,0,0,,mulai dari sini ke atas adalah\Narea ujian lantai 3, 2, dan 1.
Dialogue: 10,0:13:19.95,0:13:21.28,dialog,,0,0,0,,Area ujian?
Dialogue: 10,0:13:21.28,0:13:22.20,dialog,,0,0,0,,Benar.
Dialogue: 10,0:13:22.20,0:13:25.83,dialog,,0,0,0,,Pertama, ujian lantai 3 untuk\Nmendapat akses ke ruang arsip.
Dialogue: 10,0:13:26.28,0:13:29.66,dialog,,0,0,0,,Hak akses ke ruang arsip\NPerpustakaan Agung Pleiades.
Dialogue: 10,0:13:29.66,0:13:33.50,dialog,,0,0,0,,Itulah rintangan terbesar kami saat ini.
Dialogue: 10,0:13:33.50,0:13:34.96,dialog,,0,0,0,,Jadi begitu.
Dialogue: 10,0:13:34.96,0:13:38.92,dialog,,0,0,0,,Selama aku tertidur,\Nkalian mencoba ujian itu.
Dialogue: 10,0:13:46.26,0:13:47.72,dialog,,0,0,0,,Tempat ini...
Dialogue: 10,0:13:47.72,0:13:49.85,dialog,,0,0,0,,Ruangan yang membuatku\Ntak ingin berlama-lama.
Dialogue: 10,0:13:49.85,0:13:51.06,dialog,,0,0,0,,Setuju.
Dialogue: 10,0:13:51.35,0:13:54.27,dialog,,0,0,0,,Berada di sini terlalu lama\Nmembuat kepala pusing.
Dialogue: 10,0:14:03.20,0:14:05.20,dialog,,0,0,0,,Lempengan... batu?
Dialogue: 10,0:14:05.41,0:14:10.33,dialog,,0,0,0,,Itu adalah perangkat\Nyang memberikan teka-teki.
Dialogue: 10,0:14:10.33,0:14:12.33,dialog,,0,0,0,,Apakah dengan menyentuh lempengan itu
Dialogue: 10,0:14:12.33,0:14:14.37,dialog,,0,0,0,,ujiannya akan langsung dimulai?
Dialogue: 10,0:14:15.50,0:14:17.84,dialog,,0,0,0,,Jadi aku cukup menyentuh monolit ini?
Dialogue: 10,0:14:18.25,0:14:19.71,dialog,,0,0,0,,Monolit, ya?
Dialogue: 10,0:14:19.96,0:14:22.26,dialog,,0,0,0,,Sebutan aneh yang terasa pas.
Dialogue: 10,0:14:22.26,0:14:23.43,dialog,,0,0,0,,Sekarang aku akan menyebutnya begitu.
Dialogue: 10,0:14:23.88,0:14:24.89,dialog,,0,0,0,,Aku sentuh, ya.
Dialogue: 10,0:14:44.20,0:14:46.66,dialog,,0,0,0,,Pahlawan yang dibinasakan Shaula,
Dialogue: 10,0:14:47.32,0:14:50.08,dialog,,0,0,0,,sentuhlah ia yang bersinar terang.
Dialogue: 10,0:14:51.08,0:14:52.16,dialog,,0,0,0,,Bagaimana?
Dialogue: 10,0:14:53.29,0:14:55.25,dialog,,0,0,0,,Apakah kau sudah memahami
Dialogue: 10,0:14:56.17,0:14:57.75,dialog,,0,0,0,,keterkejutan yang kami rasakan?
Dialogue: 10,0:15:01.73,0:15:04.90,dialog,,0,0,0,,Yang terdengar tadi itu soal ujiannya?
Dialogue: 10,0:15:04.90,0:15:08.70,dialog,,0,0,0,,Subaru, ada beberapa hal yang perlu\Ndiperhatikan sebelum ujian dimulai.
Dialogue: 10,0:15:08.91,0:15:11.57,dialog,,0,0,0,,Pertama, sentuhlah lempengan batu...
Dialogue: 10,0:15:11.99,0:15:14.49,dialog,,0,0,0,,tidak, monolit di dekatmu.
Dialogue: 10,0:15:14.49,0:15:16.41,dialog,,0,0,0,,Kau suka sekali sebutan itu, ya?
Dialogue: 10,0:15:16.41,0:15:18.40,dialog,,0,0,0,,Ya, tak masalah, sih.
Dialogue: 10,0:15:25.13,0:15:27.11,dialog,,0,0,0,,Kembali ke kondisi awal.
Dialogue: 10,0:15:27.51,0:15:30.51,dialog,,0,0,0,,Artinya, kita gagal dalam ujian ini.
Dialogue: 10,0:15:31.22,0:15:32.01,dialog,,0,0,0,,Tentu saja...
Dialogue: 10,0:15:38.77,0:15:41.10,dialog,,0,0,0,,Pahlawan yang dibinasakan Shaula,
Dialogue: 10,0:15:41.60,0:15:44.36,dialog,,0,0,0,,sentuhlah ia yang bersinar terang.
Dialogue: 10,0:15:45.23,0:15:46.61,dialog,,0,0,0,,Jadi begitu.
Dialogue: 10,0:15:46.61,0:15:49.53,dialog,,0,0,0,,Kita bisa mencobanya berkali-kali\Nsampai berhasil.
Dialogue: 10,0:15:49.76,0:15:52.72,dialog,,0,0,0,,Begitulah asumsi kami sejauh ini.
Dialogue: 10,0:15:52.93,0:15:54.89,dialog,,0,0,0,,Omong-omong soal monolit ini,
Dialogue: 10,0:15:54.89,0:15:57.81,dialog,,0,0,0,,menyentuhnya secara acak\Ntak akan memberi jawaban.
Dialogue: 10,0:15:57.81,0:15:59.69,dialog,,0,0,0,,Setidaknya itu harus kusampaikan.
Dialogue: 10,0:15:59.69,0:16:02.44,dialog,,0,0,0,,Jadi kalian sudah coba menebak asal, ya.
Dialogue: 10,0:16:04.40,0:16:07.24,dialog,,0,0,0,,Sudah ketebak Emilia akan melakukannya.
Dialogue: 10,0:16:07.49,0:16:08.66,dialog,,0,0,0,,Akan tetapi,
Dialogue: 10,0:16:08.66,0:16:10.99,dialog,,0,0,0,,kalaupun kita tahu jawabannya,
Dialogue: 10,0:16:10.99,0:16:15.12,dialog,,0,0,0,,bagaimana menyentuh yang bersinar terang?
Dialogue: 10,0:16:15.87,0:16:17.12,dialog,,0,0,0,,Benar juga.
Dialogue: 10,0:16:17.37,0:16:20.67,dialog,,0,0,0,,Takkan ada kemajuan\Nkalau hanya dipikirkan, bukan?
Dialogue: 10,0:16:21.00,0:16:24.21,dialog,,0,0,0,,Sebaiknya kita langsung tanya\Nke kakak setengah telanjang ini.
Dialogue: 10,0:16:24.46,0:16:26.38,dialog,,0,0,0,,Ya, benar juga.
Dialogue: 10,0:16:26.55,0:16:30.39,dialog,,0,0,0,,Shaula, kau ingat pahlawan\Nyang kau binasakan?
Dialogue: 10,0:16:30.39,0:16:35.02,dialog,,0,0,0,,Mengingat satu per satu orang\Nyang dibunuh itu pekerjaan amatir.
Dialogue: 10,0:16:35.02,0:16:39.31,dialog,,0,0,0,,Profesional sepertiku takkan ingat lagi\Njika korbannya lebih dari 100.
Dialogue: 10,0:16:39.31,0:16:40.52,dialog,,0,0,0,,Sudah kuduga.
Dialogue: 10,0:16:40.77,0:16:44.02,dialog,,0,0,0,,Kalau begitu, mari coba dari\Nnama-nama yang kita kenal...
Dialogue: 10,0:16:44.02,0:16:45.28,dialog,,0,0,0,,Siapa, ya?
Dialogue: 10,0:16:46.03,0:16:46.99,dialog,,0,0,0,,Bagaimana dengan Reid?
Dialogue: 10,0:16:46.99,0:16:49.40,dialog,,0,0,0,,Bukankah kau yang membunuh\NPedang Suci pertama?
Dialogue: 10,0:16:51.70,0:16:52.37,dialog,,0,0,0,,Bahaya!
Dialogue: 10,0:16:54.37,0:16:57.16,dialog,,0,0,0,,Te-Terima kasih, Abang.
Dialogue: 10,0:16:57.16,0:17:00.83,dialog,,0,0,0,,Tidak, ini karena aku asal bicara.
Dialogue: 10,0:17:01.04,0:17:01.83,dialog,,0,0,0,,Kenapa?
Dialogue: 10,0:17:01.83,0:17:04.34,dialog,,0,0,0,,Pedang Suci pertama semenakutkan itu, ya?
Dialogue: 10,0:17:06.59,0:17:07.46,dialog,,0,0,0,,Ada-ada saja.
Dialogue: 10,0:17:07.92,0:17:11.30,dialog,,0,0,0,,Dia itu leluhur keluarga Astrea,\Nkeluarga Reinhard dan lainnya.
Dialogue: 10,0:17:11.30,0:17:14.89,dialog,,0,0,0,,Bukan cuma kemampuan pedangnya,\Nkepribadiannya pasti luar biasa.
Dialogue: 10,0:17:15.18,0:17:18.68,dialog,,0,0,0,,Nona Shaula, aku ingin dengar\Npendapat jujurmu.
Dialogue: 10,0:17:19.39,0:17:21.39,dialog,,0,0,0,,Sampah masyarakat.
Dialogue: 10,0:17:24.23,0:17:26.69,dialog,,0,0,0,,Aku ingin dengar pendapat jujurmu.
Dialogue: 10,0:17:26.69,0:17:28.11,dialog,,0,0,0,,Jangan pura-pura tidak dengar!
Dialogue: 10,0:17:28.40,0:17:31.20,dialog,,0,0,0,,Pokoknya, dia orang yang menyebalkan.
Dialogue: 10,0:17:31.20,0:17:34.66,dialog,,0,0,0,,Sifatnya seperti anak nakal\Nyang tumbuh dewasa.
Dialogue: 10,0:17:34.66,0:17:37.62,dialog,,0,0,0,,Dia suka sekali menindas yang lemah.
Dialogue: 10,0:17:37.87,0:17:42.54,dialog,,0,0,0,,Bahkan, bagi si sampah itu,\Nhampir semua lawannya itu lemah.
Dialogue: 10,0:17:42.54,0:17:45.71,dialog,,0,0,0,,Jadi, bertarung dengan siapa pun\Nsama saja menindas yang lemah.
Dialogue: 10,0:17:45.71,0:17:47.55,dialog,,0,0,0,,Aku juga kalah telak.
Dialogue: 10,0:17:47.55,0:17:50.88,dialog,,0,0,0,,Kalau dia bisa mengalahkanmu,\Ndia benar-benar monster.
Dialogue: 10,0:17:51.22,0:17:52.13,dialog,,0,0,0,,Tunggu sebentar.
Dialogue: 10,0:17:52.55,0:17:57.18,dialog,,0,0,0,,Penantang menara bisa saja masuk\Nsetelah mengalahkan Shaula,
Dialogue: 10,0:17:57.39,0:18:00.89,dialog,,0,0,0,,jadi teka-teki ini pasti bisa dijawab\Ntanpa bertanya padanya, 'kan?
Dialogue: 10,0:18:01.73,0:18:02.81,dialog,,0,0,0,,Subaru?
Dialogue: 10,0:18:02.81,0:18:05.02,dialog,,0,0,0,,Natsuki, kau memikirkan sesuatu?
Dialogue: 10,0:18:05.73,0:18:08.90,dialog,,0,0,0,,Kita bisa menaklukkan menara\Ntanpa melibatkan Shaula?
Dialogue: 10,0:18:09.23,0:18:11.69,dialog,,0,0,0,,Bagaimana kalau ada Shaula lain
Dialogue: 10,0:18:11.69,0:18:13.82,dialog,,0,0,0,,yang tidak diketahui olehnya?
Dialogue: 10,0:18:14.95,0:18:16.74,dialog,,0,0,0,,Ada apa, Master?
Dialogue: 10,0:18:16.95,0:18:20.12,dialog,,0,0,0,,Kalau ditatap terus begitu,\Naku jadi malu, tahu.
Dialogue: 10,0:18:28.55,0:18:29.25,dialog,,0,0,0,,Beako.
Dialogue: 10,0:18:31.34,0:18:32.59,dialog,,0,0,0,,Wajah itu...
Dialogue: 10,0:18:32.84,0:18:35.97,dialog,,0,0,0,,Wajah Subaru yang Beti sukai.
Dialogue: 10,0:18:36.18,0:18:38.05,dialog,,0,0,0,,Aku akan melompat agak tinggi.
Dialogue: 10,0:18:38.43,0:18:40.52,dialog,,0,0,0,,Aku ingin melihat monolit ini dari atas.
Dialogue: 10,0:18:43.89,0:18:44.73,dialog,,0,0,0,,Murak.
Dialogue: 10,0:18:50.44,0:18:52.03,dialog,,0,0,0,,Seperti dugaanku.
Dialogue: 10,0:18:52.03,0:18:53.74,dialog,,0,0,0,,Sudah dapat yang kau cari?
Dialogue: 10,0:18:53.74,0:18:54.49,dialog,,0,0,0,,Tentu saja.
Dialogue: 10,0:18:55.53,0:18:56.78,dialog,,0,0,0,,Tempat ini...
Dialogue: 10,0:18:57.28,0:18:59.99,dialog,,0,0,0,,Parahnya kebangetan.
Dialogue: 10,0:19:04.41,0:19:06.04,dialog,,0,0,0,,Aku sudah tahu
Dialogue: 10,0:19:06.54,0:19:07.60,dialog,,0,0,0,,nama pahlawannya.
Dialogue: 10,0:20:40.76,0:20:43.76,dialog,,0,0,0,,Natsuki, dari mana kau tahu jawabannya?
Dialogue: 10,0:20:43.76,0:20:45.97,dialog,,0,0,0,,Bukan hal yang hebat, kok.
Dialogue: 10,0:20:46.22,0:20:48.94,dialog,,0,0,0,,Tak bisa memecahkannya bukan salah kalian.
Dialogue: 10,0:20:49.14,0:20:52.23,dialog,,0,0,0,,Sejak awal, cuma segelintir orang\Nyang bisa memecahkannya.
Dialogue: 10,0:20:52.61,0:20:55.11,dialog,,0,0,0,,"Pahlawan yang dibinasakan Shaula."
Dialogue: 10,0:20:55.11,0:20:56.44,dialog,,0,0,0,,Namanya adalah
Dialogue: 10,0:20:56.73,0:20:57.82,dialog,,0,0,0,,Orion.
Dialogue: 10,0:20:58.40,0:20:59.70,dialog,,0,0,0,,Orion?
Dialogue: 10,0:21:01.36,0:21:04.08,dialog,,0,0,0,,Tunggu, tunggu!\NAku tidak kenal dia!
Dialogue: 10,0:21:04.24,0:21:06.16,dialog,,0,0,0,,Wajar kalau tak kenal.
Dialogue: 10,0:21:06.45,0:21:10.33,dialog,,0,0,0,,Lagi pula, "Shaula" yang dimaksud\Nbukan kau.
Dialogue: 10,0:21:10.33,0:21:12.79,dialog,,0,0,0,,Shaula itu cuma aku!
Dialogue: 10,0:21:12.79,0:21:14.75,dialog,,0,0,0,,Nama pemberian Masterku!
Dialogue: 10,0:21:14.75,0:21:19.67,dialog,,0,0,0,,Nama pemberian Mastermu itu\Nsebenarnya punya asal usul.
Dialogue: 10,0:21:19.67,0:21:22.05,dialog,,0,0,0,,Asal usul nama Shaula?
Dialogue: 10,0:21:22.39,0:21:25.18,dialog,,0,0,0,,Itu hal yang cuma Subaru tahu lagi?
Dialogue: 10,0:21:25.18,0:21:27.43,dialog,,0,0,0,,Bukan aku saja, sih.
Dialogue: 10,0:21:28.02,0:21:31.14,dialog,,0,0,0,,Di tempat asalku, ada nama bintang\Nyang disebut "Shaula".
Dialogue: 10,0:21:31.14,0:21:33.06,dialog,,0,0,0,,Artinya "jarum".
Dialogue: 10,0:21:33.06,0:21:36.15,dialog,,0,0,0,,Maksudnya jarum sengat kalajengking.
Dialogue: 10,0:21:36.44,0:21:37.82,dialog,,0,0,0,,Kalajengking?
Dialogue: 10,0:21:38.11,0:21:39.74,dialog,,0,0,0,,Menurut legenda,
Dialogue: 10,0:21:39.74,0:21:42.78,dialog,,0,0,0,,karena pahlawan Orion sangat sombong,
Dialogue: 10,0:21:42.78,0:21:45.91,dialog,,0,0,0,,seekor kalajengking dikirim\Nuntuk menyengatnya hingga mati,
Dialogue: 10,0:21:45.91,0:21:47.08,dialog,,0,0,0,,lalu ia jadi bintang.
Dialogue: 10,0:21:47.45,0:21:51.54,dialog,,0,0,0,,Kalajengking yang membunuh Orion\Njuga menjadi bintang.
Dialogue: 10,0:21:51.79,0:21:53.00,dialog,,0,0,0,,Sekarang pun di langit,
Dialogue: 10,0:21:53.00,0:21:56.29,dialog,,0,0,0,,Orion masih takut pada kalajengking.
Dialogue: 10,0:21:56.54,0:21:58.30,dialog,,0,0,0,,Kalau Subaru yang menjelaskan,
Dialogue: 10,0:21:58.30,0:22:00.97,dialog,,0,0,0,,kisah pahlawan jadi terasa hambar.
Dialogue: 10,0:22:00.97,0:22:02.13,dialog,,0,0,0,,Intinya,
Dialogue: 10,0:22:02.76,0:22:07.18,dialog,,0,0,0,,ada konsep rasi bintang yang wujudnya\Ndigambarkan sebagai manusia atau hewan.
Dialogue: 10,0:22:07.18,0:22:09.89,dialog,,0,0,0,,Bisa juga disebut sebagai Asterisma.
Dialogue: 10,0:22:10.48,0:22:11.10,dialog,,0,0,0,,Lalu,
Dialogue: 10,0:22:11.73,0:22:14.90,dialog,,0,0,0,,kalau kita lihat monolit itu dari atas...
Dialogue: 10,0:22:16.36,0:22:18.78,dialog,,0,0,0,,Bila dibayangkan sebagai rasi bintang,
Dialogue: 10,0:22:18.78,0:22:20.99,dialog,,0,0,0,,kita bisa melacak posisi Orion...
Dialogue: 10,0:22:21.36,0:22:22.57,dialog,,0,0,0,,Setelah itu?
Dialogue: 10,0:22:23.20,0:22:27.45,dialog,,0,0,0,,"Sentuhlah ia yang bersinar terang"\Nsebenarnya itu ungkapan jebakan.
Dialogue: 10,0:22:27.83,0:22:30.45,dialog,,0,0,0,,Cara bintang bersinar itu bermacam-macam.
Dialogue: 10,0:22:30.45,0:22:34.04,dialog,,0,0,0,,Ada yang selalu terang,\Nada yang hanya sesekali bersinar kuat.
Dialogue: 10,0:22:35.12,0:22:39.13,dialog,,0,0,0,,Dalam rasi Orion, ada dua bintang\Nyang paling terang.
Dialogue: 10,0:22:39.92,0:22:42.47,dialog,,0,0,0,,Yang selalu terang adalah Rigel,
Dialogue: 10,0:22:42.84,0:22:45.76,dialog,,0,0,0,,tapi Betelgeuse adalah bintang\Nyang terkadang bersinar kuat.
Dialogue: 10,0:22:48.10,0:22:50.43,dialog,,0,0,0,,Ada dua kemungkinan pilihan...
Dialogue: 10,0:22:50.43,0:22:53.10,dialog,,0,0,0,,Itu bukan jawaban yang elegan.
Dialogue: 10,0:22:55.35,0:22:56.48,dialog,,0,0,0,,Tapi kalau aku,
Dialogue: 10,0:22:56.98,0:22:58.94,dialog,,0,0,0,,mungkin akan memilih Rigel.
