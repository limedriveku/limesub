Dialogue: 0,0:15:17.37,0:15:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:15:17.91,0:15:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sampai di situ!
Dialogue: 0,0:15:22.19,0:15:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru!
Dialogue: 0,0:15:37.37,0:15:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, cukup.
Dialogue: 0,0:15:38.92,0:15:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup!
Dialogue: 0,0:15:43.59,0:15:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau berusaha menyelamatkanku?
Dialogue: 0,0:15:45.86,0:15:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru.
Dialogue: 0,0:15:46.68,0:15:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah gila!
Dialogue: 0,0:15:48.03,0:15:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau, Julius, dan Beatrice!
Dialogue: 0,0:15:51.51,0:15:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Echidna minta maaf padaku di akhir.
Dialogue: 0,0:15:55.02,0:15:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengerti!
Dialogue: 0,0:15:56.89,0:15:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya... Echidna?
Dialogue: 0,0:15:59.29,0:16:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, ada apa?\NDi mana Echidna dan yang lain?
Dialogue: 0,0:16:02.37,0:16:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati!
Dialogue: 0,0:16:03.23,0:16:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua kakinya putus.
Dialogue: 0,0:16:04.99,0:16:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit dan berdarah-darah.
Dialogue: 0,0:16:07.43,0:16:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beatrice juga mati!
Dialogue: 0,0:16:13.00,0:16:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius bahkan memohon agar aku pergi.
Dialogue: 0,0:16:16.74,0:16:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:16:19.29,0:16:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua bodoh.
Dialogue: 0,0:16:23.17,0:16:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya apa yang mereka harapkan?
Dialogue: 0,0:16:26.14,0:16:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta tolong, ingin pulih seperti semula,
Dialogue: 0,0:16:29.26,0:16:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai minta maaf karena sempat curiga.
Dialogue: 0,0:16:32.43,0:16:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang mereka bicarakan?
Dialogue: 0,0:16:39.48,0:16:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kali aku bertemu Subaru
Dialogue: 0,0:16:42.15,0:16:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah di gudang barang curian di ibu kota.
Dialogue: 0,0:16:45.11,0:16:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:16:47.11,0:16:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu,
Dialogue: 0,0:16:48.37,0:16:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lencana pentingku dicuri oleh Felt.
Dialogue: 0,0:16:52.70,0:16:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Pack panik harus merebutnya kembali.
Dialogue: 0,0:16:56.97,0:16:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu saat kami mengejarnya,
Dialogue: 0,0:16:59.89,0:17:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami diincar oleh kakak Meili,
Dialogue: 0,0:17:02.94,0:17:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Subaru datang menolongku.
Dialogue: 0,0:17:06.49,0:17:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:08.31,0:17:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah pertemuan pertamaku dengan Subaru.
Dialogue: 0,0:17:14.06,0:17:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingat?
Dialogue: 0,0:17:17.63,0:17:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi demi melindungiku,\NSubaru terluka parah.
Dialogue: 0,0:17:22.51,0:17:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kubawa dia ke kediaman Roswaal.
Dialogue: 0,0:17:26.31,0:17:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana Beatrice menyembuhkanmu\Nsambil menggerutu.
Dialogue: 0,0:17:31.34,0:17:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin Ram, bahkan Rem,
Dialogue: 0,0:17:34.71,0:17:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat akrab dengan Subaru.
Dialogue: 0,0:17:38.58,0:17:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kali itu bukan kakaknya lagi,
Dialogue: 0,0:17:41.74,0:17:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Meili yang menghasut binatang iblis.
Dialogue: 0,0:17:44.71,0:17:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru dan Ram menghentikannya,
Dialogue: 0,0:17:47.21,0:17:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roswaal menghabisi binatang iblis,
Dialogue: 0,0:17:49.49,0:17:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku tinggal di rumah.
Dialogue: 0,0:17:51.74,0:17:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu juga kita berjanji untuk berkencan.
Dialogue: 0,0:17:55.43,0:17:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingat?
Dialogue: 0,0:18:03.54,0:18:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, aku dipanggil ke ibu kota\Nuntuk pemilihan kandidat raja.
Dialogue: 0,0:18:07.94,0:18:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itulah aku dan Subaru\Nbertengkar pertama kali.
Dialogue: 0,0:18:13.11,0:18:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu aku tak ingin Subaru\Nmemaksakan diri sampai terluka.
Dialogue: 0,0:18:18.00,0:18:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut karena tak paham\Nkenapa kau sebaik itu.
Dialogue: 0,0:18:23.37,0:18:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:18:24.63,0:18:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kukira semua akan berakhir\Nsetelah kita bertengkar.
Dialogue: 0,0:18:31.06,0:18:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku tak tahu lagi harus bagaimana,
Dialogue: 0,0:18:33.80,0:18:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat terseret situasi\Nyang membingungkan dan menakutkan,
Dialogue: 0,0:18:37.51,0:18:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau datang menghampiriku.
Dialogue: 0,0:18:41.00,0:18:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:18:46.40,0:18:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:18:47.86,0:18:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingat apa yang dia katakan waktu itu?
Dialogue: 0,0:18:59.46,0:19:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku ingat semuanya.
Dialogue: 0,0:19:02.63,0:19:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau katakan, kau lakukan,
Dialogue: 0,0:19:06.17,0:19:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kau janjikan,
Dialogue: 0,0:19:09.03,0:19:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingat semuanya.
Dialogue: 0,0:19:12.54,0:19:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingat.
Dialogue: 0,0:19:14.17,0:19:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tak ingat!
Dialogue: 0,0:19:16.63,0:19:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:19:17.94,0:19:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...! Kalian semua...!
Dialogue: 0,0:19:20.03,0:19:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya sedang membicarakan siapa?
Dialogue: 0,0:19:22.49,0:19:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mempertaruhkan nyawa demi orang lain?
Dialogue: 0,0:19:24.56,0:19:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bergerak spontan demi orang lain?
Dialogue: 0,0:19:26.63,0:19:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berlari mati-matian demi orang lain?
Dialogue: 0,0:19:29.36,0:19:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bertaruh nyawa demi orang lain?
Dialogue: 0,0:19:32.94,0:19:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:19:34.74,0:19:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang begitu tak mungkin Natsuki Subaru!
Dialogue: 0,0:19:36.94,0:19:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu!
Dialogue: 0,0:19:38.87,0:19:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu betapa tak berguna\Ndan sampahnya Natsuki Subaru!
Dialogue: 0,0:19:42.00,0:19:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bajingan busuk yang tak becus apa-apa!
Dialogue: 0,0:19:45.03,0:19:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki Subaru itu bajingan busuk\Nyang tak becus!
Dialogue: 0,0:19:48.31,0:19:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paling tahu itu lebih dari siapa pun!
Dialogue: 0,0:19:55.91,0:19:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak harus aku juga, 'kan?
Dialogue: 0,0:20:00.31,0:20:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada yang lebih kuat dan pintar dariku.
Dialogue: 0,0:20:05.66,0:20:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... bagiku...
Dialogue: 0,0:20:08.23,0:20:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa, aku takkan bisa.
Dialogue: 0,0:20:15.34,0:20:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Emilia.
Dialogue: 0,0:20:17.61,0:20:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup Emilia.
Dialogue: 0,0:20:19.26,0:20:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:23.49,0:20:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak sekali hal
Dialogue: 0,0:20:25.58,0:20:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ingin kubicarakan\Ndan kutanyakan padamu.
Dialogue: 0,0:20:30.11,0:20:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untuk sekarang,\Nizinkan aku tanya satu hal.
Dialogue: 0,0:20:34.40,0:20:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri tahu siapa namamu.
Dialogue: 0,0:20:40.01,0:20:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:42.55,0:20:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa di sini harus Natsuki Subaru?
Dialogue: 0,0:20:45.17,0:20:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa dia lakukan?
Dialogue: 0,0:20:46.77,0:20:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian harapkan darinya?
Dialogue: 0,0:20:50.06,0:20:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada benarnya ucapanmu.
Dialogue: 0,0:20:52.74,0:20:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang lebih kuat dari Subaru.
Dialogue: 0,0:20:55.11,0:20:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti banyak juga yang lebih pintar.
Dialogue: 0,0:20:58.44,0:21:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagiku, dalam situasi apa pun,
Dialogue: 0,0:21:01.74,0:21:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin Subaru yang ada di sisiku.
Dialogue: 0,0:21:03.97,0:21:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya dan berharap Subaru pasti bisa.
Dialogue: 0,0:21:08.09,0:21:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena...
Dialogue: 0,0:21:10.40,0:21:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kalaupun aku ditolong,
Dialogue: 0,0:21:12.74,0:21:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan oleh orang yang kebetulan mampu\Natau ada di sana,
Dialogue: 0,0:21:18.34,0:21:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku lebih senang ditolong\Norang yang kucintai.
Dialogue: 0,0:21:28.40,0:21:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:21:31.63,0:21:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki Subaru.
Dialogue: 0,0:21:34.26,0:21:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau jatuh cinta\Npada gadis secantik ini?
Dialogue: 0,0:21:38.03,0:21:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini sumber kekuatanmu?
Dialogue: 0,0:21:43.86,0:21:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu diri juga ada batasnya, tahu.
Dialogue: 0,0:21:46.91,0:21:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau bisa berharap setinggi ini?
Dialogue: 0,0:21:50.04,0:21:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana pantas orang sepertimu\Nbersanding dengannya.
Dialogue: 0,0:21:53.74,0:21:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Emilia.
Dialogue: 0,0:21:56.00,0:21:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup Emilia.
Dialogue: 0,0:22:03.38,0:22:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong
Dialogue: 0,0:22:05.30,0:22:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beri tahu siapa namamu.
Dialogue: 0,0:22:27.09,0:22:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Natsuki Subaru.
Dialogue: 0,0:22:31.06,0:22:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dipercaya Julius.
Dialogue: 0,0:22:33.37,0:22:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang diyakini Beatrice.
Dialogue: 0,0:22:35.37,0:22:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dimaafkan Echidna.
Dialogue: 0,0:22:37.71,0:22:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Emilia, yang kau harapkan.
Dialogue: 0,0:22:40.59,0:22:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika nama pria itu Natsuki Subaru,
Dialogue: 0,0:22:43.80,0:22:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka akulah Natsuki Subaru.
Dialogue: 0,0:22:46.74,0:22:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menolong mereka.
Dialogue: 0,0:22:48.89,0:22:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kuselamatkan dari menara ini.
Dialogue: 0,0:22:50.81,0:22:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Natsuki Subaru bisa melakukannya,
Dialogue: 0,0:22:53.09,0:22:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka aku akan melakukannya.
Dialogue: 0,0:22:55.66,0:22:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Emilia,\Nsudah membuatku berpikir begitu.
Dialogue: 0,0:23:01.51,0:23:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru.
Dialogue: 0,0:23:03.49,0:23:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:23:11.34,0:23:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia!
Dialogue: 0,0:23:14.91,0:23:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia!
Dialogue: 0,0:23:29.68,0:23:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru!
Dialogue: 0,0:23:36.48,0:23:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kami akan ditelan\Ndan berakhir begitu saja?
Dialogue: 0,0:23:40.54,0:23:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini bukan akhir!
Dialogue: 0,0:23:43.31,0:23:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru inilah...
Dialogue: 0,0:23:44.66,0:23:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari sinilah semuanya bermula!
Dialogue: 0,0:23:48.91,0:23:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat.
Dialogue: 0,0:23:51.26,0:23:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat semuanya!
Dialogue: 0,0:23:55.49,0:23:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau lupa,
Dialogue: 0,0:23:58.91,0:24:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku takkan melupakan kalian!
Dialogue: 0,0:24:05.17,0:24:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru.
Dialogue: 0,0:24:06.13,0:24:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Subaru, kau tak apa-apa?
Dialogue: 0,0:24:14.77,0:24:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:24:16.34,0:24:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami benar-benar khawatir.
Dialogue: 0,0:24:18.10,0:24:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emilia, marahi dia lebih keras\Natau dia takkan jera.
Dialogue: 0,0:24:26.74,0:24:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali.
