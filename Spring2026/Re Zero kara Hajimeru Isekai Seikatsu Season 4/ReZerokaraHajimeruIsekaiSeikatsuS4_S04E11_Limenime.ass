Dialogue: 0,0:13:32.79,0:13:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:13:34.09,0:13:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:13:35.50,0:13:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:13:36.83,0:13:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Aku sudah muak!
Dialogue: 0,0:13:39.17,0:13:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mencintai diriku sendiri!
Dialogue: 0,0:13:41.34,0:13:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:13:43.26,0:13:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mencintai diriku sendiri.
Dialogue: 0,0:13:46.34,0:13:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu aku dicintai.
Dialogue: 0,0:13:49.26,0:13:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu!
Dialogue: 0,0:13:51.86,0:13:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan ibu menyayangiku sepenuh hati.
Dialogue: 0,0:13:57.09,0:13:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu!
Dialogue: 0,0:13:58.29,0:14:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku tak tahu!
Dialogue: 0,0:14:01.91,0:14:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu... aku ingin lenyap saja.
Dialogue: 0,0:14:05.97,0:14:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski disayangi orang tuaku,
Dialogue: 0,0:14:08.31,0:14:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak bisa menyayangi\Ndiriku yang tak layak ini!
Dialogue: 0,0:14:12.50,0:14:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:14:13.96,0:14:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mencintaimu.\N- Hentikan!
Dialogue: 0,0:14:15.42,0:14:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mencintaimu.\N- Tolong, hentikan! Sudah cukup, 'kan?!
Dialogue: 0,0:14:18.30,0:14:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:14:19.11,0:14:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mencintaimu.\N- Aku sudah lama tahu jawabannya!
Dialogue: 0,0:14:22.76,0:14:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melakukannya dengan sungguh-sungguh.
Dialogue: 0,0:14:25.91,0:14:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sebaik itu padaku\Ntak mungkin orang jahat!
Dialogue: 0,0:14:29.97,0:14:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu!
Dialogue: 0,0:14:33.52,0:14:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu
Dialogue: 0,0:14:35.11,0:14:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harusnya aku lenyap saja sejak dulu.
Dialogue: 0,0:14:38.48,0:14:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini hal terakhir yang bisa kulakukan,
Dialogue: 0,0:14:40.91,0:14:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar ini jadi akhirnya
Dialogue: 0,0:14:42.91,0:14:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sosok Natsuki Subaru lenyap selamanya.
Dialogue: 0,0:14:47.54,0:14:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:14:48.95,0:14:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
