Dialogue: 0,0:02:01.64,0:02:02.60,sign,,0000,0000,0000,,NATSUKI SUBARU TELAH TIBA
Dialogue: 0,0:02:04.02,0:02:04.90,sign,,0000,0000,0000,,NATSUKI SUBARU TELAH TIBA
Dialogue: 0,0:02:06.61,0:02:07.86,sign,,0000,0000,0000,,NATSUKI SUBARU TELAH TIBA
Dialogue: 0,0:24:02.10,0:24:05.11,sign,,0000,0000,0000,,MEMULAI KEHIDUPAN BARU DI DUNIA LAIN DARI NOL
Dialogue: 0,0:00:03.83,0:00:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akui saja kejahatanmu, produk gagal.
Dialogue: 0,0:00:08.51,0:00:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesimpulan barbar yang membosankan.
Dialogue: 0,0:00:13.54,0:00:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kira si lemah Ram ini\Nakan menantang pria gagal sendirian?
Dialogue: 0,0:00:18.87,0:00:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku berharap\Nini cuma kesalahpahaman Ram.
Dialogue: 0,0:00:26.09,0:00:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ada apa denganmu, Subaru?
Dialogue: 0,0:00:29.59,0:00:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau begini?
Dialogue: 0,0:00:31.69,0:00:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu...
Dialogue: 0,0:00:33.22,0:00:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia mau bicara\Nkalau sedikit disakiti.
Dialogue: 0,0:00:36.43,0:00:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:00:37.43,0:00:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru sedang tidak waras,\Nharusnya kita bicara dulu, 'kan?
Dialogue: 0,0:00:40.77,0:00:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Emilia terlalu naif.
Dialogue: 0,0:00:42.97,0:00:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Kota Gerbang Air ada Uskup Agung\Nyang bisa menyamar, 'kan?
Dialogue: 0,0:00:47.43,0:00:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau Uskup Agung\Nmenyamar jadi Barusu?
Dialogue: 0,0:00:51.66,0:00:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu...
Dialogue: 0,0:00:52.83,0:00:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat dia bicara.
Dialogue: 0,0:00:54.70,0:00:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar tahu di mana Barusu asli dan Meili.
Dialogue: 0,0:00:57.97,0:00:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ram, hentikan.\N- Bukan mereka
Dialogue: 0,0:00:59.66,0:01:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan buru-buru\N- yang memindahkan Meili?
Dialogue: 0,0:01:01.37,0:01:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- menuduhnya palsu.\N- Aku hilang ingatan!
Dialogue: 0,0:01:09.46,0:01:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong apa lagi sekarang?!
Dialogue: 0,0:01:11.97,0:01:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram!
Dialogue: 0,0:01:13.26,0:01:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru sudah bilang!
Dialogue: 0,0:01:14.74,0:01:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada alasannya!
Dialogue: 0,0:01:19.97,0:01:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rem...
Dialogue: 0,0:01:22.51,0:01:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu bagaimana dengan Rem?
Dialogue: 0,0:01:24.44,0:01:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur!
Dialogue: 0,0:01:29.94,0:01:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba katakan sekali lagi kalau kau lupa.
Dialogue: 0,0:01:31.99,0:01:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, bukan begitu.
Dialogue: 0,0:01:34.69,0:01:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau bilang lupa soal Rem lagi\Ndengan wajah itu...
Dialogue: 0,0:01:38.83,0:01:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Ram!
Dialogue: 0,0:01:40.69,0:01:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:01:52.97,0:01:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurungannya...
Dialogue: 0,0:01:56.43,0:01:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Emilia dan Ram?
Dialogue: 0,0:02:11.60,0:02:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:02:12.89,0:02:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?\NRuangan menjijikkan.
Dialogue: 0,0:02:16.41,0:02:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dekorasinya menjijikkan begini?
Dialogue: 0,0:02:21.49,0:02:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:02:24.00,0:02:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ReZERO -Starting Life in Another World-\NSeason 4
Dialogue: 0,0:02:31.86,0:02:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tampangmu begitu?
Dialogue: 0,0:02:34.55,0:02:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ketakutan, ya?
Dialogue: 0,0:02:36.55,0:02:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menangis, hah?
Dialogue: 0,0:02:41.69,0:02:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habis bertengkar dengan kawanmu?
Dialogue: 0,0:02:44.06,0:02:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik.
Dialogue: 0,0:02:44.94,0:02:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu!
Dialogue: 0,0:02:46.26,0:02:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau tak bisa turun\Ndari lantai atas?
Dialogue: 0,0:02:50.80,0:02:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aturan itu sudah tak berlaku.
Dialogue: 0,0:02:53.66,0:02:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak berlaku? Kenapa?
Dialogue: 0,0:02:56.77,0:02:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:02:57.69,0:02:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:02:58.80,0:03:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan harap kau selalu dapat semua jawaban.
Dialogue: 0,0:03:02.24,0:03:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa keluar.
Dialogue: 0,0:03:03.66,0:03:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku mau pergi dari sini.
Dialogue: 0,0:03:05.46,0:03:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi? Dari menara ini?
Dialogue: 0,0:03:08.66,0:03:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku tuntaskan urusan\Nyang mengganjal.
Dialogue: 0,0:03:12.89,0:03:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mengganjal?
Dialogue: 0,0:03:14.66,0:03:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, lalu bagaimana ujiannya?
Dialogue: 0,0:03:22.37,0:03:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, datang juga.
Dialogue: 0,0:03:42.49,0:03:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak lihat yang lain.
Dialogue: 0,0:03:45.12,0:03:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, malah jadi lebih mudah begini.
Dialogue: 0,0:03:56.86,0:04:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan bagus untuk membunuhnya.
Dialogue: 0,0:04:00.93,0:04:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu aku bisa baca Buku Orang Mati.
Dialogue: 0,0:04:13.73,0:04:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di belakangmu, Julius!
Dialogue: 0,0:04:24.29,0:04:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihan hidup orang lemah memang sedikit.
Dialogue: 0,0:04:27.17,0:04:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka cuma jago cari-cari alasan.
Dialogue: 0,0:04:39.11,0:04:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau ada di sini?
Dialogue: 0,0:04:41.43,0:04:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kenapa? Apa? Bagaimana bisa?"
Dialogue: 0,0:04:44.05,0:04:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaannya sama saja.\NKalian akrab sekali, ya.
Dialogue: 0,0:04:50.27,0:04:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo! Ayo! Ayo! Ayo! Ayo!
Dialogue: 0,0:04:59.82,0:05:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita lanjutkan ujiannya.
Dialogue: 0,0:05:02.20,0:05:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba rebut sebelum aku bosan.
Dialogue: 0,0:05:09.43,0:05:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Echidna...
Dialogue: 0,0:05:10.91,0:05:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku titip Nona Anastasia padamu!
Dialogue: 0,0:05:19.97,0:05:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifatmu ini sungguh tak bisa diubah, ya.
Dialogue: 0,0:05:33.14,0:05:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke mana kau?
Dialogue: 0,0:05:38.44,0:05:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Abang menolongnya?
Dialogue: 0,0:05:43.54,0:05:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Abang sendiri mencekikku.
Dialogue: 0,0:05:47.09,0:05:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, dari tadi aku mencarimu!
Dialogue: 0,0:05:49.58,0:05:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya pergi ke sana.
Dialogue: 0,0:05:51.50,0:05:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau di luar kurungan?
Dialogue: 0,0:05:52.83,0:05:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beatrice, menjauhlah darinya.
Dialogue: 0,0:05:54.88,0:05:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kata Ram,\Ndia bukan orang yang kau kenal.
Dialogue: 0,0:05:58.21,0:05:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ram?
Dialogue: 0,0:05:59.11,0:06:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, aku tak membunuh Emilia dan Ram.
Dialogue: 0,0:06:02.76,0:06:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar!
Dialogue: 0,0:06:04.51,0:06:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beti pasti tahu kalau memegang tangannya.
Dialogue: 0,0:06:07.00,0:06:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, dia tak bisa dipercaya.
Dialogue: 0,0:06:09.83,0:06:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku ikuti insting Ana.
Dialogue: 0,0:06:12.73,0:06:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari awal,\Nharusnya tak kubawa siapa pun ke sini.
Dialogue: 0,0:06:17.89,0:06:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesalahanku.
Dialogue: 0,0:06:19.86,0:06:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa? Aku tak peduli.
Dialogue: 0,0:06:23.11,0:06:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menara ini sudah tak ada harapan.
Dialogue: 0,0:06:24.86,0:06:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kenapa, Subaru?
Dialogue: 0,0:06:26.49,0:06:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara bicaramu seperti bukan dirimu.
Dialogue: 0,0:06:28.99,0:06:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Seperti diriku" itu maksudnya apa?
Dialogue: 0,0:06:30.80,0:06:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok yang kalian\Nsebut "diriku" itu di mana?
Dialogue: 0,0:06:33.71,0:06:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau masih ngotot soal lupa ingatan itu?
Dialogue: 0,0:06:38.51,0:06:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bersama Ram yang lupa adiknya\Ndan Julius yang dilupakan dunia,
Dialogue: 0,0:06:43.17,0:06:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau masih berakting kejam begini?
Dialogue: 0,0:06:45.38,0:06:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akting?
Dialogue: 0,0:06:46.14,0:06:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akting, katamu?!
Dialogue: 0,0:06:47.89,0:06:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang yang kulakukan ini cuma akting?!
Dialogue: 0,0:06:51.31,0:06:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa memilih,\Npasti kupilih jadi orang yang lebih baik!
Dialogue: 0,0:06:55.14,0:06:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang sudi jadi "Natsuki Subaru"?!
Dialogue: 0,0:06:59.20,0:07:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi orang menjijikkan seperti ini!
Dialogue: 0,0:07:02.51,0:07:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu kalian ini siapa!
Dialogue: 0,0:07:04.86,0:07:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini siapa?!
Dialogue: 0,0:07:06.32,0:07:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kehilangan segalanya!
Dialogue: 0,0:07:09.14,0:07:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma lagi pulang dari minimarket.
Dialogue: 0,0:07:11.40,0:07:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kuingat cuma bicara dengan kasir!
Dialogue: 0,0:07:14.91,0:07:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tahu-tahu di dunia lain?
Dialogue: 0,0:07:17.00,0:07:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menara pasir? Mayat?
Dialogue: 0,0:07:18.71,0:07:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian? Palsu? Natsuki Subaru?
Dialogue: 0,0:07:22.46,0:07:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:07:24.21,0:07:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:07:28.97,0:07:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti heran\Nkenapa aku tiba-tiba kalut, 'kan?
Dialogue: 0,0:07:32.47,0:07:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sudah tak kuat lagi.
Dialogue: 0,0:07:35.23,0:07:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu dalam diriku yang meledak.
Dialogue: 0,0:07:37.66,0:07:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disuruh apa pun aku tak bisa!\NAku tak bisa apa-apa!
Dialogue: 0,0:07:40.98,0:07:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:07:44.11,0:07:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, maafkan aku.
Dialogue: 0,0:07:48.34,0:07:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong maafkan aku.
Dialogue: 0,0:07:50.51,0:07:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku pulang ke rumah.
Dialogue: 0,0:07:54.89,0:07:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini hukuman dari Tuhan untukku,
Dialogue: 0,0:07:58.17,0:07:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengerti.
Dialogue: 0,0:08:00.29,0:08:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengaku bersalah.
Dialogue: 0,0:08:05.00,0:08:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru.
Dialogue: 0,0:08:07.22,0:08:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beatrice, sebaiknya kau tetap bersamanya.
Dialogue: 0,0:08:10.31,0:08:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencari Julius.
Dialogue: 0,0:08:12.01,0:08:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:13.23,0:08:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:08:13.91,0:08:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subaru, sekarang...
Dialogue: 0,0:08:17.14,0:08:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:08:19.66,0:08:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengalah.
Dialogue: 0,0:08:21.71,0:08:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa kau begini?
Dialogue: 0,0:08:25.60,0:08:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius yang menyuruhku.
Dialogue: 0,0:08:27.65,0:08:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disuruh dia?
Dialogue: 0,0:08:36.53,0:08:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}EMT Tidak Sempurna!
Dialogue: 0,0:08:49.49,0:08:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki.
Dialogue: 0,0:08:51.01,0:08:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bikin aku bingung.
Dialogue: 0,0:08:53.93,0:08:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku tahu.
Dialogue: 0,0:08:55.85,0:08:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma refleks.
Dialogue: 0,0:09:00.11,0:09:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}El Jiwald!
Dialogue: 0,0:09:15.62,0:09:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau sebenarnya?
Dialogue: 0,0:09:19.17,0:09:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maumu? Kau di pihak siapa?
Dialogue: 0,0:09:22.54,0:09:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak tahu.
Dialogue: 0,0:09:26.17,0:09:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, aku...
Dialogue: 0,0:09:28.05,0:09:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hilang ingatan.
Dialogue: 0,0:09:30.89,0:09:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tak ingat kaulah\Nyang membawa Beti keluar?
Dialogue: 0,0:09:35.17,0:09:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:09:37.34,0:09:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:09:38.63,0:09:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:09:40.26,0:09:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Subaru lupa, Beti takkan lupa.
Dialogue: 0,0:09:44.77,0:09:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan selalu ingat.
Dialogue: 0,0:09:48.23,0:09:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pindah. Kita tak bisa terus di sini.
Dialogue: 0,0:09:51.31,0:09:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Echidna, kau...
Dialogue: 0,0:09:53.69,0:09:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih curiga padamu.
Dialogue: 0,0:09:55.74,0:09:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada situasi yang lebih penting.
Dialogue: 0,0:09:58.83,0:10:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beginilah cara berpikir pedagang.
Dialogue: 0,0:10:01.00,0:10:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku sudah melihatnya dari dekat.
Dialogue: 0,0:10:04.00,0:10:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:10:28.66,0:10:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, cukup.
Dialogue: 0,0:10:31.49,0:10:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggalkan saja aku.
Dialogue: 0,0:10:34.57,0:10:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:10:35.70,0:10:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Sial! Sial!
Dialogue: 0,0:10:38.14,0:10:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki.
Dialogue: 0,0:10:40.03,0:10:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah... cukup.
Dialogue: 0,0:10:42.87,0:10:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak cukup!
Dialogue: 0,0:10:44.46,0:10:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang cukup sama sekali!
Dialogue: 0,0:10:49.17,0:10:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada memikirkanku...
Dialogue: 0,0:10:51.69,0:10:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pikirkanlah Beatrice...
Dialogue: 0,0:11:01.35,0:11:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya...
Dialogue: 0,0:11:03.57,0:11:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang selalu begitu.
Dialogue: 0,0:11:08.80,0:11:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit.
Dialogue: 0,0:11:10.63,0:11:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sakit sekali.
Dialogue: 0,0:11:14.24,0:11:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh manusia memang sungguh terasa sakit.
Dialogue: 0,0:11:18.06,0:11:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:11:19.49,0:11:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:11:20.41,0:11:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, bukan itu maksudku.
Dialogue: 0,0:11:23.09,0:11:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:11:23.66,0:11:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa sakit ini
Dialogue: 0,0:11:25.31,0:11:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}satu-satunya caraku membalas Ana.
Dialogue: 0,0:11:29.08,0:11:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:11:31.37,0:11:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tubuhnya kukembalikan sekarang,
Dialogue: 0,0:11:34.00,0:11:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ana akan merasakan sakit ini
Dialogue: 0,0:11:36.63,0:11:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ketakutan akan kematian.
Dialogue: 0,0:11:40.89,0:11:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan coba akhiri penderitaanku.
Dialogue: 0,0:11:47.00,0:11:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku begini saja sudah cukup.
Dialogue: 0,0:11:50.19,0:11:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau dengar itu?
Dialogue: 0,0:11:53.15,0:11:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini kesempatan emas?
Dialogue: 0,0:12:01.83,0:12:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Abang.
Dialogue: 0,0:12:04.54,0:12:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini namanya meringankan penderitaan.
Dialogue: 0,0:12:36.40,0:12:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal semudah ini saja kau tak bisa,
Dialogue: 0,0:12:41.46,0:12:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki Subaru.
Dialogue: 0,0:12:45.26,0:12:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki.
Dialogue: 0,0:12:47.83,0:12:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk meringankan hidupku,
Dialogue: 0,0:12:51.31,0:12:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengangkat batu pun kau tak bisa.
Dialogue: 0,0:12:55.09,0:12:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah mencurigaimu.
Dialogue: 0,0:13:05.56,0:13:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tak mati saja?
Dialogue: 0,0:13:11.19,0:13:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:13:20.94,0:13:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:13:26.94,0:13:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:13:28.51,0:13:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:13:29.96,0:13:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
