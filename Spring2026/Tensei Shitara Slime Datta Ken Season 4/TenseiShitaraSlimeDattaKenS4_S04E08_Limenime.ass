Dialogue: 0,0:01:38.29,0:01:41.00,tanda-5,,0,0,0,,{\fs100\bord3\shad0\c&HCC920E&\pos(960,75)\3c&HFFFFFF&}(Tensura) Bereinkarnasi Malah Menjadi Slime
Dialogue: 0,0:01:44.59,0:01:47.60,dialog - atas,,0,0,0,,{\blur3}{\fad(00,40)}Grandmaster Yuuki Kagurazaka.
Dialogue: 0,0:01:48.21,0:01:52.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dia telah sepenuhnya berada\Ndi bawah kendali Maribel.
Dialogue: 0,0:01:52.66,0:01:57.56,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar kata Maribel,\Nmustahil bekerja sama dengan Raja Iblis.
Dialogue: 0,0:01:58.03,0:02:00.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadinya bagaimana?
Dialogue: 0,0:02:00.06,0:02:04.58,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pengaruh Rimuru di masyarakat\Numat manusia makin meningkat.
Dialogue: 0,0:02:05.18,0:02:07.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Johann, ada laporan mendesak.
Dialogue: 0,0:02:09.13,0:02:11.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada panggilan sihir.
Dialogue: 0,0:02:13.14,0:02:17.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mustahil, si rubah licik itu...
Dialogue: 0,0:02:17.16,0:02:20.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya Glenda tertangkap\Noleh Raja Iblis Rimuru.
Dialogue: 0,0:02:20.53,0:02:23.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bisa pastikan kondisinya dengan Keserakahan?
Dialogue: 0,0:02:23.97,0:02:26.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pantas aku tidak bisa membaca emosinya.
Dialogue: 0,0:02:26.37,0:02:27.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:28.16,0:02:32.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kemungkinan Glenda telah dibunuh\NRaja Iblis Rimuru.
Dialogue: 0,0:02:35.12,0:02:40.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yuuki, apa kamu ada rencana bertemu\NRaja Iblis Rimuru?
Dialogue: 0,0:02:40.26,0:02:42.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rimuru?
Dialogue: 0,0:02:42.45,0:02:44.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku pikir dulu.
Dialogue: 0,0:02:44.13,0:02:50.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kagali berencana menyelidiki reruntuhan kuno\Nbernama Amrita bersama Rimuru.
Dialogue: 0,0:02:51.02,0:02:54.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Amrita?\NAku pernah dengar.
Dialogue: 0,0:02:55.25,0:02:58.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Reruntuhan kuno\Nyang ada di bawah tanah Jistave.
Dialogue: 0,0:02:58.34,0:03:03.30,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Konon kota itu dibangun meniru Soma,\NKekaisaran Sihir Agung kuno itu.
Dialogue: 0,0:03:03.30,0:03:08.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kagali bilang, Reaktor Daya Kendali Sihir\Ntersedia di sana.
Dialogue: 0,0:03:08.67,0:03:11.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Reaktor Daya Kendali Sihir?
Dialogue: 0,0:03:11.28,0:03:14.80,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Fasilitas daya yang dahulu digunakan\Nuntuk mengelola Kota Soma.
Dialogue: 0,0:03:15.31,0:03:18.46,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebuah mahakarya\Ndari teknologi sihir dunia lama.
Dialogue: 0,0:03:18.46,0:03:22.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sampai meledak,\Narea di sekitarnya akan lenyap.
Dialogue: 0,0:03:26.58,0:03:31.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yuuki, kamu pernah bilang bisa mengalahkan\NRaja Iblis Rimuru kalau dia sendirian, kan?
Dialogue: 0,0:03:31.42,0:03:34.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu mau menggunakan rencana itu?
Dialogue: 0,0:03:34.74,0:03:36.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebaiknya jangan.
Dialogue: 0,0:03:36.62,0:03:39.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Katanya Raja Iblis Milim\Nakan ikut dalam penyelidikan ini.
Dialogue: 0,0:03:39.73,0:03:42.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada dua Raja Iblis?\NItu gegabah!
Dialogue: 0,0:03:43.12,0:03:46.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, kita tetap pakai rencana itu.
Dialogue: 0,0:03:46.70,0:03:49.46,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekalian hancurkan Raja Iblis Milim juga.
Dialogue: 0,0:03:49.46,0:03:53.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terlalu ceroboh!\NDari mana kita punya kekuatan untuk itu?
Dialogue: 0,0:03:56.88,0:04:00.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kita akan mengerahkan segalanya.
Dialogue: 0,0:04:03.54,0:04:06.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalian sudah paham situasi kita, kan?
Dialogue: 0,0:04:06.75,0:04:10.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang saatnya menggunakan itu.
Dialogue: 0,0:04:11.20,0:04:16.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yuuki, gunakan yang kamu dapat\Ndari sarang naga itu.
Dialogue: 0,0:04:16.11,0:04:20.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu bahaya, aku belum\Nbenar-benar bisa mengendalikannya!
Dialogue: 0,0:04:20.07,0:04:22.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:04:22.02,0:04:25.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, itu milik Raja Iblis Milim.
Dialogue: 0,0:04:25.26,0:04:27.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kita hanya mengembalikannya.
Dialogue: 0,0:04:27.07,0:04:30.46,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ini bisa jadi bencana besar\Nuntuk umat manusia!
Dialogue: 0,0:04:30.46,0:04:31.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terus?
Dialogue: 0,0:04:33.46,0:04:35.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh, benar juga.
Dialogue: 0,0:04:35.57,0:04:40.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya itu bisa mengalihkan\Nperhatian Raja Iblis Milim.
Dialogue: 0,0:04:40.88,0:04:44.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Strategi terbaik untuk memisah\Nkedua raja iblis itu.
Dialogue: 0,0:04:44.22,0:04:47.14,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baguslah kamu cepat paham.
Dialogue: 0,0:04:47.14,0:04:50.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selagi Raja Iblis Milim sibuk sendiri...
Dialogue: 0,0:04:51.10,0:04:54.15,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kita akan mengendalikan Rimuru.
Dialogue: 0,0:04:56.82,0:04:59.47,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi ada satu yang perlu dicemaskan.
Dialogue: 0,0:04:59.47,0:05:01.46,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Soal Naga Badai?
Dialogue: 0,0:05:01.46,0:05:06.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, kalau kita gagal mengendalikan Rimuru\Ndan jadi harus membunuhnya,
Dialogue: 0,0:05:07.38,0:05:10.05,dialog,,0,0,0,,{\blur3}{\fad(00,40)}naga jahat itu bisa saja
Dialogue: 0,0:05:10.05,0:05:11.96,dialog,,0,0,0,,{\blur3}{\fad(00,40)}akan memusnahkan umat manusia.
Dialogue: 0,0:05:15.49,0:05:18.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Soal itu, tenang saja.
Dialogue: 0,0:05:18.45,0:05:24.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu tidak perlu mencemaskan apa pun,\Nfokus kalahkan Raja Iblis Rimuru saja.
Dialogue: 0,0:05:27.28,0:05:30.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kamu bilang begitu,\Naku akan menurut.
Dialogue: 0,0:05:32.90,0:05:36.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa benar Yuuki sedang dikendalikan?
Dialogue: 0,0:05:36.86,0:05:38.36,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:39.18,0:05:42.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maribel pernah bilang\Ndi depan orangnya langsung.
Dialogue: 0,0:05:43.22,0:05:44.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Orang yang sudah dikendalikan
Dialogue: 0,0:05:44.93,0:05:48.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tidak akan sadar pada kenyataan itu,\Napa pun yang dikatakan padanya.
Dialogue: 0,0:05:48.66,0:05:52.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tampaknya Yuuki tidak mendapatkan\NSkill Unik saat menyeberangi dunia
Dialogue: 0,0:05:52.90,0:05:55.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}sehingga dia tidak bisa melindungi diri.
Dialogue: 0,0:05:55.62,0:05:59.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa berarti Yuuki tidak bersalah?
Dialogue: 0,0:05:59.67,0:06:03.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sudah boleh, kan, Raja Iblis?\NAku masih punya info lain!
Dialogue: 0,0:06:03.23,0:06:05.14,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rekrut aku sekarang juga!
Dialogue: 0,0:06:08.81,0:06:10.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku mohon!
Dialogue: 0,0:06:13.30,0:06:16.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang, mari kita makan dulu.
Dialogue: 0,0:06:19.47,0:06:20.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi ini...
Dialogue: 0,0:06:20.98,0:06:25.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, gedung parlemen baru Tempest!
Dialogue: 0,0:06:28.99,0:06:32.12,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bangunan yang sungguh megah.
Dialogue: 0,0:06:32.12,0:06:36.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tempest berkembang pesat\Nsetelah Festival Pendirian.
Dialogue: 0,0:06:36.37,0:06:38.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadinya terbawa suasana, deh.
Dialogue: 0,0:06:39.50,0:06:43.97,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Glenda akan direkrut di bawah\Nbadan intelijen khusus Souei.
Dialogue: 0,0:06:44.47,0:06:48.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebesar apa pun masalah yang dia buat,\Nselama di bawah Souei, aku bisa tenang.
Dialogue: 0,0:06:49.49,0:06:50.40,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:06:50.40,0:06:51.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:06:51.84,0:06:53.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu yang minta dibuatkan itu?
Dialogue: 0,0:06:54.88,0:06:56.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}I-Itu...
Dialogue: 0,0:06:56.73,0:07:01.40,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kami ingin menyebarkan kehebatan\NTuan Rimuru lebih luas lagi.
Dialogue: 0,0:07:01.40,0:07:02.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:07:19.84,0:07:22.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ramai sekali.
Dialogue: 0,0:07:22.93,0:07:24.47,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aromanya lezat.
Dialogue: 0,0:07:24.47,0:07:28.18,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sudah menentukan pesanan,\Nambil label kayu di sini
Dialogue: 0,0:07:28.18,0:07:31.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}lalu tukar dengan hidangan di loket.
Dialogue: 0,0:07:31.10,0:07:35.60,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kami punya tiga menu rekomendasi harian\Ndan menu spesial.
Dialogue: 0,0:07:35.60,0:07:37.58,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh, ada yang begitu?
Dialogue: 0,0:07:37.58,0:07:40.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Biasanya langsung disiapkan untukku.
Dialogue: 0,0:07:40.61,0:07:45.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena kami langsung menyiapkan\Nmenu spesial untuk Anda.
Dialogue: 0,0:07:45.28,0:07:47.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu yang paling populer.
Dialogue: 0,0:07:47.86,0:07:50.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak mengumpulkan poin jasa
Dialogue: 0,0:07:50.17,0:07:52.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}atau tidak antre lebih awal,\Ntidak akan kebagian.
Dialogue: 0,0:07:54.70,0:07:56.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mumpung lagi di sini,
Dialogue: 0,0:07:56.29,0:07:58.32,dialog,,0,0,0,,{\blur3}{\fad(00,40)}akan kuberi menu spesial untukmu.
Dialogue: 0,0:07:58.32,0:08:00.46,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Boleh, nih?
Dialogue: 0,0:08:00.46,0:08:02.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ini hadiah perkenalan.
Dialogue: 0,0:08:02.67,0:08:05.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Anggap aku yang mentraktir Glenda hari ini.
Dialogue: 0,0:08:05.44,0:08:06.47,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:06.47,0:08:08.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:08:08.64,0:08:11.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga mau menu spesial.
Dialogue: 0,0:08:11.01,0:08:13.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh, Hinata?
Dialogue: 0,0:08:15.14,0:08:17.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:08:22.10,0:08:25.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong,\Nidemu tentang poin itu boleh juga.
Dialogue: 0,0:08:25.61,0:08:30.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena persiapan sistem kami terlambat,\Nkami belum bisa membagikan gaji.
Dialogue: 0,0:08:30.82,0:08:33.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ah, di Ruberios pakai sistem yang sama.
Dialogue: 0,0:08:33.49,0:08:37.12,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Masa? Bukannya negara kalian\Nsudah ada sejak lama?
Dialogue: 0,0:08:37.12,0:08:39.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Negara kami mengutamakan kesetaraan.\N- Selamat makan.
Dialogue: 0,0:08:39.71,0:08:42.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Intinya sama dengan di sini,\Ndibayar pakai barang.
Dialogue: 0,0:08:42.61,0:08:44.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Berarti kamu juga?
Dialogue: 0,0:08:44.67,0:08:46.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:46.03,0:08:50.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi karena jabatanku, aku bisa mengelola\Nanggaran negara sampai batas tertentu.
Dialogue: 0,0:08:50.26,0:08:54.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Waktu Festival Pendirian\Nkamu hedon banget.
Dialogue: 0,0:08:54.41,0:08:55.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Korupsi?
Dialogue: 0,0:08:55.22,0:09:00.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bukan, itu uang pribadiku\Ndari upah membasmi monster.
Dialogue: 0,0:09:01.65,0:09:05.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maksudnya kamu punya uang,\Ntapi tetap minta traktir?
Dialogue: 0,0:09:05.90,0:09:08.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu ini suka mempermasalahkan hal sepele.
Dialogue: 0,0:09:08.03,0:09:10.05,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu namanya berhemat.
Dialogue: 0,0:09:12.05,0:09:13.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Gagal paham.
Dialogue: 0,0:09:14.99,0:09:18.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selama ini, aku berpikir uang itu nomor satu.
Dialogue: 0,0:09:18.75,0:09:21.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi hari ini, aku berubah pikiran.
Dialogue: 0,0:09:22.12,0:09:24.94,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mulai sekarang diganti dengan poin!
Dialogue: 0,0:09:25.50,0:09:28.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, semangat, ya.
Dialogue: 0,0:09:31.30,0:09:35.18,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sudah waktunya mendengar\Ninformasi lanjutan darimu.
Dialogue: 0,0:09:36.70,0:09:40.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, pertama soal Dewan.
Dialogue: 0,0:09:40.06,0:09:43.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada tokoh-tokoh berpengaruh yang disebut\NLima Tetua yang mengendalikannya.
Dialogue: 0,0:09:43.77,0:09:46.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ketuanya tentu saja Granville.
Dialogue: 0,0:09:46.66,0:09:51.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lalu yang merancang kekacauan\Nkali ini adalah Maribel.
Dialogue: 0,0:09:52.26,0:09:56.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi si dalang Gaban itu pun\Nhanya dimanfaatkan?
Dialogue: 0,0:09:56.53,0:10:01.04,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dia salah satu Lima Tetua,\NJohann juga sama.
Dialogue: 0,0:10:02.24,0:10:05.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Johann itu pria berpenampilan rapi\Nyang menegur Gaban, kan?
Dialogue: 0,0:10:05.98,0:10:10.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ya, keduanya tampak berbeda pendapat.
Dialogue: 0,0:10:10.66,0:10:14.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Membenturkan sesama anggota organisasi\Nadalah taktik Maribel.
Dialogue: 0,0:10:15.42,0:10:18.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau Gaban berhasil menundukkan\NRaja Iblis, itu bagus.
Dialogue: 0,0:10:18.85,0:10:22.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau gagal, Johann yang berseberangan\Ndengannya justru naik kredibilitasnya
Dialogue: 0,0:10:22.73,0:10:24.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}sehingga lebih mudah mendekatimu.
Dialogue: 0,0:10:25.68,0:10:29.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin bagi mereka\Nini pertarungan hidup-mati,
Dialogue: 0,0:10:29.25,0:10:34.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tapi bagi Maribel, pion mana pun yang tersisa,\Nsemuanya berjalan sesuai rencana.
Dialogue: 0,0:10:34.61,0:10:37.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dasar pengecut yang tidak berani\Nmenunjukkan dirinya!
Dialogue: 0,0:10:37.33,0:10:39.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi ingin kubakar habis semuanya.
Dialogue: 0,0:10:39.63,0:10:42.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku paham perasaanmu, tapi jangan.
Dialogue: 0,0:10:42.86,0:10:44.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Satu lagi.
Dialogue: 0,0:10:44.37,0:10:46.51,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Di balik keluarga Rozzo,
Dialogue: 0,0:10:46.51,0:10:49.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}ada organisasi bernama Blood Shadow\Nyang mengerjakan pekerjaan kotor.
Dialogue: 0,0:10:50.69,0:10:54.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mereka bergerak di mana-mana,\Njadi berhati-hatilah.
Dialogue: 0,0:10:56.53,0:10:59.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu semua yang aku tahu.
Dialogue: 0,0:10:59.39,0:11:01.36,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:11:01.36,0:11:04.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa mereka begitu memusuhiku, ya?
Dialogue: 0,0:11:04.66,0:11:07.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Padahal aku slime yang tidak berbahaya.
Dialogue: 0,0:11:07.27,0:11:08.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:08.69,0:11:11.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Eh? Eh?
Dialogue: 0,0:11:11.19,0:11:14.83,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Setelah kamu bertingkah mengajak ribut begitu,
Dialogue: 0,0:11:14.83,0:11:16.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tentu semuanya mewaspadaimu.
Dialogue: 0,0:11:16.50,0:11:17.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:17.41,0:11:19.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya juga mengira Anda mengajak ribut.
Dialogue: 0,0:11:19.74,0:11:20.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:20.43,0:11:23.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dewan akan menjadi langkah pertama\Nuntuk membangun zona ekonomi.
Dialogue: 0,0:11:23.28,0:11:24.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:24.37,0:11:26.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Intel saya juga bagian dari itu.
Dialogue: 0,0:11:26.70,0:11:27.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:27.67,0:11:30.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu melakukannya tanpa sadar?
Dialogue: 0,0:11:30.17,0:11:33.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bu-Bukan berarti aku sama sekali\Ntidak punya niat itu,
Dialogue: 0,0:11:33.87,0:11:36.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tapi kukira untuk sementara cukup\Ndengan negosiasi damai.
Dialogue: 0,0:11:37.38,0:11:40.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mana ada penguasa yang menyambut baik
Dialogue: 0,0:11:40.99,0:11:43.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}pendatang baru yang merusak pasar?
Dialogue: 0,0:11:44.80,0:11:46.48,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:11:47.27,0:11:49.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ka-Kalau begitu,
Dialogue: 0,0:11:49.23,0:11:52.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}mari kita berjuang sampai bisa menguasai\Nekonomi Negara-Negara Barat!
Dialogue: 0,0:11:52.98,0:11:53.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:11:54.40,0:11:56.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Di sana ramai banget.
Dialogue: 0,0:11:57.04,0:12:01.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Nah, gambaran besar musuh sudah terlihat\Nberkat informasi dari Glenda.
Dialogue: 0,0:12:01.41,0:12:05.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Souei, tolong selidiki\Nkeluarga Rozzo dan Lima Tetua.
Dialogue: 0,0:12:05.50,0:12:06.80,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:12:06.80,0:12:09.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kita perlu mewaspadai pergerakan Yuuki juga.
Dialogue: 0,0:12:09.42,0:12:13.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, ada kemungkinan\Ndia memasang jebakan melalui serikat.
Dialogue: 0,0:12:13.81,0:12:15.92,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebaiknya hindari mereka dulu.
Dialogue: 0,0:12:15.92,0:12:18.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh, terus penyelidikan reruntuhannya?
Dialogue: 0,0:12:18.93,0:12:19.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:19.87,0:12:21.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Anda lupa, ya?
Dialogue: 0,0:12:21.87,0:12:25.30,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Beliau sempat pamer ke saya soal\Npergi menyelidiki reruntuhan
Dialogue: 0,0:12:25.30,0:12:26.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}bersama Wakil Ketua Serikat.
Dialogue: 0,0:12:26.77,0:12:29.97,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ah, iya juga!
Dialogue: 0,0:12:29.97,0:12:32.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa tidak bisa dibatalkan sekarang?
Dialogue: 0,0:12:32.29,0:12:36.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Letak reruntuhan itu ada di Jistave.
Dialogue: 0,0:12:36.06,0:12:40.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena sudah jadi wilayah kekuasaan Milim,\Naku mengajaknya juga.
Dialogue: 0,0:12:40.53,0:12:44.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Menyelidiki reruntuhan?\NAku pasti akan ikut!
Dialogue: 0,0:12:44.98,0:12:47.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu rencana yang sebaiknya\Njangan dibatalkan!
Dialogue: 0,0:12:47.79,0:12:49.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, bukannya berbahaya?
Dialogue: 0,0:12:49.73,0:12:53.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Seperti masuk ke jebakan musuh\Ndengan sukarela.
Dialogue: 0,0:12:54.75,0:12:55.89,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saran.
Dialogue: 0,0:12:55.89,0:12:59.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sengaja membuat celah untuk memancing\Nmusuh keluar juga bisa jadi opsi.
Dialogue: 0,0:12:59.45,0:13:00.47,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:13:00.93,0:13:03.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kita akan memanfaatkan jebakan itu.
Dialogue: 0,0:13:03.73,0:13:05.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Biar aku pancing musuh keluar,
Dialogue: 0,0:13:05.87,0:13:08.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}lalu hadapi dengan persiapan penuh!
Dialogue: 0,0:13:08.23,0:13:10.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apakah akan baik-baik saja?
Dialogue: 0,0:13:10.39,0:13:14.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada Milim, dan Shion yang jadi pengawalnya.
Dialogue: 0,0:13:14.38,0:13:15.36,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:13:15.92,0:13:19.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}ada orang yang bertambah kuat\Nberkat pelatihan dari Milim.
Dialogue: 0,0:13:20.72,0:13:24.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu juga ikut, Gobta.
Dialogue: 0,0:13:24.45,0:13:28.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak mau!\NSiapa juga yang mau masuk jebakan musuh!
Dialogue: 0,0:13:28.50,0:13:31.30,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Serahkan saja pertahanan kota pada saya.
Dialogue: 0,0:13:31.30,0:13:33.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya akan memperkuat penghalang juga.
Dialogue: 0,0:13:33.23,0:13:35.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Serahkan pengawasan\Nnegara-negara tetangga pada saya.
Dialogue: 0,0:13:37.33,0:13:41.36,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata di Tempest itu cepat sekali\Nmembuat keputusan penting.
Dialogue: 0,0:13:41.36,0:13:44.18,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu akan terbiasa soal itu di sini.
Dialogue: 0,0:13:44.72,0:13:46.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu yang kuinginkan!
Dialogue: 0,0:13:47.85,0:13:50.18,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, aku akan pulang.
Dialogue: 0,0:13:50.18,0:13:52.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, salam untuk Luminus.
Dialogue: 0,0:13:55.23,0:13:57.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terkadang kamu suka lengah,
Dialogue: 0,0:13:57.81,0:14:00.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}jadi berhati-hatilah.
Dialogue: 0,0:14:00.22,0:14:01.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:14:01.70,0:14:03.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bukan urusanmu!
Dialogue: 0,0:14:03.91,0:14:06.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dasar, dia memang tsundere.
Dialogue: 0,0:14:06.75,0:14:08.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, bukan.
Dialogue: 0,0:14:10.04,0:14:12.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pokoknya, rencananya sudah ditentukan.
Dialogue: 0,0:14:12.85,0:14:15.48,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sisanya tinggal bersiap untuk itu.
Dialogue: 0,0:14:23.80,0:14:26.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:14:27.28,0:14:28.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Masuk saja.
Dialogue: 0,0:14:29.62,0:14:31.89,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Anda memanggil, Tuan Rimuru?
Dialogue: 0,0:14:31.89,0:14:33.60,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:33.60,0:14:35.48,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:14:35.48,0:14:38.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oleh-oleh yang kubeli dari Ingrassia\Ndi sela-sela rapat.
Dialogue: 0,0:14:39.87,0:14:43.32,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Senang rasanya!\NAkan saya jadikan barang berharga!
Dialogue: 0,0:14:43.32,0:14:46.21,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana kalau langsung dibuka saja?
Dialogue: 0,0:14:46.21,0:14:47.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:14:51.08,0:14:53.04,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Boleh langsung saya kenakan?
Dialogue: 0,0:14:53.04,0:14:54.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, boleh.
Dialogue: 0,0:15:02.48,0:15:05.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana, Tuan Rimuru?
Dialogue: 0,0:15:05.34,0:15:07.84,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wah, terlihat cocok.
Dialogue: 0,0:15:07.84,0:15:09.92,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:15:12.56,0:15:16.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Setelah itu, aku memperkenalkan\NGlenda pada semua orang.
Dialogue: 0,0:15:16.10,0:15:18.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dia akan berada di bawah\Npengawasan ketat,
Dialogue: 0,0:15:18.81,0:15:21.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}semoga dia bisa memenangkan\Nkepercayaan kami.
Dialogue: 0,0:15:21.98,0:15:23.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hari-hari menjelang penyelidikan reruntuhan
Dialogue: 0,0:15:23.90,0:15:27.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}diisi dengan memesan pembuatan\Nsenjata api pada Dord,
Dialogue: 0,0:15:27.07,0:15:29.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}berkali-kali merevisi rencana,
Dialogue: 0,0:15:29.37,0:15:32.12,dialog,,0,0,0,,{\blur3}{\fad(00,40)}hingga memesan pakaian ekspedisi baru,
Dialogue: 0,0:15:32.12,0:15:34.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dan semuanya berlalu begitu cepat.
Dialogue: 0,0:15:43.38,0:15:45.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Persiapan sudah sangat matang.
Dialogue: 0,0:15:45.88,0:15:46.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:15:46.82,0:15:49.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sudah kepalang ikut,\Nlebih baik dinikmati saja!
Dialogue: 0,0:15:49.64,0:15:51.08,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:15:51.08,0:15:55.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kemeja dan celana pendek memang tidak biasa,\Ntapi tidak apa-apa karena terlihat cocok!
Dialogue: 0,0:15:56.90,0:16:00.52,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maaf menunggu.\NWaktunya berangkat menyelidiki reruntuhan!
Dialogue: 0,0:16:00.52,0:16:04.51,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak boleh!\NGanti baju yang cocok sana!
Dialogue: 0,0:16:06.75,0:16:08.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik...
Dialogue: 0,0:16:11.28,0:16:13.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:16:13.33,0:16:17.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong, Gobta,\Nkamu bawa benda itu?
Dialogue: 0,0:16:18.08,0:16:19.83,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:16:23.09,0:16:25.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Keren banget, deh!
Dialogue: 0,0:16:25.34,0:16:28.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Entakannya juga terasa mantap banget, ya!
Dialogue: 0,0:16:28.90,0:16:31.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Senang rasanya hadiahnya berguna.
Dialogue: 0,0:16:31.17,0:16:34.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah menduga\Nkamu akan sepaham denganku.
Dialogue: 0,0:16:36.05,0:16:40.31,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku kaget waktu prototipenya sudah bisa\Nditunjukkan hanya dalam beberapa hari.
Dialogue: 0,0:16:40.31,0:16:45.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagi kami yang bisa menggunakan sihir kuat,\Nini tidak terlalu berguna.
Dialogue: 0,0:16:47.24,0:16:49.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi itu bukan intinya.
Dialogue: 0,0:16:49.99,0:16:53.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Namanya juga roman, kan?
Dialogue: 0,0:16:55.74,0:16:57.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya sudah ganti pakaian.
Dialogue: 0,0:16:57.66,0:17:00.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh, bukan pakaian ekspedisi?
Dialogue: 0,0:17:01.23,0:17:04.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Nona Shuna bilang\Ntidak sempat membuatnya sekarang.
Dialogue: 0,0:17:04.82,0:17:06.60,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya juga.
Dialogue: 0,0:17:13.08,0:17:16.09,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Setelah ini, aku akan bertemu\NRaja Iblis Rimuru.
Dialogue: 0,0:17:16.09,0:17:19.04,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rencananya langsung berangkat\Nbegitu pertemuan selesai.
Dialogue: 0,0:17:20.03,0:17:25.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa ikut, jadi sampaikan salamku\Nke semua anggota pasukan.
Dialogue: 0,0:17:25.47,0:17:27.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik, Bos.
Dialogue: 0,0:17:27.94,0:17:29.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kamu tidak apa-apa?
Dialogue: 0,0:17:30.70,0:17:34.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Raja Iblis Milim\Nseharusnya ikut dalam penyelidikan ini.
Dialogue: 0,0:17:34.03,0:17:36.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah dia yang menghancurkan\Nkampung halamanmu?
Dialogue: 0,0:17:38.45,0:17:40.04,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:17:40.04,0:17:43.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Trauma itu sudah kuatasi\Ndalam proses menjadi Raja Iblis.
Dialogue: 0,0:17:43.44,0:17:47.00,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mekanisme pertahanan Amrita\Nakan diaktifkan sesuai rencana.
Dialogue: 0,0:17:47.00,0:17:51.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau hanya menggerakkannya,\Ntidak akan dicurigai.
Dialogue: 0,0:17:51.07,0:17:54.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, aku mengandalkanmu.
Dialogue: 0,0:17:54.01,0:17:58.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ini juga kesempatan untuk menyelidiki\Nkemampuan Raja Iblis Rimuru.
Dialogue: 0,0:17:58.78,0:18:02.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Memperhitungkan sampai sejauh itu,\Nkamu memang luar biasa, Bos.
Dialogue: 0,0:18:02.69,0:18:05.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya ingin melakukan apa yang kubisa.
Dialogue: 0,0:18:06.15,0:18:09.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena ambisiku besar.
Dialogue: 0,0:18:11.15,0:18:13.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yuuki Kagurazaka.
Dialogue: 0,0:18:14.67,0:18:17.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa dia bisa dipercaya?
Dialogue: 0,0:18:18.38,0:18:21.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu khawatir, Kakek.
Dialogue: 0,0:18:22.05,0:18:26.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagi Yuuki yang ambisinya besar,\Nkendali Keserakahan atas dirinya sudah mutlak.
Dialogue: 0,0:18:30.16,0:18:33.68,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Raja Iblis Rimuru, ya?
Dialogue: 0,0:18:35.68,0:18:41.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Seiring hancurnya Tujuh Luminari\Ndan menguatnya kekuatan Orang Suci Hinata,
Dialogue: 0,0:18:41.44,0:18:44.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}sistem kekuasaan Raja Iblis Rimuru
Dialogue: 0,0:18:44.19,0:18:46.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}pasti akan makin kokoh.
Dialogue: 0,0:18:47.23,0:18:50.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu yang harus dicegah,
Dialogue: 0,0:18:50.67,0:18:51.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}bukan?
Dialogue: 0,0:18:51.71,0:18:53.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu bisa mengendalikannya?
Dialogue: 0,0:18:54.70,0:18:56.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Akan kucoba.
Dialogue: 0,0:18:56.88,0:18:59.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau gagal, tinggal dibunuh.
Dialogue: 0,0:19:01.63,0:19:07.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekalipun Naga Badai mengamuk,\NRaja Iblis Luminus tidak akan tinggal diam.
Dialogue: 0,0:19:08.18,0:19:11.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi Negara-Negara Barat\Nbisa terlindungi, ya?
Dialogue: 0,0:19:13.44,0:19:15.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lakukan sesukamu.
Dialogue: 0,0:19:18.55,0:19:21.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku pergi dulu, Kakek.
Dialogue: 0,0:19:22.59,0:19:25.48,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selamat jalan, Maribel.
Dialogue: 0,0:19:26.14,0:19:30.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Demi masa depan umat manusia.
Dialogue: 0,0:19:36.28,0:19:38.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kami sudah menunggu kalian.
Dialogue: 0,0:19:38.53,0:19:42.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lama tidak bertemu.\NMohon bantuannya mulai hari ini.
Dialogue: 0,0:19:42.72,0:19:45.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Perkenalkan, aku Milim!
Dialogue: 0,0:19:46.41,0:19:48.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Salam kenal!
Dialogue: 0,0:19:49.82,0:19:54.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Salam kenal juga, Nona Milim.
Dialogue: 0,0:19:54.17,0:19:57.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, mari kita ke pelataran.
Dialogue: 0,0:20:00.11,0:20:01.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:20:01.53,0:20:04.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya tidak ada masalah.
Dialogue: 0,0:20:04.43,0:20:08.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi rasanya...
Dialogue: 0,0:20:17.04,0:20:21.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Perkenalkan, mereka tim penyelidik\Nyang akan bersama kita hari ini.
Dialogue: 0,0:20:21.07,0:20:25.56,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mereka individu unggulan\Nyang pernah saya latih.
Dialogue: 0,0:20:25.56,0:20:27.54,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mohon kerja samanya.
Dialogue: 0,0:20:27.54,0:20:28.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:20:28.86,0:20:31.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mohon kerja samanya juga.
Dialogue: 0,0:20:32.58,0:20:35.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya bawa ke kereta di sana.
Dialogue: 0,0:20:36.21,0:20:38.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Berarti kita akan lewat rute ini?
Dialogue: 0,0:20:38.38,0:20:39.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:39.89,0:20:42.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru, barang bawaannya di mana?
Dialogue: 0,0:20:42.75,0:20:44.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Biar sekalian dibawa.
Dialogue: 0,0:20:44.39,0:20:48.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ah, kami tidak menyiapkan apa-apa.
Dialogue: 0,0:20:48.43,0:20:52.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Anda bercanda, kan?
Dialogue: 0,0:20:52.16,0:20:54.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan pakaiannya juga tipis begitu.
Dialogue: 0,0:20:54.44,0:20:56.83,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuh, maksudnya soal lengan pendekmu.
Dialogue: 0,0:20:56.83,0:20:58.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ma-Masa, sih?
Dialogue: 0,0:20:58.24,0:20:59.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mending lengan panjang sepertiku...
Dialogue: 0,0:20:59.86,0:21:01.20,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalian sama saja!
Dialogue: 0,0:21:01.20,0:21:05.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagi saya, kalian terlihat\Nmeremehkan ekspedisi!
Dialogue: 0,0:21:05.70,0:21:08.18,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:21:08.18,0:21:11.83,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Meski begini, aku punya banyak\Npengalaman bertualang.
Dialogue: 0,0:21:13.07,0:21:16.05,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah kalau Anda bilang begitu.
Dialogue: 0,0:21:16.05,0:21:19.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau perlu sesuatu,\Nlangsung bilang saja padaku.
Dialogue: 0,0:21:19.42,0:21:21.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Silakan naik ke kereta kuda.
Dialogue: 0,0:21:21.17,0:21:22.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu kereta kuda juga.
Dialogue: 0,0:21:22.72,0:21:23.76,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:24.61,0:21:26.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku bisa menghubungkan ke lokasi.
Dialogue: 0,0:21:43.97,0:21:46.20,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Silakan lewat.
Dialogue: 0,0:21:46.20,0:21:48.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Di balik sana ada Jistave.
Dialogue: 0,0:21:58.82,0:22:00.76,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:22:00.76,0:22:03.47,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Padahal jaraknya bisa dua bulan\Nnaik kereta kuda.
Dialogue: 0,0:22:08.22,0:22:11.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Raja Iblis itu terlalu hebat.
Dialogue: 0,0:22:19.53,0:22:22.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh, ada yang menyambut kita.
Dialogue: 0,0:22:24.56,0:22:29.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kami sudah menunggu kalian,\NTuan Rimuru, Nona Milim,
Dialogue: 0,0:22:29.11,0:22:31.08,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dan orang-orang dari serikat.
Dialogue: 0,0:22:31.66,0:22:34.14,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selamat datang di Jistave.
Dialogue: 0,0:24:06.05,0:24:08.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya, "Penyelidikan Reruntuhan".
