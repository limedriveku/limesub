Dialogue: 0,0:02:55.28,0:02:58.03,tanda-5,,0,0,0,,{\fs100\bord3\shad0\c&HCC920E&\pos(960,75)\3c&HFFFFFF&}(Tensura) Bereinkarnasi Malah Menjadi Slime
Dialogue: 0,0:00:15.04,0:00:19.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua akan mudah\Ndengan skill Penembak Jitu milikku.
Dialogue: 0,0:00:22.75,0:00:24.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Warp Shot!
Dialogue: 0,0:00:42.23,0:00:45.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mustahil, kenapa hawa keberadaan\NPangeran Elric masih ada?
Dialogue: 0,0:00:46.70,0:00:48.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Satu tembakan lagi...
Dialogue: 0,0:00:48.24,0:00:54.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, ini karena aku meremehkan\Nmajikan para iblis itu.
Dialogue: 0,0:00:54.11,0:00:55.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:59.12,0:01:01.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu meremehkan Tuan Rimuru.
Dialogue: 0,0:01:02.88,0:01:08.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Betapa bodohnya masih diam di tempat\Nsetelah gagal membunuh.
Dialogue: 0,0:01:08.88,0:01:10.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:01:10.53,0:01:14.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Souei, mata-mata setia Tuan Rimuru.
Dialogue: 0,0:01:14.89,0:01:17.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata memang Raja Iblis itu...
Dialogue: 0,0:01:18.86,0:01:22.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan membuatmu buka mulut.
Dialogue: 0,0:01:22.21,0:01:24.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mau melawan, silakan.
Dialogue: 0,0:01:24.15,0:01:27.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, kulawan dengan kemampuan penuh!
Dialogue: 0,0:02:58.03,0:03:01.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, kulawan dengan kemampuan penuh!
Dialogue: 0,0:03:03.44,0:03:04.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti yang kuduga,
Dialogue: 0,0:03:04.98,0:03:09.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}serangan fisik tidak akan mempan\Nterhadap Majin tingkat atas.
Dialogue: 0,0:03:09.79,0:03:11.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:12.00,0:03:15.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak boleh gagal lagi!
Dialogue: 0,0:03:16.51,0:03:18.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hebat juga.
Dialogue: 0,0:03:18.26,0:03:21.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa dia menyadari sihir pada pisau ini?
Dialogue: 0,0:03:25.39,0:03:29.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia bisa langsung mengenali\Nhal yang membahayakannya lalu menghindar.
Dialogue: 0,0:03:29.90,0:03:32.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tipe petarung hemat energi.
Dialogue: 0,0:03:32.65,0:03:34.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menghadapi musuh semacam ini...
Dialogue: 0,0:03:40.37,0:03:43.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, intuisimu boleh juga.
Dialogue: 0,0:03:43.12,0:03:45.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makasih.
Dialogue: 0,0:03:45.25,0:03:47.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu juga lumayan.
Dialogue: 0,0:03:47.92,0:03:49.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Percuma!
Dialogue: 0,0:03:49.04,0:03:50.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kena!
Dialogue: 0,0:04:01.52,0:04:03.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akhirnya cowok ganteng ini lengah juga.
Dialogue: 0,0:04:03.97,0:04:07.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mengimbuhkan sihir pada satu peluru.
Dialogue: 0,0:04:07.06,0:04:12.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini efektif melawan musuh\Nyang terlalu percaya diri.
Dialogue: 0,0:04:12.06,0:04:16.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata kamu bisa mengimbuhkan sihir\Npada peluru juga.
Dialogue: 0,0:04:16.57,0:04:19.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, kamu tahu peluru?
Dialogue: 0,0:04:19.74,0:04:23.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Peluru itu terbuat dari sihirku\Nyang dipadatkan.
Dialogue: 0,0:04:23.20,0:04:28.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lumayan efektif untuk melawanmu\Nyang tahan peluru biasa, kan?
Dialogue: 0,0:04:28.21,0:04:29.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:04:29.82,0:04:34.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong jelaskan hal itu\Ndi hadapan Tuan Rimuru nanti.
Dialogue: 0,0:04:34.21,0:04:37.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena beliau pribadi yang baik.
Dialogue: 0,0:04:37.09,0:04:39.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau menurut, kamu tidak akan dibunuh.
Dialogue: 0,0:04:39.97,0:04:43.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong kosong pecundang?\NTapi maaf saja...
Dialogue: 0,0:04:44.26,0:04:48.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku harus melenyapkanmu\Nkarena sudah kepalang melihat wajahku.
Dialogue: 0,0:04:48.68,0:04:50.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akhiri dengan ini.
Dialogue: 0,0:05:14.03,0:05:18.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak disangka harus mengeluarkan semua kartu as\Nuntuk melawan musuh sekuat ini.
Dialogue: 0,0:05:18.88,0:05:20.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:05:23.70,0:05:28.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akui saja kekalahanmu\Ndan biarkan aku menangkapmu.
Dialogue: 0,0:05:28.02,0:05:31.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mu-Mustahil!\NBarusan kamu sudah mati!
Dialogue: 0,0:05:31.23,0:05:33.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana mungkin aku mati semudah itu.
Dialogue: 0,0:05:33.47,0:05:36.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sengaja menerima serangan\Nuntuk melihat kemampuanmu.
Dialogue: 0,0:05:39.50,0:05:41.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan menggertak!
Dialogue: 0,0:05:42.74,0:05:44.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:44.37,0:05:48.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dua orang?\NBukan, empat orang?
Dialogue: 0,0:05:49.62,0:05:51.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang benar saja?
Dialogue: 0,0:05:51.21,0:05:54.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya tubuh asli?
Dialogue: 0,0:05:55.61,0:05:59.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mudah saja, aku punya skill tubuh bayangan.
Dialogue: 0,0:05:59.84,0:06:01.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski masih di bawah yang asli,
Dialogue: 0,0:06:01.80,0:06:05.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}berbanggalah karena berhasil mengalahkannya.
Dialogue: 0,0:06:06.10,0:06:10.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nah, aku tidak boleh membuat\NTuan Rimuru menunggu.
Dialogue: 0,0:06:10.82,0:06:12.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita mulai.
Dialogue: 0,0:06:14.73,0:06:17.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:06:19.63,0:06:24.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, rapatnya panjang banget!
Dialogue: 0,0:06:24.36,0:06:26.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu karena banyak hal yang terjadi.
Dialogue: 0,0:06:26.70,0:06:28.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:31.17,0:06:34.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski rencana Gaban itu sangat payah,
Dialogue: 0,0:06:34.29,0:06:37.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}niat buruk mereka terhadapku sudah jelas.
Dialogue: 0,0:06:37.36,0:06:40.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kasus percobaan pembunuhan\NPangeran Elric membuktikan
Dialogue: 0,0:06:40.11,0:06:42.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}mereka cuma pion.
Dialogue: 0,0:06:42.01,0:06:46.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tujuan asli mereka adalah memfitnahku\Natas kematian Pangeran
Dialogue: 0,0:06:46.02,0:06:50.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}untuk menyingkirkan Tempest\Ndari Negara-Negara Barat.
Dialogue: 0,0:06:50.96,0:06:52.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari sekian banyak masalah,
Dialogue: 0,0:06:52.52,0:06:56.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}untung Hinata dan Shuna mengamuk duluan.
Dialogue: 0,0:06:56.24,0:07:00.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebagai perwakilan negara,\Nkurang etis kalau aku yang turun tangan.
Dialogue: 0,0:07:00.23,0:07:03.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku bukannya mengamuk,
Dialogue: 0,0:07:03.20,0:07:06.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}hanya mendisiplinkan mereka saja.
Dialogue: 0,0:07:06.11,0:07:08.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saya juga, Tuan Rimuru.
Dialogue: 0,0:07:08.98,0:07:12.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya memberi sedikit pelajaran\Npada orang kurang ajar.
Dialogue: 0,0:07:16.56,0:07:19.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata kamu bisa\Nmenahan diri juga, Benimaru.
Dialogue: 0,0:07:19.39,0:07:22.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jujur saja aku paling mengkhawatirkanmu.
Dialogue: 0,0:07:22.38,0:07:27.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya saya sudah dipenuhi amarah,
Dialogue: 0,0:07:27.12,0:07:31.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi sadar kembali berkat Shuna\Nyang bertindak duluan.
Dialogue: 0,0:07:32.64,0:07:37.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terlambat sedikit saja,\Nmereka semua pasti sudah terbakar habis.
Dialogue: 0,0:07:39.98,0:07:41.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Enteng amat bicaranya!
Dialogue: 0,0:07:41.47,0:07:42.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bercanda.
Dialogue: 0,0:07:42.65,0:07:45.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan bohong, tadi itu nadanya serius!
Dialogue: 0,0:07:45.82,0:07:47.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:07:47.39,0:07:51.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berbahaya juga.\NAku hampir jadi musuh umat manusia.
Dialogue: 0,0:07:51.74,0:07:55.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku harus hati-hati memilih orang\Nuntuk urusan seperti ini.
Dialogue: 0,0:07:56.54,0:07:57.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru.
Dialogue: 0,0:07:57.78,0:08:00.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, kamu sudah kembali.
Dialogue: 0,0:08:00.08,0:08:01.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:08:07.31,0:08:10.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi begitu kejadiannya.
Dialogue: 0,0:08:10.98,0:08:15.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih sudah menangkap pelakunya.\NKamu hebat, Souei.
Dialogue: 0,0:08:15.01,0:08:16.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebuah kehormatan bagi saya.
Dialogue: 0,0:08:16.64,0:08:20.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski begitu, dia berhasil mengalahkan\Ntiga tubuh bayangan saya.
Dialogue: 0,0:08:20.67,0:08:23.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saya harus berlatih lebih keras lagi.
Dialogue: 0,0:08:23.02,0:08:26.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pada akhirnya, dia tidak mau\Nmenyebutkan namanya?
Dialogue: 0,0:08:26.58,0:08:27.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:27.72,0:08:30.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Identitasnya tidak diketahui,\Ntapi dia menyebut Anda
Dialogue: 0,0:08:30.64,0:08:35.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}"majikan dari bajingan iblis",\Nkemungkinan maksudnya adalah Tuan Diablo.
Dialogue: 0,0:08:36.88,0:08:41.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak menerima laporan apa pun,\Ntapi mengingat ini Diablo...
Dialogue: 0,0:08:41.17,0:08:44.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah membuat musuhnya\Nketakutan setengah mati,
Dialogue: 0,0:08:44.40,0:08:47.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}"Saking sepelenya, saya sampai lupa."
Dialogue: 0,0:08:47.13,0:08:49.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasti dia akan bilang begitu.
Dialogue: 0,0:08:49.80,0:08:52.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mengenai senjata pelakunya...
Dialogue: 0,0:08:52.61,0:08:54.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:08:54.06,0:08:57.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kemungkinan itu senjata dari dunia sana.
Dialogue: 0,0:08:57.93,0:08:58.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jawab.
Dialogue: 0,0:08:58.93,0:09:03.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Diduga penembak tersebut memproyeksikannya\Nsecara langsung menggunakan energi sihir.
Dialogue: 0,0:09:03.30,0:09:05.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kemampuan ini serupa\Ndengan otoritas Reality Weapon.
Dialogue: 0,0:09:05.94,0:09:07.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:09:07.71,0:09:12.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kemungkinan besar dia adalah Orang Dunia Lain\Nyang memanifestasikan ingatannya sendiri.
Dialogue: 0,0:09:12.95,0:09:14.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:09:14.78,0:09:18.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata dia menyembunyikan\Nskill yang cukup merepotkan.
Dialogue: 0,0:09:18.20,0:09:20.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hinata?
Dialogue: 0,0:09:20.71,0:09:24.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena nanti juga kamu akan tahu,\Njadi kuberi tahu sekarang saja.
Dialogue: 0,0:09:24.66,0:09:28.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pembunuh wanita yang kulihat\Nlewat Transmisi Pikiran itu
Dialogue: 0,0:09:28.11,0:09:30.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}anggota Tiga Petarung Bijak Rook Genius,
Dialogue: 0,0:09:31.09,0:09:33.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Glenda si Laut Ganas.
Dialogue: 0,0:09:34.02,0:09:36.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia mantan bawahanku.
Dialogue: 0,0:09:40.27,0:09:42.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ketua!
Dialogue: 0,0:09:42.82,0:09:45.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lama tidak bertemu, Glenda.
Dialogue: 0,0:09:45.44,0:09:47.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ke-Kenapa?
Dialogue: 0,0:09:57.47,0:09:59.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya kamu baik-baik saja.
Dialogue: 0,0:10:06.08,0:10:09.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya hidupku cuma sampai sini.
Dialogue: 0,0:10:09.14,0:10:12.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bunuh saja aku.\NNasib mata-mata yang tertangkap...
Dialogue: 0,0:10:12.34,0:10:13.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:10:13.95,0:10:16.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu hanya perlu menjawab pertanyaan.
Dialogue: 0,0:10:16.85,0:10:19.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya dia sudah kena mental.
Dialogue: 0,0:10:20.43,0:10:22.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan bertanya duluan.
Dialogue: 0,0:10:22.27,0:10:23.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:10:35.23,0:10:37.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pantas saja aku merasa ada yang aneh.
Dialogue: 0,0:10:37.90,0:10:39.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pergerakan Dewan selama ini
Dialogue: 0,0:10:39.62,0:10:44.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}terkesan selalu mengawasi langkah\NGereja Suci Barat.
Dialogue: 0,0:10:44.37,0:10:48.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu ada mata-mata di sekitar,
Dialogue: 0,0:10:48.75,0:10:53.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan kamu pengkhianatnya sejak awal, kan?
Dialogue: 0,0:10:53.01,0:10:54.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak mau jawab.
Dialogue: 0,0:10:54.76,0:11:00.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa orang yang mengendalikan Dewan\Ndan memerintahkanmu membunuh
Dialogue: 0,0:11:00.29,0:11:02.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pangeran Elric?
Dialogue: 0,0:11:02.02,0:11:03.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak mau jawab.
Dialogue: 0,0:11:03.77,0:11:08.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mau menyebutkan nama bosmu,\Naku bisa meringankan hukumanmu.
Dialogue: 0,0:11:09.26,0:11:12.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kubilang, aku tidak mau jawab!
Dialogue: 0,0:11:13.65,0:11:17.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, pertanyaan terakhir.
Dialogue: 0,0:11:18.03,0:11:22.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu memercayai Tuhan Luminus?
Dialogue: 0,0:11:25.39,0:11:27.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuhan itu tidak ada.
Dialogue: 0,0:11:27.65,0:11:30.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Daripada memercayai begituan,\Nmending kasih aku uang...
Dialogue: 0,0:11:38.18,0:11:41.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu berlebihan, Hinata.\NIni hanya interogasi.
Dialogue: 0,0:11:41.60,0:11:43.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu malah mau membunuhnya.
Dialogue: 0,0:11:44.24,0:11:47.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak berniat begitu.
Dialogue: 0,0:11:47.10,0:11:50.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan bohong!\NPadahal niat membunuhnya kuat banget!
Dialogue: 0,0:11:51.41,0:11:54.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tenang saja, Tuan Rimuru.
Dialogue: 0,0:11:54.11,0:11:59.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski dia sampai terbunuh,\Nsumber informasinya tidak akan hilang.
Dialogue: 0,0:11:59.71,0:12:00.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:00.62,0:12:03.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena saya bisa membangkitkannya.
Dialogue: 0,0:12:03.62,0:12:04.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar itu.
Dialogue: 0,0:12:04.96,0:12:08.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga punya kemampuan Kebangkitan,\Njadi itu bukan masalah.
Dialogue: 0,0:12:08.87,0:12:11.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan itu masalahnya.
Dialogue: 0,0:12:11.63,0:12:15.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pokoknya, kamu diam dulu\Ndan perhatikan, Hinata.
Dialogue: 0,0:12:21.76,0:12:24.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku yang akan menginterogasinya.
Dialogue: 0,0:12:27.95,0:12:33.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nah, perkenalkan, Glenda,\Naku Raja Iblis Rimuru.
Dialogue: 0,0:12:33.81,0:12:35.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:12:35.07,0:12:37.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebelum interogasi, dengar ini.
Dialogue: 0,0:12:37.88,0:12:42.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Percuma menyuruh profesional sepertimu\Nuntuk langsung membocorkan informasi.
Dialogue: 0,0:12:42.43,0:12:45.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena itu, cukup dengarkan perkataanku.
Dialogue: 0,0:12:45.83,0:12:49.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jaga ekspresi datarmu itu kalau bisa.
Dialogue: 0,0:12:49.63,0:12:52.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak usah mengingatkanku segala.
Dialogue: 0,0:12:53.49,0:12:56.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang saatnya giliranmu, Kak Raphael.
Dialogue: 0,0:12:56.84,0:13:01.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik. Interogasi terhadap\Nindividu Glenda dimulai.
Dialogue: 0,0:13:02.82,0:13:05.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita mulai.
Dialogue: 0,0:13:05.76,0:13:09.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sering kali Skill Unik berakar jauh\Ndi dalam jiwa seseorang.
Dialogue: 0,0:13:09.89,0:13:15.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kemampuanmu tampaknya melekat\Nsangat kuat pada jiwamu juga.
Dialogue: 0,0:13:15.34,0:13:17.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, aku baru dengar.
Dialogue: 0,0:13:17.79,0:13:19.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terus kenapa?
Dialogue: 0,0:13:19.49,0:13:24.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pada sidang tadi siang, banyak anggota dewan\Nyang jiwanya dipenuhi keserakahan
Dialogue: 0,0:13:25.24,0:13:30.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}akibat kiriman Skill Unik pihak lain.
Dialogue: 0,0:13:30.91,0:13:34.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua manusia memang serakah.
Dialogue: 0,0:13:34.00,0:13:36.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:13:36.05,0:13:40.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena keserakahan mereka memiliki\Ngelombang yang sama,
Dialogue: 0,0:13:41.11,0:13:44.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku yakin mereka dikendalikan\Noleh satu orang.
Dialogue: 0,0:13:44.76,0:13:49.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu juga di bawah pengaruh itu, Glenda.
Dialogue: 0,0:13:50.54,0:13:51.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:13:52.40,0:13:57.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena jiwamu dilindungi oleh Skill Unik sendiri,
Dialogue: 0,0:13:57.42,0:14:01.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}kamu tidak sampai sepenuhnya dikendalikan.
Dialogue: 0,0:14:02.19,0:14:05.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kak Raphael, aku juga baru dengar soal itu.
Dialogue: 0,0:14:05.23,0:14:06.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita lanjutkan.
Dialogue: 0,0:14:06.22,0:14:07.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, iya.
Dialogue: 0,0:14:09.30,0:14:13.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya mereka juga menyusup\Nsaat Festival Pendirian berlangsung.
Dialogue: 0,0:14:14.94,0:14:17.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mampu memengaruhi orang sebanyak itu,
Dialogue: 0,0:14:17.46,0:14:20.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}kemungkinan si pengguna\Nberada di dekat lokasi.
Dialogue: 0,0:14:21.33,0:14:25.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Singkatnya, bosmu menghadiri Festival Pendirian.
Dialogue: 0,0:14:25.55,0:14:28.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kemampuan analisisku ini luar biasa.
Dialogue: 0,0:14:28.78,0:14:31.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak hanya bisa mendeteksi skill,
Dialogue: 0,0:14:31.25,0:14:36.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi bisa merasakan hawa orang\Nyang berusaha menyembunyikannya juga.
Dialogue: 0,0:14:36.56,0:14:41.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia pasti takut kemampuannya\Nketahuan olehku.
Dialogue: 0,0:14:41.55,0:14:46.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena itu, aku menyuruh bawahanku\Nmelacak keberadaan hawa tersebut.
Dialogue: 0,0:14:46.93,0:14:48.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maribel Rozzo.
Dialogue: 0,0:14:49.68,0:14:52.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu pernah mendengar namanya?
Dialogue: 0,0:14:52.00,0:14:54.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}E-Entahlah.
Dialogue: 0,0:14:54.33,0:14:55.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rozzo?
Dialogue: 0,0:14:56.42,0:15:00.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata Rozzo terlibat soal ini.
Dialogue: 0,0:15:00.94,0:15:04.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keluarga dari leluhur Granville Rozzo,\Nmantan pahlawan pemersatu
Dialogue: 0,0:15:04.42,0:15:08.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Negara-Negara Barat\Nsekaligus pemimpin Tujuh Luminari.
Dialogue: 0,0:15:08.85,0:15:13.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski Granville telah tiada,\Nrupanya tekadnya masih diwariskan.
Dialogue: 0,0:15:15.82,0:15:18.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maribel itu bosmu, kan?
Dialogue: 0,0:15:23.82,0:15:27.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gagal.\NKita sudah gagal.
Dialogue: 0,0:15:28.46,0:15:33.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kasihan sekali nasib Gaban,\Npadahal dia sudah mengabdi banyak padamu.
Dialogue: 0,0:15:33.12,0:15:37.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berkatnya, Inkuisitor Sihir pun\Nsampai turun tangan.
Dialogue: 0,0:15:37.26,0:15:39.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukannya itu saja sudah bagus?
Dialogue: 0,0:15:39.46,0:15:41.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:41.84,0:15:47.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena Kakek mengkhawatirkannya,\Naku menyelidikinya lewat Gaban.
Dialogue: 0,0:15:47.97,0:15:51.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi dia sama sekali\Nbukan tandingan Raja Iblis.
Dialogue: 0,0:15:51.45,0:15:53.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar tidak berguna.
Dialogue: 0,0:15:53.72,0:15:56.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terlebih lagi, Raja Iblis Rimuru...
Dialogue: 0,0:15:56.98,0:15:58.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangankan menjebaknya atas pembunuhan
Dialogue: 0,0:15:58.98,0:16:02.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}lalu menyingkirkan Tempest\Ndari Negara-Negara Barat.
Dialogue: 0,0:16:02.53,0:16:06.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini justru memperkuat pengaruhnya\Ndi dalam Dewan.
Dialogue: 0,0:16:07.04,0:16:10.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku terlalu naif.\NAku telah meremehkannya.
Dialogue: 0,0:16:11.74,0:16:17.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Johann, aku ingin kamu menyelidiki\Nsituasi internal Raja Iblis.
Dialogue: 0,0:16:17.50,0:16:20.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku menyelidiki Raja Iblis?
Dialogue: 0,0:16:20.50,0:16:25.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belum mengerti alasanku membuatmu\Ndan Gaban saling bermusuhan?
Dialogue: 0,0:16:26.64,0:16:30.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua itu demi membuat\NRaja Iblis memercayaimu.
Dialogue: 0,0:16:31.68,0:16:35.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau gagal, aku juga akan disingkirkan.
Dialogue: 0,0:16:38.27,0:16:42.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah bekerja sama dengan Raja Iblis Rimuru\Nadalah langkah terbaik?
Dialogue: 0,0:16:42.44,0:16:45.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia menginginkan koeksistensi\Ndengan umat manusia, bukan?
Dialogue: 0,0:16:45.78,0:16:48.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita tidak perlu menjadikan\NTempest sebagai musuh.
Dialogue: 0,0:16:48.53,0:16:51.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu membuat kesimpulan yang salah besar.
Dialogue: 0,0:16:53.57,0:16:57.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu tahu alasan sebenarnya\Naku menyarankan Kakek
Dialogue: 0,0:16:57.98,0:17:00.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}untuk menyingkirkan Raja Iblis?
Dialogue: 0,0:17:00.37,0:17:05.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena zona ekonomi baru yang dia buat
Dialogue: 0,0:17:05.25,0:17:07.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}mengancam posisi kita?
Dialogue: 0,0:17:07.63,0:17:12.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar, tapi itu baru di permukaan.
Dialogue: 0,0:17:12.39,0:17:18.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Alasan aslinya, kita tidak akan bisa\Nberkutik lagi di hadapannya.
Dialogue: 0,0:17:19.15,0:17:20.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:17:21.74,0:17:25.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Raja Iblis punya kekuatan militer\Nyang mengerikan,
Dialogue: 0,0:17:25.22,0:17:28.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}ditambah lagi ada Naga Badai di sisinya.
Dialogue: 0,0:17:28.56,0:17:34.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa jadinya kalau dia memanfaatkan itu\Nsebagai tameng untuk bernegosiasi?
Dialogue: 0,0:17:34.24,0:17:38.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, bukankah dia berjanji\Nakan tunduk pada aturan Dewan?
Dialogue: 0,0:17:38.75,0:17:42.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia hanya patuh untuk saat ini saja.
Dialogue: 0,0:17:42.91,0:17:46.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu pengaruh Tempest diakui secara luas,
Dialogue: 0,0:17:46.02,0:17:49.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}giliran Negara-Negara Barat\Nyang harus tunduk.
Dialogue: 0,0:17:49.59,0:17:54.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan begitu, dominasi Raja Iblis\Nakan selesai secara damai.
Dialogue: 0,0:17:54.93,0:17:58.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Konyol.\NIni benar-benar konyol.
Dialogue: 0,0:17:58.22,0:18:04.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana bisa mereka mengira\Nmanusia bisa setara Raja Iblis?
Dialogue: 0,0:18:04.44,0:18:07.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong kosong seperti "negosiasi"
Dialogue: 0,0:18:07.94,0:18:11.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}hanya bisa terjadi\Nkarena kemurahan hati sang Raja Iblis!
Dialogue: 0,0:18:20.94,0:18:23.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Umur manusia itu singkat.
Dialogue: 0,0:18:23.74,0:18:26.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kita tidak menghentikannya sekarang,
Dialogue: 0,0:18:26.77,0:18:30.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}ambisi Rozzo akan hancur selamanya.
Dialogue: 0,0:18:30.82,0:18:34.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bekerja sama atau memanfaatkan Raja Iblis?
Dialogue: 0,0:18:34.35,0:18:37.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejak awal itu hal yang mustahil.
Dialogue: 0,0:18:38.47,0:18:40.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:18:40.22,0:18:44.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku kelihatan seperti sudah\Nmembocorkan semuanya pada kalian!
Dialogue: 0,0:18:45.89,0:18:48.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasakan itu, Glenda.
Dialogue: 0,0:18:48.27,0:18:51.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cocok untuk pengkhianat sepertimu.
Dialogue: 0,0:18:51.95,0:18:58.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sial, kalau begini, aku bisa dibunuh.
Dialogue: 0,0:18:59.65,0:19:03.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memangnya Maribel seberbahaya itu?
Dialogue: 0,0:19:05.41,0:19:07.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan itu masalahnya.
Dialogue: 0,0:19:09.07,0:19:12.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang yang dipanggil dari dunia lain,
Dialogue: 0,0:19:12.62,0:19:16.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}telah diikat oleh kutukan\Nagar tidak bisa melawan.
Dialogue: 0,0:19:16.59,0:19:19.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat kami dianggap telah berkhianat...
Dialogue: 0,0:19:25.23,0:19:28.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jiwa kami akan langsung hancur.
Dialogue: 0,0:19:28.48,0:19:33.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maksudnya, kamu bukan mengkhianati\NTuhan Luminus atas kemauan sendiri,
Dialogue: 0,0:19:33.95,0:19:36.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi hanya karena tidak bisa melawan?
Dialogue: 0,0:19:37.17,0:19:40.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu perihal yang rumit.
Dialogue: 0,0:19:41.14,0:19:44.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada sisi yang ingin bergantung\Npada belas kasih Tuhan,
Dialogue: 0,0:19:44.98,0:19:49.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi pada akhirnya\Naku tidak bisa lepas dari kutukan.
Dialogue: 0,0:19:51.04,0:19:55.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya merasa tidak pantas
Dialogue: 0,0:19:55.05,0:19:57.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}diselamatkan oleh Tuhan.
Dialogue: 0,0:19:59.47,0:20:03.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belas kasih Tuhan\Nmemang tidak bisa berbuat sejauh itu.
Dialogue: 0,0:20:03.84,0:20:08.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Manusia yang jiwanya hancur tidak bisa\Ndihidupkan dengan Kebangkitan.
Dialogue: 0,0:20:10.22,0:20:13.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kak Raphael, masalahnya bisa diselesaikan?
Dialogue: 0,0:20:13.23,0:20:14.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:20:14.29,0:20:17.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan masalah.\NMau melepasnya?
Dialogue: 0,0:20:29.71,0:20:33.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nah, karena urusan sudah selesai,\Nkamu boleh hidup bebas.
Dialogue: 0,0:20:36.18,0:20:39.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini belas kasihan terakhirmu?
Dialogue: 0,0:20:39.13,0:20:41.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:20:41.36,0:20:44.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku baru melepas kutukan\Nyang membelenggumu.
Dialogue: 0,0:20:46.42,0:20:47.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:47.39,0:20:50.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, kamu sudah bebas.
Dialogue: 0,0:20:50.90,0:20:52.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:53.71,0:20:56.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu selalu saja serbabisa.
Dialogue: 0,0:20:56.15,0:21:01.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kamu tetap berniat memusuhi kami,\Ntidak akan ada ampun bagimu.
Dialogue: 0,0:21:01.97,0:21:03.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan soal itu.
Dialogue: 0,0:21:03.91,0:21:06.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kejadian ini aku anggap tidak ada.
Dialogue: 0,0:21:06.91,0:21:08.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan itu!
Dialogue: 0,0:21:09.79,0:21:13.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu bilang baru melepas kutukanku?
Dialogue: 0,0:21:13.06,0:21:14.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu benar?
Dialogue: 0,0:21:14.79,0:21:17.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, rasanya lega, kan?
Dialogue: 0,0:21:24.80,0:21:27.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu ini sangat tidak tahu malu.
Dialogue: 0,0:21:27.98,0:21:30.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, aku punya satu permohonan.
Dialogue: 0,0:21:30.27,0:21:33.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong pekerjakan aku!
Dialogue: 0,0:21:33.54,0:21:34.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:34.44,0:21:36.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pekerjaan kotor atau apa pun\Nakan kulakukan!
Dialogue: 0,0:21:36.72,0:21:40.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin kamu tidak akan memercayaiku,\Ntapi aku bersumpah akan setia!
Dialogue: 0,0:21:40.32,0:21:43.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, aku mohon, Raja Iblis!
Dialogue: 0,0:21:44.93,0:21:47.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masa aku mempekerjakan\Nmata-mata orang lain...
Dialogue: 0,0:21:47.33,0:21:51.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan membocorkan semua\Ninformasi yang kutahu.
Dialogue: 0,0:21:51.65,0:21:55.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soal Granville yang kalian kira sudah tiada...
Dialogue: 0,0:21:55.08,0:21:57.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia masih hidup.
Dialogue: 0,0:21:57.84,0:21:59.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:59.01,0:22:00.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Granville yang itu?
Dialogue: 0,0:22:00.76,0:22:03.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gran dari Tujuh Luminari,
Dialogue: 0,0:22:03.41,0:22:07.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}hanya tubuh spiritual\Nyang dirasuki Tuan Granville.
Dialogue: 0,0:22:08.35,0:22:11.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang yang berada di atas Maribel\Nadalah Tuan Granville.
Dialogue: 0,0:22:11.42,0:22:16.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku memang tidak tahu rencana Maribel,
Dialogue: 0,0:22:16.02,0:22:20.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi aku tahu siapa pion terkuat\Nyang paling mengancam kalian.
Dialogue: 0,0:22:21.53,0:22:25.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Grandmaster dari Serikat Bebas,
Dialogue: 0,0:22:25.03,0:22:26.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yuuki Kagurazaka.
Dialogue: 0,0:22:26.85,0:22:31.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia telah sepenuhnya berada\Ndi bawah kendali Maribel!
Dialogue: 0,0:24:06.01,0:24:09.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya, "Siasat sang Serakah".
