Dialogue: 0,0:11:19.68,0:11:23.93,tanda-5,,0,0,0,,{\pos(960,862)\fs65\b1\bord3\c&H000000&\3c&HEEEEEE&\fad(450,500)}Kerajaan Ingrassia\NMarkas Besar Dewan Negara-Negara Barat
Dialogue: 0,0:00:26.08,0:00:26.92,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jean!
Dialogue: 0,0:00:28.10,0:00:29.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dia mati.
Dialogue: 0,0:00:31.30,0:00:34.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini pun aku masih prima!
Dialogue: 0,0:00:34.16,0:00:37.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kecepatan ini...\NKamu sang Meteor Merah, Scarlet, ya?
Dialogue: 0,0:00:37.39,0:00:39.31,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wush!
Dialogue: 0,0:00:41.04,0:00:42.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wahai angin yang berembus,
Dialogue: 0,0:00:42.98,0:00:45.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}jadilah tornado dan cabik-cabiklah musuh!
Dialogue: 0,0:00:45.73,0:00:47.76,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rapalan ini...
Dialogue: 0,0:00:47.76,0:00:51.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Konon tidak ada yang selamat\Nsetelah melihat api itu!
Dialogue: 0,0:00:51.63,0:00:52.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sang Malaikat Maut Biru!
Dialogue: 0,0:00:52.99,0:00:53.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Blue Death!
Dialogue: 0,0:00:53.95,0:00:55.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Biarkan angin mengamuk,
Dialogue: 0,0:00:55.43,0:00:57.54,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tornado Blade!
Dialogue: 0,0:01:02.73,0:01:04.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maja! Naja!
Dialogue: 0,0:01:04.62,0:01:07.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sial! Dia sengaja mengincar\Ngarda belakang, ya!
Dialogue: 0,0:01:07.28,0:01:08.59,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Beraninya!
Dialogue: 0,0:01:09.92,0:01:11.68,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:01:17.20,0:01:19.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ahem!
Dialogue: 0,0:01:19.06,0:01:20.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:01:20.03,0:01:21.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu lengah!
Dialogue: 0,0:01:21.64,0:01:23.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Celahmu terlihat jelas!
Dialogue: 0,0:01:24.55,0:01:27.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu kurang waspada, dasar bodoh.
Dialogue: 0,0:01:31.23,0:01:32.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sudah begini...
Dialogue: 0,0:01:34.53,0:01:38.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu pikir bisa kabur dari kami?
Dialogue: 0,0:01:40.10,0:01:44.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Barang langka\Nyang sudah kukumpulkan susah payah...
Dialogue: 0,0:01:47.58,0:01:50.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lapor. Pertempuran selesai.
Dialogue: 0,0:03:18.30,0:03:20.97,dialog,,0,0,0,,{\blur3}{\fad(00,40)}(Tensura) Bereinkarnasi Malah Menjadi Slime
Dialogue: 0,0:03:24.91,0:03:27.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lawan keroco melulu jadi berasa kurang.
Dialogue: 0,0:03:27.73,0:03:29.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Betul banget!
Dialogue: 0,0:03:29.57,0:03:32.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kita ini yang terkuat dan tidak terkalahkan!
Dialogue: 0,0:03:32.27,0:03:35.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mereka bukan lawan\Nyang pantas untuk kita!
Dialogue: 0,0:03:35.65,0:03:38.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hei, jangan jemawa dulu.
Dialogue: 0,0:03:38.26,0:03:40.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ini bagian dari pekerjaan juga.
Dialogue: 0,0:03:40.03,0:03:43.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}I-Iya, aku juga mengerti.
Dialogue: 0,0:03:43.41,0:03:47.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, ayo kita lanjut berburu lagi!
Dialogue: 0,0:03:47.26,0:03:48.92,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:03:48.92,0:03:51.09,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ora, ora, ora!
Dialogue: 0,0:03:56.64,0:03:59.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Setelah insiden Tim Amukan Hijau,
Dialogue: 0,0:03:59.13,0:04:02.14,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Teknik Rahasia, Tebasan Satu Panel!\N- kami mulai berburu penantang.
Dialogue: 0,0:04:02.14,0:04:03.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekalian buat latihan juga.
Dialogue: 0,0:04:05.02,0:04:08.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena ada kemungkinan\Nmereka akan balas dendam.
Dialogue: 0,0:04:09.86,0:04:12.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pengelolaan dungeon berjalan lancar,
Dialogue: 0,0:04:12.06,0:04:15.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}suasana kota pun dipenuhi semangat!
Dialogue: 0,0:04:15.82,0:04:19.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Masayuki benar-benar berjasa\Nsebagai ikon promosi.
Dialogue: 0,0:04:20.10,0:04:22.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Berkat keberuntungan alaminya,
Dialogue: 0,0:04:22.57,0:04:25.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dia sudah melengkapi\Nset perlengkapan langka.
Dialogue: 0,0:04:26.58,0:04:31.08,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saat ini dia bahkan mengincar lantai 50.
Dialogue: 0,0:04:33.30,0:04:35.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hasil siaran dari aksi Masayuki
Dialogue: 0,0:04:35.02,0:04:39.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dan para penantang lainnya
Dialogue: 0,0:04:39.34,0:04:42.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}benar-benar membakar semangat mereka.
Dialogue: 0,0:04:44.56,0:04:48.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik mereka yang mencari kekuatan\Nmaupun ketenaran,
Dialogue: 0,0:04:48.45,0:04:52.60,dialog,,0,0,0,,{\blur3}{\fad(00,40)}sekarang banyak penantang tangguh\Nyang bermunculan.
Dialogue: 0,0:04:52.60,0:04:56.48,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamilah sosok yang akan menghadang mereka.
Dialogue: 0,0:04:56.48,0:04:57.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:04:57.69,0:04:58.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Muncul juga!
Dialogue: 0,0:04:58.99,0:05:01.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dungeon Dominator!
Dialogue: 0,0:05:05.75,0:05:08.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Gim yang menantang pasti lebih seru, kan?
Dialogue: 0,0:05:08.86,0:05:10.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kami bukan mau main-main, kok!
Dialogue: 0,0:05:12.96,0:05:15.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rasanya ada yang kurang.
Dialogue: 0,0:05:15.34,0:05:18.21,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa tidak ada lawan yang lebih gereget?
Dialogue: 0,0:05:18.59,0:05:20.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jangan terburu-buru.
Dialogue: 0,0:05:20.66,0:05:25.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dungeon kita makin terkenal,\Nbanyak penantang kuat yang akan berdatangan.
Dialogue: 0,0:05:25.25,0:05:28.35,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku mau lanjut latihan supaya makin kuat!
Dialogue: 0,0:05:30.29,0:05:33.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru, ternyata Anda sudah kembali.
Dialogue: 0,0:05:34.00,0:05:38.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Anda kedatangan tamu,\Ndan kebetulan saya sedang mencari Anda.
Dialogue: 0,0:05:38.65,0:05:40.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh, ada tamu?
Dialogue: 0,0:05:41.17,0:05:43.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Anda bersama Nona Milim juga.
Dialogue: 0,0:05:43.91,0:05:45.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kebetulan sekali.
Dialogue: 0,0:05:45.67,0:05:47.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kebetulan?
Dialogue: 0,0:05:52.18,0:05:55.00,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya datang berkunjung, Tuan Rimuru.
Dialogue: 0,0:05:55.62,0:05:57.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Frey!
Dialogue: 0,0:05:58.00,0:06:00.96,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eng, ada perlu apa hari ini?
Dialogue: 0,0:06:01.43,0:06:04.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya tidak terlalu penting.
Dialogue: 0,0:06:04.39,0:06:07.51,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ah, Milim.\NTernyata kamu di sini.
Dialogue: 0,0:06:08.53,0:06:12.60,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong,\Nsoal tugas yang kuberikan padamu...
Dialogue: 0,0:06:12.60,0:06:14.60,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa sudah selesai?
Dialogue: 0,0:06:14.60,0:06:18.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dia menelantarkan tugasnya\Ndan malah main ke sini.
Dialogue: 0,0:06:18.61,0:06:22.89,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bu-Bukan begitu!\NAda alasan rumit untuk hal ini!
Dialogue: 0,0:06:24.01,0:06:25.15,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:06:26.35,0:06:30.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Penjaga yang kutugaskan mengawasimu\Nditemukan terkapar tergulung karpet.
Dialogue: 0,0:06:30.74,0:06:34.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu punya alasan masuk akal\Nuntuk menjelaskan ini, kan?
Dialogue: 0,0:06:35.37,0:06:39.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}I-Itu, karena Rimuru dan kawan-kawannya...
Dialogue: 0,0:06:39.13,0:06:42.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aduh, kalau lagi punya tugas,\Nbilang, dong.
Dialogue: 0,0:06:42.63,0:06:45.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maaf mengajakmu tanpa tahu soal itu.
Dialogue: 0,0:06:45.57,0:06:47.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Padahal bilang saja dari awal.
Dialogue: 0,0:06:47.69,0:06:50.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalian jahat banget!
Dialogue: 0,0:06:53.10,0:06:57.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Frey! Bukan begitu!\NDengarkan aku!
Dialogue: 0,0:06:58.46,0:07:01.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja akan kudengarkan.
Dialogue: 0,0:07:03.23,0:07:07.84,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku dengarkan dengan saksama\Nsetelah kita sampai di rumah.
Dialogue: 0,0:07:15.59,0:07:18.51,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Untung kita tidak ikut terlibat.
Dialogue: 0,0:07:18.51,0:07:20.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kerja sama kita kompak banget tadi.
Dialogue: 0,0:07:20.98,0:07:22.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yang terbaik sejauh ini, kan?
Dialogue: 0,0:07:22.71,0:07:23.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:23.67,0:07:26.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong, Tuan Rimuru.
Dialogue: 0,0:07:26.01,0:07:29.35,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selama ini, apa yang Anda lakukan?
Dialogue: 0,0:07:29.35,0:07:30.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:30.90,0:07:33.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, aku cuma meneliti, kok.
Dialogue: 0,0:07:33.50,0:07:37.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku lagi meneliti sendiri tentang\Ngaya bertarung para penantang.
Dialogue: 0,0:07:37.64,0:07:39.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sendiri?
Dialogue: 0,0:07:39.95,0:07:41.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:07:41.53,0:07:45.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Anda main di dungeon sampai lupa waktu, ya?
Dialogue: 0,0:07:45.67,0:07:47.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pe-Peka banget!
Dialogue: 0,0:07:47.57,0:07:48.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:07:48.28,0:07:50.96,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku mau meneliti sihir di kamarku, ah.
Dialogue: 0,0:07:50.96,0:07:53.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga ikut menemani, deh.
Dialogue: 0,0:07:53.82,0:07:55.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Boleh! Ayo kita meneliti bersama!\N- Maaf, Milim.
Dialogue: 0,0:07:55.87,0:07:59.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sikap pura-pura kayak begitu\Nternyata menjengkelkan!
Dialogue: 0,0:07:59.50,0:08:00.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lapor.
Dialogue: 0,0:08:00.75,0:08:02.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu menjelaskan alibi.
Dialogue: 0,0:08:03.19,0:08:06.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dihadapi langsung,\Nmasalah akan selesai.
Dialogue: 0,0:08:06.01,0:08:08.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Maksudnya bagaimana?
Dialogue: 0,0:08:08.38,0:08:10.76,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru!
Dialogue: 0,0:08:10.76,0:08:13.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata Anda ada di sini!
Dialogue: 0,0:08:13.44,0:08:14.52,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mjollmile!
Dialogue: 0,0:08:14.52,0:08:17.89,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada surat dari dewan.
Dialogue: 0,0:08:17.89,0:08:21.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kemungkinan besar ini undangan\Nuntuk menghadiri rapat
Dialogue: 0,0:08:21.93,0:08:24.40,dialog,,0,0,0,,{\blur3}{\fad(00,40)}penentuan status keanggotaan dewan kita.
Dialogue: 0,0:08:24.40,0:08:26.08,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:08:26.08,0:08:28.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku memang sudah merasa perlu datang.
Dialogue: 0,0:08:28.65,0:08:30.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:08:30.87,0:08:36.21,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku menduga Tim Amukan Hijau adalah\Nutusan dewan untuk menyelidiki kita.
Dialogue: 0,0:08:36.21,0:08:39.15,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi kita juga mau menyelidiki mereka.
Dialogue: 0,0:08:39.51,0:08:45.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Meski Kak Raphael sudah melakukannya\Nwaktu kami lagi bermain-main.
Dialogue: 0,0:08:45.17,0:08:47.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mohon maaf.
Dialogue: 0,0:08:47.33,0:08:51.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya kira Anda ikut bermain\Nbersama Nona Milim.
Dialogue: 0,0:08:51.43,0:08:53.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:08:53.01,0:08:55.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wajar kalau terlihat seperti itu.
Dialogue: 0,0:09:01.92,0:09:04.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku berhasil mengeles di waktu yang tepat.
Dialogue: 0,0:09:04.42,0:09:07.58,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, kalau tidak ada Kak Raphael,
Dialogue: 0,0:09:07.58,0:09:11.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}sebenarnya aku mengabaikan tugas lain\Nkarena kebanyakan bermain.
Dialogue: 0,0:09:11.45,0:09:14.09,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Semua memang harus ada batasnya.
Dialogue: 0,0:09:14.66,0:09:19.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Bukannya Anda\Nbaru mau mulai menyelidiki?
Dialogue: 0,0:09:19.50,0:09:20.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:09:20.66,0:09:25.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, apa yang Anda selidiki\Nsetelah perginya Tim Amukan Hijau?
Dialogue: 0,0:09:28.19,0:09:29.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru?
Dialogue: 0,0:09:30.46,0:09:34.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kak Raphael, masalahnya belum selesai, nih!
Dialogue: 0,0:09:34.83,0:09:38.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bisa diselesaikan dengan dimarahi\Ndan menyesali diri.
Dialogue: 0,0:09:43.04,0:09:45.89,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ya-Yang benar saja.
Dialogue: 0,0:09:53.35,0:09:55.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Keberadaan uang sangatlah penting
Dialogue: 0,0:09:56.30,0:09:58.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}bagi perkembangan peradaban.
Dialogue: 0,0:10:00.47,0:10:04.58,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dari zaman biji-bijian dianggap\Nsebagai alat tukar,
Dialogue: 0,0:10:05.00,0:10:08.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}beralih ke logam mulia emas dan perak,
Dialogue: 0,0:10:08.94,0:10:11.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}hingga akhirnya menuju ekonomi kertas
Dialogue: 0,0:10:11.26,0:10:13.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}yang menggunakan kontrak.
Dialogue: 0,0:10:15.71,0:10:18.15,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Di wilayah ekonomi negara-negara barat pun,
Dialogue: 0,0:10:18.15,0:10:21.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}melalui dewan, aku mendorong\Ntransisi ke ekonomi kertas
Dialogue: 0,0:10:21.93,0:10:24.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dengan mata uang tersendiri tiap negara.
Dialogue: 0,0:10:25.77,0:10:28.47,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hal terpenting adalah menciptakan lingkungan
Dialogue: 0,0:10:28.47,0:10:31.35,dialog,,0,0,0,,{\blur3}{\fad(00,40)}ketika nilai tukar berfluktuasi\Nsesuai kekuatan nasional,
Dialogue: 0,0:10:32.01,0:10:35.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dan memastikan kami yang membuat aturannya.
Dialogue: 0,0:10:36.28,0:10:40.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tanpa itu, kemenangan mutlak\Ntidak akan pernah terjamin.
Dialogue: 0,0:10:46.55,0:10:51.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dewan dan Lima Tetua\Nyang menentukan nilai dari tiap negara.
Dialogue: 0,0:10:52.55,0:10:55.60,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kemudian yang mengendalikan mereka
Dialogue: 0,0:10:56.48,0:10:57.94,dialog,,0,0,0,,{\blur3}{\fad(00,40)}adalah aku.
Dialogue: 0,0:10:59.50,0:11:03.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Akulah yang akan selalu memegang kendali.
Dialogue: 0,0:11:10.14,0:11:12.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dewan Negara-Negara Barat,
Dialogue: 0,0:11:13.83,0:11:15.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Council of the West,
Dialogue: 0,0:11:15.86,0:11:19.68,dialog,,0,0,0,,{\blur3}{\fad(00,40)}adalah organisasi yang beranggotakan\Nnegara di sekitar Hutan Agung Jura.
Dialogue: 0,0:11:20.93,0:11:23.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tanpa memandang besar kecilnya suatu negara,
Dialogue: 0,0:11:23.77,0:11:27.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dewan ini bertujuan untuk memberikan\Nmanfaat bagi seluruh umat manusia.
Dialogue: 0,0:11:28.42,0:11:31.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Agendanya mencakup berbagai hal,\Nmulai dari
Dialogue: 0,0:11:31.65,0:11:36.18,dialog,,0,0,0,,{\blur3}{\fad(00,40)}penanganan monster hingga kekeringan,\Nwabah, dan bencana alam.
Dialogue: 0,0:11:37.93,0:11:40.31,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Agenda yang tengah dibahas
Dialogue: 0,0:11:40.31,0:11:44.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}mengenai layak atau tidaknya negara monster\NTempest bergabung ke dalam dewan.
Dialogue: 0,0:11:45.75,0:11:49.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tempest...\NBukankah kita bisa memercayai mereka?
Dialogue: 0,0:11:49.19,0:11:54.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kita membuat Raja Iblis itu marah,\Nbukankah Naga Badai akan menyerang?
Dialogue: 0,0:11:54.19,0:11:58.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tenang saja.\NDia hanya berlindung di balik punggung naga.
Dialogue: 0,0:11:58.70,0:12:01.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Raja Iblis sendiri tidaklah sekuat itu.
Dialogue: 0,0:12:02.26,0:12:07.04,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lalu bagaimana penjelasannya dia bisa\Nseri melawan Nona Hinata?
Dialogue: 0,0:12:07.04,0:12:10.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Memangnya cerita itu bisa dipercaya?
Dialogue: 0,0:12:10.41,0:12:11.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:11.79,0:12:14.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana rumor itu bisa menyebar, ya?
Dialogue: 0,0:12:14.24,0:12:17.80,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bisa-bisanya dia bicara seperti itu\Ndi depan orangnya.
Dialogue: 0,0:12:18.32,0:12:22.32,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku diundang sebagai kenalan\NRaja Iblis Rimuru,
Dialogue: 0,0:12:22.79,0:12:26.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tapi ternyata kumpulan orang bodoh ini\Nsama sekali tidak produktif.
Dialogue: 0,0:12:27.98,0:12:31.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Beda jauh dengan rapat di Tempest.
Dialogue: 0,0:12:32.27,0:12:35.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tempat itu memang bisa dianggap anomali.
Dialogue: 0,0:12:35.57,0:12:37.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dengarkan baik-baik!
Dialogue: 0,0:12:37.17,0:12:42.12,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Raja Iblis Rimuru telah mendeklarasikan\NHutan Agung Jura sebagai wilayah kekuasaannya!
Dialogue: 0,0:12:42.12,0:12:45.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pikirkanlah baik-baik\Napa maksud dari tindakannya ini!
Dialogue: 0,0:12:45.62,0:12:49.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar, sejak Tempest berdiri,
Dialogue: 0,0:12:49.28,0:12:53.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}kerugian akibat serangan monster\Ndi wilayah kami jadi berkurang.
Dialogue: 0,0:12:53.17,0:12:56.92,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bodoh! Kalian semua sudah\Ndicuci otak oleh Raja Iblis!
Dialogue: 0,0:12:57.27,0:12:59.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Dia itu raja para monster!\N- Yah, mustahil menarik kesimpulan
Dialogue: 0,0:12:59.49,0:13:01.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Kalian akan menyesal setelah kena bencana!\N- Yah, mustahil menarik kesimpulan
Dialogue: 0,0:13:01.13,0:13:02.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Kalian akan menyesal setelah kena bencana!\N- Raja Iblis Rimuru itu baik atau jahat
Dialogue: 0,0:13:02.99,0:13:07.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tanpa mengetahui seperti apa kepribadiannya.
Dialogue: 0,0:13:08.43,0:13:12.94,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Masalah yang lebih merepotkan adalah\Nanggota dewan dari negara besar.
Dialogue: 0,0:13:13.58,0:13:18.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya, bergabungnya Tempest ke dalam\Ndewan juga menguntungkan bagiku.
Dialogue: 0,0:13:20.66,0:13:22.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Akui saja mereka.
Dialogue: 0,0:13:22.93,0:13:27.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dia bilang ingin menjadi sekutu kita,\Nsambut saja dengan tangan terbuka.
Dialogue: 0,0:13:27.33,0:13:31.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, dia harus membawa upeti untuk kita.
Dialogue: 0,0:13:31.33,0:13:33.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:13:33.11,0:13:36.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bertikai dengannya hanya akan\Nberakhir seperti Falmuth.
Dialogue: 0,0:13:36.38,0:13:40.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, dia harus tahu diri.
Dialogue: 0,0:13:40.06,0:13:44.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa dia bersedia mematuhi\Nhukum internasional yang kita tetapkan?
Dialogue: 0,0:13:44.26,0:13:46.83,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya itu bukan masalah.
Dialogue: 0,0:13:46.83,0:13:50.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Anda tentu sudah dengar rumor\Nsoal jatuhnya Duke Muese, kan?
Dialogue: 0,0:13:50.66,0:13:55.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa peduli kita dengan rencana\NRaja Iblis Rimuru?
Dialogue: 0,0:13:55.02,0:13:59.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yang penting\Ndia bisa dimanfaatkan atau tidak.
Dialogue: 0,0:13:59.79,0:14:01.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tepat sekali.
Dialogue: 0,0:14:01.78,0:14:04.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dengan pergerakan\NKekaisaran Timur yang mencemaskan,
Dialogue: 0,0:14:04.37,0:14:08.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tidak ada alasan bagi kita untuk menolak\Nkekuatan Raja Iblis sebagai sekutu.
Dialogue: 0,0:14:08.41,0:14:10.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Timur?
Dialogue: 0,0:14:10.17,0:14:12.21,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jangan bilang Kekaisaran Timur...
Dialogue: 0,0:14:12.63,0:14:15.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rostia, apakah itu benar?
Dialogue: 0,0:14:15.76,0:14:17.97,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalian semua pasti sudah tahu,
Dialogue: 0,0:14:17.97,0:14:19.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}bahwa ada pergerakan militer
Dialogue: 0,0:14:19.67,0:14:25.30,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kekaisaran Bersatu Timur\NNasca Namrium Ulmeria.
Dialogue: 0,0:14:25.70,0:14:29.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Akhir-akhir ini, mereka makin sering\Nmengadakan latihan militer.
Dialogue: 0,0:14:30.18,0:14:31.54,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kekaisaran...
Dialogue: 0,0:14:31.54,0:14:33.56,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa di saat seperti ini...
Dialogue: 0,0:14:33.95,0:14:38.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mereka itu negara militer yang haus kekuasaan\Ndan telah menelan banyak negara!
Dialogue: 0,0:14:38.41,0:14:41.94,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang akan terjadi pada kita\Nkalau perang pecah?
Dialogue: 0,0:14:41.94,0:14:43.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Benar itu!\N- Jangan sampai itu terjadi!
Dialogue: 0,0:14:43.79,0:14:45.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apakah perang akan pecah?
Dialogue: 0,0:14:45.22,0:14:46.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:14:46.82,0:14:50.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kekaisaran tidak akan bergerak\Ndalam waktu dekat.
Dialogue: 0,0:14:50.70,0:14:53.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana bisa tenang!
Dialogue: 0,0:14:53.17,0:14:56.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tanpa Kerajaan Falmuth,\Nnegara kecil seperti kami
Dialogue: 0,0:14:56.65,0:14:59.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tidak akan sanggup membangun\Ngaris pertahanan!
Dialogue: 0,0:14:59.65,0:15:04.54,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena itulah, mari kita diskusikan\Nlangkah pencegahannya di sini.
Dialogue: 0,0:15:04.54,0:15:05.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:15:05.72,0:15:09.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pendapat Anggota Dewan Johann ada benarnya.
Dialogue: 0,0:15:09.13,0:15:11.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tenanglah sedikit.
Dialogue: 0,0:15:12.23,0:15:16.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Percuma ada dewan kalau kalian\Nhanya saling melempar argumen.
Dialogue: 0,0:15:17.45,0:15:20.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih, Anggota Dewan Gaban.
Dialogue: 0,0:15:20.22,0:15:25.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku merasa kekaisaran tidak akan\Nbergerak secepat itu.
Dialogue: 0,0:15:25.24,0:15:28.58,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Alasan mereka tidak menyerang selama ini
Dialogue: 0,0:15:28.58,0:15:32.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}karena keberadaan Naga Badai\Ndi Hutan Agung Jura.
Dialogue: 0,0:15:32.79,0:15:36.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah sekarang dia sudah bangkit?
Dialogue: 0,0:15:36.25,0:15:40.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maksudnya, kita harus\Nmengandalkan naga jahat itu?
Dialogue: 0,0:15:40.99,0:15:47.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kabar yang beredar, Naga Badai telah\Ndijinakkan oleh Raja Iblis Rimuru.
Dialogue: 0,0:15:47.70,0:15:49.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lalu bukankah dia sendiri
Dialogue: 0,0:15:49.79,0:15:53.52,dialog,,0,0,0,,{\blur3}{\fad(00,40)}yang ingin bergabung dengan dewan ini?
Dialogue: 0,0:15:53.52,0:15:55.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Apa?\N- Naga Badai itu dijinakkan?
Dialogue: 0,0:15:55.11,0:15:56.52,dialog,,0,0,0,,{\blur3}{\fad(00,40)}- Bagaimana bisa?\N- Naga Badai itu dijinakkan?
Dialogue: 0,0:15:57.11,0:15:59.21,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar kata Anggota Dewan Gaban.
Dialogue: 0,0:15:59.21,0:16:01.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Di hadapan ancaman Timur,
Dialogue: 0,0:16:01.17,0:16:04.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}bukan saatnya bagi kita\Nuntuk terus bertikai.
Dialogue: 0,0:16:04.78,0:16:08.32,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau Raja Iblis Rimuru bergabung,
Dialogue: 0,0:16:08.32,0:16:12.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}kekuatan militernya\Nakan menjadi bantuan besar bagi kita!
Dialogue: 0,0:16:12.33,0:16:14.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:14.06,0:16:17.58,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Prioritas utama kita sekarang adalah\Nmenyatukan pihak Barat.
Dialogue: 0,0:16:17.58,0:16:19.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu masuk akal.
Dialogue: 0,0:16:19.73,0:16:22.59,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku mendukung keanggotaan Tempest!
Dialogue: 0,0:16:22.59,0:16:23.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:16:23.62,0:16:24.59,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:16:24.59,0:16:26.94,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mari kita sambut Tempest sebagai anggota!
Dialogue: 0,0:16:28.79,0:16:30.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tenang!
Dialogue: 0,0:16:30.90,0:16:34.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, kita akan melakukan\Npemungutan suara
Dialogue: 0,0:16:34.41,0:16:37.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}terkait bergabungnya Tempest\Nke dalam dewan.
Dialogue: 0,0:16:37.27,0:16:39.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagi anggota yang setuju, silakan berdiri.
Dialogue: 0,0:16:43.36,0:16:47.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dengan suara mayoritas,\NFederasi Jura Tempest
Dialogue: 0,0:16:47.87,0:16:51.36,dialog,,0,0,0,,{\blur3}{\fad(00,40)}resmi diakui sebagai sekutu kita.
Dialogue: 0,0:16:52.03,0:16:56.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Setelah mengirim surat undangan\Nkepada Federasi Jura Tempest
Dialogue: 0,0:16:56.62,0:16:59.84,dialog,,0,0,0,,{\blur3}{\fad(00,40)}untuk mengonfirmasi niat Raja Iblis Rimuru,
Dialogue: 0,0:16:59.84,0:17:02.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}rapat berikutnya akan segera dilaksanakan.
Dialogue: 0,0:17:03.35,0:17:04.40,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekian!
Dialogue: 0,0:17:11.29,0:17:16.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pada akhirnya, alasan mereka mengundangku\Nhanya karena takut akan sosok Rimuru.
Dialogue: 0,0:17:16.70,0:17:21.60,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Padahal, tinggal memintaku mengawasi\NRaja Iblis Rimuru agar tidak lepas kendali saja.
Dialogue: 0,0:17:21.60,0:17:23.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Malah bawa-bawa kekaisaran segala.
Dialogue: 0,0:17:24.48,0:17:26.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar konyol.
Dialogue: 0,0:17:28.08,0:17:31.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah muak terlibat dengan bangsawan.
Dialogue: 0,0:17:31.93,0:17:33.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hinata.
Dialogue: 0,0:17:36.33,0:17:40.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aduh, Putra Mahkota Kerajaan Ingrassia.
Dialogue: 0,0:17:40.37,0:17:43.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Justru dia inilah bangsawan paling menyebalkan.
Dialogue: 0,0:17:44.69,0:17:46.80,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada perlu apa denganku?
Dialogue: 0,0:17:47.39,0:17:50.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin meminta sedikit waktumu.
Dialogue: 0,0:17:51.42,0:17:52.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apakah berkenan?
Dialogue: 0,0:17:57.04,0:18:00.31,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, apa yang perlu dibicarakan?
Dialogue: 0,0:18:00.31,0:18:04.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya aku punya permintaan untukmu.
Dialogue: 0,0:18:04.53,0:18:06.56,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pada rapat berikutnya,
Dialogue: 0,0:18:06.99,0:18:09.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}aku ingin menguji Raja Iblis Rimuru.
Dialogue: 0,0:18:11.97,0:18:14.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Meski dia Raja Iblis yang kuat,
Dialogue: 0,0:18:14.95,0:18:19.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dia tetap harus memikul kewajiban\Nsebagai anggota dewan.
Dialogue: 0,0:18:20.65,0:18:24.56,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, kita perlu memastikan sejauh mana
Dialogue: 0,0:18:24.56,0:18:26.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}dia mau mendengarkan tuntutan kita.
Dialogue: 0,0:18:28.21,0:18:29.59,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:29.59,0:18:31.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Di sinilah
Dialogue: 0,0:18:31.26,0:18:33.92,dialog,,0,0,0,,{\blur3}{\fad(00,40)}peranmu dibutuhkan.
Dialogue: 0,0:18:34.89,0:18:40.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena lawan kita Raja Iblis,\Nbisa gawat kalau dia sampai lepas kendali.
Dialogue: 0,0:18:40.53,0:18:41.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:18:42.42,0:18:45.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}aku ingin kamu menjadi pengawal pribadiku.
Dialogue: 0,0:18:47.59,0:18:49.36,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:49.73,0:18:51.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Kenapa?
Dialogue: 0,0:18:52.74,0:18:57.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ka-Karena aku mengakui kemampuanmu!
Dialogue: 0,0:18:57.13,0:18:59.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebagai Komandan Kesatria Suci terkuat,
Dialogue: 0,0:18:59.38,0:19:04.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tangan kanan Tuhan,\Ndan kepala kesatria Rook Genius,
Dialogue: 0,0:19:04.02,0:19:07.46,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tidak ada yang sebanding denganmu\Ndi negara-negara barat ini.
Dialogue: 0,0:19:07.46,0:19:10.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan rumornya kamu seri\Nmelawan Raja Iblis Rimuru!
Dialogue: 0,0:19:10.66,0:19:13.05,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sosok sepertimu mau bekerja sama,
Dialogue: 0,0:19:13.05,0:19:17.05,dialog,,0,0,0,,{\blur3}{\fad(00,40)}aku jadi bisa menguak niat asli\NRaja Iblis Rimuru dengan aman!
Dialogue: 0,0:19:17.97,0:19:23.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa dia sadar dengan ucapannya sendiri\Nsaat bicara padaku?
Dialogue: 0,0:19:24.24,0:19:26.56,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebaiknya hentikan saja.
Dialogue: 0,0:19:27.82,0:19:29.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Beliau benar-benar kuat.
Dialogue: 0,0:19:30.39,0:19:34.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan aku tidak punya jaminan menang\Nkalau harus melawannya lagi.
Dialogue: 0,0:19:35.55,0:19:38.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, rumor seri yang beredar itu
Dialogue: 0,0:19:38.25,0:19:40.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}hasil yang kami sebarkan sendiri.
Dialogue: 0,0:19:43.24,0:19:47.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Nona Hinata,\Ntidak perlu berpura-pura manis begitu
Dialogue: 0,0:19:47.23,0:19:50.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}di hadapan Tuan Elric.
Dialogue: 0,0:19:50.29,0:19:54.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wajar saja kalau kamu terpesona\Noleh wajah tampannya.
Dialogue: 0,0:19:54.23,0:19:55.59,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku menolak.
Dialogue: 0,0:19:55.59,0:19:56.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:57.63,0:20:02.14,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Gereja Suci Barat\Ndan Kekaisaran Suci Ruberios
Dialogue: 0,0:20:02.14,0:20:05.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}telah menyepakati pakta nonagresi\Ndengan Tempest.
Dialogue: 0,0:20:05.85,0:20:08.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, ini peringatan dariku.
Dialogue: 0,0:20:08.98,0:20:11.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jangan coba-coba memancing\Namarah Raja Iblis Rimuru.
Dialogue: 0,0:20:11.86,0:20:13.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:20:13.28,0:20:15.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ka-Kamu berani memerintahku?
Dialogue: 0,0:20:18.07,0:20:23.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu, kalau ini permintaan resmi,\Nbukankah perlu mengikuti prosedur yang benar?
Dialogue: 0,0:20:23.50,0:20:25.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}I-Itu...
Dialogue: 0,0:20:25.90,0:20:27.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:20:31.86,0:20:33.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu akan menyesal, Hinata!
Dialogue: 0,0:20:35.65,0:20:40.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sayangnya, aku menaruh kepercayaan\Npada Raja Iblis Rimuru.
Dialogue: 0,0:20:50.77,0:20:55.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rencana ceroboh yang hanya menumpang\Npada situasi kebetulan
Dialogue: 0,0:20:55.10,0:20:56.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}biasanya mudah ditebak.
Dialogue: 0,0:20:57.81,0:20:58.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:21:00.62,0:21:03.30,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana kalau pembicaraan ini\Ndan rapat tadi
Dialogue: 0,0:21:03.94,0:21:07.30,dialog,,0,0,0,,{\blur3}{\fad(00,40)}sudah direncanakan seseorang sejak awal?
Dialogue: 0,0:21:11.76,0:21:14.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rasanya itu mustahil.
Dialogue: 0,0:21:19.59,0:21:22.55,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru, sudah waktunya berangkat.
Dialogue: 0,0:21:23.39,0:21:24.89,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, benar juga.
Dialogue: 0,0:21:27.69,0:21:28.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru!
Dialogue: 0,0:21:28.98,0:21:30.31,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Shion?
Dialogue: 0,0:21:31.31,0:21:34.09,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa saya disuruh jaga rumah terus?
Dialogue: 0,0:21:34.09,0:21:38.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Nona Shuna dan yang lain selalu diajak,\Ncurang banget!
Dialogue: 0,0:21:38.07,0:21:40.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ah, soal itu...
Dialogue: 0,0:21:44.90,0:21:49.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Shion, kamu bukan hanya jaga rumah!
Dialogue: 0,0:21:49.02,0:21:52.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Banyak petinggi Tempest yang sedang pergi.
Dialogue: 0,0:21:52.61,0:21:57.47,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Artinya, hanya kamu, Sekretaris Pertamaku,\Nyang bisa melindungi tempat ini!
Dialogue: 0,0:21:59.26,0:22:01.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Laksanakan dengan baik, ya?
Dialogue: 0,0:22:01.90,0:22:02.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:22:05.19,0:22:08.09,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku masih agak khawatir membawanya
Dialogue: 0,0:22:08.09,0:22:10.68,dialog,,0,0,0,,{\blur3}{\fad(00,40)}ke kota besar yang penuh manusia.
Dialogue: 0,0:22:14.24,0:22:16.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oke, semuanya sudah siap.
Dialogue: 0,0:22:17.49,0:22:19.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tolong jaga rumah, Shion.
Dialogue: 0,0:22:19.90,0:22:22.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik! Hati-hati di jalan!
Dialogue: 0,0:22:23.93,0:22:25.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ayo berangkat!
Dialogue: 0,0:22:33.34,0:22:35.59,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Menuju ke tempat dewan!
Dialogue: 0,0:24:05.88,0:24:08.80,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya, "Langkah Pertama".
