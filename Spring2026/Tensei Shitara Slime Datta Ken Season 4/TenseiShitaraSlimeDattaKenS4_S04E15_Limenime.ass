Dialogue: 0,0:00:11.49,0:00:12.89,sign,,0000,0000,0000,,300 TAHUN LALU
Dialogue: 0,0:03:28.93,0:03:31.23,sign,,0000,0000,0000,,"EPISODE 87: HAWA KEBERADAAN YANG MENCEKAM"
Dialogue: 0,0:07:15.46,0:07:18.17,sign,,0000,0000,0000,,"NEGERI EMAS EL DORADO KASTEL SPIRAL, RUANG TAKHTA"
Dialogue: 0,0:13:11.94,0:13:15.74,sign,,0000,0000,0000,,NEGARA BARAT TERTENTU, MARKAS CERBERUS
Dialogue: 0,0:24:09.33,0:24:11.01,sign,,0000,0000,0000,,SANG PAHLAWAN FAJAR, GRAN
Dialogue: 0,0:00:12.90,0:00:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Samar-samar aku ingat,
Dialogue: 0,0:00:14.70,0:00:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya saat itu aku mengamuk.
Dialogue: 0,0:00:18.12,0:00:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ada kepribadian lain\Nyang bukan diriku.
Dialogue: 0,0:00:22.88,0:00:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kalau saatnya tiba...
Dialogue: 0,0:00:25.88,0:00:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:00:27.51,0:00:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan saja padaku.
Dialogue: 0,0:00:29.42,0:00:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu tiba, aku berjanji
Dialogue: 0,0:00:31.64,0:00:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menyegel kalian dengan kekuatanku.
Dialogue: 0,0:00:36.79,0:00:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lama kemudian,\Nsosok itu menghilang dari panggung sejarah.
Dialogue: 0,0:00:43.13,0:00:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu, sudah ratusan tahun
Dialogue: 0,0:00:44.86,0:00:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak Raja Iblis Luminus menyegel\Ndan menyembunyikannya.
Dialogue: 0,0:00:50.11,0:00:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caranya bertarung waktu itu
Dialogue: 0,0:00:52.81,0:00:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pantas disebut sebagai\Nsenjata pemungkas ultima,
Dialogue: 0,0:00:56.10,0:00:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sosok yang benar-benar tidak tertandingi.
Dialogue: 0,0:01:00.95,0:01:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun Raja Iblis Luminus.
Dialogue: 0,0:01:04.45,0:01:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang disembunyikan,\Nkemungkinan besar...
Dialogue: 0,0:01:14.14,0:01:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk.
Dialogue: 0,0:01:18.39,0:01:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sudah datang, Nona Luminus.
Dialogue: 0,0:01:21.14,0:01:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinata, bagaimana keadaan Tempest?
Dialogue: 0,0:01:25.02,0:01:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya tentang apa?
Dialogue: 0,0:01:27.08,0:01:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruberios dan negara itu\Nmenandatangani perjanjian non-agresi,
Dialogue: 0,0:01:30.61,0:01:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan menjanjikan pertukaran budaya.
Dialogue: 0,0:01:33.80,0:01:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:01:35.37,0:01:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya belum ada pertukaran apa pun.
Dialogue: 0,0:01:40.01,0:01:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya...
Dialogue: 0,0:01:41.33,0:01:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen di sana nyaman sekali.
Dialogue: 0,0:01:45.72,0:01:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sukiyaki... Tempura...
Dialogue: 0,0:01:48.34,0:01:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan orkestra\Npada Festival Pendirian juga luar biasa.
Dialogue: 0,0:01:53.34,0:01:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu paham maksudku, kan?
Dialogue: 0,0:03:26.73,0:03:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}(Tensura) Bereinkarnasi Malah Menjadi Slime
Dialogue: 0,0:03:28.93,0:03:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkait para Demon yang dibawa Diablo,
Dialogue: 0,0:03:31.24,0:03:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuserahkan pada ketiga gadis kenalan lamanya\Nuntuk mengoordinasi mereka.
Dialogue: 0,0:03:38.56,0:03:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Testarossa.
Dialogue: 0,0:03:39.66,0:03:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ultima.
Dialogue: 0,0:03:40.96,0:03:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Carrera.
Dialogue: 0,0:03:42.58,0:03:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kalian akan bekerja di negeri ini,
Dialogue: 0,0:03:45.00,0:03:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memberi kalian\Nmasing-masing jabatan.
Dialogue: 0,0:03:48.10,0:03:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Testarossa, kamu akan bergabung di Dewan\Nsebagai atase diplomatik,
Dialogue: 0,0:03:51.69,0:03:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengoordinasi Negara-Negara Barat.
Dialogue: 0,0:03:54.20,0:03:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya terima dengan hormat.
Dialogue: 0,0:03:56.85,0:04:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin akan ada hal\Nyang membuat kesal di Dewan,
Dialogue: 0,0:04:00.12,0:04:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jangan lupa\Nkamu membawa nama negara ini.
Dialogue: 0,0:04:03.10,0:04:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan saja pada saya.
Dialogue: 0,0:04:05.19,0:04:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun terjadi sesuatu,
Dialogue: 0,0:04:06.87,0:04:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya tidak akan meninggalkan bukti\Nbahwa sayalah pelakunya.
Dialogue: 0,0:04:11.86,0:04:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ultima,
Dialogue: 0,0:04:13.25,0:04:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu akan jadi Jaksa Agung di "Kejaksaan"\Nyang menindak kejahatan di dalam negeri.
Dialogue: 0,0:04:17.39,0:04:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan bekerja sama dengan pihak keamanan,\Njadi mohon bantuannya.
Dialogue: 0,0:04:21.01,0:04:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma perlu mencari kejahatan\Nyang lebih besar dariku?
Dialogue: 0,0:04:23.62,0:04:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya seru juga!
Dialogue: 0,0:04:25.38,0:04:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku bukan begitu, sih.
Dialogue: 0,0:04:28.38,0:04:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Carrera, kamu jadi "Ketua Mahkamah Agung"\Ndi yudikatif.
Dialogue: 0,0:04:32.13,0:04:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patuhi hukum,\Ndan adili semua perkara dengan adil.
Dialogue: 0,0:04:35.27,0:04:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keputusanku selalu adil.
Dialogue: 0,0:04:37.67,0:04:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha sekuat tenaga\Nmemenuhi harapan Tuanku.
Dialogue: 0,0:04:41.18,0:04:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja kamu kena dendam\Ndari pihak yang kamu adili,
Dialogue: 0,0:04:44.89,0:04:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau ada yang coba menyuap...
Dialogue: 0,0:04:48.69,0:04:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun yang mencobanya, akan kuberikan\Nhukuman mati lewat keadilanku!
Dialogue: 0,0:04:54.20,0:04:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan mereka memang terbukti,\Ntapi apa akan baik-baik saja?
Dialogue: 0,0:04:58.73,0:04:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intip.
Dialogue: 0,0:04:59.95,0:05:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti akan memenuhi harapan Anda.
Dialogue: 0,0:05:03.05,0:05:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, kamu sendiri cuma mau lari\Ndari tanggung jawab, kan?
Dialogue: 0,0:05:07.24,0:05:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka sampai mengacau,\Naku lempar saja pada Diablo.
Dialogue: 0,0:05:11.13,0:05:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, mohon bantuan kalian, ya!
Dialogue: 0,0:05:14.09,0:05:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada kami.
Dialogue: 0,0:05:15.76,0:05:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah yang membuatku pusing\Nbeberapa bulan terakhir akhirnya selesai,
Dialogue: 0,0:05:20.21,0:05:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Tempest bisa melangkah\Nsebagai negara hukum.
Dialogue: 0,0:05:25.03,0:05:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak yang harus dikerjakan,
Dialogue: 0,0:05:27.33,0:05:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi untuk sementara\Nhari-hariku bisa lebih tenang.
Dialogue: 0,0:05:33.73,0:05:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas!
Dialogue: 0,0:05:35.80,0:05:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak boleh sampai tertangkap.
Dialogue: 0,0:05:40.45,0:05:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Bu Tiss?
Dialogue: 0,0:05:42.63,0:05:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang gedung sekolah yang baru ini.
Dialogue: 0,0:05:44.96,0:05:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para guru dan semuanya terlihat senang.
Dialogue: 0,0:05:48.03,0:05:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, para murid juga\Nterlihat semangat belajar.
Dialogue: 0,0:05:52.92,0:05:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi orang dewasa, ini\Nberkaitan langsung dengan pekerjaan.
Dialogue: 0,0:05:56.72,0:05:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami masih kekurangan guru,
Dialogue: 0,0:05:59.35,0:06:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi masih bisa diatasi\Nberkat bantuan para pedagang
Dialogue: 0,0:06:02.97,0:06:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Crusaders.
Dialogue: 0,0:06:05.27,0:06:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buruan!
Dialogue: 0,0:06:05.94,0:06:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tangkap, nih!
Dialogue: 0,0:06:06.76,0:06:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, tunggu, dong!
Dialogue: 0,0:06:08.90,0:06:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan anak-anak?
Dialogue: 0,0:06:10.71,0:06:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka belajar bersama dengan akrab.
Dialogue: 0,0:06:13.09,0:06:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski masih nakal seperti biasanya.
Dialogue: 0,0:06:16.68,0:06:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru!
Dialogue: 0,0:06:19.38,0:06:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa!
Dialogue: 0,0:06:27.71,0:06:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:06:28.54,0:06:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu Kumara, ya?
Dialogue: 0,0:06:31.69,0:06:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:06:33.21,0:06:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bisa berubah wujud jadi manusia!
Dialogue: 0,0:06:36.55,0:06:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul!
Dialogue: 0,0:06:38.01,0:06:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami juga mau ikut bersekolah!
Dialogue: 0,0:06:42.81,0:06:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya!
Dialogue: 0,0:06:44.12,0:06:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semangat!\N- Pak Guru!
Dialogue: 0,0:06:45.62,0:06:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chloe, ya?
Dialogue: 0,0:06:47.75,0:06:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga kamu bisa lolos dari deteksiku!
Dialogue: 0,0:06:52.25,0:06:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sekolahnya menyenangkan?
Dialogue: 0,0:06:54.69,0:06:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:06:55.57,0:06:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:56.57,0:06:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Rimuru!
Dialogue: 0,0:06:58.65,0:07:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Pak Guru sedang berkunjung!
Dialogue: 0,0:07:00.95,0:07:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau diperhatikan\Nseperti Kumara dan Chloe!
Dialogue: 0,0:07:03.62,0:07:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang, dong, kalau mau berkunjung!
Dialogue: 0,0:07:05.49,0:07:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, tuh!
Dialogue: 0,0:07:06.29,0:07:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ah, maaf, maaf!\N- Pak Guru juga sibuk, tahu.
Dialogue: 0,0:07:08.77,0:07:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak bisa jadi alasan!
Dialogue: 0,0:07:15.46,0:07:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis Leon Cromwell,
Dialogue: 0,0:07:18.17,0:07:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami datang untuk memohon\Npenghentian sementara
Dialogue: 0,0:07:22.85,0:07:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}transaksi "barang rahasia khusus".
Dialogue: 0,0:07:25.46,0:07:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:26.56,0:07:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Seperti yang Anda ketahui,
Dialogue: 0,0:07:28.93,0:07:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis Rimuru sedang naik daun\Ndi Negara-Negara Barat.
Dialogue: 0,0:07:32.42,0:07:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau menentang dan melarang keras\Npemanggilan orang dari dunia lain.
Dialogue: 0,0:07:37.14,0:07:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kami jadi kesulitan mendapatkan
Dialogue: 0,0:07:39.99,0:07:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasokan anak-anak "calon pahlawan gagal".
Dialogue: 0,0:07:45.41,0:07:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rimuru, ya?
Dialogue: 0,0:07:49.87,0:07:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu memang tidak bisa dihindari.
Dialogue: 0,0:07:52.53,0:07:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bukannya masih ada wilayah Timur?
Dialogue: 0,0:07:55.50,0:07:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, biar saya jelaskan.
Dialogue: 0,0:07:58.01,0:08:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, wilayah Timur juga\Nmulai mencurigakan.
Dialogue: 0,0:08:01.49,0:08:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka diam-diam bersiap perang,
Dialogue: 0,0:08:04.24,0:08:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi sulit mengamankan orang\Nuntuk ritual pemanggilan.
Dialogue: 0,0:08:09.14,0:08:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukan berarti transaksi berhenti.
Dialogue: 0,0:08:12.81,0:08:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ritualnya bisa dilaksanakan lagi,\Nsaya akan mengabari Anda.
Dialogue: 0,0:08:20.61,0:08:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tidak jujur saja sekalian?
Dialogue: 0,0:08:24.85,0:08:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, apa aku salah bicara?
Dialogue: 0,0:08:27.74,0:08:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritakan semua yang kamu sembunyikan.
Dialogue: 0,0:08:33.87,0:08:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda memang tajam, Raja Iblis Leon.
Dialogue: 0,0:08:37.13,0:08:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, masih ada anak-anak\Nyang dulu dilindungi Shizue Izawa.
Dialogue: 0,0:08:42.88,0:08:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizu...
Dialogue: 0,0:08:43.66,0:08:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, soal lokasinya ini\Nyang jadi masalah...
Dialogue: 0,0:08:47.83,0:08:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempest, ya?
Dialogue: 0,0:08:49.39,0:08:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebakan Anda tepat sekali.
Dialogue: 0,0:08:52.13,0:08:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami tidak bisa berbua...
Dialogue: 0,0:08:53.86,0:08:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak itu...
Dialogue: 0,0:08:55.35,0:08:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:08:56.15,0:08:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa nama mereka?
Dialogue: 0,0:08:58.40,0:09:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken Mizaru, Ryozeki, Gale Gibus,\NAlison, dan Kurobe Hoeru.
Dialogue: 0,0:09:07.41,0:09:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, itulah nama-namanya!
Dialogue: 0,0:09:10.35,0:09:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sepertinya Anda tidak tertarik pada\Nnama produk yang tidak bisa didapat.
Dialogue: 0,0:09:15.88,0:09:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa nama itu sudah benar?
Dialogue: 0,0:09:18.04,0:09:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:19.34,0:09:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan Chloe, tapi benar Kurobe, kan?
Dialogue: 0,0:09:24.45,0:09:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia terlihat begitu tertarik?
Dialogue: 0,0:09:28.10,0:09:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf, informasi saya kurang akurat.
Dialogue: 0,0:09:33.94,0:09:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:09:36.05,0:09:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau begitu, Raja Iblis Leon,\Nkami izin undur diri.
Dialogue: 0,0:09:44.10,0:09:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau mereka kami lenyapkan?
Dialogue: 0,0:09:46.32,0:09:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja.\NYang jadi masalah justru perangnya.
Dialogue: 0,0:09:51.30,0:09:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau banyak orang yang mati,
Dialogue: 0,0:09:53.62,0:09:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu bisa memanggil Demon yang merepotkan.
Dialogue: 0,0:09:56.58,0:09:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaune saja sudah sangat merepotkan kita.
Dialogue: 0,0:10:00.98,0:10:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, soal Tempest...
Dialogue: 0,0:10:03.51,0:10:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Blue Knight yang akan menyelidikinya.
Dialogue: 0,0:10:07.26,0:10:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan padamu.
Dialogue: 0,0:10:30.65,0:10:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kamu ada di mana?
Dialogue: 0,0:10:34.01,0:10:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chloe.
Dialogue: 0,0:10:36.73,0:10:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup!
Dialogue: 0,0:10:38.33,0:10:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Bawel, ah!
Dialogue: 0,0:10:40.08,0:10:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, para cowok!\NBantu piket di kelas, dong!
Dialogue: 0,0:10:43.65,0:10:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kenapa kami harus melakukan\Nhal merepotkan itu?
Dialogue: 0,0:10:47.80,0:10:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken, jangan membuat Alice marah.
Dialogue: 0,0:10:50.93,0:10:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:10:52.42,0:10:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku akan mengalahkan Alice\Ndan menjadi bos baru!
Dialogue: 0,0:10:56.02,0:10:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani juga kamu,\Nakan kutunjukkan kengerianku!
Dialogue: 0,0:10:59.81,0:11:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Kenya, sejak kapan dia\Njadi bos geng kelas?
Dialogue: 0,0:11:04.26,0:11:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Alice yang jadi ketua kelasnya, ya?
Dialogue: 0,0:11:06.69,0:11:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, siapa yang akan menang hari ini?
Dialogue: 0,0:11:09.65,0:11:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja maharani kita, Alice.
Dialogue: 0,0:11:12.07,0:11:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Kenya naksir sama Alice.
Dialogue: 0,0:11:14.52,0:11:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin menang.
Dialogue: 0,0:11:15.59,0:11:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Masa, sih?
Dialogue: 0,0:11:17.16,0:11:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gale! Jangan bicara seenaknya!
Dialogue: 0,0:11:19.99,0:11:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar itu, masa Kenya naksir sama aku?\NKalian sudah gila, ya?
Dialogue: 0,0:11:24.55,0:11:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah? Apa-apaan kamu?\N- Urusan cinta masih terlalu dini buat mereka.
Dialogue: 0,0:11:27.80,0:11:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siapa juga yang naksir?\N- Daripada itu...
Dialogue: 0,0:11:29.38,0:11:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak, sudah waktunya...
Dialogue: 0,0:11:32.89,0:11:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak boleh merepotkan guru.
Dialogue: 0,0:11:37.56,0:11:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, sudah cukup!
Dialogue: 0,0:11:42.50,0:11:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Pak Rimuru.
Dialogue: 0,0:11:44.84,0:11:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Tiss juga, terima kasih sudah\Nmengajar dengan baik.
Dialogue: 0,0:11:48.42,0:11:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Yang Mulia Rimuru ada di sini.
Dialogue: 0,0:11:52.23,0:11:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Fritz dan Bacchus.
Dialogue: 0,0:11:54.76,0:11:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih telah membantu di sini.
Dialogue: 0,0:11:58.93,0:12:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu berterima kasih.
Dialogue: 0,0:12:00.66,0:12:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan latihan Crusaders,\Nmisi ini seperti di surga dunia.
Dialogue: 0,0:12:05.75,0:12:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kami sampai rebutan.
Dialogue: 0,0:12:08.50,0:12:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dapat makan, dihormati anak-anak pula.
Dialogue: 0,0:12:12.00,0:12:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh banget bedanya sama\Nlatihan neraka Hinata.
Dialogue: 0,0:12:15.76,0:12:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Fritz, jangan dilanjut...
Dialogue: 0,0:12:18.18,0:12:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faktanya begitu, kan?
Dialogue: 0,0:12:20.02,0:12:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinata itu tidak kenal kata "ampun".
Dialogue: 0,0:12:23.05,0:12:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada latihan gila itu,
Dialogue: 0,0:12:25.22,0:12:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- mending di sini...\N- Oh...
Dialogue: 0,0:12:27.64,0:12:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:12:29.78,0:12:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh! Nona Hinata!
Dialogue: 0,0:12:31.83,0:12:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah menyesuaikan\Ndengan kemampuan kalian.
Dialogue: 0,0:12:36.20,0:12:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya itu tidak perlu lagi.
Dialogue: 0,0:12:40.49,0:12:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habis kita.
Dialogue: 0,0:12:42.01,0:12:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya...
Dialogue: 0,0:12:44.79,0:12:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, memangnya ada apa\Nsampai memanggilku ke sekolah?
Dialogue: 0,0:12:48.92,0:12:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah menyita waktumu.
Dialogue: 0,0:12:51.51,0:12:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak enak bicara di sini,\Nmari ke dungeon saja.
Dialogue: 0,0:12:56.57,0:12:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu
Dialogue: 0,0:12:58.51,0:13:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memperhatikan perkembangan mereka.
Dialogue: 0,0:13:01.59,0:13:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:03.27,0:13:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:13:04.85,0:13:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengurus kalian belakangan.
Dialogue: 0,0:13:08.02,0:13:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:13:15.74,0:13:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya berjalan lancar.
Dialogue: 0,0:13:17.87,0:13:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ini permintaanmu, tunduk pada\Norang yang membunuh Ketua Kazaream
Dialogue: 0,0:13:23.45,0:13:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejujurnya berat juga.
Dialogue: 0,0:13:25.42,0:13:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat membantu.
Dialogue: 0,0:13:26.86,0:13:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membereskan urusan di sini dulu\Nsebelum pergi dari Negara-Negara Barat.
Dialogue: 0,0:13:31.30,0:13:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misha, maaf juga, ya, sudah repot-repot\Ndatang jauh-jauh dari Timur.
Dialogue: 0,0:13:35.64,0:13:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai salah satu bos Cerberus.
Dialogue: 0,0:13:38.85,0:13:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:13:40.89,0:13:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku baru saja mengambil alih\Nmarkas Barat dari Damrada.
Dialogue: 0,0:13:44.77,0:13:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:13:45.91,0:13:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah tepat menghentikan transaksi\Ndengan Cerberus dan Raja Iblis Leon?
Dialogue: 0,0:13:50.03,0:13:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan situasi sekarang, sulit mendapatkan\Npasokan "barang rahasia khusus" itu.
Dialogue: 0,0:13:55.17,0:14:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, "calon pahlawan gagal" itu\Ntidak bisa didapat sembarang orang.
Dialogue: 0,0:14:01.29,0:14:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau perlu koneksi lagi\Ndengan Raja Iblis Leon,
Dialogue: 0,0:14:04.19,0:14:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tinggal kita buka penawaran baru lagi.
Dialogue: 0,0:14:07.30,0:14:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada maksud apa memberi tahu\Nsoal anak-anak itu?
Dialogue: 0,0:14:12.45,0:14:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma penasaran bagaimana reaksinya\Nkalau info soal anak-anak itu kubocorkan.
Dialogue: 0,0:14:17.06,0:14:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, dari reaksinya,
Dialogue: 0,0:14:19.12,0:14:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa menebak tujuan dia\Nmengumpulkan mereka?
Dialogue: 0,0:14:23.56,0:14:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:14:26.07,0:14:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang begitu, bilang dari awal, dong.
Dialogue: 0,0:14:29.71,0:14:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai panik dicurigai tadi.
Dialogue: 0,0:14:32.05,0:14:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, deh.
Dialogue: 0,0:14:33.61,0:14:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga takut Laplace salah ngomong.
Dialogue: 0,0:14:36.78,0:14:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:14:38.57,0:14:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:14:39.57,0:14:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:40.37,0:14:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian jahat banget!
Dialogue: 0,0:14:43.82,0:14:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:14:44.83,0:14:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, waktu itu...
Dialogue: 0,0:14:47.63,0:14:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:14:49.38,0:14:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bertanya untuk memastikan\Nnama anak-anak itu.
Dialogue: 0,0:14:53.66,0:14:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku menyebut nama Kurobe Hoeru,
Dialogue: 0,0:14:56.14,0:15:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bilang, "Bukan Chloe,\Ntapi benar Kurobe, kan?"
Dialogue: 0,0:15:01.52,0:15:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipikirkan, Footman,\Ndia memang agak sensitif.
Dialogue: 0,0:15:06.40,0:15:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu?
Dialogue: 0,0:15:08.08,0:15:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau roda sebab-akibat memang berputar,\Nitu bukan hal mustahil.
Dialogue: 0,0:15:12.89,0:15:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, jangan-jangan...
Dialogue: 0,0:15:16.41,0:15:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:17.53,0:15:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan besar,\Ntujuan Raja Iblis Leon adalah
Dialogue: 0,0:15:22.33,0:15:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak bernama Chloe itu.
Dialogue: 0,0:15:23.91,0:15:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius? Gawat, nih.
Dialogue: 0,0:15:27.57,0:15:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya apa?
Dialogue: 0,0:15:29.09,0:15:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau benar begitu, kita sudah melepas\Nkartu as untuk melawan Raja Iblis Leon.
Dialogue: 0,0:15:47.86,0:15:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Chloe!
Dialogue: 0,0:15:49.11,0:15:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balaskan dendam kami!
Dialogue: 0,0:15:51.36,0:15:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri satu pukulan telak pada Pak Rimuru!
Dialogue: 0,0:15:55.71,0:15:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tambah kuatnya terlalu cepat!
Dialogue: 0,0:15:58.41,0:16:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sekarang lebih kuat dari Holy Knight biasa.\N- Semangat!
Dialogue: 0,0:16:03.89,0:16:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama Chloe... kemampuannya beda level.
Dialogue: 0,0:16:15.16,0:16:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa gawat kalau tidak serius.
Dialogue: 0,0:16:18.97,0:16:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku tidak boleh
Dialogue: 0,0:16:20.67,0:16:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlihat payah!
Dialogue: 0,0:16:28.75,0:16:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah.
Dialogue: 0,0:16:30.56,0:16:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Guru kuat banget!
Dialogue: 0,0:16:33.57,0:16:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bimbingannya!
Dialogue: 0,0:16:40.83,0:16:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku paham maksudmu.
Dialogue: 0,0:16:43.51,0:16:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka benar-benar bertambah kuat.
Dialogue: 0,0:16:45.45,0:16:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka masih sangat muda.
Dialogue: 0,0:16:48.48,0:16:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu juga tahu keadaannya,
Dialogue: 0,0:16:50.96,0:16:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar mereka tetap berada\Ndi jalan yang benar.
Dialogue: 0,0:16:54.93,0:16:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, di kota ini banyak senior\Nyang bisa membimbing.
Dialogue: 0,0:16:59.09,0:17:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pastikan mereka tidak salah jalan.
Dialogue: 0,0:17:05.23,0:17:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti akan bilang begitu.
Dialogue: 0,0:17:07.81,0:17:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu saja alasanmu datang hari ini?
Dialogue: 0,0:17:11.44,0:17:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, masih ada satu lagi.
Dialogue: 0,0:17:13.66,0:17:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah, ini yang jadi topik utamanya.
Dialogue: 0,0:17:17.33,0:17:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Luminus terus menagih\Nkapan pertukaran musik diadakan.
Dialogue: 0,0:17:22.00,0:17:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, soal itu.
Dialogue: 0,0:17:23.95,0:17:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya beliau sangat menyukai\Npertunjukan musik kalian.
Dialogue: 0,0:17:27.33,0:17:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Naku akan segera mampir ke sana.
Dialogue: 0,0:17:31.01,0:17:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Rimuru!
Dialogue: 0,0:17:33.09,0:17:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke suatu tempat bersama Kak Hinata?
Dialogue: 0,0:17:35.73,0:17:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, rencananya aku mau mengadakan\Npertukaran musik di Ruberios.
Dialogue: 0,0:17:40.84,0:17:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertukaran musik?\NAku mau ikut!
Dialogue: 0,0:17:44.16,0:17:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:17:45.13,0:17:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka berdua ikut, aku juga ikut!
Dialogue: 0,0:17:48.09,0:17:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:17:49.21,0:17:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau ikut.
Dialogue: 0,0:17:50.79,0:17:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir kalau cuma mereka yang pergi.
Dialogue: 0,0:17:54.05,0:17:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga,\Nbisa sekalian dijadikan studi tur.
Dialogue: 0,0:18:01.18,0:18:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin ikut.
Dialogue: 0,0:18:05.49,0:18:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumara, tidak perlu sungkan.
Dialogue: 0,0:18:08.22,0:18:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit egois tidak masalah.
Dialogue: 0,0:18:12.17,0:18:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua pergi sama-sama saja!
Dialogue: 0,0:18:13.57,0:18:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:18:15.54,0:18:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka sekali memanjakan mereka.
Dialogue: 0,0:18:22.30,0:18:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, ini mungkin bisa dimanfaatkan.
Dialogue: 0,0:18:25.18,0:18:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sesuai perkiraan,
Dialogue: 0,0:18:27.27,0:18:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa mengadu domba Rimuru\Ndan Raja Iblis Leon.
Dialogue: 0,0:18:31.23,0:18:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dimanfaatkan untuk pekerjaan itu juga.
Dialogue: 0,0:18:34.86,0:18:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan apa?
Dialogue: 0,0:18:37.35,0:18:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, permintaan dari Granville.
Dialogue: 0,0:18:40.35,0:18:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Bos sempat pergi\Nke tempatnya Granville, ya?
Dialogue: 0,0:18:44.40,0:18:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:18:45.78,0:18:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya,
Dialogue: 0,0:18:47.44,0:18:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi harus mengerjakan satu tugas lagi\Nsebelum berangkat ke Timur.
Dialogue: 0,0:18:53.09,0:18:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu. Jadi, itulah akhir Maribel.
Dialogue: 0,0:18:57.17,0:18:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga berat buatku.
Dialogue: 0,0:18:59.58,0:19:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dikendalikan dan dipaksa bertarung\Nmelawan Raja Iblis Rimuru.
Dialogue: 0,0:19:04.05,0:19:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana keadaan Raja Iblis Rimuru?
Dialogue: 0,0:19:06.55,0:19:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa.
Dialogue: 0,0:19:08.52,0:19:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kamu mencurigaiku,
Dialogue: 0,0:19:10.95,0:19:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi semuanya sudah kuatur seolah-olah\NMaribel pelakunya.
Dialogue: 0,0:19:14.67,0:19:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan menyalahkanku.
Dialogue: 0,0:19:22.21,0:19:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah harapan umat manusia musnah,
Dialogue: 0,0:19:25.23,0:19:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan melancarkan balas dendam
Dialogue: 0,0:19:28.23,0:19:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan harta karun\Nyang disembunyikan Luminus.
Dialogue: 0,0:19:30.99,0:19:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Luminus?\NTerus, dia bilang harta karun?
Dialogue: 0,0:19:34.61,0:19:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa yang kamu bicarakan,
Dialogue: 0,0:19:36.42,0:19:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong jangan libatkan aku lagi.
Dialogue: 0,0:19:41.86,0:19:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti sudah tahu, kan?
Dialogue: 0,0:19:45.80,0:19:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal apa?
Dialogue: 0,0:19:47.80,0:19:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahwa dewa agama Luminus\Nadalah Raja Iblis Luminus sendiri,
Dialogue: 0,0:19:52.88,0:19:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bahwa akulah pemimpin Tujuh Luminari.
Dialogue: 0,0:19:57.68,0:20:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu mengakuinya.
Dialogue: 0,0:20:00.65,0:20:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sempat curiga\Nsoal Tujuh Luminari itu.
Dialogue: 0,0:20:04.95,0:20:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang kamu rencanakan\Nsampai memberi tahu semua ini?
Dialogue: 0,0:20:10.20,0:20:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak merencanakan apa-apa.
Dialogue: 0,0:20:12.85,0:20:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kehilangan Maribel,
Dialogue: 0,0:20:15.15,0:20:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada lagi yang bisa kupercayakan\Nmasa depan Negara-Negara Barat
Dialogue: 0,0:20:19.49,0:20:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan umat manusia ini, selain dirimu.
Dialogue: 0,0:20:22.59,0:20:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya itu bisa diurus Rimuru?
Dialogue: 0,0:20:26.16,0:20:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian Dewan sudah menjadi miliknya.
Dialogue: 0,0:20:30.78,0:20:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih naif rupanya.
Dialogue: 0,0:20:34.85,0:20:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keberadaan Raja Iblis bernama Rimuru itu\Nsama sekali tidak boleh dibiarkan.
Dialogue: 0,0:20:40.23,0:20:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki, aku tidak memintamu memercayaiku.
Dialogue: 0,0:20:44.01,0:20:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mari kita bentuk aliansi,
Dialogue: 0,0:20:46.49,0:20:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya untuk saat ini saja.
Dialogue: 0,0:20:50.07,0:20:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa untungnya bagiku?
Dialogue: 0,0:20:53.04,0:20:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuserahkan harta karun\Nyang disembunyikan Luminus padamu.
Dialogue: 0,0:21:02.75,0:21:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik juga ceritanya,
Dialogue: 0,0:21:05.50,0:21:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak senaif itu\Nuntuk langsung percaya.
Dialogue: 0,0:21:08.29,0:21:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bergerak lebih dulu.
Dialogue: 0,0:21:11.26,0:21:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, bertindaklah sesuai keadaan.
Dialogue: 0,0:21:16.48,0:21:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sejauh itu, apa untungnya bagimu?
Dialogue: 0,0:21:19.68,0:21:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya Raja Iblis Luminus itu majikanmu?
Dialogue: 0,0:21:23.09,0:21:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dicampakkan olehnya.
Dialogue: 0,0:21:26.00,0:21:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Nona Luminus sedang berusaha\Nbersekutu dengan Raja Iblis Rimuru.
Dialogue: 0,0:21:30.61,0:21:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Ndia pun tak lain adalah musuhku.
Dialogue: 0,0:21:36.38,0:21:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kukira kamu cuma kakek tua\Nyang sudah layu,
Dialogue: 0,0:21:41.27,0:21:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau sampai sebegitunya,\Naku akan mencoba bertaruh.
Dialogue: 0,0:21:46.55,0:21:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan jadi kerja sama sementara,\Nsekaligus yang terakhir,
Dialogue: 0,0:21:50.93,0:21:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku menantikannya.
Dialogue: 0,0:21:53.18,0:21:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, di mana harta karun\NRaja Iblis Luminus itu?
Dialogue: 0,0:21:57.68,0:21:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun itu...
Dialogue: 0,0:22:00.32,0:22:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di kastel Raja Iblis Luminus.
Dialogue: 0,0:22:02.69,0:22:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:22:04.08,0:22:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:22:06.82,0:22:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medan perangnya ada di Ruberios.
Dialogue: 0,0:22:14.45,0:22:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Rimuru benar-benar akan dibunuh?
Dialogue: 0,0:22:18.01,0:22:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah berubah total.
Dialogue: 0,0:22:28.88,0:22:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku ingin cepat-cepat memelukmu.
Dialogue: 0,0:24:05.92,0:24:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Sang Pahlawan Fajar, Gran".
