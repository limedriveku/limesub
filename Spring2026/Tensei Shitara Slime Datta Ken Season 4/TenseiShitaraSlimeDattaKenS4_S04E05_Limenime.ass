Dialogue: 0,0:02:30.00,0:02:35.05,tanda-6,,0,0,0,,{\fad(1000,438)\fs80\blur0.5\bord2\shad2\b0\pos(1798,918)}Episode 77: Langkah Pertama
Dialogue: 0,0:24:04.98,0:24:10.92,tanda-5,,0,0,0,,{\fad(200,0)\blur0.5\fs100\bord0\shad0\pos(960,360)\c&HD9ECF0&}Dewan Negara-Negara Barat
Dialogue: 0,0:00:18.91,0:00:20.58,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selamat datang di Ingrassia.
Dialogue: 0,0:00:21.19,0:00:22.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:00:24.90,0:00:26.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:00:26.61,0:00:29.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dilihat begini,\Nternyata Tempest besar juga.
Dialogue: 0,0:00:30.22,0:00:31.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:31.66,0:00:35.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Soal luas wilayah,\Nmungkin seukuran negara-negara barat?
Dialogue: 0,0:00:35.76,0:00:38.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kita diterima besok,
Dialogue: 0,0:00:38.10,0:00:41.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}mimpi Anda akan jadi kenyataan.
Dialogue: 0,0:00:41.10,0:00:42.47,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:42.47,0:00:45.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Langkah pertama menuju kemakmuran bersama\Nbagi manusia dan monster.
Dialogue: 0,0:00:49.69,0:00:50.97,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Waktunya telah tiba.
Dialogue: 0,0:00:51.97,0:00:56.54,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Akhirnya, rapat penentuan yang akan\Nmemutuskan bergabungnya Tempest
Dialogue: 0,0:00:56.54,0:00:58.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}ke Dewan Negara-Negara\NBarat akan digelar besok.
Dialogue: 0,0:02:27.33,0:02:30.00,dialog,,0,0,0,,{\blur3}{\fad(00,40)}(Tensura) Bereinkarnasi Malah Menjadi Slime
Dialogue: 0,0:02:36.15,0:02:37.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:02:37.22,0:02:39.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ramai seperti biasanya.
Dialogue: 0,0:02:48.32,0:02:49.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:02:49.86,0:02:52.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:02:53.34,0:02:55.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Manis sekali pakaian ini!
Dialogue: 0,0:02:56.39,0:02:58.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mumpung di sini, pilihlah yang kamu mau.
Dialogue: 0,0:02:59.77,0:03:01.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apakah boleh?
Dialogue: 0,0:03:01.24,0:03:02.55,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:03:02.55,0:03:05.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hadiah dariku untuk bantuanmu selama ini.
Dialogue: 0,0:03:05.29,0:03:07.36,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:03:07.36,0:03:09.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pilih yang mana, ya?
Dialogue: 0,0:03:11.26,0:03:12.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalian juga boleh pilih.
Dialogue: 0,0:03:12.99,0:03:14.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh, saya juga?
Dialogue: 0,0:03:14.69,0:03:16.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya tidak usah.
Dialogue: 0,0:03:16.38,0:03:18.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu sungkan.
Dialogue: 0,0:03:18.27,0:03:21.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pakaian kalian termasuk mencolok di sini.
Dialogue: 0,0:03:24.16,0:03:26.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah kalau begitu.
Dialogue: 0,0:03:37.26,0:03:39.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Syukurlah dia terlihat bahagia.
Dialogue: 0,0:03:39.71,0:03:42.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Soalnya dia yang paling bekerja keras.
Dialogue: 0,0:03:42.99,0:03:45.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah menyiapkan setelan untuk rapat,
Dialogue: 0,0:03:45.81,0:03:48.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}tapi tidak punya banyak baju sehari-hari.
Dialogue: 0,0:03:48.37,0:03:51.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sesekali, bolehlah memberinya hadiah.
Dialogue: 0,0:03:52.63,0:03:56.30,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rangkul dia sekarang,\Nbiar ada pegangan saat kepepet nanti, ya?
Dialogue: 0,0:03:56.88,0:03:59.51,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu bicara sesuatu, Benimaru?
Dialogue: 0,0:03:59.51,0:04:00.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:04:05.53,0:04:06.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:04:06.82,0:04:08.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:04:08.27,0:04:11.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatan bagus!\NCocok buatmu, Shuna!
Dialogue: 0,0:04:12.27,0:04:13.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Senang mendengarnya!
Dialogue: 0,0:04:14.27,0:04:19.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pakaian miko memang bagus, tapi\Nyang kasual tidak kalah bagus dan segar!
Dialogue: 0,0:04:22.53,0:04:24.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya mencoba yang ini.
Dialogue: 0,0:04:27.69,0:04:29.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kira-kira seperti ini?
Dialogue: 0,0:04:32.64,0:04:34.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, lumayan.
Dialogue: 0,0:04:34.45,0:04:36.55,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kesan buat kami asal-asalan saja, nih?
Dialogue: 0,0:04:36.55,0:04:38.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Siapa suruh kalian lama banget pilihnya!
Dialogue: 0,0:04:39.45,0:04:40.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:40.65,0:04:43.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya bingung mana yang bagus.
Dialogue: 0,0:04:43.11,0:04:47.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Padahal semuanya cocok,\Ndasar cowok-cowok ganteng.
Dialogue: 0,0:04:47.02,0:04:51.35,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, Anda tidak ikut mencoba juga?
Dialogue: 0,0:04:52.15,0:04:55.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga, aku mau pilih juga, deh.
Dialogue: 0,0:04:55.19,0:04:56.94,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dengar!
Dialogue: 0,0:04:56.94,0:05:00.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Memilih pakaian itu harus cepat!\NAda metode patennya!
Dialogue: 0,0:05:00.88,0:05:01.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:05:01.91,0:05:03.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Metode paten?
Dialogue: 0,0:05:03.70,0:05:07.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pak, boleh minta tolong pilihkan\Nyang cocok untukku?
Dialogue: 0,0:05:07.06,0:05:08.31,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Malah menyuruh orang!
Dialogue: 0,0:05:27.66,0:05:29.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Perpaduan pahit dan manis.
Dialogue: 0,0:05:29.81,0:05:32.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kopi cocoknya untuk orang dewasa.
Dialogue: 0,0:05:32.85,0:05:36.40,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Siapa yang orang dewasa?\NHitungannya kopi susu itu.
Dialogue: 0,0:05:37.67,0:05:39.84,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Be-Berisik, ah!
Dialogue: 0,0:05:39.84,0:05:42.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku cuma mengikuti suasana saja!
Dialogue: 0,0:05:42.65,0:05:45.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi pakaiannya seperti anak-anak.
Dialogue: 0,0:05:45.07,0:05:45.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:45.91,0:05:49.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata ini memang pakaian anak-anak!
Dialogue: 0,0:05:49.11,0:05:52.46,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dasar pelayan toko itu!\NSialan!
Dialogue: 0,0:05:52.46,0:05:54.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Cocok sekali untuk Anda.
Dialogue: 0,0:05:54.33,0:05:57.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya kira Anda menyukainya.
Dialogue: 0,0:05:57.17,0:05:58.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sependapat.
Dialogue: 0,0:06:01.38,0:06:02.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:06:07.10,0:06:09.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Penghalang redam suara diaktifkan.
Dialogue: 0,0:06:11.02,0:06:13.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih sudah datang.
Dialogue: 0,0:06:13.95,0:06:17.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada yang ingin kutanyakan soal rapat besok.
Dialogue: 0,0:06:18.29,0:06:22.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Keanggotaan Tempest sudah disetujui\Ndalam rapat istimewa.
Dialogue: 0,0:06:22.28,0:06:27.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Setelah sesi tanya jawab denganmu,\Nkeputusan resminya akan keluar besok.
Dialogue: 0,0:06:27.53,0:06:30.54,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tepat seperti yang kuduga.
Dialogue: 0,0:06:30.54,0:06:33.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu baru keputusan sementara.
Dialogue: 0,0:06:33.10,0:06:36.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin akan ada pertanyaan\Nyang menyulut emosimu.
Dialogue: 0,0:06:37.22,0:06:39.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu pikir aku gampang naik darah?
Dialogue: 0,0:06:39.65,0:06:44.55,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tenang saja, tidak sepertimu,\Naku orang dewasa yang pandai bersosialisasi.
Dialogue: 0,0:06:44.55,0:06:45.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:45.86,0:06:47.70,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mengajak ribut, akan kuladeni.
Dialogue: 0,0:06:47.70,0:06:49.85,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sendirinya emosian.
Dialogue: 0,0:06:51.85,0:06:53.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:06:53.64,0:06:57.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada orang-orang dungu\Nyang sedang merencanakan sesuatu.
Dialogue: 0,0:06:57.13,0:06:58.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Berhati-hatilah.
Dialogue: 0,0:06:59.52,0:07:02.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pasti terjadi sesuatu antara dia dan mereka.
Dialogue: 0,0:07:04.59,0:07:07.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hotel yang mereka siapkan pun bintang lima.
Dialogue: 0,0:07:07.99,0:07:10.08,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pasti ada maunya.
Dialogue: 0,0:07:10.08,0:07:13.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Meski Souei sudah menyelidiki hal itu.
Dialogue: 0,0:07:13.25,0:07:14.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:14.45,0:07:17.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada yang ingin saya pastikan soal itu.
Dialogue: 0,0:07:18.75,0:07:24.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya ada beberapa anggota dewan\Nyang berencana memanfaatkan negara kami.
Dialogue: 0,0:07:24.17,0:07:27.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mereka terus-menerus mengungkit soal...
Dialogue: 0,0:07:27.01,0:07:30.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kekuatan pertahanan\Nuntuk melawan Kekaisaran Timur, bukan?
Dialogue: 0,0:07:30.88,0:07:31.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:32.26,0:07:36.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Misalnya kita dimintai tolong\Nkalau kekaisaran menyerang?
Dialogue: 0,0:07:36.79,0:07:37.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:37.64,0:07:43.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh, kalau soal kekaisaran,\Ntidak ada yang perlu dikhawatirkan.
Dialogue: 0,0:07:43.95,0:07:45.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Boleh tanya alasannya?
Dialogue: 0,0:07:45.65,0:07:47.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Simpel saja.
Dialogue: 0,0:07:47.37,0:07:51.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kuncinya, berpikir\Ndari sudut pandang kekaisaran.
Dialogue: 0,0:07:51.49,0:07:56.00,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagi mereka, ada tiga rute invasi\Nmenuju Negara-Negara Barat.
Dialogue: 0,0:07:56.43,0:08:00.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pertama, jalur laut, tapi di sana\Ndihuni monster laut raksasa.
Dialogue: 0,0:08:00.75,0:08:05.76,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kedua, jalur pegunungan melewati\NPegunungan Canaat milik Dwargon.
Dialogue: 0,0:08:06.21,0:08:09.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu wilayah yang disebut "Sarang Naga".
Dialogue: 0,0:08:09.77,0:08:12.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terakhir, Hutan Agung Jura kita.
Dialogue: 0,0:08:12.95,0:08:16.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itu wilayahku sebagai seorang Raja Iblis.
Dialogue: 0,0:08:16.77,0:08:21.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ditambah, Tuan Veldora sudah bangkit.
Dialogue: 0,0:08:22.33,0:08:24.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi kekaisaran tidak bisa gegabah.
Dialogue: 0,0:08:24.90,0:08:26.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kira-kira begitu.
Dialogue: 0,0:08:27.04,0:08:28.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:08:28.95,0:08:32.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, pergerakan kekaisaran\Nmemang mencurigakan.
Dialogue: 0,0:08:32.88,0:08:35.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya kita perlu menyelidikinya.
Dialogue: 0,0:08:35.28,0:08:38.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya aku setuju dengan Rimuru...
Dialogue: 0,0:08:38.29,0:08:41.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, baiklah.
Dialogue: 0,0:08:41.03,0:08:44.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau situasinya seperti itu,\Nkami juga akan menyelidiki.
Dialogue: 0,0:08:44.62,0:08:46.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:47.02,0:08:49.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mereka berhati-hati sekali.
Dialogue: 0,0:08:50.45,0:08:51.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lapor.
Dialogue: 0,0:08:51.23,0:08:54.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Situasi saat ini memang tidak ada masalah.
Dialogue: 0,0:08:54.07,0:08:58.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tergantung informasi terbaru,\Nakan diperlukan penyesuaian rencana.
Dialogue: 0,0:08:58.81,0:09:01.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu, ada sedikit saran.
Dialogue: 0,0:09:03.81,0:09:07.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Nona Hinata, boleh aku minta tolong sesuatu?
Dialogue: 0,0:09:07.53,0:09:09.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba sopan begitu?
Dialogue: 0,0:09:10.00,0:09:13.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku mau minta tolong selidiki\Ninternal Dwargon juga.
Dialogue: 0,0:09:14.42,0:09:15.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dwargon?
Dialogue: 0,0:09:15.74,0:09:19.94,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ibu kota yang dibangun dengan merombak\Ngua besar di Pegunungan Canaat, ya?
Dialogue: 0,0:09:21.85,0:09:23.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Masuk akal.
Dialogue: 0,0:09:23.25,0:09:27.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada kemungkinan negara itu\Nmenjadi rute invasi juga.
Dialogue: 0,0:09:27.90,0:09:32.30,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu ini meski terlihat ceroboh,\Nternyata tidak bisa diremehkan.
Dialogue: 0,0:09:33.68,0:09:35.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:09:35.37,0:09:37.89,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Padahal itu saran dari Kak Raphael.
Dialogue: 0,0:09:38.31,0:09:39.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru.
Dialogue: 0,0:09:39.65,0:09:40.68,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:09:40.68,0:09:41.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:09:42.96,0:09:46.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin membagikan informasi pada kalian.
Dialogue: 0,0:09:47.21,0:09:51.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Masih ingat orang menyebalkan\Nsaat Festival Pendirian?
Dialogue: 0,0:09:51.91,0:09:54.32,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Duke Muese, bukan?
Dialogue: 0,0:09:55.07,0:09:58.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dia telah dibunuh.
Dialogue: 0,0:10:01.31,0:10:03.54,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kemungkinan untuk membungkamnya.
Dialogue: 0,0:10:04.09,0:10:08.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Atasannya jelas berasal\Ndari negara-negara barat.
Dialogue: 0,0:10:09.35,0:10:12.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kemungkinan besar juga\Nada hubungannya dengan dewan.
Dialogue: 0,0:10:13.09,0:10:16.94,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Metode pembunuhannya diduga\Ndilakukan dari jarak jauh.
Dialogue: 0,0:10:16.94,0:10:20.54,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Diduga?\NKamu pun tidak bisa memastikannya?
Dialogue: 0,0:10:20.54,0:10:21.52,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:21.92,0:10:23.91,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saat sedang mengawasi, tiba-tiba saja.
Dialogue: 0,0:10:23.91,0:10:27.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sesaat setelah itu,\Nada suara seperti sesuatu yang meletus.
Dialogue: 0,0:10:28.25,0:10:30.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Suara?\NSetelah dia mati?
Dialogue: 0,0:10:30.88,0:10:31.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:31.86,0:10:35.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa tidak ada jejak sihir atau auranya?
Dialogue: 0,0:10:35.24,0:10:37.04,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sama sekali tidak ada.
Dialogue: 0,0:10:37.04,0:10:40.67,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Soal jejak, hanya ada lubang di dahinya.
Dialogue: 0,0:10:41.75,0:10:43.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lubang di dahinya?
Dialogue: 0,0:10:44.58,0:10:46.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Luka tembakan?
Dialogue: 0,0:10:46.42,0:10:48.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kedengarannya begitu.
Dialogue: 0,0:10:48.16,0:10:51.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Suara yang terdengar setelahnya\Nterasa janggal.
Dialogue: 0,0:10:51.82,0:10:54.68,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa itu luka tembakan?
Dialogue: 0,0:10:55.24,0:10:57.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Iya juga.
Dialogue: 0,0:10:57.82,0:11:00.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dunia ini belum pernah\Nmelihat senjata api, ya?
Dialogue: 0,0:11:01.75,0:11:03.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kira-kira seperti ini.
Dialogue: 0,0:11:03.68,0:11:04.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:11:04.98,0:11:06.19,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi ini...
Dialogue: 0,0:11:06.19,0:11:09.05,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya saya juga bisa menggunakan ini.
Dialogue: 0,0:11:09.05,0:11:12.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Gadis yang menakutkan!\NDia baru saja bilang hal yang ngeri!
Dialogue: 0,0:11:18.51,0:11:22.08,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih informasinya.\NTolong bantuannya untuk rapat besok.
Dialogue: 0,0:11:22.08,0:11:25.21,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya, kita harus berhati-hati.
Dialogue: 0,0:11:25.21,0:11:27.58,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kumohon, jangan sampai terpancing emosi, ya.
Dialogue: 0,0:11:27.58,0:11:31.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebegitu khawatirnya, ya?\NTenang saja.
Dialogue: 0,0:11:36.58,0:11:39.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saatnya kembali ke hotel.
Dialogue: 0,0:11:39.44,0:11:42.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kita perlu istirahat\Nuntuk menghadapi rapat besok.
Dialogue: 0,0:11:42.77,0:11:43.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:43.72,0:11:45.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lihat anak itu!
Dialogue: 0,0:11:45.01,0:11:46.53,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Manisnya!
Dialogue: 0,0:11:46.53,0:11:49.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dia pakai ponco!
Dialogue: 0,0:11:50.02,0:11:53.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebelum itu, aku mau mengeluh ke toko baju.
Dialogue: 0,0:11:58.09,0:12:02.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan melihat pergerakan Raja\NIblis Rimuru di rapat dewan nanti.
Dialogue: 0,0:12:03.25,0:12:09.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Lalu mencari cara yang pasti dan aman\Nuntuk mengendalikan Raja Iblis itu.
Dialogue: 0,0:12:10.02,0:12:13.09,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Persetujuan keanggotaannya itu cuma umpan?
Dialogue: 0,0:12:13.58,0:12:14.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:15.09,0:12:17.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mustahil aku mau menerimanya.
Dialogue: 0,0:12:17.93,0:12:20.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah menyiapkan berbagai rencana.
Dialogue: 0,0:12:20.37,0:12:22.95,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan tidak perlu sampai\Nmenggerakkan Yuuki.
Dialogue: 0,0:12:24.24,0:12:29.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Raja Iblis Rimuru akan mengubur\Nidealismenya sendiri nanti.
Dialogue: 0,0:12:30.35,0:12:34.24,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Negara-Negara Barat tidaklah bersatu.
Dialogue: 0,0:12:34.24,0:12:38.48,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terutama Ingrassia,\Nmereka mati-matian menghimpun kekuatan
Dialogue: 0,0:12:38.48,0:12:41.35,dialog,,0,0,0,,{\blur3}{\fad(00,40)}demi melawan keluarga Rozzo kita.
Dialogue: 0,0:12:41.87,0:12:45.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maksudmu para Inkuisitor Sihir Raja Aegil?
Dialogue: 0,0:12:45.25,0:12:47.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu sudah memperhitungkannya?
Dialogue: 0,0:12:47.29,0:12:48.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:12:50.23,0:12:53.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Berhati-hatilah, Maribel.
Dialogue: 0,0:12:56.24,0:12:57.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamulah
Dialogue: 0,0:12:58.57,0:13:00.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}harapan umat manusia.
Dialogue: 0,0:13:05.42,0:13:08.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya Raja Iblis Rimuru\Nsudah keluar dari hotel.
Dialogue: 0,0:13:09.14,0:13:11.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang sedang menuju markas besar dewan.
Dialogue: 0,0:13:13.29,0:13:14.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:13:19.99,0:13:21.97,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dari Kakek.
Dialogue: 0,0:13:21.97,0:13:26.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Beliau mengirimkannya bersama camilan\Ndan bilang sangat menantikan hasilnya.
Dialogue: 0,0:13:27.15,0:13:28.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu mau juga?
Dialogue: 0,0:13:29.23,0:13:31.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, aku terima.
Dialogue: 0,0:13:32.79,0:13:36.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku harus menulis balasan\Nyang bagus untuk Kakek.
Dialogue: 0,0:13:36.79,0:13:39.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar, kan, Johann?
Dialogue: 0,0:13:50.40,0:13:53.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kamu yakin bersikap begitu pada Lima Tetua?
Dialogue: 0,0:13:53.90,0:13:56.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Biar saja dia diperlakukan begitu.
Dialogue: 0,0:13:58.21,0:14:02.25,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, kamu datang jauh-jauh\Nuntuk menyalamiku?
Dialogue: 0,0:14:02.93,0:14:06.73,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah mendapatkan apa\Nyang kamu inginkan, Maribel.
Dialogue: 0,0:14:06.73,0:14:08.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan sampai harus ke Sarang Naga.
Dialogue: 0,0:14:08.49,0:14:12.00,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh! Yuuki, kamu memang hebat.
Dialogue: 0,0:14:12.38,0:14:17.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekuat apa pun itu, bukannya percuma\Nkalau tidak bisa dikendalikan?
Dialogue: 0,0:14:17.49,0:14:20.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sebanyak apa pun kartu di tangan,\Nrasanya selalu kurang.
Dialogue: 0,0:14:21.02,0:14:24.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Waktu kita tinggal sedikit.
Dialogue: 0,0:14:25.54,0:14:28.35,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Manusia, raja iblis...
Dialogue: 0,0:14:28.35,0:14:31.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aturan di dunia ini tidak masuk akal.
Dialogue: 0,0:14:31.74,0:14:36.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Makanya kamu ingin jadi\Npenguasa dunia ini, kan?
Dialogue: 0,0:14:38.58,0:14:41.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tetap saja aku butuh jaminan.
Dialogue: 0,0:14:45.20,0:14:47.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dasar gadis kecil!
Dialogue: 0,0:14:47.10,0:14:49.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak boleh gagal.
Dialogue: 0,0:14:54.96,0:14:57.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya rasa ini tidak akan mudah.
Dialogue: 0,0:14:57.71,0:15:02.71,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Begitulah, dari awal kita tidak bisa\Nberharap banyak dari mereka.
Dialogue: 0,0:15:03.63,0:15:04.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:15:10.85,0:15:12.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yang Mulia Rimuru!
Dialogue: 0,0:15:12.97,0:15:14.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru!
Dialogue: 0,0:15:14.27,0:15:15.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Wah, wah!
Dialogue: 0,0:15:15.98,0:15:19.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Senang bertemu dengan Anda di sini.\NFestival Pendiriannya luar biasa!
Dialogue: 0,0:15:19.87,0:15:22.45,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hidangannya juga menakjubkan!
Dialogue: 0,0:15:22.45,0:15:25.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya harap kita bisa makin dekat\Nuntuk ke depannya!
Dialogue: 0,0:15:25.99,0:15:29.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Malah disambut dengan ramah?
Dialogue: 0,0:15:29.34,0:15:32.99,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sama-sama, ke depannya\Nakan sering diadakan lagi.
Dialogue: 0,0:15:32.99,0:15:34.50,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ehem!
Dialogue: 0,0:15:35.18,0:15:37.75,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru terlihat kerepotan.
Dialogue: 0,0:15:38.14,0:15:42.62,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Para negara kecil ini\Ntidak sadar posisi, ya?
Dialogue: 0,0:15:42.62,0:15:45.76,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar, mereka sama sekali\Ntidak paham tata krama.
Dialogue: 0,0:15:45.76,0:15:48.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apa-apaan mereka?
Dialogue: 0,0:15:48.10,0:15:50.64,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mereka para dewan dari negara besar.
Dialogue: 0,0:15:50.64,0:15:54.56,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh, kudengar posisi dewan itu setara,
Dialogue: 0,0:15:54.98,0:15:56.81,dialog,,0,0,0,,{\blur3}{\fad(00,40)}ternyata cuma di atas kertas.
Dialogue: 0,0:15:56.81,0:15:58.66,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sungguh...
Dialogue: 0,0:15:58.66,0:16:03.69,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada gunanya berdiskusi\Ndengan orang-orang seperti mereka.
Dialogue: 0,0:16:03.69,0:16:06.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Maksudnya orang-orang seperti mereka?
Dialogue: 0,0:16:06.57,0:16:08.42,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh, maaf.
Dialogue: 0,0:16:08.42,0:16:12.65,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Apakah kata-kataku terlalu berbelit-belit\Nuntuk dimengerti monster sepertimu?
Dialogue: 0,0:16:12.65,0:16:16.83,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana kalau kami ajarkan sedikit\Ntata krama bangsawan kepadamu?
Dialogue: 0,0:16:19.44,0:16:22.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ra-Rasanya kesal juga.
Dialogue: 0,0:16:22.34,0:16:25.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong, soal kereta sihir itu...
Dialogue: 0,0:16:25.90,0:16:29.34,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kudengar Anda membuat sesuatu yang menarik.
Dialogue: 0,0:16:29.34,0:16:32.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Biar negara kami yang mengelola\Ndistribusinya untuk Anda.
Dialogue: 0,0:16:33.21,0:16:36.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eng, ada urutannya untuk pemasangan rel...
Dialogue: 0,0:16:36.98,0:16:40.40,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu memikirkan hal semacam itu.
Dialogue: 0,0:16:40.40,0:16:42.52,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh? Bukan begitu...
Dialogue: 0,0:16:42.52,0:16:45.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Negara kami menginginkan\Nsenjata buatan negaramu.
Dialogue: 0,0:16:45.49,0:16:48.08,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tentu, jangan lupa membalas budi.
Dialogue: 0,0:16:48.08,0:16:52.27,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sudah, jangan bahas\Nhal tidak elegan di sini.
Dialogue: 0,0:16:55.04,0:16:57.52,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Percuma, mereka tidak nyambung\Ndiajak bicara.
Dialogue: 0,0:16:58.16,0:17:01.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, aku harus menggunakan\Njurus pemungkas!
Dialogue: 0,0:17:02.73,0:17:04.21,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kami akan mempertimbangkannya.
Dialogue: 0,0:17:04.21,0:17:07.02,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kata-kata yang sungguh melegakan.
Dialogue: 0,0:17:07.02,0:17:08.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kami mengharapkan Anda.
Dialogue: 0,0:17:14.65,0:17:16.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yakin dibiarkan begitu saja?
Dialogue: 0,0:17:16.72,0:17:19.61,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Rasanya janggal membiarkan sampah\Nberkeliaran begitu saja.
Dialogue: 0,0:17:19.61,0:17:21.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga...
Dialogue: 0,0:17:21.23,0:17:25.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Menurutmu Tuan Rimuru akan terganggu\Noleh omong kosong cecunguk?
Dialogue: 0,0:17:25.23,0:17:26.23,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:26.23,0:17:27.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:27.78,0:17:33.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Meladeni orang-orang rendahan seperti mereka\Ncuma buang-buang energi Tuan Rimuru.
Dialogue: 0,0:17:34.55,0:17:36.80,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Be-Benar itu, Benimaru.
Dialogue: 0,0:17:36.80,0:17:38.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Mereka bukan siapa-siapa.
Dialogue: 0,0:17:39.51,0:17:41.79,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:17:41.79,0:17:44.41,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya masih harus banyak belajar.
Dialogue: 0,0:17:44.41,0:17:46.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Benimaru, maaf, ya.
Dialogue: 0,0:17:47.30,0:17:50.55,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Anda Yang Mulia Rimuru Tempest, bukan?
Dialogue: 0,0:17:50.55,0:17:53.86,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya Lester selaku ketua sidang.
Dialogue: 0,0:17:53.86,0:17:55.68,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Silakan ikut saya.
Dialogue: 0,0:17:55.68,0:17:58.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih atas panduannya.
Dialogue: 0,0:18:10.58,0:18:12.63,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa di kursi ini?
Dialogue: 0,0:18:15.41,0:18:16.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:16.88,0:18:19.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Langkah pencegahan untuk menghadapiku, ya?
Dialogue: 0,0:18:20.65,0:18:22.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Oh, Hinata di sana.
Dialogue: 0,0:18:26.71,0:18:30.32,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Waktunya tiba, mari kita mulai.
Dialogue: 0,0:18:30.32,0:18:34.72,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Agendanya adalah bergabungnya Tempest\Nke Dewan Negara-Negara Barat.
Dialogue: 0,0:18:35.30,0:18:39.97,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Dewan berencana menyetujui\Nkeanggotaan negara Anda.
Dialogue: 0,0:18:40.46,0:18:43.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tetapi, ada beberapa syarat.
Dialogue: 0,0:18:44.42,0:18:45.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Akan saya dengarkan.
Dialogue: 0,0:18:46.57,0:18:48.88,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ada tiga syarat.
Dialogue: 0,0:18:48.88,0:18:51.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Pertama, "Kepatuhan Hukum Internasional".
Dialogue: 0,0:18:51.98,0:18:55.87,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ini kewajiban tiap anggota,\Njadi bukan masalah.
Dialogue: 0,0:18:56.90,0:19:00.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kedua, "Pembukaan Pasar".
Dialogue: 0,0:19:00.06,0:19:03.04,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ini agak bermasalah.
Dialogue: 0,0:19:03.04,0:19:06.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tanpa konsep paten di dunia ini,
Dialogue: 0,0:19:06.11,0:19:09.00,dialog,,0,0,0,,{\blur3}{\fad(00,40)}teknologi kami bisa dicuri.
Dialogue: 0,0:19:09.51,0:19:13.51,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Masih mending kalau cuma dicuri.
Dialogue: 0,0:19:14.38,0:19:18.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Prioritaskan pembangunan rel di negaraku!
Dialogue: 0,0:19:18.01,0:19:22.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Negarakulah yang paling pantas\Njadi sekutu Tempest!
Dialogue: 0,0:19:22.43,0:19:23.80,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, seharusnya negara kami!
Dialogue: 0,0:19:23.81,0:19:28.16,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak sudi diperalat seperti pesuruh\Nberkedok kerja sama bisnis.
Dialogue: 0,0:19:28.16,0:19:29.44,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Negaramu diam saja!
Dialogue: 0,0:19:29.44,0:19:31.06,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Harap tenang!
Dialogue: 0,0:19:31.06,0:19:33.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang bukan waktunya\Nmendengarkan tuntutan tiap negara!
Dialogue: 0,0:19:33.78,0:19:36.40,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ketua sidang pun\Npunya kerepotan tersendiri, ya.
Dialogue: 0,0:19:36.95,0:19:38.36,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terakhir,
Dialogue: 0,0:19:38.36,0:19:40.76,dialog,,0,0,0,,{\blur3}{\fad(00,40)}"Penyediaan Kekuatan Militer".
Dialogue: 0,0:19:40.76,0:19:46.29,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Meski perlu ditinjau, jujur ini syarat\Nyang menguntungkan bagi kami.
Dialogue: 0,0:19:47.54,0:19:52.82,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tiap negara akan membayar biaya pertahanan\Ndan bergantung pada kami.
Dialogue: 0,0:19:52.82,0:19:57.78,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Artinya, kami dapat uang sekaligus\Nmemperkuat pengaruh politik.
Dialogue: 0,0:19:58.98,0:20:03.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena mereka memanfaatkan kami,\Nkami pun harus ambil untung.
Dialogue: 0,0:20:03.82,0:20:08.77,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Itulah syarat keanggotaan bagi\NFederasi Jura Tempest.
Dialogue: 0,0:20:09.12,0:20:12.96,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yang Mulia Rimuru, apa Anda keberatan?
Dialogue: 0,0:20:14.00,0:20:15.37,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kak Raphael.
Dialogue: 0,0:20:15.86,0:20:17.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:20:33.82,0:20:35.03,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tolong.
Dialogue: 0,0:20:35.03,0:20:35.84,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:20:46.35,0:20:49.57,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Rimuru telah merangkum pertanyaan\Ndan usulan penggantinya.
Dialogue: 0,0:20:49.57,0:20:50.98,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tolong ditinjau.
Dialogue: 0,0:20:50.98,0:20:53.17,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:20:57.03,0:21:00.11,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Penjelasanku dirangkum kata demi kata!
Dialogue: 0,0:21:00.11,0:21:02.49,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan sampai diberikan revisi?
Dialogue: 0,0:21:02.49,0:21:05.28,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Singkatnya saya setuju\Ndengan persyaratannya.
Dialogue: 0,0:21:05.28,0:21:08.12,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hal yang ingin saya sampaikan\Njuga tertulis di sana.
Dialogue: 0,0:21:08.63,0:21:13.13,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalau diterima, saya anggap kita sepakat.
Dialogue: 0,0:21:14.64,0:21:19.01,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Saya butuh waktu untuk mempertimbangkannya.
Dialogue: 0,0:21:19.01,0:21:21.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:21:21.81,0:21:25.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Padahal mereka tidak kasih kami\Nwaktu berpikir.
Dialogue: 0,0:21:28.16,0:21:31.10,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Tepat tiga jam kemudian.
Dialogue: 0,0:21:35.85,0:21:38.07,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih sudah menunggu.
Dialogue: 0,0:21:40.98,0:21:43.04,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Surat tuntutan, ya?
Dialogue: 0,0:21:43.04,0:21:45.74,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Ketua sidang mungkin setuju...
Dialogue: 0,0:21:45.74,0:21:48.20,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Yah, aku akan tetap berunding.
Dialogue: 0,0:21:48.20,0:21:51.33,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Karena aku datang ke sini untuk diskusi.
Dialogue: 0,0:21:51.33,0:21:53.90,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Demi terwujudnya hidup berdampingan\Nmanusia dan monster.
Dialogue: 0,0:22:16.92,0:22:18.22,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa...?
Dialogue: 0,0:22:20.77,0:22:23.93,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Hei, kalian...
Dialogue: 0,0:22:24.75,0:22:26.43,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa...?
Dialogue: 0,0:22:27.51,0:22:30.39,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kalian meremehkanku?
Dialogue: 0,0:22:30.97,0:22:35.38,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa jadi begini?
Dialogue: 0,0:24:05.92,0:24:09.26,dialog,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya, "Dewan Negara-Negara Barat".
