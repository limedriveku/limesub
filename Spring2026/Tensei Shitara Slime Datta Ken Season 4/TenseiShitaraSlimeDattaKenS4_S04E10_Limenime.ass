Dialogue: 0,0:03:37.86,0:03:42.99,sign,,0000,0000,0000,,EPISODE 82: SANG PENGUASA KESERAKAHAN
Dialogue: 0,0:24:09.10,0:24:10.90,sign,,0000,0000,0000,,TEMAN MILIM
Dialogue: 0,0:00:12.13,0:00:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka seorang Raja Iblis\Nadalah pemimpi seperti ini.
Dialogue: 0,0:00:16.81,0:00:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutunjukkan kenyataannya padamu.
Dialogue: 0,0:00:19.69,0:00:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kita buktikan siapa yang benar.
Dialogue: 0,0:00:29.81,0:00:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang melawanmu.
Dialogue: 0,0:00:32.00,0:00:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, menarik.
Dialogue: 0,0:00:34.16,0:00:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pecundang yang dikendalikan orang lain
Dialogue: 0,0:00:37.00,0:00:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah tandinganku!
Dialogue: 0,0:00:41.81,0:00:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubah!
Dialogue: 0,0:00:46.91,0:00:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga salah satu dari Empat Petinggi!
Dialogue: 0,0:00:48.99,0:00:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil latihanku bersama Ranga...
Dialogue: 0,0:00:53.91,0:00:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serigala yang berpihak pada raja iblis jahat,\Naku yang akan melawanmu!
Dialogue: 0,0:00:58.75,0:01:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum selesai bicara!
Dialogue: 0,0:01:03.06,0:01:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis Rimuru, musuhnya beliau.
Dialogue: 0,0:01:06.80,0:01:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kesatria itu punya dendam padaku?
Dialogue: 0,0:01:11.52,0:01:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginan membalas dendamnya\Ndimanfaatkan Maribel, ya?
Dialogue: 0,0:01:16.95,0:01:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai, Gaiye.
Dialogue: 0,0:01:18.77,0:01:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalahkan Raja Iblis Rimuru.
Dialogue: 0,0:01:25.69,0:01:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaiye?
Dialogue: 0,0:01:26.61,0:01:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria congkak waktu itu?
Dialogue: 0,0:01:31.24,0:01:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau begitu...
Dialogue: 0,0:01:39.39,0:01:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat ingin melawanku, kan?
Dialogue: 0,0:01:42.24,0:01:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah keinginanmu tercapai\Nsebelum kamu mati.
Dialogue: 0,0:01:46.13,0:01:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, kekuatan apa itu?
Dialogue: 0,0:01:49.81,0:01:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mencari tahu siapa musuhmu dulu?
Dialogue: 0,0:01:58.51,0:02:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya giliranmu, Maribel Rozzo.
Dialogue: 0,0:02:03.14,0:02:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah mangsaku.
Dialogue: 0,0:03:34.32,0:03:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}(Tensura) Bereinkarnasi Malah Menjadi Slime
Dialogue: 0,0:03:42.99,0:03:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaiye bisa dikalahkan semudah itu.
Dialogue: 0,0:03:46.79,0:03:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal seluruh jiwanya sudah dikorbankan\Ndemi kekuatan penuh.
Dialogue: 0,0:03:51.41,0:03:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir itu bisa mengulur waktu\Nsampai Raja Iblis berada di bawah kendaliku.
Dialogue: 0,0:03:55.28,0:03:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meremehkannya.
Dialogue: 0,0:03:57.76,0:03:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:04:01.66,0:04:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor. Terdeteksi adanya telepon sihir\Ndari individu Maribel Rozzo.
Dialogue: 0,0:04:07.28,0:04:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Target telah mengirimkan perintah ke luar.
Dialogue: 0,0:04:11.57,0:04:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku berat!
Dialogue: 0,0:04:14.98,0:04:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat perasaan ini.
Dialogue: 0,0:04:18.24,0:04:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medan Suci, ya?
Dialogue: 0,0:04:20.06,0:04:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kamu benar.
Dialogue: 0,0:04:22.86,0:04:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sadar tidak punya peluang menang\Ndengan menghadapimu langsung.
Dialogue: 0,0:04:28.75,0:04:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, kamu yang terlalu percaya diri
Dialogue: 0,0:04:32.94,0:04:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah lengah di hadapanku.
Dialogue: 0,0:04:36.77,0:04:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang akan merenggut nyawamu.
Dialogue: 0,0:04:40.02,0:04:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarilah perbedaan kecerdasan\Nantara manusia dan monster.
Dialogue: 0,0:04:43.47,0:04:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:04:47.60,0:04:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu akan begini.
Dialogue: 0,0:04:50.38,0:04:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah tahu kalau Granville adalah\Nsalah satu dari Tujuh Luminari.
Dialogue: 0,0:04:54.82,0:04:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir kamu yang menjebakku?
Dialogue: 0,0:04:58.07,0:05:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sebaliknya.
Dialogue: 0,0:05:00.07,0:05:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sengaja menjadi umpan\Nuntuk memancingmu keluar.
Dialogue: 0,0:05:03.97,0:05:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu harus datang sendiri ke sini\Nuntuk mengendalikanku, kan?
Dialogue: 0,0:05:10.94,0:05:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, itu memang benar.
Dialogue: 0,0:05:13.98,0:05:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang terlalu percaya diri\Ndengan kekuatanku.
Dialogue: 0,0:05:17.59,0:05:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengendalikan Raja Iblis Rimuru\Nternyata hanyalah angan.
Dialogue: 0,0:05:21.80,0:05:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku ingin, tapi aku tidak boleh\Nmengabaikan makhluk seperti itu.
Dialogue: 0,0:05:27.60,0:05:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pilihan lain.
Dialogue: 0,0:05:30.38,0:05:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan serius.
Dialogue: 0,0:05:32.19,0:05:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membunuhmu\Ndengan mempertaruhkan segalanya.
Dialogue: 0,0:05:35.61,0:05:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku juga akan mengerahkan segalanya.
Dialogue: 0,0:05:46.53,0:05:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambutlah kematianmu, Lost Entropy!
Dialogue: 0,0:05:54.04,0:05:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru!
Dialogue: 0,0:05:55.29,0:05:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan waktunya mencemaskan orang lain!
Dialogue: 0,0:06:01.26,0:06:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh membosankan.
Dialogue: 0,0:06:03.47,0:06:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehebat apa pun makhluk, tidak ada\Nyang bisa membuang hasrat untuk hidup.
Dialogue: 0,0:06:07.01,0:06:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku tidak terkalahkan.
Dialogue: 0,0:06:09.85,0:06:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keserakahan-ku adalah yang terkuat.
Dialogue: 0,0:06:13.41,0:06:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:06:15.69,0:06:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasrat untuk hidup secara insting\Nyang dimiliki tiap makhluk hidup.
Dialogue: 0,0:06:20.69,0:06:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini teknik untuk membalikkannya?
Dialogue: 0,0:06:23.28,0:06:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang skill terkuat.
Dialogue: 0,0:06:26.07,0:06:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang...
Dialogue: 0,0:06:27.87,0:06:32.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kehebatan itu berlaku\Ndi tingkat Skill Unik saja.
Dialogue: 0,0:06:32.87,0:06:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:33.77,0:06:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan tersebut tidak akan mempan terhadap\NMaster yang telah membangkitkan Skill Ultima.
Dialogue: 0,0:06:37.71,0:06:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena perbedaan ketahanan jiwa.
Dialogue: 0,0:06:40.06,0:06:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesimpulannya, peluang menang bagi\Nindividu Maribel Rozzo adalah nol.
Dialogue: 0,0:06:46.29,0:06:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, analisis selesai.
Dialogue: 0,0:06:49.71,0:06:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, kekuatanmu tidak akan mempan.
Dialogue: 0,0:06:54.14,0:06:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar di luar nalar.
Dialogue: 0,0:06:58.16,0:07:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundurlah, Maribel.
Dialogue: 0,0:07:00.35,0:07:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini peringatan terakhir.
Dialogue: 0,0:07:03.14,0:07:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau hidup sebagai gadis biasa,\Naku tidak akan membunuhmu.
Dialogue: 0,0:07:09.44,0:07:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh kalah.
Dialogue: 0,0:07:11.94,0:07:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya jalan lagi selain\Nmenundukkan Raja Iblis Rimuru.
Dialogue: 0,0:07:16.50,0:07:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negara-Negara Barat dan dunia ini\Nadalah milikku seorang.
Dialogue: 0,0:07:23.14,0:07:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang, masih kurang.
Dialogue: 0,0:07:29.22,0:07:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski harus mempertaruhkan segalanya,
Dialogue: 0,0:07:31.68,0:07:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan merebut kemenangan di sini!
Dialogue: 0,0:07:35.17,0:07:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begini cara dia memperkuat Gaiye.
Dialogue: 0,0:07:39.52,0:07:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:07:40.90,0:07:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor.
Dialogue: 0,0:07:41.92,0:07:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan fisik individu Maribel Rozzo
Dialogue: 0,0:07:44.96,0:07:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beserta Skill Unik Keserakahan,\Nmeningkat drastis.
Dialogue: 0,0:07:49.41,0:07:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia meningkatkan daya skill-nya.
Dialogue: 0,0:07:51.78,0:07:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah, Raja Iblis Rimuru!
Dialogue: 0,0:08:08.70,0:08:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang kekuatanmu\Ntidak akan mempan.
Dialogue: 0,0:08:19.41,0:08:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubiarkan kamu hidup.
Dialogue: 0,0:08:21.77,0:08:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkacalah di dalam diriku.
Dialogue: 0,0:08:32.49,0:08:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion!
Dialogue: 0,0:08:40.50,0:08:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Yuuki!
Dialogue: 0,0:08:47.46,0:08:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki.
Dialogue: 0,0:08:54.85,0:08:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah memandang rendah dirimu,\NRaja Iblis Rimuru.
Dialogue: 0,0:08:59.66,0:09:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menduga\Nakan dipojokkan sejauh ini.
Dialogue: 0,0:09:03.36,0:09:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor. Kemampuan individu\NYuuki Kagurazaka meningkat.
Dialogue: 0,0:09:08.19,0:09:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya individu Maribel Rozzo\Ntelah mentransfer kekuatannya
Dialogue: 0,0:09:12.80,0:09:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melalui Skill Unik Keserakahan.
Dialogue: 0,0:09:14.99,0:09:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini merepotkan.
Dialogue: 0,0:09:16.99,0:09:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terima itu sebagai pujian.
Dialogue: 0,0:09:30.67,0:09:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempat-sempatnya aku lengah.
Dialogue: 0,0:09:32.95,0:09:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan serius.
Dialogue: 0,0:09:38.37,0:09:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darurat. Penghalang Berlapis\NUriel telah ditembus.
Dialogue: 0,0:09:42.14,0:09:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:09:44.56,0:09:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disimpulkan bahwa individu\NYuuki Kagurazaka memiliki Anti-Skill.
Dialogue: 0,0:09:51.38,0:09:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, bukan cuma\NPertahanan Absolutku yang jebol,
Dialogue: 0,0:09:55.01,0:09:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi semua seranganku juga\Nakan dinetralkan olehnya?
Dialogue: 0,0:09:58.45,0:10:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Anti-Skill adalah kondisi tubuh spiritual\Nyang menetralkan sihir dan skill sepenuhnya.
Dialogue: 0,0:10:03.90,0:10:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti hanya Art yang mempan?
Dialogue: 0,0:10:06.53,0:10:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kok bisa dia menjebol Skill Ultima?
Dialogue: 0,0:10:09.84,0:10:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu pernah bilang tidak punya\NSkill Unik atau kemampuan khusus?
Dialogue: 0,0:10:15.09,0:10:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berbohong, kok.
Dialogue: 0,0:10:17.34,0:10:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah bilang kalau cuma\Nkemampuan fisikku yang tumbuh abnormal.
Dialogue: 0,0:10:21.10,0:10:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:10:25.98,0:10:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia hanya sedang dikendalikan,\Naku tidak ingin membunuhnya.
Dialogue: 0,0:10:30.13,0:10:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi.
Dialogue: 0,0:10:36.61,0:10:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pedangnya bagus.
Dialogue: 0,0:10:39.97,0:10:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salahkan aku kalau kamu mati.
Dialogue: 0,0:10:45.54,0:10:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku yang bilang begitu.
Dialogue: 0,0:10:55.51,0:10:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grandmaster, kenapa...
Dialogue: 0,0:10:57.58,0:11:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia mematuhi gadis yang tadi.
Dialogue: 0,0:11:00.69,0:11:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita hanya dimanfaatkan?
Dialogue: 0,0:11:02.77,0:11:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:11:03.64,0:11:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil Tuan Yuuki mengkhianati kita!
Dialogue: 0,0:11:07.57,0:11:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada alasannya.
Dialogue: 0,0:11:10.52,0:11:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar, mungkin ada\Nyang tidak bisa diceritakan pada kita.
Dialogue: 0,0:11:15.71,0:11:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:11:34.63,0:11:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana baiknya, ya?
Dialogue: 0,0:11:36.43,0:11:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seandainya aku bisa membatalkan\Ngangguan spiritualnya.
Dialogue: 0,0:11:39.34,0:11:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor. Intervensi digagalkan karena\Nterbentur oleh efek Anti-Skill.
Dialogue: 0,0:11:44.47,0:11:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas begitu.
Dialogue: 0,0:11:49.27,0:11:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pukulan biasaku selalu mengandung skill,
Dialogue: 0,0:11:54.32,0:11:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya tidak akan mempan.
Dialogue: 0,0:11:57.07,0:11:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya begitu.
Dialogue: 0,0:12:00.94,0:12:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia repot-repot menghindar\Natau menangkis tebasan pedangku?
Dialogue: 0,0:12:05.12,0:12:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor. Anti-Skill tidak bisa\Nditerapkan pada senjata.
Dialogue: 0,0:12:08.67,0:12:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar.
Dialogue: 0,0:12:10.00,0:12:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti serangan fisik dengan senjata\Ntetap mempan!
Dialogue: 0,0:12:13.09,0:12:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, serangan senjata dari Yuuki...
Dialogue: 0,0:12:19.93,0:12:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lengah, Rimuru.
Dialogue: 0,0:12:28.56,0:12:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, malah lebih sakit\Ndipukul dengan tangan kosong.
Dialogue: 0,0:12:32.98,0:12:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sengaja menerima seranganku?
Dialogue: 0,0:12:35.15,0:12:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masuk akal.
Dialogue: 0,0:12:39.12,0:12:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan senjata Yuuki terbukti gagal\Nmenembus Pertahanan Absolutku.
Dialogue: 0,0:12:44.24,0:12:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Storm Break!
Dialogue: 0,0:13:05.26,0:13:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebasan pedang yang digabungkan dengan\Nsihir badai dari Skill Ultima, Veldora.
Dialogue: 0,0:13:11.17,0:13:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor. Sebagian efek teknik tersebut\Ntelah diredam oleh Anti-Skill.
Dialogue: 0,0:13:17.15,0:13:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NLagian aku tidak berniat membunuhnya.
Dialogue: 0,0:13:24.91,0:13:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir badai ini biasanya menghancurkan\Njaringan tubuh melalui luka.
Dialogue: 0,0:13:31.94,0:13:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat Anti-Skill,\Nluka ini tidak mematikan bagimu.
Dialogue: 0,0:13:38.67,0:13:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Analisis penilaian.
Dialogue: 0,0:13:42.75,0:13:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwanya sudah sepenuhnya dikuasai\NKeserakahan milik Maribel.
Dialogue: 0,0:13:46.53,0:13:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gangguan spiritualnya tidak bisa dibatalkan.
Dialogue: 0,0:13:49.72,0:13:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya cara...
Dialogue: 0,0:13:55.92,0:13:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidurlah sampai aku membereskan Maribel.
Dialogue: 0,0:13:58.62,0:14:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sedikit kasar, jangan salahkan...
Dialogue: 0,0:14:00.80,0:14:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tunggu sebentar!
Dialogue: 0,0:14:02.78,0:14:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bunuh Tuan Yuuki!
Dialogue: 0,0:14:06.78,0:14:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya!\NYuuki sedang dikendalikan, lo!
Dialogue: 0,0:14:09.91,0:14:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mustahil keteguhan hati Tuan Yuuki\Nkalah oleh gadis sekecil itu!
Dialogue: 0,0:14:15.92,0:14:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Yuuki, kuatkan dirimu!
Dialogue: 0,0:14:19.28,0:14:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bukan tipe yang bisa\Ndikendalikan orang lain!
Dialogue: 0,0:14:22.72,0:14:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kagali.
Dialogue: 0,0:14:24.55,0:14:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar kata Kagali!
Dialogue: 0,0:14:27.30,0:14:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:14:28.31,0:14:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grandmaster kami tidak selemah itu!
Dialogue: 0,0:14:34.21,0:14:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi kayak penjahatnya.
Dialogue: 0,0:14:37.31,0:14:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalian...
Dialogue: 0,0:14:41.01,0:14:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Yuuki!
Dialogue: 0,0:14:43.95,0:14:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah begini,\Naku tidak boleh terlihat payah.
Dialogue: 0,0:14:49.86,0:14:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:51.24,0:14:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grandmaster!
Dialogue: 0,0:14:52.67,0:14:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda sudah sadar?
Dialogue: 0,0:14:54.08,0:14:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sepertinya suara kalian telah\Nmengembalikan kesadaranku.
Dialogue: 0,0:14:59.39,0:15:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:00.42,0:15:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grandmaster!
Dialogue: 0,0:15:01.98,0:15:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:15:03.80,0:15:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya dari awal.
Dialogue: 0,0:15:06.43,0:15:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor.
Dialogue: 0,0:15:07.19,0:15:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisi individu Yuuki Kagurazaka\Ntelah berubah.
Dialogue: 0,0:15:10.69,0:15:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek gangguan spiritual dari Keserakahan\Ntelah dilepas.
Dialogue: 0,0:15:14.39,0:15:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada jalan cerita yang semulus itu!
Dialogue: 0,0:15:18.70,0:15:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama Yuuki tidak menjadi musuh,\Nsatu kesatria yang tersisa bukanlah ancaman.
Dialogue: 0,0:15:23.57,0:15:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pengaruh gangguan spiritualnya lepas,\Nsosok "pengkhianat" yang dimaksud
Dialogue: 0,0:15:28.29,0:15:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata adalah Glenda.
Dialogue: 0,0:15:30.87,0:15:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mantan Tiga Petarung Bijak.
Dialogue: 0,0:15:33.97,0:15:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah posisinya direbut Glenda,\Nhatinya juga kena rebut.
Dialogue: 0,0:15:38.96,0:15:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Glenda masih hidup,\Nbilang dari awal, dong.
Dialogue: 0,0:15:42.19,0:15:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang dari tadi!
Dialogue: 0,0:15:44.26,0:15:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, luka Yuuki juga sudah sembuh.
Dialogue: 0,0:15:47.93,0:15:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Anti-Skill bisa diaktifkan\Ndan dinonaktifkan sendiri.
Dialogue: 0,0:15:51.74,0:15:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf telah merepotkanmu.
Dialogue: 0,0:15:55.07,0:15:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tertolong.
Dialogue: 0,0:15:58.69,0:16:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu absurd.
Dialogue: 0,0:16:04.94,0:16:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rimuru.
Dialogue: 0,0:16:06.53,0:16:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku yang membereskan Maribel?
Dialogue: 0,0:16:09.82,0:16:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin bisa menang?
Dialogue: 0,0:16:11.60,0:16:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak lengah, itu gampang.
Dialogue: 0,0:16:14.22,0:16:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikendalikan saat Anti-Skill sedang nonaktif\Nbenar-benar menyenggol harga diriku.
Dialogue: 0,0:16:20.38,0:16:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:22.43,0:16:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sepertinya berniat meledakkan\Nfasilitas daya di bagian terdalam
Dialogue: 0,0:16:27.14,0:16:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyeretmu mati bersamanya.
Dialogue: 0,0:16:29.47,0:16:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fasilitas daya?
Dialogue: 0,0:16:31.52,0:16:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai lepas kendali,\Ndampaknya lebih dari kehancuran.
Dialogue: 0,0:16:35.87,0:16:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku ikut.
Dialogue: 0,0:16:38.35,0:16:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah meneliti reruntuhan\Njenis ini di Soma.
Dialogue: 0,0:16:43.01,0:16:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terjadi sesuatu, aku bisa menanganinya.
Dialogue: 0,0:16:47.49,0:16:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi serius dari wanita cantik itu\Nsungguh meluluhkan hatiku.
Dialogue: 0,0:16:52.14,0:16:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku serahkan padamu.
Dialogue: 0,0:16:55.50,0:16:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion! Gobta!
Dialogue: 0,0:16:57.07,0:17:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pandu mereka yang di sini\Nuntuk bertemu Dark Elf.
Dialogue: 0,0:17:00.56,0:17:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lindungi mereka juga!
Dialogue: 0,0:17:01.75,0:17:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti!
Dialogue: 0,0:17:03.15,0:17:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Anda mau ke mana?
Dialogue: 0,0:17:04.67,0:17:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau membantu Milim!
Dialogue: 0,0:17:13.93,0:17:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak menggunakan serangan kejutan,\Nmustahil bisa menghabisi Raja Iblis itu.
Dialogue: 0,0:17:19.74,0:17:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara ini memang membahayakan diri,
Dialogue: 0,0:17:24.19,0:17:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku sudah tidak peduli lagi.
Dialogue: 0,0:17:30.95,0:17:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:38.11,0:17:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kosong?
Dialogue: 0,0:17:41.33,0:17:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh.
Dialogue: 0,0:17:44.25,0:17:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:17:48.67,0:17:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di reruntuhan ini tidak ada yang namanya\NReaktor Daya Kendali Sihir.
Dialogue: 0,0:17:52.76,0:17:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, di Soma juga tidak ada.
Dialogue: 0,0:17:58.30,0:18:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Yuuki?
Dialogue: 0,0:18:00.02,0:18:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ini aku.
Dialogue: 0,0:18:03.02,0:18:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana pertarunganmu melawan\NRaja Iblis Rimuru?
Dialogue: 0,0:18:06.40,0:18:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah beres.
Dialogue: 0,0:18:07.86,0:18:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat serius melawannya,\Ntapi dia terlalu kuat.
Dialogue: 0,0:18:11.71,0:18:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kalau bisa menang,\Naku mau menghabisinya sekalian.
Dialogue: 0,0:18:15.66,0:18:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai jantungan.
Dialogue: 0,0:18:18.14,0:18:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengira telah dikhianati.
Dialogue: 0,0:18:23.15,0:18:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf.
Dialogue: 0,0:18:24.75,0:18:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sengaja merahasiakannya darimu\Nsupaya terlihat lebih meyakinkan.
Dialogue: 0,0:18:28.96,0:18:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, tapi aku harus mengakuinya.
Dialogue: 0,0:18:33.46,0:18:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faktanya dia sudah terbebas\Ndari pengaruh Keserakahan.
Dialogue: 0,0:18:39.36,0:18:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki, kamu bisa menghancurkan kekuatanku?
Dialogue: 0,0:18:43.89,0:18:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?\NSejak kapan?
Dialogue: 0,0:18:46.98,0:18:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penasaran?
Dialogue: 0,0:18:48.19,0:18:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab saja!
Dialogue: 0,0:18:50.40,0:18:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, biar kuperlihatkan.
Dialogue: 0,0:18:55.41,0:19:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, ini tidak mungkin.
Dialogue: 0,0:19:02.91,0:19:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini kamu berpura-pura dikendalikan?
Dialogue: 0,0:19:08.24,0:19:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, jawabannya aku hanya berakting.
Dialogue: 0,0:19:12.18,0:19:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktingku hebat, kan?
Dialogue: 0,0:19:14.84,0:19:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, makin besar keserakahanmu,
Dialogue: 0,0:19:18.05,0:19:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makin mutlak kendaliku atas dirimu!
Dialogue: 0,0:19:20.96,0:19:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi untuk orang yang seserakah dirimu!
Dialogue: 0,0:19:24.10,0:19:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuanku adalah kekuatan terkuat\Nyang bersumber dari emosi keserakahan!
Dialogue: 0,0:19:29.20,0:19:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil ada yang bisa menang melawannya!
Dialogue: 0,0:19:32.17,0:19:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:19:33.74,0:19:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, setelah menyeberang ke dunia ini,
Dialogue: 0,0:19:37.82,0:19:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku langsung "menciptakan" Anti-Skill ini.
Dialogue: 0,0:19:41.49,0:19:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menciptakan?
Dialogue: 0,0:19:43.24,0:19:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, demi menetralkan\Nsegala kejahatan terhadap diriku.
Dialogue: 0,0:19:48.75,0:19:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, semua hal itu\Nsudah tidak penting.
Dialogue: 0,0:19:52.11,0:19:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena
Dialogue: 0,0:19:53.58,0:19:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dibanding keserakahanmu,\Nhasratku jauh lebih besar.
Dialogue: 0,0:19:59.07,0:20:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa Anti-Skill pun, Keserakahanmu\Ntidak akan mempan padaku.
Dialogue: 0,0:20:05.14,0:20:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini hanyalah tempat bermainku.
Dialogue: 0,0:20:17.47,0:20:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambisiku adalah menjadi raja di dunia ini.
Dialogue: 0,0:20:22.16,0:20:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meremehkanku.\NAku Maribel.
Dialogue: 0,0:20:29.62,0:20:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maribel sang Serakah.
Dialogue: 0,0:20:32.84,0:20:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukanlah tandinganku!
Dialogue: 0,0:20:36.84,0:20:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang percuma.
Dialogue: 0,0:20:38.98,0:20:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasrat sekecil itu tidak bisa mengalahkanku.
Dialogue: 0,0:20:45.26,0:20:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mustahil...
Dialogue: 0,0:20:47.65,0:20:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Keserakahan ini...\NKamu merebut kekuatanku?
Dialogue: 0,0:20:51.85,0:20:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:20:53.61,0:20:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin hal itu bisa terjadi...
Dialogue: 0,0:20:57.61,0:20:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, kok.
Dialogue: 0,0:20:59.54,0:21:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini hanya berpindah\Nke wadah yang lebih layak.
Dialogue: 0,0:21:08.22,0:21:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seandainya kamu terlahir di dunia ini\Nsepuluh tahun lebih cepat,
Dialogue: 0,0:21:12.72,0:21:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin kamu sudah menguasai dunia.
Dialogue: 0,0:21:21.26,0:21:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya kurang beruntung.
Dialogue: 0,0:21:23.82,0:21:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tubuh sekecil itu, kamu pasti tidak bisa\Nmengendalikan skill-mu sepenuhnya, kan?
Dialogue: 0,0:21:30.82,0:21:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah tidak mendengarku, ya?
Dialogue: 0,0:21:39.28,0:21:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri yang mengatakannya.
Dialogue: 0,0:21:42.14,0:21:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahwa ambisiku terlalu besar.
Dialogue: 0,0:21:53.30,0:21:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur, Maribel.
Dialogue: 0,0:21:55.90,0:21:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menanggung\Nseluruh keserakahanmu.
Dialogue: 0,0:22:05.60,0:22:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maribel yang hidup di era bergejolak ini
Dialogue: 0,0:22:08.42,0:22:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengakhiri kehidupan singkatnya.
Dialogue: 0,0:22:12.94,0:22:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai hukum alam
Dialogue: 0,0:22:16.34,0:22:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang lemah akan menjadi yang kalah.
Dialogue: 0,0:24:05.92,0:24:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Teman Milim".
