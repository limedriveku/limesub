Dialogue: 0,0:01:50.05,0:01:51.36,dialog,,0,0,0,,Ayo.
Dialogue: 0,0:02:08.64,0:02:10.35,dialog,,0,0,0,,Biar aku yang melawannya!
Dialogue: 0,0:02:23.07,0:02:24.65,dialog,,0,0,0,,Masayuki!
Dialogue: 0,0:02:27.93,0:02:30.49,dialog,,0,0,0,,Oh, serangan dari dua arah, ya?
Dialogue: 0,0:02:30.49,0:02:33.04,dialog,,0,0,0,,Ternyata Masayuki mengincar ini!
Dialogue: 0,0:02:33.04,0:02:34.63,dialog,,0,0,0,,Memang hebat!
Dialogue: 0,0:02:34.98,0:02:36.05,dialog,,0,0,0,,Biar kubantu!
Dialogue: 0,0:02:36.05,0:02:37.86,dialog,,0,0,0,,Mad Hand!
Dialogue: 0,0:02:43.02,0:02:43.85,dialog,,0,0,0,,Sekarang!
Dialogue: 0,0:02:46.62,0:02:49.10,dialog,,0,0,0,,Bak, bak, bak!
Dialogue: 0,0:02:49.10,0:02:51.27,dialog,,0,0,0,,Wind Cutter!
Dialogue: 0,0:03:02.89,0:03:03.99,dialog,,0,0,0,,Jiwu!
Dialogue: 0,0:03:09.68,0:03:11.37,dialog,,0,0,0,,Masayuki!
Dialogue: 0,0:03:21.17,0:03:22.01,dialog,,0,0,0,,Eh?
Dialogue: 0,0:03:36.02,0:03:39.18,dialog,,0,0,0,,Tuan Masayuki telah menyelamatkan kita!
Dialogue: 0,0:03:45.24,0:03:50.12,dialog,,0,0,0,,Barang-barang peringatan penaklukan lantai 30\Noleh Pahlawan Masayuki sedang dijual!
Dialogue: 0,0:03:50.45,0:03:52.62,dialog,,0,0,0,,Belilah selagi tersedia!
Dialogue: 0,0:03:53.04,0:03:55.88,dialog,,0,0,0,,Manju Masayuki rasanya lezat, lo!
Dialogue: 0,0:03:59.82,0:04:03.13,dialog,,0,0,0,,Sudah dengar soal pertarungan\NPahlawan Masayuki?
Dialogue: 0,0:04:03.13,0:04:07.89,dialog,,0,0,0,,Iya, siapa sangka dia mematahkan pedangnya\Nsupaya bisa menyerang bosnya!
Dialogue: 0,0:04:07.89,0:04:10.26,dialog,,0,0,0,,Pahlawan Masayuki telah tiba!
Dialogue: 0,0:04:10.26,0:04:11.89,dialog,,0,0,0,,Tiba!
Dialogue: 0,0:04:16.06,0:04:20.48,dialog,,0,0,0,,Wah, sepertinya kamu jadi\Ntambah populer sekarang!
Dialogue: 0,0:04:21.21,0:04:22.99,dialog,,0,0,0,,Pahlawan Masayuki!
Dialogue: 0,0:04:22.99,0:04:25.95,dialog,,0,0,0,,Tuan Rimuru juga jangan ikut-ikutan, dong.
Dialogue: 0,0:04:25.95,0:04:27.46,dialog,,0,0,0,,Aku hampir tidak berbuat apa-apa di sana.
Dialogue: 0,0:04:27.46,0:04:31.84,dialog,,0,0,0,,Dasar, jago banget merendah!
Dialogue: 0,0:04:32.98,0:04:36.04,dialog,,0,0,0,,Tapi, benaran sukses besar!
Dialogue: 0,0:04:36.04,0:04:38.60,dialog,,0,0,0,,Ada area istirahat di tiap lantai,
Dialogue: 0,0:04:38.60,0:04:41.42,dialog,,0,0,0,,terus ide-ide sebelumnya juga brilian sekali!
Dialogue: 0,0:04:41.42,0:04:45.41,dialog,,0,0,0,,Betul itu, misalnya gerbang\Nyang terhubung ke kota di lantai 95, kan?
Dialogue: 0,0:04:45.41,0:04:47.65,dialog,,0,0,0,,Tarif masuknya tiga koin perak.
Dialogue: 0,0:04:47.65,0:04:50.43,dialog,,0,0,0,,Meski terhitung agak mahal,
Dialogue: 0,0:04:50.43,0:04:52.70,dialog,,0,0,0,,penginapannya laku banget.
Dialogue: 0,0:04:52.70,0:04:54.74,dialog,,0,0,0,,Layanan makanan hangat
Dialogue: 0,0:04:54.74,0:04:57.36,dialog,,0,0,0,,dan tempat istirahat yang aman\Ndi dalam dungeon
Dialogue: 0,0:04:57.36,0:04:58.81,dialog,,0,0,0,,populer banget, lo!
Dialogue: 0,0:04:59.22,0:05:03.30,dialog,,0,0,0,,Bisa dibilang promosi dungeon-nya\Nsukses besar, kan?
Dialogue: 0,0:05:03.30,0:05:04.82,dialog,,0,0,0,,Jelas itu!
Dialogue: 0,0:05:05.24,0:05:09.32,dialog,,0,0,0,,Level para penantang pun naik,\Nbenar-benar mantap!
Dialogue: 0,0:05:09.32,0:05:13.38,dialog,,0,0,0,,Belakangan ini,\Nada petualang yang mencolok, kan?
Dialogue: 0,0:05:14.21,0:05:15.92,dialog,,0,0,0,,Tim Amukan Hijau.
Dialogue: 0,0:05:15.92,0:05:20.59,dialog,,0,0,0,,Grup yang naik daun setelah menaklukkan\N20 lantai dalam tiga hari, kan?
Dialogue: 0,0:05:21.02,0:05:24.91,dialog,,0,0,0,,Kunci kecepatan penaklukan mereka\Nada pada pemimpinnya, seorang Elementaler.
Dialogue: 0,0:05:24.91,0:05:29.79,dialog,,0,0,0,,Dia menggunakan "Komunikasi Roh"\Nuntuk menanyakan jalan kepada roh dalam dungeon.
Dialogue: 0,0:05:29.79,0:05:33.23,dialog,,0,0,0,,Tapi, aku dikasih tahu itu\Nsama Bu Raphael, sih.
Dialogue: 0,0:05:34.17,0:05:37.77,dialog,,0,0,0,,Terus bagaimana?\NAku bisa saja menghalangi mereka.
Dialogue: 0,0:05:39.46,0:05:41.48,dialog,,0,0,0,,Sebaiknya jangan.
Dialogue: 0,0:05:41.48,0:05:43.54,dialog,,0,0,0,,Itu juga salah satu cara penaklukan.
Dialogue: 0,0:05:44.16,0:05:47.46,dialog,,0,0,0,,Lebih seru kalau ada beberapa\Ntim yang mencolok, kan?
Dialogue: 0,0:05:47.46,0:05:48.78,dialog,,0,0,0,,Siap, laksanakan!
Dialogue: 0,0:05:48.78,0:05:52.37,dialog,,0,0,0,,Syukurlah pendapatan kita terus naik.
Dialogue: 0,0:05:52.37,0:05:54.64,dialog,,0,0,0,,Setelah dipotong semua biaya pengeluaran,
Dialogue: 0,0:05:54.64,0:05:56.79,dialog,,0,0,0,,keuntungan kita masih melimpah.
Dialogue: 0,0:05:57.85,0:05:59.87,dialog,,0,0,0,,Keuntungan?
Dialogue: 0,0:05:59.87,0:06:04.66,dialog,,0,0,0,,Be-Be-Berarti saatnya aku gajian, dong?
Dialogue: 0,0:06:08.51,0:06:10.69,dialog,,0,0,0,,Se-Sebanyak ini...
Dialogue: 0,0:06:10.69,0:06:13.18,dialog,,0,0,0,,Wah, aku juga dapat jatah?
Dialogue: 0,0:06:13.18,0:06:14.48,dialog,,0,0,0,,Jelas!
Dialogue: 0,0:06:14.48,0:06:18.08,dialog,,0,0,0,,Bekerja dengan giat\Ndan raih keuntungan yang sepadan.
Dialogue: 0,0:06:18.08,0:06:19.73,dialog,,0,0,0,,Itulah yang terpenting.
Dialogue: 0,0:06:21.15,0:06:24.19,dialog,,0,0,0,,Aku punya pengalaman kerja di kedai.
Dialogue: 0,0:06:24.19,0:06:28.04,dialog,,0,0,0,,Sekarang aku paham pekerjaan itu\Nhal yang berharga.
Dialogue: 0,0:06:28.04,0:06:29.61,dialog,,0,0,0,,Sok bijak banget.
Dialogue: 0,0:06:30.57,0:06:32.45,dialog,,0,0,0,,Ini dia!
Dialogue: 0,0:06:32.45,0:06:35.87,dialog,,0,0,0,,Akhirnya era kita telah tiba!
Dialogue: 0,0:06:36.19,0:06:39.62,dialog,,0,0,0,,Yah, berkat kalian berdua,\Ndungeon-nya sukses besar!
Dialogue: 0,0:06:39.62,0:06:42.63,dialog,,0,0,0,,Sekarang kota-kota di atas pun ikut untung.
Dialogue: 0,0:06:42.63,0:06:48.13,dialog,,0,0,0,,Bahkan pedagang dari barat yang ingin\Nbekerja sama pun makin banyak.
Dialogue: 0,0:06:48.13,0:06:51.38,dialog,,0,0,0,,Oh, berarti sesuai yang kita incar.
Dialogue: 0,0:06:52.32,0:06:56.60,dialog,,0,0,0,,Negara kita menarik orang\Ndengan memicu keinginan mereka.
Dialogue: 0,0:06:56.60,0:07:01.48,dialog,,0,0,0,,Kalau kita dianggap bisa memuaskannya,\Nhubungan ini akan berjalan lancar.
Dialogue: 0,0:07:02.40,0:07:07.40,dialog,,0,0,0,,Benar, kelihatannya kita sudah\Ndipercaya sama mereka.
Dialogue: 0,0:07:07.78,0:07:12.32,dialog,,0,0,0,,Sepertinya kamu sudah terbiasa\Njadi Menkeu, Nak Mjollmile.
Dialogue: 0,0:07:12.32,0:07:15.83,dialog,,0,0,0,,Ini berkat bimbinganmu, Yang Mulia Rimuru.
Dialogue: 0,0:07:22.44,0:07:25.03,dialog,,0,0,0,,Operasional dungeon kini telah berjalan lancar.
Dialogue: 0,0:07:25.03,0:07:28.70,dialog,,0,0,0,,Lantai terbawahnya dimulai\Ndari aula besar Veldora,
Dialogue: 0,0:07:28.70,0:07:32.31,dialog,,0,0,0,,yang kini jadi ruang luas berisi\Nberbagai fasilitas penelitian.
Dialogue: 0,0:07:33.18,0:07:37.68,dialog,,0,0,0,,Ada fasilitas riset dengan Gabiru sebagai kepala\Ndan Vesta sebagai wakilnya,
Dialogue: 0,0:07:37.68,0:07:41.02,dialog,,0,0,0,,lalu fasilitas riset pribadi Ramiris.
Dialogue: 0,0:07:42.66,0:07:47.81,dialog,,0,0,0,,Selain itu, aku juga meminta Ramiris menyiapkan\Nfasilitas pengembangan khusus untukku.
Dialogue: 0,0:07:47.81,0:07:52.23,dialog,,0,0,0,,Di sini, aspek pertahanan dan pencegahan\Nkebocoran informasi sangat terjamin.
Dialogue: 0,0:07:52.23,0:07:56.48,dialog,,0,0,0,,Dengan begitu, aku bisa berkonsentrasi\Nmembuat wadah yang diminta Diablo.
Dialogue: 0,0:07:56.99,0:07:59.77,dialog,,0,0,0,,Sekalian aku juga sudah berjanji\Nmembuatkan wadah
Dialogue: 0,0:07:59.77,0:08:02.79,dialog,,0,0,0,,untuk Treyni dan adik-adiknya.
Dialogue: 0,0:08:04.25,0:08:08.30,dialog,,0,0,0,,Oh, jadi kalau begini lebih...
Dialogue: 0,0:08:08.30,0:08:10.27,dialog,,0,0,0,,Tuan Rimuru!
Dialogue: 0,0:08:11.34,0:08:14.82,dialog,,0,0,0,,Ada apa?\NPadahal lagi seru-serunya ini.
Dialogue: 0,0:08:14.82,0:08:15.65,dialog,,0,0,0,,Lapor.
Dialogue: 0,0:08:15.65,0:08:18.45,dialog,,0,0,0,,Komunikasi dengan pihak luar\Ntelah terputus selama beberapa hari.
Dialogue: 0,0:08:18.45,0:08:20.36,dialog,,0,0,0,,Ada kemungkinan sesuatu telah terjadi.
Dialogue: 0,0:08:20.36,0:08:21.22,dialog,,0,0,0,,Eh?
Dialogue: 0,0:08:22.99,0:08:25.48,dialog,,0,0,0,,Eng, ada apa?
Dialogue: 0,0:08:25.86,0:08:27.36,dialog,,0,0,0,,Syukurlah Anda baik-baik saja!
Dialogue: 0,0:08:27.36,0:08:29.10,dialog,,0,0,0,,Kami khawatir.
Dialogue: 0,0:08:29.10,0:08:31.86,dialog,,0,0,0,,Soalnya Anda tidak muncul\Nsaat waktunya makan.
Dialogue: 0,0:08:31.86,0:08:34.76,dialog,,0,0,0,,Maaf, aku sampai lupa waktu.
Dialogue: 0,0:08:34.76,0:08:36.95,dialog,,0,0,0,,Tidak, yang penting Anda baik-baik saja.
Dialogue: 0,0:08:36.95,0:08:40.42,dialog,,0,0,0,,Iya, tidak akan ada yang protes,
Dialogue: 0,0:08:40.42,0:08:42.59,dialog,,0,0,0,,meski Anda asyik meneliti sendiri.
Dialogue: 0,0:08:43.26,0:08:46.70,dialog,,0,0,0,,Mulai sekarang\Naku akan setor muka tiap hari, deh.
Dialogue: 0,0:08:46.70,0:08:49.57,dialog,,0,0,0,,Wah, kelihatannya lezat!
Dialogue: 0,0:08:53.59,0:08:58.72,dialog,,0,0,0,,O-Omong-omong, Tuan Mjollmile\Nsedang mencari Anda.
Dialogue: 0,0:09:00.05,0:09:01.50,dialog,,0,0,0,,Mjollmile?
Dialogue: 0,0:09:01.89,0:09:06.47,dialog,,0,0,0,,Tuan Rimuru!
Dialogue: 0,0:09:07.73,0:09:09.94,dialog,,0,0,0,,Ada apa terburu-buru begitu?
Dialogue: 0,0:09:10.35,0:09:12.30,dialog,,0,0,0,,Ga-Gawat!
Dialogue: 0,0:09:12.30,0:09:16.95,dialog,,0,0,0,,Sudah ada yang hampir bisa menembus\Nlantai 30 seperti Tuan Masayuki!
Dialogue: 0,0:09:17.32,0:09:20.07,dialog,,0,0,0,,Jangan bilang...
Dialogue: 0,0:09:20.07,0:09:23.58,dialog,,0,0,0,,Betul! Tim Amukan Hijau!
Dialogue: 0,0:09:23.89,0:09:26.16,dialog,,0,0,0,,Nah, itu orangnya.
Dialogue: 0,0:09:38.87,0:09:39.68,dialog,,0,0,0,,Selanjutnya.
Dialogue: 0,0:09:50.72,0:09:52.32,dialog,,0,0,0,,Apaan ini?
Dialogue: 0,0:09:52.32,0:09:56.82,dialog,,0,0,0,,Mereka menaklukkannya\Ndengan hampir melanggar aturan, tahu!
Dialogue: 0,0:09:56.82,0:09:58.72,dialog,,0,0,0,,Contohnya ini!
Dialogue: 0,0:09:58.72,0:10:00.28,dialog,,0,0,0,,Bola Rekam Kejadian.
Dialogue: 0,0:10:00.28,0:10:04.08,dialog,,0,0,0,,Ini titik simpan sekali pakai\Nuntuk seluruh anggota tim.
Dialogue: 0,0:10:04.94,0:10:07.90,dialog,,0,0,0,,Barang ini bisa dipakai tepat\Ndi depan ruang bos, kan?
Dialogue: 0,0:10:07.90,0:10:12.90,dialog,,0,0,0,,Setelahnya, bisa memakai Peluit Kemenangan\Nuntuk keluar dari dungeon,
Dialogue: 0,0:10:12.90,0:10:14.99,dialog,,0,0,0,,lalu bubarkan timnya.
Dialogue: 0,0:10:14.99,0:10:18.71,dialog,,0,0,0,,Setelah itu masing-masing anggota tadi\Nmembentuk tim baru lagi
Dialogue: 0,0:10:18.71,0:10:21.41,dialog,,0,0,0,,dengan jumlah maksimal 10 orang,
Dialogue: 0,0:10:21.41,0:10:23.60,dialog,,0,0,0,,terus balik lagi ke titik simpan tadi...
Dialogue: 0,0:10:24.15,0:10:28.10,dialog,,0,0,0,,Totalnya 100 orang.\NSeperti bawa pasukan kecil, ya.
Dialogue: 0,0:10:36.20,0:10:38.36,dialog,,0,0,0,,Ada cara seperti itu?
Dialogue: 0,0:10:38.36,0:10:41.31,dialog,,0,0,0,,Menurut penyelidikan Nona Souka,
Dialogue: 0,0:10:41.31,0:10:44.20,dialog,,0,0,0,,mereka kelompok tentara bayaran\Nterkenal bernama "Vert".
Dialogue: 0,0:10:44.20,0:10:48.97,dialog,,0,0,0,,Kabarnya, pendanaan mereka berasal\Ndari Kerajaan Ingrassia.
Dialogue: 0,0:10:49.45,0:10:51.21,dialog,,0,0,0,,Ingrassia, ya?
Dialogue: 0,0:10:51.21,0:10:56.44,dialog,,0,0,0,,Prediksiku, bos lantai 40 pun\Nakan mereka kalahkan.
Dialogue: 0,0:10:56.44,0:10:58.59,dialog,,0,0,0,,Melawan jumlah sebanyak itu,
Dialogue: 0,0:10:58.59,0:11:02.15,dialog,,0,0,0,,Gozul di lantai 50 pun\Nbelum tentu bisa bertahan.
Dialogue: 0,0:11:02.15,0:11:03.75,dialog,,0,0,0,,Iya juga.
Dialogue: 0,0:11:04.39,0:11:06.35,dialog,,0,0,0,,Gawat.
Dialogue: 0,0:11:06.87,0:11:09.27,dialog,,0,0,0,,Perkembangan ini benar-benar gawat.
Dialogue: 0,0:11:15.03,0:11:16.33,dialog,,0,0,0,,Sebenarnya...
Dialogue: 0,0:11:16.78,0:11:18.24,dialog,,0,0,0,,Hah?
Dialogue: 0,0:11:18.24,0:11:22.53,dialog,,0,0,0,,Bos monster lantai 60 ke atas tidak berfungsi?
Dialogue: 0,0:11:22.88,0:11:25.57,dialog,,0,0,0,,I-Ingat janji soal latihan tempur
Dialogue: 0,0:11:25.57,0:11:28.96,dialog,,0,0,0,,Crusaders di Festival Pendirian?
Dialogue: 0,0:11:28.96,0:11:30.76,dialog,,0,0,0,,Saat kamu lagi sibuk meneliti,
Dialogue: 0,0:11:30.76,0:11:33.63,dialog,,0,0,0,,pelatihan itu sudah dimulai dari lantai 51.
Dialogue: 0,0:11:33.63,0:11:36.54,dialog,,0,0,0,,Tapi, Elemental Colossus-ku
Dialogue: 0,0:11:36.54,0:11:39.88,dialog,,0,0,0,,malah membantai mereka semua di lantai 70.
Dialogue: 0,0:11:40.30,0:11:43.78,dialog,,0,0,0,,Terus Hinata lumayan kecewa sama mereka.
Dialogue: 0,0:11:44.53,0:11:47.52,dialog,,0,0,0,,Bukankah ini mustahil bagi\NNona Hinata sekalipun?
Dialogue: 0,0:11:47.52,0:11:48.49,dialog,,0,0,0,,Hah?
Dialogue: 0,0:11:53.08,0:11:54.52,dialog,,0,0,0,,Mustahil?
Dialogue: 0,0:11:54.52,0:11:58.31,dialog,,0,0,0,,Serangan dahsyat Hinata pun\Ndimulai dari situ!
Dialogue: 0,0:11:58.31,0:11:59.70,dialog,,0,0,0,,Uwah.
Dialogue: 0,0:11:59.70,0:12:02.95,dialog,,0,0,0,,Yah, memang sangat mengerikan, sih.
Dialogue: 0,0:12:03.34,0:12:06.95,dialog,,0,0,0,,Setelah menghancurkan\NElemental Colossus sebagai pemanasan,
Dialogue: 0,0:12:06.95,0:12:09.20,dialog,,0,0,0,,dia langsung mengalahkan bos-bos berikutnya!
Dialogue: 0,0:12:09.20,0:12:12.99,dialog,,0,0,0,,Bahkan sampai menembus lantai 90.
Dialogue: 0,0:12:12.99,0:12:16.71,dialog,,0,0,0,,Jadi, karena masalah semacam itu,\Ndungeon-nya jadi belum siap!
Dialogue: 0,0:12:16.71,0:12:19.72,dialog,,0,0,0,,Setelah itu, dia menginap santai
Dialogue: 0,0:12:19.72,0:12:22.53,dialog,,0,0,0,,di penginapan lantai 95.
Dialogue: 0,0:12:22.53,0:12:25.68,dialog,,0,0,0,,Bahkan naga-naga tangkapan Nona Milim pun
Dialogue: 0,0:12:25.68,0:12:27.51,dialog,,0,0,0,,habis dikalahkan olehnya.
Dialogue: 0,0:12:27.92,0:12:30.17,dialog,,0,0,0,,Kok kayak pemain speedrun, ya?
Dialogue: 0,0:12:30.17,0:12:31.89,dialog,,0,0,0,,Hm? Itu berarti...
Dialogue: 0,0:12:32.22,0:12:35.40,dialog,,0,0,0,,Iya, akhirnya aku bisa beraksi.
Dialogue: 0,0:12:35.40,0:12:37.78,dialog,,0,0,0,,Serius? Kamu sampai bertarung?
Dialogue: 0,0:12:37.78,0:12:39.94,dialog,,0,0,0,,Lawan semua yang datang!
Dialogue: 0,0:12:39.94,0:12:43.16,dialog,,0,0,0,,Sebagai bos terakhir, aku tidak akan kabur!
Dialogue: 0,0:12:43.65,0:12:45.78,dialog,,0,0,0,,Hinata memang benar-benar kuat.
Dialogue: 0,0:12:45.78,0:12:50.04,dialog,,0,0,0,,Dia bertarung sambil mencari\Nserangan apa yang mempan padaku.
Dialogue: 0,0:12:50.36,0:12:52.92,dialog,,0,0,0,,Meski cara bertarungnya kurang efisien,
Dialogue: 0,0:12:52.92,0:12:55.38,dialog,,0,0,0,,serangan terakhirnya terasa mantap.
Dialogue: 0,0:13:00.51,0:13:04.51,dialog,,0,0,0,,Serangannya mempan meski hanya sedikit.
Dialogue: 0,0:13:05.14,0:13:08.26,dialog,,0,0,0,,Teknik itu mengingatkanku\Npada Pemutus Mutlak
Dialogue: 0,0:13:08.26,0:13:11.25,dialog,,0,0,0,,milik pahlawan yang menyegelku\N300 tahun lalu.
Dialogue: 0,0:13:12.05,0:13:15.09,dialog,,0,0,0,,Setelah dipikir-pikir,\Ncara berpedangnya juga mirip.
Dialogue: 0,0:13:15.09,0:13:18.82,dialog,,0,0,0,,Bedanya serangan pahlawan itu\Nsangatlah efisien.
Dialogue: 0,0:13:18.82,0:13:21.25,dialog,,0,0,0,,Duh, pengin nonton!
Dialogue: 0,0:13:21.25,0:13:23.27,dialog,,0,0,0,,Jadi, kamu menang, kan?
Dialogue: 0,0:13:23.27,0:13:27.20,dialog,,0,0,0,,Jelas, kamu bukan khawatir soal itu, kan?
Dialogue: 0,0:13:27.76,0:13:31.33,dialog,,0,0,0,,Soalnya ada satu orang yang kalah\Nkarena terpesona sama lawan.
Dialogue: 0,0:13:31.33,0:13:34.04,dialog,,0,0,0,,A-Aku juga belajar dari kesalahan!
Dialogue: 0,0:13:34.48,0:13:37.84,dialog,,0,0,0,,Ternyata Hinata sehebat itu, ya.
Dialogue: 0,0:13:38.25,0:13:40.45,dialog,,0,0,0,,Yah, aku mengerti sekarang.
Dialogue: 0,0:13:40.45,0:13:45.09,dialog,,0,0,0,,Kita butuh solusi\Nuntuk bos lantai 60 ke atas, kan?
Dialogue: 0,0:13:45.09,0:13:47.56,dialog,,0,0,0,,Bu-Bukan hanya itu.
Dialogue: 0,0:13:47.56,0:13:51.93,dialog,,0,0,0,,Sebenarnya, Nona Hinata bertanya
Dialogue: 0,0:13:51.93,0:13:53.68,dialog,,0,0,0,,ada uang hadiahnya atau tidak.
Dialogue: 0,0:13:53.68,0:13:55.51,dialog,,0,0,0,,Tolak saja.
Dialogue: 0,0:13:55.51,0:13:59.40,dialog,,0,0,0,,Mata duitan banget, Ketua Holy Knight!\NGajinya kecil, ya?
Dialogue: 0,0:13:59.40,0:14:05.57,dialog,,0,0,0,,Maksudku, sebaiknya Tuan Rimuru saja yang bilang...
Dialogue: 0,0:14:07.16,0:14:09.33,dialog,,0,0,0,,Tolong, ya, Nak Mjollmile!
Dialogue: 0,0:14:09.33,0:14:12.54,dialog,,0,0,0,,Bentar, bentar, bentar!\NTuan Rimuru!
Dialogue: 0,0:14:13.94,0:14:16.21,dialog,,0,0,0,,Pertama, penguatan lantai 60.
Dialogue: 0,0:14:16.60,0:14:18.50,dialog,,0,0,0,,Yang kutugaskan menjadi bos...
Dialogue: 0,0:14:18.50,0:14:19.75,dialog,,0,0,0,,Sujud!
Dialogue: 0,0:14:20.83,0:14:23.26,dialog,,0,0,0,,Wight King Adalmann.
Dialogue: 0,0:14:23.26,0:14:26.12,dialog,,0,0,0,,Atas kekalahan saya dari Crusaders,
Dialogue: 0,0:14:26.12,0:14:28.24,dialog,,0,0,0,,saya sangat memohon maaf!
Dialogue: 0,0:14:28.24,0:14:32.06,dialog,,0,0,0,,Saya siap menerima hukuman apa pun\Ndengan lapang dada!
Dialogue: 0,0:14:32.06,0:14:36.02,dialog,,0,0,0,,Angkat kepalamu.\NKamilah yang kurang waspada.
Dialogue: 0,0:14:36.02,0:14:40.18,dialog,,0,0,0,,Lawanmu Holy Knight,\Nmusuh alami bagi undead sepertimu.
Dialogue: 0,0:14:41.49,0:14:46.70,dialog,,0,0,0,,Lagi pula, kamu sudah tidak bisa\Nmemakai sihir suci, kan?
Dialogue: 0,0:14:46.70,0:14:48.53,dialog,,0,0,0,,Bagaimana Anda bisa tahu?
Dialogue: 0,0:14:48.95,0:14:51.91,dialog,,0,0,0,,Sihir suci berasal dari kekuatan iman.
Dialogue: 0,0:14:52.31,0:14:56.04,dialog,,0,0,0,,Butuh kontrak dengan sosok yang mampu
Dialogue: 0,0:14:56.04,0:15:00.08,dialog,,0,0,0,,memanipulasi Spiritron sebagai imbalannya.
Dialogue: 0,0:15:00.62,0:15:05.73,dialog,,0,0,0,,Luminus mungkin memasukkan kontrak itu\Ndalam ritual keagamaan mereka.
Dialogue: 0,0:15:06.54,0:15:10.26,dialog,,0,0,0,,Masalahnya, sekarang kamu menyembahku.
Dialogue: 0,0:15:10.26,0:15:12.60,dialog,,0,0,0,,Artinya, kontrak itu sudah batal.
Dialogue: 0,0:15:13.01,0:15:15.66,dialog,,0,0,0,,Kamu tidak bisa meminjam\Nkekuatan Luminus lagi.
Dialogue: 0,0:15:15.66,0:15:17.52,dialog,,0,0,0,,A-Apa?
Dialogue: 0,0:15:17.52,0:15:21.18,dialog,,0,0,0,,Shuna mungkin sudah paham rahasianya,
Dialogue: 0,0:15:21.18,0:15:24.02,dialog,,0,0,0,,makanya dia bisa memakai sihir suci.
Dialogue: 0,0:15:24.02,0:15:28.07,dialog,,0,0,0,,Tepatnya, saya hanya menirunya\Ndengan kemampuan "Analis".
Dialogue: 0,0:15:28.79,0:15:32.27,dialog,,0,0,0,,Saya sangat memercayai Anda, Tuan Rimuru.
Dialogue: 0,0:15:32.27,0:15:37.71,dialog,,0,0,0,,Karena itu, entah kenapa saya merasa\Nbisa meminjam kekuatan Anda.
Dialogue: 0,0:15:37.71,0:15:39.87,dialog,,0,0,0,,Iya, kamu memang hebat.
Dialogue: 0,0:15:39.87,0:15:45.17,dialog,,0,0,0,,Jadi, aku akan memberikan "Rahasia Terdalam\NIman dan Anugerah" pada kalian berdua.
Dialogue: 0,0:15:45.17,0:15:47.77,dialog,,0,0,0,,Wight sepertimu bisa memakainya\Ntanpa efek samping.
Dialogue: 0,0:15:47.77,0:15:50.63,dialog,,0,0,0,,Meski mepet,\Naku sempat membuat sihir orisinal juga.
Dialogue: 0,0:15:51.02,0:15:53.55,dialog,,0,0,0,,Bu-Buatan Anda sendiri, Tuan Rimuru?
Dialogue: 0,0:15:53.88,0:15:56.31,dialog,,0,0,0,,Dengar, ini adalah kontrak.
Dialogue: 0,0:15:56.31,0:15:58.72,dialog,,0,0,0,,Sifatnya juga sangat rahasia.
Dialogue: 0,0:15:58.72,0:16:00.75,dialog,,0,0,0,,Jangan sampai bocor, ya.
Dialogue: 0,0:16:00.75,0:16:02.06,dialog,,0,0,0,,Baik!
Dialogue: 0,0:16:05.07,0:16:07.48,dialog,,0,0,0,,Holy Ray!
Dialogue: 0,0:16:11.32,0:16:14.95,dialog,,0,0,0,,Meluap! Kekuatanku meluap-luap!
Dialogue: 0,0:16:14.95,0:16:18.33,dialog,,0,0,0,,Tuhanku! Wahai Tuhanku Rimuru!
Dialogue: 0,0:16:18.87,0:16:21.28,dialog,,0,0,0,,Dia jadi makin berlebihan begini.
Dialogue: 0,0:16:21.28,0:16:23.46,dialog,,0,0,0,,Oh, iya, sekalian saja.
Dialogue: 0,0:16:30.92,0:16:35.26,dialog,,0,0,0,,Begini sudah cukup?\NRuangan bos baru buat Adalmann-nya?
Dialogue: 0,0:16:35.67,0:16:37.99,dialog,,0,0,0,,Boleh juga!
Dialogue: 0,0:16:39.27,0:16:42.77,dialog,,0,0,0,,Takhta yang diberikan Tuhanku Rimuru!
Dialogue: 0,0:16:43.19,0:16:46.77,dialog,,0,0,0,,Saya akan melindunginya sampai akhir!
Dialogue: 0,0:16:47.21,0:16:50.13,dialog,,0,0,0,,Dengan begini, lantai 60 sudah terisi.
Dialogue: 0,0:16:50.13,0:16:53.11,dialog,,0,0,0,,Aku sudah menyuruhnya membentuk tim\Ndengan tipe anggota berbeda.
Dialogue: 0,0:16:53.11,0:16:55.04,dialog,,0,0,0,,Hanya ini yang bisa kulakukan saat ini.
Dialogue: 0,0:16:55.04,0:17:00.11,dialog,,0,0,0,,Iya, kita hanya perlu menunggu sebentar\Nperkembangan dan evolusi bos lain.
Dialogue: 0,0:17:00.11,0:17:03.25,dialog,,0,0,0,,Tunggu sebentar!\NLantai 70?
Dialogue: 0,0:17:03.25,0:17:07.04,dialog,,0,0,0,,Elemental Colossus-ku masih rusak di sana!
Dialogue: 0,0:17:07.04,0:17:11.63,dialog,,0,0,0,,Eh? Bukannya monster dalam dungeon\Nbisa bangkit setelah dikalahkan?
Dialogue: 0,0:17:12.03,0:17:13.22,dialog,,0,0,0,,Soal itu...
Dialogue: 0,0:17:13.22,0:17:17.19,dialog,,0,0,0,,Waktu kamu menghancurkan\Ndungeon lama juga begini.
Dialogue: 0,0:17:17.19,0:17:20.45,dialog,,0,0,0,,Kenapa golemku tidak mau bangkit lagi, sih?
Dialogue: 0,0:17:20.45,0:17:21.98,dialog,,0,0,0,,Hiks!
Dialogue: 0,0:17:24.35,0:17:27.56,dialog,,0,0,0,,Tenang saja, aku punya ide.
Dialogue: 0,0:17:28.39,0:17:31.50,dialog,,0,0,0,,Pokoknya, sekarang kita perlu ulur waktu.
Dialogue: 0,0:17:31.50,0:17:34.10,dialog,,0,0,0,,Anggap situasi ini sebagai kesempatan.
Dialogue: 0,0:17:36.50,0:17:41.95,dialog,,0,0,0,,Jangan lupa, dungeon kita ini\Ntipe yang terus berevolusi.
Dialogue: 0,0:17:42.37,0:17:45.25,dialog,,0,0,0,,Kita makin kuat tiap kali mengatasi masalah.
Dialogue: 0,0:17:45.64,0:17:46.79,dialog,,0,0,0,,Benar, kan?
Dialogue: 0,0:17:46.79,0:17:48.92,dialog,,0,0,0,,Iya, itu sudah jelas.
Dialogue: 0,0:17:50.08,0:17:52.96,dialog,,0,0,0,,Kalian ada di sini rupanya.
Dialogue: 0,0:17:52.96,0:17:53.88,dialog,,0,0,0,,Hm?
Dialogue: 0,0:17:54.27,0:17:58.89,dialog,,0,0,0,,Aku sudah dengar\Nkalau naga-nagaku dikalahkan!
Dialogue: 0,0:17:58.89,0:18:00.89,dialog,,0,0,0,,I-Iya.
Dialogue: 0,0:18:01.44,0:18:04.23,dialog,,0,0,0,,Latihan kejam macam apa\Nyang dialami mereka?
Dialogue: 0,0:18:06.17,0:18:08.65,dialog,,0,0,0,,Aku selamat.
Dialogue: 0,0:18:09.05,0:18:11.72,dialog,,0,0,0,,Iya, kamu layak dapat pujian.
Dialogue: 0,0:18:11.72,0:18:14.15,dialog,,0,0,0,,Siapa sangka bisa menyelesaikan mode neraka.
Dialogue: 0,0:18:14.48,0:18:18.20,dialog,,0,0,0,,Oh, aku juga mau mengajarinya\Nbertarung ala Veldora.
Dialogue: 0,0:18:18.20,0:18:21.57,dialog,,0,0,0,,Jangan! Gobta itu muridku!
Dialogue: 0,0:18:21.57,0:18:23.25,dialog,,0,0,0,,Na-Napasku...
Dialogue: 0,0:18:23.25,0:18:27.80,dialog,,0,0,0,,Tu-Tuanku, saya pulang.
Dialogue: 0,0:18:27.80,0:18:31.00,dialog,,0,0,0,,Kamu sudah berjuang keras,\Nberistirahatlah dalam bayanganku.
Dialogue: 0,0:18:35.39,0:18:37.22,dialog,,0,0,0,,Kamu juga hebat, Gobta!
Dialogue: 0,0:18:37.22,0:18:39.19,dialog,,0,0,0,,- Aku akan mengajakmu ke toko elf\N- Ayo mampir.
Dialogue: 0,0:18:39.19,0:18:40.39,dialog,,0,0,0,,- yang sudah kujanjikan.\N- Ayo mampir.
Dialogue: 0,0:18:41.31,0:18:43.31,dialog,,0,0,0,,Serius?
Dialogue: 0,0:18:44.53,0:18:46.64,dialog,,0,0,0,,Sepertinya kamu masih sehat.
Dialogue: 0,0:18:48.65,0:18:52.65,dialog,,0,0,0,,Ampuni aku, dong!
Dialogue: 0,0:18:54.72,0:18:58.16,dialog,,0,0,0,,Jadi, apa yang sedang terjadi?
Dialogue: 0,0:19:00.37,0:19:02.28,dialog,,0,0,0,,Tim Amukan Hijau?
Dialogue: 0,0:19:02.58,0:19:07.17,dialog,,0,0,0,,Iya, akhirnya mereka berhasil\Nmengalahkan bos lantai 40.
Dialogue: 0,0:19:07.17,0:19:10.53,dialog,,0,0,0,,Apa maksudnya ini?\NKita tidak boleh diremehkan begini!
Dialogue: 0,0:19:10.53,0:19:11.67,dialog,,0,0,0,,Bukan masalah.
Dialogue: 0,0:19:12.23,0:19:16.67,dialog,,0,0,0,,Kalau terus lanjut, mereka akan\Nkena jebakanku di lantai 49.
Dialogue: 0,0:19:16.67,0:19:20.80,dialog,,0,0,0,,Itu tempat khusus isinya jebakan semua.
Dialogue: 0,0:19:21.34,0:19:25.48,dialog,,0,0,0,,Jangan bilang kita mau turun langsung?
Dialogue: 0,0:19:27.18,0:19:28.80,dialog,,0,0,0,,Kita pakai ini.
Dialogue: 0,0:19:29.79,0:19:31.59,dialog,,0,0,0,,Apa ini?
Dialogue: 0,0:19:32.41,0:19:34.29,dialog,,0,0,0,,Namanya "Jiwa Buatan".
Dialogue: 0,0:19:34.29,0:19:37.69,dialog,,0,0,0,,Ini prototipe yang meniru wadah jiwa.
Dialogue: 0,0:19:38.18,0:19:42.42,dialog,,0,0,0,,Oh, ternyata kamu bikin ini\Npas mengurung diri.
Dialogue: 0,0:19:42.42,0:19:44.20,dialog,,0,0,0,,Kalau yang hitam ini?
Dialogue: 0,0:19:44.62,0:19:46.05,dialog,,0,0,0,,"Master Core".
Dialogue: 0,0:19:46.05,0:19:48.96,dialog,,0,0,0,,Ini terbuat dari inti sihir Charybdis.
Dialogue: 0,0:19:48.96,0:19:51.46,dialog,,0,0,0,,Yah, lebih cepat kalau langsung dicoba.
Dialogue: 0,0:19:51.80,0:19:56.06,dialog,,0,0,0,,Semuanya, pegang ini dan bayangkan\Nmonster kesukaan kalian.
Dialogue: 0,0:19:56.06,0:19:58.72,dialog,,0,0,0,,Ah, jangan ganti di tengah jalan, ya.
Dialogue: 0,0:19:59.61,0:20:00.68,dialog,,0,0,0,,Monster?
Dialogue: 0,0:20:01.21,0:20:03.80,dialog,,0,0,0,,Sebenarnya apa yang kamu pikirkan?
Dialogue: 0,0:20:14.05,0:20:17.19,dialog,,0,0,0,,Makhluk yang muncul keren banget ini!
Dialogue: 0,0:20:17.61,0:20:22.00,dialog,,0,0,0,,Master Core akan berubah wujud\Nsesuai kehendak penggunanya.
Dialogue: 0,0:20:22.00,0:20:24.66,dialog,,0,0,0,,Sangat pas untuk melindungi\Nwadah jiwa juga.
Dialogue: 0,0:20:24.66,0:20:26.62,dialog,,0,0,0,,Keren banget!
Dialogue: 0,0:20:26.62,0:20:29.16,dialog,,0,0,0,,Kerangka itu memang kesukaan lelaki sejati!
Dialogue: 0,0:20:29.16,0:20:31.01,dialog,,0,0,0,,Mereka enggak dengar.
Dialogue: 0,0:20:31.01,0:20:33.52,dialog,,0,0,0,,Dia tumbuh sangat pesat!\NBukan main!
Dialogue: 0,0:20:33.52,0:20:35.42,dialog,,0,0,0,,Tumbuh sangat pesat!
Dialogue: 0,0:20:35.76,0:20:36.85,dialog,,0,0,0,,Milim?
Dialogue: 0,0:20:40.67,0:20:42.05,dialog,,0,0,0,,Ternyata slime!
Dialogue: 0,0:20:42.05,0:20:45.85,dialog,,0,0,0,,Biarkan saja!\NLagian aku suka, kok!
Dialogue: 0,0:20:48.13,0:20:50.71,dialog,,0,0,0,,Rasanya bikin malu.
Dialogue: 0,0:20:50.71,0:20:52.10,dialog,,0,0,0,,Oh, begitu.
Dialogue: 0,0:20:52.10,0:20:56.73,dialog,,0,0,0,,Kamu ingin menggunakan mereka\Nuntuk mencegat Tim Amukan Hijau, kan?
Dialogue: 0,0:20:57.14,0:20:58.73,dialog,,0,0,0,,Begitulah.
Dialogue: 0,0:20:58.73,0:21:01.95,dialog,,0,0,0,,Tapi, golem buatan Rimuru...
Dialogue: 0,0:21:02.51,0:21:04.36,dialog,,0,0,0,,Enggak mau gerak!
Dialogue: 0,0:21:06.05,0:21:08.16,dialog,,0,0,0,,Inilah fitur utamanya.
Dialogue: 0,0:21:09.96,0:21:10.91,dialog,,0,0,0,,Merasuk.
Dialogue: 0,0:21:15.22,0:21:16.22,dialog,,0,0,0,,Rimuru!
Dialogue: 0,0:21:16.22,0:21:17.59,dialog,,0,0,0,,- Kamu lapar?\N- Tiba-tiba?
Dialogue: 0,0:21:18.55,0:21:20.28,dialog,,0,0,0,,Hm? Kesadarannya...
Dialogue: 0,0:21:20.74,0:21:22.34,dialog,,0,0,0,,Wah.
Dialogue: 0,0:21:22.70,0:21:25.24,dialog,,0,0,0,,Ternyata langsung terbiasa.
Dialogue: 0,0:21:26.30,0:21:28.73,dialog,,0,0,0,,Kamu Rimuru?
Dialogue: 0,0:21:28.73,0:21:29.46,dialog,,0,0,0,,Iya.
Dialogue: 0,0:21:29.46,0:21:31.10,dialog,,0,0,0,,Apa yang kamu lakukan?
Dialogue: 0,0:21:31.10,0:21:36.02,dialog,,0,0,0,,Gabungkan Jiwa Buatan berisi jiwamu\Ndengan Master Core.
Dialogue: 0,0:21:37.90,0:21:41.65,dialog,,0,0,0,,Jadi kalian bisa punya Avatar Core\Nyang bisa digerakkan sesuka hati.
Dialogue: 0,0:21:42.95,0:21:44.65,dialog,,0,0,0,,- Ayo kita coba juga!\N- Ayo sikat!
Dialogue: 0,0:21:47.66,0:21:49.16,dialog,,0,0,0,,Merasuk.
Dialogue: 0,0:21:52.12,0:21:54.83,dialog,,0,0,0,,Wah! Benaran bisa digerakkan!
Dialogue: 0,0:21:54.83,0:21:58.49,dialog,,0,0,0,,Aku selalu percaya kalau kamu\Norang yang hebat, Rimuru!
Dialogue: 0,0:21:58.49,0:22:01.80,dialog,,0,0,0,,Kalau aku dari awal sudah percaya!
Dialogue: 0,0:22:01.80,0:22:05.05,dialog,,0,0,0,,Mereka ini jago banget menjilat orang!
Dialogue: 0,0:22:05.53,0:22:07.69,dialog,,0,0,0,,Ayo kita berangkat.
Dialogue: 0,0:22:07.69,0:22:12.18,dialog,,0,0,0,,Mari kita habisi para penantang,\Nbukan, para penyusup itu!
Dialogue: 0,0:23:50.54,0:23:52.02,dialog,,0,0,0,,Gampang banget, ya.
Dialogue: 0,0:23:52.02,0:23:54.12,dialog,,0,0,0,,Mereka cuma keroco.
Dialogue: 0,0:23:56.31,0:24:00.40,dialog,,0,0,0,,Siapa sangka kita dikalahkan tim pemula.
Dialogue: 0,0:24:00.40,0:24:05.06,dialog,,0,0,0,,Kita harus latihan!
Dialogue: 0,0:24:06.05,0:24:09.60,dialog,,0,0,0,,Selanjutnya, "Pembentukan Tim Avatar".
