Dialogue: 0,0:01:01.82,0:01:03.85,sign,,0000,0000,0000,,PRIMORDIAL KUNING - JAUNE
Dialogue: 0,0:03:16.30,0:03:17.22,sign,,0000,0000,0000,,EPISODE 86: LEGIUN HITAM
Dialogue: 0,0:07:11.29,0:07:15.05,sign,,0000,0000,0000,,"PRIMORDIAL UNGU - VIOLET"
Dialogue: 0,0:10:11.63,0:10:13.39,sign,,0000,0000,0000,,PRIMORDIAL PUTIH - BLANC
Dialogue: 0,0:15:07.99,0:15:09.50,sign,,0000,0000,0000,,LANTAI 100 BAWAH TANAH
Dialogue: 0,0:19:02.29,0:19:05.71,sign,,0000,0000,0000,,REKAN DEMON - CARRERA
Dialogue: 0,0:19:06.46,0:19:09.84,sign,,0000,0000,0000,,REKAN DEMON - ULTIMA
Dialogue: 0,0:19:10.59,0:19:13.97,sign,,0000,0000,0000,,REKAN DEMON - TESTAROSSA
Dialogue: 0,0:19:57.09,0:19:57.71,sign,,0000,0000,0000,,ARCH DEMON: ESPRIT, AGERA, ZONDA, CIEN
Dialogue: 0,0:20:02.76,0:20:03.34,sign,,0000,0000,0000,,DEMON PEER: VEYRON, MOSS
Dialogue: 0,0:20:03.35,0:20:06.18,sign,,0000,0000,0000,,"ARCH DEMON: VENOM
Dialogue: 0,0:24:09.01,0:24:12.66,sign,,0000,0000,0000,,HAWA KEBERADAAN YANG MENCEKAM
Dialogue: 0,0:00:13.02,0:00:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia Iblis.
Dialogue: 0,0:00:14.47,0:00:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia para Demon\Nyang merupakan makhluk spiritual,
Dialogue: 0,0:00:18.25,0:00:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebuah dunia roh yang juga dikenal\Nsebagai Alam Baka atau Neraka.
Dialogue: 0,0:00:23.04,0:00:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:00:24.84,0:00:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:00:26.88,0:00:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kamu bukan orang sini!
Dialogue: 0,0:00:29.86,0:00:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengganggu.
Dialogue: 0,0:00:37.72,0:00:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai makhluk spiritual, para Demon
Dialogue: 0,0:00:40.28,0:00:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan bangkit kembali\Nmeski tubuh mereka dihancurkan.
Dialogue: 0,0:00:43.65,0:00:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah karakteristik sekaligus batasan\Nbagi mereka yang tak memiliki tubuh material.
Dialogue: 0,0:00:50.61,0:00:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia materi, para Demon
Dialogue: 0,0:00:52.99,0:00:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan bisa bermanifestasi\Ntanpa wadah fisik.
Dialogue: 0,0:00:56.62,0:01:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi mereka, mendapatkan tubuh fisik adalah\Nambisi yang paling didambakan.
Dialogue: 0,0:01:03.86,0:01:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa, Jaune.
Dialogue: 0,0:01:08.00,0:01:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noir, kamu telah bermanifestasi?
Dialogue: 0,0:01:13.85,0:01:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku sudah punya nama, yaitu Diablo.
Dialogue: 0,0:01:17.85,0:01:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku Rimuru yang memberikan\Nnama berharga ini.
Dialogue: 0,0:01:22.39,0:01:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memberimu nama?
Dialogue: 0,0:01:24.40,0:01:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:01:25.74,0:01:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu kehormatan\Nuntuk mengabdi padanya, Jaune.
Dialogue: 0,0:01:32.28,0:01:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha!
Dialogue: 0,0:01:41.43,0:01:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkhayalnya setelah mati saja, Noir!
Dialogue: 0,0:03:14.72,0:03:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}(Tensura) Bereinkarnasi Malah Menjadi Slime
Dialogue: 0,0:03:17.23,0:03:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:03:28.32,0:03:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya memandang rendah diriku!
Dialogue: 0,0:03:38.45,0:03:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:03:39.46,0:03:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betapa bodohnya, padahal sudah kutawari\Nmengabdi pada Tuan Rimuru.
Dialogue: 0,0:03:46.04,0:03:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubunuh kamu!
Dialogue: 0,0:03:55.53,0:03:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil kamu bisa\Nmengalahkanku yang sekarang.
Dialogue: 0,0:03:58.77,0:04:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi Rimuru yang memberimu nama?
Dialogue: 0,0:04:03.27,0:04:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak terima kamu memanggilnya begitu.
Dialogue: 0,0:04:05.64,0:04:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mulai tertarik?
Dialogue: 0,0:04:07.53,0:04:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya luar biasa secara spiritual,\Nwujudnya juga sangat mengagumkan.
Dialogue: 0,0:04:12.90,0:04:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu berkilau, bening hingga tampak agung,
Dialogue: 0,0:04:15.77,0:04:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat kenyal, menyejukkan,\Ndan menggemaskan!
Dialogue: 0,0:04:17.95,0:04:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bening?\NKenyal?
Dialogue: 0,0:04:20.82,0:04:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:04:23.40,0:04:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Beliau memiliki wujud slime!\N- Kenyal!
Dialogue: 0,0:04:26.84,0:04:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Slime jadi Raja Iblis?
Dialogue: 0,0:04:29.84,0:04:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik juga.
Dialogue: 0,0:04:31.46,0:04:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengalahkannya\Nsetelah mengalahkanmu!
Dialogue: 0,0:04:34.55,0:04:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir bisa menang?
Dialogue: 0,0:04:55.70,0:04:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu tubuh\Nasalkan mau mengikutiku.
Dialogue: 0,0:05:00.47,0:05:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaune, Violet, serta Blanc.
Dialogue: 0,0:05:04.13,0:05:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bertiga\Nsaling menghalangi untuk bermanifestasi,
Dialogue: 0,0:05:07.44,0:05:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan saling menjatuhkan selama ribuan\Nhingga puluhan ribu tahun.
Dialogue: 0,0:05:11.92,0:05:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh menggelikan.
Dialogue: 0,0:05:14.76,0:05:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian menginginkan tantangan, kan?
Dialogue: 0,0:05:34.53,0:05:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah sadar posisimu?
Dialogue: 0,0:05:37.99,0:05:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mampir ke sini lagi,\Njadi persiapkan dirimu.
Dialogue: 0,0:05:43.04,0:05:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian ubah sikap kurang ajarmu itu.
Dialogue: 0,0:05:49.88,0:05:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis slime?
Dialogue: 0,0:05:53.78,0:05:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia lebih menarik daripada Leon.
Dialogue: 0,0:06:02.56,0:06:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kalah.
Dialogue: 0,0:06:04.13,0:06:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak kalah.
Dialogue: 0,0:06:05.39,0:06:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada lain kali.
Dialogue: 0,0:06:07.27,0:06:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibilang aku tidak kalah!
Dialogue: 0,0:06:11.81,0:06:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari-hari membosankan ini\Nsepertinya akan berakhir.
Dialogue: 0,0:06:18.20,0:06:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan soal itu.
Dialogue: 0,0:06:20.76,0:06:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balas dendamnya harus hari ini juga!
Dialogue: 0,0:06:27.43,0:06:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, apa-apaan dia itu?
Dialogue: 0,0:06:30.50,0:06:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bukan Demon,\Naku bisa langsung lenyap!
Dialogue: 0,0:06:33.61,0:06:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucari, lalu kupukul dia.
Dialogue: 0,0:06:36.34,0:06:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:37.34,0:06:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:06:42.14,0:06:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, Jaune itu tidak ada kapoknya.
Dialogue: 0,0:06:46.35,0:06:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ke sini, sialan!\NBeraninya menyerangku tadi!
Dialogue: 0,0:06:59.97,0:07:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, selanjutnya...
Dialogue: 0,0:07:06.77,0:07:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian...
Dialogue: 0,0:07:08.41,0:07:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa benar sudah introspeksi diri?
Dialogue: 0,0:07:11.29,0:07:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum, kan? Belum, sih.
Dialogue: 0,0:07:15.05,0:07:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona.
Dialogue: 0,0:07:18.55,0:07:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kita mulai.
Dialogue: 0,0:07:22.89,0:07:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lagi sibuk.\NBisa jangan mengganggu?
Dialogue: 0,0:07:26.64,0:07:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noir.
Dialogue: 0,0:07:28.16,0:07:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang namaku Diablo, Violet.
Dialogue: 0,0:07:31.89,0:07:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph!
Dialogue: 0,0:07:36.42,0:07:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku kamu tidak terlihat sibuk.
Dialogue: 0,0:07:38.78,0:07:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka telah menggagalkan\Nrencana manifestasiku.
Dialogue: 0,0:07:43.88,0:07:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lagi menghukumnya.
Dialogue: 0,0:07:46.04,0:07:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manifestasi, ya?
Dialogue: 0,0:07:48.04,0:07:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan.
Dialogue: 0,0:07:49.86,0:07:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau mengabdi pada Tuan Rimuru,\Nharapanmu akan terkabul.
Dialogue: 0,0:07:54.82,0:07:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jangan ikut campur?
Dialogue: 0,0:07:57.13,0:08:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak punya hak menolak.
Dialogue: 0,0:08:00.13,0:08:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas kamu tidak bisa\Nmenang melawanku, kan?
Dialogue: 0,0:08:05.86,0:08:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubunuh!
Dialogue: 0,0:08:06.93,0:08:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaune dan Blanc.
Dialogue: 0,0:08:09.45,0:08:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyampaikan ini pada mereka juga.
Dialogue: 0,0:08:12.35,0:08:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin keputusan mereka yang bijak\Nakan mendahuluimu bermanifestasi.
Dialogue: 0,0:08:23.24,0:08:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa soal manifestasi itu benar?
Dialogue: 0,0:08:26.82,0:08:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, biasanya dia tidak bisa dipercaya.
Dialogue: 0,0:08:31.78,0:08:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tubuhnya mengecewakan,\Ntinggal bunuh saja semuanya.
Dialogue: 0,0:08:39.15,0:08:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua pikirannya simpel,
Dialogue: 0,0:08:41.26,0:08:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Blanc tidak bisa dibujuk semudah itu.
Dialogue: 0,0:08:46.26,0:08:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, dasar bedebah itu.
Dialogue: 0,0:08:50.04,0:08:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:08:50.60,0:08:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia, kali ini\Nakan kutunjukkan kengerianku!
Dialogue: 0,0:08:57.33,0:09:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ora, ora, ora!
Dialogue: 0,0:09:00.66,0:09:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:09:03.93,0:09:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh! Sakit banget!
Dialogue: 0,0:09:06.78,0:09:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentunya dia tidak sebodoh itu,\N- Ah, sakit!
Dialogue: 0,0:09:09.59,0:09:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai tidak menyadari pesona Tuan Rimuru.
Dialogue: 0,0:09:17.21,0:09:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:09:20.81,0:09:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya ada yang bisa diajak diskusi.
Dialogue: 0,0:09:25.26,0:09:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antarkan aku ke tempat Blanc.
Dialogue: 0,0:09:28.72,0:09:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Hitam...
Dialogue: 0,0:09:31.45,0:09:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kutolak, aku akan bernasib sama\Ndengan mayat-mayat itu.
Dialogue: 0,0:09:34.93,0:09:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau membiarkannya masuk,\Nhukuman sudah menantiku.
Dialogue: 0,0:09:40.31,0:09:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah yang namanya terpojok?
Dialogue: 0,0:09:47.61,0:09:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa, Raja Hitam.
Dialogue: 0,0:09:50.13,0:09:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku...
Dialogue: 0,0:09:51.93,0:09:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin menemuimu.
Dialogue: 0,0:09:57.70,0:09:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:09:59.43,0:10:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu sembunyi di sini, Blanc.
Dialogue: 0,0:10:13.40,0:10:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu sudah bermanifestasi, Noir.
Dialogue: 0,0:10:16.39,0:10:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:17.97,0:10:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku sekarang...
Dialogue: 0,0:10:19.40,0:10:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diablo, kan?
Dialogue: 0,0:10:25.22,0:10:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, pembahasannya jadi cepat.
Dialogue: 0,0:10:27.91,0:10:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku sedang mengabdi\Nsebagai bawahan Raja Iblis Rimuru.
Dialogue: 0,0:10:34.12,0:10:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah menorehkan pencapaian luar biasa!
Dialogue: 0,0:10:37.24,0:10:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan berkali-kali menerima\Npujian langsung dari beliau.
Dialogue: 0,0:10:40.68,0:10:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah, Blanc,
Dialogue: 0,0:10:42.29,0:10:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ke sini untuk memberi tahu dirimu\Nbetapa indahnya mengabdi
Dialogue: 0,0:10:47.57,0:10:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di bawah kepemimpinan Tuan Rimuru.
Dialogue: 0,0:10:49.43,0:10:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, suasana hati tuanku...
Dialogue: 0,0:10:51.97,0:10:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Raja Hitam...
Dialogue: 0,0:10:58.69,0:11:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam dulu.
Dialogue: 0,0:11:16.93,0:11:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita temui dia.
Dialogue: 0,0:11:19.87,0:11:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin bertemu dengannya.
Dialogue: 0,0:11:29.26,0:11:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh...
Dialogue: 0,0:11:31.05,0:11:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:11:33.30,0:11:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:11:36.02,0:11:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jadikan aku bawahanmu!
Dialogue: 0,0:11:38.53,0:11:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan apa saja!\NJadi...
Dialogue: 0,0:11:43.72,0:11:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya beri tahu namamu!
Dialogue: 0,0:11:49.16,0:11:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:11:51.19,0:11:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Diablo.
Dialogue: 0,0:11:53.65,0:11:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu Empat Petinggi yang setia\Nkepada Tuan Rimuru.
Dialogue: 0,0:11:57.91,0:12:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja... Iblis... Rimuru?
Dialogue: 0,0:12:02.67,0:12:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:12:13.06,0:12:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis Rimuru.
Dialogue: 0,0:12:18.79,0:12:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekretaris Kedua, Diablo,
Dialogue: 0,0:12:21.30,0:12:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah kembali.
Dialogue: 0,0:12:22.95,0:12:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:12:24.90,0:12:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kamu baik-baik saja,\Nmeski aku tidak cemas, sih.
Dialogue: 0,0:12:29.69,0:12:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh perkataan yang indah!\NAkan saya ukir dalam hati!
Dialogue: 0,0:12:35.94,0:12:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana rekrutanmu?
Dialogue: 0,0:12:38.01,0:12:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjalan lancar.
Dialogue: 0,0:12:39.45,0:12:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk saat ini, ada tiga orang.
Dialogue: 0,0:12:42.44,0:12:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka orang-orang yang saya anggap layak
Dialogue: 0,0:12:45.78,0:12:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk langsung menghadap Anda.
Dialogue: 0,0:12:54.81,0:12:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ketiganya wanita, ya?
Dialogue: 0,0:12:57.65,0:12:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik semua pula.
Dialogue: 0,0:12:59.63,0:13:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenalan lama Diablo, ya?
Dialogue: 0,0:13:02.17,0:13:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak kelihatan kuat, sih.
Dialogue: 0,0:13:06.41,0:13:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:13:07.64,0:13:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketiganya adalah Arch Demon,\Nkasta atas di antara para Demon.
Dialogue: 0,0:13:11.54,0:13:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arch Demon?
Dialogue: 0,0:13:13.19,0:13:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya mereka menyamar sebagai manusia\Ndengan mengendalikan magi mereka.
Dialogue: 0,0:13:18.13,0:13:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, pantas saja.
Dialogue: 0,0:13:21.58,0:13:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamaran kalian luar biasa juga,\Nbenaran terlihat seperti manusia.
Dialogue: 0,0:13:25.35,0:13:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Holy Knight saja tidak bisa\Nmelihat kalian sebagai Arch Demon.
Dialogue: 0,0:13:31.34,0:13:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah bicara?
Dialogue: 0,0:13:34.22,0:13:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru memang hebat.
Dialogue: 0,0:13:36.29,0:13:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, giliran mereka memperkenalkan diri.
Dialogue: 0,0:13:43.51,0:13:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan, aku Raja Iblis Rimuru.
Dialogue: 0,0:13:46.45,0:13:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya kamu bisa menguak\Nidentitas kami dalam sekejap.
Dialogue: 0,0:13:49.98,0:13:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:13:57.86,0:14:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu bisa diandalkan.
Dialogue: 0,0:14:17.96,0:14:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku ini tidak mengecewakan.
Dialogue: 0,0:14:20.55,0:14:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawa dua ratus pasukanku\Nuntuk mengabdi padamu!
Dialogue: 0,0:14:25.64,0:14:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mohon bantuannya.
Dialogue: 0,0:14:28.14,0:14:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, yang selanjutnya.
Dialogue: 0,0:14:31.22,0:14:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan, Tuan Rimuru.
Dialogue: 0,0:14:33.93,0:14:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya bersama dua ratus bawahan saya.
Dialogue: 0,0:14:36.17,0:14:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon izinkan kami untuk mengabdi\Ndi bawah perintah Anda.
Dialogue: 0,0:14:40.11,0:14:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama, maksudku, saya.
Dialogue: 0,0:14:43.18,0:14:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama dua ratus pelayan saya,\Nsaya ingin mengabdi kepadamu.
Dialogue: 0,0:14:47.55,0:14:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mohon bantuan kalian juga.
Dialogue: 0,0:14:50.54,0:14:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain mereka bertiga, ada satu lagi\Nyang menurut saya menarik.
Dialogue: 0,0:14:55.30,0:15:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia memiliki seratus bawahan,\Ntotalnya menjadi tujuh ratus.
Dialogue: 0,0:15:00.23,0:15:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya berniat menyiapkan seribu Demon,\Ntetapi diri ini sungguh mengecewakan!
Dialogue: 0,0:15:05.14,0:15:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup banyak, kok.
Dialogue: 0,0:15:09.51,0:15:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian boleh menampakkan diri.
Dialogue: 0,0:15:12.22,0:15:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujudkan diri kalian!
Dialogue: 0,0:15:27.09,0:15:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:15:28.57,0:15:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya mereka juga Arch Demon?
Dialogue: 0,0:15:31.33,0:15:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keenam orang ini\Nkepercayaan ketiga orang tadi.
Dialogue: 0,0:15:34.49,0:15:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya bisa sedikit diandalkan.
Dialogue: 0,0:15:37.21,0:15:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:15:38.67,0:15:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya memungut Greater Demon ini\Ndi tengah jalan.
Dialogue: 0,0:15:41.63,0:15:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan tanya\Nalasan dia babak belur, deh.
Dialogue: 0,0:15:45.05,0:15:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, beri salam kepada Tuan Rimuru.
Dialogue: 0,0:15:50.80,0:15:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai saat ini,\Nkami pelayan setia Raja Iblis Rimuru.
Dialogue: 0,0:15:55.81,0:15:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan beri kami perintah.
Dialogue: 0,0:15:58.30,0:16:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung saja...
Dialogue: 0,0:16:10.55,0:16:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, kali ini ada apa lagi?
Dialogue: 0,0:16:12.83,0:16:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:16:15.32,0:16:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuat kalian menunggu.
Dialogue: 0,0:16:17.29,0:16:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau aku saja yang mengatur\Npenampilan kalian?
Dialogue: 0,0:16:20.65,0:16:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung olehmu?
Dialogue: 0,0:16:22.54,0:16:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terlihat lebih dari yang lain.
Dialogue: 0,0:16:25.11,0:16:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:16:27.48,0:16:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat pakai inti kerangka yang ini.
Dialogue: 0,0:16:30.57,0:16:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:16:31.82,0:16:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orihalcum!
Dialogue: 0,0:16:34.66,0:16:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali.
Dialogue: 0,0:16:41.56,0:16:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, mereka bertiga itu...
Dialogue: 0,0:16:44.77,0:16:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umurnya sudah panjang banget, kan?
Dialogue: 0,0:16:46.81,0:16:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun berpikiran sama.
Dialogue: 0,0:16:48.53,0:16:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begitu, ya.
Dialogue: 0,0:16:50.78,0:16:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masing-masing dari mereka bahkan punya\Ndua Arch Demon yang selevel sebagai pelayan.
Dialogue: 0,0:16:55.43,0:17:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada faktor lain yang tidak bisa diukur\Nhanya dari jumlah energi belaka?
Dialogue: 0,0:17:00.58,0:17:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab.
Dialogue: 0,0:17:01.74,0:17:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara para Demon, terdapat klasifikasi\Nberdasarkan usia hidup mereka.
Dialogue: 0,0:17:05.69,0:17:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dari Ras Kuno\Nyang sudah hidup lebih dari seribu tahun,
Dialogue: 0,0:17:08.58,0:17:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}termasuk dalam kasta penguasa
Dialogue: 0,0:17:10.61,0:17:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan konon memiliki otoritas mutlak\Ndari Demon lain.
Dialogue: 0,0:17:14.26,0:17:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diduga Individu Diablo dan ketiga Demon tadi\Ntermasuk dalam kasta penguasa ini.
Dialogue: 0,0:17:20.19,0:17:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:17:21.58,0:17:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya, ketiga gadis itu sama\Nmengerikannya dengan Diablo, kan?
Dialogue: 0,0:17:26.41,0:17:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:17:27.56,0:17:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan soal berapa lama mereka hidup.
Dialogue: 0,0:17:29.83,0:17:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting sekarang kita ketambahan\Nkawan Demon yang luar biasa, kan?
Dialogue: 0,0:17:33.82,0:17:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan seberapa lama mereka hidup,\Ntetapi cara mereka hidup.
Dialogue: 0,0:17:37.85,0:17:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar begitu, kan?
Dialogue: 0,0:17:39.54,0:17:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:17:41.10,0:17:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama mereka siapa?
Dialogue: 0,0:17:43.46,0:17:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:17:44.86,0:17:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau begitu...
Dialogue: 0,0:17:46.30,0:17:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan bilang...
Dialogue: 0,0:17:47.94,0:17:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menamai kalian.
Dialogue: 0,0:17:51.93,0:17:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa akan baik-baik saja?
Dialogue: 0,0:17:53.57,0:17:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aman saja.
Dialogue: 0,0:17:55.88,0:18:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan nama, kalian bisa bertambah kuat\Ndan lebih mudah dipanggil juga.
Dialogue: 0,0:18:00.66,0:18:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana?
Dialogue: 0,0:18:02.69,0:18:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati.
Dialogue: 0,0:18:04.79,0:18:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang!
Dialogue: 0,0:18:06.56,0:18:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan.
Dialogue: 0,0:18:08.32,0:18:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, sudah diputuskan.
Dialogue: 0,0:18:10.49,0:18:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita gunakan nama seri mobil sport\Nsama seperti Diablo.
Dialogue: 0,0:18:14.55,0:18:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Testarossa.
Dialogue: 0,0:18:16.53,0:18:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Carrera.
Dialogue: 0,0:18:18.54,0:18:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ultima.
Dialogue: 0,0:18:20.54,0:18:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, itulah nama kalian!
Dialogue: 0,0:18:27.27,0:18:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalau asal memberi nama pada mereka...
Dialogue: 0,0:18:54.15,0:18:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:18:55.59,0:18:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab.
Dialogue: 0,0:18:57.07,0:19:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah memberi mereka nama,\Nmereka berevolusi menjadi Demon Lord.
Dialogue: 0,0:19:13.97,0:19:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius, nih?\NJumlah energinya gila banget.
Dialogue: 0,0:19:17.72,0:19:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisi tubuh kalian?
Dialogue: 0,0:19:19.74,0:19:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbaik!
Dialogue: 0,0:19:21.03,0:19:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tubuh ini sangat luar biasa.
Dialogue: 0,0:19:24.12,0:19:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru, izinkan saya terus mengikrarkan\Nkesetiaan ini kepada Anda.
Dialogue: 0,0:19:30.90,0:19:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, sejak pandangan pertama,\Ndebaran ini tidak mau berhenti.
Dialogue: 0,0:19:35.88,0:19:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku juga sejak tadi tidak bisa\Nmenahan rasa berdebar ini!
Dialogue: 0,0:19:39.59,0:19:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melayanimu\Ndengan segenap kemampuanku!
Dialogue: 0,0:19:41.97,0:19:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!\NPerintahkan apa saja padaku, Tuanku!
Dialogue: 0,0:19:45.96,0:19:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, lakukan saja sesuka kalian.
Dialogue: 0,0:19:51.64,0:19:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil memberikan tubuh untuk para Demon lainnya,\Naku pun memberi mereka nama.
Dialogue: 0,0:19:57.72,0:20:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara orang-orang kepercayaan mereka,\NMoss dan Veyron berevolusi menjadi Demon Lord.
Dialogue: 0,0:20:03.35,0:20:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sementara Venom berevolusi menjadi Arch Demon.
Dialogue: 0,0:20:07.06,0:20:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan memanfaatkan magi di dalam kapsul,\Nproses pemberian nama pun selesai dalam dua hari.
Dialogue: 0,0:20:12.34,0:20:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat nama baru itu, para bawahan lainnya\Njuga naik pangkat ke kelas A ke atas.
Dialogue: 0,0:20:18.34,0:20:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itulah, pasukan iblis yang akan dikenal\Nsebagai "Legiun Hitam" resmi terlahir.
Dialogue: 0,0:20:26.87,0:20:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diablo.
Dialogue: 0,0:20:27.89,0:20:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:20:29.12,0:20:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku paham alasanmu\Nmengagumi Tuan Rimuru.
Dialogue: 0,0:20:32.88,0:20:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, beliau hebat juga.
Dialogue: 0,0:20:36.09,0:20:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa langsung membongkar penyamaran kami.
Dialogue: 0,0:20:39.78,0:20:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan bisa menahan tekanan intimidasiku\Nseolah sedang mengelus anak kucing!
Dialogue: 0,0:20:44.51,0:20:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau beliau ternyata membosankan,\Naku berniat membunuhmu juga.
Dialogue: 0,0:20:48.68,0:20:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:20:50.42,0:20:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah tidak membuatku malu\Ndi hadapan Tuan Rimuru.
Dialogue: 0,0:20:55.16,0:20:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian berniat melakukannya...
Dialogue: 0,0:20:57.33,0:20:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Diablo.
Dialogue: 0,0:21:00.71,0:21:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendapatkan tubuh\Nadalah impian terbesar para Demon.
Dialogue: 0,0:21:03.61,0:21:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi hal itu, kita menghabiskan waktu lama\Nuntuk mencari tubuh yang ideal.
Dialogue: 0,0:21:09.41,0:21:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Tuan Rimuru telah memberikan\Ntubuh yang sangat cocok untukku.
Dialogue: 0,0:21:16.20,0:21:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, sama seperti dirimu\Nyang bangga dengan namamu,
Dialogue: 0,0:21:20.43,0:21:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga sangat menyukai nama
Dialogue: 0,0:21:23.37,0:21:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Testarossa yang dianugerahkan olehnya.
Dialogue: 0,0:21:29.62,0:21:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi nama ini, aku bersumpah akan setia.
Dialogue: 0,0:21:33.00,0:21:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bersumpah demi nama Ultima.
Dialogue: 0,0:21:35.90,0:21:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mengabdi padanya lebih menyenangkan\Ndaripada menyiksa para Demon.
Dialogue: 0,0:21:41.70,0:21:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bersumpah demi nama Carrera.
Dialogue: 0,0:21:47.43,0:21:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, jangan sampai merepotkanku.
Dialogue: 0,0:21:53.10,0:21:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya pada Tuan Rimuru,\Nkalian juga harus menuruti perintahku.
Dialogue: 0,0:22:03.08,0:22:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih seperti itulah percakapan kami.
Dialogue: 0,0:22:05.85,0:22:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berada di bawah komando saya,
Dialogue: 0,0:22:09.39,0:22:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi entah apa yang akan mereka perbuat.
Dialogue: 0,0:22:11.74,0:22:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ini kekhawatiran yang tidak perlu,\Nmohon tetap berhati-hati.
Dialogue: 0,0:22:16.11,0:22:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya...
Dialogue: 0,0:22:17.88,0:22:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kan kamu yang memanggil mereka bertiga!
Dialogue: 0,0:22:22.57,0:22:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:22:24.86,0:22:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mereka ada di bawah\Nkomando Diablo, sih.
Dialogue: 0,0:22:28.62,0:22:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya jadi tanggung jawab dia.
Dialogue: 0,0:22:32.62,0:22:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ini lezat!
Dialogue: 0,0:24:05.92,0:24:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Hawa Keberadaan yang Mencekam".
