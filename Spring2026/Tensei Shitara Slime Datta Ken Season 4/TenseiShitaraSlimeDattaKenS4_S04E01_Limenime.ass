Dialogue: 0,0:00:11.73,0:00:15.98,tanda,,0000,0000,0000,,IBU KOTA FEDERASI JURA TEMPEST: RIMURU
Dialogue: 0,0:03:30.31,0:03:32.98,tanda,,0000,0000,0000,,BEREINKARNASI MALAH MENJADI SLIME\NMUSIM KEEMPAT
Dialogue: 0,0:03:33.31,0:03:38.03,tanda,,0000,0000,0000,,EPISODE 73: KESEHARIAN BARU
Dialogue: 0,0:04:12.89,0:04:16.01,tanda,,0000,0000,0000,,"TAKOYAKI"
Dialogue: 0,0:04:46.72,0:04:49.72,tanda,,0000,0000,0000,,LOKASI PEMBANGUNAN STASIUN KERETA SIHIR
Dialogue: 0,0:09:59.04,0:10:03.29,tanda,,0000,0000,0000,,KERAJAAN INGRASSIA
Dialogue: 0,0:10:04.29,0:10:05.28,tanda,,0000,0000,0000,,MARKAS BESAR SERIKAT BEBAS
Dialogue: 0,0:12:37.40,0:12:38.01,tanda,,0000,0000,0000,,DUNGEON BAWAH TANAH,\NRUANG RAPAT LANTAI 100
Dialogue: 0,0:21:20.76,0:21:24.89,tanda,,0000,0000,0000,,KERAJAAN SILTROSSO
Dialogue: 0,0:24:09.15,0:24:12.93,tanda,,0000,0000,0000,,SELANJUTNYA: EVOLUSI DUNGEON
Dialogue: 0,0:00:27.48,0:00:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada...
Dialogue: 0,0:00:30.02,0:00:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah,
Dialogue: 0,0:00:30.76,0:00:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian ada yang melihat Tuan Rimuru?
Dialogue: 0,0:00:33.97,0:00:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru?
Dialogue: 0,0:00:35.72,0:00:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, hari ini aku belum\Nmelihatnya sama sekali...
Dialogue: 0,0:00:40.31,0:00:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:00:44.94,0:00:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru...
Dialogue: 0,0:00:46.87,0:00:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda di mana?
Dialogue: 0,0:00:58.61,0:01:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, makin terlihat besar, ya.
Dialogue: 0,0:01:04.58,0:01:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival Pendirian Tempest, kota monster kita,\Ntelah berakhir dengan sukses besar.
Dialogue: 0,0:01:13.75,0:01:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, ini hanyalah desa goblin kecil.
Dialogue: 0,0:01:20.20,0:01:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, perlahan tapi pasti\Nkota ini makin berkembang,
Dialogue: 0,0:01:23.35,0:01:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari desa menjadi kota,\Ndan kawan-kawan pun makin bertambah.
Dialogue: 0,0:01:28.86,0:01:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbagai rencana pembangunan kota\Nsedang berjalan,
Dialogue: 0,0:01:31.79,0:01:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}termasuk dungeon yang telah memasuki\Ntahap uji coba pembukaan.
Dialogue: 0,0:01:38.41,0:01:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, aku ingin membangun\Nhubungan simbiosis
Dialogue: 0,0:01:41.94,0:01:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat manusia dan monster\Nbisa bekerja sama.
Dialogue: 0,0:01:45.31,0:01:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:01:46.25,0:01:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuanku adalah kemakmuran bersama\Nbagi manusia dan monster!
Dialogue: 0,0:01:54.73,0:01:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus mengandalkanmu, sobat.
Dialogue: 0,0:01:57.34,0:01:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:01:58.25,0:02:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku, Master.
Dialogue: 0,0:02:00.91,0:02:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:03:38.23,0:03:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup, hup, yak.\NWah!
Dialogue: 0,0:03:40.74,0:03:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih buat yang kemarin.
Dialogue: 0,0:03:42.71,0:03:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sewajarnya tolong-menolong\Ndi saat susah.
Dialogue: 0,0:03:45.89,0:03:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip! Nanti kita minum-minum!
Dialogue: 0,0:03:48.21,0:03:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh!
Dialogue: 0,0:03:50.52,0:03:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Tuan Rimuru!
Dialogue: 0,0:03:52.03,0:03:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai.
Dialogue: 0,0:03:52.82,0:03:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru, selamat pagi.
Dialogue: 0,0:03:54.85,0:03:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:03:56.12,0:03:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru, salam sejahtera.
Dialogue: 0,0:03:58.63,0:04:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam sejahtera.
Dialogue: 0,0:04:00.01,0:04:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Tuan Rimuru!
Dialogue: 0,0:04:01.07,0:04:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo!
Dialogue: 0,0:04:03.28,0:04:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:04:05.17,0:04:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hati-hati.
Dialogue: 0,0:04:07.47,0:04:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:04:11.19,0:04:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru!
Dialogue: 0,0:04:12.89,0:04:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru matang, nih. Silakan ambil!
Dialogue: 0,0:04:16.01,0:04:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, boleh, nih?
Dialogue: 0,0:04:19.17,0:04:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya lezat!
Dialogue: 0,0:04:22.95,0:04:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru, hari ini sedang\Nmeninjau kondisi kota?
Dialogue: 0,0:04:26.32,0:04:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, soalnya inspeksi juga penting.
Dialogue: 0,0:04:30.07,0:04:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru memang hebat!
Dialogue: 0,0:04:36.38,0:04:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mulai sore nanti...
Dialogue: 0,0:04:37.89,0:04:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:04:39.14,0:04:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru!
Dialogue: 0,0:04:40.79,0:04:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada oleh-oleh, bagikan untuk semuanya, ya.
Dialogue: 0,0:04:43.21,0:04:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:04:44.52,0:04:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:04:53.54,0:04:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita bisa membangun stasiun di sini.
Dialogue: 0,0:04:57.66,0:04:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah impian kaum pria!
Dialogue: 0,0:04:59.67,0:05:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi stasiun di Eurazania juga\Nsepertinya sudah ditentukan.
Dialogue: 0,0:05:03.71,0:05:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya,
Dialogue: 0,0:05:04.61,0:05:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lokasinya akan menyatu\Ndi lantai satu istana baru.
Dialogue: 0,0:05:08.95,0:05:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Geld dan yang lain sudah berjuang keras.
Dialogue: 0,0:05:12.74,0:05:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempest dan Eurazania,
Dialogue: 0,0:05:14.74,0:05:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta negara lain nanti\Nakan terhubung dengan kereta sihir.
Dialogue: 0,0:05:20.72,0:05:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konstruksi di luar juga lancar\Nseperti di dalam kota.
Dialogue: 0,0:05:24.01,0:05:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gedung parlemen baru juga hampir selesai.
Dialogue: 0,0:05:27.10,0:05:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, gedung yang terlalu mewah itu, ya?
Dialogue: 0,0:05:30.51,0:05:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:05:31.66,0:05:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menyebarkan keagungan Tuan Rimuru!
Dialogue: 0,0:05:35.39,0:05:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-Yah, yang penting kotanya\Nberkembang pesat...
Dialogue: 0,0:05:39.90,0:05:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, dungeon juga\Nmakin berkembang, ya?
Dialogue: 0,0:05:44.07,0:05:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya!\NTerima kasih sudah menanyakan!
Dialogue: 0,0:05:47.04,0:05:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memindahkan fasilitas penelitian\NGabiru dan yang lain dari gua,
Dialogue: 0,0:05:50.57,0:05:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu ada toko elf khusus anggota eksklusif\Ndi lantai 95 bawah tanah!
Dialogue: 0,0:05:55.62,0:05:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muah.
Dialogue: 0,0:06:00.00,0:06:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang dungeon?
Dialogue: 0,0:06:02.13,0:06:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya musuh semua!
Dialogue: 0,0:06:04.13,0:06:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada perlengkapan langka!
Dialogue: 0,0:06:06.13,0:06:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang akan termotivasi\Nuntuk menaklukkannya?
Dialogue: 0,0:06:08.92,0:06:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kami bilang...
Dialogue: 0,0:06:10.43,0:06:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!\NIni namanya penipuan!
Dialogue: 0,0:06:13.46,0:06:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cuma mau untungnya saja, kan?
Dialogue: 0,0:06:16.27,0:06:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, beginilah kelakuan monster.
Dialogue: 0,0:06:19.85,0:06:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:06:21.12,0:06:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu.
Dialogue: 0,0:06:25.81,0:06:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada keributan apa ini?
Dialogue: 0,0:06:28.18,0:06:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:29.32,0:06:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:06:36.47,0:06:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan dia?
Dialogue: 0,0:06:38.29,0:06:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:06:39.83,0:06:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjadi keributan?
Dialogue: 0,0:06:41.84,0:06:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru.
Dialogue: 0,0:06:43.48,0:06:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada penantang dungeon,
Dialogue: 0,0:06:45.84,0:06:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi menggerutu karena tidak bisa\Nmencapai lantai dua.
Dialogue: 0,0:06:49.97,0:06:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini banyak yang begitu.
Dialogue: 0,0:06:52.13,0:06:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:06:53.62,0:06:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf jadi merepotkan kalian.
Dialogue: 0,0:06:56.36,0:06:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, itu hanya hal kecil.
Dialogue: 0,0:06:58.98,0:07:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisanya cuma mengumpat karena kalah saja.
Dialogue: 0,0:07:01.88,0:07:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau hal ini terus berlanjut,\Nbisa memengaruhi operasional.
Dialogue: 0,0:07:07.10,0:07:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu dipertimbangkan lagi.
Dialogue: 0,0:07:10.86,0:07:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elementaler, penyihir khusus\Nyang mengendalikan roh.
Dialogue: 0,0:07:15.03,0:07:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang tahu apa ciri khas\Ndari skill sihir mereka?
Dialogue: 0,0:07:18.79,0:07:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku!
Dialogue: 0,0:07:20.83,0:07:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, aku, aku!
Dialogue: 0,0:07:23.04,0:07:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku, aku, aku!\N- Pak Rimuru?
Dialogue: 0,0:07:25.19,0:07:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku, aku, aku!\N- Kok ada di sini?
Dialogue: 0,0:07:26.50,0:07:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas mau belajar...
Dialogue: 0,0:07:27.94,0:07:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh!
Dialogue: 0,0:07:29.55,0:07:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, sedang apa di sini?
Dialogue: 0,0:07:32.68,0:07:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku cuma mau inspeksi...
Dialogue: 0,0:07:36.18,0:07:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganggu.
Dialogue: 0,0:07:44.69,0:07:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:07:46.83,0:07:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang banget.
Dialogue: 0,0:07:48.36,0:07:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku juga mau diajari Bu Hinata.
Dialogue: 0,0:07:53.27,0:07:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak itu mau menuruti\Nperkataan Bu Hinata, ya.
Dialogue: 0,0:07:58.63,0:08:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah dia mau meluangkan\Nwaktunya untuk mengajar.
Dialogue: 0,0:08:02.46,0:08:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinata itu ahli dalam mengendalikan roh,
Dialogue: 0,0:08:05.46,0:08:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya cocok banget jadi guru mereka.
Dialogue: 0,0:08:08.32,0:08:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi siapa sangka dia mau\Nmenerima tawaran itu.
Dialogue: 0,0:08:13.18,0:08:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya anak-anak itu benar-benar\Nmenikmati keseharian mereka
Dialogue: 0,0:08:16.04,0:08:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak pindah ke sekolah di Tempest.
Dialogue: 0,0:08:19.99,0:08:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga langsung akrab\Ndengan teman barunya.
Dialogue: 0,0:08:23.89,0:08:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:08:25.78,0:08:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi,
Dialogue: 0,0:08:26.98,0:08:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena sudah yakin Yuuki dalangnya,
Dialogue: 0,0:08:29.57,0:08:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa membiarkan anak-anak\Ntetap di Kerajaan Ingrassia.
Dialogue: 0,0:08:43.88,0:08:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma apa ini?
Dialogue: 0,0:08:48.77,0:08:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini rasanya masuk angin...
Dialogue: 0,0:08:51.02,0:08:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh menarik.
Dialogue: 0,0:08:53.13,0:08:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang menarik?
Dialogue: 0,0:08:55.10,0:08:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah pantas kamu jadi sekretaris kedua\Ndengan tubuh selemah ini?
Dialogue: 0,0:08:59.16,0:09:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu,
Dialogue: 0,0:09:01.26,0:09:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu serius mau menyajikan ini nanti?
Dialogue: 0,0:09:04.65,0:09:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa?
Dialogue: 0,0:09:08.56,0:09:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi bikin apa, nih?
Dialogue: 0,0:09:10.23,0:09:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Tuan Rimuru!
Dialogue: 0,0:09:12.06,0:09:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya baru merasakan\Npengalaman menegangkan...
Dialogue: 0,0:09:14.42,0:09:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Begini!\NSebenarnya saya ingin...
Dialogue: 0,0:09:17.49,0:09:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, itu, begini...
Dialogue: 0,0:09:19.80,0:09:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\NNona Shuna sedang mencari Anda,
Dialogue: 0,0:09:24.00,0:09:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa Anda sudah menemui...
Dialogue: 0,0:09:25.17,0:09:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru!
Dialogue: 0,0:09:28.58,0:09:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, ternyata Anda ada di sini.
Dialogue: 0,0:09:33.29,0:09:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya ada apa?
Dialogue: 0,0:09:39.66,0:09:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya punya camilan baru.
Dialogue: 0,0:09:41.64,0:09:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kelihatannya lezat!
Dialogue: 0,0:09:44.39,0:09:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya ingin Anda jadi pencicip pertama...
Dialogue: 0,0:09:47.52,0:09:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi saya mencari-cari Anda.
Dialogue: 0,0:09:50.44,0:09:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shuna...
Dialogue: 0,0:10:05.29,0:10:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, bagaimana, ya...
Dialogue: 0,0:10:08.70,0:10:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Raja Iblis Rimuru\Nbenar-benar mencurigaiku.
Dialogue: 0,0:10:12.96,0:10:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:14.97,0:10:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, aku tidak mau bermusuhan\Ndengan slime itu...
Dialogue: 0,0:10:19.96,0:10:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, kayaknya kemarin\Nterlalu ikut campur, ya?
Dialogue: 0,0:10:25.50,0:10:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang menghasut Tujuh Luminari
Dialogue: 0,0:10:27.58,0:10:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar Hinata bergerak membasmi\NRaja Iblis Rimuru, kan?
Dialogue: 0,0:10:32.10,0:10:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ketahuan gara-gara itu?
Dialogue: 0,0:10:34.31,0:10:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini soal bos kita,
Dialogue: 0,0:10:36.50,0:10:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mustahil dia meninggalkan bukti, kan?
Dialogue: 0,0:10:39.28,0:10:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:10:40.62,0:10:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya dilakukan lewat Damrada...
Dialogue: 0,0:10:44.02,0:10:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tahu hubungan antara\NBu Shizu dengan slime itu,
Dialogue: 0,0:10:48.79,0:10:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak bisa mengelak soal hubungan kita\Ndengan pedagang dari timur.
Dialogue: 0,0:10:53.04,0:10:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kertas yang kita gunakan saja\Nbuatan Kekaisaran.
Dialogue: 0,0:10:55.58,0:11:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil serikat yang membawahi\Nbanyak petualang berkata,
Dialogue: 0,0:11:00.53,0:11:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"kami tidak ada hubungannya."
Dialogue: 0,0:11:02.58,0:11:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi mereka, bukti tidak langsungnya\Nsudah terkumpul lengkap.
Dialogue: 0,0:11:06.56,0:11:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kita akan merombak rencananya?
Dialogue: 0,0:11:09.31,0:11:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah dicurigai begini,\Ntidak bisa dilanjutkan begitu saja, kan?
Dialogue: 0,0:11:13.85,0:11:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kurasa tetap begini juga\Ntidak apa-apa.
Dialogue: 0,0:11:17.35,0:11:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:11:19.03,0:11:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup buat dia berpikir
Dialogue: 0,0:11:21.59,0:11:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"saat ini tidak perlu bermusuhan".
Dialogue: 0,0:11:23.99,0:11:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia itu mengubah sudut pandangnya\Ntergantung situasi.
Dialogue: 0,0:11:27.73,0:11:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, soal pengelolaan dungeon,\Nmereka sendiri yang minta bantuan.
Dialogue: 0,0:11:31.95,0:11:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:33.04,0:11:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ingin serikat mempromosikan\Nsistem hadiahnya.
Dialogue: 0,0:11:36.95,0:11:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, itu terlalu mencurigakan!
Dialogue: 0,0:11:39.53,0:11:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas-jelas jebakan!
Dialogue: 0,0:11:41.86,0:11:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, bagaimana, ya?
Dialogue: 0,0:11:44.09,0:11:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu tawaran yang didasari\Nperhitungan untung-rugi.
Dialogue: 0,0:11:48.47,0:11:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mari kita siapkan langkah antisipasi\Nsambil terus memantau keadaan.
Dialogue: 0,0:11:54.12,0:11:56.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini demi ambisi kita.
Dialogue: 0,0:11:59.58,0:12:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah kalau begitu.
Dialogue: 0,0:12:02.82,0:12:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum berniat melepaskan\Nkekuasaan atas wilayah barat.
Dialogue: 0,0:12:14.45,0:12:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lezat!
Dialogue: 0,0:12:16.71,0:12:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan, nih?\NMakanan macam apa ini?
Dialogue: 0,0:12:19.81,0:12:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sampai ingin menangis!
Dialogue: 0,0:12:22.46,0:12:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Enak banget! Tambah, dong!\N- Shuna, kamu makin berkembang lagi...
Dialogue: 0,0:12:28.11,0:12:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kok bisa? Makan ini malah ingin nangis!\N- Eng, bagaimana dengan rapatnya?
Dialogue: 0,0:12:33.32,0:12:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:12:36.01,0:12:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:12:38.02,0:12:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah uji coba pembukaan dungeon,\Nkita akan rapat operasional pertama,
Dialogue: 0,0:12:43.25,0:12:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jujur hasilnya parah banget!
Dialogue: 0,0:12:46.86,0:12:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengecek langsung\Ndan dengar keluhan di kota,
Dialogue: 0,0:12:50.42,0:12:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata level para penantang\Nterlalu rendah!
Dialogue: 0,0:12:53.45,0:12:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka cuma keliling lantai satu\Ntanpa persiapan apa pun.
Dialogue: 0,0:12:57.37,0:12:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang serakah,
Dialogue: 0,0:12:59.13,0:13:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus malah kalah sama monster peringkat F.
Dialogue: 0,0:13:02.63,0:13:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada yang menyerah\Ngara-gara kelaparan...
Dialogue: 0,0:13:07.13,0:13:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, siapa yang bisa naik\Nsampai lantai sepuluh?
Dialogue: 0,0:13:11.71,0:13:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya, operasional dungeon kita\Nsedang dalam krisis!
Dialogue: 0,0:13:14.56,0:13:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?\NTerus kapan aku bisa beraksi?
Dialogue: 0,0:13:17.12,0:13:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usaha kami jadi sia-sia!
Dialogue: 0,0:13:18.98,0:13:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, memang terlalu banyak pemula, sih.
Dialogue: 0,0:13:24.70,0:13:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin butuh pemberian petunjuk\Nuntuk penaklukannya.
Dialogue: 0,0:13:29.25,0:13:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:13:30.99,0:13:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau mengadakan\Nsesi pelatihan penaklukan?
Dialogue: 0,0:13:35.49,0:13:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelatihan?
Dialogue: 0,0:13:36.91,0:13:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:13:38.00,0:13:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf malah ikut campur.
Dialogue: 0,0:13:40.12,0:13:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelepasan gara-gara topiknya\Nsedikit bisa kumengerti...
Dialogue: 0,0:13:43.72,0:13:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sungkan, sarankan apa saja.
Dialogue: 0,0:13:46.00,0:13:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelatihan macam apa misalnya?
Dialogue: 0,0:13:48.39,0:13:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, seperti tutorial dalam gim.
Dialogue: 0,0:13:51.72,0:13:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat mereka merasakan pertempuran dan jebakan\Nlayaknya wahana ketangkasan.
Dialogue: 0,0:13:56.31,0:13:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga, tuh!\NAda yang lain?
Dialogue: 0,0:13:58.81,0:14:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lagi, ya?
Dialogue: 0,0:14:01.46,0:14:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus juga kalau ada penginapan\Natau tempat makan di tiap lantai.
Dialogue: 0,0:14:06.23,0:14:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Repot karena tidak ada toilet di dungeon.
Dialogue: 0,0:14:09.26,0:14:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:14:11.25,0:14:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bagaimana kalau ada\Ntitik simpan sekali pakai?
Dialogue: 0,0:14:14.12,0:14:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:14:15.87,0:14:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau monster yang dikalahkan\Nbisa menjatuhkan barang?
Dialogue: 0,0:14:20.20,0:14:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, menarik juga!
Dialogue: 0,0:14:22.10,0:14:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, semuanya bisa kubereskan!
Dialogue: 0,0:14:24.21,0:14:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, saran diterima!
Dialogue: 0,0:14:26.77,0:14:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dungeon-nya memang kurang ramah.
Dialogue: 0,0:14:29.61,0:14:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus berterima kasih\Nsama pengamat Masayuki!
Dialogue: 0,0:14:31.99,0:14:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tidak terlalu membantu...
Dialogue: 0,0:14:34.26,0:14:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kamu ini?
Dialogue: 0,0:14:35.83,0:14:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung saja aku mengundangmu\Nsebagai sesama penggemar gim.
Dialogue: 0,0:14:42.52,0:14:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah, bukan, namamu Masayuki, ya?
Dialogue: 0,0:14:45.90,0:14:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kemampuanmu boleh juga.
Dialogue: 0,0:14:48.27,0:14:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, terima kasih banyak.
Dialogue: 0,0:14:50.60,0:14:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul itu, namanya juga\NOrang Dunia Lain seperti Rimuru!
Dialogue: 0,0:14:54.93,0:14:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:14:56.28,0:14:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku belum memperkenalkannya.
Dialogue: 0,0:15:00.31,0:15:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sahabatku, Veldora.
Dialogue: 0,0:15:03.57,0:15:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang menjaga lantai seratus.
Dialogue: 0,0:15:06.25,0:15:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, salam kenal, ya.
Dialogue: 0,0:15:08.73,0:15:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Veldora?
Dialogue: 0,0:15:10.44,0:15:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Ramiris.
Dialogue: 0,0:15:11.90,0:15:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peri pembuat dungeon ini\Ndan anggota Oktagram.
Dialogue: 0,0:15:15.99,0:15:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal, Masayuki.
Dialogue: 0,0:15:17.97,0:15:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oktagram?
Dialogue: 0,0:15:21.82,0:15:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga Badai dan Raja Iblis...
Dialogue: 0,0:15:24.44,0:15:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau saja menjadikanmu bawahanku.
Dialogue: 0,0:15:27.80,0:15:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ramiris,\NTuan Masayuki jadi kebingungan.
Dialogue: 0,0:15:32.07,0:15:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja, sih.
Dialogue: 0,0:15:34.25,0:15:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:15:35.70,0:15:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru.
Dialogue: 0,0:15:36.71,0:15:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:15:37.32,0:15:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Tuan Masayuki,
Dialogue: 0,0:15:39.47,0:15:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita jadi punya beberapa ide perbaikan.
Dialogue: 0,0:15:42.43,0:15:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sekalian,
Dialogue: 0,0:15:44.58,0:15:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bolehkah saya mengusulkan satu ide lagi?
Dialogue: 0,0:15:52.46,0:15:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah tantangan dari Raja Iblis Rimuru!
Dialogue: 0,0:15:55.34,0:15:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada berita besar baru, nih!
Dialogue: 0,0:15:58.59,0:16:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang berhasil menembus lantai 50,
Dialogue: 0,0:16:01.10,0:16:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan ada bonus bulanan sebesar\Nsatu koin emas bintang!
Dialogue: 0,0:16:04.60,0:16:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga hadiah uang\Nuntuk tiap bos yang dikalahkan!
Dialogue: 0,0:16:08.10,0:16:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:16:10.61,0:16:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang bisa menaklukkan lantai terdalam,\Nakan mendapatkan 100 koin emas bintang!
Dialogue: 0,0:16:15.11,0:16:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, 100 koin emas bintang katanya!
Dialogue: 0,0:16:18.52,0:16:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayak yang bisa saja.
Dialogue: 0,0:16:21.12,0:16:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dermawan juga ternyata.
Dialogue: 0,0:16:24.16,0:16:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempest, ya?
Dialogue: 0,0:16:26.88,0:16:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita coba ke Tempest!
Dialogue: 0,0:16:29.00,0:16:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru menantang!
Dialogue: 0,0:16:39.80,0:16:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, mereka semangat sekali.
Dialogue: 0,0:16:43.46,0:16:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}100 koin emas bintang bagi yang bisa\Nmenaklukkan lantai terdalam?
Dialogue: 0,0:16:47.37,0:16:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian seserius ini, ya?
Dialogue: 0,0:16:49.06,0:16:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Target kita adalah para bangsawan yang akan\Nmendanai dan menyewa para petualang ini.
Dialogue: 0,0:16:54.03,0:16:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai ini bukanlah apa-apa bagi mereka.
Dialogue: 0,0:16:57.00,0:16:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:16:58.07,0:17:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang melindungi lantai terdalam\Nadalah Tuan Veldora yang itu, lo.
Dialogue: 0,0:17:05.59,0:17:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil ada yang bisa mengalahkan\Nnaga agung seperti diriku ini!
Dialogue: 0,0:17:10.17,0:17:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, itu mustahil.
Dialogue: 0,0:17:12.33,0:17:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tepat sekali.
Dialogue: 0,0:17:18.36,0:17:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, aku juga butuh bantuanmu, Masayuki!
Dialogue: 0,0:17:21.39,0:17:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:17:22.93,0:17:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bikin Tim Kilat aktif terus\Nsebagai ikon iklan kita.
Dialogue: 0,0:17:27.25,0:17:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek promosi dari Tuan Pahlawan\Nmemang luar biasa besar, ya.
Dialogue: 0,0:17:31.35,0:17:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sendiri pun merasa sangat beruntung\Nbisa melihat langsung
Dialogue: 0,0:17:35.00,0:17:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aksi Tuan Masayuki dengan mata sendiri.
Dialogue: 0,0:17:43.50,0:17:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:17:51.07,0:17:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah.
Dialogue: 0,0:17:52.38,0:17:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:53.29,0:17:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai besok.
Dialogue: 0,0:17:57.80,0:18:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, penjualan alkohol meningkat.
Dialogue: 0,0:18:00.83,0:18:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dungeon jadi lebih aktif begini,\Nberdampak positif juga pada kota.
Dialogue: 0,0:18:05.11,0:18:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, semuanya sesuai rencana Anda.
Dialogue: 0,0:18:09.22,0:18:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, penjualan yang lain...
Dialogue: 0,0:18:21.97,0:18:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu beli daun teh baru?
Dialogue: 0,0:18:23.68,0:18:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya beda dari biasa.
Dialogue: 0,0:18:25.34,0:18:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf!
Dialogue: 0,0:18:27.24,0:18:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya akan seduhkan yang dulu!
Dialogue: 0,0:18:34.20,0:18:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang, Shion yang menyuguhkan ini?
Dialogue: 0,0:18:39.01,0:18:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru, setelah saya mencicipinya,\Nsaya bisa menjamin teh ini aman.
Dialogue: 0,0:18:48.76,0:18:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:18:53.85,0:18:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah belajar banyak, Shion.
Dialogue: 0,0:18:56.69,0:18:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya! Terima kasih atas pujiannya!
Dialogue: 0,0:19:00.21,0:19:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya seduhkan lagi, ya!
Dialogue: 0,0:19:10.72,0:19:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:19:13.72,0:19:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, saya juga izin undur diri.
Dialogue: 0,0:19:16.80,0:19:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diablo, kalau dipikir-pikir,
Dialogue: 0,0:19:20.00,0:19:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku belum memberimu hadiah\Npenaklukan Falmuth.
Dialogue: 0,0:19:22.88,0:19:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak perlu.
Dialogue: 0,0:19:24.52,0:19:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harapan saya hanyalah bisa berguna bagi Anda.
Dialogue: 0,0:19:29.66,0:19:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kamu bilang begitu...
Dialogue: 0,0:19:32.34,0:19:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, izin meminta satu hal.
Dialogue: 0,0:19:34.24,0:19:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya juga ingin bawahan\Nyang bisa diandalkan.
Dialogue: 0,0:19:39.92,0:19:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sebagai demon yang kuat,\Nkamu tidak mau disuruh-suruh bikin teh, ya?
Dialogue: 0,0:19:44.07,0:19:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan begitu!
Dialogue: 0,0:19:46.88,0:19:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melayani Anda adalah tugas penting bagi saya!
Dialogue: 0,0:19:51.50,0:19:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, orang yang bisa\Nmenghancurkan negara...
Dialogue: 0,0:19:56.56,0:19:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang bisa menggantikan\Ntugas semacam itu,
Dialogue: 0,0:19:59.80,0:20:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya bisa selalu berada di samping Anda.
Dialogue: 0,0:20:04.32,0:20:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya.
Dialogue: 0,0:20:06.89,0:20:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diizinkan,\Nsaya ingin merekrut kenalan lama.
Dialogue: 0,0:20:11.58,0:20:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi saya membutuhkan tubuh\Nyang bisa dijadikan wadah.
Dialogue: 0,0:20:16.74,0:20:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka seperti Beretta tidak apa-apa?
Dialogue: 0,0:20:19.40,0:20:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, itu lebih dari cukup.
Dialogue: 0,0:20:23.00,0:20:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:20:23.98,0:20:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyiapkannya,\Njadi kamu harus pulang dengan selamat, ya.
Dialogue: 0,0:20:28.84,0:20:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mengerti.
Dialogue: 0,0:20:30.80,0:20:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dengan berat hati,
Dialogue: 0,0:20:32.93,0:20:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}izinkan saya untuk meninggalkan sisi Anda\Nuntuk sementara waktu.
Dialogue: 0,0:20:37.62,0:20:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:20:39.75,0:20:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, saya permisi.
Dialogue: 0,0:20:47.07,0:20:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah...
Dialogue: 0,0:20:50.43,0:20:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Souei.
Dialogue: 0,0:20:51.43,0:20:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:20:52.18,0:20:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu yang aneh\Ndi sekitar Duke Muese?
Dialogue: 0,0:20:55.66,0:20:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:20:56.92,0:20:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara ini belum ada pergerakan.
Dialogue: 0,0:20:59.65,0:21:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:21:00.62,0:21:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap pantau dan selidiki siapa saja\Nyang ada di belakangnya.
Dialogue: 0,0:21:03.89,0:21:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:21:29.72,0:21:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal selangkah lagi sampai bisa menguasai\Nnegara-negara barat sepenuhnya.
Dialogue: 0,0:21:36.04,0:21:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi kejayaan Keluarga Rosso,
Dialogue: 0,0:21:38.61,0:21:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami sudah menghabiskan banyak waktu\Nuntuk mempersiapkan semua ini...
Dialogue: 0,0:21:42.33,0:21:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:21:47.88,0:21:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempest...\NNegara yang sangat mengerikan.
Dialogue: 0,0:21:52.90,0:21:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya mereka bukan halangan bagimu.
Dialogue: 0,0:21:56.50,0:21:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah khawatir.
Dialogue: 0,0:21:58.71,0:22:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:22:00.41,0:22:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja bukan, Kakek.
Dialogue: 0,0:22:03.56,0:22:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keinginan luhur\Ndari kakek buyut yang agung,
Dialogue: 0,0:22:07.18,0:22:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sang mantan pahlawan sekaligus\Nleluhur Keluarga Rosso kita.
Dialogue: 0,0:22:12.38,0:22:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bersumpah\Nuntuk membantu mewujudkannya.
Dialogue: 0,0:22:15.87,0:22:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maribel, kamulah harapanku.
Dialogue: 0,0:22:20.83,0:22:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia manusia tidak boleh dikuasai\Noleh Raja Iblis.
Dialogue: 0,0:22:27.57,0:22:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita...
Dialogue: 0,0:22:29.63,0:22:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umat manusialah yang seharusnya berkuasa.
Dialogue: 0,0:24:06.16,0:24:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Evolusi Dungeon".
