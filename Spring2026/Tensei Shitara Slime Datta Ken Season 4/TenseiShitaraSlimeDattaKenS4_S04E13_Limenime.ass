Dialogue: 0,0:00:55.45,0:00:57.45,sign,,0000,0000,0000,,CHAOTIC BREATH
Dialogue: 0,0:01:42.08,0:01:44.08,sign,,0000,0000,0000,,LANTAI 50 TERTAKLUKKAN!
Dialogue: 0,0:04:18.30,0:04:19.00,sign,,0000,0000,0000,,EPISODE 85: KAWAN-KAWAN BARU
Dialogue: 0,0:06:06.71,0:06:09.12,sign,,0000,0000,0000,,"JIWA BUATAN"
Dialogue: 0,0:12:58.94,0:13:00.69,sign,,0000,0000,0000,,WUS
Dialogue: 0,0:13:48.20,0:13:48.67,sign,,0000,0000,0000,,NAGA
Dialogue: 0,0:24:09.03,0:24:12.91,sign,,0000,0000,0000,,LEGIUN HITAM
Dialogue: 0,0:00:14.83,0:00:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang Tempest makin berkembang,\Ntapi dokumennya juga makin menumpuk.
Dialogue: 0,0:00:22.46,0:00:24.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:00:25.42,0:00:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rimuru, aku mau bertualang sama Gaia!
Dialogue: 0,0:00:30.18,0:00:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertualang?
Dialogue: 0,0:00:32.50,0:00:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini penting untuk Gaia.
Dialogue: 0,0:00:35.96,0:00:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai naga predator terkuat,
Dialogue: 0,0:00:38.80,0:00:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia hanya ingin makan tangkapannya sendiri.
Dialogue: 0,0:00:42.15,0:00:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengajarinya cara berburu!
Dialogue: 0,0:00:48.65,0:00:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah, Gaia!
Dialogue: 0,0:01:01.75,0:01:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantan Chaos Dragon memang hebat!
Dialogue: 0,0:01:03.91,0:01:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:01:04.95,0:01:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Gaia!
Dialogue: 0,0:01:08.05,0:01:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaia terlahir kembali\Nsebagai Elemental Dragon.
Dialogue: 0,0:01:12.91,0:01:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elemental Dragon adalah keberadaan\Nyang menjadi asal-usul semua naga.
Dialogue: 0,0:01:17.96,0:01:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penciptanya adalah Naga Sejati terkuat,\N"Naga Raja Bintang".
Dialogue: 0,0:01:22.95,0:01:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga Sejati, termasuk Veldora,\Nhanya ada empat di dunia.
Dialogue: 0,0:01:27.73,0:01:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon mereka benar-benar\Nberbeda dari naga biasa.
Dialogue: 0,0:01:34.17,0:01:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku kalah...
Dialogue: 0,0:01:46.42,0:01:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gozul sudah bukan lawan\Nyang sepadan bagi kita!
Dialogue: 0,0:01:50.87,0:01:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?\NPerkembangan kita sedikit kebablasan, deh.
Dialogue: 0,0:01:54.68,0:01:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak terkalahkan!
Dialogue: 0,0:01:59.12,0:02:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:02:00.12,0:02:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh!
Dialogue: 0,0:02:03.18,0:02:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Milim!
Dialogue: 0,0:02:06.27,0:02:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlihat sangat bersenang-senang, ya.
Dialogue: 0,0:02:08.44,0:02:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, super bersenang-senang!
Dialogue: 0,0:02:10.86,0:02:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frey?
Dialogue: 0,0:02:14.13,0:02:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kamu sudah janji pulang\Nsetelah Gaia menetas?
Dialogue: 0,0:02:18.66,0:02:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu...
Dialogue: 0,0:02:21.54,0:02:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jaga sahabatku, Gaia!
Dialogue: 0,0:02:26.92,0:02:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku akan membesarkannya dengan baik.
Dialogue: 0,0:02:31.36,0:02:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa labirin,\NGaia tidak bisa tumbuh dengan leluasa.
Dialogue: 0,0:02:36.43,0:02:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah,
Dialogue: 0,0:02:37.43,0:02:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum kena marah Shuna,\Nharus memperbaiki sikap.
Dialogue: 0,0:02:41.79,0:02:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya mengerjakan dengan serius
Dialogue: 0,0:02:43.77,0:02:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wadah yang diminta Diablo.
Dialogue: 0,0:04:16.74,0:04:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}(Tensura) Bereinkarnasi Malah Menjadi Slime
Dialogue: 0,0:04:19.01,0:04:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:04:21.26,0:04:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata jumlahnya bukan main.
Dialogue: 0,0:04:26.09,0:04:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka akan jadi sebanyak ini.
Dialogue: 0,0:04:33.84,0:04:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru.
Dialogue: 0,0:04:35.89,0:04:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Diablo?
Dialogue: 0,0:04:37.33,0:04:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya lupa menyampaikan\Nberapa banyak bawahan yang saya butuhkan.
Dialogue: 0,0:04:41.85,0:04:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, memangnya berapa?
Dialogue: 0,0:04:43.86,0:04:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling banyak hanya beberapa ratus,
Dialogue: 0,0:04:46.05,0:04:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya rasa tidak akan sampai seribu.
Dialogue: 0,0:04:48.48,0:04:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak amat!
Dialogue: 0,0:04:53.84,0:04:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyiapkannya buat jaga-jaga.
Dialogue: 0,0:04:58.61,0:05:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benaran mau bawa seribu pasukan?
Dialogue: 0,0:05:02.88,0:05:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia, bisa saja, sih.
Dialogue: 0,0:05:05.13,0:05:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master, selanjutnya tolong yang di sana.
Dialogue: 0,0:05:08.16,0:05:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia bekerja keras.
Dialogue: 0,0:05:11.89,0:05:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vesta, tolong kumpulkan data.
Dialogue: 0,0:05:14.07,0:05:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, rapikan dokumennya, lalu...
Dialogue: 0,0:05:17.39,0:05:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:05:18.81,0:05:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mau jadi asistenku,\NRamiris.
Dialogue: 0,0:05:21.75,0:05:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga dimintai tolong sama Ramiris?
Dialogue: 0,0:05:24.44,0:05:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya...
Dialogue: 0,0:05:25.80,0:05:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru...
Dialogue: 0,0:05:29.70,0:05:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya ada apa?
Dialogue: 0,0:05:31.85,0:05:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan kami terlalu banyak\Nsampai kurang orang!
Dialogue: 0,0:05:37.58,0:05:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan apa? Wadahnya kan sudah...
Dialogue: 0,0:05:42.04,0:05:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Inti Sihir Roh?
Dialogue: 0,0:05:44.55,0:05:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ide dariku!
Dialogue: 0,0:05:46.91,0:05:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau disematkan inti yang kuat,\Nwadahnya jadi lebih tangguh!
Dialogue: 0,0:05:51.07,0:05:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide Nona Ramiris selalu luar biasa
Dialogue: 0,0:05:53.67,0:05:56.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sangat menarik.
Dialogue: 0,0:05:56.60,0:05:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian menyematkan inti ke semua wadah?
Dialogue: 0,0:05:59.96,0:06:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:06:01.11,0:06:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyiapkan seribu Inti Sihir Roh\Nuntuk seribu wadah?
Dialogue: 0,0:06:06.71,0:06:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah Jiwa Buatan juga?
Dialogue: 0,0:06:09.13,0:06:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik, kan?
Dialogue: 0,0:06:13.05,0:06:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi kagetmu adalah kebanggaan bagi kami.
Dialogue: 0,0:06:17.92,0:06:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja kalian butuh banyak orang.
Dialogue: 0,0:06:21.07,0:06:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku juga butuh asisten.
Dialogue: 0,0:06:24.70,0:06:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Vesta dan Master\Npunya pekerjaan lain.
Dialogue: 0,0:06:28.80,0:06:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini banyak yang bersifat rahasia juga,\Njadi tidak bisa merekrut sembarangan.
Dialogue: 0,0:06:33.43,0:06:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh orang, ya?
Dialogue: 0,0:06:35.59,0:06:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rimuru, aku juga...
Dialogue: 0,0:06:37.36,0:06:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Rimuru.
Dialogue: 0,0:06:38.98,0:06:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shuna?
Dialogue: 0,0:06:41.31,0:06:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa sampai datang ke sini?
Dialogue: 0,0:06:44.13,0:06:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu untukmu.
Dialogue: 0,0:06:46.39,0:06:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamu?
Dialogue: 0,0:06:47.75,0:06:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya beliau kenalanmu.
Dialogue: 0,0:06:50.55,0:06:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Dino.
Dialogue: 0,0:06:52.11,0:06:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:53.57,0:06:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dino?
Dialogue: 0,0:06:56.41,0:06:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai.
Dialogue: 0,0:06:58.00,0:06:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu.
Dialogue: 0,0:07:00.32,0:07:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga Raja Iblis Dino.
Dialogue: 0,0:07:03.56,0:07:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggota Oktagram sepertiku,\Ndan punya julukan Sleeping Ruler.
Dialogue: 0,0:07:15.05,0:07:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat menikmati.
Dialogue: 0,0:07:19.65,0:07:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana kabarmu?
Dialogue: 0,0:07:22.72,0:07:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, meski belum bisa bersantai\Nkarena ada beberapa insiden.
Dialogue: 0,0:07:27.42,0:07:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu?
Dialogue: 0,0:07:29.59,0:07:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa?
Dialogue: 0,0:07:31.45,0:07:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya berkunjung\Nsebagai sesama Raja Iblis.
Dialogue: 0,0:07:36.79,0:07:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, alasan sebenarnya?
Dialogue: 0,0:07:38.95,0:07:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku diusir dari tempat tinggalku.
Dialogue: 0,0:07:42.84,0:07:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:07:44.21,0:07:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya rumah, dan selama ini\Nmenumpang di tempatnya Dagruel.
Dialogue: 0,0:07:49.79,0:07:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus aku juga miskin.
Dialogue: 0,0:07:52.08,0:07:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantaskah Raja Iblis begini?\NKayak pengangguran.
Dialogue: 0,0:07:56.22,0:08:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, izinkan aku menumpang di sini.
Dialogue: 0,0:08:00.10,0:08:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:08:03.60,0:08:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:05.41,0:08:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:05.99,0:08:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tung-Tunggu sebentar!\NJadi kamu mau menelantarkanku?
Dialogue: 0,0:08:10.12,0:08:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kerja.
Dialogue: 0,0:08:11.04,0:08:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengada-ada!\NAku punya prinsip untuk tidak bekerja.
Dialogue: 0,0:08:15.75,0:08:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa ratus tahun ini,\Naku belum pernah menghasilkan uang,
Dialogue: 0,0:08:18.91,0:08:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan belum pernah beli makan\Ndengan uangku sendiri!
Dialogue: 0,0:08:21.62,0:08:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat amat, habis makan, pulang, ya.
Dialogue: 0,0:08:35.85,0:08:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rimuru... Bukan, Tuan Rimuru.
Dialogue: 0,0:08:38.90,0:08:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku menjadi rakyatmu dan melayanimu.
Dialogue: 0,0:08:42.91,0:08:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap menerima perintah apa pun!
Dialogue: 0,0:08:45.20,0:08:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dino, kamu cuma mengincar kue sus, ya?
Dialogue: 0,0:08:48.90,0:08:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa makan enak tiap hari,\Naku mau jadi warga sini!
Dialogue: 0,0:08:54.75,0:08:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Keputusanku sudah bulat!\N- Dasar, cuma mau enaknya saja.
Dialogue: 0,0:08:57.72,0:08:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ambil saja dan pulang sana!
Dialogue: 0,0:09:02.70,0:09:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa bilang begitu setelah melihat ini?
Dialogue: 0,0:09:05.77,0:09:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini surat yang ditulis Raja Iblis tertua,\NGuy Crimson untukmu.
Dialogue: 0,0:09:10.84,0:09:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guy yang berambut merah itu?
Dialogue: 0,0:09:17.89,0:09:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tampung Dino.
Dialogue: 0,0:09:21.92,0:09:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kenapa aku harus mengurusnya?
Dialogue: 0,0:09:24.93,0:09:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab. Kemungkinan besar Individu Guy Crimson
Dialogue: 0,0:09:28.21,0:09:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melimpahkan urusan merepotkan ini pada Master\Nkarena tidak mau menanggung Individu Dino.
Dialogue: 0,0:09:33.40,0:09:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:34.65,0:09:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cuma bilang, "Hah!"
Dialogue: 0,0:09:39.40,0:09:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang merepotkan,\Ntapi aku tidak mau bermusuhan dengan Guy.
Dialogue: 0,0:09:44.66,0:09:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:09:46.48,0:09:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menampungmu,\Ntapi kamu harus bekerja!
Dialogue: 0,0:09:49.92,0:09:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Bekerja?
Dialogue: 0,0:09:52.99,0:09:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bilangnya bekerja,\Ntugasmu gampang, kok.
Dialogue: 0,0:09:57.29,0:09:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah asistennya Ramiris.
Dialogue: 0,0:09:59.84,0:10:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya dia selalu mengurung diri di labirin\Ndan kelakuannya sama denganku?
Dialogue: 0,0:10:05.16,0:10:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei, Master! Setop!
Dialogue: 0,0:10:09.27,0:10:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Kapsulnya retak!
Dialogue: 0,0:10:12.52,0:10:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh, duh!
Dialogue: 0,0:10:14.28,0:10:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa yang kalian lakukan?
Dialogue: 0,0:10:17.03,0:10:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rimuru! Dino juga!
Dialogue: 0,0:10:22.19,0:10:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kalian menyuntikkan magi Veldora\Nlangsung ke kapsul?
Dialogue: 0,0:10:27.04,0:10:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:28.51,0:10:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira dengan menggunakan kekuatan Master,\Npertumbuhan tubuhnya bisa cepat,
Dialogue: 0,0:10:32.81,0:10:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan wadahnya selesai lebih cepat.
Dialogue: 0,0:10:37.30,0:10:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, magi dalam kapsul meningkat drastis,
Dialogue: 0,0:10:41.16,0:10:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hampir meledak?
Dialogue: 0,0:10:43.75,0:10:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:47.52,0:10:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya aku akan memarahinya...
Dialogue: 0,0:10:50.06,0:10:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor.
Dialogue: 0,0:10:51.29,0:10:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bone Golem berbahan sihir baja
Dialogue: 0,0:10:53.25,0:10:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah mengalami perubahan sifat akibat\Npengaruh gelombang Individu Veldora.
Dialogue: 0,0:10:56.84,0:10:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejenis Adamantite.
Dialogue: 0,0:10:58.75,0:11:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau harus diberi nama sementara,\Nmungkin "Dragontite".
Dialogue: 0,0:11:02.07,0:11:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah dapat hasil yang tidak terduga.
Dialogue: 0,0:11:05.76,0:11:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa kalian buru-buru\Ningin menyelesaikannya?
Dialogue: 0,0:11:09.45,0:11:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:11:12.29,0:11:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin anak-anak yang mengagumiku
Dialogue: 0,0:11:15.80,0:11:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa segera mendapatkan tubuh mereka sendiri.
Dialogue: 0,0:11:19.59,0:11:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, mereka pasti senang,
Dialogue: 0,0:11:22.31,0:11:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kita pun dapat tambahan orang,\Njadi semua untung, kan?
Dialogue: 0,0:11:26.12,0:11:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ramiris...
Dialogue: 0,0:11:29.81,0:11:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang dari awal, dong.
Dialogue: 0,0:11:32.52,0:11:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung Diablo belum pulang,\Nakan kusiapkan dulu tubuh untuk para Dryad.
Dialogue: 0,0:11:37.84,0:11:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, nih?
Dialogue: 0,0:11:39.28,0:11:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:11:42.51,0:11:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Rimuru!
Dialogue: 0,0:11:45.77,0:11:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:11:47.40,0:11:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita butuh bantuannya.
Dialogue: 0,0:11:52.60,0:11:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, aku tidak mau bekerja.
Dialogue: 0,0:11:55.68,0:11:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena terpaksa,\Naku akan membantu... mohon bimbingannya.
Dialogue: 0,0:11:58.96,0:12:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bimbingannya juga!
Dialogue: 0,0:12:00.76,0:12:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nlangsung kita mulai saja, Tuan Dino.
Dialogue: 0,0:12:04.97,0:12:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:05.80,0:12:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malah bilang, "Eh!"
Dialogue: 0,0:12:08.24,0:12:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:09.10,0:12:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kita terbatas!
Dialogue: 0,0:12:13.10,0:12:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku ini Raja Iblis, lo?
Dialogue: 0,0:12:16.25,0:12:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus?
Dialogue: 0,0:12:18.07,0:12:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelar tidak berpengaruh di sini!
Dialogue: 0,0:12:21.53,0:12:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:12:22.49,0:12:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini,\Nmasalah kekurangan orang sudah teratasi.
Dialogue: 0,0:12:26.27,0:12:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga masih ada kerjaan...
Dialogue: 0,0:12:27.58,0:12:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:12:30.51,0:12:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rimuru,
Dialogue: 0,0:12:32.23,0:12:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga punya permintaan.
Dialogue: 0,0:12:37.62,0:12:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya permintaan?
Dialogue: 0,0:12:39.96,0:12:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:41.91,0:12:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau asisten!
Dialogue: 0,0:12:43.96,0:12:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Asisten?
Dialogue: 0,0:12:48.31,0:12:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi semua lagi sibuk.
Dialogue: 0,0:12:51.16,0:12:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya waktu membantumu.
Dialogue: 0,0:12:53.31,0:12:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:12:54.81,0:12:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun membantu Ramiris,
Dialogue: 0,0:12:57.31,0:12:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjaga labirin.
Dialogue: 0,0:13:00.69,0:13:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengemban tugas penting.
Dialogue: 0,0:13:03.69,0:13:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya wajar kalau aku punya asisten
Dialogue: 0,0:13:06.36,0:13:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menghargai, memuji, dan menghiburku.
Dialogue: 0,0:13:13.04,0:13:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham perasaanmu, tapi mencari orang\Nyang cocok untukmu itu tidak mudah...
Dialogue: 0,0:13:17.91,0:13:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir soal itu!
Dialogue: 0,0:13:20.54,0:13:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku punya teman,
Dialogue: 0,0:13:24.66,0:13:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ketika masih ada di perutmu.
Dialogue: 0,0:13:27.01,0:13:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:28.28,0:13:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor. Diperkirakan roh tingkat tinggi\Nbernama Ifrit.
Dialogue: 0,0:13:32.62,0:13:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:33.26,0:13:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ifrit yang pernah bersemayam di tubuh Shizu?
Dialogue: 0,0:13:37.23,0:13:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan jadi teman?
Dialogue: 0,0:13:40.02,0:13:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab.
Dialogue: 0,0:13:41.29,0:13:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Ifrit dilahap,
Dialogue: 0,0:13:43.15,0:13:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas intervensi Individu Veldora,\NIfrit pun diisolasi di tempat yang sama.
Dialogue: 0,0:13:48.68,0:13:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu, mereka menghabiskan waktu\Nbersama dan menjalin persahabatan.
Dialogue: 0,0:13:53.39,0:13:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kejadian semacam itu di perutku?
Dialogue: 0,0:13:58.22,0:14:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu ingin membangkitkan Ifrit?
Dialogue: 0,0:14:04.39,0:14:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cepat paham seperti biasanya!
Dialogue: 0,0:14:08.78,0:14:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini agak membuatku dilema.
Dialogue: 0,0:14:12.59,0:14:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Ifrit telah menyelamatkan Shizu\Nyang dipanggil ke dunia ini,
Dialogue: 0,0:14:17.64,0:14:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia yang membuatnya menderita juga.
Dialogue: 0,0:14:20.70,0:14:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa mengiakannya semudah itu.
Dialogue: 0,0:14:25.90,0:14:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak berkenan, ya?
Dialogue: 0,0:14:28.43,0:14:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rimuru, aku juga ikut memohon.
Dialogue: 0,0:14:30.78,0:14:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kabulkan permintaan Master.
Dialogue: 0,0:14:36.30,0:14:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bukannya Ifrit sudah bersumpah setia\Npada Raja Iblis Leon?
Dialogue: 0,0:14:42.51,0:14:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia akan menurutimu?
Dialogue: 0,0:14:49.17,0:14:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:50.54,0:14:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, tidak perlu khawatir.
Dialogue: 0,0:14:53.18,0:14:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kegigihanku, dengan senang hati\Ndia mengajukan diri jadi asistenku!
Dialogue: 0,0:14:58.56,0:15:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran, nih?
Dialogue: 0,0:15:00.16,0:15:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan kamu mengobrol sama Ifrit, ya?
Dialogue: 0,0:15:02.85,0:15:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tidak ada yang mustahil bagiku.
Dialogue: 0,0:15:06.34,0:15:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master hebat banget, lo!
Dialogue: 0,0:15:08.40,0:15:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia meminta Ifrit memanggil banyak Salamander\Nuntuk kereta sihir!
Dialogue: 0,0:15:13.87,0:15:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja terasa janggal\Nsaat dengar Veldora yang memanggil.
Dialogue: 0,0:15:18.49,0:15:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya lebih baik dijadikan kawan saja.
Dialogue: 0,0:15:24.54,0:15:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, deh.
Dialogue: 0,0:15:26.30,0:15:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu harus bertanggung jawab.
Dialogue: 0,0:15:28.75,0:15:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:15:30.46,0:15:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Master!
Dialogue: 0,0:15:32.49,0:15:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:15:33.51,0:15:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asisten pertamaku!
Dialogue: 0,0:15:36.16,0:15:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:15:37.18,0:15:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hore!\N- Rasanya kayak diperas peliharaan sendiri.
Dialogue: 0,0:15:40.72,0:15:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong taruh bahan-bahannya di situ.
Dialogue: 0,0:15:43.85,0:15:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:47.48,0:15:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus melakukan ini?
Dialogue: 0,0:15:49.52,0:15:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya pakai yang ini saja?
Dialogue: 0,0:15:50.94,0:15:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, oke.
Dialogue: 0,0:15:52.95,0:15:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bisa lebih mudah\Nberadaptasi dengan kekuatanku.
Dialogue: 0,0:15:57.57,0:16:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kita mulai.
Dialogue: 0,0:16:00.79,0:16:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wadah rohnya Bone Golem berbahan Dragontite\Nyang berubah akibat menyerap magi Veldora.
Dialogue: 0,0:16:06.08,0:16:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang digunakan sebagai inti\Nadalah Inti Sihir milik Charybdis.
Dialogue: 0,0:16:09.34,0:16:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor.
Dialogue: 0,0:16:10.50,0:16:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa-sisa Ifrit terkonfirmasi.
Dialogue: 0,0:16:12.72,0:16:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Migrasi ke Inti Sihir Charybdis.
Dialogue: 0,0:16:15.90,0:16:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil.
Dialogue: 0,0:16:18.47,0:16:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilanjutkan dengan pembuatan wadah jiwa.
Dialogue: 0,0:16:21.86,0:16:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggabungkan ke wadah roh\Nberbahan Dragontite.
Dialogue: 0,0:16:35.56,0:16:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei.
Dialogue: 0,0:16:39.24,0:16:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah?
Dialogue: 0,0:16:43.68,0:16:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuang cairan kultur.
Dialogue: 0,0:16:45.62,0:16:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuka kapsul.
Dialogue: 0,0:16:56.80,0:17:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ifrit begini bentuknya?
Dialogue: 0,0:17:00.23,0:17:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ifrit, bagaimana perasaanmu\Nsetelah bangkit dan memiliki tubuh?
Dialogue: 0,0:17:06.24,0:17:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Veldora, ini pertama kalinya\Nkita berjumpa di dunia nyata.
Dialogue: 0,0:17:11.80,0:17:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Tuan Rimuru.
Dialogue: 0,0:17:13.58,0:17:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih telah membangkitkanku.
Dialogue: 0,0:17:17.59,0:17:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, syukurlah kamu baik-baik saja.
Dialogue: 0,0:17:20.84,0:17:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku ingin bertanya.
Dialogue: 0,0:17:24.31,0:17:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sebelumnya kamu lebih...
Dialogue: 0,0:17:31.19,0:17:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan wujud ini adalah\Nkehendaknya Tuan Veldora.
Dialogue: 0,0:17:36.67,0:17:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, berkat pengaruh kekuatan\NTuan Veldora,
Dialogue: 0,0:17:40.26,0:17:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya bisa mengendalikan angin\Nmeski sebagai roh api.
Dialogue: 0,0:17:46.63,0:17:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Charybdis itu perempuan.
Dialogue: 0,0:17:50.54,0:17:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau kembali ke sebelumnya...
Dialogue: 0,0:17:52.23,0:17:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak perlu.
Dialogue: 0,0:17:54.57,0:18:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesampingkan penampilannya, wujud ini\Njauh lebih kuat dari saya sebelumnya.
Dialogue: 0,0:18:01.55,0:18:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:03.30,0:18:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bukannya kamu
Dialogue: 0,0:18:06.26,0:18:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dendam padaku?
Dialogue: 0,0:18:08.46,0:18:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:10.60,0:18:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu,
Dialogue: 0,0:18:11.59,0:18:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajar saja Anda berusaha menyingkirkanku\Ndemi Shizue Izawa.
Dialogue: 0,0:18:17.99,0:18:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memiliki pandangan yang bertentangan\Ndan tidak akan pernah bisa bersatu.
Dialogue: 0,0:18:25.23,0:18:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada jalan lain yang bisa ditempuh...
Dialogue: 0,0:18:28.80,0:18:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak boleh terus menyesali itu.
Dialogue: 0,0:18:35.87,0:18:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,\Naku bertukar cerita dengan Ifrit.
Dialogue: 0,0:18:39.99,0:18:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah perjuangan seputar Veldora,
Dialogue: 0,0:18:42.32,0:18:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan soal Raja Iblis Leon\Nyang dulu pernah dia layani.
Dialogue: 0,0:18:57.88,0:19:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku saat ini seolah sudah dikalahkan\Ndan dibunuh olehmu.
Dialogue: 0,0:19:04.11,0:19:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya saya diselamatkan Tuan Veldora\Nsehingga terhindar dari kehilangan kesadaran,
Dialogue: 0,0:19:08.54,0:19:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi saya sadar diri ini\Nsudah berbeda dari sebelumnya.
Dialogue: 0,0:19:15.72,0:19:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya masih merasakan\Nkeagungan Raja Iblis Leon,
Dialogue: 0,0:19:19.47,0:19:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi saat ini saya ingin\Nmelayani Tuan Veldora.
Dialogue: 0,0:19:25.74,0:19:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:27.93,0:19:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,\Nbekerjalah sebagai asistennya Veldora.
Dialogue: 0,0:19:37.99,0:19:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:19:46.51,0:19:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ifrit, mulai sekarang namamu Charys!
Dialogue: 0,0:19:53.75,0:20:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, sebagai Charys, saya bersumpah setia\Npada Tuan Veldora yang agung!
Dialogue: 0,0:20:07.70,0:20:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:20:09.22,0:20:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor. Roh tingkat tinggi Ifrit,\Ntelah berevolusi menjadi Flame Lord.
Dialogue: 0,0:20:16.54,0:20:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:20:17.79,0:20:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku memercayakan\Nkeluaran magi padamu.
Dialogue: 0,0:20:28.96,0:20:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Eh?
Dialogue: 0,0:20:34.16,0:20:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:20:36.40,0:20:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, balik lagi jadi laki-laki.
Dialogue: 0,0:20:39.31,0:20:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:40.38,0:20:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang dahsyat.
Dialogue: 0,0:20:42.60,0:20:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:44.11,0:20:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dengan wujud ini,\Nkekuatan apiku...
Dialogue: 0,0:20:47.41,0:20:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian...
Dialogue: 0,0:20:52.52,0:20:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan wujud perempuan,\Nkekuatan anginnya jadi lebih kuat.
Dialogue: 0,0:20:58.35,0:20:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja.
Dialogue: 0,0:20:59.96,0:21:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Charys, aku akan mengandalkanmu\Nsebagai asistenku.
Dialogue: 0,0:21:04.98,0:21:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti, Tuan Veldora.
Dialogue: 0,0:21:07.59,0:21:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan cuma makin kuat,\Nmalah makin merepotkan Veldora.
Dialogue: 0,0:21:12.89,0:21:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Flame Lord itu\Njadi teman baru mereka.
Dialogue: 0,0:21:16.44,0:21:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, memang ada saja kejadian begini.
Dialogue: 0,0:21:19.86,0:21:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dino, kalau mau tinggal sama Rimuru dan Master,\Njangan kaget sama hal seperti itu.
Dialogue: 0,0:21:25.74,0:21:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:21:28.74,0:21:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan sogimu belum berkarat, kan?
Dialogue: 0,0:21:31.75,0:21:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita buktikan saja.
Dialogue: 0,0:21:33.41,0:21:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata percuma saja\Naku mencoba memahaminya.
Dialogue: 0,0:21:42.36,0:21:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada rekan-rekan lainnya.
Dialogue: 0,0:21:47.51,0:21:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dryad yang berevolusi menjadi Dryas Doll Dryad\Nseperti Treyni ada hampir sepuluh orang,
Dialogue: 0,0:21:54.28,0:21:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Treant yang bisa bergerak di dalam labirin\Nbertambah jadi lebih dari seratus orang.
Dialogue: 0,0:21:59.75,0:22:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Tuan Rimuru.
Dialogue: 0,0:22:04.57,0:22:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini,\Nmasalah kekurangan orang sudah teratasi.
Dialogue: 0,0:22:13.45,0:22:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal menunggu Diablo pulang.
Dialogue: 0,0:22:21.40,0:22:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti bisa memenuhi\Nekspektasi Tuan Rimuru.
Dialogue: 0,0:24:05.88,0:24:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Legiun Hitam".
