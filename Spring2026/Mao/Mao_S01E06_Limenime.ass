Dialogue: 0,0:00:42.70,0:00:44.83,tanda,,0000,0000,0000,,"KIBA NANOKA"
Dialogue: 0,0:00:57.34,0:00:59.43,tanda,,0000,0000,0000,,"MAO"
Dialogue: 0,0:01:08.06,0:01:09.40,tanda,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:02:49.87,0:02:53.42,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:04:07.78,0:04:11.04,tanda,,0000,0000,0000,,KENANGAN HARI ITU
Dialogue: 0,0:05:23.44,0:05:25.03,tanda,,0000,0000,0000,,"JUMAT, 15 AGUSTUS"
Dialogue: 0,0:05:41.50,0:05:42.59,tanda,,0000,0000,0000,,"HARUKA, HITOMI, NAKAGAWA YUI"
Dialogue: 0,0:05:49.26,0:05:51.22,tanda,,0000,0000,0000,,UOZUMI FUNA
Dialogue: 0,0:06:05.07,0:06:06.99,tanda,,0000,0000,0000,,KAKEK NANOKA
Dialogue: 0,0:06:32.72,0:06:35.22,tanda,,0000,0000,0000,,KAU SUDAH PULANG DARI RUMAH SAKIT?\NKAU DARI PERTUNJUKAN KEMBANG API?
Dialogue: 0,0:08:34.67,0:08:35.84,tanda,,0000,0000,0000,,"JALAN PERBELANJAAN KELIMA"
Dialogue: 0,0:09:59.55,0:10:01.76,tanda,,0000,0000,0000,,SHIRAHA
Dialogue: 0,0:10:05.18,0:10:06.19,tanda,,0000,0000,0000,,"NANOKA MUNGKIN SUDAH PULANG"
Dialogue: 0,0:10:06.27,0:10:07.10,tanda,,0000,0000,0000,,ASAL KAU TAHU SAJA
Dialogue: 0,0:13:24.09,0:13:26.97,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:14:44.84,0:14:46.55,tanda,,0000,0000,0000,,"BYOKI"
Dialogue: 0,0:24:49.11,0:24:50.36,tanda,,0000,0000,0000,,"SELANJUTNYA"
Dialogue: 0,0:00:27.65,0:00:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vampir?
Dialogue: 0,0:00:29.11,0:00:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:30.15,0:00:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya beberapa orang\Ndiserang di dekat sini.
Dialogue: 0,0:00:33.45,0:00:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar
Dialogue: 0,0:00:35.32,0:00:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka memakai jubah hitam\Nseperti jubah biarawati Barat.
Dialogue: 0,0:00:39.49,0:00:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku!
Dialogue: 0,0:00:42.70,0:00:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa kota ini
Dialogue: 0,0:00:44.92,0:00:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kembali normal karena…
Dialogue: 0,0:00:46.75,0:00:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayakashi Kutu penghalang Byoki\Nsudah dimusnahkan
Dialogue: 0,0:00:50.42,0:00:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan gereja itu menghilang?
Dialogue: 0,0:00:52.59,0:00:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mungkin itu alasannya.
Dialogue: 0,0:00:55.09,0:00:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak kelelahan.
Dialogue: 0,0:00:57.34,0:00:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghalang Byoki melingkupi kota ini
Dialogue: 0,0:00:59.51,0:01:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam tabir tipis energi yokai.
Dialogue: 0,0:01:02.47,0:01:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota aslinya pasti tersembunyi\Ndi balik tabir itu.
Dialogue: 0,0:01:07.15,0:01:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu artinya
Dialogue: 0,0:01:08.06,0:01:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu mungkin masih
Dialogue: 0,0:01:09.90,0:01:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersembunyi di bawah batu kunci itu?
Dialogue: 0,0:01:14.65,0:01:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang batu kunci itu…
Dialogue: 0,0:01:17.82,0:01:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu kunci itu akan
Dialogue: 0,0:01:19.83,0:01:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}segera menghilang.
Dialogue: 0,0:01:21.03,0:01:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:01:22.95,0:01:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:01:24.12,0:01:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau tahu?
Dialogue: 0,0:01:26.12,0:01:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lama lagi,
Dialogue: 0,0:01:27.54,0:01:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada tanggal 1 September, akan ada
Dialogue: 0,0:01:30.13,0:01:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gempa bumi besar.
Dialogue: 0,0:01:33.26,0:01:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gempa Besar Kanto.
Dialogue: 0,0:01:35.72,0:01:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area ini akan hancur.
Dialogue: 0,0:01:38.18,0:01:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu
Dialogue: 0,0:01:39.93,0:01:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurut catatan sejarah, batu kunci itu\Nmenghilang sejak hari itu.
Dialogue: 0,0:01:44.98,0:01:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:01:46.31,0:01:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada kucing besar…
Dialogue: 0,0:01:50.56,0:01:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kesaksian bahwa orang-orang melihat
Dialogue: 0,0:01:53.61,0:01:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kucing besar menatap\Nkota yang terbakar dari langit.
Dialogue: 0,0:01:57.49,0:01:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja
Dialogue: 0,0:01:59.91,0:02:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu Byoki.
Dialogue: 0,0:02:02.70,0:02:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu berbahaya untuk tetap di sini.
Dialogue: 0,0:02:04.66,0:02:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau harus meninggalkan kota\Nuntuk sementara.
Dialogue: 0,0:02:07.58,0:02:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan menjadi gempa bumi yang dahsyat.
Dialogue: 0,0:02:10.33,0:02:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini untuk memberitahumu itu.
Dialogue: 0,0:02:12.13,0:02:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau bisa tahu masa depan?
Dialogue: 0,0:02:18.88,0:02:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini sulit dipercaya,
Dialogue: 0,0:02:21.72,0:02:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku datang…
Dialogue: 0,0:02:24.18,0:02:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari 100 tahun di masa depan.
Dialogue: 0,0:02:31.10,0:02:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak mungkin.
Dialogue: 0,0:02:32.86,0:02:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:33.94,0:02:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus percaya padaku!
Dialogue: 0,0:04:11.58,0:04:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah! Aku berkata jujur!
Dialogue: 0,0:04:14.29,0:04:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang dari 100 tahun di masa depan.
Dialogue: 0,0:04:16.07,0:04:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepatnya 96 tahun.
Dialogue: 0,0:04:20.92,0:04:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerbang di jalan itu\Nterhubung ke masa depan.
Dialogue: 0,0:04:25.76,0:04:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah penghalang Byoki itu hilang,
Dialogue: 0,0:04:28.22,0:04:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisakah aku pulang lewat sana\Nseperti sebelumnya?
Dialogue: 0,0:04:32.14,0:04:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Mao.
Dialogue: 0,0:04:33.64,0:04:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:36.06,0:04:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pulang sekarang.
Dialogue: 0,0:04:39.32,0:04:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kau pergi dari sini, mengerti?
Dialogue: 0,0:04:41.90,0:04:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka…
Dialogue: 0,0:04:48.37,0:04:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini akan berhasil?
Dialogue: 0,0:04:50.04,0:04:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku terpaksa bermalam\Ndi sisi ini.
Dialogue: 0,0:04:58.84,0:05:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:05:02.80,0:05:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:05:05.63,0:05:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:05:09.26,0:05:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:11.43,0:05:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil kembali.
Dialogue: 0,0:05:13.89,0:05:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika ada kembang api…
Dialogue: 0,0:05:17.94,0:05:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:05:20.48,0:05:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya sudah musim panas?
Dialogue: 0,0:05:23.44,0:05:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}15 Agustus…
Dialogue: 0,0:05:25.57,0:05:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu bulan berlalu?
Dialogue: 0,0:05:29.03,0:05:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Kakek!\NAku akan pulang sekarang!
Dialogue: 0,0:05:33.37,0:05:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik sekali!
Dialogue: 0,0:05:36.67,0:05:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu Nanoka?
Dialogue: 0,0:05:38.46,0:05:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Di mana?
Dialogue: 0,0:05:40.59,0:05:41.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh…
Dialogue: 0,0:05:41.50,0:05:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:05:42.67,0:05:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang mirip dengannya, tapi…
Dialogue: 0,0:05:46.59,0:05:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang, Kakek!
Dialogue: 0,0:05:51.56,0:05:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uozumi.
Dialogue: 0,0:05:53.68,0:05:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:05:55.81,0:05:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang melihatmu. Selamat datang.
Dialogue: 0,0:05:59.15,0:06:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa gelap sekali di dalam?
Dialogue: 0,0:06:02.19,0:06:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakekmu sedang beristirahat.
Dialogue: 0,0:06:08.07,0:06:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek.
Dialogue: 0,0:06:14.12,0:06:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada…
Dialogue: 0,0:06:16.12,0:06:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tak beres.
Dialogue: 0,0:06:22.63,0:06:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}500 pesan belum dibaca…
Dialogue: 0,0:06:26.26,0:06:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menghilang selama sebulan.
Dialogue: 0,0:06:35.81,0:06:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, aku di rumah sakit lagi.
Dialogue: 0,0:06:42.40,0:06:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:06:45.82,0:06:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek…
Dialogue: 0,0:06:48.82,0:06:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah. Kau dari mana saja?
Dialogue: 0,0:06:52.78,0:06:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Kakek.
Dialogue: 0,0:06:55.12,0:06:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat khawatir.
Dialogue: 0,0:06:58.46,0:06:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khawatir?
Dialogue: 0,0:07:00.25,0:07:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dia bahkan tidak mengajukan\Nlaporan orang hilang ke polisi?
Dialogue: 0,0:07:04.50,0:07:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:07:06.05,0:07:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka, smoothie-mu.
Dialogue: 0,0:07:09.30,0:07:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:12.43,0:07:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Smoothie ini juga mencurigakan.
Dialogue: 0,0:07:16.18,0:07:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah, Nanoka.
Dialogue: 0,0:07:18.02,0:07:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baik untukmu.
Dialogue: 0,0:07:24.44,0:07:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang aneh.
Dialogue: 0,0:07:28.24,0:07:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa mual setiap kali meminumnya.
Dialogue: 0,0:07:33.28,0:07:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelah.
Dialogue: 0,0:07:35.99,0:07:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya tenaga.
Dialogue: 0,0:07:39.00,0:07:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah saat kekuatanmu tak berfungsi
Dialogue: 0,0:07:40.91,0:07:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kau dalam masalah.
Dialogue: 0,0:07:42.42,0:07:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:07:44.08,0:07:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat yang Mao berikan beberapa waktu lalu…
Dialogue: 0,0:07:46.30,0:07:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa masih ada di sini.
Dialogue: 0,0:07:50.34,0:07:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini penawar.
Dialogue: 0,0:07:52.51,0:07:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukannya!
Dialogue: 0,0:07:55.76,0:07:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:08:09.99,0:08:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiba Nanoka.
Dialogue: 0,0:08:11.99,0:08:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemasi barang-barangmu.
Dialogue: 0,0:08:13.78,0:08:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru?
Dialogue: 0,0:08:16.45,0:08:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu? Kenapa ada di sini?
Dialogue: 0,0:08:18.41,0:08:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:08:19.62,0:08:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek tidak sehat.
Dialogue: 0,0:08:23.12,0:08:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat sekarang!
Dialogue: 0,0:08:24.79,0:08:25.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu…
Dialogue: 0,0:08:28.42,0:08:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek sudah lama keluar masuk rumah sakit.
Dialogue: 0,0:08:31.84,0:08:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu bilang dia mungkin\Ntidak akan selamat kali ini.
Dialogue: 0,0:08:34.67,0:08:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dalam perjalanan ke rumah sakit
Dialogue: 0,0:08:35.92,0:08:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersama Ibu dan Ayah.
Dialogue: 0,0:08:39.17,0:08:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itulah kami terjebak\Ndalam kecelakaan lubang runtuhan.
Dialogue: 0,0:08:42.80,0:08:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu dan Ayah tewas
Dialogue: 0,0:08:45.40,0:08:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku tinggal bersama Kakek sejak itu.
Dialogue: 0,0:08:55.99,0:08:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua akan baik-baik saja, Nanoka.
Dialogue: 0,0:08:58.45,0:09:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek akan bersamamu
Dialogue: 0,0:09:01.37,0:09:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selalu.
Dialogue: 0,0:09:05.75,0:09:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek…
Dialogue: 0,0:09:13.88,0:09:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada masalah, Nanoka?
Dialogue: 0,0:09:17.26,0:09:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Aku baik-baik saja.
Dialogue: 0,0:09:19.93,0:09:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau mau camilan,
Dialogue: 0,0:09:22.18,0:09:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa Uozumi meninggalkan sesuatu\Ndi kulkas.
Dialogue: 0,0:09:25.35,0:09:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:09:28.65,0:09:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu, Kakek dalam kondisi kritis.
Dialogue: 0,0:09:33.90,0:09:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak masuk akal. Apa yang terjadi?
Dialogue: 0,0:09:36.74,0:09:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Ibu dan Ayah meninggal\Ndalam kecelakaan lubang runtuhan,
Dialogue: 0,0:09:39.74,0:09:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek sedang sekarat.
Dialogue: 0,0:09:42.49,0:09:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku baru ingat sekarang?
Dialogue: 0,0:09:45.29,0:09:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, obat yang Mao berikan…
Dialogue: 0,0:09:50.63,0:09:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini penawar.
Dialogue: 0,0:09:52.21,0:09:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk racun?
Dialogue: 0,0:09:54.34,0:09:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan, Mao! Katakan!
Dialogue: 0,0:10:05.18,0:10:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka kembali?
Dialogue: 0,0:10:07.27,0:10:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia ada di rumah?
Dialogue: 0,0:10:10.81,0:10:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertemu dengannya.
Dialogue: 0,0:10:14.78,0:10:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kami tidak berpacaran,
Dialogue: 0,0:10:17.70,0:10:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi jika aku tiba-tiba muncul,\Napa dia akan takut?
Dialogue: 0,0:10:19.99,0:10:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus…
Dialogue: 0,0:10:28.21,0:10:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:10:33.09,0:10:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Dia sudah pergi.
Dialogue: 0,0:10:38.63,0:10:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku.
Dialogue: 0,0:10:40.18,0:10:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat. Kita akan basah kuyup!
Dialogue: 0,0:10:41.89,0:10:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujan lagi.
Dialogue: 0,0:10:43.68,0:10:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat tidak terduga.
Dialogue: 0,0:10:47.89,0:10:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:10:54.23,0:10:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak ada di sini.
Dialogue: 0,0:10:57.24,0:10:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada tanggal 1 September,
Dialogue: 0,0:10:58.57,0:11:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan ada gempa bumi besar.
Dialogue: 0,0:11:01.03,0:11:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau harus meninggalkan kota\Nuntuk sementara.
Dialogue: 0,0:11:04.24,0:11:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:11:07.45,0:11:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sudah pergi.
Dialogue: 0,0:11:10.25,0:11:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?
Dialogue: 0,0:11:12.63,0:11:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa sangat kesepian.
Dialogue: 0,0:11:21.72,0:11:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:11:23.18,0:11:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:25.06,0:11:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kembali?
Dialogue: 0,0:11:27.60,0:11:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:11:30.52,0:11:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu lagi, Nona Nanoka.
Dialogue: 0,0:11:33.90,0:11:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak pergi?
Dialogue: 0,0:11:35.44,0:11:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak?
Dialogue: 0,0:11:36.86,0:11:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:11:39.07,0:11:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat setelah kau kembali,\NTuan Mao langsung tertidur
Dialogue: 0,0:11:43.24,0:11:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama sekitar 10 hari.
Dialogue: 0,0:11:44.66,0:11:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh hari?
Dialogue: 0,0:11:45.91,0:11:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu dia tidur,\Ntidak ada yang akan membangunkannya.
Dialogue: 0,0:11:50.87,0:11:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat itu, aku merasa lebih baik.
Dialogue: 0,0:11:53.21,0:11:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan entah benar atau tidak,
Dialogue: 0,0:11:57.55,0:12:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika gempa besar terjadi\Ndan batu kunci itu menghilang,
Dialogue: 0,0:12:01.68,0:12:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu adalah kesempatan sekali seumur hidup\Nuntuk menghadapi Byoki.
Dialogue: 0,0:12:05.80,0:12:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku tidak bisa\Nmeninggalkan tempat ini.
Dialogue: 0,0:12:08.52,0:12:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun…
Dialogue: 0,0:12:12.56,0:12:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengawasi batu kunci itu setiap hari,
Dialogue: 0,0:12:16.02,0:12:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak ada yang berubah.
Dialogue: 0,0:12:17.86,0:12:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:12:20.24,0:12:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih penting,\Nbagaimana denganmu, Nanoka?
Dialogue: 0,0:12:23.16,0:12:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau kembali?
Dialogue: 0,0:12:26.20,0:12:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku…
Dialogue: 0,0:12:28.83,0:12:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini…
Dialogue: 0,0:12:31.08,0:12:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:33.08,0:12:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:12:34.33,0:12:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat wajah Mao saja\Nmembuatku merasa sangat lega.
Dialogue: 0,0:12:44.47,0:12:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini gempa bumi?
Dialogue: 0,0:13:13.87,0:13:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:13:19.25,0:13:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini?
Dialogue: 0,0:13:20.59,0:13:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini?
Dialogue: 0,0:13:27.68,0:13:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:13:28.85,0:13:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padamkan apinya!
Dialogue: 0,0:13:35.77,0:13:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya, kau baik-baik saja?
Dialogue: 0,0:13:37.35,0:13:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku baik-baik saja.
Dialogue: 0,0:13:39.77,0:13:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melindungi guci kodoku dengan nyawaku.
Dialogue: 0,0:13:42.19,0:13:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:13:43.90,0:13:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gempa bumi benar-benar terjadi.
Dialogue: 0,0:13:46.36,0:13:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya…
Dialogue: 0,0:13:48.32,0:13:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu kuncinya!
Dialogue: 0,0:13:50.12,0:13:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Tunggu!
Dialogue: 0,0:13:57.75,0:13:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:14:07.09,0:14:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayakashi!
Dialogue: 0,0:14:11.26,0:14:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa itu?
Dialogue: 0,0:14:12.56,0:14:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gempa bumi…
Dialogue: 0,0:14:17.48,0:14:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku panas sekali.
Dialogue: 0,0:14:19.86,0:14:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka?
Dialogue: 0,0:14:29.41,0:14:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata kucing?
Dialogue: 0,0:14:41.13,0:14:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:14:43.09,0:14:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki!
Dialogue: 0,0:14:44.84,0:14:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan
Dialogue: 0,0:14:46.63,0:14:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuhku!
Dialogue: 0,0:14:52.39,0:14:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan tubuhnya?
Dialogue: 0,0:15:04.07,0:15:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keras!
Dialogue: 0,0:15:15.37,0:15:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mao!\N- Tuan Mao!
Dialogue: 0,0:15:20.50,0:15:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya kepala?
Dialogue: 0,0:15:21.96,0:15:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:15:23.54,0:15:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan tubuhmu.
Dialogue: 0,0:15:26.92,0:15:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada hari itu, 900 tahun lalu…
Dialogue: 0,0:15:30.43,0:15:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:15:32.22,0:15:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan tubuhmu.
Dialogue: 0,0:15:35.26,0:15:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan nyawamu padaku.
Dialogue: 0,0:15:40.27,0:15:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir mati
Dialogue: 0,0:15:42.40,0:15:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Byoki terluka parah,\Nhampir tidak bisa bertahan.
Dialogue: 0,0:15:45.98,0:15:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika menawarkan tubuhmu kepadaku,
Dialogue: 0,0:15:48.74,0:15:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan terus hidup.
Dialogue: 0,0:15:50.95,0:15:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah wadahku,
Dialogue: 0,0:15:52.99,0:15:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hiduplah di dalam diriku.
Dialogue: 0,0:15:57.37,0:15:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki!
Dialogue: 0,0:15:58.83,0:16:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, biar kau ikut bersamaku!
Dialogue: 0,0:16:03.96,0:16:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku memenggal kepalanya,\NByoki ini menghilang.
Dialogue: 0,0:16:35.07,0:16:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana.
Dialogue: 0,0:16:37.33,0:16:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:16:38.87,0:16:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau wadah yang hanya muncul\Nseribu tahun sekali.
Dialogue: 0,0:16:42.71,0:16:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan tubuhmu dan menyatulah denganku.
Dialogue: 0,0:16:47.00,0:16:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:16:51.22,0:16:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wadah yang hanya muncul\Nseribu tahun sekali?
Dialogue: 0,0:16:54.13,0:16:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak yakin.
Dialogue: 0,0:16:56.22,0:16:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu artinya\Nmereka benar-benar serasi.
Dialogue: 0,0:17:01.98,0:17:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terus mencarimu
Dialogue: 0,0:17:04.90,0:17:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengakhiri hidupmu
Dialogue: 0,0:17:07.02,0:17:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memutus kutukanmu selamanya.
Dialogue: 0,0:17:09.27,0:17:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutukan, katamu?
Dialogue: 0,0:17:11.99,0:17:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, mungkinkah kau tidak tahu
Dialogue: 0,0:17:16.24,0:17:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang sebenarnya terjadi saat itu?
Dialogue: 0,0:17:21.07,0:17:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:23.16,0:17:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak tahu siapa yang membunuh gurumu,
Dialogue: 0,0:17:26.17,0:17:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membakar Ruang Pusaka,
Dialogue: 0,0:17:30.13,0:17:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memanahmu?
Dialogue: 0,0:17:34.63,0:17:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua dijebak.
Dialogue: 0,0:17:36.84,0:17:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dan aku.
Dialogue: 0,0:17:43.31,0:17:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:17:52.82,0:17:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mao!\N- Tuan Mao!
Dialogue: 0,0:17:56.95,0:17:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang di sana, Gadis Muda.
Dialogue: 0,0:17:58.87,0:18:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?
Dialogue: 0,0:18:03.12,0:18:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berbicara denganku?
Dialogue: 0,0:18:04.71,0:18:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa?
Dialogue: 0,0:18:06.37,0:18:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa kau, seperti Mao,
Dialogue: 0,0:18:08.67,0:18:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga memiliki darah Byoki?
Dialogue: 0,0:18:12.67,0:18:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga pantas menjadi wadahku.
Dialogue: 0,0:18:19.68,0:18:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Apa maksudmu?
Dialogue: 0,0:18:24.06,0:18:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah saat itu
Dialogue: 0,0:18:26.56,0:18:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bertemu
Dialogue: 0,0:18:28.27,0:18:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki?
Dialogue: 0,0:18:31.02,0:18:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau mengutukku hari itu?
Dialogue: 0,0:18:34.28,0:18:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:35.69,0:18:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:18:37.49,0:18:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah terlelap selama ratusan tahun.
Dialogue: 0,0:18:40.95,0:18:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:41.99,0:18:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ratusan tahun? Jangan pura-pura bodoh!
Dialogue: 0,0:18:45.58,0:18:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, jelaskan bagaimana tubuhku\Nbisa menjadi seperti ini!
Dialogue: 0,0:19:04.26,0:19:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:19:24.83,0:19:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:19:27.54,0:19:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}monster yang kulihat hari itu!
Dialogue: 0,0:19:39.84,0:19:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu
Dialogue: 0,0:19:41.26,0:19:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar Mao?
Dialogue: 0,0:19:42.80,0:19:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Meski dia jarang berwujud seperti itu.
Dialogue: 0,0:19:47.18,0:19:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seperti
Dialogue: 0,0:19:48.56,0:19:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}binatang buas.
Dialogue: 0,0:19:50.44,0:19:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya itu tubuh Byoki.
Dialogue: 0,0:19:54.06,0:19:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketujuh ekor adalah buktinya.
Dialogue: 0,0:19:57.07,0:19:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dia akan dijadikan wadah Byoki,
Dialogue: 0,0:19:59.40,0:20:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia memenggal kepalanya\Nkarena terbawa suasana
Dialogue: 0,0:20:01.82,0:20:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tubuh mereka akhirnya menyatu.
Dialogue: 0,0:20:05.16,0:20:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya Byoki\Nmenginginkan tubuhnya kembali.
Dialogue: 0,0:20:10.71,0:20:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja, Mao.
Dialogue: 0,0:20:12.92,0:20:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kau melukaiku,
Dialogue: 0,0:20:15.46,0:20:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama aku bersatu dengan tubuhmu,
Dialogue: 0,0:20:19.46,0:20:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak akan mati!
Dialogue: 0,0:20:33.85,0:20:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:20:35.44,0:20:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kita bertarung,
Dialogue: 0,0:20:38.28,0:20:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu tidak menyelesaikan apa pun.
Dialogue: 0,0:20:44.41,0:20:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur!
Dialogue: 0,0:20:45.95,0:20:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya\N"tidak menyelesaikan apa pun"?
Dialogue: 0,0:20:50.62,0:20:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka, di sini berbahaya.
Dialogue: 0,0:20:52.62,0:20:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi dari sini.
Dialogue: 0,0:20:53.92,0:20:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:20:59.88,0:21:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:21:01.72,0:21:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh kota terbakar.
Dialogue: 0,0:21:05.64,0:21:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah… Ibu…
Dialogue: 0,0:21:08.39,0:21:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu seorang anak.
Dialogue: 0,0:21:09.97,0:21:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia ditinggalkan.
Dialogue: 0,0:21:18.44,0:21:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu
Dialogue: 0,0:21:19.69,0:21:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku?
Dialogue: 0,0:21:21.28,0:21:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan tahun lalu, hari itu,
Dialogue: 0,0:21:23.11,0:21:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ditarik oleh kekuatan yang dahsyat
Dialogue: 0,0:21:27.24,0:21:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berada di sini?
Dialogue: 0,0:21:30.29,0:21:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:21:32.29,0:21:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita tidak membantunya, dia akan mati.
Dialogue: 0,0:21:39.96,0:21:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:21:49.35,0:21:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat sekarang.\NAku mendengar suara setelah ini.
Dialogue: 0,0:21:52.98,0:21:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggu 900 tahun.
Dialogue: 0,0:21:55.77,0:21:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menunggu sedikit lebih lama.
Dialogue: 0,0:21:58.69,0:21:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:21:59.90,0:22:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapkan wadah baru
Dialogue: 0,0:22:02.40,0:22:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum hidupmu berakhir.
Dialogue: 0,0:22:07.24,0:22:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wadah baru?
Dialogue: 0,0:22:18.00,0:22:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao! Kau mengenaliku?
Dialogue: 0,0:22:28.30,0:22:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang itu sama.
Dialogue: 0,0:22:30.80,0:22:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membantunya!
Dialogue: 0,0:22:33.39,0:22:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu adalah aku!
Dialogue: 0,0:22:50.78,0:22:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:23:03.55,0:23:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang melesat keluar.
Dialogue: 0,0:23:16.73,0:23:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:24:49.11,0:24:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mungkin akan menjadi
Dialogue: 0,0:24:50.57,0:24:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wadah Byoki.
Dialogue: 0,0:24:53.74,0:24:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini batu pelindung.
Dialogue: 0,0:24:55.45,0:24:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan melindungimu seperti penghalang.
Dialogue: 0,0:24:58.24,0:24:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di reruntuhan bekas ibu kota yang terbakar,
Dialogue: 0,0:25:00.00,0:25:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih ada mayat yang belum ditemukan.
Dialogue: 0,0:25:02.92,0:25:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kisah
Dialogue: 0,0:25:04.63,0:25:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepala terbakar yang terbang di malam hari.
Dialogue: 0,0:25:07.17,0:25:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau takut,
Dialogue: 0,0:25:08.46,0:25:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetaplah di sini
Dialogue: 0,0:25:10.05,0:25:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersamaku.
Dialogue: 0,0:25:12.05,0:25:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak seperguruanku? Tidak mungkin!
Dialogue: 0,0:25:14.64,0:25:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Wadah Baru".
