Dialogue: 0,0:01:30.92,0:01:33.92,tanda,,0000,0000,0000,,"HARUKA, HITOMI, NAKAGAWA YUI"
Dialogue: 0,0:02:21.97,0:02:25.35,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:03:39.59,0:03:43.01,tanda,,0000,0000,0000,,BATU KUNCI
Dialogue: 0,0:03:43.01,0:03:43.74,tanda,,0000,0000,0000,,PERPUSTAKAAN
Dialogue: 0,0:04:40.27,0:04:40.73,tanda,,0000,0000,0000,,TERSENTUH
Dialogue: 0,0:04:49.12,0:04:50.24,tanda,,0000,0000,0000,,SHIKIGAMI
Dialogue: 0,0:04:59.67,0:05:00.96,tanda,,0000,0000,0000,,"TERSENTUH"
Dialogue: 0,0:05:24.57,0:05:26.82,tanda,,0000,0000,0000,,"GEMPA BESAR KANTO"
Dialogue: 0,0:05:26.91,0:05:28.99,tanda,,0000,0000,0000,,"MISTERI JALAN KELIMA"
Dialogue: 0,0:06:55.20,0:06:56.95,tanda,,0000,0000,0000,,"PERLINDUNGAN MELAWAN GEMPA"
Dialogue: 0,0:06:57.04,0:06:58.29,tanda,,0000,0000,0000,,"BATU KUNCI JALAN KELIMA"
