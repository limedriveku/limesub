Dialogue: 0,0:00:22.85,0:00:24.14,tanda,,0000,0000,0000,,JALAN PERBELANJAAN KELIMA
Dialogue: 0,0:01:39.14,0:01:39.97,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:01:42.26,0:01:44.18,tanda,,0000,0000,0000,,"KIBA NANOKA"
Dialogue: 0,0:02:34.32,0:02:35.53,tanda,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:02:35.61,0:02:37.11,tanda,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:03:06.52,0:03:11.52,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:04:25.72,0:04:29.06,tanda,,0000,0000,0000,,WANITA LABA-LABA
Dialogue: 0,0:05:15.60,0:05:16.52,tanda,,0000,0000,0000,,MAYAT TANPA KEPALA DITEMUKAN
Dialogue: 0,0:05:25.24,0:05:27.24,tanda,,0000,0000,0000,,"MAYAT TANPA KEPALA DITEMUKAN"
Dialogue: 0,0:05:27.32,0:05:28.99,tanda,,0000,0000,0000,,"MAYAT TANPA KEPALA DITEMUKAN"
Dialogue: 0,0:05:33.58,0:05:34.96,tanda,,0000,0000,0000,,"KOTA DIGEMPARKAN MAYAT TANPA KEPALA DITEMUKAN"
Dialogue: 0,0:05:42.88,0:05:45.92,tanda,,0000,0000,0000,,"8 MEI 1923"
Dialogue: 0,0:06:00.98,0:06:03.15,tanda,,0000,0000,0000,,MILK HALL
Dialogue: 0,0:06:04.36,0:06:05.99,tanda,,0000,0000,0000,,"TENKO"
Dialogue: 0,0:07:07.38,0:07:08.80,tanda,,0000,0000,0000,,"SAYOKO"
Dialogue: 0,0:12:32.21,0:12:34.42,tanda,,0000,0000,0000,,"ISTRI VISCOUNT"
Dialogue: 0,0:12:53.06,0:12:54.65,tanda,,0000,0000,0000,,VISCOUNT
Dialogue: 0,0:14:06.01,0:14:10.01,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:24:49.03,0:24:49.86,tanda,,0000,0000,0000,,SELANJUTNYA
Dialogue: 0,0:00:20.31,0:00:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kecil, aku pernah mati.
Dialogue: 0,0:00:24.23,0:00:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan tahun lalu.
Dialogue: 0,0:00:25.73,0:00:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih kelas satu.
Dialogue: 0,0:00:29.19,0:00:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kebetulan lewat sana.
Dialogue: 0,0:00:31.53,0:00:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itulah jalanannya runtuh.
Dialogue: 0,0:00:36.16,0:00:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar sesuatu.
Dialogue: 0,0:00:45.71,0:00:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:00:52.80,0:00:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao, sepertinya\Nterjadi sesuatu di kota.
Dialogue: 0,0:00:55.55,0:00:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku!
Dialogue: 0,0:00:57.59,0:00:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur.
Dialogue: 0,0:01:04.43,0:01:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia membunuhnya.
Dialogue: 0,0:01:06.77,0:01:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawahan Tuan Mao.
Dialogue: 0,0:01:09.90,0:01:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya siap membantu.
Dialogue: 0,0:01:11.19,0:01:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:01:12.11,0:01:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ayakashi, 'kan?
Dialogue: 0,0:01:17.70,0:01:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa...
Dialogue: 0,0:01:19.78,0:01:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganku?
Dialogue: 0,0:01:21.29,0:01:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao adalah onmyoji.
Dialogue: 0,0:01:23.79,0:01:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Byoki...
Dialogue: 0,0:01:25.21,0:01:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu tentang itu?
Dialogue: 0,0:01:27.00,0:01:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki?
Dialogue: 0,0:01:29.50,0:01:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:01:30.59,0:01:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat!
Dialogue: 0,0:01:34.76,0:01:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihat siluman.
Dialogue: 0,0:01:40.05,0:01:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang melihat siluman?
Dialogue: 0,0:01:42.26,0:01:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi...
Dialogue: 0,0:01:45.27,0:01:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siluman itu terlihat seperti manusia.
Dialogue: 0,0:01:51.36,0:01:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu siluman semacam itu?
Dialogue: 0,0:01:53.73,0:01:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak ayakashi seperti itu.
Dialogue: 0,0:01:56.53,0:01:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka benar-benar ada.
Dialogue: 0,0:01:58.78,0:01:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao...
Dialogue: 0,0:02:00.57,0:02:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memanggil tumpangan.
Dialogue: 0,0:02:02.83,0:02:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa waktu.
Dialogue: 0,0:02:07.50,0:02:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana, Tuan?
Dialogue: 0,0:02:09.66,0:02:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu riksha!
Dialogue: 0,0:02:11.00,0:02:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berangkat!
Dialogue: 0,0:02:12.79,0:02:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kalian meninggalkanku?
Dialogue: 0,0:02:14.51,0:02:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan bertemu lagi, Nanoka.
Dialogue: 0,0:02:18.26,0:02:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaanku belum selesai!
Dialogue: 0,0:02:23.14,0:02:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku takkan bertemu dia lagi.
Dialogue: 0,0:02:27.52,0:02:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu Nona Nanoka itu apa, Tuan Mao?
Dialogue: 0,0:02:31.23,0:02:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia manusia? Atau ayakashi?
Dialogue: 0,0:02:34.32,0:02:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:02:35.61,0:02:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia berubah
Dialogue: 0,0:02:37.19,0:02:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak melihat siluman itu...
Dialogue: 0,0:02:41.45,0:02:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja Nanoka...
Dialogue: 0,0:02:45.66,0:02:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao...
Dialogue: 0,0:02:47.70,0:02:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengikuti kita.
Dialogue: 0,0:02:48.79,0:02:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmm?
Dialogue: 0,0:02:49.75,0:02:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:50.87,0:02:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:04:37.36,0:04:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teganya kau!
Dialogue: 0,0:04:38.77,0:04:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau meninggalkanku begitu saja?
Dialogue: 0,0:04:41.44,0:04:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:04:42.86,0:04:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kau mengantarku pulang!
Dialogue: 0,0:04:44.95,0:04:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larimu cepat juga.
Dialogue: 0,0:04:46.24,0:04:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengulanginya lagi!
Dialogue: 0,0:04:50.62,0:04:52.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Ada apa ini?
Dialogue: 0,0:04:53.66,0:04:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang di sini tidak tembus pandang.
Dialogue: 0,0:04:57.84,0:05:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melewati gerbang itu lagi dan...
Dialogue: 0,0:05:01.80,0:05:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dunianya terlihat normal?
Dialogue: 0,0:05:05.59,0:05:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baca beritanya!
Dialogue: 0,0:05:08.43,0:05:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak.\N- Bacalah.
Dialogue: 0,0:05:09.97,0:05:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini tidak normal.\N- Kasus mayat tanpa kepala terbaru!
Dialogue: 0,0:05:12.02,0:05:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semuanya sangat kuno.\N- Baca beritanya!
Dialogue: 0,0:05:17.44,0:05:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjadi lagi, 'kan?
Dialogue: 0,0:05:19.06,0:05:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:20.90,0:05:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat meresahkan.
Dialogue: 0,0:05:22.99,0:05:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk koran?
Dialogue: 0,0:05:25.24,0:05:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasus mayat tanpa kepala lagi.
Dialogue: 0,0:05:27.32,0:05:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lima korban.
Dialogue: 0,0:05:29.91,0:05:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku belum pernah mendengar\Nkasus seperti itu!
Dialogue: 0,0:05:33.58,0:05:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kulihat.
Dialogue: 0,0:05:37.21,0:05:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kertas koran apa ini? Tidak ada fotonya.
Dialogue: 0,0:05:42.88,0:05:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tahun 1923?
Dialogue: 0,0:05:57.39,0:05:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berada di era Taisho?
Dialogue: 0,0:06:03.23,0:06:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:06:04.36,0:06:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Dokter Mao.
Dialogue: 0,0:06:07.11,0:06:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untukmu, Tenko.
Dialogue: 0,0:06:09.66,0:06:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatkan obat untuk anemiamu.
Dialogue: 0,0:06:12.45,0:06:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:06:13.83,0:06:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa ini?
Dialogue: 0,0:06:16.37,0:06:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:06:18.25,0:06:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sangat...
Dialogue: 0,0:06:19.92,0:06:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuno!
Dialogue: 0,0:06:22.59,0:06:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:06:24.00,0:06:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakimu kelihatan!
Dialogue: 0,0:06:29.01,0:06:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia
Dialogue: 0,0:06:30.43,0:06:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pemain sirkus?
Dialogue: 0,0:06:32.55,0:06:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, pakaiannya memang agak aneh.
Dialogue: 0,0:06:36.06,0:06:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak sadar diri.
Dialogue: 0,0:06:39.65,0:06:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi... apa ini artinya
Dialogue: 0,0:06:41.94,0:06:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau berasal dari era Taisho?
Dialogue: 0,0:06:45.78,0:06:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:06:47.61,0:06:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk saat ini, anggap saja begitu.
Dialogue: 0,0:06:50.70,0:06:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:52.32,0:06:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawaban macam apa itu?
Dialogue: 0,0:06:54.79,0:06:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Mao.
Dialogue: 0,0:06:56.54,0:06:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperkenalkan.\NDia sudah kuanggap seperti adik sendiri.
Dialogue: 0,0:07:03.92,0:07:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyelinap keluar dari kediaman\Nternyata tidak mudah.
Dialogue: 0,0:07:07.38,0:07:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Sayoko.
Dialogue: 0,0:07:14.30,0:07:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pelayan di kediaman Viscount.
Dialogue: 0,0:07:19.85,0:07:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:07:20.98,0:07:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kau sudah tahu\Nkasus mayat tanpa kepala, Dokter Mao?
Dialogue: 0,0:07:25.90,0:07:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:07:27.28,0:07:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, ada korban lagi.
Dialogue: 0,0:07:30.45,0:07:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korban pertama adalah siswa SMA.
Dialogue: 0,0:07:35.03,0:07:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk satu pria tak dikenal,
Dialogue: 0,0:07:37.70,0:07:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua korbannya adalah pemuda.
Dialogue: 0,0:07:41.54,0:07:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sebelum pembunuhan dimulai,
Dialogue: 0,0:07:45.59,0:07:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tuanku jatuh sakit.
Dialogue: 0,0:07:49.63,0:07:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gejalanya dimulai\Ndengan benjolan di wajahnya.
Dialogue: 0,0:07:53.55,0:07:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount melarang dokter atau pelayan
Dialogue: 0,0:07:56.56,0:07:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendekatinya.
Dialogue: 0,0:07:58.64,0:08:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya mengizinkan istrinya yang merawat.
Dialogue: 0,0:08:02.98,0:08:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia mulai sering\Nkeluar rumah saat malam hari.
Dialogue: 0,0:08:08.78,0:08:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu pulang,
Dialogue: 0,0:08:09.78,0:08:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat semua orang\Ndi kediaman sudah tertidur.
Dialogue: 0,0:08:14.28,0:08:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu malam,
Dialogue: 0,0:08:16.62,0:08:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku melihatnya.
Dialogue: 0,0:08:22.79,0:08:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang mirip darah
Dialogue: 0,0:08:26.71,0:08:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menetes dari tas tuanku.
Dialogue: 0,0:08:30.46,0:08:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat ketakutan, lalu lari ke kamarku.
Dialogue: 0,0:08:38.30,0:08:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku mengeceknya keesokan pagi,
Dialogue: 0,0:08:39.77,0:08:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bercak darah itu sudah dibersihkan.
Dialogue: 0,0:08:44.31,0:08:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu ada kepala\Nyang dipenggal di dalam tas itu?
Dialogue: 0,0:08:48.27,0:08:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukuran tasnya sangat pas.
Dialogue: 0,0:08:51.94,0:08:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada kaitannya\Ndengan Byoki yang kauburu, Dokter Mao?
Dialogue: 0,0:08:58.37,0:08:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki!
Dialogue: 0,0:09:00.24,0:09:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa wajah Viscount sekarang?
Dialogue: 0,0:09:03.71,0:09:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya selalu ditutupi perban.
Dialogue: 0,0:09:08.92,0:09:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku tak tahu.
Dialogue: 0,0:09:14.22,0:09:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyelidikinya.
Dialogue: 0,0:09:15.34,0:09:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau mau pergi sekarang?
Dialogue: 0,0:09:17.85,0:09:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah hampir malam.
Dialogue: 0,0:09:22.89,0:09:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihatnya langsung.
Dialogue: 0,0:09:27.23,0:09:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:09:30.57,0:09:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:09:40.24,0:09:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu...
Dialogue: 0,0:09:44.58,0:09:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:48.42,0:09:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku sudah mati.
Dialogue: 0,0:09:56.93,0:09:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:09:59.05,0:10:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan tubuhmu.
Dialogue: 0,0:10:03.52,0:10:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Byoki.
Dialogue: 0,0:10:05.64,0:10:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan nyawamu padaku.
Dialogue: 0,0:10:20.78,0:10:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang mengirim Byoki
Dialogue: 0,0:10:23.58,0:10:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengutukku?
Dialogue: 0,0:10:26.16,0:10:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi siapa?
Dialogue: 0,0:10:29.33,0:10:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki!
Dialogue: 0,0:10:30.42,0:10:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya aku akan menyeretmu bersamaku!
Dialogue: 0,0:10:45.27,0:10:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku sudah membunuh Byoki.
Dialogue: 0,0:10:50.10,0:10:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ternyata...
Dialogue: 0,0:10:52.11,0:10:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:10:53.32,0:10:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tahu rupa Viscount,
Dialogue: 0,0:10:56.99,0:10:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia manusia, 'kan?
Dialogue: 0,0:10:59.91,0:11:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:11:01.24,0:11:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu...
Dialogue: 0,0:11:04.66,0:11:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menggunakan tubuh manusia sebagai wadah.
Dialogue: 0,0:11:08.79,0:11:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu dia merasuki manusia?
Dialogue: 0,0:11:15.59,0:11:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Mao.
Dialogue: 0,0:11:17.84,0:11:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membiarkan\Npintu belakang tak terkunci untukmu.
Dialogue: 0,0:11:23.14,0:11:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:11:25.64,0:11:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari sudah gelap.
Dialogue: 0,0:11:29.56,0:11:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek pasti cemas.
Dialogue: 0,0:11:33.44,0:11:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kemarin, saat aku pulang,
Dialogue: 0,0:11:36.02,0:11:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktu tak bergerak sama sekali.
Dialogue: 0,0:11:38.90,0:11:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara kerja waktu di sini?
Dialogue: 0,0:11:42.28,0:11:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa masa kini dan era Taisho terhubung?
Dialogue: 0,0:11:49.33,0:11:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini pasti menyimpan semacam petunjuk
Dialogue: 0,0:11:53.54,0:11:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang perubahan di tubuhku
Dialogue: 0,0:11:56.13,0:11:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta
Dialogue: 0,0:11:58.30,0:12:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}insiden hari itu.
Dialogue: 0,0:12:03.64,0:12:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau akan mengantarku pulang, 'kan?
Dialogue: 0,0:12:11.81,0:12:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga...
Dialogue: 0,0:12:20.36,0:12:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya, aku membawa antiseptik\Ndan perban baru.
Dialogue: 0,0:12:26.91,0:12:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau, Sayoko.
Dialogue: 0,0:12:28.70,0:12:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Letakkan saja di situ.
Dialogue: 0,0:12:30.83,0:12:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suamiku tidak ingin
Dialogue: 0,0:12:32.21,0:12:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dilihat siapa pun.
Dialogue: 0,0:12:35.38,0:12:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Nyonya.
Dialogue: 0,0:12:39.55,0:12:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuklah.
Dialogue: 0,0:12:41.22,0:12:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:42.13,0:12:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda sudah bangun, Tuan?
Dialogue: 0,0:12:50.14,0:12:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayoko.
Dialogue: 0,0:12:51.68,0:12:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Tuan?
Dialogue: 0,0:12:54.73,0:12:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang kau temui di luar?
Dialogue: 0,0:13:03.11,0:13:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mencium baunya darimu.
Dialogue: 0,0:13:05.20,0:13:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau yang kubenci!
Dialogue: 0,0:13:10.74,0:13:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Mao.
Dialogue: 0,0:13:14.67,0:13:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan energi yokai.
Dialogue: 0,0:13:16.08,0:13:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:18.54,0:13:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:13:20.55,0:13:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayoko.
Dialogue: 0,0:13:22.80,0:13:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:13:24.55,0:13:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membocorkan rahasiaku\Nke orang luar, 'kan?
Dialogue: 0,0:13:30.64,0:13:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat batasanmu, Nona!
Dialogue: 0,0:13:37.56,0:13:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku!
Dialogue: 0,0:13:38.90,0:13:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak boleh ikut campur!
Dialogue: 0,0:13:50.78,0:13:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa di sana?
Dialogue: 0,0:13:58.79,0:14:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasus mayat tanpa kepala itu...
Dialogue: 0,0:14:01.67,0:14:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pelakunya, 'kan?
Dialogue: 0,0:14:12.85,0:14:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayoko bilang akan membiarkan\Npintu belakang terbuka.
Dialogue: 0,0:14:16.60,0:14:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia tak lewat sana?
Dialogue: 0,0:14:18.40,0:14:19.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat sini lebih cepat.
Dialogue: 0,0:14:21.77,0:14:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita susul,
Dialogue: 0,0:14:23.19,0:14:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:14:25.40,0:14:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:28.70,0:14:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo naik.
Dialogue: 0,0:14:30.45,0:14:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:34.49,0:14:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cepat sekali.
Dialogue: 0,0:14:37.29,0:14:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:38.54,0:14:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melompat tinggi lagi.
Dialogue: 0,0:14:42.13,0:14:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ayakashi, 'kan?
Dialogue: 0,0:14:45.42,0:14:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin aku ayakashi?
Dialogue: 0,0:14:51.55,0:14:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membunuh para pemuda\Ndan memenggal kepala mereka.
Dialogue: 0,0:14:58.31,0:14:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:15:00.52,0:15:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Mao!
Dialogue: 0,0:15:03.73,0:15:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau benar-benar pemilik rumah ini?
Dialogue: 0,0:15:07.95,0:15:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:28.34,0:15:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya. Nanoka.
Dialogue: 0,0:15:30.13,0:15:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lindungi Sayoko!
Dialogue: 0,0:15:32.26,0:15:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Tuan Mao.
Dialogue: 0,0:15:33.51,0:15:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku juga disuruh?
Dialogue: 0,0:15:38.73,0:15:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sayoko!
Dialogue: 0,0:15:41.65,0:15:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma pingsan.
Dialogue: 0,0:15:44.48,0:15:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:15:45.57,0:15:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:15:46.69,0:15:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pria itu?
Dialogue: 0,0:15:49.78,0:15:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istrinya?
Dialogue: 0,0:15:51.91,0:15:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia onmyoji.
Dialogue: 0,0:15:53.49,0:15:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kemari setelah mendengar\Nkasus mayat tanpa kepala.
Dialogue: 0,0:15:56.95,0:15:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onmyoji?
Dialogue: 0,0:16:00.91,0:16:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang harus kutanyakan.
Dialogue: 0,0:16:02.58,0:16:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau Byoki?
Dialogue: 0,0:16:05.59,0:16:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki, katamu?
Dialogue: 0,0:16:11.05,0:16:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupenggal kepalamu!
Dialogue: 0,0:16:19.89,0:16:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan kepalamu!
Dialogue: 0,0:16:23.06,0:16:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku salah.
Dialogue: 0,0:16:25.90,0:16:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi yokai-nya memang jahat,
Dialogue: 0,0:16:27.90,0:16:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi auranya sangat berbeda dari Byoki.
Dialogue: 0,0:16:35.99,0:16:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya buang-buang waktu saja.
Dialogue: 0,0:16:43.08,0:16:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan
Dialogue: 0,0:16:44.63,0:16:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wujud aslimu.
Dialogue: 0,0:16:54.59,0:16:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benang?
Dialogue: 0,0:17:06.98,0:17:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laba-laba.
Dialogue: 0,0:17:10.28,0:17:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tubuhnya sudah mati,
Dialogue: 0,0:17:14.81,0:17:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dikendalikan laba-laba?
Dialogue: 0,0:17:20.74,0:17:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:17:22.36,0:17:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelaku sebenarnya ada di sana!
Dialogue: 0,0:17:25.36,0:17:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya! Nanoka!
Dialogue: 0,0:17:29.04,0:17:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan! Apa ini?
Dialogue: 0,0:17:31.38,0:17:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan!
Dialogue: 0,0:17:33.97,0:17:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaring laba-laba?
Dialogue: 0,0:17:39.30,0:17:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau takkan bisa lolos.
Dialogue: 0,0:17:42.52,0:17:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia istrinya?
Dialogue: 0,0:17:46.10,0:17:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman onmyoji-mu itu,
Dialogue: 0,0:17:48.44,0:17:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lumayan tampan.
Dialogue: 0,0:17:53.24,0:17:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:17:56.61,0:17:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih muda.
Dialogue: 0,0:17:58.03,0:18:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku akan mengambil kepalanya juga.
Dialogue: 0,0:18:01.12,0:18:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalanya?
Dialogue: 0,0:18:02.83,0:18:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh mau melakukannya?
Dialogue: 0,0:18:04.00,0:18:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebelum itu...
Dialogue: 0,0:18:12.50,0:18:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak butuh wanita.
Dialogue: 0,0:18:14.84,0:18:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupelintir kepalamu\Nlalu kujadikan pupuk bunga.
Dialogue: 0,0:18:20.01,0:18:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:21.64,0:18:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja dijadikan pupuk! Menghina sekali!
Dialogue: 0,0:18:30.15,0:18:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya! Nanoka!
Dialogue: 0,0:18:31.77,0:18:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baik-baik saja?
Dialogue: 0,0:18:34.36,0:18:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:18:39.49,0:18:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matanya itu...
Dialogue: 0,0:18:40.74,0:18:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao...
Dialogue: 0,0:18:43.08,0:18:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Otoya?
Dialogue: 0,0:18:43.99,0:18:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka tercekik.
Dialogue: 0,0:18:47.33,0:18:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau diam saja?
Dialogue: 0,0:18:49.58,0:18:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:51.71,0:18:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangku saja kesulitan memotong jaringnya.
Dialogue: 0,0:18:56.09,0:18:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku bisa memutus semuanya.
Dialogue: 0,0:18:58.55,0:19:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku diam saja, lehernya akan...
Dialogue: 0,0:19:05.60,0:19:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putus!
Dialogue: 0,0:19:12.23,0:19:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:19:13.15,0:19:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mempan.
Dialogue: 0,0:19:15.53,0:19:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira dia gadis manusia biasa.
Dialogue: 0,0:19:18.11,0:19:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ayakashi, 'kan?
Dialogue: 0,0:19:22.95,0:19:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao!
Dialogue: 0,0:19:25.54,0:19:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini bisa terjadi?
Dialogue: 0,0:19:28.04,0:19:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onmyoji dan ayakashi bekerja sama?
Dialogue: 0,0:19:32.46,0:19:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita Laba-Laba.
Dialogue: 0,0:19:34.80,0:19:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau yang mengendalikan tubuh Viscount
Dialogue: 0,0:19:36.92,0:19:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengumpulkan kepala pemuda.
Dialogue: 0,0:19:40.88,0:19:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Aku butuh kepala mereka\Nsebagai tempat bertelur.
Dialogue: 0,0:19:45.85,0:19:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi pemuda akan menghasilkan\Nketurunan yang sehat.
Dialogue: 0,0:19:50.69,0:19:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupenggal kepalamu juga.
Dialogue: 0,0:19:56.61,0:19:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang yang berbahaya.
Dialogue: 0,0:19:59.99,0:20:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukan berarti kau bisa
Dialogue: 0,0:20:01.70,0:20:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memotong jaringku dengan itu!
Dialogue: 0,0:20:07.16,0:20:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kau tampan sekali dari dekat.
Dialogue: 0,0:20:15.25,0:20:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak melawan.
Dialogue: 0,0:20:17.30,0:20:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao kehilangan minat\Nkarena dia bukan Byoki.
Dialogue: 0,0:20:21.88,0:20:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia sengaja\Nmembiarkan wanita itu menggigitnya
Dialogue: 0,0:20:23.51,0:20:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar racun di darahnya membunuh wanita itu?
Dialogue: 0,0:20:33.02,0:20:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lagi...
Dialogue: 0,0:20:37.65,0:20:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:20:43.32,0:20:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku akan mati!
Dialogue: 0,0:20:48.16,0:20:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darahmu melelehkan jaringku?
Dialogue: 0,0:20:52.04,0:20:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa kau ini?
Dialogue: 0,0:20:53.87,0:20:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Aku harus kabur dari sini!
Dialogue: 0,0:20:57.21,0:20:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali!
Dialogue: 0,0:20:58.46,0:21:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak melawan, Nona Nanoka?
Dialogue: 0,0:21:01.34,0:21:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa!
Dialogue: 0,0:21:02.26,0:21:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah berkelahi seumur hidupku!
Dialogue: 0,0:21:04.64,0:21:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini lemah.
Dialogue: 0,0:21:05.76,0:21:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lemah? Tapi kau...
Dialogue: 0,0:21:14.44,0:21:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjauhlah dariku!
Dialogue: 0,0:21:16.19,0:21:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau
Dialogue: 0,0:21:17.44,0:21:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa lincah begitu?
Dialogue: 0,0:21:29.74,0:21:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh pedang itu!
Dialogue: 0,0:21:35.62,0:21:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:21:42.21,0:21:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:21:45.47,0:21:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onmyoji.
Dialogue: 0,0:21:47.09,0:21:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau melelehkan jaringku\Npakai darahmu juga?
Dialogue: 0,0:21:50.18,0:21:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konyol sekali.
Dialogue: 0,0:21:53.52,0:21:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa memutusnya.
Dialogue: 0,0:21:56.23,0:21:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai pedang Mao.
Dialogue: 0,0:22:02.53,0:22:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan kehabisan darah
Dialogue: 0,0:22:05.45,0:22:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum bisa melelehkan jaringku.
Dialogue: 0,0:22:15.12,0:22:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah darahmu habis,
Dialogue: 0,0:22:16.71,0:22:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepalamu akan jadi milikku.
Dialogue: 0,0:22:29.93,0:22:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:43.40,0:22:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan kau...
Dialogue: 0,0:22:52.16,0:22:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, kau baru saja memakai pedangku?
Dialogue: 0,0:22:59.46,0:23:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mencoba memotong jaringnya.
Dialogue: 0,0:23:02.84,0:23:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang itu hanya bisa kugunakan sendiri.
Dialogue: 0,0:23:05.42,0:23:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:23:06.67,0:23:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia bisa menggunakannya, berarti...
Dialogue: 0,0:23:11.09,0:23:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:23:12.43,0:23:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dan aku sama.
Dialogue: 0,0:24:49.94,0:24:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang ini, sama sepertiku,\Nmenanggung kutukan Byoki.
Dialogue: 0,0:24:53.53,0:24:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota itu terbakar...
Dialogue: 0,0:24:55.24,0:24:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao, seperti dugaan kita,
Dialogue: 0,0:24:56.87,0:24:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kota ini terhubung dengan Byoki.
Dialogue: 0,0:24:59.29,0:25:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyebab jalan runtuh di Jalan Kelima\Nmasih menjadi misteri.
Dialogue: 0,0:25:03.17,0:25:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus pergi.
Dialogue: 0,0:25:04.67,0:25:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shouko bisa memanipulasi\Numur orang sesukanya.
Dialogue: 0,0:25:09.09,0:25:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu
Dialogue: 0,0:25:10.80,0:25:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin pernah bertemu Byoki.
Dialogue: 0,0:25:14.26,0:25:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Yang Terkutuk".
