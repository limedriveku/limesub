Dialogue: 0,0:01:11.02,0:01:12.36,tanda,,0000,0000,0000,,"KAKEK NANOKA"
Dialogue: 0,0:01:19.41,0:01:21.16,tanda,,0000,0000,0000,,"UOZUMI FUNA"
Dialogue: 0,0:02:09.16,0:02:11.46,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:03:26.29,0:03:28.91,tanda,,0000,0000,0000,,NANOKA DAN MAO
Dialogue: 0,0:03:47.51,0:03:50.10,tanda,,0000,0000,0000,,"HARUKA, NAKAGAWA YUI"
Dialogue: 0,0:04:09.70,0:04:11.25,tanda,,0000,0000,0000,,"HITOMI"
Dialogue: 0,0:04:36.40,0:04:38.19,tanda,,0000,0000,0000,,"PERBELANJAAN JALAN KELIMA"
