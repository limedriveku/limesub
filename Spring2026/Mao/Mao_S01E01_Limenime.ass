Dialogue: 0,0:00:33.61,0:00:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siluman?
Dialogue: 0,0:00:40.99,0:00:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada korban luka!
Dialogue: 0,0:00:42.91,0:00:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kecil. Dia berdarah.
Dialogue: 0,0:00:46.75,0:00:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bernapas.
Dialogue: 0,0:00:47.79,0:00:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat. Angkat dia.
Dialogue: 0,0:00:54.26,0:00:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:00:55.80,0:00:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana liburan sepuluh hari kalian?
Dialogue: 0,0:00:58.93,0:01:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin macet total di mana-mana.
Dialogue: 0,0:01:03.06,0:01:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat liburan berakhir.
Dialogue: 0,0:01:04.09,0:01:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek.
Dialogue: 0,0:01:05.94,0:01:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat.
Dialogue: 0,0:01:09.02,0:01:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Nanoka.
Dialogue: 0,0:01:11.02,0:01:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:01:12.44,0:01:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kau mulai sekolah lagi, 'kan?
Dialogue: 0,0:01:16.57,0:01:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, Ibu, aku berangkat.
Dialogue: 0,0:01:19.41,0:01:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:01:21.54,0:01:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah smoothie ini.
Dialogue: 0,0:01:23.95,0:01:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Bibi Uozumi.
Dialogue: 0,0:01:25.54,0:01:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku tak mau minum.
Dialogue: 0,0:01:26.83,0:01:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja kau menolak.
Dialogue: 0,0:01:29.08,0:01:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah.
Dialogue: 0,0:01:30.67,0:01:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, ini demi kebaikanmu.
Dialogue: 0,0:01:39.51,0:01:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:01:40.72,0:01:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar menjijikkan.
Dialogue: 0,0:01:42.64,0:01:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti air rawa dari neraka.
Dialogue: 0,0:01:45.48,0:01:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat.
Dialogue: 0,0:01:51.15,0:01:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah mati.
Dialogue: 0,0:03:30.12,0:03:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersedia.
Dialogue: 0,0:03:31.71,0:03:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:03:33.25,0:03:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:03:43.22,0:03:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiba Nanoka, 16,8 detik.
Dialogue: 0,0:03:46.26,0:03:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambat sekali.
Dialogue: 0,0:03:47.51,0:03:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka tampak seperti pelari alami.
Dialogue: 0,0:03:50.18,0:03:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan atletisnya sia-sia.
Dialogue: 0,0:03:52.31,0:03:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Masa? Benarkah?\N- Tentu saja.
Dialogue: 0,0:03:53.69,0:03:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar ada sesuatu di Jalan Shutter.
Dialogue: 0,0:03:56.52,0:03:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Distrik Kelima?
Dialogue: 0,0:03:58.98,0:04:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada makhluk yang muncul.
Dialogue: 0,0:04:01.45,0:04:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Hantu?
Dialogue: 0,0:04:03.74,0:04:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan. Entahlah, sulit menjelaskannya.
Dialogue: 0,0:04:05.66,0:04:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terdengar suara-suara aneh.
Dialogue: 0,0:04:07.74,0:04:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba pikirkan.
Dialogue: 0,0:04:08.66,0:04:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kecelakaan tragis
Dialogue: 0,0:04:09.70,0:04:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pernah terjadi di sana?
Dialogue: 0,0:04:11.33,0:04:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei!\N- Bodoh.
Dialogue: 0,0:04:14.37,0:04:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:16.70,0:04:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun lalu kau di kelas lain,\Nwajar kau tidak tahu.
Dialogue: 0,0:04:19.80,0:04:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tua Nanoka meninggal\Ndalam kecelakaan itu.
Dialogue: 0,0:04:22.13,0:04:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:24.89,0:04:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Nanoka.
Dialogue: 0,0:04:27.47,0:04:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:04:29.60,0:04:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan tahun lalu,
Dialogue: 0,0:04:31.39,0:04:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku kelas satu.
Dialogue: 0,0:04:35.19,0:04:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku
Dialogue: 0,0:04:36.40,0:04:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kebetulan lewat sana.
Dialogue: 0,0:04:39.40,0:04:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami terjebak kecelakaan reruntuhan.
Dialogue: 0,0:04:44.32,0:04:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,
Dialogue: 0,0:04:45.70,0:04:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}paramedis menemukanku di luar mobil.
Dialogue: 0,0:04:48.45,0:04:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berlumuran darah dan napasku terhenti.
Dialogue: 0,0:04:53.79,0:04:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hantu?
Dialogue: 0,0:04:57.50,0:04:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalannya sudah diperbaiki.
Dialogue: 0,0:04:59.88,0:05:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah tak pernah terjadi apa-apa.
Dialogue: 0,0:05:03.67,0:05:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruka, siapa yang memberitahumu?
Dialogue: 0,0:05:06.26,0:05:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, suara aneh apa itu?
Dialogue: 0,0:05:08.94,0:05:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:05:10.60,0:05:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hantu,\Npasti muncul tengah malam, 'kan?
Dialogue: 0,0:05:13.56,0:05:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujung-ujungnya,\Nmereka tetap datang melihat.
Dialogue: 0,0:05:16.60,0:05:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Nanoka,
Dialogue: 0,0:05:18.31,0:05:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak apa kau lewat sini?
Dialogue: 0,0:05:20.44,0:05:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kejadiannya sudah lama.
Dialogue: 0,0:05:22.57,0:05:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku tidak suka.
Dialogue: 0,0:05:23.94,0:05:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini jalan pintas ke sekolah.
Dialogue: 0,0:05:28.95,0:05:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:05:30.83,0:05:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dengar sesuatu?
Dialogue: 0,0:05:31.91,0:05:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hentikan.
Dialogue: 0,0:05:33.25,0:05:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:34.16,0:05:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada suara apa pun.
Dialogue: 0,0:05:35.91,0:05:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma rumor?
Dialogue: 0,0:05:37.54,0:05:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku dengar sesuatu.
Dialogue: 0,0:05:41.84,0:05:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari dalam?
Dialogue: 0,0:06:12.16,0:06:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:14.24,0:06:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di mana?
Dialogue: 0,0:06:18.37,0:06:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku di Jalan Shutter.
Dialogue: 0,0:06:23.21,0:06:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menyebutnya, ya?
Dialogue: 0,0:06:24.59,0:06:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian semua orang di sini sangat kuno.
Dialogue: 0,0:06:29.38,0:06:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga tembus pandang.
Dialogue: 0,0:06:31.01,0:06:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka hantu?
Dialogue: 0,0:06:33.68,0:06:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga. Sebaiknya aku kembali.
Dialogue: 0,0:06:35.77,0:06:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:06:39.27,0:06:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau manusia, 'kan?
Dialogue: 0,0:06:44.73,0:06:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia terluka?
Dialogue: 0,0:07:02.29,0:07:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:07:05.96,0:07:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat!
Dialogue: 0,0:07:09.76,0:07:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao, ada apa
Dialogue: 0,0:07:11.80,0:07:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan jalan ini?
Dialogue: 0,0:07:13.47,0:07:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu tidak tembus pandang.
Dialogue: 0,0:07:15.47,0:07:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia manusia biasa.
Dialogue: 0,0:07:16.81,0:07:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku!
Dialogue: 0,0:07:21.98,0:07:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, urus saja dirimu sendiri.
Dialogue: 0,0:07:23.98,0:07:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:38.50,0:07:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia kabur.
Dialogue: 0,0:07:57.60,0:07:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengalahkan belalang itu?
Dialogue: 0,0:08:07.48,0:08:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:08:09.86,0:08:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukannya…
Dialogue: 0,0:08:11.74,0:08:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:08:14.74,0:08:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kami minta ini?
Dialogue: 0,0:08:16.70,0:08:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memang mengejarnya.
Dialogue: 0,0:08:20.00,0:08:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa ini?
Dialogue: 0,0:08:23.00,0:08:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:08:24.08,0:08:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak membantuku dari awal?
Dialogue: 0,0:08:27.50,0:08:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau tak akan apa-apa.
Dialogue: 0,0:08:31.26,0:08:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau pikir semua orang…
Dialogue: 0,0:08:35.59,0:08:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:38.26,0:08:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganmu tergeletak di sini.
Dialogue: 0,0:08:41.30,0:08:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:08:44.23,0:08:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku…
Dialogue: 0,0:08:59.99,0:09:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku sudah tersambung.
Dialogue: 0,0:09:02.00,0:09:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak sakit.
Dialogue: 0,0:09:04.16,0:09:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini cuma mimpi?
Dialogue: 0,0:09:08.17,0:09:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah sadar?
Dialogue: 0,0:09:09.80,0:09:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, ini…
Dialogue: 0,0:09:13.38,0:09:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao menyembuhkanmu.
Dialogue: 0,0:09:15.93,0:09:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelah.
Dialogue: 0,0:09:17.47,0:09:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa mereka?
Dialogue: 0,0:09:28.73,0:09:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu siluman yang tadi.
Dialogue: 0,0:09:34.95,0:09:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak melawannya tadi?
Dialogue: 0,0:09:38.20,0:09:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku?
Dialogue: 0,0:09:40.12,0:09:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau bertanya?
Dialogue: 0,0:09:41.33,0:09:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari mana pun, kau jauh lebih kuat.
Dialogue: 0,0:09:45.12,0:09:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya,
Dialogue: 0,0:09:47.17,0:09:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah terkena darahmu,
Dialogue: 0,0:09:49.29,0:09:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siluman itu langsung kabur.
Dialogue: 0,0:09:53.13,0:09:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:09:55.84,0:09:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darahku?
Dialogue: 0,0:09:58.93,0:10:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ayakashi, 'kan?
Dialogue: 0,0:10:08.73,0:10:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu. Aku belum selesai bicara.
Dialogue: 0,0:10:11.94,0:10:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sudah cukup.
Dialogue: 0,0:10:14.32,0:10:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar orang aneh yang suka melantur.
Dialogue: 0,0:10:21.03,0:10:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah. Aku menemukan jalan pulang.
Dialogue: 0,0:10:24.54,0:10:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus kembali.
Dialogue: 0,0:10:26.41,0:10:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ayakashi dari sini, 'kan?
Dialogue: 0,0:10:29.21,0:10:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan jalan ini?
Dialogue: 0,0:10:32.75,0:10:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya
Dialogue: 0,0:10:35.30,0:10:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang bertanya.
Dialogue: 0,0:10:36.88,0:10:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikuti aku.
Dialogue: 0,0:10:38.84,0:10:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:10:43.35,0:10:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah pergi.
Dialogue: 0,0:10:47.39,0:10:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tak ada apa pun di sini.
Dialogue: 0,0:10:48.98,0:10:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kembali.
Dialogue: 0,0:10:50.81,0:10:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:10:51.73,0:10:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita ke sini\Nkarena suara aneh itu?
Dialogue: 0,0:10:54.02,0:10:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah katamu itu cuma rumor?
Dialogue: 0,0:10:55.61,0:10:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengar dari orang lain.
Dialogue: 0,0:10:57.24,0:10:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, ada apa denganmu?
Dialogue: 0,0:10:59.28,0:11:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau kotor sekali?
Dialogue: 0,0:11:01.53,0:11:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganku?
Dialogue: 0,0:11:06.20,0:11:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:11:07.70,0:11:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tiba-tiba masuk.
Dialogue: 0,0:11:09.41,0:11:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pulang berlumuran lumpur.
Dialogue: 0,0:11:11.71,0:11:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini semacam tipuan?
Dialogue: 0,0:11:16.76,0:11:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa sebenarnya?
Dialogue: 0,0:11:17.67,0:11:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini Jalan Shutter...\N- Entahlah.
Dialogue: 0,0:11:18.59,0:11:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yang asli.\N- Ada apa dengan Nanoka?
Dialogue: 0,0:11:26.52,0:11:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu mimpi?
Dialogue: 0,0:11:31.27,0:11:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada luka di tanganku.
Dialogue: 0,0:11:36.02,0:11:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:11:37.40,0:11:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lukamu yang kemarin sudah sembuh?
Dialogue: 0,0:11:41.11,0:11:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sepertinya lukanya tidak parah.
Dialogue: 0,0:11:45.24,0:11:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:11:46.95,0:11:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisimu sangat lemah.
Dialogue: 0,0:11:49.20,0:11:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, berhati-hatilah.
Dialogue: 0,0:11:52.00,0:11:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa cerita ke Kakek\Nkejadian kemarin.
Dialogue: 0,0:11:54.59,0:11:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau pasti cemas.
Dialogue: 0,0:11:56.50,0:11:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\Naku sendiri pun masih tidak percaya.
Dialogue: 0,0:11:59.42,0:12:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:12:01.26,0:12:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan minum smoothie-nya.
Dialogue: 0,0:12:10.81,0:12:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan, seperti biasa.
Dialogue: 0,0:12:15.48,0:12:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pelindung di pintu ini.
Dialogue: 0,0:12:18.98,0:12:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita ayakashi itu pasti kabur\Nke seberang pelindung.
Dialogue: 0,0:12:23.74,0:12:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Tuan Mao...
Dialogue: 0,0:12:25.28,0:12:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sepertinya memberinya pil\Nsaat mengobatinya.
Dialogue: 0,0:12:28.99,0:12:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pil apa itu?
Dialogue: 0,0:12:32.25,0:12:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangannya tidak mau menempel lagi,
Dialogue: 0,0:12:35.38,0:12:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, aku mencoba menetralkan racunnya.
Dialogue: 0,0:12:37.54,0:12:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menetralkan?
Dialogue: 0,0:12:40.34,0:12:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ayakashi-nya sepertinya disegel.
Dialogue: 0,0:12:48.18,0:12:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:12:49.77,0:12:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yui, selamat pagi.
Dialogue: 0,0:12:51.52,0:12:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, aku berangkat duluan.
Dialogue: 0,0:12:54.73,0:12:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat. Aku bisa terlambat.
Dialogue: 0,0:12:56.44,0:12:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus bergegas.
Dialogue: 0,0:13:00.03,0:13:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:02.53,0:13:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini? Gerakanku cepat sekali.
Dialogue: 0,0:13:14.00,0:13:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:13:15.50,0:13:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tertabrak?
Dialogue: 0,0:13:16.63,0:13:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:13:18.00,0:13:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia baik-baik saja?
Dialogue: 0,0:13:19.17,0:13:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang terbang.
Dialogue: 0,0:13:21.05,0:13:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:22.92,0:13:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:13:26.47,0:13:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:31.77,0:13:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu Nanoka?
Dialogue: 0,0:13:41.23,0:13:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganku?
Dialogue: 0,0:14:00.96,0:14:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak enak badan.
Dialogue: 0,0:14:03.21,0:14:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek.
Dialogue: 0,0:14:05.13,0:14:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, ada apa?
Dialogue: 0,0:14:07.26,0:14:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:14:08.84,0:14:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau merasa tidak sehat?
Dialogue: 0,0:14:15.02,0:14:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganku?
Dialogue: 0,0:14:17.19,0:14:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku izin libur?
Dialogue: 0,0:14:21.69,0:14:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kembali ke kamarmu dan tidurlah.
Dialogue: 0,0:14:27.28,0:14:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu semua sungguhan?
Dialogue: 0,0:14:31.87,0:14:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadi benar-benar melompat, 'kan?
Dialogue: 0,0:14:35.58,0:14:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak hal aneh terjadi sejak kemarin.
Dialogue: 0,0:14:38.79,0:14:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa semuanya nyata?
Dialogue: 0,0:14:43.21,0:14:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ayakashi, 'kan?
Dialogue: 0,0:14:45.84,0:14:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, nama pria itu Mao.
Dialogue: 0,0:14:51.60,0:14:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:14:58.98,0:15:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:01.65,0:15:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau bicaranya melantur,
Dialogue: 0,0:15:04.11,0:15:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin saja dia tahu sesuatu.
Dialogue: 0,0:15:09.70,0:15:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya aku ke sekolah.
Dialogue: 0,0:15:11.32,0:15:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku jauh lebih baik sekarang.
Dialogue: 0,0:15:13.12,0:15:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:15:14.62,0:15:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:15:15.87,0:15:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Uozumi meracik obat untukmu.
Dialogue: 0,0:15:19.21,0:15:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka, ini smoothie yang lebih pekat.
Dialogue: 0,0:15:22.75,0:15:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah.
Dialogue: 0,0:15:27.01,0:15:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terima kasih.
Dialogue: 0,0:15:28.05,0:15:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat.
Dialogue: 0,0:15:28.97,0:15:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:15:30.30,0:15:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:15:31.55,0:15:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya itu ampuh.
Dialogue: 0,0:15:38.85,0:15:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku ke sini,
Dialogue: 0,0:15:42.94,0:15:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat ini hanya Jalan Shutter biasa.
Dialogue: 0,0:15:45.61,0:15:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang berlalu-lalang.
Dialogue: 0,0:15:48.53,0:15:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan ada yang berubah.
Dialogue: 0,0:16:04.08,0:16:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali ke sini.
Dialogue: 0,0:16:07.00,0:16:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:08.80,0:16:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wanita ayakashi kemarin.
Dialogue: 0,0:16:11.22,0:16:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah kembali.
Dialogue: 0,0:16:13.18,0:16:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau anak yang bersama Mao, 'kan?
Dialogue: 0,0:16:17.18,0:16:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawahan Tuan Mao.
Dialogue: 0,0:16:20.77,0:16:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Otoya.
Dialogue: 0,0:16:23.02,0:16:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nanoka.
Dialogue: 0,0:16:25.81,0:16:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:16:27.90,0:16:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertemu Mao.
Dialogue: 0,0:16:32.57,0:16:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku bicara dengannya?
Dialogue: 0,0:16:34.91,0:16:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:36.03,0:16:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao sedang menyelidiki jalan ini.
Dialogue: 0,0:16:39.75,0:16:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tempat ini aneh?
Dialogue: 0,0:16:41.83,0:16:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang di sini transparan.
Dialogue: 0,0:16:43.54,0:16:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kalian penghuni sini?
Dialogue: 0,0:16:46.96,0:16:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kami baru datang kemarin.
Dialogue: 0,0:17:07.90,0:17:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat mencurigakan,
Dialogue: 0,0:17:13.10,0:17:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak merasakan\Nniat jahat darinya.
Dialogue: 0,0:17:17.66,0:17:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:17:20.99,0:17:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bukan penghuni sini, 'kan?
Dialogue: 0,0:17:25.54,0:17:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau yang berpatroli di sini?
Dialogue: 0,0:17:29.80,0:17:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak tahu?
Dialogue: 0,0:17:32.09,0:17:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat mencurigakan.
Dialogue: 0,0:17:36.34,0:17:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan trik murahanmu.
Dialogue: 0,0:17:44.85,0:17:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit.
Dialogue: 0,0:17:47.10,0:17:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutmu lebat juga.
Dialogue: 0,0:17:51.40,0:17:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:18:00.45,0:18:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku menemukan orang\Nyang bisa diajak bicara.
Dialogue: 0,0:18:05.08,0:18:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memangsamu.
Dialogue: 0,0:18:10.50,0:18:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bergerak.
Dialogue: 0,0:18:13.63,0:18:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena rambutmu kutempel ke patung kertas.
Dialogue: 0,0:18:18.39,0:18:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai.
Dialogue: 0,0:18:20.97,0:18:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang memasang pelindung di jalan ini?
Dialogue: 0,0:18:23.56,0:18:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Entahlah.
Dialogue: 0,0:18:26.06,0:18:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah pelindung ini selalu ada di sini?
Dialogue: 0,0:18:30.23,0:18:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia.
Dialogue: 0,0:18:31.77,0:18:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia melawan siluman lagi.
Dialogue: 0,0:18:34.86,0:18:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:36.32,0:18:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao adalah onmyoji.
Dialogue: 0,0:18:38.11,0:18:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau tak cuma bisa meramal,\Ntapi bisa menyembuhkan penyakit.
Dialogue: 0,0:18:40.62,0:18:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang, ia juga melawan ayakashi.
Dialogue: 0,0:18:44.58,0:18:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata onmyoji benar-benar ada.
Dialogue: 0,0:18:49.25,0:18:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau pindah kemari karena kebetulan?
Dialogue: 0,0:18:54.51,0:18:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tempat ini nyaman.
Dialogue: 0,0:18:57.97,0:19:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku menanyakan satu hal lagi.
Dialogue: 0,0:19:01.14,0:19:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu soal Byoki?
Dialogue: 0,0:19:05.60,0:19:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki…
Dialogue: 0,0:19:07.35,0:19:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyakit apa?
Dialogue: 0,0:19:08.73,0:19:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki.
Dialogue: 0,0:19:10.52,0:19:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:19:12.23,0:19:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sama sekali tidak tahu.
Dialogue: 0,0:19:15.15,0:19:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:19:21.82,0:19:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bergerak.
Dialogue: 0,0:19:23.45,0:19:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau boleh pergi sekarang.
Dialogue: 0,0:19:25.70,0:19:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku pergi.
Dialogue: 0,0:19:27.41,0:19:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebelum itu,
Dialogue: 0,0:19:29.00,0:19:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memakanmu!
Dialogue: 0,0:19:31.17,0:19:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:19:43.22,0:19:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:50.14,0:19:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:19:52.81,0:19:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:19:55.02,0:19:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaianmu robek.
Dialogue: 0,0:19:57.73,0:19:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya.
Dialogue: 0,0:20:00.70,0:20:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayakashi yang kemarin.
Dialogue: 0,0:20:02.57,0:20:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa namanya Nanoka.
Dialogue: 0,0:20:08.66,0:20:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berlumuran darah.
Dialogue: 0,0:20:13.88,0:20:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini…
Dialogue: 0,0:20:15.67,0:20:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau butuh perban?
Dialogue: 0,0:20:18.34,0:20:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:20:20.34,0:20:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga melihatnya, 'kan?
Dialogue: 0,0:20:22.22,0:20:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayakashi akan bernasib sial\Njika menyentuh darahku.
Dialogue: 0,0:20:26.89,0:20:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan ayakashi!
Dialogue: 0,0:20:29.68,0:20:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau juga aneh.
Dialogue: 0,0:20:33.81,0:20:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kau yang lebih mirip yokai.
Dialogue: 0,0:20:36.19,0:20:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kubilang?
Dialogue: 0,0:20:37.90,0:20:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao adalah Onmyoji.
Dialogue: 0,0:20:40.65,0:20:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Lalu apa yang tadi itu sejenis mantra?
Dialogue: 0,0:20:44.91,0:20:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dikutuk.
Dialogue: 0,0:20:47.08,0:20:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikutuk?
Dialogue: 0,0:20:49.49,0:20:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dikutuk oleh Byoki.
Dialogue: 0,0:20:55.79,0:20:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah tulisan "Byoki".
Dialogue: 0,0:20:59.25,0:21:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki?
Dialogue: 0,0:21:01.55,0:21:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu sejenis kucing siluman?
Dialogue: 0,0:21:03.93,0:21:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya tak terdengar seram sama sekali.
Dialogue: 0,0:21:05.84,0:21:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu jenis kodoku\Nyang sangat mengerikan.
Dialogue: 0,0:21:09.77,0:21:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kodoku?
Dialogue: 0,0:21:12.02,0:21:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau tak tahu apa-apa.
Dialogue: 0,0:21:14.77,0:21:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup.
Dialogue: 0,0:21:17.36,0:21:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah guci kodoku ini.
Dialogue: 0,0:21:22.86,0:21:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siluman belalang sembah itu\Ndimasukkan ke sini.
Dialogue: 0,0:21:25.86,0:21:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kanji untuk kodoku.
Dialogue: 0,0:21:28.66,0:21:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangga beracun seperti laba-laba,\Nlipan, dan ular dimasukkan ke dalam
Dialogue: 0,0:21:32.16,0:21:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar saling memangsa.
Dialogue: 0,0:21:34.46,0:21:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang selamat disebut kodoku.
Dialogue: 0,0:21:38.29,0:21:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa untuk mengutuk atau meracuni orang.
Dialogue: 0,0:21:42.09,0:21:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki juga seperti ini.
Dialogue: 0,0:21:43.55,0:21:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak kucing disatukan untuk\Nbertarung dan saling memangsa.
Dialogue: 0,0:21:46.89,0:21:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kodoku yang bertahan hidup disebut Byoki.
Dialogue: 0,0:21:54.35,0:21:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada yang mengutukmu dengan Byoki?
Dialogue: 0,0:22:00.44,0:22:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu.
Dialogue: 0,0:22:05.40,0:22:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pelakunya?
Dialogue: 0,0:22:08.16,0:22:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingat kejadian saat itu.
Dialogue: 0,0:22:13.83,0:22:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu. Punggungmu…
Dialogue: 0,0:22:19.25,0:22:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukamu parah.
Dialogue: 0,0:22:21.30,0:22:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus berdarah pula.
Dialogue: 0,0:22:24.01,0:22:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukanya tadinya di sini?
Dialogue: 0,0:22:27.68,0:22:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini?
Dialogue: 0,0:22:31.43,0:22:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang lukanya muncul.
Dialogue: 0,0:22:33.14,0:22:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tanda kutukan Byoki.
Dialogue: 0,0:22:35.35,0:22:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pakaian ganti terakhir.
Dialogue: 0,0:22:38.40,0:22:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan dikotori lagi.
Dialogue: 0,0:22:41.15,0:22:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu?
Dialogue: 0,0:22:42.65,0:22:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:44.03,0:22:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau datang jauh-jauh kemari.
Dialogue: 0,0:22:46.74,0:22:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba ingin bilang sesuatu?
Dialogue: 0,0:22:49.32,0:22:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, pertanyaanku lebih banyak darimu.
Dialogue: 0,0:22:52.49,0:22:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku ini manusia.
Dialogue: 0,0:22:56.00,0:22:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tiba-tiba…
Dialogue: 0,0:22:58.08,0:23:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak aku ke sini kemarin, tubuhku jadi...
Dialogue: 0,0:23:01.50,0:23:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu cara menjelaskannya.
Dialogue: 0,0:23:03.96,0:23:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau manusia?
Dialogue: 0,0:23:06.67,0:23:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:23:08.76,0:23:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini…
Dialogue: 0,0:23:10.22,0:23:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, orang tuaku manusia biasa.
Dialogue: 0,0:23:15.60,0:23:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reruntuhan tempo hari
Dialogue: 0,0:23:18.69,0:23:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terjadi di jalan ini.
Dialogue: 0,0:23:19.94,0:23:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejadiannya di tengah Jalan Shutter.
Dialogue: 0,0:23:24.57,0:23:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru ingat.
Dialogue: 0,0:23:41.96,0:23:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu aku melihat siluman.
Dialogue: 0,0:25:14.93,0:25:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode selanjutnya, "Wanita Laba-laba."
