Dialogue: 0,0:01:40.43,0:01:42.64,tanda,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:02:15.17,0:02:18.18,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:03:32.79,0:03:36.04,tanda,,0000,0000,0000,,WADAH BARU
Dialogue: 0,0:09:04.79,0:09:07.03,tanda,,0000,0000,0000,,"KAKEK NANOKA"
Dialogue: 0,0:10:56.61,0:10:59.95,tanda,,0000,0000,0000,,"BYOKI"
Dialogue: 0,0:12:58.86,0:13:00.69,tanda,,0000,0000,0000,,SHIRAHA
Dialogue: 0,0:14:09.30,0:14:11.10,tanda,,0000,0000,0000,,"UOZUMI FUNA"
Dialogue: 0,0:14:46.84,0:14:49.93,tanda,,0000,0000,0000,,MAO
Dialogue: 0,0:15:49.90,0:15:51.53,tanda,,0000,0000,0000,,"PUSAT MEDIS DARURAT"
Dialogue: 0,0:18:53.34,0:18:54.51,tanda,,0000,0000,0000,,"TENKO"
Dialogue: 0,0:21:28.24,0:21:29.66,tanda,,0000,0000,0000,,"PEMIMPIN KLAN GOKO"
Dialogue: 0,0:22:21.38,0:22:22.46,tanda,,0000,0000,0000,,"TENGKORAK BERAPI"
Dialogue: 0,0:24:49.36,0:24:50.53,tanda,,0000,0000,0000,,"SELANJUTNYA"
Dialogue: 0,0:00:23.77,0:00:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang itu sama…
Dialogue: 0,0:00:26.23,0:00:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menolongnya!
Dialogue: 0,0:00:28.86,0:00:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu adalah aku!
Dialogue: 0,0:00:45.17,0:00:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:00:57.26,0:00:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu terbang keluar.
Dialogue: 0,0:01:09.57,0:01:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao…
Dialogue: 0,0:01:18.70,0:01:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kembali normal.
Dialogue: 0,0:01:21.33,0:01:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:01:24.66,0:01:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao…
Dialogue: 0,0:01:35.72,0:01:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Dia telanjang.
Dialogue: 0,0:01:38.09,0:01:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?
Dialogue: 0,0:01:39.51,0:01:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka,
Dialogue: 0,0:01:40.43,0:01:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus bawa Tuan Mao ke tempat aman.
Dialogue: 0,0:01:43.27,0:01:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:01:44.89,0:01:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak sadarkan diri.
Dialogue: 0,0:01:46.44,0:01:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:47.81,0:01:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bagaimana caranya?
Dialogue: 0,0:01:49.86,0:01:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia telanjang.
Dialogue: 0,0:01:51.77,0:01:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?
Dialogue: 0,0:01:54.48,0:01:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dokter Mao!
Dialogue: 0,0:03:38.13,0:03:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:03:39.51,0:03:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi jahat dari kepala kucing raksasa itu\Nbegitu menakutkan
Dialogue: 0,0:03:42.84,0:03:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga kami tidak bisa\Nmendekati Jalan Kelima.
Dialogue: 0,0:03:46.51,0:03:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Dokter Mao baik-baik saja?
Dialogue: 0,0:03:49.60,0:03:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:03:51.02,0:03:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cukup kecewa setelah membiarkan
Dialogue: 0,0:03:52.60,0:03:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki yang dia kejar bertahun-tahun lolos.
Dialogue: 0,0:03:56.23,0:03:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya.
Dialogue: 0,0:03:58.07,0:04:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao, kau sudah sadar?
Dialogue: 0,0:04:02.74,0:04:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Nanoka?
Dialogue: 0,0:04:04.36,0:04:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, Nanoka…
Dialogue: 0,0:04:08.79,0:04:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu Ibu Kota Kekaisaran di kejauhan?
Dialogue: 0,0:04:10.83,0:04:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu mengerikan. Itu lautan api.
Dialogue: 0,0:04:14.25,0:04:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area ini dan Jalan Kelima hancur.
Dialogue: 0,0:04:17.75,0:04:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, apa yang terjadi\Ndengan batu kuncinya?
Dialogue: 0,0:04:20.95,0:04:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu menghilang,\Nmeninggalkan lubang menganga.
Dialogue: 0,0:04:24.26,0:04:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu kuncinya…
Dialogue: 0,0:04:26.64,0:04:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki yang bersembunyi\Ndi bawah batu kunci itu
Dialogue: 0,0:04:29.43,0:04:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lolos karena gempa bumi.
Dialogue: 0,0:04:32.64,0:04:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pikir penghalang Byoki\Ntelah menghilang
Dialogue: 0,0:04:36.65,0:04:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kekuatan gempa bumi\Nkeluar dari gerbang
Dialogue: 0,0:04:43.74,0:04:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyebabkan kecelakaan lubang runtuhan.
Dialogue: 0,0:04:51.91,0:04:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku terseret ke era Taisho.
Dialogue: 0,0:04:56.79,0:04:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kenapa? Apa itu hanya kebetulan?
Dialogue: 0,0:05:00.96,0:05:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan tubuhmu kepadaku
Dialogue: 0,0:05:02.97,0:05:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyatulah denganku.
Dialogue: 0,0:05:05.72,0:05:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:05:07.09,0:05:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adalah wadah yang hanya muncul\Nseribu tahun sekali.
Dialogue: 0,0:05:11.93,0:05:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wadah yang hanya muncul\Nseribu tahun sekali?
Dialogue: 0,0:05:15.02,0:05:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa kau, seperti Mao,
Dialogue: 0,0:05:18.90,0:05:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga memiliki darah Byoki?
Dialogue: 0,0:05:22.94,0:05:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga pantas menjadi wadahku.
Dialogue: 0,0:05:30.03,0:05:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku terpilih menjadi wadah barunya?
Dialogue: 0,0:05:33.29,0:05:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wadah yang hanya muncul\Nseribu tahun sekali?
Dialogue: 0,0:05:35.87,0:05:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak yakin.
Dialogue: 0,0:05:38.17,0:05:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu artinya mereka\Npasangan serasi. Sangat cocok.
Dialogue: 0,0:05:44.01,0:05:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menginginkanku
Dialogue: 0,0:05:45.01,0:05:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai wadahnya untuk menggantikan Mao?
Dialogue: 0,0:05:48.30,0:05:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:05:50.68,0:05:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:05:53.35,0:05:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah merasa lebih baik?
Dialogue: 0,0:05:57.14,0:05:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao?
Dialogue: 0,0:05:59.35,0:06:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bilang kau adalah anak kecil itu?
Dialogue: 0,0:06:03.03,0:06:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:04.61,0:06:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:06.15,0:06:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, rasanya urutan waktunya berantakan.
Dialogue: 0,0:06:10.70,0:06:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada saat itu,
Dialogue: 0,0:06:12.16,0:06:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal terbaik yang bisa kulakukan\Nadalah mengirim shikigami penjaga.
Dialogue: 0,0:06:18.50,0:06:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu lepas ke duniamu\Ndi luar penghalang
Dialogue: 0,0:06:23.00,0:06:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengincarmu.
Dialogue: 0,0:06:37.68,0:06:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerbang penghalangnya masih utuh
Dialogue: 0,0:06:40.90,0:06:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski kota ini sudah menjadi abu.
Dialogue: 0,0:06:44.65,0:06:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku melewatinya,
Dialogue: 0,0:06:46.07,0:06:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisakah aku kembali ke masa kini?
Dialogue: 0,0:06:59.83,0:07:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:07:01.46,0:07:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya.
Dialogue: 0,0:07:03.38,0:07:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kau lakukan sekarang?
Dialogue: 0,0:07:06.42,0:07:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pertanyaan bagus.\NApa yang harus kulakukan?
Dialogue: 0,0:07:12.93,0:07:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Mao?
Dialogue: 0,0:07:14.30,0:07:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak cukup kecewa.
Dialogue: 0,0:07:16.27,0:07:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia membiarkan Byoki itu lolos?
Dialogue: 0,0:07:19.43,0:07:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebagian alasannya, tentu saja,
Dialogue: 0,0:07:22.02,0:07:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi saat dia berwujud binatang itu,
Dialogue: 0,0:07:24.86,0:07:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia hampir tak menyadari apa yang terjadi.
Dialogue: 0,0:07:27.11,0:07:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, setelah itu, dia cenderung\Nsangat mengkhawatirkan apa yang terjadi.
Dialogue: 0,0:07:31.91,0:07:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti orang yang menyesal setelah mabuk?
Dialogue: 0,0:07:34.37,0:07:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya...
Dialogue: 0,0:07:35.78,0:07:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia meminta penjelasan rinci\Ntentang apa yang terjadi
Dialogue: 0,0:07:38.91,0:07:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat berwujud binatang.
Dialogue: 0,0:07:52.38,0:07:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak berpikir keras.
Dialogue: 0,0:07:54.80,0:07:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:07:56.01,0:07:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu katashiro untuk shikigami.
Dialogue: 0,0:07:58.06,0:07:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:08:00.31,0:08:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,
Dialogue: 0,0:08:02.10,0:08:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao bilang dia mengirim shikigami penjaga.
Dialogue: 0,0:08:11.90,0:08:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:08:13.61,0:08:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kau lakukan mulai sekarang?
Dialogue: 0,0:08:15.74,0:08:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Soal itu…
Dialogue: 0,0:08:20.29,0:08:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut…
Dialogue: 0,0:08:23.08,0:08:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu melarikan diri ke duniamu.
Dialogue: 0,0:08:26.13,0:08:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, aku tak bisa\Nmelewati penghalang itu.
Dialogue: 0,0:08:29.42,0:08:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa gelisah\Nmembiarkanmu pulang sendirian.
Dialogue: 0,0:08:32.72,0:08:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:34.54,0:08:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga.
Dialogue: 0,0:08:38.92,0:08:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada hal lain?
Dialogue: 0,0:08:41.52,0:08:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak orang tuaku meninggal\Ndalam kecelakaan itu,
Dialogue: 0,0:08:44.65,0:08:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dibesarkan oleh kakekku.
Dialogue: 0,0:08:48.77,0:08:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat baik.
Dialogue: 0,0:08:51.03,0:08:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu berada di sisiku.
Dialogue: 0,0:08:55.61,0:08:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku ingat sesuatu.
Dialogue: 0,0:08:58.74,0:09:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari orang tuaku meninggal,
Dialogue: 0,0:09:00.70,0:09:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku ditarik ke era Taisho,
Dialogue: 0,0:09:04.79,0:09:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek sedang sekarat.
Dialogue: 0,0:09:08.79,0:09:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umur orang sekarat diperpanjang?
Dialogue: 0,0:09:13.09,0:09:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:09:15.26,0:09:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bilang,
Dialogue: 0,0:09:16.76,0:09:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki bisa memanipulasi umur orang.
Dialogue: 0,0:09:20.76,0:09:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki memperpanjang hidup Kakek?
Dialogue: 0,0:09:24.52,0:09:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk tujuan apa?
Dialogue: 0,0:09:27.02,0:09:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu berarti
Dialogue: 0,0:09:29.61,0:09:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek berada di bawah kendali Byoki.
Dialogue: 0,0:09:32.82,0:09:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin mengawasimu saat membesarkanmu.
Dialogue: 0,0:09:37.49,0:09:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:38.66,0:09:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek…
Dialogue: 0,0:09:44.87,0:09:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua akan baik-baik saja, Nanoka.
Dialogue: 0,0:09:47.54,0:09:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek akan bersamamu.
Dialogue: 0,0:09:49.92,0:09:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka! Astaga, apa yang terjadi?
Dialogue: 0,0:09:52.05,0:09:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau merasa tak sehat?
Dialogue: 0,0:09:53.96,0:09:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukamu kemarin…\NKau baik-baik saja sekarang?
Dialogue: 0,0:09:57.38,0:09:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu lemah,
Dialogue: 0,0:09:59.60,0:10:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kau harus berhati-hati.
Dialogue: 0,0:10:02.26,0:10:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengawasiku?
Dialogue: 0,0:10:04.98,0:10:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:10:06.60,0:10:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau kembali sekarang,
Dialogue: 0,0:10:07.98,0:10:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu mungkin menjadikanmu wadahnya.
Dialogue: 0,0:10:14.82,0:10:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi…
Dialogue: 0,0:10:17.82,0:10:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau takut, tetaplah di sini.
Dialogue: 0,0:10:20.57,0:10:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersamaku.
Dialogue: 0,0:10:22.66,0:10:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:23.79,0:10:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia baru saja
Dialogue: 0,0:10:26.41,0:10:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memintaku tinggal bersamanya selamanya?
Dialogue: 0,0:10:30.79,0:10:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:10:33.38,0:10:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentu saja kuat secara fisik,
Dialogue: 0,0:10:35.80,0:10:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hatimu juga baik.
Dialogue: 0,0:10:37.55,0:10:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jujur dan berani.
Dialogue: 0,0:10:39.59,0:10:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Dia tiba-tiba memujiku.
Dialogue: 0,0:10:42.76,0:10:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:10:47.31,0:10:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan lebih dari mampu menjadi bawahanku.
Dialogue: 0,0:10:50.81,0:10:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:52.94,0:10:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,\Njika kau tidak ada di sisi lain,
Dialogue: 0,0:10:56.61,0:10:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu akhirnya akan kembali ke sini.
Dialogue: 0,0:11:00.57,0:11:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa bekerja sebagai asistenku\Nsampai saat itu
Dialogue: 0,0:11:03.45,0:11:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan belajar cara melawan Byoki itu.
Dialogue: 0,0:11:06.50,0:11:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!\NUntuk apa aku mau menjadi bawahanmu?
Dialogue: 0,0:11:10.67,0:11:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:11:15.59,0:11:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri aku jimat penghalang, senjata,
Dialogue: 0,0:11:18.63,0:11:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau semacamnya!
Dialogue: 0,0:11:26.47,0:11:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:11:29.02,0:11:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan kembali?
Dialogue: 0,0:11:30.69,0:11:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:32.02,0:11:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mencari tahu yang sebenarnya
Dialogue: 0,0:11:34.61,0:11:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang kakekku.
Dialogue: 0,0:11:37.07,0:11:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:11:41.45,0:11:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:11:43.57,0:11:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:11:50.25,0:11:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:11:51.50,0:11:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini batu pelindung.
Dialogue: 0,0:11:53.33,0:11:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan mengusir kejahatan\Nyang mendekatimu.
Dialogue: 0,0:11:57.34,0:11:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan melindungimu
Dialogue: 0,0:11:59.88,0:12:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti penghalang.
Dialogue: 0,0:12:02.22,0:12:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Terima kasih.
Dialogue: 0,0:12:05.26,0:12:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan di sisi lain,
Dialogue: 0,0:12:06.85,0:12:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}shikigami penjaga yang kukirim\Nseharusnya ada di sana.
Dialogue: 0,0:12:10.64,0:12:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku tidak tahu wujud apa\Nyang dibutuhkan untuk membantumu.
Dialogue: 0,0:12:15.11,0:12:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu aku punya sekutu di sana?
Dialogue: 0,0:12:19.11,0:12:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:12:21.03,0:12:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa\Nyang akan terjadi di masa depan,
Dialogue: 0,0:12:25.41,0:12:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak menghadapinya sendirian.
Dialogue: 0,0:12:31.29,0:12:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada masalah?
Dialogue: 0,0:12:33.21,0:12:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Kalau begitu, aku permisi.
Dialogue: 0,0:12:37.04,0:12:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, Nona Nanoka.
Dialogue: 0,0:12:46.43,0:12:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sekutuku?
Dialogue: 0,0:12:50.22,0:12:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang yang dekat dan selalu membantuku.
Dialogue: 0,0:13:00.98,0:13:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiba.
Dialogue: 0,0:13:02.44,0:13:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiraha.
Dialogue: 0,0:13:04.32,0:13:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini… Kau baik-baik saja?
Dialogue: 0,0:13:07.91,0:13:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:09.03,0:13:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kau pulang dari rumah sakit\Nselama liburan musim panas,
Dialogue: 0,0:13:12.54,0:13:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah kelas mulai.\Ntapi kau tak masuk sekolah
Dialogue: 0,0:13:15.42,0:13:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga. Semester kedua sudah dimulai.
Dialogue: 0,0:13:19.42,0:13:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu…
Dialogue: 0,0:13:21.76,0:13:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku pernah melihatmu
Dialogue: 0,0:13:23.72,0:13:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di jalan perbelanjaan sepi ini,\Ntapi kemudian
Dialogue: 0,0:13:26.84,0:13:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku kehilanganmu.
Dialogue: 0,0:13:31.77,0:13:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu hanya imajinasiku,
Dialogue: 0,0:13:35.69,0:13:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi saat aku melihatmu,\Nkau tampak gelisah.
Dialogue: 0,0:13:38.31,0:13:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hari saat aku menemui Mao
Dialogue: 0,0:13:41.15,0:13:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan gempa bumi itu terjadi.
Dialogue: 0,0:13:43.82,0:13:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, jika ada yang bisa kubantu,
Dialogue: 0,0:13:47.53,0:13:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}minta saja.
Dialogue: 0,0:13:48.66,0:13:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:50.03,0:13:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan di sisi lain,
Dialogue: 0,0:13:52.20,0:13:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}shikigami penjaga yang kukirim\Nseharusnya ada di sana.
Dialogue: 0,0:13:57.75,0:13:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah…
Dialogue: 0,0:13:59.42,0:14:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah itu Shiraha?
Dialogue: 0,0:14:02.09,0:14:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:14:05.17,0:14:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kau kembali dengan selamat.
Dialogue: 0,0:14:09.30,0:14:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk menjemputmu.
Dialogue: 0,0:14:11.72,0:14:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uozumi.
Dialogue: 0,0:14:15.64,0:14:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.\NAku harus bicara dengan Shiraha.
Dialogue: 0,0:14:20.11,0:14:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku tak percaya Nanoka…
Dialogue: 0,0:14:24.61,0:14:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin bicara denganku!
Dialogue: 0,0:14:27.74,0:14:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Uozumi,\Nbisakah kau kembali tanpa aku?
Dialogue: 0,0:14:31.41,0:14:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Shiraha.
Dialogue: 0,0:14:34.91,0:14:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:14:38.21,0:14:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bertemu Tuan Mao, bukan?
Dialogue: 0,0:14:41.08,0:14:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:53.18,0:14:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah lihat itu?
Dialogue: 0,0:14:54.97,0:14:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil!
Dialogue: 0,0:14:57.18,0:14:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Ibu dan Ayah meninggal,
Dialogue: 0,0:15:00.23,0:15:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mulai tinggal bersama Kakek.
Dialogue: 0,0:15:03.48,0:15:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lama setelah itu,
Dialogue: 0,0:15:05.19,0:15:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uozumi tinggal dengan kami\Nsebagai asisten rumah tangga.
Dialogue: 0,0:15:08.95,0:15:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan saat masih kecil,
Dialogue: 0,0:15:10.24,0:15:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa dia tidak sepenuhnya manusia.
Dialogue: 0,0:15:14.66,0:15:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau shikigami?
Dialogue: 0,0:15:16.87,0:15:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:19.50,0:15:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tengah gempa bumi besar itu,
Dialogue: 0,0:15:21.88,0:15:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku meninggalkan katashiro-ku\Natas perintah Tuan Mao,
Dialogue: 0,0:15:25.59,0:15:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu mengikuti Byoki itu dan kau\Nke tempat ini.
Dialogue: 0,0:15:31.59,0:15:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberitahumu\Napa yang kulihat saat itu.
Dialogue: 0,0:15:35.22,0:15:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau melewati penghalang itu,
Dialogue: 0,0:15:38.23,0:15:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau berlumuran darah beracun
Dialogue: 0,0:15:40.06,0:15:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari Byoki yang terluka.
Dialogue: 0,0:15:42.44,0:15:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang biasa akan langsung mati.
Dialogue: 0,0:15:47.03,0:15:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu menghilang di suatu tempat.
Dialogue: 0,0:15:49.90,0:15:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dibawa ke rumah sakit
Dialogue: 0,0:15:51.61,0:15:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kemungkinan besar sama
Dialogue: 0,0:15:52.95,0:15:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan tempat kakekmu dirawat.
Dialogue: 0,0:15:57.74,0:15:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:16:00.37,0:16:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka… Nanoka…
Dialogue: 0,0:16:03.29,0:16:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka…
Dialogue: 0,0:16:05.96,0:16:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek seharusnya dalam kondisi kritis.
Dialogue: 0,0:16:09.05,0:16:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter bilang itu keajaiban.
Dialogue: 0,0:16:13.93,0:16:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu memperpanjang hidupnya?
Dialogue: 0,0:16:16.72,0:16:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kenapa?
Dialogue: 0,0:16:18.39,0:16:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia butuh seseorang\Nuntuk melindungi dan membesarkanmu.
Dialogue: 0,0:16:25.31,0:16:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begitu aku dewasa,
Dialogue: 0,0:16:27.57,0:16:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ia berencana menjadikanku wadahnya?
Dialogue: 0,0:16:30.28,0:16:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasku adalah menjauhkanmu dari Byoki itu
Dialogue: 0,0:16:35.57,0:16:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melindungimu.
Dialogue: 0,0:16:38.91,0:16:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selamat dari paparan darah Byoki
Dialogue: 0,0:16:42.50,0:16:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memperoleh kekuatan yokai,\Nsehingga menjadikanmu wadah yang cocok.
Dialogue: 0,0:16:47.29,0:16:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah mengapa aku mengambil inisiatif
Dialogue: 0,0:16:48.92,0:16:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menghilangkan\Nkekuatan yokai-mu sepenuhnya
Dialogue: 0,0:16:53.18,0:16:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyegelnya.
Dialogue: 0,0:16:56.97,0:16:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku mengerti!
Dialogue: 0,0:16:59.26,0:17:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Smoothie yang terasa\Nseperti lumpur busuk itu…
Dialogue: 0,0:17:02.98,0:17:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencampur campuran herba rahasia
Dialogue: 0,0:17:05.02,0:17:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menekan kekuatanmu\Ndan menutupi keberadaanmu.
Dialogue: 0,0:17:09.48,0:17:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bukankah Kakek terhubung\Ndengan Byoki itu?
Dialogue: 0,0:17:13.85,0:17:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga sesuatu yang tidak kupahami.
Dialogue: 0,0:17:19.11,0:17:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau pergi,
Dialogue: 0,0:17:22.00,0:17:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kakekmu hampir tidak bergerak
Dialogue: 0,0:17:24.57,0:17:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau tertidur lelap.
Dialogue: 0,0:17:27.32,0:17:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah
Dialogue: 0,0:17:30.21,0:17:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia hidup hanya untukmu, Nanoka.
Dialogue: 0,0:17:40.64,0:17:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pulang!
Dialogue: 0,0:17:43.93,0:17:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:17:45.81,0:17:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek.
Dialogue: 0,0:17:47.56,0:17:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat khawatir.
Dialogue: 0,0:17:49.90,0:17:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana saja kau?
Dialogue: 0,0:17:53.82,0:17:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu pelindungnya.
Dialogue: 0,0:17:56.28,0:17:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan mengusir kejahatan\Nyang mendekatimu.
Dialogue: 0,0:18:00.41,0:18:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan melindungimu
Dialogue: 0,0:18:02.62,0:18:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti penghalang.
Dialogue: 0,0:18:05.66,0:18:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua baik-baik saja, Nanoka?
Dialogue: 0,0:18:08.04,0:18:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek.
Dialogue: 0,0:18:10.13,0:18:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:18:11.63,0:18:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lega sekali.
Dialogue: 0,0:18:16.05,0:18:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali,
Dialogue: 0,0:18:18.84,0:18:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:18:21.60,0:18:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek!
Dialogue: 0,0:18:28.35,0:18:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kakekku tersayang!
Dialogue: 0,0:18:53.34,0:18:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Mao?
Dialogue: 0,0:18:56.51,0:18:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku masuk?
Dialogue: 0,0:18:58.68,0:19:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kau mungkin butuh persediaan,\Njadi aku mengumpulkan beberapa barang.
Dialogue: 0,0:19:02.97,0:19:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenko.
Dialogue: 0,0:19:04.47,0:19:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang melihatmu baik-baik saja.
Dialogue: 0,0:19:07.23,0:19:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:11.90,0:19:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian.
Dialogue: 0,0:19:14.11,0:19:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau bisa mendapatkan ini?
Dialogue: 0,0:19:16.28,0:19:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Milk Hall?
Dialogue: 0,0:19:18.61,0:19:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada retakan, tapi berhasil bertahan.
Dialogue: 0,0:19:21.91,0:19:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kami akan tutup untuk sementara.
Dialogue: 0,0:19:25.70,0:19:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar apa yang terjadi, Dokter Mao.
Dialogue: 0,0:19:29.12,0:19:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, akhirnya kau menghadapi Byoki
Dialogue: 0,0:19:31.17,0:19:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kau cari selama ini.
Dialogue: 0,0:19:34.04,0:19:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:19:35.34,0:19:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, pada akhirnya,\Naku membiarkannya lolos.
Dialogue: 0,0:19:40.26,0:19:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada
Dialogue: 0,0:19:41.68,0:19:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terselesaikan.
Dialogue: 0,0:19:44.47,0:19:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, mungkinkah kau tidak tahu
Dialogue: 0,0:19:48.85,0:19:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang sebenarnya terjadi saat itu?
Dialogue: 0,0:19:53.77,0:19:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:55.48,0:19:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak tahu siapa yang membunuh gurumu,
Dialogue: 0,0:19:58.74,0:20:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membakar Ruang Pusaka,
Dialogue: 0,0:20:02.03,0:20:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memanahmu?
Dialogue: 0,0:20:06.58,0:20:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dijebak.
Dialogue: 0,0:20:08.87,0:20:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dan aku.
Dialogue: 0,0:20:12.08,0:20:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ingin dikatakan Byoki itu\Nkepadaku?
Dialogue: 0,0:20:15.96,0:20:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Mao, kurasa
Dialogue: 0,0:20:18.09,0:20:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita tidak boleh mengabaikan\Nsoal kepala yang terbakar.
Dialogue: 0,0:20:20.72,0:20:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala yang terbakar?
Dialogue: 0,0:20:22.47,0:20:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang tewas\Ndalam gempa bumi besar itu.
Dialogue: 0,0:20:27.43,0:20:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di reruntuhan Ibu Kota Kekaisaran\Nyang terbakar,
Dialogue: 0,0:20:29.22,0:20:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih ada jasad yang belum ditemukan.
Dialogue: 0,0:20:33.23,0:20:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya di malam hari,
Dialogue: 0,0:20:35.36,0:20:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita tidak tahu apakah itu\Nkepala yang terpisah dari mayat,
Dialogue: 0,0:20:39.65,0:20:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mereka terbang, terselubung api.
Dialogue: 0,0:20:46.37,0:20:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi. Tuan Mao.
Dialogue: 0,0:20:49.29,0:20:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa yang menyerang Jalan Kelima
Dialogue: 0,0:20:52.41,0:20:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada hari gempa bumi besar?
Dialogue: 0,0:20:57.29,0:21:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir mereka mungkin ayakashi\Nyang tertarik pada aura jahat Byoki itu.
Dialogue: 0,0:21:01.38,0:21:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi tampaknya\Nmereka tidak terhubung dengan Byoki itu.
Dialogue: 0,0:21:06.18,0:21:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka berbeda\Ndari kepala yang terbakar di ibu kota?
Dialogue: 0,0:21:09.68,0:21:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari yang kulihat,
Dialogue: 0,0:21:11.77,0:21:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka seperti kepala yang sangat kuno.
Dialogue: 0,0:21:15.27,0:21:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala yang terbakar…
Dialogue: 0,0:21:22.65,0:21:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kepala kuda!
Dialogue: 0,0:21:25.57,0:21:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:21:28.24,0:21:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa kau biarkan benda terkutuk
Dialogue: 0,0:21:29.74,0:21:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kabur dari tempat ini?
Dialogue: 0,0:21:31.75,0:21:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau pikirkan?
Dialogue: 0,0:21:34.16,0:21:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:21:38.21,0:21:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kena masalah lagi.
Dialogue: 0,0:21:41.55,0:21:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tidak memikirkan
Dialogue: 0,0:21:44.47,0:21:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kakak seperguruanku dari 900 tahun lalu.
Dialogue: 0,0:21:48.76,0:21:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak seperguruanku?
Dialogue: 0,0:21:50.10,0:21:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil!
Dialogue: 0,0:21:54.18,0:21:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada masalah?
Dialogue: 0,0:21:56.10,0:21:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao?
Dialogue: 0,0:21:57.90,0:21:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:22:09.12,0:22:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menara Asakusa…
Dialogue: 0,0:22:11.20,0:22:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, kita tidak akan bisa mengadakan\Npertunjukan di sini untuk sementara.
Dialogue: 0,0:22:15.66,0:22:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku tahu.
Dialogue: 0,0:22:17.62,0:22:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan pergi ke Osaka.
Dialogue: 0,0:22:19.25,0:22:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkemaslah, semuanya!
Dialogue: 0,0:22:21.38,0:22:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah di sini?
Dialogue: 0,0:22:22.92,0:22:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gadis Ular.\N- Ya, Bos.
Dialogue: 0,0:22:25.26,0:22:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Manusia Iblis.\N- Hadir, Bos.
Dialogue: 0,0:22:27.51,0:22:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Samurai Tiga Sentimeter.\N- Hadir.
Dialogue: 0,0:22:29.80,0:22:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master Kepala Berapi.
Dialogue: 0,0:22:32.35,0:22:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master Kepala Berapi?
Dialogue: 0,0:22:36.35,0:22:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master Kepala Berapi, kau di sini?
Dialogue: 0,0:22:39.31,0:22:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhenti.
Dialogue: 0,0:22:40.65,0:22:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti?
Dialogue: 0,0:22:42.19,0:22:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Dia bilang tengkoraknya yang terlatih\Nmelarikan diri.
Dialogue: 0,0:22:46.99,0:22:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:47.99,0:22:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bukankah itu
Dialogue: 0,0:22:50.66,0:22:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya properti?
Dialogue: 0,0:23:13.76,0:23:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, gara-gara Byoki itu bisnis jadi sepi.
Dialogue: 0,0:24:49.36,0:24:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryounkaku?
Dialogue: 0,0:24:50.69,0:24:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita melewatinya\Nsaat tiba di Ibu Kota Kekaisaran.
Dialogue: 0,0:24:53.41,0:24:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bangunan yang megah.
Dialogue: 0,0:24:55.07,0:24:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:24:56.33,0:24:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau begitulah menurutku, tapi kau…
Dialogue: 0,0:24:58.20,0:24:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang itu…
Dialogue: 0,0:24:59.45,0:25:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Pedang Hagunsei, bukan?
Dialogue: 0,0:25:01.54,0:25:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Dia mati?
Dialogue: 0,0:25:03.21,0:25:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mewarisi banyak kutukan rahasia,
Dialogue: 0,0:25:06.46,0:25:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penting untuk tahu cara menyalurkan
Dialogue: 0,0:25:08.92,0:25:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}energi dari emosi gelap.
Dialogue: 0,0:25:11.38,0:25:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu artinya Mao akan menjadi suamiku.
Dialogue: 0,0:25:14.68,0:25:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Hyakka".
