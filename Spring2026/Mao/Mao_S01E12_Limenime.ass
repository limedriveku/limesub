Dialogue: 0,0:02:56.92,0:03:01.81,sign,,0000,0000,0000,,"SHIRANUI"
Dialogue: 0,0:04:00.03,0:04:03.28,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:05:17.77,0:05:21.07,sign,,0000,0000,0000,,PENYIHIR AIR
Dialogue: 0,0:05:29.28,0:05:30.74,sign,,0000,0000,0000,,"MAO"
Dialogue: 0,0:05:33.37,0:05:34.29,sign,,0000,0000,0000,,"GURU KLAN GOKO"
Dialogue: 0,0:06:44.44,0:06:47.03,sign,,0000,0000,0000,,MASAGO
Dialogue: 0,0:07:54.85,0:07:57.39,sign,,0000,0000,0000,,"HYAKKA"
Dialogue: 0,0:08:03.98,0:08:05.56,sign,,0000,0000,0000,,"KIBA NANOKA"
Dialogue: 0,0:08:36.79,0:08:38.22,sign,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:09:35.03,0:09:36.20,sign,,0000,0000,0000,,"KAMON"
Dialogue: 0,0:14:40.92,0:14:43.92,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:15:32.34,0:15:34.47,sign,,0000,0000,0000,,BENIKO
Dialogue: 0,0:16:04.71,0:16:07.21,sign,,0000,0000,0000,,"YURAKO"
Dialogue: 0,0:16:37.99,0:16:39.79,sign,,0000,0000,0000,,JALAN PERBELANJAAN KELIMA
Dialogue: 0,0:17:16.45,0:17:19.03,sign,,0000,0000,0000,,BYOKI
Dialogue: 0,0:18:32.15,0:18:34.23,sign,,0000,0000,0000,,UOZUMI FUNA
Dialogue: 0,0:20:14.79,0:20:15.84,sign,,0000,0000,0000,,"SHIRAHA"
Dialogue: 0,0:24:49.03,0:24:49.86,sign,,0000,0000,0000,,SELANJUTNYA
Dialogue: 0,0:00:20.39,0:00:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka...
Dialogue: 0,0:00:22.43,0:00:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak yang ingin kuajarkan kepadamu.
Dialogue: 0,0:00:28.40,0:00:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao?
Dialogue: 0,0:00:30.65,0:00:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao?
Dialogue: 0,0:00:33.57,0:00:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:00:35.49,0:00:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao... Hei! Jangan!
Dialogue: 0,0:00:38.20,0:00:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tinggalkan aku!
Dialogue: 0,0:00:39.66,0:00:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa-apa!
Dialogue: 0,0:00:42.75,0:00:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melakukan apa pun sendirian.
Dialogue: 0,0:00:45.00,0:00:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon... Ayolah, Mao!
Dialogue: 0,0:00:47.25,0:00:49.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak... Jangan mati!
Dialogue: 0,0:00:49.63,0:00:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Tidak! Tidak!
Dialogue: 0,0:00:51.17,0:00:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:00:52.97,0:00:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:00:59.01,0:00:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:01:04.59,0:01:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:01:07.06,0:01:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa pusing.
Dialogue: 0,0:01:26.08,0:01:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka Tuan Mao
Dialogue: 0,0:01:28.17,0:01:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai sembuh.
Dialogue: 0,0:01:36.05,0:01:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:01:41.72,0:01:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya darahmu
Dialogue: 0,0:01:44.31,0:01:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku tetap hidup, entah bagaimana.
Dialogue: 0,0:01:48.19,0:01:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya itu yang terjadi.
Dialogue: 0,0:01:51.27,0:01:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darahku
Dialogue: 0,0:01:53.53,0:01:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama seperti darah Mao.
Dialogue: 0,0:01:55.78,0:01:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikutuk oleh Byoki itu.
Dialogue: 0,0:01:59.32,0:02:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku senang Mao masih hidup.
Dialogue: 0,0:02:04.79,0:02:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melawan murid senior\Nyang merupakan Penyihir Air.
Dialogue: 0,0:02:10.83,0:02:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air ada di sekeliling kita.
Dialogue: 0,0:02:13.92,0:02:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah mereka mengawasiku melalui air?
Dialogue: 0,0:02:18.01,0:02:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:02:19.72,0:02:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawamu ke ibu kota.
Dialogue: 0,0:02:22.26,0:02:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubawa kau ke ibu kota.
Dialogue: 0,0:02:26.02,0:02:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak datang langsung?
Dialogue: 0,0:02:30.40,0:02:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang mencegah mereka\Nmeninggalkan ibu kota?
Dialogue: 0,0:02:38.49,0:02:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra dan pewarisku yang berharga
Dialogue: 0,0:02:40.82,0:02:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jatuh sakit parah\Ndan para dokter pun menyerah.
Dialogue: 0,0:02:44.16,0:02:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku kehabisan akal,\Naku mendengar rumor tentangmu.
Dialogue: 0,0:02:48.50,0:02:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyadari onmyoji Klan Goko\Nadalah harapan terakhirku.
Dialogue: 0,0:02:53.25,0:02:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membayar berapa pun.
Dialogue: 0,0:02:56.92,0:03:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjaga kehidupan adalah tugas Klan Goko.
Dialogue: 0,0:03:02.05,0:03:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyelamatkan putramu.
Dialogue: 0,0:03:06.43,0:03:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tenangkan pikiranmu.
Dialogue: 0,0:03:08.81,0:03:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah... Karisma yang sangat istimewa.
Dialogue: 0,0:03:18.86,0:03:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Shiranui.
Dialogue: 0,0:03:20.49,0:03:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada lagi yang muncul di cermin air.
Dialogue: 0,0:03:23.57,0:03:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kalian gagal lagi?
Dialogue: 0,0:03:30.08,0:03:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian, shikigami
Dialogue: 0,0:03:32.04,0:03:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat tidak berguna.
Dialogue: 0,0:03:40.55,0:03:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:03:42.13,0:03:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar bertemu denganmu lagi.
Dialogue: 0,0:05:22.99,0:05:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mau ke mana hari ini, Tuan?
Dialogue: 0,0:05:25.82,0:05:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan melihat keadaan di Pantai Utara.
Dialogue: 0,0:05:29.28,0:05:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantai Utara...
Dialogue: 0,0:05:30.99,0:05:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sanalah Penyihir Air berlatih.
Dialogue: 0,0:05:33.37,0:05:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:34.37,0:05:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, sebaiknya kau mengamati mereka.
Dialogue: 0,0:05:38.08,0:05:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Guru.
Dialogue: 0,0:06:09.66,0:06:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:06:16.37,0:06:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru...
Dialogue: 0,0:06:19.04,0:06:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru...
Dialogue: 0,0:06:22.54,0:06:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang merapal mantra itu?
Dialogue: 0,0:06:27.05,0:06:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perapalnya adalah Masago?
Dialogue: 0,0:06:49.36,0:06:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita?
Dialogue: 0,0:06:59.50,0:07:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, Masago.
Dialogue: 0,0:07:10.05,0:07:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengenalmu.
Dialogue: 0,0:07:11.64,0:07:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu Mao?
Dialogue: 0,0:07:13.18,0:07:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku baru saja tiba di kediaman ini.
Dialogue: 0,0:07:16.77,0:07:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:07:18.14,0:07:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:07:19.64,0:07:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau sudah diizinkan\Nmenemani Guru berkeliling.
Dialogue: 0,0:07:28.19,0:07:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah selagi bisa.
Dialogue: 0,0:07:30.03,0:07:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:31.91,0:07:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tinggal di sini cukup lama,\Nkau akan mengerti alasannya.
Dialogue: 0,0:07:36.16,0:07:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!
Dialogue: 0,0:07:38.50,0:07:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak berbakat!
Dialogue: 0,0:07:41.04,0:07:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti saja!
Dialogue: 0,0:07:44.17,0:07:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Guru!
Dialogue: 0,0:07:48.59,0:07:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempat yang kejam.
Dialogue: 0,0:07:53.26,0:07:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara Penyihir Air,
Dialogue: 0,0:07:54.85,0:07:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masago adalah yang terkuat,
Dialogue: 0,0:07:57.47,0:07:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan?
Dialogue: 0,0:07:59.52,0:08:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga berpikir begitu, Hyakka?
Dialogue: 0,0:08:02.19,0:08:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:03.98,0:08:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia wanita, tapi...
Dialogue: 0,0:08:06.02,0:08:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika ada yang layak dipanggil ke Goshikido,
Dialogue: 0,0:08:08.28,0:08:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada penyihir\Nyang lebih hebat dari Masago.
Dialogue: 0,0:08:12.20,0:08:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, entah kenapa,\Ncaraku diserang sekarang
Dialogue: 0,0:08:16.07,0:08:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak cocok dengan Masago yang kukenal.
Dialogue: 0,0:08:19.29,0:08:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin hidup selama ratusan tahun\Nmengubah seseorang?
Dialogue: 0,0:08:24.50,0:08:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, makan!
Dialogue: 0,0:08:26.63,0:08:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa udon?
Dialogue: 0,0:08:28.30,0:08:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertunjukanku berikutnya.
Dialogue: 0,0:08:31.17,0:08:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua pertunjukanku dahulu\Nberdasar pada api.
Dialogue: 0,0:08:34.42,0:08:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu tidak berjalan lancar\Nbelakangan ini.
Dialogue: 0,0:08:36.79,0:08:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang masih trauma
Dialogue: 0,0:08:38.30,0:08:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan gempa bumi dan kebakaran.
Dialogue: 0,0:08:41.05,0:08:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:08:42.14,0:08:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selamat makan.
Dialogue: 0,0:08:43.69,0:08:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah! Katakan bagaimana rasanya.
Dialogue: 0,0:08:58.24,0:09:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kapan kau akan mulai makan?
Dialogue: 0,0:09:00.79,0:09:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku seperti kucing,\Ntak tahan makanan panas.
Dialogue: 0,0:09:03.12,0:09:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kau lamban sekali.
Dialogue: 0,0:09:08.09,0:09:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga, Mao?
Dialogue: 0,0:09:10.38,0:09:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:09:27.06,0:09:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mendapatkan akses\Nke keluarga kaya yang putrinya hampir mati
Dialogue: 0,0:09:30.57,0:09:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan meyakinkan bahwa mereka\Nbisa memperpanjang umurnya.
Dialogue: 0,0:09:35.03,0:09:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sayangnya
Dialogue: 0,0:09:36.28,0:09:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal itu mudah ketahuan.
Dialogue: 0,0:09:39.49,0:09:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengaku sebagai anggota Klan Goko,
Dialogue: 0,0:09:41.16,0:09:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka menjajakan\Nmantra kasar mereka ke kelas atas.
Dialogue: 0,0:09:47.96,0:09:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu mungkin Penyihir Air.
Dialogue: 0,0:09:52.09,0:09:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu benar, mungkinkah...
Dialogue: 0,0:09:54.59,0:09:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masago?
Dialogue: 0,0:10:03.47,0:10:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Shiranui.
Dialogue: 0,0:10:05.18,0:10:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang pengunjung telah muncul\Ndi cermin air.
Dialogue: 0,0:10:14.61,0:10:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini...
Dialogue: 0,0:10:23.62,0:10:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kata Tuan...
Dialogue: 0,0:10:26.46,0:10:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun yang selamat\Ndari pertarungan kutukan mematikan
Dialogue: 0,0:10:28.50,0:10:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan yang terakhir bertahan,\Nadalah penerus sejati.
Dialogue: 0,0:10:33.42,0:10:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Mao, sang tumbal, masih hidup.
Dialogue: 0,0:10:37.09,0:10:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:10:38.93,0:10:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon, kenapa kau masih hidup?
Dialogue: 0,0:10:43.81,0:10:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang ingin kuketahui.
Dialogue: 0,0:10:52.69,0:10:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang! Terima kasih sudah datang.
Dialogue: 0,0:10:55.32,0:10:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kuchinawa...\NMereka memanggilmu begitu?
Dialogue: 0,0:11:02.07,0:11:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan Masago.
Dialogue: 0,0:11:10.08,0:11:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ekspresimu begitu?
Dialogue: 0,0:11:12.67,0:11:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kuchinawa, kau adalah...
Dialogue: 0,0:11:15.75,0:11:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon, bukan?
Dialogue: 0,0:11:22.64,0:11:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh...
Dialogue: 0,0:11:24.05,0:11:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir bisa masuk ke dalam perangkapku?
Dialogue: 0,0:11:42.78,0:11:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa
Dialogue: 0,0:11:44.58,0:11:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau?
Dialogue: 0,0:11:47.41,0:11:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tak ingat, tak masalah bagiku.
Dialogue: 0,0:11:51.67,0:11:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal kau tahu saja.
Dialogue: 0,0:11:53.17,0:11:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuhan
Dialogue: 0,0:11:55.21,0:11:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum berakhir!
Dialogue: 0,0:12:13.73,0:12:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah dia orang itu?
Dialogue: 0,0:12:17.44,0:12:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon, aku ingin herba obat\Nyang akan menghentikan pendarahan.
Dialogue: 0,0:12:21.86,0:12:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau terluka, Masago?
Dialogue: 0,0:12:24.74,0:12:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan untukku.
Dialogue: 0,0:12:26.53,0:12:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu murid junior\Nterlalu memaksakan diri selama latihan.
Dialogue: 0,0:12:32.04,0:12:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Nona Masago.
Dialogue: 0,0:12:37.79,0:12:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang terjadi saat seseorang\Nmencoba menggunakan mantra
Dialogue: 0,0:12:40.17,0:12:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di luar kemampuannya.
Dialogue: 0,0:12:42.05,0:12:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia diam-diam melihat teknikku
Dialogue: 0,0:12:44.05,0:12:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mencoba menirunya.
Dialogue: 0,0:12:46.26,0:12:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, keluarkan dia.
Dialogue: 0,0:12:48.14,0:12:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melakukan itu.
Dialogue: 0,0:12:51.56,0:12:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masago selalu menjaga murid junior\Nyang putus asa itu.
Dialogue: 0,0:13:08.41,0:13:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa namanya?
Dialogue: 0,0:13:10.62,0:13:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat sekarang. Kalau tidak salah...
Dialogue: 0,0:13:13.75,0:13:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui.
Dialogue: 0,0:13:49.91,0:13:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Shiranui.
Dialogue: 0,0:13:51.79,0:13:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih hidup di era ini\Nhanya bisa berarti...
Dialogue: 0,0:13:57.42,0:13:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau
Dialogue: 0,0:13:58.88,0:14:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipanggil ke Goshikido?
Dialogue: 0,0:14:02.75,0:14:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau?
Dialogue: 0,0:14:04.05,0:14:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada yang dipanggil, seharusnya Masago.
Dialogue: 0,0:14:06.51,0:14:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar putus asa saat itu.
Dialogue: 0,0:14:09.93,0:14:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan diriku yang dahulu.
Dialogue: 0,0:14:13.02,0:14:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum berubah.
Dialogue: 0,0:14:15.10,0:14:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sekarang,
Dialogue: 0,0:14:17.48,0:14:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau hanya bisa merapal mantra\Nperpanjangan umur setengah jadi.
Dialogue: 0,0:14:21.94,0:14:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:14:22.90,0:14:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau berkeliaran menggunakan nama Klan Goko.
Dialogue: 0,0:14:25.53,0:14:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:14:28.20,0:14:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah.
Dialogue: 0,0:14:45.05,0:14:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah.
Dialogue: 0,0:15:41.56,0:15:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kamon.
Dialogue: 0,0:15:43.81,0:15:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau terluka?
Dialogue: 0,0:15:45.52,0:15:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sudah kubalas berlipat ganda.
Dialogue: 0,0:15:48.69,0:15:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ada apa dengan kaki Shiranui?
Dialogue: 0,0:15:54.87,0:15:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Aku gagal membunuhnya.
Dialogue: 0,0:15:58.25,0:15:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Kakak?
Dialogue: 0,0:16:01.96,0:16:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alih-alih terkurung\Ndi dalam penghalang ini,
Dialogue: 0,0:16:04.71,0:16:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari kita pergi ke Ibu Kota Kekaisaran.
Dialogue: 0,0:16:08.21,0:16:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai semudah itu...
Dialogue: 0,0:16:10.55,0:16:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang mudah.
Dialogue: 0,0:16:12.26,0:16:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang berkuasa di mana-mana\Nyang tidak ingin mati.
Dialogue: 0,0:16:18.10,0:16:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:16:20.06,0:16:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga ingin bertemu Mao.
Dialogue: 0,0:16:23.69,0:16:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao yang kulihat di cermin air
Dialogue: 0,0:16:26.23,0:16:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah berubah sejak saat itu,
Dialogue: 0,0:16:29.78,0:16:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku ingin bertemu Mao lagi.
Dialogue: 0,0:16:42.71,0:16:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali ke sisi ini.
Dialogue: 0,0:16:45.54,0:16:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika dia diserang seperti itu lagi...
Dialogue: 0,0:16:48.84,0:16:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya darahmu
Dialogue: 0,0:16:51.30,0:16:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku tetap hidup, entah bagaimana.
Dialogue: 0,0:16:55.97,0:16:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus selalu berada di sisinya.
Dialogue: 0,0:17:07.60,0:17:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak... Apa aku semacam kantong darah?
Dialogue: 0,0:17:10.81,0:17:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin hubungan kami\Nmenjadi seperti itu.
Dialogue: 0,0:17:27.50,0:17:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya sedang apa?
Dialogue: 0,0:17:29.88,0:17:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membuat guci kodoku baru.
Dialogue: 0,0:17:34.01,0:17:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guci kodoku yang menopang hidupku\Nsampai sekarang
Dialogue: 0,0:17:37.26,0:17:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah hancur.
Dialogue: 0,0:17:39.68,0:17:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ramuan berharga yang dibuat Otoya\Nselama berabad-abad, tapi...
Dialogue: 0,0:17:43.48,0:17:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya seperti resep rahasia.
Dialogue: 0,0:17:45.31,0:17:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus terus menambahkannya.
Dialogue: 0,0:17:47.35,0:17:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh 49 hari sampai kodoku pertama siap.
Dialogue: 0,0:17:55.99,0:17:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tubuhmu akan baik-baik saja\Nsampai saat itu, Tuan Mao?
Dialogue: 0,0:17:59.49,0:18:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk saat ini, ya.
Dialogue: 0,0:18:02.12,0:18:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah,
Dialogue: 0,0:18:04.04,0:18:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak saat itu...
Dialogue: 0,0:18:05.91,0:18:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah darah Nanoka mengalir ke tubuhku
Dialogue: 0,0:18:09.59,0:18:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan lukaku sembuh...
Dialogue: 0,0:18:15.05,0:18:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka...
Dialogue: 0,0:18:16.76,0:18:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipenuhi kekuatan.
Dialogue: 0,0:18:20.35,0:18:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena darah kami memiliki\Nkutukan Byoki yang sama?
Dialogue: 0,0:18:46.41,0:18:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga...
Dialogue: 0,0:18:48.58,0:18:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao memberiku batu pelindung ini.
Dialogue: 0,0:18:51.04,0:18:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang ini akan melindungiku\Ndari kejahatan.
Dialogue: 0,0:18:55.46,0:18:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lupa memakainya.
Dialogue: 0,0:19:05.72,0:19:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka!
Dialogue: 0,0:19:12.98,0:19:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki...
Dialogue: 0,0:19:15.69,0:19:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukanmu...
Dialogue: 0,0:19:22.03,0:19:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak... Bagaimana?
Dialogue: 0,0:19:25.16,0:19:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecuali dia mengambil kembali tubuh\Nyang menyatu dengan Mao,
Dialogue: 0,0:19:28.37,0:19:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu seharusnya\Ntidak bisa pindah ke tubuhku
Dialogue: 0,0:19:30.75,0:19:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai wadah barunya.
Dialogue: 0,0:19:33.59,0:19:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa?
Dialogue: 0,0:19:41.05,0:19:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia inginkan dariku?
Dialogue: 0,0:19:50.35,0:19:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:19:51.81,0:19:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:19:55.36,0:19:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku, Mao!
Dialogue: 0,0:20:14.79,0:20:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka?
Dialogue: 0,0:20:28.72,0:20:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:42.99,0:20:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku aman sekarang.
Dialogue: 0,0:20:45.87,0:20:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pulang.
Dialogue: 0,0:21:02.38,0:21:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:21:08.43,0:21:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku tidak mau bergerak!
Dialogue: 0,0:21:14.48,0:21:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih bisa kembali sekarang.
Dialogue: 0,0:21:20.57,0:21:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau terus menyerahkan dirimu\Nkepada Mao,
Dialogue: 0,0:21:24.95,0:21:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan...
Dialogue: 0,0:21:35.46,0:21:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uozumi!
Dialogue: 0,0:21:39.29,0:21:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:21:42.26,0:21:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hilang.
Dialogue: 0,0:21:48.10,0:21:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya luka Byoki itu\Nmasih belum sembuh.
Dialogue: 0,0:21:51.64,0:21:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,\Naku bisa menembus penghalangnya.
Dialogue: 0,0:21:55.73,0:21:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Uozumi.
Dialogue: 0,0:21:58.81,0:22:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:22:01.48,0:22:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat takut.
Dialogue: 0,0:22:04.19,0:22:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dilakukannya padamu?
Dialogue: 0,0:22:06.53,0:22:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:22:08.49,0:22:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:22:10.70,0:22:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau terus menyerahkan dirimu\Nkepada Mao,
Dialogue: 0,0:22:15.16,0:22:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan...
Dialogue: 0,0:22:17.12,0:22:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa
Dialogue: 0,0:22:19.17,0:22:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maksudnya?
Dialogue: 0,0:22:27.72,0:22:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Mao, apa rencananya sekarang?
Dialogue: 0,0:22:31.68,0:22:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan ke Kyoto\Nuntuk membunuh murid senior
Dialogue: 0,0:22:34.47,0:22:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang merupakan Penyihir Air?
Dialogue: 0,0:22:36.31,0:22:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku tidak tertarik membunuh.
Dialogue: 0,0:22:40.40,0:22:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku ingin jawaban.
Dialogue: 0,0:22:44.28,0:22:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu, saat kediaman itu terbakar...
Dialogue: 0,0:22:47.32,0:22:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi hari itu?
Dialogue: 0,0:22:51.07,0:22:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku sungguh membunuh Nona Sana?
Dialogue: 0,0:22:58.96,0:23:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawaban?
Dialogue: 0,0:23:00.38,0:23:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, mereka datang untuk membunuhmu!
Dialogue: 0,0:23:02.59,0:23:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu lembut hati.
Dialogue: 0,0:23:06.17,0:23:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelah.
Dialogue: 0,0:23:08.63,0:23:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, boleh aku tidur di sini?
Dialogue: 0,0:23:11.26,0:23:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:23:13.26,0:23:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon...
Dialogue: 0,0:24:49.94,0:24:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memberi tahu Mao\Nbahwa aku bertemu Byoki itu.
Dialogue: 0,0:24:52.82,0:24:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Byoki itu muncul di hadapan Nanoka\Nuntuk memperingatkannya?
Dialogue: 0,0:24:56.70,0:24:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi ke wastu itu.
Dialogue: 0,0:24:59.41,0:25:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:25:01.00,0:25:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keluarga yang belum pernah kulihat\Ntinggal di sana
Dialogue: 0,0:25:03.42,0:25:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mereka menolakku dengan sopan.
Dialogue: 0,0:25:05.08,0:25:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa Nona Sana?
Dialogue: 0,0:25:08.00,0:25:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untukmu.
Dialogue: 0,0:25:09.25,0:25:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Natal!
Dialogue: 0,0:25:10.80,0:25:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya sesuatu untukmu.
Dialogue: 0,0:25:14.34,0:25:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Byoki".
