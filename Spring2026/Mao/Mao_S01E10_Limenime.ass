Dialogue: 0,0:00:45.21,0:00:46.33,sign,,0000,0000,0000,,"KIBA NANOKA, MAO"
Dialogue: 0,0:01:31.55,0:01:32.59,sign,,0000,0000,0000,,"HYAKKA"
Dialogue: 0,0:01:59.36,0:02:00.20,sign,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:03:32.29,0:03:35.42,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:04:49.87,0:04:53.04,sign,,0000,0000,0000,,TAIZANFUKUN
Dialogue: 0,0:05:24.57,0:05:26.15,sign,,0000,0000,0000,,"BYOKI"
Dialogue: 0,0:05:39.08,0:05:40.34,sign,,0000,0000,0000,,"TAIZANFUKUN"
Dialogue: 0,0:06:53.62,0:06:55.20,sign,,0000,0000,0000,,"HARUKA, HITOMI, NAKAGAWA YUI"
Dialogue: 0,0:07:04.38,0:07:05.30,sign,,0000,0000,0000,,"SHIRAHA"
Dialogue: 0,0:07:07.01,0:07:08.67,sign,,0000,0000,0000,,"DEMOKRASI TAISHO"
Dialogue: 0,0:10:55.32,0:10:58.87,sign,,0000,0000,0000,,"MOKUZU"
Dialogue: 0,0:14:11.68,0:14:15.10,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:14:46.09,0:14:47.47,sign,,0000,0000,0000,,"HAIMARU, NONA SANA"
Dialogue: 0,0:15:24.77,0:15:25.55,sign,,0000,0000,0000,,RASANYA SEOLAH-OLAH ADA YANG MENGAWASIKU
Dialogue: 0,0:20:16.71,0:20:17.84,sign,,0000,0000,0000,,"TAIZANFUKUN"
Dialogue: 0,0:24:56.58,0:24:57.66,sign,,0000,0000,0000,,KAMON, BENIKO
Dialogue: 0,0:25:13.97,0:25:14.46,sign,,0000,0000,0000,,SELANJUTNYA
Dialogue: 0,0:00:20.18,0:00:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan baik-baik saja, Nanoka.
Dialogue: 0,0:00:21.98,0:00:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berada di sisimu.
Dialogue: 0,0:00:23.89,0:00:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:00:27.56,0:00:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:00:29.73,0:00:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa!\NAku takut!
Dialogue: 0,0:00:31.19,0:00:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan!
Dialogue: 0,0:00:34.99,0:00:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:00:36.41,0:00:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa.\NCoba lagi.
Dialogue: 0,0:00:41.25,0:00:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:00:45.21,0:00:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awasi dia.
Dialogue: 0,0:00:46.42,0:00:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokuskan energimu
Dialogue: 0,0:00:47.33,0:00:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bidik tanden-nya.
Dialogue: 0,0:00:49.09,0:00:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dorong!
Dialogue: 0,0:00:56.26,0:00:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kembali menjadi manusia.
Dialogue: 0,0:00:58.18,0:01:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air?\NKe mana perginya?
Dialogue: 0,0:01:00.35,0:01:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:01:02.10,0:01:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, satu lagi.
Dialogue: 0,0:01:03.60,0:01:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:01:08.44,0:01:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, Nanoka.\NTeruskan seperti itu.
Dialogue: 0,0:01:10.77,0:01:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!\NMao, tetaplah di sisiku, ya?
Dialogue: 0,0:01:13.32,0:01:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tinggalkan aku!
Dialogue: 0,0:01:15.40,0:01:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana dia pergi?
Dialogue: 0,0:01:21.70,0:01:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air yang dia muntahkan melarikan diri.
Dialogue: 0,0:01:24.37,0:01:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana perginya?
Dialogue: 0,0:01:31.55,0:01:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mereka!
Dialogue: 0,0:01:32.67,0:01:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shikigami itu sumber dari semua ini!
Dialogue: 0,0:01:35.59,0:01:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kabur!
Dialogue: 0,0:01:50.44,0:01:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NMereka tidak berubah!
Dialogue: 0,0:01:52.57,0:01:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NMenakutkan sekali!
Dialogue: 0,0:01:54.40,0:01:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sudah cukup.
Dialogue: 0,0:01:57.11,0:01:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan gadis itu?
Dialogue: 0,0:01:59.36,0:02:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka
Dialogue: 0,0:02:00.28,0:02:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya petarung yang cukup hebat.
Dialogue: 0,0:02:04.75,0:02:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:02:07.21,0:02:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kau,
Dialogue: 0,0:02:08.91,0:02:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}shikigami itu memuntahkan jimat terkutuknya.
Dialogue: 0,0:02:14.46,0:02:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tulisannya?
Dialogue: 0,0:02:16.55,0:02:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin itu perintah untuk\Nmemburu dan membunuh kita, bukan?
Dialogue: 0,0:02:22.64,0:02:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kulihat?
Dialogue: 0,0:02:23.85,0:02:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jika Mao masih hidup,
Dialogue: 0,0:02:25.68,0:02:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tangkap dia hidup-hidup\Ndan bawa dia kepadaku."
Dialogue: 0,0:02:27.89,0:02:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tulisannya.
Dialogue: 0,0:02:28.94,0:02:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Hanya Mao?
Dialogue: 0,0:02:30.27,0:02:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganku?
Dialogue: 0,0:02:31.31,0:02:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung mereka tidak menginginkanmu.
Dialogue: 0,0:02:33.82,0:02:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak cocok melawan mantra Air.
Dialogue: 0,0:02:35.94,0:02:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:02:38.95,0:02:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:02:40.86,0:02:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya. Kuas.
Dialogue: 0,0:02:42.24,0:02:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:02:46.33,0:02:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao?
Dialogue: 0,0:02:50.21,0:02:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telan ini.
Dialogue: 0,0:02:53.42,0:02:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali kepada tuanmu.
Dialogue: 0,0:02:55.09,0:02:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:03:00.26,0:03:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membiarkan mereka pergi?
Dialogue: 0,0:03:01.97,0:03:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kita menghancurkan shikigami di sini,
Dialogue: 0,0:03:04.26,0:03:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku punya firasat yang lain\Nakan terus berdatangan.
Dialogue: 0,0:03:07.10,0:03:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa melanjutkan ini.
Dialogue: 0,0:03:09.18,0:03:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:03:10.19,0:03:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perut bagian bawahku sakit…
Dialogue: 0,0:03:12.69,0:03:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya
Dialogue: 0,0:03:15.15,0:03:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah memasang perangkap.
Dialogue: 0,0:04:54.33,0:04:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum gempa bumi besar terjadi,
Dialogue: 0,0:04:56.38,0:04:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu bersembunyi di lubang ini.
Dialogue: 0,0:04:58.84,0:05:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para shikigami itu
Dialogue: 0,0:05:00.34,0:05:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diperintahkan untuk menangkapku hidup-hidup.
Dialogue: 0,0:05:04.13,0:05:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan untuk membunuhku.
Dialogue: 0,0:05:06.30,0:05:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya seseorang\Ningin bertemu denganmu.
Dialogue: 0,0:05:08.55,0:05:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu
Dialogue: 0,0:05:09.89,0:05:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}undangan yang cukup kasar.
Dialogue: 0,0:05:12.22,0:05:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka tidak ingin\Nmengobrol dengan tenang.
Dialogue: 0,0:05:15.35,0:05:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun yang mengendalikan\Nshikigami itu tidak mengincarku,
Dialogue: 0,0:05:18.48,0:05:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kemungkinan besar Byoki itu.
Dialogue: 0,0:05:19.86,0:05:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:20.77,0:05:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih spesifik,
Dialogue: 0,0:05:22.90,0:05:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mengincar mantra
Dialogue: 0,0:05:24.57,0:05:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari gulungan rahasia yang dilahap Byoki.
Dialogue: 0,0:05:26.66,0:05:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra rahasia Taizanfukun?
Dialogue: 0,0:05:30.28,0:05:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taiza apa?
Dialogue: 0,0:05:32.66,0:05:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra untuk memanipulasi umur manusia.
Dialogue: 0,0:05:35.25,0:05:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seni rahasia tertinggi Onmyodo.
Dialogue: 0,0:05:38.17,0:05:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Taizanfukun.
Dialogue: 0,0:05:39.08,0:05:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Taizanfukun.
Dialogue: 0,0:05:40.96,0:05:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu sebutannya?
Dialogue: 0,0:05:43.51,0:05:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka, kau percaya aku bekerja sama\Ndengan Byoki itu, bukan?
Dialogue: 0,0:05:47.93,0:05:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:49.01,0:05:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum lupa!
Dialogue: 0,0:05:50.72,0:05:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar lupa.
Dialogue: 0,0:05:52.26,0:05:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia meminta bantuan kita.
Dialogue: 0,0:05:54.31,0:05:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya orang lain\Nmemikirkan hal yang sama.
Dialogue: 0,0:05:58.77,0:06:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk siapa pun dalang serangan ini.
Dialogue: 0,0:06:01.23,0:06:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya\Nkita memancing mereka kepada kita.
Dialogue: 0,0:06:03.86,0:06:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti, jadi ini jebakan…
Dialogue: 0,0:06:06.90,0:06:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kau memberi\Nshikigami itu perintah baru?
Dialogue: 0,0:06:10.99,0:06:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:12.08,0:06:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau tulis?
Dialogue: 0,0:06:14.04,0:06:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kami menemukan Mao,\Ntapi dia menolak ditangkap.
Dialogue: 0,0:06:17.46,0:06:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya bisa menahannya di satu lokasi.
Dialogue: 0,0:06:21.08,0:06:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan, kami ingin kau pergi ke sana sendiri."
Dialogue: 0,0:06:26.01,0:06:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:27.22,0:06:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:06:28.51,0:06:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:06:42.77,0:06:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu paus?
Dialogue: 0,0:06:43.77,0:06:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu tampak jauh lebih aneh!
Dialogue: 0,0:06:48.11,0:06:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaanmu hari ini, Nanoka?
Dialogue: 0,0:06:51.28,0:06:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini catatan dari kelas yang kau lewatkan.
Dialogue: 0,0:06:53.62,0:06:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencatat untukmu, untuk berjaga-jaga.
Dialogue: 0,0:06:55.29,0:06:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:06:56.29,0:06:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat membantu!
Dialogue: 0,0:06:57.75,0:07:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung kita SMP dan SMA terintegrasi.
Dialogue: 0,0:07:00.29,0:07:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu belajar untuk ujian masuk.
Dialogue: 0,0:07:02.04,0:07:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua baik sekali!
Dialogue: 0,0:07:04.38,0:07:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Nanoka,
Dialogue: 0,0:07:05.38,0:07:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagian itu akan diuji.
Dialogue: 0,0:07:07.01,0:07:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Era Taisho menunjukkan…
Dialogue: 0,0:07:09.34,0:07:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan dengan mereka, Mao sangat…
Dialogue: 0,0:07:12.55,0:07:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh beberapa hari\Nsebelum tuan shikigami itu tiba di sini.
Dialogue: 0,0:07:16.31,0:07:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan kau pulang,
Dialogue: 0,0:07:18.43,0:07:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku ingin kau kembali\Nke sini secepatnya.
Dialogue: 0,0:07:21.19,0:07:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau
Dialogue: 0,0:07:22.98,0:07:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyuruhku bertarung bersamamu?
Dialogue: 0,0:07:26.40,0:07:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.\NKau harus mendapatkan pengalaman.
Dialogue: 0,0:07:30.40,0:07:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu sama sekali tidak berniat
Dialogue: 0,0:07:32.78,0:07:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melindungi gadis lemah sepertiku.
Dialogue: 0,0:07:38.54,0:07:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu agak menyakiti perasaanku.
Dialogue: 0,0:07:41.25,0:07:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuputuskan.\NAku akan cuti selama beberapa hari.
Dialogue: 0,0:07:46.25,0:07:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:07:47.55,0:07:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan meminta Shiraha\Nmencari tahu soal mantra Taizan
Dialogue: 0,0:07:50.88,0:07:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dibicarakan Mao.
Dialogue: 0,0:07:55.55,0:07:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada apa
Dialogue: 0,0:07:57.85,0:07:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan Nanoka?
Dialogue: 0,0:07:59.85,0:08:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit menjelaskannya.
Dialogue: 0,0:08:02.19,0:08:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sepertiku.\NKami berdua dikutuk oleh Byoki.
Dialogue: 0,0:08:06.40,0:08:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikutuk, ya?
Dialogue: 0,0:08:08.23,0:08:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu merasuki tubuh manusia\Nsebagai wadah,
Dialogue: 0,0:08:10.36,0:08:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berpindah dari satu inang ke inang lain.
Dialogue: 0,0:08:12.03,0:08:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka diincar\Nsebagai wadah barunya setelah aku.
Dialogue: 0,0:08:16.95,0:08:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu melarikan diri ke dunia Nanoka.
Dialogue: 0,0:08:21.29,0:08:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku ingin mengajarinya\Ncara bertarung
Dialogue: 0,0:08:24.25,0:08:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar dia bisa melindungi dirinya\Nbahkan saat sendirian.
Dialogue: 0,0:08:26.92,0:08:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:08:28.05,0:08:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh tidak mengerti.
Dialogue: 0,0:08:29.59,0:08:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:08:31.38,0:08:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini cukup untuk katashiro, Tuan Mao?
Dialogue: 0,0:08:36.09,0:08:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:08:48.69,0:08:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:08:49.90,0:08:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memasang umpan di tempatku.
Dialogue: 0,0:08:52.69,0:08:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lubang ini masih berisi energi yokai Byoki.
Dialogue: 0,0:08:56.99,0:08:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:08:58.49,0:09:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat musuh datang dan mengintip\Nke dalam lubang…
Dialogue: 0,0:09:02.20,0:09:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, begitu kita memastikan\Nsiapa mereka dan menentukan
Dialogue: 0,0:09:04.33,0:09:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah mereka punya niat jahat,
Dialogue: 0,0:09:06.12,0:09:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan gunakan dinamitmu\Nuntuk membuat lubang
Dialogue: 0,0:09:09.55,0:09:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjebak mereka\Ndi bawah tanah untuk sementara.
Dialogue: 0,0:09:13.09,0:09:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar melihat siapa yang datang.
Dialogue: 0,0:09:17.34,0:09:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa memikirkan beberapa murid senior
Dialogue: 0,0:09:20.06,0:09:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tahu mantra Air.
Dialogue: 0,0:09:24.35,0:09:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi adakah orang yang akan\Nmenggunakan taktik agresif seperti itu?
Dialogue: 0,0:09:30.48,0:09:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka datang.
Dialogue: 0,0:09:31.90,0:09:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini terlalu cepat?
Dialogue: 0,0:09:33.07,0:09:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berlindung.
Dialogue: 0,0:09:49.29,0:09:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa itu?
Dialogue: 0,0:09:55.34,0:09:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:09:56.51,0:09:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya?
Dialogue: 0,0:10:23.87,0:10:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:10:25.00,0:10:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu apa, sih?
Dialogue: 0,0:10:30.50,0:10:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuh dengan ikan.
Dialogue: 0,0:10:37.80,0:10:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao…
Dialogue: 0,0:10:40.22,0:10:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tahu namaku?
Dialogue: 0,0:10:43.22,0:10:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mao! Kau tahu siapa\Nyang mengendalikan monster itu?
Dialogue: 0,0:10:51.86,0:10:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao…
Dialogue: 0,0:10:55.32,0:10:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa saja menyuruhku mengambil air.
Dialogue: 0,0:10:59.49,0:11:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mokuzu.
Dialogue: 0,0:11:02.24,0:11:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:11:03.91,0:11:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya meminta satu mantra.
Dialogue: 0,0:11:05.62,0:11:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:06.79,0:11:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kau mengajariku satu mantra saja?
Dialogue: 0,0:11:10.00,0:11:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah membahas ini.
Dialogue: 0,0:11:12.42,0:11:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berhak mengajarimu,
Dialogue: 0,0:11:15.84,0:11:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Guru sangat melarangnya.
Dialogue: 0,0:11:21.18,0:11:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir jika aku melayani\Ndi kediaman onmyoji,
Dialogue: 0,0:11:23.80,0:11:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mungkin akan belajar\Nsetidaknya satu mantra.
Dialogue: 0,0:11:27.35,0:11:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin menjadi onmyoji, Mokuzu?
Dialogue: 0,0:11:30.85,0:11:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.\NItu sesuatu yang selalu kuimpikan.
Dialogue: 0,0:11:35.44,0:11:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kemiripannya mencolok?
Dialogue: 0,0:11:38.32,0:11:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mokuzu, si pelayan?
Dialogue: 0,0:11:40.99,0:11:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:41.87,0:11:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu dahulu juga memohon\Nagar aku mengajarinya mantra.
Dialogue: 0,0:11:46.16,0:11:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah melakukannya.
Dialogue: 0,0:11:47.87,0:11:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mokuzu bukan penyihir.
Dialogue: 0,0:11:51.58,0:11:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa seseorang mengajarinya mantra itu?
Dialogue: 0,0:11:54.50,0:11:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao…
Dialogue: 0,0:12:06.05,0:12:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun itu, makhluk ini bukan manusia.
Dialogue: 0,0:12:08.72,0:12:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lakukan!
Dialogue: 0,0:12:10.06,0:12:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyalakan!
Dialogue: 0,0:12:19.03,0:12:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ia melihat ke dalam lubang,
Dialogue: 0,0:12:21.11,0:12:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dinamitnya meledak.
Dialogue: 0,0:12:23.61,0:12:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya semua berjalan sesuai rencana.
Dialogue: 0,0:12:25.74,0:12:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:12:27.16,0:12:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai rencana!
Dialogue: 0,0:12:38.96,0:12:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubah menjadi kolam ikan raksasa.
Dialogue: 0,0:12:47.30,0:12:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:12:49.39,0:12:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ajari aku
Dialogue: 0,0:12:51.52,0:12:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra rahasia Taizanfukun.
Dialogue: 0,0:12:54.31,0:12:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu tujuannya, sesuai dugaan.
Dialogue: 0,0:12:57.15,0:12:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:12:58.82,0:13:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau Mokuzu?
Dialogue: 0,0:13:01.36,0:13:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra rahasia Taizanfukun
Dialogue: 0,0:13:03.61,0:13:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya diketahui beberapa orang di kediaman.
Dialogue: 0,0:13:07.28,0:13:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tahu soal itu?
Dialogue: 0,0:13:09.20,0:13:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra rahasia diwariskan\Nkepada penerus yang sah.
Dialogue: 0,0:13:14.58,0:13:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:15.62,0:13:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa penerus yang sah?
Dialogue: 0,0:13:18.13,0:13:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao, kau pasti tahu.
Dialogue: 0,0:13:20.96,0:13:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau menyatu dengan Byoki itu.
Dialogue: 0,0:13:25.18,0:13:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya alasan kau masih hidup sekarang
Dialogue: 0,0:13:28.68,0:13:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah karena kekuatan Byoki menopangmu.
Dialogue: 0,0:13:31.72,0:13:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kumohon,
Dialogue: 0,0:13:33.68,0:13:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi aku.
Dialogue: 0,0:13:37.02,0:13:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dibicarakannya?
Dialogue: 0,0:13:41.02,0:13:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang mengubah
Dialogue: 0,0:13:43.61,0:13:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kucing Nona Sana, Haimaru, menjadi Byoki
Dialogue: 0,0:13:47.45,0:13:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah aku, Mokuzu.
Dialogue: 0,0:13:55.71,0:13:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari, Otoya!
Dialogue: 0,0:14:21.90,0:14:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka.
Dialogue: 0,0:14:23.94,0:14:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita di dalam tubuh Mokuzu?
Dialogue: 0,0:14:27.40,0:14:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:14:28.70,0:14:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawamu ke Kyoto.
Dialogue: 0,0:14:37.83,0:14:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:14:41.63,0:14:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bernapas.
Dialogue: 0,0:14:44.71,0:14:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:14:46.09,0:14:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa sebaiknya
Dialogue: 0,0:14:47.55,0:14:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau menjauh dari Mokuzu.
Dialogue: 0,0:14:49.43,0:14:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana.
Dialogue: 0,0:14:51.01,0:14:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia melakukan kesalahan?
Dialogue: 0,0:14:53.18,0:14:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup lama, Mokuzu
Dialogue: 0,0:14:54.85,0:14:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengganggu berbagai murid\Nuntuk mengajarinya mantra onmyo.
Dialogue: 0,0:15:00.27,0:15:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sejak kau terpilih sebagai penerus,
Dialogue: 0,0:15:03.02,0:15:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bersikap aneh.
Dialogue: 0,0:15:08.40,0:15:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering melihat
Dialogue: 0,0:15:09.78,0:15:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia menatapku.
Dialogue: 0,0:15:11.74,0:15:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menatapmu?
Dialogue: 0,0:15:13.37,0:15:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menjelaskannya,
Dialogue: 0,0:15:15.45,0:15:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi matanya…
Dialogue: 0,0:15:18.66,0:15:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya
Dialogue: 0,0:15:20.04,0:15:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seolah-olah
Dialogue: 0,0:15:22.29,0:15:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada yang mengawasiku.
Dialogue: 0,0:15:28.59,0:15:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang mengendalikan Mokuzu.
Dialogue: 0,0:15:34.97,0:15:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang pernah kabur
Dialogue: 0,0:15:37.43,0:15:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah terjebak di dalam tubuhku.
Dialogue: 0,0:15:53.78,0:15:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Mokuzu.
Dialogue: 0,0:16:00.62,0:16:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya jika kau mati di sini.
Dialogue: 0,0:16:04.54,0:16:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi kau tidur di perut ikan raksasa,
Dialogue: 0,0:16:07.50,0:16:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan membawamu ke Kyoto.
Dialogue: 0,0:16:20.39,0:16:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:51.47,0:16:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:16:55.68,0:16:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mokuzu.
Dialogue: 0,0:16:57.01,0:16:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang mengajarimu mantra ini?
Dialogue: 0,0:16:59.72,0:17:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hyakka.
Dialogue: 0,0:17:02.60,0:17:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya.
Dialogue: 0,0:17:03.69,0:17:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana keadaan Hyakka?
Dialogue: 0,0:17:05.06,0:17:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tenggelam
Dialogue: 0,0:17:06.35,0:17:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tewas.
Dialogue: 0,0:17:08.02,0:17:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang mereka incar,
Dialogue: 0,0:17:11.24,0:17:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku menyeretnya ke dalam masalah ini.
Dialogue: 0,0:17:13.70,0:17:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:17:15.10,0:17:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum berubah.\NKau selalu menjadi orang baik.
Dialogue: 0,0:17:18.70,0:17:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu menyalahkan dirimu.
Dialogue: 0,0:17:21.50,0:17:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika yang lain terlibat,
Dialogue: 0,0:17:23.61,0:17:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku diperintahkan untuk\Nmembunuh mereka juga.
Dialogue: 0,0:17:27.50,0:17:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lain?
Dialogue: 0,0:17:29.84,0:17:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya murid senior\Nyang dipanggil ke Goshikido?
Dialogue: 0,0:17:36.01,0:17:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku korban tambahan?
Dialogue: 0,0:17:38.14,0:17:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hidup kembali.
Dialogue: 0,0:17:40.68,0:17:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Kukira aku akan mati.
Dialogue: 0,0:17:43.06,0:17:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kau benar-benar mati.
Dialogue: 0,0:17:45.23,0:17:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mokuzu.
Dialogue: 0,0:17:46.60,0:17:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang kaulah
Dialogue: 0,0:17:49.06,0:17:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mengubah kucing Nona Sana,\NHaimaru, menjadi Byoki.
Dialogue: 0,0:17:52.15,0:17:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu perintah orang lain juga?
Dialogue: 0,0:17:54.44,0:17:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:55.53,0:17:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meminta para murid\Ndi kediaman untuk mengajariku mantra,
Dialogue: 0,0:17:58.24,0:17:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mereka semua menolakku.
Dialogue: 0,0:18:00.41,0:18:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecuali orang itu.
Dialogue: 0,0:18:05.12,0:18:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan mengajariku?
Dialogue: 0,0:18:06.96,0:18:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:18:09.42,0:18:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu saja!
Dialogue: 0,0:18:11.00,0:18:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau ajari aku,
Dialogue: 0,0:18:12.38,0:18:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan melakukan apa pun yang kau minta!
Dialogue: 0,0:18:15.51,0:18:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menuruti perintah.
Dialogue: 0,0:18:18.39,0:18:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diam-diam membawa Haimaru pergi
Dialogue: 0,0:18:21.01,0:18:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melemparnya ke lubang kodoku\Nyang digali di sana.
Dialogue: 0,0:18:34.03,0:18:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lubang itu dipenuhi serangga berbisa,
Dialogue: 0,0:18:36.57,0:18:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ular, anjing liar, dan babi hutan, tapi…
Dialogue: 0,0:18:40.99,0:18:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haimaru membunuh dan melahap mereka semua.
Dialogue: 0,0:18:43.54,0:18:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah dia jadi kodoku paling mematikan.
Dialogue: 0,0:18:47.83,0:18:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu.
Dialogue: 0,0:18:52.29,0:18:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa?
Dialogue: 0,0:18:53.84,0:18:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:55.09,0:18:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang menggunakan Byoki itu
Dialogue: 0,0:18:57.30,0:18:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengutuk kita sampai mati.
Dialogue: 0,0:19:00.72,0:19:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao? Matamu…
Dialogue: 0,0:19:02.51,0:19:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujelaskan nanti, Hyakka.
Dialogue: 0,0:19:04.85,0:19:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kemudian, Byoki itu
Dialogue: 0,0:19:06.81,0:19:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melahap gulungan rahasia Taizanfukun
Dialogue: 0,0:19:10.19,0:19:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyatu denganmu, Tuan Mao.
Dialogue: 0,0:19:14.02,0:19:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu,
Dialogue: 0,0:19:15.07,0:19:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku khawatir tidak akan\Ndiajari mantra apa pun,
Dialogue: 0,0:19:19.03,0:19:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi seperti yang kau lihat,
Dialogue: 0,0:19:20.57,0:19:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku telah menjadi onmyoji yang hebat.
Dialogue: 0,0:19:24.95,0:19:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Mokuzu.
Dialogue: 0,0:19:27.16,0:19:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah…
Dialogue: 0,0:19:39.76,0:19:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya dia sudah mati sejak awal.
Dialogue: 0,0:19:42.34,0:19:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mokuzu tidak punya maksud tersembunyi.
Dialogue: 0,0:19:45.51,0:19:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya pria yang terobsesi\Nmempelajari mantra.
Dialogue: 0,0:19:48.64,0:19:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang memanfaatkan itu\Ndan menjadikannya bidak.
Dialogue: 0,0:19:52.10,0:19:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Sepertinya begitu.
Dialogue: 0,0:19:54.90,0:19:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:19:56.61,0:20:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haimaru benci disentuh\Noleh siapa pun kecuali aku.
Dialogue: 0,0:20:01.57,0:20:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haimaru tak pernah menyukai\Nsiapa pun selain Nona Sana dan aku.
Dialogue: 0,0:20:06.29,0:20:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa Haimaru diam saja,
Dialogue: 0,0:20:08.37,0:20:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukannya kabur?
Dialogue: 0,0:20:11.75,0:20:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang tidak beres.
Dialogue: 0,0:20:16.71,0:20:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukannya dalam sekali coba.
Dialogue: 0,0:20:18.01,0:20:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taizanfukun.
Dialogue: 0,0:20:19.21,0:20:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:20.17,0:20:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang kau cari, kan, Nanoka?
Dialogue: 0,0:20:22.63,0:20:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taizanfukun.
Dialogue: 0,0:20:25.10,0:20:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:27.22,0:20:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra untuk memanipulasi umur manusia.
Dialogue: 0,0:20:29.85,0:20:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seni rahasia tertinggi Onmyodo.
Dialogue: 0,0:20:32.73,0:20:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari caranya bicara,
Dialogue: 0,0:20:34.31,0:20:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kukira itu rahasia penuh misteri.
Dialogue: 0,0:20:37.82,0:20:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau memintaku menyelidikinya,\Naku meringkas poin utamanya.
Dialogue: 0,0:20:41.49,0:20:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiraha, kau yang terbaik!
Dialogue: 0,0:20:45.41,0:20:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, Taizan adalah\Ngunung suci di Tiongkok.
Dialogue: 0,0:20:48.66,0:20:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taizanfukun adalah dewa Tao\Nyang lebih tua dari Jugondo.
Dialogue: 0,0:20:54.08,0:20:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, Taizanfukun mengatur umur\Ndan jiwa manusia.
Dialogue: 0,0:20:59.00,0:21:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengatur umur manusia?
Dialogue: 0,0:21:01.59,0:21:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Jepang, Taizanfukun dihormati di Onmyodo,
Dialogue: 0,0:21:04.97,0:21:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Ritus Taizanfukun adalah\Nsalah satu ritual utamanya.
Dialogue: 0,0:21:09.39,0:21:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ritus rahasia yang hanya\Ndilakukan di Istana Kekaisaran,
Dialogue: 0,0:21:11.93,0:21:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}khusus untuk bangsawan.
Dialogue: 0,0:21:14.31,0:21:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, jadi… Menurut sumber ini…
Dialogue: 0,0:21:17.36,0:21:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada satu catatan
Dialogue: 0,0:21:19.32,0:21:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa teknik rahasia Taizanfukun\Nbenar-benar digunakan.
Dialogue: 0,0:21:22.90,0:21:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat seorang pendeta agung sakit parah,
Dialogue: 0,0:21:25.95,0:21:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}murid-muridnya yang berduka\Nmencoba semua doa yang mereka bisa,
Dialogue: 0,0:21:29.20,0:21:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia tidak sembuh.
Dialogue: 0,0:21:31.37,0:21:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka memanggil Abe no Seimei,
Dialogue: 0,0:21:33.87,0:21:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}guru utama Onmyodo saat itu.
Dialogue: 0,0:21:35.62,0:21:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abe no Seimei?
Dialogue: 0,0:21:37.17,0:21:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia nyata?
Dialogue: 0,0:21:38.67,0:21:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar ada.
Dialogue: 0,0:21:40.50,0:21:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:21:41.46,0:21:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mengenalnya sebagai karakter\Ndalam gim dan semacamnya.
Dialogue: 0,0:21:44.80,0:21:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk persiapan Ritus Taizanfukun,
Dialogue: 0,0:21:46.76,0:21:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seimei bertanya apa ada murid\Nyang mau menawarkan nyawa mereka
Dialogue: 0,0:21:51.01,0:21:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai ganti guru mereka.
Dialogue: 0,0:21:53.43,0:21:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat yang lain ragu,
Dialogue: 0,0:21:55.19,0:21:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang biksu maju.
Dialogue: 0,0:21:58.52,0:22:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seimei menulis nama biksu itu di teks doa
Dialogue: 0,0:22:01.73,0:22:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang didedikasikan untuk Taizanfukun,
Dialogue: 0,0:22:03.36,0:22:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mempersembahkannya dalam ritus itu.
Dialogue: 0,0:22:05.15,0:22:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tiba-tiba,\Npenyakit guru itu mulai membaik.
Dialogue: 0,0:22:08.74,0:22:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa biksu yang berkorban itu mati…
Dialogue: 0,0:22:11.41,0:22:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:22:13.45,0:22:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:14.75,0:22:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru dan murid itu sama-sama umur panjang.
Dialogue: 0,0:22:17.71,0:22:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, ya?
Dialogue: 0,0:22:19.17,0:22:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Taizanfukun, sang dewa,
Dialogue: 0,0:22:21.63,0:22:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengasihani biksu yang berkorban\Nuntuk gurunya
Dialogue: 0,0:22:24.72,0:22:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membiarkannya hidup.
Dialogue: 0,0:22:26.63,0:22:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:22:27.89,0:22:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biksu itu dipuji,\Ndan kemudian menjadi terkenal.
Dialogue: 0,0:22:32.14,0:22:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya bahagia.
Dialogue: 0,0:22:34.81,0:22:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:22:35.85,0:22:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama-lama,\Nceritanya terdengar seperti khotbah Buddha.
Dialogue: 0,0:22:39.23,0:22:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Taizanfukun adalah\Nmantra penukar nyawa,
Dialogue: 0,0:22:42.36,0:22:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menukar satu nyawa dengan nyawa lain.
Dialogue: 0,0:22:45.19,0:22:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya itu membutuhkan nyawa orang lain.
Dialogue: 0,0:22:49.49,0:22:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu memanipulasi umur manusia
Dialogue: 0,0:22:52.08,0:22:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memakai nyawa orang lain?
Dialogue: 0,0:22:53.87,0:22:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah, Nanoka.
Dialogue: 0,0:22:57.62,0:22:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan semua yang terjadi,
Dialogue: 0,0:22:59.29,0:23:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untung Nona Nanoka tak ada di sini.
Dialogue: 0,0:23:02.75,0:23:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya…
Dialogue: 0,0:24:38.43,0:24:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kuchinawa.
Dialogue: 0,0:24:40.06,0:24:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah hendak meninggalkan kami?
Dialogue: 0,0:24:42.73,0:24:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:24:44.52,0:24:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuannya.
Dialogue: 0,0:24:48.11,0:24:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak pernah ada waktu untuk bersantai, ya?
Dialogue: 0,0:24:49.78,0:24:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah lama tidak ke Kyoto...
Dialogue: 0,0:24:53.03,0:24:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beniko, apa kau menemukan sesuatu?
Dialogue: 0,0:24:57.74,0:24:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku menemukannya, Tuan Kamon.
Dialogue: 0,0:25:00.00,0:25:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada seorang putri dari keluarga bangsawan.
Dialogue: 0,0:25:02.50,0:25:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri bangsawan.
Dialogue: 0,0:25:04.58,0:25:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:25:06.79,0:25:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sakit parah, tapi keluarga itu\Nmemanggil penyembuh spiritual.
Dialogue: 0,0:25:10.51,0:25:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah sembuh sekarang.
Dialogue: 0,0:25:14.47,0:25:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Ikatan Darah".
