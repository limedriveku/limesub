Dialogue: 0,0:00:46.12,0:00:47.50,sign,,0000,0000,0000,,MIZUCHI
Dialogue: 0,0:01:34.63,0:01:36.22,sign,,0000,0000,0000,,"KUCHINAWA"
Dialogue: 0,0:02:28.19,0:02:30.81,sign,,0000,0000,0000,,"MIYAKO"
Dialogue: 0,0:03:38.26,0:03:41.26,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:04:55.75,0:04:58.96,sign,,0000,0000,0000,,IKATAN DARAH
Dialogue: 0,0:04:59.13,0:05:00.05,sign,,0000,0000,0000,,KUCHINAWA
Dialogue: 0,0:05:00.13,0:05:00.96,sign,,0000,0000,0000,,"KAMON"
Dialogue: 0,0:05:02.80,0:05:05.13,sign,,0000,0000,0000,,BENIKO
Dialogue: 0,0:06:07.53,0:06:09.53,sign,,0000,0000,0000,,"SHIGERU"
Dialogue: 0,0:06:26.59,0:06:27.84,sign,,0000,0000,0000,,"MAO, OTOYA"
Dialogue: 0,0:06:30.64,0:06:31.60,sign,,0000,0000,0000,,KIBA NANOKA
Dialogue: 0,0:07:41.42,0:07:43.29,sign,,0000,0000,0000,,"IBU SHIGERU"
Dialogue: 0,0:07:46.17,0:07:47.34,sign,,0000,0000,0000,,ADIK SHIGERU
Dialogue: 0,0:09:59.68,0:10:02.89,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:24:49.40,0:24:50.40,sign,,0000,0000,0000,,"SELANJUTNYA"
Dialogue: 0,0:00:22.73,0:00:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shigeru… Shigeru…
Dialogue: 0,0:00:25.10,0:00:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah!
Dialogue: 0,0:00:29.07,0:00:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, jangan mati!
Dialogue: 0,0:00:33.03,0:00:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shigeru.
Dialogue: 0,0:00:35.24,0:00:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa, kumohon.
Dialogue: 0,0:00:37.99,0:00:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon.
Dialogue: 0,0:00:40.33,0:00:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong Shigeru.
Dialogue: 0,0:00:44.12,0:00:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, selamatkan nyawa putraku.
Dialogue: 0,0:00:48.13,0:00:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong selamatkan dia!
Dialogue: 0,0:00:53.72,0:00:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kuchinawa.
Dialogue: 0,0:00:55.38,0:00:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah hendak meninggalkan kami?
Dialogue: 0,0:00:57.97,0:00:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:59.68,0:01:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuannya.
Dialogue: 0,0:01:02.52,0:01:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak pernah ada waktu untuk bersantai, ya?
Dialogue: 0,0:01:05.06,0:01:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah lama tidak ke Kyoto...
Dialogue: 0,0:01:08.27,0:01:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beniko, apa kau menemukan sesuatu?
Dialogue: 0,0:01:13.03,0:01:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Tuan Kamon.
Dialogue: 0,0:01:15.28,0:01:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada seorang putri dari keluarga bangsawan.
Dialogue: 0,0:01:17.74,0:01:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri bangsawan.
Dialogue: 0,0:01:19.87,0:01:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:01:22.04,0:01:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sakit parah, tapi keluarga itu\Nmemanggil penyembuh spiritual.
Dialogue: 0,0:01:25.79,0:01:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah sembuh sekarang.
Dialogue: 0,0:01:32.63,0:01:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang bisa kubantu?
Dialogue: 0,0:01:34.63,0:01:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:01:36.43,0:01:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku, Kuchinawa.
Dialogue: 0,0:01:40.80,0:01:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja. Tuan Kuchinawa!
Dialogue: 0,0:01:42.97,0:01:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:01:44.60,0:01:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera membawamu kepada Tuan.
Dialogue: 0,0:01:49.81,0:01:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf aku terlambat.
Dialogue: 0,0:01:51.52,0:01:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk melihat keadaan putrimu.
Dialogue: 0,0:01:54.40,0:01:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas perhatianmu.
Dialogue: 0,0:01:55.82,0:01:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah sembuh sekarang.
Dialogue: 0,0:02:01.66,0:02:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu berkat penyembuh spiritual\Nyang terkenal.
Dialogue: 0,0:02:06.04,0:02:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya di antara kita saja,
Dialogue: 0,0:02:09.53,0:02:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku memanggil onmyoji terkenal\Ndari Klan Goko.
Dialogue: 0,0:02:16.05,0:02:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onmyoji dari Klan Goko.
Dialogue: 0,0:02:18.34,0:02:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:02:20.51,0:02:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah.
Dialogue: 0,0:02:28.19,0:02:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku kedatangan tamu?
Dialogue: 0,0:02:31.02,0:02:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyako.
Dialogue: 0,0:02:33.52,0:02:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:02:37.07,0:02:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang, Nona Miyako.
Dialogue: 0,0:02:39.53,0:02:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku, Kuchinawa.
Dialogue: 0,0:02:44.12,0:02:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kuchinawa.
Dialogue: 0,0:02:46.16,0:02:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang juga. Lama tidak berjumpa.
Dialogue: 0,0:02:48.79,0:02:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lega melihatmu baik-baik saja.
Dialogue: 0,0:02:50.92,0:02:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku merasa jauh lebih baik sekarang.
Dialogue: 0,0:02:56.21,0:02:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air?
Dialogue: 0,0:02:58.42,0:02:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah,
Dialogue: 0,0:03:00.80,0:03:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita seharusnya mengundang Tuan Kuchinawa\Nke pesta kesembuhanku.
Dialogue: 0,0:03:05.31,0:03:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, seharusnya begitu.\NBetapa pelupanya aku.
Dialogue: 0,0:03:07.93,0:03:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah.
Dialogue: 0,0:03:10.60,0:03:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar pelupa.
Dialogue: 0,0:03:13.23,0:03:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayolah, jangan terlalu keras padaku.\N- Gadis muda ini…
Dialogue: 0,0:03:17.11,0:03:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah mati.
Dialogue: 0,0:03:19.32,0:03:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dan orang-orang di sekitarnya\Nbahkan tak menyadarinya.
Dialogue: 0,0:05:00.13,0:05:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kamon.
Dialogue: 0,0:05:05.47,0:05:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hasilnya?
Dialogue: 0,0:05:14.23,0:05:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak berjalan lancar.
Dialogue: 0,0:05:15.52,0:05:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya penyembuh spiritual itu dirujuk\Noleh teman dari temannya.
Dialogue: 0,0:05:19.73,0:05:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, saat aku mencoba bertanya\Ndari siapa rujukan aslinya,
Dialogue: 0,0:05:22.94,0:05:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia benar-benar terdiam.
Dialogue: 0,0:05:26.41,0:05:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu ingatannya dihapus?
Dialogue: 0,0:05:29.32,0:05:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mungkin saja. Selain itu,
Dialogue: 0,0:05:31.87,0:05:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siapa pun dalangnya, jelas ingin\Norang kelas atas mengingat nama Klan Goko.
Dialogue: 0,0:05:37.29,0:05:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa agar mereka bisa menarik\Nlebih banyak klien.
Dialogue: 0,0:05:42.67,0:05:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, mantra yang mereka gunakan
Dialogue: 0,0:05:44.72,0:05:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat tidak sempurna.
Dialogue: 0,0:05:48.30,0:05:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya mereka tidak benar-benar tahu
Dialogue: 0,0:05:52.14,0:05:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seni rahasia Taizanfukun.
Dialogue: 0,0:05:56.52,0:05:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:06:03.48,0:06:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa putraku benar-benar akan sembuh?
Dialogue: 0,0:06:07.53,0:06:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Namun, sebagai gantinya…
Dialogue: 0,0:06:26.59,0:06:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap berangkat!
Dialogue: 0,0:06:31.68,0:06:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlengkapanku siap.
Dialogue: 0,0:06:34.18,0:06:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang "perlengkapanmu"?
Dialogue: 0,0:06:35.97,0:06:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:37.02,0:06:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus melindungi tanganku,
Dialogue: 0,0:06:39.56,0:06:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku membawa sarung tangan kerja,
Dialogue: 0,0:06:41.19,0:06:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sarung tangan berat.
Dialogue: 0,0:06:43.11,0:06:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bawa kacamata\Nuntuk melindungi mataku dari air.
Dialogue: 0,0:06:46.94,0:06:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kacamata renang?
Dialogue: 0,0:06:50.03,0:06:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:06:52.20,0:06:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka. Maafkan aku.
Dialogue: 0,0:06:54.41,0:06:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah berakhir.
Dialogue: 0,0:06:56.37,0:06:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:57.91,0:06:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:59.16,0:07:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang pembunuh datang\Ntepat setelah kau kembali ke duniamu.
Dialogue: 0,0:07:02.84,0:07:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?\NTapi aku datang dengan persiapan.
Dialogue: 0,0:07:05.92,0:07:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mengagumkan.
Dialogue: 0,0:07:08.51,0:07:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cocok memakai kacamata renang itu.
Dialogue: 0,0:07:10.97,0:07:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, bukan?
Dialogue: 0,0:07:12.01,0:07:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan berlatih\Nagar bisa memakainya dengan cepat.
Dialogue: 0,0:07:15.22,0:07:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini!
Dialogue: 0,0:07:16.81,0:07:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:07:19.23,0:07:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gadis yang baik.
Dialogue: 0,0:07:21.14,0:07:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mungkin lebih baik\Nkau tidak ada di sini.
Dialogue: 0,0:07:24.86,0:07:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:26.28,0:07:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju.
Dialogue: 0,0:07:29.07,0:07:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lawan yang menantang, bahkan untukku.
Dialogue: 0,0:07:33.49,0:07:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan mengirim pembunuh lain?
Dialogue: 0,0:07:38.29,0:07:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:07:41.42,0:07:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau dokter?
Dialogue: 0,0:07:44.29,0:07:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Periksalah putraku.
Dialogue: 0,0:07:47.54,0:07:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:07:49.46,0:07:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik saja?
Dialogue: 0,0:07:50.88,0:07:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:07:56.68,0:07:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya tidur.
Dialogue: 0,0:07:58.52,0:07:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:08:00.98,0:08:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu merawat kakakku tanpa tidur.
Dialogue: 0,0:08:06.44,0:08:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelelahan.
Dialogue: 0,0:08:10.86,0:08:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya. Nanoka.
Dialogue: 0,0:08:13.86,0:08:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan dia tidur di sini sebentar.
Dialogue: 0,0:08:20.41,0:08:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ke mana?
Dialogue: 0,0:08:22.00,0:08:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menemui putranya.
Dialogue: 0,0:08:24.25,0:08:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa aku ke rumahmu.
Dialogue: 0,0:08:25.67,0:08:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:30.59,0:08:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat sini.
Dialogue: 0,0:08:39.35,0:08:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga menemui pasien manusia?
Dialogue: 0,0:08:43.52,0:08:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, terkadang.
Dialogue: 0,0:08:45.65,0:08:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika pasien manusia memintanya,
Dialogue: 0,0:08:47.23,0:08:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia juga merawat mereka secara gratis.
Dialogue: 0,0:08:49.15,0:08:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:08:50.53,0:08:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia benar-benar dokter.
Dialogue: 0,0:08:58.16,0:08:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini milik Mao…
Dialogue: 0,0:09:04.16,0:09:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa bicara.
Dialogue: 0,0:09:17.85,0:09:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak bisa menggerakkan tubuhku!
Dialogue: 0,0:09:22.39,0:09:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:09:24.94,0:09:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu cangkang?
Dialogue: 0,0:09:29.06,0:09:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya?
Dialogue: 0,0:09:31.32,0:09:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:09:35.99,0:09:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:37.36,0:09:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guci kodoku…
Dialogue: 0,0:09:39.91,0:09:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang membuat Mao tetap hidup.
Dialogue: 0,0:09:55.38,0:09:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shigeru!
Dialogue: 0,0:10:05.81,0:10:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sebelah sana. Sedikit lagi.
Dialogue: 0,0:10:10.86,0:10:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak! Kakak!
Dialogue: 0,0:10:12.90,0:10:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini, Dokter!
Dialogue: 0,0:10:15.94,0:10:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat, Dokter!
Dialogue: 0,0:10:23.70,0:10:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:10:28.42,0:10:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah mati.
Dialogue: 0,0:10:31.42,0:10:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kelihatannya,
Dialogue: 0,0:10:32.96,0:10:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia mungkin sudah mati\Nsaat mereka datang meminta bantuan.
Dialogue: 0,0:11:00.78,0:11:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata itu…
Dialogue: 0,0:11:02.99,0:11:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia shikigami.
Dialogue: 0,0:11:05.95,0:11:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tuanmu?
Dialogue: 0,0:11:09.37,0:11:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan tahu saat bertemu.
Dialogue: 0,0:11:15.46,0:11:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat. Aku tidak membawa pedangku.
Dialogue: 0,0:11:22.59,0:11:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya! Otoya!
Dialogue: 0,0:11:25.31,0:11:26.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarlah!
Dialogue: 0,0:11:29.64,0:11:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah sadar?
Dialogue: 0,0:11:31.94,0:11:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terjebak dalam mantra ilusi.
Dialogue: 0,0:11:33.98,0:11:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu mencuri guci kodoku.
Dialogue: 0,0:11:36.61,0:11:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mengejarnya!
Dialogue: 0,0:11:38.36,0:11:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ke mana dia pergi?
Dialogue: 0,0:11:40.20,0:11:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa lama waktu berlalu?
Dialogue: 0,0:11:42.95,0:11:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Handuk ini…
Dialogue: 0,0:11:44.70,0:11:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang kupakaikan pada wanita itu.
Dialogue: 0,0:11:49.20,0:11:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa?
Dialogue: 0,0:11:50.71,0:11:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini…
Dialogue: 0,0:11:54.29,0:11:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:11:57.75,0:11:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:12:02.80,0:12:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana tujuannya?
Dialogue: 0,0:12:06.51,0:12:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan lolos.
Dialogue: 0,0:12:12.48,0:12:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mendekat\Ndan menghentikan serangannya!
Dialogue: 0,0:12:36.50,0:12:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kau ingat tombak apa ini?
Dialogue: 0,0:12:41.88,0:12:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari waktu itu!
Dialogue: 0,0:12:45.55,0:12:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tombak yang menusuk Byoki yang sekarat!
Dialogue: 0,0:12:50.39,0:12:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:12:51.85,0:12:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}900 tahun lalu, tombak ini
Dialogue: 0,0:12:53.98,0:12:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menusuk Byoki itu\Ndan mencuri kekuatan yokai-nya,
Dialogue: 0,0:12:57.44,0:12:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hampir merenggut nyawanya.
Dialogue: 0,0:12:59.86,0:13:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Tombak Taima.
Dialogue: 0,0:13:02.19,0:13:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao,
Dialogue: 0,0:13:03.45,0:13:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menangkap orang sepertimu,\Nyang menyatu dengan Byoki itu,
Dialogue: 0,0:13:06.99,0:13:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini senjata kutukan yang sempurna.
Dialogue: 0,0:13:10.41,0:13:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shigeru!
Dialogue: 0,0:13:12.16,0:13:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shigeru!
Dialogue: 0,0:13:14.71,0:13:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu. Kakak…
Dialogue: 0,0:13:20.50,0:13:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:13:22.05,0:13:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}guci kodoku!
Dialogue: 0,0:13:24.68,0:13:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shigeru.
Dialogue: 0,0:13:25.97,0:13:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shigeru!
Dialogue: 0,0:13:30.31,0:13:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Anakku yang malang.\N- Kakak…
Dialogue: 0,0:13:32.85,0:13:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menuruti permintaanmu dan membawa ini!
Dialogue: 0,0:13:35.77,0:13:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat, tolong selamatkan anakku.
Dialogue: 0,0:13:38.19,0:13:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamatkan anakku!
Dialogue: 0,0:13:40.07,0:13:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu sudah mati.
Dialogue: 0,0:13:42.78,0:13:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak membutuhkanmu sekarang.
Dialogue: 0,0:13:51.24,0:13:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usir!
Dialogue: 0,0:14:06.55,0:14:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melindungi pencuri\Nyang tidak tahu terima kasih.
Dialogue: 0,0:14:09.97,0:14:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh sekali.
Dialogue: 0,0:14:13.43,0:14:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:14:28.11,0:14:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang
Dialogue: 0,0:14:29.66,0:14:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan membawamu ke Kyoto.
Dialogue: 0,0:14:32.12,0:14:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan menyerahkanku kepada tuanmu
Dialogue: 0,0:14:35.20,0:14:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memaksaku mengungkap\Nseni rahasia Taizanfukun?
Dialogue: 0,0:14:40.08,0:14:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menyuruh ibu itu\Nmencuri guci kodoku?
Dialogue: 0,0:14:44.88,0:14:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan merepotkan jika kau mati\Ndalam perjalanan ke sana.
Dialogue: 0,0:14:49.68,0:14:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tahu kodoku itu menopang nyawaku?
Dialogue: 0,0:14:53.97,0:14:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dia bisa tahu?
Dialogue: 0,0:14:55.64,0:14:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:15:02.90,0:15:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:15:04.02,0:15:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:15:06.28,0:15:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:15:18.00,0:15:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka…
Dialogue: 0,0:15:21.33,0:15:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:15:22.33,0:15:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarkan tombaknya sekarang!
Dialogue: 0,0:15:24.59,0:15:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:31.55,0:15:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:15:36.52,0:15:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya tenaga lagi.
Dialogue: 0,0:15:49.78,0:15:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao! Aku datang untuk mengobati…
Dialogue: 0,0:16:01.62,0:16:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:16:03.63,0:16:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur!
Dialogue: 0,0:16:05.46,0:16:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:06.38,0:16:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, Pyo, To, Sha,\NKai, Jin, Retsu, Zai, Zen!
Dialogue: 0,0:16:10.26,0:16:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usir!
Dialogue: 0,0:16:12.30,0:16:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembilan Tebasan!
Dialogue: 0,0:16:30.44,0:16:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur.
Dialogue: 0,0:16:31.70,0:16:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:16:39.75,0:16:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengejarnya, Nanoka!
Dialogue: 0,0:16:47.46,0:16:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pergi.
Dialogue: 0,0:16:53.22,0:16:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:16:54.47,0:16:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:16:56.47,0:16:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak.
Dialogue: 0,0:16:58.22,0:16:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terluka parah.
Dialogue: 0,0:17:00.43,0:17:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya!
Dialogue: 0,0:17:01.43,0:17:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawakan guci kodoku. Cepat!
Dialogue: 0,0:17:06.48,0:17:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:17:08.56,0:17:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gucinya pecah?
Dialogue: 0,0:17:11.74,0:17:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya.
Dialogue: 0,0:17:13.60,0:17:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarlah!
Dialogue: 0,0:17:14.81,0:17:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao butuh bantuan kita!
Dialogue: 0,0:17:16.78,0:17:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?
Dialogue: 0,0:17:18.82,0:17:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun, Otoya!
Dialogue: 0,0:17:25.82,0:17:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guci kodoku.
Dialogue: 0,0:17:28.84,0:17:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang menopang nyawa Tuan Mao.
Dialogue: 0,0:17:31.55,0:17:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kodoku-nya lenyap.
Dialogue: 0,0:17:33.76,0:17:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya…
Dialogue: 0,0:17:36.47,0:17:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao!
Dialogue: 0,0:17:39.56,0:17:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya…
Dialogue: 0,0:17:41.97,0:17:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini perintah.
Dialogue: 0,0:17:46.14,0:17:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku mati di sini…
Dialogue: 0,0:17:50.44,0:17:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:51.86,0:17:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubur mayatku jauh di bawah tanah
Dialogue: 0,0:17:56.07,0:17:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan segel dengan penghalang yang kuat.
Dialogue: 0,0:17:59.99,0:18:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar Byoki itu
Dialogue: 0,0:18:01.99,0:18:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak pernah bisa menemukan jasadku.
Dialogue: 0,0:18:06.17,0:18:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Tuan Mao.
Dialogue: 0,0:18:08.88,0:18:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu. Apa maksudmu?
Dialogue: 0,0:18:11.71,0:18:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu bilang dia akan
Dialogue: 0,0:18:13.84,0:18:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menunggu
Dialogue: 0,0:18:16.76,0:18:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hidupmu berakhir.
Dialogue: 0,0:18:19.22,0:18:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kecuali dia mengambil kembali
Dialogue: 0,0:18:22.56,0:18:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuh yang menyatu denganku,
Dialogue: 0,0:18:26.60,0:18:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tidak bisa\Nmemindahkan dirinya ke Nanoka
Dialogue: 0,0:18:29.44,0:18:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai wadah baru.
Dialogue: 0,0:18:33.61,0:18:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:18:35.57,0:18:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Byoki itu bisa memindahkan wadah\Ndengan bebas,
Dialogue: 0,0:18:37.49,0:18:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka saat gempa bumi besar,
Dialogue: 0,0:18:40.12,0:18:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti sudah dirasuki olehnya.
Dialogue: 0,0:18:45.95,0:18:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:18:47.96,0:18:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lebih banyak lagi
Dialogue: 0,0:18:51.34,0:18:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ingin kuajarkan kepadamu.
Dialogue: 0,0:18:54.05,0:18:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao?
Dialogue: 0,0:18:56.59,0:18:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao?
Dialogue: 0,0:18:59.64,0:19:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:19:01.68,0:19:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao…
Dialogue: 0,0:19:02.97,0:19:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Jangan!
Dialogue: 0,0:19:04.31,0:19:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tinggalkan aku!
Dialogue: 0,0:19:05.68,0:19:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa-apa!
Dialogue: 0,0:19:08.89,0:19:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melakukan apa pun sendirian.
Dialogue: 0,0:19:11.06,0:19:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon… Ayolah, Mao!
Dialogue: 0,0:19:13.40,0:19:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan mati!
Dialogue: 0,0:19:15.57,0:19:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Tidak! Tidak!
Dialogue: 0,0:19:17.15,0:19:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:19:18.95,0:19:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:19:25.16,0:19:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:30.79,0:19:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:19:33.25,0:19:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa pusing.
Dialogue: 0,0:19:52.23,0:19:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka Tuan Mao
Dialogue: 0,0:19:54.27,0:19:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai sembuh.
Dialogue: 0,0:20:02.36,0:20:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka…
Dialogue: 0,0:20:07.95,0:20:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao…
Dialogue: 0,0:20:11.37,0:20:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hidup.
Dialogue: 0,0:20:14.79,0:20:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah…
Dialogue: 0,0:20:22.80,0:20:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:20:24.72,0:20:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja, Nona Nanoka?
Dialogue: 0,0:20:29.22,0:20:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka!
Dialogue: 0,0:22:03.40,0:22:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu, dua, tiga…
Dialogue: 0,0:22:06.36,0:22:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat, lima, enam, tujuh…
Dialogue: 0,0:22:13.79,0:22:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:15.46,0:22:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah sadar, Nanoka?
Dialogue: 0,0:22:18.13,0:22:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao. Bagaimana dengan lukamu?
Dialogue: 0,0:22:20.84,0:22:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi padaku?
Dialogue: 0,0:22:23.46,0:22:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, bagaimana perasaanmu?
Dialogue: 0,0:22:26.43,0:22:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Bagaimana perasaanku?
Dialogue: 0,0:22:29.18,0:22:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kau mengatakannya,
Dialogue: 0,0:22:31.18,0:22:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa agak lelah.
Dialogue: 0,0:22:34.77,0:22:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti setelah minum smoothie itu.
Dialogue: 0,0:22:39.48,0:22:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada saat itu,
Dialogue: 0,0:22:41.40,0:22:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sesuatu yang hangat\Nmengalir ke tubuhku melalui luka.
Dialogue: 0,0:22:46.74,0:22:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah…
Dialogue: 0,0:22:50.66,0:22:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}darahmu, Nanoka.
Dialogue: 0,0:22:57.16,0:22:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka yang disebabkan shikigami itu…
Dialogue: 0,0:23:01.38,0:23:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya darahmu
Dialogue: 0,0:23:03.88,0:23:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}entah bagaimana membuatku tetap hidup.
Dialogue: 0,0:23:07.59,0:23:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya itu yang terjadi.
Dialogue: 0,0:23:10.84,0:23:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darahku
Dialogue: 0,0:23:13.35,0:23:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama seperti darah Mao.
Dialogue: 0,0:23:15.43,0:23:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikutuk oleh Byoki itu.
Dialogue: 0,0:23:19.48,0:23:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi syukurlah
Dialogue: 0,0:23:21.15,0:23:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao masih hidup.
Dialogue: 0,0:23:27.95,0:23:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunkan aku.
Dialogue: 0,0:23:30.28,0:23:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunkan aku.
Dialogue: 0,0:23:31.62,0:23:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa berjalan?
Dialogue: 0,0:23:33.37,0:23:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa berjalan.
Dialogue: 0,0:23:38.08,0:23:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memeluknya tanpa berpikir.
Dialogue: 0,0:23:40.50,0:23:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat memalukan!
Dialogue: 0,0:23:42.58,0:23:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:23:44.80,0:23:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Napa yang terjadi pada orang-orang itu?
Dialogue: 0,0:23:47.63,0:23:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mengerikan.
Dialogue: 0,0:23:48.72,0:23:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menipumu dan mencuri gucinya.
Dialogue: 0,0:23:53.05,0:23:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,\Naku kasihan pada mereka.
Dialogue: 0,0:23:56.64,0:24:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia melakukannya\Nhanya karena ingin menyelamatkan putranya.
Dialogue: 0,0:24:00.23,0:24:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shigeru…
Dialogue: 0,0:24:02.81,0:24:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao, bagaimana shikigami itu tahu\Ntentang guci kodoku?
Dialogue: 0,0:24:08.78,0:24:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:24:10.07,0:24:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mereka tahu aku di mana?
Dialogue: 0,0:24:13.66,0:24:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melawan murid senior\Nyang merupakan Penyihir Air.
Dialogue: 0,0:24:16.29,0:24:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air ada di mana-mana di sekeliling kita.
Dialogue: 0,0:24:19.37,0:24:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah mereka mengawasiku melalui air?
Dialogue: 0,0:24:23.46,0:24:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu…
Dialogue: 0,0:24:25.21,0:24:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawamu ke ibu kota.
Dialogue: 0,0:24:27.75,0:24:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubawa kau ke ibu kota.
Dialogue: 0,0:24:31.80,0:24:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak datang langsung?
Dialogue: 0,0:24:35.85,0:24:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang mencegah mereka\Nmeninggalkan Kyoto?
Dialogue: 0,0:24:49.40,0:24:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:24:51.03,0:24:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar bertemu denganmu lagi.
Dialogue: 0,0:24:53.61,0:24:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!
Dialogue: 0,0:24:55.12,0:24:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak berbakat!
Dialogue: 0,0:24:57.45,0:24:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti saja!
Dialogue: 0,0:24:58.70,0:25:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang. Kami sudah menunggumu.
Dialogue: 0,0:25:01.00,0:25:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku tersayang.
Dialogue: 0,0:25:03.29,0:25:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alih-alih terkurung\Ndi dalam penghalang ini,
Dialogue: 0,0:25:06.04,0:25:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana jika kita pergi\Nke Ibu Kota Kekaisaran?
Dialogue: 0,0:25:09.21,0:25:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku.
Dialogue: 0,0:25:10.67,0:25:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku!
Dialogue: 0,0:25:11.84,0:25:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku, Mao!
Dialogue: 0,0:25:14.64,0:25:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Penyihir Air".
