Dialogue: 0,0:00:24.60,0:00:28.23,sign,,0000,0000,0000,,IBU KOTA KEKAISARAN SEBELUM FAJAR,\NJANUARI, TAISHO 13 1924
Dialogue: 0,0:01:31.71,0:01:35.17,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:03:00.80,0:03:04.05,sign,,0000,0000,0000,,TOPENG BESI
Dialogue: 0,0:03:15.15,0:03:15.98,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:03:17.65,0:03:20.65,sign,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:03:39.05,0:03:41.09,sign,,0000,0000,0000,,"KIBA NANOKA"
Dialogue: 0,0:05:32.45,0:05:34.54,sign,,0000,0000,0000,,"HAKUBI"
Dialogue: 0,0:05:35.46,0:05:36.58,sign,,0000,0000,0000,,"YURAKO"
Dialogue: 0,0:05:48.43,0:05:50.80,sign,,0000,0000,0000,,"KAMON"
Dialogue: 0,0:13:35.81,0:13:38.90,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:14:24.61,0:14:26.45,sign,,0000,0000,0000,,MILK HALL
Dialogue: 0,0:14:26.95,0:14:29.03,sign,,0000,0000,0000,,"HYAKKA"
Dialogue: 0,0:15:00.69,0:15:01.56,sign,,0000,0000,0000,,"TENKO"
Dialogue: 0,0:22:16.87,0:22:19.04,sign,,0000,0000,0000,,SHIRANUI
Dialogue: 0,0:24:49.07,0:24:53.70,sign,,0000,0000,0000,,"SELANJUTNYA"
Dialogue: 0,0:00:38.33,0:00:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:00:40.79,0:00:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada seseorang di sana.
Dialogue: 0,0:00:42.04,0:00:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak, apa yang harus kita lakukan?
Dialogue: 0,0:00:43.75,0:00:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus membunuhnya.
Dialogue: 0,0:00:45.50,0:00:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Pak...
Dialogue: 0,0:00:47.58,0:00:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah melihat kita.
Dialogue: 0,0:00:52.92,0:00:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak punya pilihan!
Dialogue: 0,0:01:00.47,0:01:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Dia juga tentara?
Dialogue: 0,0:03:05.18,0:03:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada hari itu,\Narea itu dilaporkan dipenuhi darah,
Dialogue: 0,0:03:08.56,0:03:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seragam militer, dan bayonet,
Dialogue: 0,0:03:11.31,0:03:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersama dengan banyak bongkahan perak\Nyang tersebar di antara mereka.
Dialogue: 0,0:03:16.07,0:03:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bongkahan perak?
Dialogue: 0,0:03:17.65,0:03:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya truk militer mengambil semuanya.
Dialogue: 0,0:03:21.32,0:03:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku penasaran apa itu?
Dialogue: 0,0:03:28.08,0:03:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mengkhawatirkan.
Dialogue: 0,0:03:39.05,0:03:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jimat kutukannya hancur berkeping-keping!
Dialogue: 0,0:03:42.72,0:03:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jejak mantra Onmyodo yang tertinggal.
Dialogue: 0,0:03:45.26,0:03:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya firasat buruk
Dialogue: 0,0:03:46.85,0:03:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang energi Logam ini.
Dialogue: 0,0:03:49.02,0:03:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logam?
Dialogue: 0,0:03:56.40,0:03:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya seorang perwira muda pemarah
Dialogue: 0,0:03:58.48,0:04:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tidak senang dengan kebijakan\Npengurangan militer baru-baru ini
Dialogue: 0,0:04:01.53,0:04:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencoba melakukan kudeta.
Dialogue: 0,0:04:04.41,0:04:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar seluruh peletonnya\Nmenghilang tanpa jejak.
Dialogue: 0,0:04:07.99,0:04:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu mereka semua kabur?
Dialogue: 0,0:04:10.83,0:04:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tampaknya,
Dialogue: 0,0:04:12.71,0:04:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten Shirasu diam-diam
Dialogue: 0,0:04:14.79,0:04:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengurus mereka di balik layar.
Dialogue: 0,0:04:28.06,0:04:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Topeng besi?
Dialogue: 0,0:04:29.97,0:04:31.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Kapten Shirasu.
Dialogue: 0,0:04:31.77,0:04:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dia memakainya sejak terluka parah
Dialogue: 0,0:04:34.27,0:04:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam perang dengan Rusia.
Dialogue: 0,0:04:35.69,0:04:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar rumor tentang dia.
Dialogue: 0,0:04:40.57,0:04:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, Kapten Shirasu!
Dialogue: 0,0:04:43.15,0:04:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang sekali kau bergabung dengan kami!
Dialogue: 0,0:04:45.49,0:04:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan tempat kesukaanku.
Dialogue: 0,0:04:48.03,0:04:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salon untuk elite politik dan keuangan.
Dialogue: 0,0:04:50.54,0:04:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak.
Dialogue: 0,0:04:51.58,0:04:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan kami mengundangmu hari ini\Nadalah atas permintaan tulus
Dialogue: 0,0:04:54.46,0:04:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang wanita muda\Ndari keluarga aristokrat.
Dialogue: 0,0:04:56.29,0:04:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang sudah lama mengagumi
Dialogue: 0,0:04:58.79,0:05:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten Shirasu yang legendaris.
Dialogue: 0,0:05:03.55,0:05:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten Shirasu!
Dialogue: 0,0:05:11.68,0:05:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kau ditugaskan ke benua.
Dialogue: 0,0:05:14.35,0:05:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang akhirnya bertemu denganmu.
Dialogue: 0,0:05:17.73,0:05:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten Shirasu.
Dialogue: 0,0:05:19.52,0:05:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau
Dialogue: 0,0:05:21.32,0:05:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}haruskah aku memanggilmu Hakubi?
Dialogue: 0,0:05:27.32,0:05:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau di Kyoto bertahun-tahun,
Dialogue: 0,0:05:29.74,0:05:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kini kau di Ibu Kota Kekaisaran.
Dialogue: 0,0:05:32.45,0:05:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rencanakan,
Dialogue: 0,0:05:35.46,0:05:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Yurako?
Dialogue: 0,0:05:38.13,0:05:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu akhirnya mulai muncul
Dialogue: 0,0:05:40.42,0:05:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di salon yang sering dikunjungi\Noleh elite politik dan keuangan.
Dialogue: 0,0:05:45.67,0:05:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengaku sebagai bangsawan,
Dialogue: 0,0:05:48.43,0:05:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ada yang tidak beres dengannya.
Dialogue: 0,0:05:51.35,0:05:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu, Kamon?
Dialogue: 0,0:05:55.23,0:05:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mulai lagi.
Dialogue: 0,0:05:57.98,0:05:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga wanita itu...
Dialogue: 0,0:06:00.02,0:06:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount Arimiya dan istrinya\Nterjebak dalam kebakaran
Dialogue: 0,0:06:03.65,0:06:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah gempa bumi besar itu dan tewas.
Dialogue: 0,0:06:06.45,0:06:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra tunggal mereka\Nadalah pewaris properti itu.
Dialogue: 0,0:06:09.49,0:06:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pewaris?
Dialogue: 0,0:06:11.07,0:06:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, yang mengelola properti itu sekarang
Dialogue: 0,0:06:13.95,0:06:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah pasangan yang mengaku\Nsebagai kerabat.
Dialogue: 0,0:06:16.62,0:06:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang tahu siapa\Nyang menjadi pewaris sah properti itu.
Dialogue: 0,0:06:20.21,0:06:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tahu kasus serupa.
Dialogue: 0,0:06:24.34,0:06:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra keluarga bangsawan
Dialogue: 0,0:06:25.92,0:06:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang rumahnya diambil alih\Noleh orang asing.
Dialogue: 0,0:06:29.38,0:06:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu seorang wanita yang mengaku\Nsebagai kerabat
Dialogue: 0,0:06:31.39,0:06:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}muncul di rumah mantan dokter\Nyang merawatnya.
Dialogue: 0,0:06:35.64,0:06:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:06:38.73,0:06:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa wanita itu di salon itu?
Dialogue: 0,0:06:42.94,0:06:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:06:44.36,0:06:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada rumor yang beredar\Ndi kalangan orang kaya.
Dialogue: 0,0:06:48.61,0:06:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya, onmyoji Klan Goko
Dialogue: 0,0:06:51.45,0:06:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bisa memperpanjang umur\Nakan datang ke Ibu Kota.
Dialogue: 0,0:06:56.79,0:06:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu Shiranui?
Dialogue: 0,0:06:59.71,0:07:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu artinya
Dialogue: 0,0:07:01.00,0:07:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao akan diserang lagi?
Dialogue: 0,0:07:04.38,0:07:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumor tentang Klan Goko mulai menyebar
Dialogue: 0,0:07:07.38,0:07:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sekitar waktu wanita itu\Nmulai muncul di salon-salon itu.
Dialogue: 0,0:07:11.43,0:07:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa
Dialogue: 0,0:07:13.14,0:07:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bekerja untuk Shiranui.
Dialogue: 0,0:07:18.98,0:07:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Mao?
Dialogue: 0,0:07:20.48,0:07:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menemui wanita itu?
Dialogue: 0,0:07:22.77,0:07:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertarik.
Dialogue: 0,0:07:25.07,0:07:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi Logam muncul, dan sekarang
Dialogue: 0,0:07:27.73,0:07:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita kembali ke Shiranui, Penyihir Air.
Dialogue: 0,0:07:40.12,0:07:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang!
Dialogue: 0,0:07:42.04,0:07:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti Pak Kuchinawa dan temanmu...
Dialogue: 0,0:07:46.09,0:07:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Nekomata.
Dialogue: 0,0:07:48.30,0:07:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami merasa terhormat kau di sini!
Dialogue: 0,0:07:50.38,0:07:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nekomata?
Dialogue: 0,0:07:52.01,0:07:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama samaran yang buruk.
Dialogue: 0,0:07:55.30,0:07:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:07:58.39,0:08:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka dan Otoya,\Nsilakan tunggu di ruangan lain.
Dialogue: 0,0:08:01.56,0:08:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kenapa?
Dialogue: 0,0:08:04.35,0:08:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan yang menemani\Ntak diperbolehkan masuk.
Dialogue: 0,0:08:07.15,0:08:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan?
Dialogue: 0,0:08:09.03,0:08:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di salon ini,
Dialogue: 0,0:08:10.53,0:08:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang berkuasa datang\Nuntuk membahas topik rumit.
Dialogue: 0,0:08:15.12,0:08:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan pesta dansa.
Dialogue: 0,0:08:21.50,0:08:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku bisa memakai gaun.
Dialogue: 0,0:08:24.67,0:08:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tampak manis, Nona Nanoka.
Dialogue: 0,0:08:28.55,0:08:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:33.92,0:08:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah dengar rumornya?
Dialogue: 0,0:08:35.84,0:08:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang pembawa pesan onmyoji\Nyang bisa memperpanjang umur orang?
Dialogue: 0,0:08:39.47,0:08:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar mereka akan muncul malam ini.
Dialogue: 0,0:08:42.55,0:08:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumornya menyebar dengan cepat.
Dialogue: 0,0:08:45.02,0:08:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:46.36,0:08:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, wanita yang bekerja\Nsebagai pembawa pesan untuk Shiranui
Dialogue: 0,0:08:50.11,0:08:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memakai pertemuan seperti ini\Nuntuk mencari klien
Dialogue: 0,0:08:53.03,0:08:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ingin memperpanjang umur mereka.
Dialogue: 0,0:08:55.11,0:08:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu cara kerjanya?
Dialogue: 0,0:08:57.16,0:09:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi sepertinya mereka\Ndi tahap menerima pemesanan.
Dialogue: 0,0:09:00.99,0:09:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:09:02.70,0:09:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra perpanjangan umur Shiranui\Nsangat kasar.
Dialogue: 0,0:09:06.75,0:09:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut dia bisa tetap berbisnis
Dialogue: 0,0:09:08.92,0:09:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama ini di Kyoto tanpa ketahuan.
Dialogue: 0,0:09:11.59,0:09:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan Shiranui datang\Nke Ibu Kota Kekaisaran,
Dialogue: 0,0:09:14.76,0:09:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti seni rahasia Taizanfukun.
Dialogue: 0,0:09:17.97,0:09:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:19.93,0:09:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, katamu kau menyatu\Ndengan tubuh Byoki itu,
Dialogue: 0,0:09:25.35,0:09:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi apa yang terjadi pada kepalanya?
Dialogue: 0,0:09:28.27,0:09:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Byoki itu melarikan diri.
Dialogue: 0,0:09:33.53,0:09:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seni rahasia Taizanfukun
Dialogue: 0,0:09:36.24,0:09:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada di dalam kepala Byoki itu\Nyang memakan gulungan rahasia.
Dialogue: 0,0:09:40.87,0:09:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu mantranya.
Dialogue: 0,0:09:44.75,0:09:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Shiranui tidak tahu itu
Dialogue: 0,0:09:48.25,0:09:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia mengejarmu.
Dialogue: 0,0:09:59.93,0:10:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:10:01.56,0:10:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami merasa terhormat dengan kehadiranmu,\NNona Yurako.
Dialogue: 0,0:10:05.27,0:10:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam sejahtera.
Dialogue: 0,0:10:07.77,0:10:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yurako.
Dialogue: 0,0:10:11.57,0:10:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya tertutup, tapi dia pasti cantik.
Dialogue: 0,0:10:16.28,0:10:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon!
Dialogue: 0,0:10:17.86,0:10:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sekali.
Dialogue: 0,0:10:19.49,0:10:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:10:20.87,0:10:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:10:22.66,0:10:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau siapa?
Dialogue: 0,0:10:25.33,0:10:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu lagi.\NAku Kuchinawa.
Dialogue: 0,0:10:30.79,0:10:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja. Kuchinawa.
Dialogue: 0,0:10:33.67,0:10:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kabar?
Dialogue: 0,0:10:35.71,0:10:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima kasih.
Dialogue: 0,0:10:37.30,0:10:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon.
Dialogue: 0,0:10:40.14,0:10:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kuchinawa.
Dialogue: 0,0:10:43.01,0:10:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam, Nona Yurako.
Dialogue: 0,0:10:45.60,0:10:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya dia tahu tentang kami.
Dialogue: 0,0:10:48.94,0:10:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana sekarang?
Dialogue: 0,0:10:51.40,0:10:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Pak Kuchinawa,
Dialogue: 0,0:10:52.94,0:10:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang membuatmu sibuk belakangan ini?
Dialogue: 0,0:10:54.73,0:10:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini. Aku mengawasi kota.
Dialogue: 0,0:10:57.99,0:10:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:11:00.16,0:11:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:11:04.20,0:11:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku permisi untuk malam ini!
Dialogue: 0,0:11:08.33,0:11:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Yurako?
Dialogue: 0,0:11:10.46,0:11:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo ikuti dia, Mao.\N- Baik.
Dialogue: 0,0:11:16.13,0:11:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa mengejarnya.
Dialogue: 0,0:11:17.76,0:11:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu dia memasang penghalang?
Dialogue: 0,0:11:20.38,0:11:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia penyihir?
Dialogue: 0,0:11:22.43,0:11:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa wanita ini?
Dialogue: 0,0:11:25.60,0:11:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus kembali, Nona Nanoka.
Dialogue: 0,0:11:28.52,0:11:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya seperti ini taman orang kaya.
Dialogue: 0,0:11:32.40,0:11:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nanoka!\N- Apa? Mao?
Dialogue: 0,0:11:34.77,0:11:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan dia, Nanoka!
Dialogue: 0,0:11:41.03,0:11:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diakah yang bekerja untuk Shiranui?
Dialogue: 0,0:11:45.58,0:11:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halangi aku!
Dialogue: 0,0:11:58.84,0:12:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa itu?
Dialogue: 0,0:12:01.88,0:12:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya seperti\Nbanyak suara berbicara bersamaan!
Dialogue: 0,0:12:44.26,0:12:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana.
Dialogue: 0,0:12:48.47,0:12:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana?
Dialogue: 0,0:12:52.52,0:12:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:12:54.48,0:12:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin bertemu seperti ini.
Dialogue: 0,0:13:16.46,0:13:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cukup mengejutkan.
Dialogue: 0,0:13:19.63,0:13:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Nona Sana?
Dialogue: 0,0:13:28.18,0:13:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana
Dialogue: 0,0:13:31.43,0:13:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih hidup?
Dialogue: 0,0:13:41.36,0:13:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao bekerja sama dengan Byoki itu\Ndan melarikan diri!
Dialogue: 0,0:13:43.69,0:13:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:13:44.82,0:13:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru dibunuh!
Dialogue: 0,0:13:48.12,0:13:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana.
Dialogue: 0,0:13:51.62,0:13:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana.
Dialogue: 0,0:13:53.33,0:13:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana juga.
Dialogue: 0,0:13:55.29,0:13:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:13:56.29,0:13:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungnya dicabut dari dadanya.
Dialogue: 0,0:13:58.21,0:13:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao membunuhnya!
Dialogue: 0,0:14:02.30,0:14:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka.
Dialogue: 0,0:14:04.09,0:14:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:14:05.34,0:14:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon.
Dialogue: 0,0:14:07.18,0:14:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao membunuh Nona Sana.
Dialogue: 0,0:14:08.93,0:14:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:14:10.14,0:14:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, Hyakka.
Dialogue: 0,0:14:12.89,0:14:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang melihatnya.
Dialogue: 0,0:14:17.69,0:14:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga melihatnya.
Dialogue: 0,0:14:20.73,0:14:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hakubi.
Dialogue: 0,0:14:26.95,0:14:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihat jasad Nona Sana
Dialogue: 0,0:14:29.11,0:14:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan mataku sendiri.
Dialogue: 0,0:14:30.66,0:14:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga melihatnya, Kamon.
Dialogue: 0,0:14:32.70,0:14:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:33.62,0:14:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai saat jasadnya dikubur.
Dialogue: 0,0:14:36.50,0:14:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku yakin itu Nona Sana.
Dialogue: 0,0:14:40.42,0:14:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dia menyebut dirinya Yurako.
Dialogue: 0,0:14:44.17,0:14:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan dia bekerja untuk Shiranui.
Dialogue: 0,0:14:47.59,0:14:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:14:49.80,0:14:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia bangkit dari kubur?
Dialogue: 0,0:14:52.89,0:14:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil!
Dialogue: 0,0:14:55.14,0:14:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dari semua orang mengatakan itu?
Dialogue: 0,0:14:57.89,0:15:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggumu setelah tutup,\NNona Tenko.
Dialogue: 0,0:15:00.69,0:15:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:15:01.65,0:15:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,\Npemiliknya senang menampung kami.
Dialogue: 0,0:15:05.23,0:15:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, Pak.
Dialogue: 0,0:15:06.69,0:15:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati.
Dialogue: 0,0:15:09.24,0:15:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika wanita itu masih hidup,
Dialogue: 0,0:15:13.28,0:15:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti cerita tentang Dokter Mao membunuhnya\Nadalah bohong?
Dialogue: 0,0:15:17.25,0:15:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:18.29,0:15:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuduhan itu sangat membebani Tuan Mao.
Dialogue: 0,0:15:22.08,0:15:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, meski tahu wanita itu masih hidup,
Dialogue: 0,0:15:24.80,0:15:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tidak tampak senang.
Dialogue: 0,0:15:31.30,0:15:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Nona Sana?
Dialogue: 0,0:15:33.64,0:15:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak seperti yang kubayangkan.
Dialogue: 0,0:15:37.27,0:15:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halangi aku!
Dialogue: 0,0:15:39.69,0:15:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara itu...
Dialogue: 0,0:15:41.31,0:15:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin aku berkhayal.
Dialogue: 0,0:15:44.65,0:15:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah kuberi tahu Mao soal itu?
Dialogue: 0,0:15:47.57,0:15:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Mao,
Dialogue: 0,0:15:49.95,0:15:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika terpaksa, kau siap melawan Nona Sana?
Dialogue: 0,0:15:57.62,0:15:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi sebelumnya,
Dialogue: 0,0:15:59.29,0:16:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana
Dialogue: 0,0:16:01.17,0:16:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bekerja untuk Shiranui sekarang.
Dialogue: 0,0:16:03.88,0:16:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia musuh.
Dialogue: 0,0:16:06.17,0:16:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memperlakukan Nona Sana sebagai musuh...
Dialogue: 0,0:16:09.26,0:16:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa!
Dialogue: 0,0:16:10.84,0:16:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, diamlah.
Dialogue: 0,0:16:13.39,0:16:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun itu sudah lama sekali,
Dialogue: 0,0:16:14.97,0:16:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pernah menjadi wanita\Nyang berjanji akan kau nikahi, bukan?
Dialogue: 0,0:16:18.81,0:16:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyebutnya janji.
Dialogue: 0,0:16:22.23,0:16:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau mewarisi semua gulungan rahasia...
Dialogue: 0,0:16:26.44,0:16:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, itu artinya kau akan menjadi suamiku.
Dialogue: 0,0:16:30.53,0:16:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mematuhi keinginan ayahku.
Dialogue: 0,0:16:36.37,0:16:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana mencintai orang lain.
Dialogue: 0,0:16:39.75,0:16:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?
Dialogue: 0,0:16:41.33,0:16:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku tahu.
Dialogue: 0,0:16:43.83,0:16:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana hanya tertarik
Dialogue: 0,0:16:47.34,0:16:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepadanya.
Dialogue: 0,0:16:50.63,0:16:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak ada perebutan jabatan,
Dialogue: 0,0:16:53.38,0:16:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana akan menghabiskan\Nhidupnya bersamanya
Dialogue: 0,0:16:56.55,0:16:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menemukan kebahagiaan.
Dialogue: 0,0:17:00.18,0:17:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyelamatkannya.
Dialogue: 0,0:17:07.35,0:17:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya itu cinta tak berbalas.
Dialogue: 0,0:17:10.35,0:17:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tetap saja,\Nrasanya dia tidak pernah melupakannya.
Dialogue: 0,0:17:14.31,0:17:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao.
Dialogue: 0,0:17:16.36,0:17:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin bertemu seperti ini.
Dialogue: 0,0:17:22.70,0:17:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu apa maksudnya itu?
Dialogue: 0,0:17:26.25,0:17:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halangi aku!
Dialogue: 0,0:17:28.46,0:17:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan suara manusia.
Dialogue: 0,0:17:32.05,0:17:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberi tahu Mao.
Dialogue: 0,0:17:34.42,0:17:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao...
Dialogue: 0,0:17:35.51,0:17:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shh!
Dialogue: 0,0:17:42.77,0:17:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang datang.
Dialogue: 0,0:18:16.84,0:18:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:18:25.89,0:18:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:18:27.90,0:18:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat seperti shikigami.
Dialogue: 0,0:18:29.23,0:18:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shikigami, makhluk itu?
Dialogue: 0,0:18:31.44,0:18:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi Logam ini.
Dialogue: 0,0:18:33.32,0:18:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sama dengan yang ada\Ndi insiden militer itu.
Dialogue: 0,0:18:36.74,0:18:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia datang untukku?
Dialogue: 0,0:18:41.78,0:18:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu, aku berteman\Ndengan pedagang Kansai yang kaya
Dialogue: 0,0:18:45.87,0:18:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia mengizinkanku\Nnaik kapal menuju Edo.
Dialogue: 0,0:18:50.25,0:18:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski langit cerah\Ndan pelayarannya tampak lancar,
Dialogue: 0,0:18:54.21,0:18:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kapal itu tiba-tiba terbalik\Ndan kami hampir mati.
Dialogue: 0,0:18:58.22,0:19:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kami menabrak paus,
Dialogue: 0,0:19:01.14,0:19:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku melihat sesuatu yang mirip\Nonmyoji raksasa berenang menjauh.
Dialogue: 0,0:19:05.18,0:19:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira mataku menipuku.
Dialogue: 0,0:19:08.56,0:19:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, setelah kupikirkan,
Dialogue: 0,0:19:09.90,0:19:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa itu perbuatan Shiranui juga?
Dialogue: 0,0:19:12.73,0:19:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:13.86,0:19:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti Mokuzu,
Dialogue: 0,0:19:17.15,0:19:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}salah satu bawahan Shiranui.
Dialogue: 0,0:19:19.78,0:19:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga diincar, Hyakka?
Dialogue: 0,0:19:22.70,0:19:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matamu...
Dialogue: 0,0:19:24.12,0:19:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:25.24,0:19:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Itu sekitar waktu perang dengan Rusia.
Dialogue: 0,0:19:31.33,0:19:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini...
Dialogue: 0,0:19:32.71,0:19:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi Logam?
Dialogue: 0,0:19:41.43,0:19:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, bawa Otoya bersamamu dan lari.
Dialogue: 0,0:19:44.05,0:19:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Namun...
Dialogue: 0,0:19:45.35,0:19:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang diincarnya.
Dialogue: 0,0:20:02.95,0:20:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berhasil?\N- Ya.
Dialogue: 0,0:20:05.41,0:20:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu shikigami Logam.
Dialogue: 0,0:20:08.16,0:20:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api melelehkan Logam.
Dialogue: 0,0:20:10.16,0:20:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api mengalahkan Logam.
Dialogue: 0,0:20:12.42,0:20:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya Tuan Mao\Nmenggunakan katashiro Api.
Dialogue: 0,0:20:21.97,0:20:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menghentikannya?
Dialogue: 0,0:20:32.60,0:20:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mao!\N- Tuan Mao!
Dialogue: 0,0:20:43.61,0:20:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hilang.
Dialogue: 0,0:20:44.99,0:20:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:20:46.03,0:20:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, apa yang terjadi?
Dialogue: 0,0:20:47.78,0:20:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao...
Dialogue: 0,0:20:50.20,0:20:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia diculik?
Dialogue: 0,0:20:51.54,0:20:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Sepertinya makhluk itu\Nmenggunakan semacam penghalang.
Dialogue: 0,0:20:54.33,0:20:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:20:55.92,0:20:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir hanya Shiranui
Dialogue: 0,0:20:57.54,0:20:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mencoba menangkap Mao hidup-hidup?
Dialogue: 0,0:20:59.55,0:21:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu shikigami Logam mekanis.
Dialogue: 0,0:21:02.72,0:21:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tertembak.
Dialogue: 0,0:21:04.84,0:21:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menolongnya!
Dialogue: 0,0:21:17.44,0:21:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Hagunsei...
Dialogue: 0,0:21:19.44,0:21:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang itu berusaha kembali ke Tuan Mao.
Dialogue: 0,0:21:24.66,0:21:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon! Bawa aku ke Mao!
Dialogue: 0,0:21:44.13,0:21:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:21:45.30,0:21:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jejak energi Logam.
Dialogue: 0,0:21:47.18,0:21:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita ikuti.
Dialogue: 0,0:21:48.22,0:21:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:21:59.82,0:22:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana aku?
Dialogue: 0,0:22:02.65,0:22:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air...
Dialogue: 0,0:22:20.54,0:22:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui...
Dialogue: 0,0:22:36.94,0:22:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:22:38.52,0:22:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar kau, Mao.
Dialogue: 0,0:22:41.52,0:22:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak hari itu,
Dialogue: 0,0:22:43.19,0:22:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak sehari pun berlalu tanpa aku mengingat
Dialogue: 0,0:22:45.82,0:22:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}betapa aku membencimu.
Dialogue: 0,0:22:48.82,0:22:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membenciku?
Dialogue: 0,0:24:49.07,0:24:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gua Tulang Putih adalah labirin alami
Dialogue: 0,0:24:53.78,0:24:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan banyak terowongan bercabang.
Dialogue: 0,0:24:55.57,0:24:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya perlu keluar hidup-hidup.
Dialogue: 0,0:24:57.28,0:24:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membunuhnya, bukan?
Dialogue: 0,0:24:59.75,0:25:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Karena itu...\N- Jawab aku, Shiranui.
Dialogue: 0,0:25:02.83,0:25:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Nona Sana masih hidup dan bersamamu?
Dialogue: 0,0:25:06.75,0:25:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dia bisa hidup?
Dialogue: 0,0:25:08.34,0:25:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa Nona Sana?
Dialogue: 0,0:25:10.46,0:25:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berita!
Dialogue: 0,0:25:12.42,0:25:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembantaian misterius di Desa Hitokabe!
Dialogue: 0,0:25:15.30,0:25:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Shiranui".
