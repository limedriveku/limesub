Dialogue: 0,0:02:00.74,0:02:05.91,sign,,0000,0000,0000,,20 TAHUN LALU, 1904 ERA MEIJI
Dialogue: 0,0:02:13.50,0:02:15.67,sign,,0000,0000,0000,,"HYAKKA"
Dialogue: 0,0:04:51.62,0:04:55.08,sign,,0000,0000,0000,,HAKUBI
Dialogue: 0,0:05:24.24,0:05:25.11,sign,,0000,0000,0000,,"MAO"
Dialogue: 0,0:06:26.55,0:06:27.97,sign,,0000,0000,0000,,OTOYA
Dialogue: 0,0:07:11.12,0:07:15.02,sign,,0000,0000,0000,,"HAKUBI"
Dialogue: 0,0:10:27.41,0:10:28.42,sign,,0000,0000,0000,,KAYU, API, TANAH, AIR, LOGAM
Dialogue: 0,0:19:13.07,0:19:15.40,sign,,0000,0000,0000,,"KAYU, API, TANAH, AIR, LOGAM"
Dialogue: 0,0:22:45.74,0:22:47.15,sign,,0000,0000,0000,,"KIBA NANOKA"
Dialogue: 0,0:22:47.24,0:22:48.07,sign,,0000,0000,0000,,KIBA NANOKA
Dialogue: 0,0:24:49.03,0:24:49.86,sign,,0000,0000,0000,,SELANJUTNYA
Dialogue: 0,0:24:54.16,0:24:55.62,sign,,0000,0000,0000,,"EFISIEN"
Dialogue: 0,0:00:20.27,0:00:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini aneh, Hyakka?
Dialogue: 0,0:00:22.52,0:00:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:00:24.35,0:00:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembantaian di Desa Hitokabe
Dialogue: 0,0:00:27.23,0:00:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terjadi kurang dari tiga hari lalu,
Dialogue: 0,0:00:29.98,0:00:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak ada satu pun reporter\Natau polisi di sini.
Dialogue: 0,0:00:34.49,0:00:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya koran dan polisi\Ntelah diminta untuk menjauh.
Dialogue: 0,0:00:39.33,0:00:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu juga sama.
Dialogue: 0,0:00:43.54,0:00:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka
Dialogue: 0,0:00:45.71,0:00:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiba-tiba muncul.
Dialogue: 0,0:00:53.51,0:00:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan?
Dialogue: 0,0:00:54.42,0:00:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang di desa dibantai.
Dialogue: 0,0:00:57.55,0:00:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir tidak bisa kabur,
Dialogue: 0,0:00:59.85,0:01:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi insiden itu tidak pernah masuk koran\Natau bahkan memicu rumor.
Dialogue: 0,0:01:05.09,0:01:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kali ini, insiden itu masuk koran.
Dialogue: 0,0:01:08.77,0:01:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka, kurasa ini…
Dialogue: 0,0:01:19.32,0:01:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya insiden di desa ini
Dialogue: 0,0:01:21.62,0:01:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah jebakan untuk memancing kita.
Dialogue: 0,0:01:25.25,0:01:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tapi…
Dialogue: 0,0:01:28.54,0:01:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau juga akan muncul, Hyakka.
Dialogue: 0,0:01:33.67,0:01:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek! Apa kau dalang di balik\Norang-orangan sawah 20 tahun lalu?
Dialogue: 0,0:01:38.55,0:01:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:40.35,0:01:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, kita berdua
Dialogue: 0,0:01:41.52,0:01:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak punya kesempatan untuk melihat\Nwajah satu sama lain dengan baik.
Dialogue: 0,0:01:45.10,0:01:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau melihat wajahku?
Dialogue: 0,0:01:47.52,0:01:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum kucungkil sisa matamu?
Dialogue: 0,0:01:53.65,0:01:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini orangnya,
Dialogue: 0,0:01:56.03,0:01:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang melakukan itu pada mata Hyakka?
Dialogue: 0,0:02:11.17,0:02:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:02:13.50,0:02:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang melakukan ini?
Dialogue: 0,0:02:17.34,0:02:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa itu?
Dialogue: 0,0:02:22.85,0:02:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orangan sawah logam?
Dialogue: 0,0:02:37.86,0:02:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura logam?
Dialogue: 0,0:02:41.99,0:02:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada onmyoji di belakang mereka!
Dialogue: 0,0:02:54.17,0:02:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu dia?
Dialogue: 0,0:04:55.58,0:04:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Ini semua perbuatanmu, bukan?
Dialogue: 0,0:04:58.71,0:05:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyeret penduduk desa\Nyang tidak bersalah ke dalam masalah ini.
Dialogue: 0,0:05:02.13,0:05:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster sialan!
Dialogue: 0,0:05:05.93,0:05:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa yang sial.
Dialogue: 0,0:05:08.51,0:05:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua karena kau kebetulan\Nada di sana, Hyakka.
Dialogue: 0,0:05:13.10,0:05:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:05:14.64,0:05:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu tempat pengujian yang bagus\Nuntuk prajuritku.
Dialogue: 0,0:05:21.57,0:05:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persetan kau!
Dialogue: 0,0:05:24.24,0:05:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka!
Dialogue: 0,0:05:34.20,0:05:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pita baja ini identik dengan yang\Ndigunakan shikigami yang menyerangku.
Dialogue: 0,0:05:42.34,0:05:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria ini juga bekerja dengan Shiranui.
Dialogue: 0,0:05:47.01,0:05:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?
Dialogue: 0,0:05:53.64,0:05:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur, Mao!
Dialogue: 0,0:05:55.02,0:05:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia milikku!
Dialogue: 0,0:06:02.94,0:06:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelindung!
Dialogue: 0,0:06:25.59,0:06:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengannya…
Dialogue: 0,0:06:30.93,0:06:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Lenganmu itu…\NApa itu karena yang terjadi saat itu?
Dialogue: 0,0:06:36.31,0:06:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meremehkanmu, berpikir kau hanya bocah.
Dialogue: 0,0:06:42.81,0:06:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama berabad-abad,
Dialogue: 0,0:06:44.40,0:06:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak pernah terluka\Noleh siapa pun dalam pertempuran…
Dialogue: 0,0:06:49.74,0:06:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun ini sama sekali\Ntidak mengganggu kenyamananku.
Dialogue: 0,0:06:58.79,0:06:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:07:07.84,0:07:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya masalah adalah…
Dialogue: 0,0:07:11.12,0:07:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum menua sedikit pun.
Dialogue: 0,0:07:16.01,0:07:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hakubi!
Dialogue: 0,0:07:22.02,0:07:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao membunuh Nona Sana…
Dialogue: 0,0:07:25.19,0:07:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:07:26.82,0:07:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah, Hyakka.
Dialogue: 0,0:07:30.32,0:07:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga melihatnya.
Dialogue: 0,0:07:32.66,0:07:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao mengkhianati Klan Goko…
Dialogue: 0,0:07:35.78,0:07:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia musuh bebuyutan kita!
Dialogue: 0,0:07:38.75,0:07:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga dipanggil ke Goshikido, Hakubi?
Dialogue: 0,0:07:42.58,0:07:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:44.00,0:07:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka…
Dialogue: 0,0:07:45.46,0:07:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau juga dipanggil.
Dialogue: 0,0:07:49.84,0:07:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melawanmu 20 tahun lalu\Nadalah berkah terselubung.
Dialogue: 0,0:07:56.31,0:07:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belajar bahwa kita\Nyang dipanggil ke Goshikido
Dialogue: 0,0:07:59.93,0:08:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa saling melukai dan membunuh.
Dialogue: 0,0:08:07.52,0:08:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara anggota Klan Goko,
Dialogue: 0,0:08:10.82,0:08:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hakubi adalah salah satu\Nyang paling dipercaya Guru.
Dialogue: 0,0:08:13.11,0:08:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ditugaskan merapal banyak kutukan.
Dialogue: 0,0:08:18.04,0:08:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru memberinya gulungan
Dialogue: 0,0:08:21.21,0:08:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dalam beberapa hari, rumor menyebar\Nbahwa seorang bangsawan telah meninggal,
Dialogue: 0,0:08:25.79,0:08:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diikuti dengan pengiriman\Nberbagai hadiah ke kediaman.
Dialogue: 0,0:08:31.34,0:08:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa isi gulungan yang diberikan Guru
Dialogue: 0,0:08:35.09,0:08:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setiap kali dia memesan kutukan?
Dialogue: 0,0:08:39.17,0:08:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, Klan Goko adalah tempat\Naku merasa benar-benar betah.
Dialogue: 0,0:08:45.65,0:08:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Mao,
Dialogue: 0,0:08:47.94,0:08:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengkhianatanmu menyebabkan\Nkejatuhan Klan Goko.
Dialogue: 0,0:08:53.40,0:08:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama berabad-abad,
Dialogue: 0,0:08:56.03,0:08:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bertarung dalam banyak pertempuran.
Dialogue: 0,0:09:01.16,0:09:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyadari bahwa aku lebih cocok\Ndi medan perang
Dialogue: 0,0:09:04.12,0:09:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daripada bersembunyi dalam bayang-bayang\Nmerapal mantra.
Dialogue: 0,0:09:13.09,0:09:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mati berkali-kali,\Natau merasa seperti itu.
Dialogue: 0,0:09:17.34,0:09:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setiap kali aku bangun,
Dialogue: 0,0:09:20.47,0:09:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setiap luka yang kuderita\Ndalam pertempuran menghilang tanpa jejak.
Dialogue: 0,0:09:25.98,0:09:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka,
Dialogue: 0,0:09:27.48,0:09:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah kau juga begitu?
Dialogue: 0,0:09:30.90,0:09:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku juga.
Dialogue: 0,0:09:33.94,0:09:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya, 20 tahun lalu, Hyakka…
Dialogue: 0,0:09:38.62,0:09:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kita bertemu dan bertarung
Dialogue: 0,0:09:41.45,0:09:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku sadar lenganku yang putus
Dialogue: 0,0:09:43.75,0:09:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan luka bakar di wajahku tak akan sembuh,
Dialogue: 0,0:09:48.08,0:09:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sangat senang.
Dialogue: 0,0:09:55.84,0:09:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena saat itulah aku tahu
Dialogue: 0,0:09:57.84,0:09:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada akhirnya!
Dialogue: 0,0:10:05.23,0:10:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lenganmu berguna sekali.
Dialogue: 0,0:10:06.94,0:10:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukabulkan keinginanmu\Ndan mengakhiri ini dengan cepat.
Dialogue: 0,0:10:23.37,0:10:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya,
Dialogue: 0,0:10:25.04,0:10:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api mengalahkan Logam.
Dialogue: 0,0:10:28.50,0:10:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hyakka seharusnya unggul,
Dialogue: 0,0:10:31.79,0:10:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi itu hanya saat kedua penyihir\Nseimbang dalam energi elemen.
Dialogue: 0,0:10:36.17,0:10:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi Logam Hakubi
Dialogue: 0,0:10:39.72,0:10:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat kuat.
Dialogue: 0,0:10:53.48,0:10:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah…
Dialogue: 0,0:10:59.53,0:11:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Mungkinkah?
Dialogue: 0,0:11:02.87,0:11:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, apa itu pedang pemberian Guru?
Dialogue: 0,0:11:07.29,0:11:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Hagunsei?
Dialogue: 0,0:11:10.87,0:11:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin?
Dialogue: 0,0:11:13.00,0:11:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang terkutuk itu dimaksudkan\Nuntuk menandaimu sebagai tumbal.
Dialogue: 0,0:11:16.67,0:11:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak pernah dimaksudkan\Nuntuk melindungimu.
Dialogue: 0,0:11:20.63,0:11:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pedang terkutuk,\Nbermandikan darah Byoki.
Dialogue: 0,0:11:25.22,0:11:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga dikutuk oleh Byoki.
Dialogue: 0,0:11:29.60,0:11:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikutuk, katamu?
Dialogue: 0,0:11:32.56,0:11:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuatku tertawa, Mao.
Dialogue: 0,0:11:34.44,0:11:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menggunakan pedang terkutuk itu
Dialogue: 0,0:11:37.78,0:11:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menerima perlindungan Byoki!
Dialogue: 0,0:11:41.99,0:11:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, berikan tubuhmu.
Dialogue: 0,0:11:47.58,0:11:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlindungan Byoki?
Dialogue: 0,0:11:51.08,0:11:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa peduli?!
Dialogue: 0,0:11:53.50,0:11:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek…
Dialogue: 0,0:11:54.92,0:11:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meleleh saja!
Dialogue: 0,0:11:58.88,0:11:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mutiara?
Dialogue: 0,0:12:00.72,0:12:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci\Nharus menggunakan energi Air, tapi…
Dialogue: 0,0:12:16.23,0:12:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah lupa, Hakubi?
Dialogue: 0,0:12:18.19,0:12:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua puluh tahun lalu, aku membakar\Nsemua orang-orangan sawahmu menjadi abu.
Dialogue: 0,0:12:24.66,0:12:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada api…
Dialogue: 0,0:12:32.00,0:12:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka!
Dialogue: 0,0:12:34.29,0:12:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia baru saja menggunakan\Nenergi Air dari mutiara
Dialogue: 0,0:12:36.25,0:12:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyegel mantra Hyakka?
Dialogue: 0,0:12:39.05,0:12:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Aku tak bisa melepaskannya.
Dialogue: 0,0:12:41.55,0:12:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka…
Dialogue: 0,0:12:42.93,0:12:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membunuhmu dengan benar nanti.
Dialogue: 0,0:12:45.97,0:12:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hakubi.
Dialogue: 0,0:12:48.81,0:12:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bekerja sama dengan Shiranui?
Dialogue: 0,0:12:52.18,0:12:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:53.52,0:12:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengatakan hal yang sama tentangmu.
Dialogue: 0,0:12:58.11,0:13:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bergabung dengan Byoki
Dialogue: 0,0:13:00.61,0:13:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengkhianati Klan Goko.
Dialogue: 0,0:13:04.03,0:13:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao,
Dialogue: 0,0:13:05.36,0:13:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau adalah
Dialogue: 0,0:13:07.37,0:13:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}musuh bebuyutan Klan Goko!
Dialogue: 0,0:13:18.88,0:13:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adalah musuh bebuyutan Klan Goko!
Dialogue: 0,0:13:28.47,0:13:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memihak Klan Goko palsu ini?
Dialogue: 0,0:13:33.43,0:13:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Palsu?
Dialogue: 0,0:13:35.23,0:13:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin soal itu?
Dialogue: 0,0:13:40.36,0:13:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kali aku mendengar rumor\Ntentang Klan Goko
Dialogue: 0,0:13:43.32,0:13:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjelang akhir era Tokugawa.
Dialogue: 0,0:13:47.03,0:13:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang yang mengaku\Ndari Klan Goko yang gugur
Dialogue: 0,0:13:50.70,0:13:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dikatakan melakukan layanan
Dialogue: 0,0:13:52.24,0:13:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perpanjangan hidup dan kutukan\Nuntuk para bangsawan.
Dialogue: 0,0:13:57.00,0:13:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi mencarinya.
Dialogue: 0,0:13:58.96,0:14:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin itu peniru\Nyang memakai nama Klan Goko.
Dialogue: 0,0:14:02.55,0:14:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat membunuh peniru itu.
Dialogue: 0,0:14:06.63,0:14:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi
Dialogue: 0,0:14:07.93,0:14:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke Pantai Utara tempat Penyihir Air\Ndari Klan Goko berlatih,
Dialogue: 0,0:14:12.22,0:14:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menemukan kuil\Nyang dilindungi oleh penghalang…
Dialogue: 0,0:14:18.56,0:14:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyelinap melewati penghalang\Ntanpa kesulitan.
Dialogue: 0,0:14:22.27,0:14:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mereka pasti\Nmembiarkanku masuk dengan sengaja.
Dialogue: 0,0:14:27.74,0:14:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menungguku adalah wanita itu.
Dialogue: 0,0:14:33.66,0:14:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memiliki aura jahat,\Ngelap, dan familiar.
Dialogue: 0,0:14:38.58,0:14:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan peniru.
Dialogue: 0,0:14:41.04,0:14:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jelas seorang wanita dari Klan Goko.
Dialogue: 0,0:14:44.42,0:14:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang wanita?
Dialogue: 0,0:14:45.84,0:14:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:14:50.01,0:14:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, kau sudah bertemu dengannya, bukan?
Dialogue: 0,0:14:53.85,0:14:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Yurako.
Dialogue: 0,0:14:59.06,0:15:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana?
Dialogue: 0,0:15:01.44,0:15:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Hakubi! Berengsek!
Dialogue: 0,0:15:03.44,0:15:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelap? Jahat? Siapa yang kau bicarakan?
Dialogue: 0,0:15:07.61,0:15:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu dirilah, Hyakka.
Dialogue: 0,0:15:09.53,0:15:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan rasa hormat\Nsaat kau menyebut namaku.
Dialogue: 0,0:15:18.29,0:15:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, biar kuberi tahu.
Dialogue: 0,0:15:20.96,0:15:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu tidak seperti yang kau pikirkan.
Dialogue: 0,0:15:25.96,0:15:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau tahu?
Dialogue: 0,0:15:31.47,0:15:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus mencari tahu sendiri.
Dialogue: 0,0:15:35.22,0:15:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera membiarkanmu\Nbertemu dengannya.
Dialogue: 0,0:15:45.52,0:15:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao!
Dialogue: 0,0:15:47.19,0:15:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, aku akan membawamu kembali hidup-hidup.
Dialogue: 0,0:15:52.07,0:15:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tujuanmu
Dialogue: 0,0:15:53.70,0:15:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra rahasia Taizanfukun?
Dialogue: 0,0:15:58.62,0:16:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tertarik\Ndengan mantra perpanjangan hidup.
Dialogue: 0,0:16:03.38,0:16:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Shiranui bersikeras mempelajarinya.
Dialogue: 0,0:16:13.22,0:16:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengan Berlianku meleleh?
Dialogue: 0,0:16:33.45,0:16:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao! Sial!
Dialogue: 0,0:16:36.45,0:16:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui memberitahuku
Dialogue: 0,0:16:39.29,0:16:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa darah Byoki mengalir\Ndi pembuluh darahmu, Mao.
Dialogue: 0,0:16:43.17,0:16:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang itu racun mematikan
Dialogue: 0,0:16:44.92,0:16:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membakar dan melelehkan\Nsiapa pun yang menyentuhnya.
Dialogue: 0,0:16:49.30,0:16:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seharusnya tidak melawanku…
Dialogue: 0,0:16:52.30,0:16:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao… Jangan bilang kau sudah mati?
Dialogue: 0,0:17:18.91,0:17:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao…
Dialogue: 0,0:17:21.70,0:17:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu Mao?
Dialogue: 0,0:17:24.71,0:17:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti sekarang, Hyakka.
Dialogue: 0,0:17:27.29,0:17:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada hari saat kediaman terbakar,
Dialogue: 0,0:17:29.92,0:17:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak pernah melihat monster ini, bukan?
Dialogue: 0,0:17:34.30,0:17:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kau terlalu pengecut,\Nbersembunyi demi nyawamu.
Dialogue: 0,0:18:03.83,0:18:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantra Hakubi tidak mempan!
Dialogue: 0,0:18:12.88,0:18:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini kekuatan Byoki…
Dialogue: 0,0:18:17.13,0:18:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao,
Dialogue: 0,0:18:18.47,0:18:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah menyatu dengan Byoki,
Dialogue: 0,0:18:20.80,0:18:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bukan lagi sekadar musuh Klan Goko.
Dialogue: 0,0:18:22.93,0:18:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau musuh semua onmyoji!
Dialogue: 0,0:18:25.39,0:18:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onmyoji?
Dialogue: 0,0:18:27.06,0:18:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:18:29.90,0:18:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghukummu!
Dialogue: 0,0:18:34.74,0:18:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum masuk Klan Goko,
Dialogue: 0,0:18:37.45,0:18:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku belum pernah melihat kucing.
Dialogue: 0,0:18:41.16,0:18:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka, kau juga begitu, kan?
Dialogue: 0,0:18:45.00,0:18:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:18:47.29,0:18:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya…
Dialogue: 0,0:18:49.25,0:18:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada masa itu,
Dialogue: 0,0:18:50.42,0:18:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kudengar kucing hanya dipelihara\Noleh keluarga bangsawan.
Dialogue: 0,0:18:54.51,0:18:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haimaru Nona Sana adalah kucing pertama\Nyang pernah kulihat.
Dialogue: 0,0:18:59.43,0:19:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:19:01.80,0:19:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing ada di luar dunia Onmyodo.
Dialogue: 0,0:19:05.77,0:19:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini makhluk yang bukan milik Lima Elemen.
Dialogue: 0,0:19:10.52,0:19:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,
Dialogue: 0,0:19:13.07,0:19:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka ada di luar siklus perlawanan unsur
Dialogue: 0,0:19:15.48,0:19:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga kebal terhadap mantra elemen.
Dialogue: 0,0:19:19.99,0:19:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa Guru menyambut\Nmakhluk mengerikan itu
Dialogue: 0,0:19:23.78,0:19:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke dalam kediaman?
Dialogue: 0,0:19:27.29,0:19:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada satu jawaban.
Dialogue: 0,0:19:29.87,0:19:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru berniat mengubah kucing itu\Nmenjadi kodoku paling menakutkan,
Dialogue: 0,0:19:33.59,0:19:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki, dan membuatnya melayaninya.
Dialogue: 0,0:19:39.34,0:19:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggunakan Byoki,\Nyang tidak terpengaruh mantra Onmyo
Dialogue: 0,0:19:41.64,0:19:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai shikigami-nya\Nakan membuatnya tidak terkalahkan.
Dialogue: 0,0:19:44.35,0:19:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebaliknya,
Dialogue: 0,0:19:45.76,0:19:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki mengamuk.
Dialogue: 0,0:19:48.10,0:19:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih buruk lagi,
Dialogue: 0,0:19:49.64,0:19:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memilih Mao si pengkhianat\Ndan mengikat dirinya padanya.
Dialogue: 0,0:19:54.40,0:19:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hakubi tidak tahu\NTuan Mao menolak Byoki…
Dialogue: 0,0:19:58.15,0:20:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hanya tubuhnya yang menyatu dengannya?
Dialogue: 0,0:20:02.24,0:20:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster mengerikan!
Dialogue: 0,0:20:15.75,0:20:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira Hakubi sialan itu bilang
Dialogue: 0,0:20:17.25,0:20:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra Onmyo tidak akan mempan\Npada Byoki…
Dialogue: 0,0:20:20.88,0:20:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hyakka.
Dialogue: 0,0:20:22.68,0:20:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan lenganmu yang disegel.
Dialogue: 0,0:20:24.89,0:20:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:26.10,0:20:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lihat apakah ini berhasil.
Dialogue: 0,0:20:27.93,0:20:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rambutku.
Dialogue: 0,0:20:30.06,0:20:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya menumbuhkan satu\Nyang panjang? Aneh sekali.
Dialogue: 0,0:20:42.82,0:20:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku tahu tak ada penghalang biasa\Nyang bisa menghentikannya.
Dialogue: 0,0:20:47.83,0:20:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan aku!
Dialogue: 0,0:21:01.26,0:21:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuh ekor telah dipotong,
Dialogue: 0,0:21:02.97,0:21:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan transformasinya berbalik…
Dialogue: 0,0:21:05.55,0:21:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jimat terkutuk\Nyang dia pasang di lengannya…
Dialogue: 0,0:21:08.18,0:21:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mirip dengan jimat di Tombak Taima
Dialogue: 0,0:21:12.23,0:21:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang hampir membunuh Byoki…
Dialogue: 0,0:21:16.86,0:21:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya berhasil.
Dialogue: 0,0:21:29.45,0:21:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hakubi…
Dialogue: 0,0:21:31.20,0:21:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah kau!
Dialogue: 0,0:21:35.08,0:21:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka…
Dialogue: 0,0:21:37.00,0:21:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau merusak segelnya?
Dialogue: 0,0:21:39.38,0:21:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka. Aku akan membunuhmu lain kali.
Dialogue: 0,0:21:43.72,0:21:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan aku sekarang, Berengsek!
Dialogue: 0,0:21:47.76,0:21:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur.
Dialogue: 0,0:21:49.05,0:21:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:21:58.36,0:21:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:21:59.69,0:22:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia kembali normal?
Dialogue: 0,0:22:02.03,0:22:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mao! Sadarlah!
Dialogue: 0,0:22:09.24,0:22:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tertidur…
Dialogue: 0,0:22:11.70,0:22:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sangat lelah.
Dialogue: 0,0:22:14.08,0:22:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:19.25,0:22:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kau di sini untuk membantu kami.
Dialogue: 0,0:22:22.50,0:22:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat menyebalkan.
Dialogue: 0,0:22:25.22,0:22:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jauh lebih kuat daripada dugaanku.
Dialogue: 0,0:22:29.01,0:22:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali!
Dialogue: 0,0:22:30.76,0:22:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api lebih kuat daripada Logam.
Dialogue: 0,0:22:33.72,0:22:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberi tahu Nona Nanoka\Napa yang kau lakukan.
Dialogue: 0,0:22:36.02,0:22:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, katakan padanya.
Dialogue: 0,0:22:37.98,0:22:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, dia tak menganggapku serius.
Dialogue: 0,0:22:45.74,0:22:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao? Otoya?
Dialogue: 0,0:22:48.82,0:22:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tidak mungkin!
Dialogue: 0,0:22:52.45,0:22:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang di sini? Aku sendirian!
Dialogue: 0,0:23:06.22,0:23:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki ada di luar dunia Onmyo…
Dialogue: 0,0:23:12.01,0:23:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku bisa mengendalikan Mao…
Dialogue: 0,0:23:15.72,0:23:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu akan menarik.
Dialogue: 0,0:24:49.94,0:24:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berselera makan.
Dialogue: 0,0:24:52.24,0:24:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leherku terasa kaku…
Dialogue: 0,0:24:54.16,0:24:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu obat.
Dialogue: 0,0:24:55.70,0:24:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubantu, Otoya.
Dialogue: 0,0:24:57.37,0:24:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, ada kegilaan besar
Dialogue: 0,0:24:59.08,0:25:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk kutukan\Nyang mengendalikan kodoku kucing.
Dialogue: 0,0:25:01.12,0:25:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa arti "maogui" dalam bahasa Jepang?
Dialogue: 0,0:25:04.83,0:25:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Iblis kucing"
Dialogue: 0,0:25:06.25,0:25:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau Byoki.
Dialogue: 0,0:25:07.88,0:25:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang yang tersisa\Nhanyalah tumpukan tanah.
Dialogue: 0,0:25:10.09,0:25:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Maksudmu tubuhnya\Nberubah menjadi tanah?
Dialogue: 0,0:25:14.72,0:25:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Maogui".
