Dialogue: 0,0:04:03.11,0:04:05.07,sign,,0000,0000,0000,,HYAKKA
Dialogue: 0,0:04:43.40,0:04:45.78,sign,,0000,0000,0000,,"PEMIMPIN KLAN GOKO"
Dialogue: 0,0:05:13.48,0:05:15.44,sign,,0000,0000,0000,,SANA
Dialogue: 0,0:12:15.90,0:12:19.03,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:13:40.90,0:13:42.48,sign,,0000,0000,0000,,"TONRO, KOMON, ROKUSON"
Dialogue: 0,0:13:42.57,0:13:43.49,sign,,0000,0000,0000,,"MONGOKU"
Dialogue: 0,0:13:43.57,0:13:45.15,sign,,0000,0000,0000,,"RENCHO, MUGOKU, HAGUN"
Dialogue: 0,0:13:45.24,0:13:47.28,sign,,0000,0000,0000,,"MUGOKU, HAGUN"
Dialogue: 0,0:13:47.36,0:13:50.33,sign,,0000,0000,0000,,"TONRO, KOMON, ROKUSON, MONGOKU"
Dialogue: 0,0:16:17.39,0:16:20.10,sign,,0000,0000,0000,,IBARAKI TANEHIKO
Dialogue: 0,0:16:26.44,0:16:27.77,sign,,0000,0000,0000,,KUCHINAWA
