Dialogue: 0,0:00:29.19,0:00:31.19,sign,,0000,0000,0000,,"KIBA NANOKA, OTOYA"
Dialogue: 0,0:01:07.10,0:01:08.15,sign,,0000,0000,0000,,"MAO"
Dialogue: 0,0:02:35.73,0:02:38.49,sign,,0000,0000,0000,,MAO
