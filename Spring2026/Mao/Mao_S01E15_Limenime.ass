Dialogue: 0,0:02:10.96,0:02:14.09,sign,,0000,0000,0000,,SHIRANUI
Dialogue: 0,0:02:19.09,0:02:22.35,sign,,0000,0000,0000,,SHIRANUI
Dialogue: 0,0:02:37.52,0:02:41.48,sign,,0000,0000,0000,,"GURU KLAN GOKO"
Dialogue: 0,0:05:17.35,0:05:20.45,sign,,0000,0000,0000,,"MAO"
Dialogue: 0,0:06:16.12,0:06:16.96,sign,,0000,0000,0000,,NANOKA KIBA
Dialogue: 0,0:06:19.83,0:06:21.29,sign,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:06:29.13,0:06:31.09,sign,,0000,0000,0000,,"HYAKKA, KAMON"
Dialogue: 0,0:12:26.66,0:12:28.58,sign,,0000,0000,0000,,YURAKO
Dialogue: 0,0:12:37.46,0:12:40.13,sign,,0000,0000,0000,,"HAKUBI"
Dialogue: 0,0:18:38.28,0:18:39.41,sign,,0000,0000,0000,,"SANA"
Dialogue: 0,0:24:49.19,0:24:50.36,sign,,0000,0000,0000,,"SELANJUTNYA"
Dialogue: 0,0:00:26.02,0:00:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air…
Dialogue: 0,0:00:30.44,0:00:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar kau, Mao…
Dialogue: 0,0:00:35.49,0:00:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui…
Dialogue: 0,0:02:23.72,0:02:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika diingat lagi,
Dialogue: 0,0:02:26.14,0:02:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu pasti ritual seleksi.
Dialogue: 0,0:02:30.23,0:02:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua murid yang berlatih bersama\Nsejak kecil dikumpulkan.
Dialogue: 0,0:02:35.48,0:02:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gua Tulang Putih adalah labirin alami
Dialogue: 0,0:02:37.52,0:02:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan banyak terowongan bercabang.
Dialogue: 0,0:02:42.37,0:02:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian hanya perlu keluar hidup-hidup.
Dialogue: 0,0:02:44.99,0:02:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja.
Dialogue: 0,0:02:46.66,0:02:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya, Guru.
Dialogue: 0,0:02:48.33,0:02:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kata Guru.
Dialogue: 0,0:02:51.71,0:02:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:02:53.21,0:02:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sebenarnya dia amati\Nadalah cara kami keluar
Dialogue: 0,0:02:57.13,0:02:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari labirin alami itu.
Dialogue: 0,0:03:06.18,0:03:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah berapa hari\Naku berkeliaran dalam kegelapan.
Dialogue: 0,0:03:14.52,0:03:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginjak jasad banyak orang
Dialogue: 0,0:03:17.65,0:03:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tidak selamat.
Dialogue: 0,0:03:22.20,0:03:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hidupku akan berakhir di sini?
Dialogue: 0,0:03:25.70,0:03:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku mulai kehilangan harapan,
Dialogue: 0,0:03:29.87,0:03:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku melihat seseorang\Nyang bukan sesama murid.
Dialogue: 0,0:03:32.00,0:03:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihatnya.
Dialogue: 0,0:03:36.21,0:03:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang, dia berhenti\Ndan mendengarkan baik-baik,
Dialogue: 0,0:03:41.30,0:03:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia terus maju tanpa pernah tersesat.
Dialogue: 0,0:03:53.27,0:03:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengikutinya dengan putus asa.
Dialogue: 0,0:03:56.82,0:03:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu…
Dialogue: 0,0:04:02.15,0:04:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau.
Dialogue: 0,0:04:06.78,0:04:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memasuki gua\Ntiga hari setelah yang lain, bukan?
Dialogue: 0,0:04:14.00,0:04:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diajari cara membaca
Dialogue: 0,0:04:15.75,0:04:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aliran energi Air\Ndan melacak pembuluh darah naga.
Dialogue: 0,0:04:19.58,0:04:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaanku, dia bukan\Nsalah satu anak dari kediaman itu.
Dialogue: 0,0:04:24.93,0:04:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah beberapa saat, dia pergi.
Dialogue: 0,0:04:27.97,0:04:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui.
Dialogue: 0,0:04:29.85,0:04:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengikuti anak itu, bukan?
Dialogue: 0,0:04:34.19,0:04:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersyukurlah setidaknya\Nkau keluar hidup-hidup.
Dialogue: 0,0:04:38.94,0:04:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menatapku seolah-olah\Naku serangga pengganggu.
Dialogue: 0,0:04:42.65,0:04:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak hari itu,
Dialogue: 0,0:04:44.40,0:04:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru tidak tertarik lagi kepadaku.
Dialogue: 0,0:04:48.41,0:04:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pun makin memburuk.
Dialogue: 0,0:04:50.87,0:04:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak berbakat!
Dialogue: 0,0:04:53.25,0:04:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti saja!
Dialogue: 0,0:04:55.00,0:04:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Guru!
Dialogue: 0,0:04:58.75,0:05:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar rumor\Nbahwa Guru menerima pelayan
Dialogue: 0,0:05:02.38,0:05:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari luar kediaman.
Dialogue: 0,0:05:05.01,0:05:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah Mao.
Dialogue: 0,0:05:07.22,0:05:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat melihatnya,
Dialogue: 0,0:05:09.26,0:05:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tahu dia anak dari gua itu.
Dialogue: 0,0:05:13.31,0:05:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui, apa kau
Dialogue: 0,0:05:17.35,0:05:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin menjadi penerus Klan Goko
Dialogue: 0,0:05:21.19,0:05:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai sebegitu membenciku?
Dialogue: 0,0:05:24.15,0:05:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipukuli dan dimarahi oleh Guru.
Dialogue: 0,0:05:29.45,0:05:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu orang luar sepertimu muncul\Ndan terpilih sebagai penerus.
Dialogue: 0,0:05:35.79,0:05:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:05:38.50,0:05:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan
Dialogue: 0,0:05:40.17,0:05:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang membunuh Guru
Dialogue: 0,0:05:42.88,0:05:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kau, Shiranui?
Dialogue: 0,0:05:47.13,0:05:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membunuhnya, bukan?
Dialogue: 0,0:05:49.64,0:05:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya…
Dialogue: 0,0:05:51.39,0:05:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya…
Dialogue: 0,0:05:57.44,0:05:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:05:58.77,0:05:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:06:02.65,0:06:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu
Dialogue: 0,0:06:05.07,0:06:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang memberiku bekas luka ini
Dialogue: 0,0:06:09.28,0:06:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kau, Shiranui?
Dialogue: 0,0:06:10.87,0:06:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak pernah mengetahuinya?
Dialogue: 0,0:06:13.16,0:06:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bercanda!
Dialogue: 0,0:06:17.04,0:06:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, kami akan segera sampai!
Dialogue: 0,0:06:19.83,0:06:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Nona Nanoka,
Dialogue: 0,0:06:22.04,0:06:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}energi Logam mengarah ke pintu itu.
Dialogue: 0,0:06:29.13,0:06:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bungker bawah tanah?
Dialogue: 0,0:06:31.76,0:06:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jejak energi Logam mengarah ke sini.
Dialogue: 0,0:06:33.68,0:06:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo masuk.
Dialogue: 0,0:06:34.77,0:06:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan masuk?
Dialogue: 0,0:06:43.98,0:06:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Hagunsei Mao cukup berguna, bukan?
Dialogue: 0,0:06:48.45,0:06:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang itu berbahaya.
Dialogue: 0,0:06:51.03,0:06:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat memegangnya,
Dialogue: 0,0:06:53.41,0:06:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku muntah darah dan hampir mati.
Dialogue: 0,0:06:55.49,0:06:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kau benar-benar mati.
Dialogue: 0,0:06:59.21,0:07:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku punya kesempatan,
Dialogue: 0,0:07:01.50,0:07:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin membunuh Guru\Ndengan tanganku sendiri
Dialogue: 0,0:07:05.17,0:07:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daripada membiarkannya dibunuh\Noleh orang luar sepertimu.
Dialogue: 0,0:07:09.93,0:07:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin membunuhnya\Nuntuk menjadi penerus Klan Goko?
Dialogue: 0,0:07:13.72,0:07:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kemudian, mantra rahasia Taizanfukun
Dialogue: 0,0:07:18.23,0:07:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}direbut olehmu dan Byoki itu,\Nlalu kalian berdua melarikan diri.
Dialogue: 0,0:07:22.27,0:07:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, Mao,
Dialogue: 0,0:07:23.77,0:07:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan mengajariku
Dialogue: 0,0:07:25.57,0:07:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra Taizanfukun.
Dialogue: 0,0:07:28.78,0:07:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Byoki itu kabur
Dialogue: 0,0:07:31.57,0:07:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan mantra Taizanfukun.
Dialogue: 0,0:07:35.45,0:07:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui tidak tahu itu.
Dialogue: 0,0:07:41.12,0:07:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuajarkan kepadamu.
Dialogue: 0,0:07:43.21,0:07:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:07:44.71,0:07:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, pertama-tama,
Dialogue: 0,0:07:47.05,0:07:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada yang ingin kutanyakan.
Dialogue: 0,0:07:49.55,0:07:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan kepada Nona Sana?
Dialogue: 0,0:07:53.93,0:07:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu
Dialogue: 0,0:07:56.31,0:07:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka bilang Nona Sana meninggal.
Dialogue: 0,0:07:58.93,0:08:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa bahkan mengeklaim\Nbahwa aku membunuhnya.
Dialogue: 0,0:08:02.31,0:08:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dia masih hidup dan bekerja untukmu.
Dialogue: 0,0:08:12.57,0:08:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:08:17.53,0:08:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya dia bertemu Yurako?
Dialogue: 0,0:08:21.58,0:08:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Mao?
Dialogue: 0,0:08:23.87,0:08:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih memikirkan Sana?
Dialogue: 0,0:08:41.05,0:08:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:08:42.98,0:08:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:08:44.69,0:08:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:08:46.61,0:08:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini darah Mao?
Dialogue: 0,0:08:49.02,0:08:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka…
Dialogue: 0,0:08:50.57,0:08:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangku!
Dialogue: 0,0:08:52.15,0:08:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:53.99,0:08:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kekuatan darah Byoki\Nyang mengalir di tubuhku.
Dialogue: 0,0:08:59.91,0:09:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui.
Dialogue: 0,0:09:01.83,0:09:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan apa yang kau lakukan\Nkepada Nona Sana.
Dialogue: 0,0:09:05.62,0:09:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Itu Shiranui?
Dialogue: 0,0:09:08.00,0:09:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui?
Dialogue: 0,0:09:10.67,0:09:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian banyak sekali?
Dialogue: 0,0:09:13.01,0:09:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua bersekongkol?
Dialogue: 0,0:09:15.43,0:09:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jawab aku, Shiranui.
Dialogue: 0,0:09:18.55,0:09:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Nona Sana masih hidup dan bersamamu?
Dialogue: 0,0:09:23.14,0:09:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dia bisa hidup?
Dialogue: 0,0:09:25.44,0:09:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang tahu?
Dialogue: 0,0:09:27.44,0:09:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tinggal bersamaku
Dialogue: 0,0:09:30.11,0:09:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas pilihannya sendiri.
Dialogue: 0,0:09:33.19,0:09:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembohong!
Dialogue: 0,0:09:41.12,0:09:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh… Itu energi dari Pedang Hagunsei?
Dialogue: 0,0:09:45.12,0:09:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan tidak mengayunkannya.
Dialogue: 0,0:09:47.04,0:09:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh…
Dialogue: 0,0:09:48.08,0:09:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut kau bisa\Nmeninggikan suaramu seperti itu.
Dialogue: 0,0:09:52.00,0:09:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu Nona Sana?
Dialogue: 0,0:09:55.42,0:09:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginannya sama denganku.
Dialogue: 0,0:09:58.84,0:10:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memperpanjang umur penguasa\Nyang memerintah negara
Dialogue: 0,0:10:02.51,0:10:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan saat diminta,\Nmengutuk saingan politik mereka.
Dialogue: 0,0:10:06.44,0:10:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah cara kami melestarikan\Nwarisan Klan Goko.
Dialogue: 0,0:10:12.65,0:10:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mematuhi keinginan ayahku.
Dialogue: 0,0:10:16.78,0:10:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana siap melanjutkan\Nwarisan Klan Goko.
Dialogue: 0,0:10:22.28,0:10:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:10:23.70,0:10:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menipu semua orang
Dialogue: 0,0:10:26.21,0:10:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan membuat mayatnya tampak hidup…
Dialogue: 0,0:10:28.50,0:10:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak akan pernah menginginkan\Neksistensi segila itu!
Dialogue: 0,0:10:35.34,0:10:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila, katamu?
Dialogue: 0,0:10:37.42,0:10:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua akan berakhir jika kau menyerahkan
Dialogue: 0,0:10:41.22,0:10:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra rahasia Taizanfukun!
Dialogue: 0,0:10:44.18,0:10:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan pernah menyerahkan
Dialogue: 0,0:10:46.06,0:10:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra itu kepada orang sepertimu!
Dialogue: 0,0:11:02.62,0:11:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakimu…
Dialogue: 0,0:11:04.66,0:11:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:06.12,0:11:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh tidak ingat?
Dialogue: 0,0:11:09.46,0:11:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao mengkhianati kita!
Dialogue: 0,0:11:11.17,0:11:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengendalikan Byoki itu\Nuntuk menghancurkan kediaman ini!
Dialogue: 0,0:11:14.71,0:11:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan goyah!
Dialogue: 0,0:11:15.84,0:11:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao membunuh Guru kita!\NDia musuh bebuyutan kita sekarang!
Dialogue: 0,0:11:19.55,0:11:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisi dia!
Dialogue: 0,0:11:38.03,0:11:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan itu?
Dialogue: 0,0:11:40.61,0:11:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meminjam kaki ini dari shikigami Kairyu.
Dialogue: 0,0:11:44.83,0:11:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kaki ini,\Naku tak pernah bisa meninggalkan air.
Dialogue: 0,0:11:48.87,0:11:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu sebabnya\Nkau tak pernah meninggalkan Kyoto
Dialogue: 0,0:11:51.87,0:11:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terus mengirim pembunuh?
Dialogue: 0,0:11:54.84,0:11:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Akan kukirim sebanyak mungkin.
Dialogue: 0,0:12:01.84,0:12:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:12:06.14,0:12:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menghentikanku?
Dialogue: 0,0:12:07.89,0:12:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bodoh?
Dialogue: 0,0:12:09.77,0:12:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kau masuk ke air,
Dialogue: 0,0:12:11.35,0:12:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau masuk ke perangkap Shiranui.
Dialogue: 0,0:12:28.66,0:12:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, akhirnya kau bertemu Mao?
Dialogue: 0,0:12:32.92,0:12:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran
Dialogue: 0,0:12:34.96,0:12:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang Mao pikirkan saat melihatku?
Dialogue: 0,0:12:37.46,0:12:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Yurako yang malang.
Dialogue: 0,0:12:42.55,0:12:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster.
Dialogue: 0,0:12:54.39,0:12:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:12:57.94,0:13:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mengikuti shikigami Logam ke sini
Dialogue: 0,0:13:01.28,0:13:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang berarti Shiranui bekerja sama\Ndengan Penyihir Logam.
Dialogue: 0,0:13:05.45,0:13:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris saja. Aku hampir menangkapnya.
Dialogue: 0,0:13:09.24,0:13:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan kembali cepat atau lambat.
Dialogue: 0,0:13:11.08,0:13:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia punya dendam serius\Nterhadapmu.
Dialogue: 0,0:13:14.25,0:13:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti juga akan menyimpan dendam.
Dialogue: 0,0:13:17.21,0:13:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memotong kakinya\Ndan meninggalkannya seperti itu.
Dialogue: 0,0:13:21.26,0:13:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao,
Dialogue: 0,0:13:22.30,0:13:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang terjadi saat itu?\Nkau sungguh tidak ingat
Dialogue: 0,0:13:26.59,0:13:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak ingat.
Dialogue: 0,0:13:30.10,0:13:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya,
Dialogue: 0,0:13:31.97,0:13:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak pernah\Nterlalu memperhatikan Shiranui.
Dialogue: 0,0:13:33.93,0:13:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, dingin sekali.
Dialogue: 0,0:13:35.85,0:13:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:13:37.98,0:13:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini dingin.
Dialogue: 0,0:13:39.48,0:13:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalilah tanpa aku.
Dialogue: 0,0:13:41.82,0:13:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan istirahat sebentar.
Dialogue: 0,0:13:44.78,0:13:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau tidak bisa berjalan?
Dialogue: 0,0:13:47.28,0:13:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau tampak baik-baik saja tadi.
Dialogue: 0,0:13:50.28,0:13:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, dia ditembak beberapa kali…
Dialogue: 0,0:13:53.58,0:13:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh shikigami Logam.
Dialogue: 0,0:13:58.46,0:14:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya. Jadi, yang terjadi tadi
Dialogue: 0,0:14:01.25,0:14:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah membicarakan Nona Sana\Nmembuatmu kesal?
Dialogue: 0,0:14:15.73,0:14:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, apa yang kau…
Dialogue: 0,0:14:17.31,0:14:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memberimu darahku.
Dialogue: 0,0:14:19.06,0:14:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bisa berjalan, bukan?
Dialogue: 0,0:14:20.61,0:14:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, jangan lakukan itu.
Dialogue: 0,0:14:22.73,0:14:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa mempersingkat umurmu.
Dialogue: 0,0:14:24.99,0:14:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak peduli!
Dialogue: 0,0:14:31.62,0:14:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon tidak akan membantu, bukan?
Dialogue: 0,0:14:34.08,0:14:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benci mantelnya kotor.
Dialogue: 0,0:14:36.54,0:14:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka terlalu kecil untuk menggendongmu.
Dialogue: 0,0:14:40.33,0:14:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak salah.\NAku tidak tahan mantelku kotor.
Dialogue: 0,0:14:44.38,0:14:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, kau baru saja mengejekku?
Dialogue: 0,0:14:49.97,0:14:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah…
Dialogue: 0,0:14:51.68,0:14:54.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukanya sembuh.
Dialogue: 0,0:15:06.11,0:15:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:15:07.32,0:15:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dia pingsan\Ndan kita harus menggendongnya.
Dialogue: 0,0:15:10.70,0:15:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, mau bertukar?
Dialogue: 0,0:15:13.03,0:15:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan menggendong Nanoka.
Dialogue: 0,0:15:16.04,0:15:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Nanoka adalah tanggung jawabku.
Dialogue: 0,0:15:20.46,0:15:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatnya terlalu memaksakan diri lagi.
Dialogue: 0,0:15:23.88,0:15:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa membiarkan ini
Dialogue: 0,0:15:25.63,0:15:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berlanjut.
Dialogue: 0,0:15:30.13,0:15:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka, kau sudah mau pulang?
Dialogue: 0,0:15:32.80,0:15:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku ingin pulang dan beristirahat.
Dialogue: 0,0:15:35.89,0:15:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao, jangan terlalu memaksakan diri juga.
Dialogue: 0,0:15:38.31,0:15:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja sekarang.
Dialogue: 0,0:15:40.19,0:15:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukaku sudah sembuh.
Dialogue: 0,0:15:45.90,0:15:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:15:47.19,0:15:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sampai jumpa.
Dialogue: 0,0:15:55.49,0:15:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihat Mao seperti itu.
Dialogue: 0,0:15:59.45,0:16:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana
Dialogue: 0,0:16:01.17,0:16:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bekerja untuk Shiranui.
Dialogue: 0,0:16:04.13,0:16:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tinggal bersamaku\Natas pilihannya sendiri.
Dialogue: 0,0:16:08.38,0:16:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembohong!
Dialogue: 0,0:16:10.80,0:16:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat cemburu pada Shiranui.
Dialogue: 0,0:16:14.76,0:16:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Sana mencintai orang lain.
Dialogue: 0,0:16:18.14,0:16:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa orang itu Shiranui?
Dialogue: 0,0:16:21.56,0:16:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sulit memercayainya.
Dialogue: 0,0:16:24.23,0:16:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, meski cintanya\Nbertepuk sebelah tangan,
Dialogue: 0,0:16:26.27,0:16:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia jelas masih mencintainya.
Dialogue: 0,0:16:28.53,0:16:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halangi aku!
Dialogue: 0,0:16:36.24,0:16:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu
Dialogue: 0,0:16:37.99,0:16:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar Nona Sana?
Dialogue: 0,0:16:45.79,0:16:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki?
Dialogue: 0,0:16:47.54,0:16:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau ingin menemuiku,
Dialogue: 0,0:16:50.30,0:16:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}panggil namaku kapan saja.
Dialogue: 0,0:16:52.63,0:16:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau di sini?
Dialogue: 0,0:16:55.72,0:16:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memanggilmu.
Dialogue: 0,0:16:59.01,0:17:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memberi Mao darahmu lagi, bukan?
Dialogue: 0,0:17:02.23,0:17:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau tahu?
Dialogue: 0,0:17:04.59,0:17:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao dan Nanoka,
Dialogue: 0,0:17:06.98,0:17:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}darah yang mengalir dalam tubuh kalian\Nadalah darahku.
Dialogue: 0,0:17:11.03,0:17:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku tahu.
Dialogue: 0,0:17:12.95,0:17:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia mengawasiku selama ini\Nsebagai wadah barunya?
Dialogue: 0,0:17:18.03,0:17:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun…
Dialogue: 0,0:17:19.54,0:17:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei,
Dialogue: 0,0:17:20.79,0:17:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau pernah bilang\Ntak berniat menyakitiku, kan?
Dialogue: 0,0:17:24.54,0:17:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya,
Dialogue: 0,0:17:25.75,0:17:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak perlu takut kepadaku.
Dialogue: 0,0:17:29.29,0:17:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ceritakan
Dialogue: 0,0:17:30.96,0:17:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang Nona Sana.
Dialogue: 0,0:17:33.97,0:17:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana?
Dialogue: 0,0:17:35.93,0:17:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pernah menjadi\Nkucing peliharaan Nona Sana, kan?
Dialogue: 0,0:17:42.64,0:17:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haimaru.
Dialogue: 0,0:17:49.57,0:17:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berita! Berita!
Dialogue: 0,0:17:51.98,0:17:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembantaian misterius di Desa Hitokabe!
Dialogue: 0,0:17:56.07,0:17:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Seorang tukang pos menemukan
Dialogue: 0,0:17:57.70,0:18:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pemandangan mengerikan di desa itu\Ndan memperingatkan pihak berwenang."
Dialogue: 0,0:18:00.91,0:18:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Para penduduk desa telah dibunuh\Ndengan apa yang tampak
Dialogue: 0,0:18:03.75,0:18:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti satu tusukan pisau tajam."
Dialogue: 0,0:18:06.37,0:18:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku melihat hal-hal
Dialogue: 0,0:18:07.46,0:18:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mirip orang-orangan sawah logam\Nmeninggalkan desa…"
Dialogue: 0,0:18:11.21,0:18:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"…kata tukang pos itu."
Dialogue: 0,0:18:14.59,0:18:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orangan sawah logam?
Dialogue: 0,0:18:16.93,0:18:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin. Mungkinkah mereka\Norang yang sama dari saat itu?
Dialogue: 0,0:18:22.81,0:18:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa Nona Sana?
Dialogue: 0,0:18:26.19,0:18:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana…
Dialogue: 0,0:18:30.73,0:18:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu shikigami, Haimaru.
Dialogue: 0,0:18:38.28,0:18:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia menghilang.
Dialogue: 0,0:18:40.95,0:18:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu, Haimaru,
Dialogue: 0,0:18:43.66,0:18:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini rumah kutukan.
Dialogue: 0,0:18:46.12,0:18:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangsawan diam-diam datang ke sini
Dialogue: 0,0:18:49.21,0:18:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memercayakan nama, rambut,\Natau kuku orang yang ingin mereka kutuk.
Dialogue: 0,0:18:53.09,0:18:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu onmyoji dari rumah ini\Nmemberikan kutukan.
Dialogue: 0,0:18:57.55,0:19:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika target dilindungi\Noleh onmyoji yang lebih terampil,
Dialogue: 0,0:19:01.97,0:19:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mungkin akan membalas kita.
Dialogue: 0,0:19:03.72,0:19:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau onmyoji dari luar\Nyang menentang rumah ini
Dialogue: 0,0:19:06.43,0:19:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin mengirim kutukan mereka sendiri.
Dialogue: 0,0:19:10.10,0:19:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, semua kutukan itu menghilang
Dialogue: 0,0:19:13.61,0:19:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di atas kediaman ini,\Nseperti yang kau lihat.
Dialogue: 0,0:19:17.69,0:19:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Itu tidak benar.
Dialogue: 0,0:19:20.28,0:19:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya menjadi tidak terlihat.
Dialogue: 0,0:19:23.74,0:19:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Nona Sana bisa melihat mereka?
Dialogue: 0,0:19:27.62,0:19:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia bisa merapal mantra Onmyo?
Dialogue: 0,0:19:29.87,0:19:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana bukan penyihir.
Dialogue: 0,0:19:33.38,0:19:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, di malam hari saat seseorang datang\Nuntuk melakukan kutukan…
Dialogue: 0,0:19:42.22,0:19:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru di kediaman itu, ayah Sana,
Dialogue: 0,0:19:52.15,0:19:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan mengumpulkan uap hitam
Dialogue: 0,0:19:55.82,0:19:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyerahkannya\Nkepada penyihir di kediaman itu.
Dialogue: 0,0:19:58.69,0:20:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uap hitam apa itu?
Dialogue: 0,0:20:02.11,0:20:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutukan, kemungkinan besar.
Dialogue: 0,0:20:04.91,0:20:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya sama dengan shikigami
Dialogue: 0,0:20:07.95,0:20:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menghilang di atas kediaman.
Dialogue: 0,0:20:10.58,0:20:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutukan keluar dari mulut Nona Sana?
Dialogue: 0,0:20:14.79,0:20:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana adalah putri Klan Goko.
Dialogue: 0,0:20:17.84,0:20:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu perannya.
Dialogue: 0,0:20:20.84,0:20:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu. Apa Mao tahu tentang semua ini?
Dialogue: 0,0:20:25.10,0:20:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:20:27.35,0:20:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat berada di sekitar Mao\Ndan para penyihir di kediaman itu,
Dialogue: 0,0:20:30.39,0:20:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana selalu dikelilingi oleh aura murni.
Dialogue: 0,0:20:35.06,0:20:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak tahu
Dialogue: 0,0:20:37.02,0:20:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah Sana sendiri menyadari perannya.
Dialogue: 0,0:20:40.94,0:20:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halangi aku!
Dialogue: 0,0:20:43.53,0:20:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan.
Dialogue: 0,0:20:44.74,0:20:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kubilang Nona Sana hidup di era Taisho,
Dialogue: 0,0:20:48.20,0:20:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kau akan memercayaiku?
Dialogue: 0,0:20:50.00,0:20:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana sudah mati.
Dialogue: 0,0:20:52.46,0:20:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungnya dicabut dari dadanya.
Dialogue: 0,0:20:56.17,0:20:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mungkin dia masih hidup.
Dialogue: 0,0:20:59.30,0:21:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu siapa wanita itu?
Dialogue: 0,0:21:06.26,0:21:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini aneh, Hyakka?
Dialogue: 0,0:21:08.64,0:21:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:21:10.39,0:21:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembantaian di Desa Hitokabe
Dialogue: 0,0:21:13.31,0:21:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terjadi kurang dari tiga hari lalu, tapi…
Dialogue: 0,0:21:15.81,0:21:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada satu pun wartawan
Dialogue: 0,0:21:17.36,0:21:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau polisi di sini.
Dialogue: 0,0:21:20.28,0:21:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya koran dan polisi
Dialogue: 0,0:21:22.82,0:21:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah diminta untuk menjauh.
Dialogue: 0,0:21:25.11,0:21:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu juga sama.
Dialogue: 0,0:21:27.37,0:21:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu saat kau bertemu\Norang-orangan sawah logam?
Dialogue: 0,0:21:32.25,0:21:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:33.79,0:21:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu 20 tahun lalu,\Nsaat perang dengan Rusia dimulai.
Dialogue: 0,0:21:38.59,0:21:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku membantu\Ndi peternakan di sebuah desa.
Dialogue: 0,0:21:43.01,0:21:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah melakukan banyak pekerjaan.
Dialogue: 0,0:21:45.47,0:21:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka…
Dialogue: 0,0:21:50.89,0:21:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiba-tiba muncul.
Dialogue: 0,0:21:59.69,0:22:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan?
Dialogue: 0,0:22:04.82,0:22:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang di desa dibantai.
Dialogue: 0,0:22:07.70,0:22:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir tidak bisa kabur, tapi…
Dialogue: 0,0:22:09.78,0:22:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}insiden itu tidak pernah masuk koran
Dialogue: 0,0:22:12.29,0:22:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau bahkan memicu rumor.
Dialogue: 0,0:22:15.37,0:22:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pembantaian itu tidak pernah terjadi?
Dialogue: 0,0:22:18.67,0:22:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:22:19.75,0:22:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kali ini, insiden ini masuk koran.
Dialogue: 0,0:22:23.42,0:22:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka, kurasa ini…
Dialogue: 0,0:22:33.81,0:22:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:22:35.56,0:22:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti 20 tahun lalu.
Dialogue: 0,0:22:38.44,0:22:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya insiden di desa ini
Dialogue: 0,0:22:40.69,0:22:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah jebakan untuk memancing kita.
Dialogue: 0,0:22:43.98,0:22:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Namun…
Dialogue: 0,0:22:47.78,0:22:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah menduga kau juga akan muncul.
Dialogue: 0,0:22:51.28,0:22:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka.
Dialogue: 0,0:22:52.91,0:22:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:22:53.87,0:22:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dalang di balik orang-orangan sawah\N20 tahun lalu?
Dialogue: 0,0:22:57.71,0:22:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:22:59.58,0:23:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, kita berdua tak sempat
Dialogue: 0,0:23:01.46,0:23:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihat wajah satu sama lain dengan jelas.
Dialogue: 0,0:23:04.25,0:23:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau melihat wajahku?
Dialogue: 0,0:23:06.72,0:23:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum kucungkil matamu satunya?
Dialogue: 0,0:23:12.85,0:23:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pria
Dialogue: 0,0:23:15.18,0:23:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang melakukan itu pada mata Hyakka?
Dialogue: 0,0:24:49.19,0:24:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur, Mao!
Dialogue: 0,0:24:50.53,0:24:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia milikku!
Dialogue: 0,0:24:51.95,0:24:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, Api mengalahkan Logam.
Dialogue: 0,0:24:55.20,0:24:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hyakka seharusnya diuntungkan, tapi…
Dialogue: 0,0:24:57.37,0:24:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku,
Dialogue: 0,0:24:58.87,0:25:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan Goko adalah tempat aku merasa nyaman.
Dialogue: 0,0:25:02.50,0:25:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Mao,
Dialogue: 0,0:25:04.00,0:25:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengkhianatanmu menyebabkan\Nkejatuhan Klan Goko.
Dialogue: 0,0:25:06.79,0:25:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memihak Klan Goko yang palsu?
Dialogue: 0,0:25:09.76,0:25:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Palsu? Kau yakin soal itu?
Dialogue: 0,0:25:12.88,0:25:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster mengerikan!
Dialogue: 0,0:25:15.18,0:25:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Hakubi".
