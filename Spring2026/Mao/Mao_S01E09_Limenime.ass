Dialogue: 0,0:21:48.35,0:21:51.03,sign,,0000,0000,0000,,"MURNIKAN KEENAM INDRA OLEH TITAH SUCI"
Dialogue: 0,0:24:49.03,0:24:49.86,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
