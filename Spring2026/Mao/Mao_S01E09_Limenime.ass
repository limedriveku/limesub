Dialogue: 0,0:00:20.52,0:00:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:00:22.68,0:00:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tanehiko.
Dialogue: 0,0:00:25.73,0:00:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melakukannya lagi.
Dialogue: 0,0:00:28.19,0:00:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jadi buah bibir di kota.
Dialogue: 0,0:00:30.78,0:00:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlepas dari semua kekacauan\Nakibat gempa bumi besar.
Dialogue: 0,0:00:34.07,0:00:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir tentang hal itu.
Dialogue: 0,0:00:37.03,0:00:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memastikan untuk memilih gadis\Ntanpa ikatan keluarga.
Dialogue: 0,0:00:41.41,0:00:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu bilang itu kali pertama
Dialogue: 0,0:00:45.12,0:00:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia mengisi perutnya dengan nasi putih.
Dialogue: 0,0:00:47.29,0:00:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak sangat bahagia.
Dialogue: 0,0:00:49.59,0:00:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia mati dengan sangat puas.
Dialogue: 0,0:00:53.22,0:00:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Kuchinawa…
Dialogue: 0,0:00:55.59,0:00:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa tenang mengetahui kau akan\Nmembersihkan semuanya untukku.
Dialogue: 0,0:00:59.47,0:01:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Tuan Tanehiko.
Dialogue: 0,0:01:09.94,0:01:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum gempa bumi besar,
Dialogue: 0,0:01:11.53,0:01:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini rumah kaca yang indah.
Dialogue: 0,0:01:20.33,0:01:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:01:22.24,0:01:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pantas mendapatkan tempat\Nperistirahatan yang lebih indah.
Dialogue: 0,0:01:36.34,0:01:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Muda,
Dialogue: 0,0:01:37.55,0:01:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berjalan sendirian\Ndi tempat seperti ini berbahaya.
Dialogue: 0,0:01:40.97,0:01:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak masuk?
Dialogue: 0,0:01:42.39,0:01:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terima kasih.
Dialogue: 0,0:01:45.18,0:01:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencari seseorang.
Dialogue: 0,0:01:47.52,0:01:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang pelayan memeriksa kerabat
Dialogue: 0,0:01:50.15,0:01:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tinggal di dekat sini
Dialogue: 0,0:01:51.86,0:01:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia tidak pernah kembali.
Dialogue: 0,0:01:54.86,0:01:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada rumor
Dialogue: 0,0:01:56.70,0:02:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa beberapa wanita muda\Nmenghilang di area ini,
Dialogue: 0,0:02:01.03,0:02:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku khawatir.
Dialogue: 0,0:02:03.45,0:02:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah?
Dialogue: 0,0:02:11.13,0:02:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, wanita yang cantik.
Dialogue: 0,0:02:14.51,0:02:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa perjalanan ke sini sepadan.
Dialogue: 0,0:02:24.93,0:02:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan pergi sekarang, Dokter Mao.
Dialogue: 0,0:02:27.10,0:02:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan kembali besok\Nuntuk membantu bersih-bersih lagi.
Dialogue: 0,0:02:30.06,0:02:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:02:34.61,0:02:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, orang-orang sangat mengaguminya.
Dialogue: 0,0:02:38.15,0:02:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Oh…
Dialogue: 0,0:02:45.87,0:02:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis sekali!
Dialogue: 0,0:02:47.66,0:02:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao, lihat.
Dialogue: 0,0:02:52.25,0:02:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi, Otoya. Nanoka.
Dialogue: 0,0:02:54.71,0:02:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:03:12.77,0:03:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:03:15.40,0:03:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih hidup.
Dialogue: 0,0:03:21.41,0:03:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci mengacaukan kamarku.
Dialogue: 0,0:03:25.66,0:03:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang mari bersenang-senang\Ndi antara bunga, ya?
Dialogue: 0,0:03:33.50,0:03:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terluka separah itu,
Dialogue: 0,0:03:35.75,0:03:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tetap wanita yang hebat.
Dialogue: 0,0:03:45.26,0:03:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:03:47.26,0:03:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?
Dialogue: 0,0:03:49.18,0:03:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiryu, Byakko, Suzaku, Genbu,
Dialogue: 0,0:03:52.23,0:03:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kochin, Teidai, Bunno, Santai, Gyokujo.
Dialogue: 0,0:03:56.65,0:03:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usir!
Dialogue: 0,0:04:02.65,0:04:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Tanehiko,
Dialogue: 0,0:04:03.99,0:04:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau sungguh tak bisa kendalikan diri, ya?
Dialogue: 0,0:04:06.53,0:04:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kau bahkan\Nbermain-main dengan ayakashi.
Dialogue: 0,0:04:09.49,0:04:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuchinawa!
Dialogue: 0,0:04:16.45,0:04:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:04:18.38,0:04:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayakashi hewan, ya?
Dialogue: 0,0:04:21.33,0:04:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kasihan padamu,\Ntapi aku harus memusnahkanmu.
Dialogue: 0,0:04:24.01,0:04:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan merepotkan jika Tuan Muda\Nhancur berkeping-keping.
Dialogue: 0,0:04:28.35,0:04:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usir!
Dialogue: 0,0:04:40.61,0:04:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria ini…
Dialogue: 0,0:06:24.25,0:06:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenko!
Dialogue: 0,0:06:29.22,0:06:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:06:30.39,0:06:31.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terluka parah!
Dialogue: 0,0:06:31.80,0:06:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:06:33.56,0:06:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matamu!
Dialogue: 0,0:06:39.31,0:06:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku sudah tamat.
Dialogue: 0,0:06:43.19,0:06:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenko, kau ayakashi?
Dialogue: 0,0:06:46.61,0:06:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:06:49.07,0:06:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu menabrakku dengan mobilnya
Dialogue: 0,0:06:51.20,0:06:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membawaku ke sini.
Dialogue: 0,0:06:53.70,0:06:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejumlah wanita muda menghilang.
Dialogue: 0,0:06:57.37,0:06:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin pria itu yang bertanggung jawab.
Dialogue: 0,0:07:00.12,0:07:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuchinawa.
Dialogue: 0,0:07:01.58,0:07:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat monster itu diam.
Dialogue: 0,0:07:04.25,0:07:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lainnya juga.
Dialogue: 0,0:07:06.05,0:07:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuchinawa?
Dialogue: 0,0:07:08.42,0:07:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu Kuchinawa?
Dialogue: 0,0:07:12.05,0:07:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya berbeda,
Dialogue: 0,0:07:13.76,0:07:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku kenal seseorang\Nyang sangat mirip denganmu.
Dialogue: 0,0:07:16.72,0:07:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau mengenalnya?
Dialogue: 0,0:07:19.56,0:07:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah.
Dialogue: 0,0:07:21.65,0:07:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak kenal\Nayakashi laki-laki mana pun.
Dialogue: 0,0:07:24.77,0:07:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku ayakashi?
Dialogue: 0,0:07:28.28,0:07:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis di sana juga ayakashi, kan?
Dialogue: 0,0:07:30.82,0:07:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Siapa pria ini?
Dialogue: 0,0:07:34.12,0:07:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa tahu?
Dialogue: 0,0:07:35.58,0:07:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara teknis, itu tidak benar.
Dialogue: 0,0:07:38.33,0:07:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah mereka ayakashi atau manusia,
Dialogue: 0,0:07:40.96,0:07:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus membunuh mereka.
Dialogue: 0,0:07:42.92,0:07:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, Kuchinawa?
Dialogue: 0,0:07:45.34,0:07:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:46.67,0:07:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kabar ini tersebar,
Dialogue: 0,0:07:47.92,0:07:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu akan menodai\Nnama terhormat keluargamu, kan?
Dialogue: 0,0:07:52.38,0:07:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria ini…
Dialogue: 0,0:07:54.55,0:07:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tidak akan menahan diri.
Dialogue: 0,0:07:56.68,0:07:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku membereskan kekacauan ini.
Dialogue: 0,0:08:03.35,0:08:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuchinawa itu kaki tangan orang jahat?
Dialogue: 0,0:08:06.61,0:08:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berniat membunuh kita.
Dialogue: 0,0:08:08.98,0:08:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu apa lagi, Kuchinawa?
Dialogue: 0,0:08:10.74,0:08:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bunuh mereka!
Dialogue: 0,0:08:12.49,0:08:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah dimulai, Tuan Tanehiko.
Dialogue: 0,0:08:21.91,0:08:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:25.25,0:08:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa menyebutkan
Dialogue: 0,0:08:27.38,0:08:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku punya majikan baru sekarang.
Dialogue: 0,0:08:30.38,0:08:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:31.76,0:08:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menculik wanita muda, memerkosa mereka,
Dialogue: 0,0:08:34.47,0:08:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak puas\Nsebelum mencekik mereka hingga mati.
Dialogue: 0,0:08:37.17,0:08:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga itu berhasil menutupi semuanya\Ndengan pengaruh mereka sampai sekarang,
Dialogue: 0,0:08:40.47,0:08:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi akhirnya mereka mencapai batasnya.
Dialogue: 0,0:08:42.77,0:08:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahmu memutuskan menunjuk putra\Nyang lebih cakap
Dialogue: 0,0:08:44.90,0:08:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai pewarisnya.
Dialogue: 0,0:08:47.11,0:08:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku diperintahkan\Nuntuk menyingkirkanmu, Tuan Muda.
Dialogue: 0,0:08:50.36,0:08:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keinginan ayahmu.
Dialogue: 0,0:08:51.99,0:08:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:54.40,0:08:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:08:56.24,0:08:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargamu masih harus\Nmelindungi reputasinya.
Dialogue: 0,0:08:58.16,0:09:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ingin kau mendapatkan\Npemakaman yang layak,
Dialogue: 0,0:09:01.16,0:09:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku akan memastikan\Ntubuhmu terlihat rapi.
Dialogue: 0,0:09:10.21,0:09:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungnya diambil.
Dialogue: 0,0:09:22.14,0:09:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang…
Dialogue: 0,0:09:26.98,0:09:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua
Dialogue: 0,0:09:28.11,0:09:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}boleh pulang.
Dialogue: 0,0:09:29.65,0:09:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau membiarkan kami pergi?
Dialogue: 0,0:09:32.69,0:09:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon.
Dialogue: 0,0:09:35.45,0:09:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Kamon, bukan?
Dialogue: 0,0:09:38.45,0:09:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Pedang itu…
Dialogue: 0,0:09:40.99,0:09:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengenalinya\Nkarena ukirannya telah berubah, tapi…
Dialogue: 0,0:09:44.83,0:09:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu Pedang Hagunsei?
Dialogue: 0,0:09:47.29,0:09:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kuduga, dia Kamon.
Dialogue: 0,0:09:50.59,0:09:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti…
Dialogue: 0,0:09:52.05,0:09:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa itu kau, Mao?
Dialogue: 0,0:09:55.26,0:09:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tahu?
Dialogue: 0,0:09:57.51,0:09:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:58.43,0:10:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang dia murid senior lainnya?
Dialogue: 0,0:10:01.93,0:10:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dulu tidak begini, 'kan?
Dialogue: 0,0:10:05.52,0:10:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao yang kuingat
Dialogue: 0,0:10:06.89,0:10:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}punya tatapan memelas\Nseperti anak anjing terlantar.
Dialogue: 0,0:10:12.15,0:10:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sekarang
Dialogue: 0,0:10:13.82,0:10:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau lebih mirip kucing.
Dialogue: 0,0:10:16.20,0:10:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon masih hidup.
Dialogue: 0,0:10:19.62,0:10:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka bukan satu-satunya.
Dialogue: 0,0:10:22.95,0:10:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau dipanggil ke Goshikido juga?
Dialogue: 0,0:10:27.00,0:10:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:28.92,0:10:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutuk Mao sampai mati.
Dialogue: 0,0:10:32.38,0:10:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tak punya tekad\Nuntuk melakukan itu,
Dialogue: 0,0:10:35.38,0:10:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}matilah di sini.
Dialogue: 0,0:10:39.68,0:10:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu tentang Goshikido.
Dialogue: 0,0:10:42.47,0:10:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu berarti
Dialogue: 0,0:10:44.22,0:10:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau di sini untuk membunuhku?
Dialogue: 0,0:10:49.31,0:10:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau akan datang untuk membunuhku!
Dialogue: 0,0:10:55.03,0:10:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka juga bilang begitu.
Dialogue: 0,0:10:58.78,0:11:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti
Dialogue: 0,0:11:00.86,0:11:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kita harus saling membunuh.
Dialogue: 0,0:11:03.37,0:11:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku hanya ingin tahu.
Dialogue: 0,0:11:06.62,0:11:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi pada hari
Dialogue: 0,0:11:08.41,0:11:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat kediaman itu terbakar?
Dialogue: 0,0:11:11.71,0:11:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan apa yang kau lihat…
Dialogue: 0,0:11:13.00,0:11:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:11:14.17,0:11:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa-apa.
Dialogue: 0,0:11:16.34,0:11:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berada di luar kediaman\Nuntuk bertemu seorang wanita.
Dialogue: 0,0:11:19.51,0:11:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:11:21.26,0:11:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa orang ini serius?
Dialogue: 0,0:11:23.97,0:11:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kau tak tahu\Nsiapa yang membunuh Nona Sana?
Dialogue: 0,0:11:27.93,0:11:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:11:29.23,0:11:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, beberapa orang bilang\Nkau membunuhnya.
Dialogue: 0,0:11:33.48,0:11:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau
Dialogue: 0,0:11:34.69,0:11:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang melakukannya?
Dialogue: 0,0:11:38.15,0:11:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat.
Dialogue: 0,0:11:41.36,0:11:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak penting sekarang.\NKejadiannya sudah lama sekali.
Dialogue: 0,0:11:45.03,0:11:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya percaya yang kulihat\Ndengan mataku sendiri.
Dialogue: 0,0:11:48.58,0:11:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang
Dialogue: 0,0:11:49.62,0:11:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus meminta keluarga Tuan Muda\Nmembawa jasadnya pergi dari sini.
Dialogue: 0,0:11:53.88,0:11:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal, Mao.
Dialogue: 0,0:11:56.55,0:11:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu obat.
Dialogue: 0,0:11:58.13,0:12:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk ayakashi hewan yang terluka.
Dialogue: 0,0:12:03.97,0:12:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamon,
Dialogue: 0,0:12:05.97,0:12:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kau masih hidup?
Dialogue: 0,0:12:09.18,0:12:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin tahu
Dialogue: 0,0:12:11.19,0:12:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jawabannya.
Dialogue: 0,0:12:21.11,0:12:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka, dari mana saja kau selama ini?
Dialogue: 0,0:12:25.12,0:12:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau berhenti dari rombongan.
Dialogue: 0,0:12:28.04,0:12:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berubah pikiran.
Dialogue: 0,0:12:30.00,0:12:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu Kota Kekaisaran terlalu berbahaya.
Dialogue: 0,0:12:32.83,0:12:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Mao masih hidup,
Dialogue: 0,0:12:34.92,0:12:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}murid senior lainnya pasti juga.
Dialogue: 0,0:12:37.75,0:12:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:12:38.84,0:12:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita meninggalkan Ibu Kota,
Dialogue: 0,0:12:42.26,0:12:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi beberapa orang menuju ke sana.
Dialogue: 0,0:12:48.01,0:12:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mungkin datang untuk menengok\Nkeluarga dan orang terkasih.
Dialogue: 0,0:12:58.73,0:13:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Lagi pula, aku berhenti!
Dialogue: 0,0:13:00.19,0:13:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Hyakka!
Dialogue: 0,0:13:03.20,0:13:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka datang
Dialogue: 0,0:13:05.11,0:13:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari barat!
Dialogue: 0,0:13:22.71,0:13:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidur nyenyak!
Dialogue: 0,0:13:29.89,0:13:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak hal terjadi belakangan ini.
Dialogue: 0,0:13:36.14,0:13:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gempa Besar Kanto,
Dialogue: 0,0:13:39.36,0:13:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rumah-rumah runtuh,
Dialogue: 0,0:13:41.57,0:13:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kota terbakar,
Dialogue: 0,0:13:44.53,0:13:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langit tertutup asap.
Dialogue: 0,0:13:47.61,0:13:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Byoki muncul.
Dialogue: 0,0:13:51.24,0:13:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan
Dialogue: 0,0:13:52.87,0:13:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuhku!
Dialogue: 0,0:13:54.75,0:13:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao…
Dialogue: 0,0:13:57.54,0:14:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao berubah menjadi semacam binatang buas.
Dialogue: 0,0:14:04.34,0:14:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu monster yang kulihat hari itu!
Dialogue: 0,0:14:10.43,0:14:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan tahun lalu, hari itu,
Dialogue: 0,0:14:14.47,0:14:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ditarik oleh kekuatan dahsyat
Dialogue: 0,0:14:19.69,0:14:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berakhir di tempat itu.
Dialogue: 0,0:14:26.07,0:14:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu
Dialogue: 0,0:14:27.36,0:14:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bertemu Byoki.
Dialogue: 0,0:14:41.59,0:14:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:14:46.59,0:14:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, semuanya sangat aneh.
Dialogue: 0,0:14:50.26,0:14:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak Byoki muncul,
Dialogue: 0,0:14:52.14,0:14:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dua murid senior Mao muncul satu per satu.
Dialogue: 0,0:14:55.64,0:14:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau Mao si pengkhianat?
Dialogue: 0,0:14:57.98,0:14:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau datang untuk membunuhku?
Dialogue: 0,0:15:01.44,0:15:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka belum pernah bertemu\Nsampai sekarang.
Dialogue: 0,0:15:04.86,0:15:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada hubungannya\Ndengan kembalinya Byoki?
Dialogue: 0,0:15:08.74,0:15:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau harus membunuh Nona Sana juga?
Dialogue: 0,0:15:10.95,0:15:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat apa pun.
Dialogue: 0,0:15:12.49,0:15:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian berdua
Dialogue: 0,0:15:13.91,0:15:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasangan?
Dialogue: 0,0:15:17.16,0:15:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka.
Dialogue: 0,0:15:18.75,0:15:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Smoothie-mu.
Dialogue: 0,0:15:20.37,0:15:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:21.54,0:15:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah selagi kau berada di masa kini.
Dialogue: 0,0:15:24.42,0:15:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, Uozumi.
Dialogue: 0,0:15:26.17,0:15:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini benar-benar perlu?
Dialogue: 0,0:15:28.76,0:15:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum belajar cara melawan Byoki.
Dialogue: 0,0:15:32.97,0:15:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia menemukanmu,\Ndia pasti akan mengendalikanmu.
Dialogue: 0,0:15:36.27,0:15:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah, Nanoka. Ini demi kesehatanmu.
Dialogue: 0,0:15:40.10,0:15:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:42.56,0:15:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak mengerti ada apa dengan Kakek.
Dialogue: 0,0:15:47.32,0:15:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan! Sangat tidak enak!
Dialogue: 0,0:15:55.95,0:15:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:15:57.45,0:15:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:16:00.66,0:16:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini!
Dialogue: 0,0:16:15.97,0:16:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Nanoka.
Dialogue: 0,0:16:17.72,0:16:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baru keluar dari rumah sakit,
Dialogue: 0,0:16:18.89,0:16:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi itu pasti sulit.
Dialogue: 0,0:16:20.89,0:16:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Smoothie-nya terlalu manjur!
Dialogue: 0,0:16:29.86,0:16:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengkhawatirkan luka Tenko.
Dialogue: 0,0:16:38.95,0:16:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali capung.
Dialogue: 0,0:16:41.66,0:16:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu agak menakutkan.
Dialogue: 0,0:16:44.12,0:16:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin akan ada gempa bumi besar lagi?
Dialogue: 0,0:16:48.09,0:16:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, capung merah itu…
Dialogue: 0,0:16:50.59,0:16:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak sekali beberapa hari ini.
Dialogue: 0,0:16:53.34,0:16:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu terlalu banyak?
Dialogue: 0,0:16:56.26,0:16:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melepas perbanmu sekarang, Tenko.
Dialogue: 0,0:16:58.39,0:16:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:17:01.48,0:17:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus. Kau sudah sembuh.
Dialogue: 0,0:17:03.81,0:17:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Dokter Mao.
Dialogue: 0,0:17:06.23,0:17:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali.
Dialogue: 0,0:17:07.98,0:17:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tertabrak mobil tempo hari.
Dialogue: 0,0:17:11.44,0:17:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini… Aku seorang ayakashi…
Dialogue: 0,0:17:15.56,0:17:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kenapa aku merasa kita diawasi?
Dialogue: 0,0:17:20.45,0:17:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah mereka shikigami\Nyang dikendalikan seseorang?
Dialogue: 0,0:17:23.91,0:17:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mungkin saja.
Dialogue: 0,0:17:27.07,0:17:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mao!
Dialogue: 0,0:17:29.13,0:17:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya kau bersembunyi di sini!
Dialogue: 0,0:17:32.05,0:17:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:33.17,0:17:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga itu kau, Hyakka.
Dialogue: 0,0:17:35.63,0:17:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau bilang\Ntak mau melihat wajah Mao lagi?
Dialogue: 0,0:17:41.85,0:17:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shikigami datang dari barat.
Dialogue: 0,0:17:45.39,0:17:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah memasuki Ibu Kota.
Dialogue: 0,0:17:47.60,0:17:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mungkin mencari kita.
Dialogue: 0,0:17:50.77,0:17:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pengkhianat.
Dialogue: 0,0:17:52.36,0:17:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mereka menemukanmu,\Nkaulah yang pertama dibunuh.
Dialogue: 0,0:17:55.03,0:17:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:55.99,0:17:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid senior lagi?
Dialogue: 0,0:17:59.07,0:18:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kenapa dia datang jauh-jauh kemari\Nuntuk memperingatkan kami?
Dialogue: 0,0:18:03.20,0:18:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia sebenarnya baik?
Dialogue: 0,0:18:05.96,0:18:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mereka shikigami,
Dialogue: 0,0:18:07.83,0:18:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa mengurus mereka\Ntanpa menarik perhatian.
Dialogue: 0,0:18:11.30,0:18:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Hyakka. Aku bisa membantumu.
Dialogue: 0,0:18:14.76,0:18:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh! Aku memerintahkanmu\Nuntuk membantuku!
Dialogue: 0,0:18:17.59,0:18:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia datang untuk meminta bantuan.
Dialogue: 0,0:18:22.39,0:18:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu…
Dialogue: 0,0:18:23.52,0:18:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan jika murid senior lainnya\Nmasih hidup,
Dialogue: 0,0:18:26.23,0:18:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kalian harus terus\Nbertarung sekarang?
Dialogue: 0,0:18:29.15,0:18:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, bukankah kalian
Dialogue: 0,0:18:32.52,0:18:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipanggil ke Goshikido itu,\Nsekitar 900 tahun lalu?
Dialogue: 0,0:18:38.16,0:18:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mewarisi seni rahasia,
Dialogue: 0,0:18:40.53,0:18:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian harus saling bertarung.
Dialogue: 0,0:18:43.83,0:18:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari hal-hal seperti Jugondo?\NBukankah dunia sudah beralih
Dialogue: 0,0:18:48.21,0:18:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanya aku.
Dialogue: 0,0:18:50.00,0:18:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:18:51.17,0:18:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya,
Dialogue: 0,0:18:52.79,0:18:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di setiap era, akan ada orang\Nyang percaya pada kutukan
Dialogue: 0,0:18:55.05,0:18:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ingin menggunakannya.
Dialogue: 0,0:18:58.26,0:19:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Klan Goko, kelompok onmyoji\Nyang melestarikan seni rahasia Jugondo
Dialogue: 0,0:19:03.68,0:19:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetap ada berdampingan dengan kutukan itu.
Dialogue: 0,0:19:07.39,0:19:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku masih tidak mengerti
Dialogue: 0,0:19:09.19,0:19:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana para murid senior\Nbisa tetap hidup.
Dialogue: 0,0:19:16.69,0:19:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ngengat?
Dialogue: 0,0:19:19.70,0:19:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang musuh sudah dekat.
Dialogue: 0,0:19:22.32,0:19:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka memakai ngengat sebagai mata-mata?
Dialogue: 0,0:19:27.54,0:19:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:19:40.59,0:19:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka…
Dialogue: 0,0:19:45.26,0:19:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menduga sebanyak ini!
Dialogue: 0,0:19:48.23,0:19:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan itu!
Dialogue: 0,0:19:54.94,0:19:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, lari!
Dialogue: 0,0:19:56.82,0:19:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kita lari?
Dialogue: 0,0:19:58.82,0:19:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:00.24,0:20:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa membunuh mereka.
Dialogue: 0,0:20:02.16,0:20:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka
Dialogue: 0,0:20:03.28,0:20:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manusia!
Dialogue: 0,0:20:04.45,0:20:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:26.76,0:20:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan. Apa mereka mencari kita?
Dialogue: 0,0:20:29.73,0:20:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memasang pelindung.
Dialogue: 0,0:20:31.60,0:20:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak akan terlihat oleh mereka.
Dialogue: 0,0:20:35.02,0:20:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa langkah kita selanjutnya, Mao?
Dialogue: 0,0:20:36.98,0:20:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah lebih cepat membunuh mereka\Ndan menyelesaikannya?
Dialogue: 0,0:20:40.28,0:20:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin mereka manusia?
Dialogue: 0,0:20:43.16,0:20:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shikigami kura-kura\Ndan katak pertama yang kulihat
Dialogue: 0,0:20:46.03,0:20:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin mengutuk penduduk setempat\Nuntuk mengendalikan mereka.
Dialogue: 0,0:20:49.24,0:20:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:20:50.58,0:20:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jika kita mematahkan kutukannya,
Dialogue: 0,0:20:52.21,0:20:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa mengembalikan mereka\Nmenjadi manusia.
Dialogue: 0,0:20:55.29,0:20:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, kemarilah.
Dialogue: 0,0:20:59.00,0:20:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:00.51,0:21:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut filosofi Lima Elemen Onmyo…
Dialogue: 0,0:21:02.80,0:21:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Apa yang tiba-tiba kau bicarakan?
Dialogue: 0,0:21:05.09,0:21:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua hal di dunia ini dipengaruhi
Dialogue: 0,0:21:07.10,0:21:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh lima elemen,\Nyaitu Kayu, Api, Tanah, Logam, dan Air.
Dialogue: 0,0:21:11.43,0:21:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katak dan kura-kura itu adalah Elemen Air.
Dialogue: 0,0:21:15.69,0:21:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air memadamkan Api.
Dialogue: 0,0:21:17.56,0:21:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, Air mengalahkan Api.
Dialogue: 0,0:21:22.78,0:21:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Hyakka menggunakan api,
Dialogue: 0,0:21:25.11,0:21:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia lemah melawan mantra Onmyodo Elemen Air.
Dialogue: 0,0:21:28.03,0:21:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:21:29.45,0:21:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sisi lain, Tanah menyerap Air\Ndan menghentikannya.
Dialogue: 0,0:21:34.12,0:21:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanah mengalahkan Air.
Dialogue: 0,0:21:36.75,0:21:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdasarkan pengamatanku, Nanoka,
Dialogue: 0,0:21:39.00,0:21:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau termasuk Elemen Tanah.
Dialogue: 0,0:21:41.09,0:21:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku mengerti.
Dialogue: 0,0:21:43.34,0:21:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa?
Dialogue: 0,0:21:44.72,0:21:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuat senjata darurat.
Dialogue: 0,0:21:47.05,0:21:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memasukkan tanah
Dialogue: 0,0:21:48.35,0:21:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta katashiro milikmu ke dalam bambu ini
Dialogue: 0,0:21:51.03,0:21:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memasukkan energi spiritual.
Dialogue: 0,0:21:53.06,0:21:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katashiro?
Dialogue: 0,0:21:55.10,0:21:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini membuatmu menyatu dengan senjata ini.
Dialogue: 0,0:21:58.86,0:22:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kau hanya perlu\Nmenyerang mereka di tanden,
Dialogue: 0,0:22:01.02,0:22:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ada di bawah pusar.
Dialogue: 0,0:22:03.69,0:22:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan mengeluarkan kutukan\Ndari tubuh mereka
Dialogue: 0,0:22:05.95,0:22:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengembalikan mereka\Nke wujud manusia tanpa membunuh mereka.
Dialogue: 0,0:22:09.03,0:22:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Sama sekali tidak!
Dialogue: 0,0:22:11.70,0:22:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katak raksasa itu bahkan tidak punya pusar\Ndan tongkat ini terlalu pendek!
Dialogue: 0,0:22:14.75,0:22:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut! Mereka menjijikkan!
Dialogue: 0,0:22:16.54,0:22:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa! Tidak mungkin!
Dialogue: 0,0:22:19.25,0:22:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, hanya kau yang bisa melakukan ini.
Dialogue: 0,0:22:22.34,0:22:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Jangan mendekat!
Dialogue: 0,0:22:24.17,0:22:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:22:25.38,0:22:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:22:26.63,0:22:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:22:28.59,0:22:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut dan…
Dialogue: 0,0:22:31.18,0:22:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanah…
Dialogue: 0,0:22:33.22,0:22:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seharusnya cukup.
Dialogue: 0,0:22:35.18,0:22:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan baik-baik saja, Nanoka.
Dialogue: 0,0:22:37.06,0:22:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berada di sisimu.
Dialogue: 0,0:22:39.06,0:22:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji? Sebaiknya begitu!
Dialogue: 0,0:22:41.23,0:22:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuka pelindungnya.
Dialogue: 0,0:22:42.90,0:22:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nanoka, semoga berhasil.
Dialogue: 0,0:22:54.75,0:22:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:22:56.83,0:22:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa! Aku takut!
Dialogue: 0,0:22:58.33,0:23:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menjijikkan!
Dialogue: 0,0:23:03.05,0:23:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:23:04.63,0:23:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa. Coba lagi.
Dialogue: 0,0:23:09.76,0:23:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:24:49.94,0:24:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa memikirkan beberapa murid senior\Nyang bisa merapal Mantra Air,
Dialogue: 0,0:24:54.66,0:24:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi adakah yang akan menggunakan\Ntaktik agresif seperti itu?
Dialogue: 0,0:24:58.12,0:24:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:24:59.75,0:25:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya meminta satu mantra.
Dialogue: 0,0:25:01.50,0:25:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kau mengajariku satu mantra saja?
Dialogue: 0,0:25:04.25,0:25:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyuruhku bertarung bersamamu?
Dialogue: 0,0:25:07.13,0:25:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mantra yang tertulis\Ndi gulungan rahasia yang dilahap Byoki.
Dialogue: 0,0:25:10.46,0:25:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seni rahasia Taizanfukun.
Dialogue: 0,0:25:14.51,0:25:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Taizanfukun".
