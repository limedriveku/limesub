Dialogue: 0,0:10:01.01,0:10:01.85,sign,,0000,0000,0000,,KUCHINAWA
Dialogue: 0,0:10:01.93,0:10:04.68,sign,,0000,0000,0000,,"KAMON"
Dialogue: 0,0:12:28.04,0:12:29.91,sign,,0000,0000,0000,,"HYAKKA"
Dialogue: 0,0:12:30.00,0:12:31.79,sign,,0000,0000,0000,,"HYAKKA"
Dialogue: 0,0:13:08.84,0:13:11.98,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:15:18.75,0:15:20.29,sign,,0000,0000,0000,,"UOZUMI FUNA, KAKEK NANOKA"
Dialogue: 0,0:15:55.95,0:15:56.95,sign,,0000,0000,0000,,"NAKAGAWA YUI"
Dialogue: 0,0:16:17.72,0:16:18.81,sign,,0000,0000,0000,,"HITOMI, HARUKA"
Dialogue: 0,0:16:24.56,0:16:27.94,sign,,0000,0000,0000,,JALAN PERBELANJAAN KELIMA
Dialogue: 0,0:21:15.69,0:21:17.48,sign,,0000,0000,0000,,"AIR, API"
Dialogue: 0,0:21:17.56,0:21:20.07,sign,,0000,0000,0000,,"AIR, API"
