Dialogue: 0,0:00:19.22,0:00:21.81,sign,,0000,0000,0000,,JALAN PERBELANJAAN KELIMA
Dialogue: 0,0:00:24.73,0:00:26.02,sign,,0000,0000,0000,,"KIBA NANOKA"
Dialogue: 0,0:00:29.15,0:00:31.15,sign,,0000,0000,0000,,"UOZUMI FUNA"
Dialogue: 0,0:01:05.26,0:01:08.44,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:02:22.68,0:02:26.02,sign,,0000,0000,0000,,BYOKI
Dialogue: 0,0:02:33.94,0:02:34.78,sign,,0000,0000,0000,,KAMON
Dialogue: 0,0:02:37.65,0:02:39.11,sign,,0000,0000,0000,,"HYAKKA"
Dialogue: 0,0:02:46.54,0:02:49.21,sign,,0000,0000,0000,,"MAO"
Dialogue: 0,0:03:19.44,0:03:21.53,sign,,0000,0000,0000,,"BENIKO"
Dialogue: 0,0:04:41.11,0:04:43.53,sign,,0000,0000,0000,,"SHIRANUI"
Dialogue: 0,0:04:54.41,0:04:56.63,sign,,0000,0000,0000,,"MASAGO"
Dialogue: 0,0:05:13.77,0:05:16.14,sign,,0000,0000,0000,,"GURU KLAN GOKO"
Dialogue: 0,0:06:06.78,0:06:08.32,sign,,0000,0000,0000,,"OTOYA"
Dialogue: 0,0:10:12.90,0:10:15.11,sign,,0000,0000,0000,,APA YANG HARUS KULAKUKAN?
Dialogue: 0,0:10:54.78,0:10:56.03,sign,,0000,0000,0000,,"UOZUMI FUNA"
Dialogue: 0,0:11:50.50,0:11:52.29,sign,,0000,0000,0000,,KAKEK NANOKA
Dialogue: 0,0:12:02.68,0:12:05.97,sign,,0000,0000,0000,,MAO
Dialogue: 0,0:12:06.05,0:12:08.93,sign,,0000,0000,0000,,BYOKI
Dialogue: 0,0:13:47.49,0:13:49.45,sign,,0000,0000,0000,,MILK HALL
Dialogue: 0,0:13:54.45,0:13:55.87,sign,,0000,0000,0000,,"TENKO"
Dialogue: 0,0:14:09.22,0:14:11.39,sign,,0000,0000,0000,,"DOKTER SHIBASATO"
Dialogue: 0,0:15:46.40,0:15:48.99,sign,,0000,0000,0000,,YOSHIFUSA
Dialogue: 0,0:15:55.37,0:15:57.66,sign,,0000,0000,0000,,"YURAKO"
Dialogue: 0,0:16:22.19,0:16:23.40,sign,,0000,0000,0000,,SHIBASATO KITAMI
Dialogue: 0,0:20:08.66,0:20:10.33,sign,,0000,0000,0000,,"SANA"
Dialogue: 0,0:21:33.50,0:21:36.38,sign,,0000,0000,0000,,KUE NATAL
Dialogue: 0,0:22:05.65,0:22:11.62,sign,,0000,0000,0000,,KUE NATAL
Dialogue: 0,0:22:28.64,0:22:30.55,sign,,0000,0000,0000,,DASAR-DASAR ONMYOJUTSU
Dialogue: 0,0:22:34.18,0:22:36.69,sign,,0000,0000,0000,,"HAFALKAN INI"
Dialogue: 0,0:22:47.15,0:22:49.07,sign,,0000,0000,0000,,UDON
Dialogue: 0,0:24:49.23,0:24:50.07,sign,,0000,0000,0000,,"SELANJUTNYA"
Dialogue: 0,0:00:24.73,0:00:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi sekarang, Uozumi.
Dialogue: 0,0:00:26.15,0:00:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri tahu sekolah\Nbahwa aku akan absen.
Dialogue: 0,0:00:29.15,0:00:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Nona Nanoka.
Dialogue: 0,0:00:31.24,0:00:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga dirimu.
Dialogue: 0,0:00:41.83,0:00:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:00:44.54,0:00:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memberi tahu Mao\Nbahwa aku bertemu Byoki itu.
Dialogue: 0,0:02:31.94,0:02:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:02:34.86,0:02:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih mengantuk…
Dialogue: 0,0:02:37.65,0:02:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakka. Teh.
Dialogue: 0,0:02:39.28,0:02:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera.
Dialogue: 0,0:02:41.66,0:02:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kamon?
Dialogue: 0,0:02:43.87,0:02:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka, kenapa kau di sini\Npagi-pagi sekali?
Dialogue: 0,0:02:46.54,0:02:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, sedang apa dia di sini?
Dialogue: 0,0:02:49.75,0:02:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NSaat kita bertemu dengannya sebelumnya…
Dialogue: 0,0:02:53.04,0:02:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk ayakashi hewan yang terluka.
Dialogue: 0,0:02:55.71,0:02:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya dia mencampur aroma pelacak
Dialogue: 0,0:02:57.30,0:02:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke dalam obat yang dia berikan.
Dialogue: 0,0:03:00.68,0:03:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu bekerja dengan baik\Npada lukanya, bukan?
Dialogue: 0,0:03:03.22,0:03:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menggunakannya pada Tenko.
Dialogue: 0,0:03:06.01,0:03:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membuat obat sendiri.
Dialogue: 0,0:03:08.81,0:03:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:09.85,0:03:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak memercayaiku?
Dialogue: 0,0:03:12.44,0:03:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku memercayaimu\Ndan tidur nyenyak semalaman.
Dialogue: 0,0:03:16.53,0:03:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya. Kalau begitu…
Dialogue: 0,0:03:19.44,0:03:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa suruh shikigami penjagamu untuk mundur?
Dialogue: 0,0:03:22.49,0:03:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tehmu.
Dialogue: 0,0:03:23.74,0:03:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir, aku tidak meracuninya.
Dialogue: 0,0:03:25.41,0:03:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan baik-baik saja.\NAku punya penawarnya.
Dialogue: 0,0:03:29.54,0:03:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan orang-orang ini?
Dialogue: 0,0:03:32.88,0:03:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sama sekali tidak saling percaya?
Dialogue: 0,0:03:36.09,0:03:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Kamon...
Dialogue: 0,0:03:37.92,0:03:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kau di Kyoto.
Dialogue: 0,0:03:40.09,0:03:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:41.13,0:03:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berkeliling\Ndengan keluarga kaya di sana.
Dialogue: 0,0:03:46.39,0:03:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situlah aku mulai mendengar rumor.
Dialogue: 0,0:03:50.02,0:03:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang onmyoji\Nyang bisa memperpanjang umur orang.
Dialogue: 0,0:03:54.06,0:03:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu memakai nama Klan Goko,
Dialogue: 0,0:03:56.40,0:03:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melakukan penipuan\Ndengan mantra perpanjangan umur palsu.
Dialogue: 0,0:04:02.86,0:04:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Mao.
Dialogue: 0,0:04:04.45,0:04:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ajari aku
Dialogue: 0,0:04:06.20,0:04:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantra rahasia Taizanfukun.
Dialogue: 0,0:04:09.91,0:04:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa orang itu Penyihir Air?
Dialogue: 0,0:04:13.33,0:04:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:14.92,0:04:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuhan
Dialogue: 0,0:04:16.83,0:04:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum berakhir!
Dialogue: 0,0:04:19.00,0:04:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menduga itu Shiranui.
Dialogue: 0,0:04:22.34,0:04:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Shiranui?
Dialogue: 0,0:04:24.22,0:04:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengejutkan, bukan?
Dialogue: 0,0:04:25.34,0:04:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:26.47,0:04:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui adalah…
Dialogue: 0,0:04:28.76,0:04:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mengatakannya?\NDi antara Penyihir Air…
Dialogue: 0,0:04:31.31,0:04:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak berbakat!
Dialogue: 0,0:04:33.81,0:04:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti saja!
Dialogue: 0,0:04:35.77,0:04:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Guru!
Dialogue: 0,0:04:41.11,0:04:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu dimarahi oleh Guru.
Dialogue: 0,0:04:44.91,0:04:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sering menemani Guru,
Dialogue: 0,0:04:47.95,0:04:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sering melihat itu terjadi.
Dialogue: 0,0:04:50.70,0:04:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika Shiranui masih hidup,
Dialogue: 0,0:04:54.41,0:04:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu berarti dia dipanggil ke Goshikido
Dialogue: 0,0:04:56.75,0:04:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan Masago, penyihir yang lebih baik.
Dialogue: 0,0:04:59.38,0:05:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sekali.
Dialogue: 0,0:05:01.00,0:05:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Goshikido dirancang
Dialogue: 0,0:05:03.13,0:05:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar setiap orang masuk sendirian\Nlewat satu dari lima pintu masuk terpisah,
Dialogue: 0,0:05:06.51,0:05:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa pernah melihat yang lain.
Dialogue: 0,0:05:09.47,0:05:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dirancang agar tidak ada yang tahu\Nsiapa lagi yang dipanggil.
Dialogue: 0,0:05:13.77,0:05:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari lima orang yang dipanggil ke sini,
Dialogue: 0,0:05:16.73,0:05:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siapa pun yang selamat pada akhirnya
Dialogue: 0,0:05:18.86,0:05:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menjadi penerus sejati.
Dialogue: 0,0:05:21.32,0:05:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,
Dialogue: 0,0:05:22.28,0:05:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika ada yang tahu\Nkau dipanggil ke Goshikido,
Dialogue: 0,0:05:26.20,0:05:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}empat orang lainnya\Nmungkin mencoba mengutukmu sampai mati.
Dialogue: 0,0:05:30.16,0:05:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya semua orang bersikap\Nseolah tidak terjadi apa-apa.
Dialogue: 0,0:05:35.79,0:05:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, sekitar waktu itu,
Dialogue: 0,0:05:37.96,0:05:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang-orang di kompleks itu\Nmulai mati secara misterius.
Dialogue: 0,0:05:41.42,0:05:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam setiap kasus, mereka murid senior
Dialogue: 0,0:05:43.26,0:05:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dianggap\Nsebagai praktisi paling terampil
Dialogue: 0,0:05:45.55,0:05:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}salah satu dari Lima Elemen.
Dialogue: 0,0:05:47.51,0:05:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:48.68,0:05:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa kematian terjadi beruntun.
Dialogue: 0,0:05:53.35,0:05:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya orang\Nyang boleh mengutuk secara terbuka…
Dialogue: 0,0:05:57.23,0:05:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Mao, sang tumbal.
Dialogue: 0,0:06:00.48,0:06:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, tak ada yang tahu\Nsiapa musuh mereka.
Dialogue: 0,0:06:03.57,0:06:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa mereka akhirnya\Ntak sengaja dikutuk sampai mati.
Dialogue: 0,0:06:06.78,0:06:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini? Itu menakutkan.
Dialogue: 0,0:06:09.41,0:06:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu seperti ini.
Dialogue: 0,0:06:12.28,0:06:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk memberitahunya\Ntentang Byoki itu,
Dialogue: 0,0:06:14.79,0:06:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi selalu ada drama gila\Nyang terjadi di sini,
Dialogue: 0,0:06:17.66,0:06:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku tidak pernah bisa\Nmemberitahunya hal penting.
Dialogue: 0,0:06:21.00,0:06:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu hal yang pasti.
Dialogue: 0,0:06:23.92,0:06:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui berusaha mendapatkan\Nteknik rahasia Taizanfukun
Dialogue: 0,0:06:28.22,0:06:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menjadi penerus sejati Klan Goko.
Dialogue: 0,0:06:32.30,0:06:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, orang itu sangat jahat.
Dialogue: 0,0:06:36.02,0:06:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa dia\Ntidak mengejar kita sendiri?
Dialogue: 0,0:06:38.73,0:06:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia sibuk menjalankan\Npenipuan perpanjangan umurnya.
Dialogue: 0,0:06:42.11,0:06:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh? Itu alasannya?
Dialogue: 0,0:06:44.19,0:06:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kakinya…
Dialogue: 0,0:06:47.11,0:06:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melukainya,
Dialogue: 0,0:06:49.28,0:06:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia pura-pura tidak merasakan apa pun.
Dialogue: 0,0:06:52.87,0:06:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakinya…
Dialogue: 0,0:06:58.04,0:06:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku mengerti.
Dialogue: 0,0:07:00.46,0:07:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa lagi, Mao.
Dialogue: 0,0:07:02.29,0:07:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa?
Dialogue: 0,0:07:03.54,0:07:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan pergi.
Dialogue: 0,0:07:05.50,0:07:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:07:08.38,0:07:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membangkitkan banyak kenangan\Nyang lebih baik kulupakan.
Dialogue: 0,0:07:15.31,0:07:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik Hyakka maupun Kamon\Ntidak ingin melanjutkan pembunuhan.
Dialogue: 0,0:07:20.48,0:07:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Shiranui sendiri
Dialogue: 0,0:07:23.48,0:07:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih berniat melanjutkan\Npertarungan sampai mati.
Dialogue: 0,0:07:28.65,0:07:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini…
Dialogue: 0,0:07:31.03,0:07:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kita bicara sekarang?
Dialogue: 0,0:07:34.28,0:07:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kau katakan?
Dialogue: 0,0:07:36.91,0:07:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu menemukanku di sisi lain.
Dialogue: 0,0:07:43.00,0:07:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kau memberitahuku lebih awal!
Dialogue: 0,0:07:46.00,0:07:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kalian bertiga\Nsedang berdiskusi penting.
Dialogue: 0,0:07:49.80,0:07:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka.
Dialogue: 0,0:07:51.13,0:07:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa ia melakukan sesuatu kepadamu?
Dialogue: 0,0:07:53.51,0:07:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia mengejarku.
Dialogue: 0,0:07:55.01,0:07:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Byoki itu bilang…
Dialogue: 0,0:07:58.60,0:08:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih bisa kembali sekarang.
Dialogue: 0,0:08:02.35,0:08:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau terus menyerahkan dirimu\Nkepada Mao,
Dialogue: 0,0:08:06.69,0:08:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan…
Dialogue: 0,0:08:09.53,0:08:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu apa artinya?
Dialogue: 0,0:08:13.70,0:08:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu tahu
Dialogue: 0,0:08:14.95,0:08:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}darah Nanoka menopang hidupku?
Dialogue: 0,0:08:21.00,0:08:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka pingsan usai memberiku darahnya,
Dialogue: 0,0:08:23.96,0:08:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku mendapatkan kembali kekuatanku.
Dialogue: 0,0:08:27.04,0:08:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu berarti
Dialogue: 0,0:08:28.17,0:08:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku memperpendek umur Nanoka?
Dialogue: 0,0:08:37.72,0:08:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ia memang membicarakan darahku.
Dialogue: 0,0:08:40.89,0:08:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:42.52,0:08:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada saat itu,
Dialogue: 0,0:08:44.69,0:08:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa seperti tersedot
Dialogue: 0,0:08:47.27,0:08:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau mungkin\Nseperti ada yang terkuras dariku.
Dialogue: 0,0:08:50.69,0:08:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak saat itu,
Dialogue: 0,0:08:53.03,0:08:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa sangat sehat.
Dialogue: 0,0:08:55.57,0:08:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu? Itu hal buruk?
Dialogue: 0,0:08:58.24,0:08:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak takut
Dialogue: 0,0:09:00.87,0:09:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mungkin menguras tenagamu?
Dialogue: 0,0:09:04.54,0:09:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:09:05.96,0:09:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu membantumu sembuh,\Nbukankah itu cukup?
Dialogue: 0,0:09:09.04,0:09:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Byoki itu muncul di depan Nanoka\Nhanya untuk memperingatkannya?
Dialogue: 0,0:09:13.38,0:09:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ia tidak mau Mao tetap hidup, bukan?
Dialogue: 0,0:09:17.89,0:09:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama Mao masih hidup,
Dialogue: 0,0:09:19.64,0:09:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki itu tidak bisa\Nmengambil kembali tubuhnya.
Dialogue: 0,0:09:23.64,0:09:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya jika kau terluka lagi,
Dialogue: 0,0:09:26.19,0:09:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memberimu darahku.
Dialogue: 0,0:09:28.27,0:09:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka!
Dialogue: 0,0:09:30.23,0:09:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak boleh mengatakan\Nhal begitu seenteng itu.
Dialogue: 0,0:09:33.65,0:09:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku tidak menduganya.
Dialogue: 0,0:09:36.41,0:09:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, itu menguntungkanmu, bukan?
Dialogue: 0,0:09:39.62,0:09:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guci kodoku-nya hancur.
Dialogue: 0,0:09:42.16,0:09:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:09:43.79,0:09:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus menjaga tubuhmu\Ndengan lebih baik.
Dialogue: 0,0:09:47.75,0:09:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:49.00,0:09:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah caramu memperlakukanku selama ini?
Dialogue: 0,0:09:52.42,0:09:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti maksudmu.
Dialogue: 0,0:09:54.26,0:09:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh tidak tahu, ya?
Dialogue: 0,0:09:56.18,0:09:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang apa?
Dialogue: 0,0:09:58.14,0:09:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:10:00.51,0:10:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya surat dari Uozumi,
Dialogue: 0,0:10:02.01,0:10:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}shikigami yang kau kirim ke dunia lain.
Dialogue: 0,0:10:19.70,0:10:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otoya, ambilkan gelas sake.
Dialogue: 0,0:10:22.12,0:10:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Tuan Mao.
Dialogue: 0,0:10:25.20,0:10:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:10:34.38,0:10:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum ini, Nanoka.
Dialogue: 0,0:10:36.59,0:10:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:10:37.80,0:10:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini air dengan jimat pelindung terlarut.
Dialogue: 0,0:10:40.39,0:10:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini,\NByoki itu tidak akan bisa menyentuhmu.
Dialogue: 0,0:10:42.93,0:10:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:48.10,0:10:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan ini kepada Funa.
Dialogue: 0,0:10:50.19,0:10:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Funa?
Dialogue: 0,0:10:51.23,0:10:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama depan shikigami itu.
Dialogue: 0,0:10:52.81,0:10:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh…
Dialogue: 0,0:10:54.78,0:10:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu sangat cocok dengannya.
Dialogue: 0,0:10:56.94,0:10:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jimat pelindung\Ndan alat kutukan untuk melindungimu.
Dialogue: 0,0:11:05.83,0:11:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan kembali sekarang.
Dialogue: 0,0:11:10.17,0:11:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, Nona Nanoka.
Dialogue: 0,0:11:15.75,0:11:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sadar Byoki itu mengincarku, tapi…
Dialogue: 0,0:11:19.26,0:11:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus menjaga tubuhmu\Ndengan lebih baik.
Dialogue: 0,0:11:24.18,0:11:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengatakan itu\Nkarena mengkhawatirkanku, bukan?
Dialogue: 0,0:11:28.73,0:11:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa cuma perasaanku saja?
Dialogue: 0,0:11:30.60,0:11:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikapnya tampak lebih baik kepadaku\Ndaripada sebelumnya.
Dialogue: 0,0:11:42.11,0:11:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang!
Dialogue: 0,0:11:43.74,0:11:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali, Nanoka.
Dialogue: 0,0:11:48.79,0:11:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek?
Dialogue: 0,0:11:59.05,0:12:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki!
Dialogue: 0,0:12:12.02,0:12:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byoki!
Dialogue: 0,0:12:14.48,0:12:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek. Pergi!
Dialogue: 0,0:12:17.69,0:12:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uozumi!
Dialogue: 0,0:12:22.07,0:12:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak bisa bergerak?
Dialogue: 0,0:12:25.03,0:12:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya Mao menyuruhmu\Nmenelan jimat pelindung.
Dialogue: 0,0:12:30.00,0:12:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kau harus tahu, Nanoka,
Dialogue: 0,0:12:32.37,0:12:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak pernah berniat menyakitimu.
Dialogue: 0,0:12:36.71,0:12:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:37.84,0:12:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu Mao.
Dialogue: 0,0:12:40.34,0:12:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, dia akan membutuhkanku.
Dialogue: 0,0:12:44.09,0:12:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia ingin tahu kebenarannya.
Dialogue: 0,0:12:48.22,0:12:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebenarannya?
Dialogue: 0,0:12:49.72,0:12:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:12:52.31,0:12:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebenaran tentang masa lalu Mao\Ndari 900 tahun lalu?
Dialogue: 0,0:12:55.02,0:12:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin telah membunuh putri Guru.
Dialogue: 0,0:12:58.15,0:13:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin telah membunuh Nona Sana.
Dialogue: 0,0:13:01.44,0:13:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka,
Dialogue: 0,0:13:03.53,0:13:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika kau ingin menemuiku,
Dialogue: 0,0:13:06.24,0:13:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}panggil namaku kapan saja.
Dialogue: 0,0:13:13.25,0:13:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hilang.
Dialogue: 0,0:13:14.92,0:13:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Nanoka?
Dialogue: 0,0:13:17.25,0:13:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek baik-baik saja?
Dialogue: 0,0:13:19.50,0:13:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:20.42,0:13:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kucing…
Dialogue: 0,0:13:22.09,0:13:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh…
Dialogue: 0,0:13:23.59,0:13:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keterlaluan.
Dialogue: 0,0:13:24.80,0:13:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit kupercaya ia masuk ke rumah kita!
Dialogue: 0,0:13:27.01,0:13:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uozumi.
Dialogue: 0,0:13:28.51,0:13:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uozumi benci kucing.
Dialogue: 0,0:13:33.89,0:13:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, dia akan membutuhkanku.
Dialogue: 0,0:13:37.56,0:13:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau ingin menemuiku,
Dialogue: 0,0:13:40.15,0:13:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}panggil namaku kapan saja.
Dialogue: 0,0:13:42.28,0:13:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku melakukan itu!
Dialogue: 0,0:13:44.40,0:13:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tetap saja,\Napa yang diinginkan Byoki itu?
Dialogue: 0,0:13:51.70,0:13:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:13:54.45,0:13:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Dokter Mao,
Dialogue: 0,0:13:57.04,0:13:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maafkan aku karena memanggilmu.
Dialogue: 0,0:13:59.00,0:14:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa. Sejak gempa bumi besar itu,
Dialogue: 0,0:14:01.21,0:14:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin tahu\Nbagaimana keadaanmu di Milk Hall.
Dialogue: 0,0:14:09.22,0:14:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Dokter Shibasato.
Dialogue: 0,0:14:11.47,0:14:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dokter yang dihormati.
Dialogue: 0,0:14:14.31,0:14:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku sudah pensiun.
Dialogue: 0,0:14:16.69,0:14:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tanganku terluka\Nsaat gempa bumi itu.
Dialogue: 0,0:14:21.19,0:14:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu,
Dialogue: 0,0:14:22.61,0:14:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dokter pribadi
Dialogue: 0,0:14:24.44,0:14:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}putra keluarga bangsawan\Nyang sakit-sakitan.
Dialogue: 0,0:14:28.45,0:14:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku belum bertemu keluarganya\Nsejak gempa bumi itu.
Dialogue: 0,0:14:33.16,0:14:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, baru-baru ini,
Dialogue: 0,0:14:35.91,0:14:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menerima telepon dari putranya.
Dialogue: 0,0:14:38.79,0:14:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter.
Dialogue: 0,0:14:40.58,0:14:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Muda.
Dialogue: 0,0:14:42.38,0:14:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Tuan Yoshifusa?
Dialogue: 0,0:14:44.13,0:14:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku… Kumohon…
Dialogue: 0,0:14:50.43,0:14:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku mengunjungi kediaman itu.
Dialogue: 0,0:14:53.89,0:14:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun…
Dialogue: 0,0:15:01.27,0:15:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di depan pintu,
Dialogue: 0,0:15:02.86,0:15:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bertemu keluarga\Nyang belum pernah kulihat.
Dialogue: 0,0:15:05.23,0:15:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dengan sopan memintaku pergi.
Dialogue: 0,0:15:09.49,0:15:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun…
Dialogue: 0,0:15:14.08,0:15:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sesaat,\Nkupikir aku melihat Tuan Yoshifusa
Dialogue: 0,0:15:17.83,0:15:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengintip dari jendela.
Dialogue: 0,0:15:21.63,0:15:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terus bertanya-tanya
Dialogue: 0,0:15:22.71,0:15:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang terjadi di rumah itu?
Dialogue: 0,0:15:25.84,0:15:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi\Nkepada mantan pemilik kediaman itu?
Dialogue: 0,0:15:29.22,0:15:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pergi dari rumah,
Dialogue: 0,0:15:30.18,0:15:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka terjebak dalam kebakaran\Nsetelah gempa bumi itu
Dialogue: 0,0:15:32.51,0:15:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghilang, menurut rumor.
Dialogue: 0,0:15:37.10,0:15:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah mereka diambil alih?
Dialogue: 0,0:15:50.24,0:15:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut…
Dialogue: 0,0:15:53.87,0:15:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa
Dialogue: 0,0:15:55.37,0:15:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gerangan orang-orang itu?
Dialogue: 0,0:16:17.81,0:16:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:16:19.02,0:16:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Hei!
Dialogue: 0,0:16:20.02,0:16:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau baik-baik saja?
Dialogue: 0,0:16:23.48,0:16:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya
Dialogue: 0,0:16:25.11,0:16:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia berjalan jauh-jauh\Nhanya untuk menemuiku.
Dialogue: 0,0:16:28.07,0:16:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Yoshifusa
Dialogue: 0,0:16:29.65,0:16:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selalu lemah.
Dialogue: 0,0:16:31.86,0:16:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:16:33.99,0:16:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Shibasato, maksudmu
Dialogue: 0,0:16:36.20,0:16:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Yoshifusa kabur dari rumah\Nuntuk menemuimu?
Dialogue: 0,0:16:42.96,0:16:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku berpikir begitu,
Dialogue: 0,0:16:45.38,0:16:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ternyata tidak.
Dialogue: 0,0:16:48.00,0:16:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa?
Dialogue: 0,0:16:50.30,0:16:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat setelah Tuan Yoshifusa dibawa masuk,
Dialogue: 0,0:16:54.09,0:16:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang kerabat wanita datang berkunjung.
Dialogue: 0,0:16:58.06,0:17:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah diambil alih oleh orang asing?
Dialogue: 0,0:17:01.56,0:17:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, itukah yang dikatakan\NTuan Yoshifusa kepadamu?
Dialogue: 0,0:17:05.09,0:17:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut kerabat ini,
Dialogue: 0,0:17:07.98,0:17:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tuan dan nyonya rumah
Dialogue: 0,0:17:10.78,0:17:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memang tewas dalam kebakaran\Nsetelah gempa bumi besar itu.
Dialogue: 0,0:17:14.56,0:17:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menolong Tuan Yoshifusa\Nyang sakit-sakitan,
Dialogue: 0,0:17:18.07,0:17:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kerabat mendiang tuan pindah ke rumah itu.
Dialogue: 0,0:17:23.75,0:17:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah sering bertemu mereka\Nsejak kecil,
Dialogue: 0,0:17:27.38,0:17:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia menjadi sangat takut pada mereka.
Dialogue: 0,0:17:30.55,0:17:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Yoshifusa selalu tidak stabil\Nsecara emosional.
Dialogue: 0,0:17:36.30,0:17:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Dia selalu seperti itu.
Dialogue: 0,0:17:40.76,0:17:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,\Nsebagai tanda terima kasih kami…
Dialogue: 0,0:17:44.81,0:17:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diberi banyak uang, dan bertanya
Dialogue: 0,0:17:46.85,0:17:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku bisa merawat Tuan Yoshifusa\Ndi rumahku untuk sementara.
Dialogue: 0,0:17:52.28,0:17:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah pensiun,
Dialogue: 0,0:17:54.07,0:17:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengkhawatirkan Tuan Yoshifusa.
Dialogue: 0,0:17:57.82,0:17:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah yang terjadi?
Dialogue: 0,0:18:06.08,0:18:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kuakui, itu agak antiklimaks.
Dialogue: 0,0:18:09.46,0:18:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:12.92,0:18:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Dokter Shibasato puas\Ndengan penjelasan itu,
Dialogue: 0,0:18:16.01,0:18:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak apa-apa.
Dialogue: 0,0:18:17.80,0:18:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak ada penyebab supernatural,
Dialogue: 0,0:18:19.55,0:18:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada yang bisa kulakukan.
Dialogue: 0,0:18:42.78,0:18:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao!
Dialogue: 0,0:18:44.49,0:18:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Aku tidak menduga\Nakan bertemu dengannya secepat ini!
Dialogue: 0,0:18:50.88,0:18:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih terlalu dini bagi kami untuk bertemu.
Dialogue: 0,0:18:55.30,0:18:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:18:57.26,0:19:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku senang telah datang\Nke Ibu Kota Kekaisaran.
Dialogue: 0,0:19:03.97,0:19:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Nanoka?
Dialogue: 0,0:19:05.47,0:19:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kembali lagi?
Dialogue: 0,0:19:07.27,0:19:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, harusnya aku yang bilang begitu.
Dialogue: 0,0:19:10.44,0:19:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai khawatir Tuan Hyakka
Dialogue: 0,0:19:13.11,0:19:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan tinggal bersama kita.
Dialogue: 0,0:19:14.61,0:19:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:19:15.90,0:19:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mampir untuk istirahat.
Dialogue: 0,0:19:20.28,0:19:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau harus membunuh Nona Sana juga?
Dialogue: 0,0:19:22.24,0:19:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu satu hal yang tidak bisa kumaafkan!
Dialogue: 0,0:19:24.54,0:19:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bilang begitu,
Dialogue: 0,0:19:26.12,0:19:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia selalu datang menemui Mao.
Dialogue: 0,0:19:28.96,0:19:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu Mao.
Dialogue: 0,0:19:31.08,0:19:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, dia akan membutuhkanku.
Dialogue: 0,0:19:34.17,0:19:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia ingin tahu kebenarannya…
Dialogue: 0,0:19:38.26,0:19:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang paling ingin diketahui Mao
Dialogue: 0,0:19:41.47,0:19:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah apa dia sungguh membunuh Nona Sana.
Dialogue: 0,0:19:45.64,0:19:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu menggerogotinya
Dialogue: 0,0:19:47.60,0:19:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena dia pasti jatuh cinta kepadanya.
Dialogue: 0,0:19:53.56,0:19:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei.\N- Hah?
Dialogue: 0,0:19:56.90,0:19:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa Nona Sana?
Dialogue: 0,0:20:01.86,0:20:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa dia?
Dialogue: 0,0:20:03.49,0:20:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cantik dan baik,
Dialogue: 0,0:20:06.20,0:20:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cerdas dan polos.
Dialogue: 0,0:20:08.66,0:20:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan meskipun dia putri Guru,
Dialogue: 0,0:20:10.87,0:20:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tetap mengobrol dengan kami,\Npara murid, tanpa berpura-pura.
Dialogue: 0,0:20:14.00,0:20:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia? Nona Sempurna?
Dialogue: 0,0:20:16.75,0:20:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penerus Klan Goko
Dialogue: 0,0:20:18.55,0:20:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya menikahi Nona Sana, kan?
Dialogue: 0,0:20:22.26,0:20:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:23.26,0:20:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mao terpilih sebagai penerus,
Dialogue: 0,0:20:26.05,0:20:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi dia pasti senang.
Dialogue: 0,0:20:28.43,0:20:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tergila-gila pada Nona Sana.
Dialogue: 0,0:20:32.64,0:20:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia tak bisa melupakannya.
Dialogue: 0,0:20:35.19,0:20:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun dia sudah lama meninggal.
Dialogue: 0,0:20:44.74,0:20:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pulang.
Dialogue: 0,0:20:46.87,0:20:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanoka di sini?
Dialogue: 0,0:20:48.95,0:20:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Namun, sepertinya\Ndia tak punya urusan penting.
Dialogue: 0,0:20:52.04,0:20:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:20:53.50,0:20:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kurasa tidak ada hal buruk\Nyang terjadi di dunianya.
Dialogue: 0,0:20:58.75,0:20:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:21:05.89,0:21:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat bodoh.
Dialogue: 0,0:21:08.81,0:21:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia tidak bisa melupakannya?\NItu terjadi 900 tahun lalu.
Dialogue: 0,0:21:12.14,0:21:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap dia melupakannya.
Dialogue: 0,0:21:15.02,0:21:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa memberitahunya tentang Byoki itu.
Dialogue: 0,0:21:20.19,0:21:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, setelah itu,\NByoki itu tidak pernah muncul.
Dialogue: 0,0:21:24.66,0:21:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu karena penghalang
Dialogue: 0,0:21:26.53,0:21:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang Uozumi pasang di sekitar rumah.
Dialogue: 0,0:21:29.70,0:21:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan tidak ada pembunuh baru\Nyang mendatangi Mao.
Dialogue: 0,0:21:37.21,0:21:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau ingin menemuiku,
Dialogue: 0,0:21:39.92,0:21:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}panggil namaku kapan saja.
Dialogue: 0,0:21:42.88,0:21:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya jika aku tidak memanggil,\Nia tidak akan datang?
Dialogue: 0,0:21:47.34,0:21:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mao.
Dialogue: 0,0:21:48.51,0:21:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Nanoka?
Dialogue: 0,0:21:51.14,0:21:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untukmu.
Dialogue: 0,0:21:52.52,0:21:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Natal!
Dialogue: 0,0:21:55.98,0:21:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya ucapan terima kasih\Natas semua yang kau lakukan untukku.
Dialogue: 0,0:21:59.19,0:22:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Nanoka.
Dialogue: 0,0:22:00.94,0:22:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya sesuatu untukmu.
Dialogue: 0,0:22:14.58,0:22:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatnya hanya untukmu.
Dialogue: 0,0:22:18.04,0:22:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengharapkan hadiah balasan, tapi
Dialogue: 0,0:22:21.38,0:22:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku senang sekali!
Dialogue: 0,0:22:34.18,0:22:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara merapal mantra dan membuat segel tangan?
Dialogue: 0,0:22:37.14,0:22:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memberiku PR?
Dialogue: 0,0:22:44.86,0:22:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayamnya sudah siap.
Dialogue: 0,0:22:49.62,0:22:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syal wol, ya?
Dialogue: 0,0:22:52.20,0:22:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cukup hangat.
Dialogue: 0,0:22:56.87,0:22:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu datanglah tahun baru.
Dialogue: 0,0:22:59.79,0:23:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu tahun ke-13 Taisho, 1924.
Dialogue: 0,0:23:12.97,0:23:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi,
Dialogue: 0,0:23:14.47,0:23:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}insiden baru mulai terungkap.
Dialogue: 0,0:24:49.23,0:24:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada hari itu,
Dialogue: 0,0:24:50.28,0:24:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}area itu dilaporkan dipenuhi darah,
Dialogue: 0,0:24:52.65,0:24:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seragam militer, dan bayonet,
Dialogue: 0,0:24:55.12,0:24:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta banyak bongkahan perak\Nyang tersebar di antaranya.
Dialogue: 0,0:24:58.95,0:25:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang akhirnya bertemu denganmu.
Dialogue: 0,0:25:00.91,0:25:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten Shirasu
Dialogue: 0,0:25:02.37,0:25:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau
Dialogue: 0,0:25:03.54,0:25:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}haruskah aku memanggilmu Hakubi?
Dialogue: 0,0:25:06.75,0:25:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia penyihir?
Dialogue: 0,0:25:08.05,0:25:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa wanita ini?
Dialogue: 0,0:25:09.17,0:25:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bukan hanya Shiranui\Nyang ingin menangkap Mao hidup-hidup?
Dialogue: 0,0:25:12.26,0:25:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini
Dialogue: 0,0:25:13.38,0:25:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}energi logam?
Dialogue: 0,0:25:15.01,0:25:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Topeng Besi".
