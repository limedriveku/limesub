Dialogue: 0,0:00:15.50,0:00:16.00,sign,,0000,0000,0000,,HANYA IRUMA YANG PERINGKAT 5
Dialogue: 0,0:00:33.47,0:00:40.77,sign,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:01:55.01,0:01:55.60,sign,,0000,0000,0000,,DI BALIK TATAPAN
Dialogue: 0,0:02:37.43,0:02:40.01,sign,,0000,0000,0000,,PERINGKAT 5 (HE)
Dialogue: 0,0:07:33.81,0:07:37.19,sign,,0000,0000,0000,,GEROMBOLAN ENAM JARI
Dialogue: 0,0:09:21.71,0:09:25.29,sign,,0000,0000,0000,,SAYA SALAH MEMILIH UCAPAN
Dialogue: 0,0:09:27.92,0:09:31.30,sign,,0000,0000,0000,,MARI KITA BAHAS BERSAMA
Dialogue: 0,0:09:31.72,0:09:36.81,sign,,0000,0000,0000,,CARA BERTEMU KEMBALI DENGAN TUAN DELKIRA
Dialogue: 0,0:13:57.86,0:14:02.32,sign,,0000,0000,0000,,KITA SAMA!
Dialogue: 0,0:17:28.94,0:17:30.95,sign,,0000,0000,0000,,SELAMAT ATAS KENAIKAN PERINGKAT
Dialogue: 0,0:17:30.95,0:17:32.86,sign,,0000,0000,0000,,DAN KEMENANGAN DI FESTIVAL MUSIK
Dialogue: 0,0:19:46.87,0:19:48.38,sign,,0000,0000,0000,,KAMERA 1
Dialogue: 0,0:19:48.38,0:19:49.88,sign,,0000,0000,0000,,KAMERA 2
Dialogue: 0,0:19:49.88,0:19:51.38,sign,,0000,0000,0000,,KAMERA 3
Dialogue: 0,0:24:07.38,0:24:08.39,sign,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:24:29.99,0:24:30.49,sign,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:00:01.52,0:00:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma dan kelas abnormal\Nberhasil memenangkan festival musik.
Dialogue: 0,0:00:05.68,0:00:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berhasil naik ke peringkat Daleth\Ndan menyelesaikan tugas mereka.
Dialogue: 0,0:00:11.41,0:00:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pun bisa tetap\Nmenggunakan Kelas Raja, Royal One.
Dialogue: 0,0:00:16.00,0:00:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Acara untuk murid kelas satu\Ntelah selesai semua.
Dialogue: 0,0:00:19.21,0:00:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akankah Iruma dan yang lain bisa menikmati\Nsekolah dengan tenang untuk sementara?
Dialogue: 0,0:01:55.60,0:01:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Di Balik Tatapan".
Dialogue: 0,0:02:01.10,0:02:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar mereka itu...
Dialogue: 0,0:02:03.14,0:02:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi seenaknya karena sedang berpesta.
Dialogue: 0,0:02:06.02,0:02:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma, tunjukkan panahmu!
Dialogue: 0,0:02:09.53,0:02:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panah yang diajarkan Barbatos itu.
Dialogue: 0,0:02:12.70,0:02:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panah iblis peringkat He\Npasti hebat, deh.
Dialogue: 0,0:02:16.53,0:02:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau pun menjawab dengan santainya...
Dialogue: 0,0:02:19.79,0:02:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kok.
Dialogue: 0,0:02:20.79,0:02:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ambil dulu bulunya\Ndi batra peralatan sihir.
Dialogue: 0,0:02:23.25,0:02:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irumachi tidak boleh pergi!
Dialogue: 0,0:02:25.88,0:02:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu, dua...
Dialogue: 0,0:02:27.59,0:02:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang mengambilnya!
Dialogue: 0,0:02:32.67,0:02:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Tuan Iruma keluar,\Npasti ada banyak yang mengerumuninya.
Dialogue: 0,0:02:37.43,0:02:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, beliau peringkat He!
Dialogue: 0,0:02:40.01,0:02:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak iblis yang mendambakan\Nwibawa beliau!
Dialogue: 0,0:02:42.31,0:02:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma memang hebat!
Dialogue: 0,0:02:44.19,0:02:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku jadi tidak seperingkat\Ndengan beliau lagi, ya.
Dialogue: 0,0:02:47.56,0:02:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:02:49.02,0:02:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus segera menyusul beliau.
Dialogue: 0,0:02:52.86,0:02:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada seseorang di dalam?
Dialogue: 0,0:02:58.95,0:03:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah kembali!
Dialogue: 0,0:03:01.79,0:03:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Schenell, kamu lagi-lagi menggunakan\Nruangan batra tanpa izin!
Dialogue: 0,0:03:08.25,0:03:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Amy?
Dialogue: 0,0:03:13.09,0:03:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asmo—
Dialogue: 0,0:03:16.72,0:03:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, bertahanlah!
Dialogue: 0,0:03:18.76,0:03:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kak! Kak! Apa kamu baik-baik saja?\N- Apakah para pemirsa yang budiman
Dialogue: 0,0:03:21.14,0:03:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kak! Kak! Apa kamu baik-baik saja?\N- masih mengingat dirinya?
Dialogue: 0,0:03:22.77,0:03:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amy Kiriwo.
Dialogue: 0,0:03:25.14,0:03:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amy Kiriwo adalah iblis\Nyang pernah bersekolah di Babyls.
Dialogue: 0,0:03:30.19,0:03:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan hidupnya adalah\Nmelihat keputusasaan orang lain.
Dialogue: 0,0:03:34.36,0:03:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mengerti?
Dialogue: 0,0:03:35.74,0:03:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat keputusasaan orang lain\Nadalah tujuan hidupku!
Dialogue: 0,0:03:40.28,0:03:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mewujudkan tujuannya itu,
Dialogue: 0,0:03:43.12,0:03:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiriwo berencana meledakkan\Nsemua murid di Babyls
Dialogue: 0,0:03:45.58,0:03:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melihat wajah orang tua\Nmereka yang putus asa.
Dialogue: 0,0:03:48.67,0:03:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, rencana itu berhasil digagalkan
Dialogue: 0,0:03:52.59,0:03:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh Iruma,\Npemuda yang pantang menyerah.
Dialogue: 0,0:03:55.92,0:03:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat, Iruma.
Dialogue: 0,0:04:00.39,0:04:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sayang sekali dunia tidak jadi kacau,\Ntapi tadi itu menyenangkan.
Dialogue: 0,0:04:04.85,0:04:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan-kapan kita main lagi, ya."
Dialogue: 0,0:04:07.81,0:04:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiriwo ditangkap dan dipenjara\Ndi rubanah Walter Park,
Dialogue: 0,0:04:12.52,0:04:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi berhasil kabur.
Dialogue: 0,0:04:14.44,0:04:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asmodeus dan Clara\Ntidak mengetahui semua itu.
Dialogue: 0,0:04:19.61,0:04:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku hanya terkejut.
Dialogue: 0,0:04:23.06,0:04:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisi tubuhmu masih sama, ya.
Dialogue: 0,0:04:27.37,0:04:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia sudah kembali?
Dialogue: 0,0:04:30.58,0:04:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali yang ingin kutanyakan.
Dialogue: 0,0:04:33.21,0:04:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia tidak masuk?\NDi mana dia selama ini?
Dialogue: 0,0:04:37.13,0:04:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:04:39.68,0:04:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Kak Kiriwo...\NSekarang tak ada di sini.
Dialogue: 0,0:04:45.68,0:04:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti akan aku ceritakan.
Dialogue: 0,0:04:47.68,0:04:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya.\N- Ya.
Dialogue: 0,0:04:48.73,0:04:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:04:50.52,0:04:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batra peralatan sihir.
Dialogue: 0,0:04:52.48,0:04:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua melindunginya, ya.
Dialogue: 0,0:04:55.61,0:04:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski interiornya agak beda.
Dialogue: 0,0:04:59.82,0:05:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:05:01.57,0:05:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir batra ini sudah dibubarkan.
Dialogue: 0,0:05:06.12,0:05:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua berkat kerja keras Tuan Iruma!
Dialogue: 0,0:05:09.12,0:05:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma?
Dialogue: 0,0:05:10.62,0:05:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:05:12.58,0:05:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama Kakak tidak masuk,\Nbanyak hal yang terjadi.
Dialogue: 0,0:05:16.38,0:05:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berhasil memenangkan festival musik.
Dialogue: 0,0:05:19.47,0:05:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma pun berhasil\Nnaik ke peringkat He!
Dialogue: 0,0:05:22.01,0:05:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau memang sosok yang membuka\Njalannya sendiri di dunia iblis!
Dialogue: 0,0:05:24.85,0:05:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat sekali, ya.
Dialogue: 0,0:05:26.93,0:05:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya kamu adalah Penuntunnya.
Dialogue: 0,0:05:30.39,0:05:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuntun?
Dialogue: 0,0:05:34.90,0:05:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu ada di sisinya\Ndan menerangi jalannya dengan apimu.
Dialogue: 0,0:05:40.86,0:05:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa terus maju pasti berkat kamu.
Dialogue: 0,0:05:46.99,0:05:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku senang kalau itu benar.
Dialogue: 0,0:05:56.04,0:05:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak.
Dialogue: 0,0:05:57.55,0:06:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada waktu, temuilah Tuan Iruma.
Dialogue: 0,0:06:00.80,0:06:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia akan senang.
Dialogue: 0,0:06:03.97,0:06:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:06:06.30,0:06:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin bertemu Iruma.
Dialogue: 0,0:06:21.32,0:06:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, panas sekali.
Dialogue: 0,0:06:24.82,0:06:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Balam pernah\Nmemperlihatkannya padaku.
Dialogue: 0,0:06:29.08,0:06:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang masuk dalam\Nmode siklus jahat.
Dialogue: 0,0:06:33.21,0:06:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang jatuh terlalu jauh\Ndalam mode siklus jahatnya.
Dialogue: 0,0:06:40.30,0:06:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tatapan yang sama.
Dialogue: 0,0:06:45.22,0:06:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:06:46.84,0:06:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, untuk apa bedebah sepertimu\Nmendekati Tuan Iruma?
Dialogue: 0,0:06:52.73,0:06:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalilah ke asalmu!
Dialogue: 0,0:06:56.60,0:06:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh.
Dialogue: 0,0:06:58.73,0:07:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan keberadaan\Nyang tidak mengenakkan.
Dialogue: 0,0:07:02.19,0:07:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu sensitif, tahu.\NJadi, ini salahmu, lo.
Dialogue: 0,0:07:06.74,0:07:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kamu mengganggu saat aku santai.
Dialogue: 0,0:07:12.33,0:07:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu payah sekali merayu.\NAku suka dipaksa, sih.
Dialogue: 0,0:07:16.87,0:07:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku juga benci yang keras kepala.
Dialogue: 0,0:07:20.00,0:07:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:07:21.09,0:07:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu tadi?\NEnam Keroco?
Dialogue: 0,0:07:27.68,0:07:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerombolan Enam Jari.
Dialogue: 0,0:07:30.14,0:07:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerombolan Enam Jari.
Dialogue: 0,0:07:31.89,0:07:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerombolan penjahat yang konon
Dialogue: 0,0:07:33.81,0:07:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlibat dalam berbagai macam kejahatan.
Dialogue: 0,0:07:38.15,0:07:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, mereka yang telah membantu
Dialogue: 0,0:07:41.02,0:07:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiriwo melarikan diri dari\Npenjara bawah tanah di Walter Park.
Dialogue: 0,0:07:46.70,0:07:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang mengendalikan Kiriwo\Ndan Gerombolan Enam Jari
Dialogue: 0,0:07:51.70,0:07:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Raja Petir, Baal.
Dialogue: 0,0:07:54.33,0:07:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan telah mengikuti Anda.
Dialogue: 0,0:07:58.58,0:08:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, cat kukuku mengelupas.\N- Saya hanya ingin bicara dengan Anda.
Dialogue: 0,0:08:01.88,0:08:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Harus kucat lagi.\N- Saya hanya ingin bicara dengan Anda.
Dialogue: 0,0:08:04.09,0:08:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Anda tertarik?
Dialogue: 0,0:08:06.30,0:08:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal kebangkitan Tuan Delkira.
Dialogue: 0,0:08:36.45,0:08:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kamu...
Dialogue: 0,0:08:38.50,0:08:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kamu bilang "kebangkitan"?
Dialogue: 0,0:08:42.75,0:08:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bicara seolah Tuan Delkira\Nsudah tidak ada di dunia ini.
Dialogue: 0,0:08:49.68,0:08:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau adalah sosok tertinggi\Ndan teramat agung.
Dialogue: 0,0:08:53.05,0:08:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu penghinaan terbesar\Nterhadap Raja Iblis saat ini!
Dialogue: 0,0:08:57.27,0:09:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Layaknya suara beliau...
Dialogue: 0,0:09:00.27,0:09:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detak jantung ganjil ini\Nharus segera dihentikan.
Dialogue: 0,0:09:06.28,0:09:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bocah.
Dialogue: 0,0:09:09.28,0:09:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, suaramu berantakan\Ndan menjijikkan, tahu.
Dialogue: 0,0:09:43.02,0:09:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau pecah!
Dialogue: 0,0:09:44.81,0:09:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Kak Amy\Nhanya punya sedikit energi sihir!
Dialogue: 0,0:09:49.03,0:09:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dia bisa\Nmembuat perisai sekuat ini?
Dialogue: 0,0:09:53.95,0:09:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak bingung, ya.
Dialogue: 0,0:09:57.33,0:10:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi sihir ini adalah pinjaman.
Dialogue: 0,0:10:01.50,0:10:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pinjaman?
Dialogue: 0,0:10:02.92,0:10:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak membuatkan tanda baru untukku.
Dialogue: 0,0:10:06.84,0:10:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar aku tidak lupa dengan\Napa yang terjadi saat itu.
Dialogue: 0,0:10:14.34,0:10:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak membuatnya berbentuk\Ncincin seperti punya Iruma.
Dialogue: 0,0:10:28.98,0:10:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu mengincar Tuan Iruma?
Dialogue: 0,0:10:33.49,0:10:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:10:34.99,0:10:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak peduli tujuanmu!
Dialogue: 0,0:10:37.24,0:10:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa membiarkan iblis sepertimu\Nmendekati Tuan Iruma!
Dialogue: 0,0:10:44.04,0:10:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu polos, ya.
Dialogue: 0,0:10:49.13,0:10:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking putih dan polosnya\Nsampai tak tahu apa-apa.
Dialogue: 0,0:10:54.09,0:10:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu bukan masalah.
Dialogue: 0,0:10:56.26,0:11:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa mengagumi Iruma\Nsebagai iblis hebat berperingkat He.
Dialogue: 0,0:11:00.47,0:11:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah sosoknya yang kamu suka\Ndan terpesona olehnya.
Dialogue: 0,0:11:04.89,0:11:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku...
Dialogue: 0,0:11:09.40,0:11:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan mengungkap diri\Nyang tidak ingin ditunjukkan olehnya
Dialogue: 0,0:11:13.74,0:11:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menikmatinya sepenuh hati.
Dialogue: 0,0:11:21.12,0:11:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz, kamu lama banget!
Dialogue: 0,0:11:24.62,0:11:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:11:26.17,0:11:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku bosan menunggu.
Dialogue: 0,0:11:28.29,0:11:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas! Apa ini?
Dialogue: 0,0:11:29.67,0:11:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh, jangan mendekat!\NDia berbaha—
Dialogue: 0,0:11:33.17,0:11:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:11:37.18,0:11:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz, kamu pasti mengkhayal, ya.
Dialogue: 0,0:11:50.73,0:11:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kiriwo.
Dialogue: 0,0:11:52.32,0:11:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toto.
Dialogue: 0,0:11:54.90,0:11:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu jadi terlihat jantan.
Dialogue: 0,0:11:57.91,0:11:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:11:59.91,0:12:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tidak pandai merayu.
Dialogue: 0,0:12:03.37,0:12:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerja kerasnya.
Dialogue: 0,0:12:05.37,0:12:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku minta tolong Hyu saja.
Dialogue: 0,0:12:09.58,0:12:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Anda?
Dialogue: 0,0:12:12.04,0:12:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda menemukan yang dicari?
Dialogue: 0,0:12:14.30,0:12:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak ketemu.
Dialogue: 0,0:12:17.51,0:12:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:12:20.76,0:12:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lain kali pasti akan kudapatkan.
Dialogue: 0,0:12:25.68,0:12:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:12:28.77,0:12:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, karena sudah\Nmenyelesaikan tugas utama,
Dialogue: 0,0:12:31.98,0:12:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak perlu berlama-lama.
Dialogue: 0,0:12:33.86,0:12:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum anjing Babyls menemukan kita,
Dialogue: 0,0:12:37.65,0:12:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo kita pergi.
Dialogue: 0,0:12:40.95,0:12:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merayu orang sepertiku\Ntidaklah murah, lo.
Dialogue: 0,0:12:46.25,0:12:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sadar akan itu.
Dialogue: 0,0:12:59.34,0:13:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, cukup bicara saja.
Dialogue: 0,0:13:03.14,0:13:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang Anda inginkan?
Dialogue: 0,0:13:06.47,0:13:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda ada di pihak yang mana?
Dialogue: 0,0:13:13.36,0:13:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihannya...
Dialogue: 0,0:13:16.73,0:13:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di tangan Anda.
Dialogue: 0,0:14:04.99,0:14:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pestanya menyenangkan sekali!
Dialogue: 0,0:14:07.79,0:14:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya! Woosh! Wuush! Weesh!\NMeriah banget!
Dialogue: 0,0:14:12.71,0:14:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking meriahnya sampai kita\Nkena marah Pak Kalego, ya.
Dialogue: 0,0:14:18.09,0:14:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Eggy pemarah.
Dialogue: 0,0:14:20.46,0:14:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Clara.
Dialogue: 0,0:14:21.88,0:14:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat sudah naik peringkat Daleth.
Dialogue: 0,0:14:23.72,0:14:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:24.64,0:14:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga selamat sudah naik peringkat He.
Dialogue: 0,0:14:27.47,0:14:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:28.64,0:14:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sampai besok,\NIrumachi, Azz-Azz.
Dialogue: 0,0:14:33.10,0:14:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Azz-Azz?
Dialogue: 0,0:14:35.27,0:14:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz?
Dialogue: 0,0:14:37.82,0:14:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Tuan Iruma.
Dialogue: 0,0:14:40.57,0:14:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:14:42.19,0:14:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Tuan Iruma...
Dialogue: 0,0:14:45.66,0:14:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak apa-apa.
Dialogue: 0,0:14:47.99,0:14:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerja kerasnya\Ndi festival musik.
Dialogue: 0,0:14:50.37,0:14:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahatlah yang nyenyak hari ini, ya.
Dialogue: 0,0:14:52.83,0:14:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Azz juga sama.
Dialogue: 0,0:14:54.83,0:14:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:14:56.42,0:14:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sampai besok.
Dialogue: 0,0:14:57.92,0:14:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara bodoh jangan sampai kesiangan.
Dialogue: 0,0:14:59.88,0:15:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak bakal!
Dialogue: 0,0:15:00.84,0:15:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara!
Dialogue: 0,0:15:02.63,0:15:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:15:04.59,0:15:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mami! Konchie! Keebow!\NSin Sin! Ran Ran!
Dialogue: 0,0:15:07.97,0:15:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}David.
Dialogue: 0,0:15:08.60,0:15:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:15:11.60,0:15:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:15:13.18,0:15:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali, Clara.\NSelamat atas kemenangannya.
Dialogue: 0,0:15:16.85,0:15:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat, Mbak!\N- Ayo pulang, David.
Dialogue: 0,0:15:18.44,0:15:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Luar biasa banget, deh!\N- Ayo pulang, David.
Dialogue: 0,0:15:21.53,0:15:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi kelas lain juga hebat!
Dialogue: 0,0:15:32.83,0:15:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:15:35.41,0:15:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali, Tuan Iruma.
Dialogue: 0,0:15:38.96,0:15:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerja kerasnya\Ndi festival musik.
Dialogue: 0,0:15:41.55,0:15:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.\NPestanya juga sangat menyenangkan.
Dialogue: 0,0:15:45.01,0:15:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek mana?\NKukira bakal...
Dialogue: 0,0:15:46.76,0:15:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma, selamat datang kembali!
Dialogue: 0,0:15:51.43,0:15:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat! Nah, waktunya berpesta!
Dialogue: 0,0:15:54.77,0:15:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira bakal begitu, sih.
Dialogue: 0,0:15:57.64,0:15:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Sullivan...
Dialogue: 0,0:16:00.31,0:16:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lagu Karpet Lilith?
Dialogue: 0,0:17:07.97,0:17:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali, Iruma!
Dialogue: 0,0:17:11.26,0:17:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:17:12.72,0:17:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iringan musikmu benar-benar luar biasa!
Dialogue: 0,0:17:15.06,0:17:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek sampai terharu!
Dialogue: 0,0:17:17.06,0:17:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking terharunya sampai\Ningin kuputar tiap malam.
Dialogue: 0,0:17:20.31,0:17:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa tidak berisik?
Dialogue: 0,0:17:22.94,0:17:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah direkam, aku jadi bisa\Ndengar berulang-ulang tanpa henti!
Dialogue: 0,0:17:28.94,0:17:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas kenaikan ke peringkat He.
Dialogue: 0,0:17:32.86,0:17:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus di festival musik.
Dialogue: 0,0:17:34.83,0:17:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:17:36.24,0:17:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kakek, Opera.
Dialogue: 0,0:17:39.25,0:17:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah sepuasmu.
Dialogue: 0,0:17:41.00,0:17:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Opera telah mengerahkan kemampuannya\Nuntuk membuat semua ini.
Dialogue: 0,0:17:44.58,0:17:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu makanannya masih banyak,\Njadi jangan sungkan.
Dialogue: 0,0:17:49.59,0:17:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan!
Dialogue: 0,0:17:54.39,0:17:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka masakan Opera.
Dialogue: 0,0:18:02.35,0:18:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Opera menang lagi.
Dialogue: 0,0:18:04.44,0:18:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Opera kuat sekali.
Dialogue: 0,0:18:06.94,0:18:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi.
Dialogue: 0,0:18:08.53,0:18:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hampir waktunya tidur.
Dialogue: 0,0:18:11.03,0:18:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, ya?
Dialogue: 0,0:18:13.03,0:18:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Opera.
Dialogue: 0,0:18:16.16,0:18:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sekali saja.
Dialogue: 0,0:18:19.87,0:18:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:18:22.41,0:18:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya.
Dialogue: 0,0:18:26.00,0:18:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku banyak dipuji hari ini.
Dialogue: 0,0:18:27.84,0:18:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanannya juga enak sekali.\NSampai nambah juga.
Dialogue: 0,0:18:31.30,0:18:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bermain gim yang menyenangkan.
Dialogue: 0,0:18:34.51,0:18:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Ali?
Dialogue: 0,0:18:37.26,0:18:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, tidak ada reaksi.
Dialogue: 0,0:18:41.27,0:18:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia tidur lagi, ya?
Dialogue: 0,0:18:48.23,0:18:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masuk ke Babyls, Iruma mendapat\N"Cincin Kerakusan" pada balapan terbang.
Dialogue: 0,0:18:53.65,0:18:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok misterius yang ada\Ndalam cincin itu adalah Ali.
Dialogue: 0,0:18:58.16,0:18:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau lengkapnya...
Dialogue: 0,0:18:59.74,0:19:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alicred.
Dialogue: 0,0:19:01.54,0:19:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya begitu.
Dialogue: 0,0:19:07.58,0:19:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bicara denganmu, Ali.
Dialogue: 0,0:19:12.76,0:19:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ali!
Dialogue: 0,0:19:15.18,0:19:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, Irubo, kudengar kamu\Nsudah berjuang di festival musik.
Dialogue: 0,0:19:18.85,0:19:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berhasil menang!
Dialogue: 0,0:19:20.35,0:19:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku juga naik peringkat He...
Dialogue: 0,0:19:22.89,0:19:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf, Irubo.\NSepertinya kita tidak bisa mengobrol lama.
Dialogue: 0,0:19:28.86,0:19:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengawasimu lebih\Nsebagai partner kecilmu.
Dialogue: 0,0:19:33.86,0:19:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya itu, Ali?
Dialogue: 0,0:19:36.57,0:19:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan pergi.
Dialogue: 0,0:19:38.66,0:19:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Ali!
Dialogue: 0,0:19:43.62,0:19:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ali!
Dialogue: 0,0:19:44.87,0:19:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memanggilku?
Dialogue: 0,0:19:52.00,0:19:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memanggilku?
Dialogue: 0,0:19:54.38,0:19:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali!
Dialogue: 0,0:19:57.38,0:20:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa kamu jadi besar?
Dialogue: 0,0:20:00.39,0:20:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah, aku masih sama.
Dialogue: 0,0:20:03.35,0:20:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, aku Ali yang baru!
Dialogue: 0,0:20:06.52,0:20:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ali yang baru?
Dialogue: 0,0:20:09.19,0:20:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, perhatian.
Dialogue: 0,0:20:13.86,0:20:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ali yang tertidur dalam cincin?
Dialogue: 0,0:20:17.61,0:20:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kamu naik ke peringkat Daleth,
Dialogue: 0,0:20:20.70,0:20:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anehnya aku merasa sangat mengantuk.
Dialogue: 0,0:20:23.49,0:20:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti putri tidur yang terkena sihir.
Dialogue: 0,0:20:27.41,0:20:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:29.67,0:20:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa? Apa? Apa yang terjadi?\N- Aku terbangun oleh suara yang amat keras!
Dialogue: 0,0:20:32.29,0:20:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa? Tidak!\N- Saat aku sadar,
Dialogue: 0,0:20:35.42,0:20:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu sudah naik ke peringkat He.
Dialogue: 0,0:20:39.84,0:20:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena itu\Naku jadi dipenuhi kekuatan.
Dialogue: 0,0:20:44.81,0:20:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kepompong yang berubah\Njadi kupu-kupu?
Dialogue: 0,0:20:48.14,0:20:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlahir kembali?
Dialogue: 0,0:20:49.35,0:20:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku jadi bisa\Nmelakukan banyak hal.
Dialogue: 0,0:20:52.81,0:20:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Irubo.
Dialogue: 0,0:20:54.02,0:20:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku bisa\Nmenggunakan sihir baru—
Dialogue: 0,0:20:57.69,0:20:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:21:00.36,0:21:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku hanya lega.
Dialogue: 0,0:21:03.49,0:21:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tentu saja aku juga terkejut.
Dialogue: 0,0:21:07.00,0:21:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kupikir kamu menghilang.
Dialogue: 0,0:21:12.67,0:21:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irubo, dengar, ya.
Dialogue: 0,0:21:15.59,0:21:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bukan keluarga,\Naku juga bukan temanmu.
Dialogue: 0,0:21:20.38,0:21:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bukan guru\Napalagi kekasihmu.
Dialogue: 0,0:21:23.51,0:21:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:21:25.68,0:21:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa satu sama lain,\Nkita tidak bisa hidup di dunia iblis ini.
Dialogue: 0,0:21:33.19,0:21:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ini partner tak tergantikan.
Dialogue: 0,0:21:37.19,0:21:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku menghilang.
Dialogue: 0,0:21:39.65,0:21:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ini tak terpisahkan.
Dialogue: 0,0:21:44.62,0:21:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, terima kasih.
Dialogue: 0,0:21:49.75,0:21:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku akan tetap\Npada ukuranku yang biasa.
Dialogue: 0,0:21:52.83,0:21:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa jadi kecil juga.
Dialogue: 0,0:21:56.13,0:21:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong...
Dialogue: 0,0:21:57.67,0:22:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa terlepas juga dari cincin, ya.
Dialogue: 0,0:22:03.43,0:22:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pergi dulu!
Dialogue: 0,0:22:06.10,0:22:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ali!
Dialogue: 0,0:22:17.77,0:22:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu tidak bisa\Npergi terlalu jauh, ya.
Dialogue: 0,0:22:20.99,0:22:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kita tidak terpisahkan.
Dialogue: 0,0:22:26.45,0:22:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma naik ke peringkat He\Ndan Ali telah berevolusi.
Dialogue: 0,0:22:30.87,0:22:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill baru telah didapatkan!
Dialogue: 0,0:24:04.51,0:24:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan.
Dialogue: 0,0:24:08.39,0:24:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma yang sedang mengajari\Nkucing keluarga Sullivan.
Dialogue: 0,0:24:11.64,0:24:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, berguling.
Dialogue: 0,0:24:15.98,0:24:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berguling.
Dialogue: 0,0:24:18.48,0:24:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imutnya.
Dialogue: 0,0:24:21.90,0:24:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berguling.
Dialogue: 0,0:24:24.69,0:24:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meong.
Dialogue: 0,0:24:26.57,0:24:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, Iruma merasa senang.
Dialogue: 0,0:24:30.49,0:24:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mendengar\Npermainan piano Iruma.
Dialogue: 0,0:24:34.24,0:24:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tak apa-apa.
Dialogue: 0,0:24:35.58,0:24:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelak, Iruma akan memainkan musik\Nyang luar biasa hanya untukku.
Dialogue: 0,0:24:41.25,0:24:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musik berjudul "Jeritan Maut".
Dialogue: 0,0:24:43.75,0:24:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:46.26,0:24:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Trio Kesayangan".
Dialogue: 0,0:24:47.59,0:24:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya.\NAku juga mau ikut.
Dialogue: 0,0:24:50.39,0:24:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah "Quartet Kesayangan"\Njuga terdengar bagus?
