Dialogue: 0,0:00:33.47,0:00:40.77,sign,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:01:55.01,0:01:59.52,sign,,0000,0000,0000,,MIRIP TUANNYA ADALAH HUKUM DUNIA IBLIS
Dialogue: 0,0:03:07.13,0:03:08.13,sign,,0000,0000,0000,,PERKAMEN PEMANGGIL
Dialogue: 0,0:03:31.90,0:03:34.44,sign,,0000,0000,0000,,FAMILIAR - SPLIT WOLF
Dialogue: 0,0:05:38.11,0:05:39.99,sign,,0000,0000,0000,,PELIHARAAN SENIMAN JALAN
Dialogue: 0,0:06:31.41,0:06:33.41,sign,,0000,0000,0000,,HYAAN
Dialogue: 0,0:06:46.47,0:06:48.05,sign,,0000,0000,0000,,POLISI CAMILAN
Dialogue: 0,0:07:35.02,0:07:37.65,sign,,0000,0000,0000,,DUNIA YANG DAMAI
Dialogue: 0,0:07:50.12,0:07:51.20,sign,,0000,0000,0000,,SPLIT WOLF
Dialogue: 0,0:08:11.76,0:08:12.39,sign,,0000,0000,0000,,TANGAN
Dialogue: 0,0:09:39.52,0:09:40.77,sign,,0000,0000,0000,,SPLIT WOLF
Dialogue: 0,0:10:58.76,0:11:03.56,sign,,0000,0000,0000,,DIAM!
Dialogue: 0,0:11:04.81,0:11:05.85,sign,,0000,0000,0000,,DI ANTARA TEMAN DEKAT
Dialogue: 0,0:11:54.78,0:11:55.95,sign,,0000,0000,0000,,ROYAL ONE - RUANG BERMAIN
Dialogue: 0,0:12:24.47,0:12:26.56,sign,,0000,0000,0000,,66 KEMENANGAN BERUNTUN!
Dialogue: 0,0:16:16.83,0:16:17.87,sign,,0000,0000,0000,,TAMPAN
Dialogue: 0,0:18:03.60,0:18:06.86,sign,,0000,0000,0000,,BEBERAPA HARI KEMUDIAN...
Dialogue: 0,0:22:16.86,0:22:19.07,sign,,0000,0000,0000,,HATI AKRAB - BERSAMA SELAMANYA!
Dialogue: 0,0:23:53.54,0:23:55.16,sign,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:24:29.99,0:24:31.20,sign,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:00:00.98,0:00:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya manusia\Nyang tinggal di dunia para iblis.
Dialogue: 0,0:00:04.19,0:00:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki Iruma, 15 tahun.
Dialogue: 0,0:00:06.49,0:00:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi Iruma menikmati\Nkehidupan sekolahnya di Babyls,
Dialogue: 0,0:00:10.78,0:00:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia punya ambisi,\Natau lebih tepatnya tujuan.
Dialogue: 0,0:00:13.70,0:00:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu, menaikkan peringkatnya.
Dialogue: 0,0:00:17.16,0:00:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantas, apakah yang menanti\Ndi akhir perjalanannya?
Dialogue: 0,0:01:55.01,0:01:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mirip Tuannya adalah Hukum Dunia Iblis".
Dialogue: 0,0:02:02.02,0:02:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Bohong!
Dialogue: 0,0:02:03.77,0:02:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seriusan?
Dialogue: 0,0:02:05.02,0:02:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita pastikan lain kali.
Dialogue: 0,0:02:13.03,0:02:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya rekomendasi toko parfait, lo.
Dialogue: 0,0:02:15.35,0:02:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku mau coba!
Dialogue: 0,0:02:17.62,0:02:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya ada di dekat alun-alun...
Dialogue: 0,0:02:23.08,0:02:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku mengambilnya.
Dialogue: 0,0:02:29.84,0:02:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, itu Jazz.
Dialogue: 0,0:02:31.76,0:02:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara murid kelas abnormal,\Ndia yang paling keren, ya.
Dialogue: 0,0:02:35.30,0:02:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma yang berbahaya.
Dialogue: 0,0:02:38.89,0:02:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas abnormal, peringkat Daleth,\NAndro M. Jazz.
Dialogue: 0,0:02:44.98,0:02:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mereka tidak tahu rahasia\Nyang ia sembunyikan.
Dialogue: 0,0:03:01.99,0:03:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, tidak ada orang.
Dialogue: 0,0:03:08.13,0:03:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:03:12.63,0:03:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Familiar!\NMemanggil Split Wolf!
Dialogue: 0,0:03:45.50,0:03:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih saja berbulu lembut, ya.
Dialogue: 0,0:03:51.29,0:03:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah naik peringkat Daleth,\Nkupikir kamu akan berubah sedikit.
Dialogue: 0,0:03:56.01,0:03:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:03:57.72,0:04:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia yang dia miliki adalah...
Dialogue: 0,0:04:01.97,0:04:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa, Spoo.
Dialogue: 0,0:04:05.98,0:04:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Familiarnya tampak sangat mengemaskan!
Dialogue: 0,0:04:11.02,0:04:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Spoo.
Dialogue: 0,0:04:13.07,0:04:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita latihan agar kamu bisa menyerang\Ndengan cakar seperti ini.
Dialogue: 0,0:04:16.74,0:04:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba serang target ini.
Dialogue: 0,0:04:20.02,0:04:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju, Spoo!
Dialogue: 0,0:04:31.42,0:04:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakinya terlalu pendek...
Dialogue: 0,0:04:35.42,0:04:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah, lakukan seperti ini!
Dialogue: 0,0:04:38.59,0:04:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai dengan berlari dan gunakan tubuhmu!
Dialogue: 0,0:04:42.43,0:04:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan malah terbang!\NKamu harus mengenai targetnya!
Dialogue: 0,0:04:46.81,0:04:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke arah sini!
Dialogue: 0,0:04:51.48,0:04:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, latihan mereka berlanjut.
Dialogue: 0,0:04:54.23,0:04:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba hadapi dia!\NDengan ekor pun tak apa-apa!
Dialogue: 0,0:05:00.86,0:05:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malah berguling!
Dialogue: 0,0:05:09.37,0:05:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malah menari.
Dialogue: 0,0:05:14.46,0:05:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, jangan menari!
Dialogue: 0,0:05:16.88,0:05:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu menyeberangi tali!
Dialogue: 0,0:05:19.13,0:05:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trik sulap juga!\NTapi, itu luar biasa!
Dialogue: 0,0:05:22.26,0:05:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum! Ayo, Spoo!
Dialogue: 0,0:05:26.01,0:05:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan mereka pun terus berlanjut.
Dialogue: 0,0:05:29.02,0:05:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar! Akhiri dengan pose!
Dialogue: 0,0:05:32.02,0:05:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peliharaan seniman jalanan\Nyang luar biasa pun terlahir!
Dialogue: 0,0:05:35.48,0:05:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!
Dialogue: 0,0:05:41.61,0:05:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, aku makin tidak bisa\Nmenunjukkanmu ke orang lain.
Dialogue: 0,0:05:45.03,0:05:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kamu bisa menghasilkan uang setidaknya.
Dialogue: 0,0:05:49.16,0:05:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bola, kan?
Dialogue: 0,0:05:51.62,0:05:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, ada di se—
Dialogue: 0,0:06:05.89,0:06:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:06:08.14,0:06:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu— Ap—\NIruma? Ke-Ke-Kenapa?
Dialogue: 0,0:06:11.73,0:06:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku cuma...
Dialogue: 0,0:06:12.89,0:06:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kamu di situ?
Dialogue: 0,0:06:14.02,0:06:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum kamu datang.
Dialogue: 0,0:06:15.06,0:06:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong!
Dialogue: 0,0:06:16.15,0:06:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kamu sedang apa, Jazz?
Dialogue: 0,0:06:21.15,0:06:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, tolong anggap\Nkamu tak melihat apa-apa.
Dialogue: 0,0:06:24.24,0:06:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jazz memberiku uang?
Dialogue: 0,0:06:25.66,0:06:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh, kok!\NKamu menakutkan!
Dialogue: 0,0:06:27.66,0:06:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru kamu lebih seram\Nkarena ada di loker!
Dialogue: 0,0:06:30.16,0:06:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:06:34.54,0:06:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:06:36.42,0:06:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:06:37.67,0:06:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bersembunyi agar bisa nyemil.
Dialogue: 0,0:06:40.96,0:06:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini,\Npolisi camilan makin ketat.
Dialogue: 0,0:06:43.55,0:06:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Iruma tertangkap basah!\NDitangkap!
Dialogue: 0,0:06:46.47,0:06:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda terlalu banyak makan!
Dialogue: 0,0:06:48.51,0:06:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jazz, kamu sembunyi\Nuntuk melatih familiarmu?
Dialogue: 0,0:06:55.06,0:06:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu sembunyi juga...
Dialogue: 0,0:06:57.06,0:06:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:06:58.90,0:07:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peliharaan adalah cerminan\Ndari kepribadian tuannya!
Dialogue: 0,0:07:06.28,0:07:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asmodeus dengan Gorgon Snake-nya.
Dialogue: 0,0:07:09.24,0:07:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabro dengan Kelbie.
Dialogue: 0,0:07:11.45,0:07:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Crocell dengan Blizzard Wolf\Ndan Snow King Fox-nya.
Dialogue: 0,0:07:15.00,0:07:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan, Clever Monkey-nya Lied\Nlumayan keren!
Dialogue: 0,0:07:18.50,0:07:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan?
Dialogue: 0,0:07:19.63,0:07:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lagi, Smart Hawk-nya Allocer.
Dialogue: 0,0:07:23.21,0:07:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau disandingkan dengan mereka...
Dialogue: 0,0:07:27.55,0:07:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda jauh denganku, kan?
Dialogue: 0,0:07:30.10,0:07:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya beda dari yang dibayangkan!
Dialogue: 0,0:07:33.10,0:07:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti satu kelompok di grup ini!
Dialogue: 0,0:07:35.02,0:07:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia yang damai.
Dialogue: 0,0:07:37.65,0:07:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jazz, kamu ternyata banyak teriak, ya.
Dialogue: 0,0:07:40.11,0:07:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, bentuk familiar dipengaruhi tuannya.
Dialogue: 0,0:07:45.28,0:07:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena penasaran, aku juga mencari tahu.
Dialogue: 0,0:07:47.86,0:07:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, seharusnya...
Dialogue: 0,0:07:51.20,0:07:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seperti ini.
Dialogue: 0,0:07:55.66,0:07:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Iruma...
Dialogue: 0,0:07:58.62,0:08:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku sebenarnya imut banget, ya.
Dialogue: 0,0:08:02.34,0:08:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sadar soal itu.
Dialogue: 0,0:08:05.21,0:08:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa tidak begitu.
Dialogue: 0,0:08:06.38,0:08:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkatku naik,\Ntapi dia sama sekali tak berubah.
Dialogue: 0,0:08:10.30,0:08:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyerah.
Dialogue: 0,0:08:12.39,0:08:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:08:17.31,0:08:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku berpikir\Nuntuk melepas kontrak dengannya.
Dialogue: 0,0:08:26.24,0:08:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku sempat memikirkannya,\Ntapi itu mustahil.
Dialogue: 0,0:08:32.07,0:08:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak salah apa-apa.
Dialogue: 0,0:08:34.99,0:08:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya salah kalau membuangnya\Nhanya karena tidak sesuai harapan.
Dialogue: 0,0:08:39.78,0:08:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga dekat banget denganku.
Dialogue: 0,0:08:46.80,0:08:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, kalian berdua mirip.
Dialogue: 0,0:08:50.38,0:08:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, di sebelah mana?
Dialogue: 0,0:08:54.85,0:08:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang orangnya bebas\Ndan terkadang melakukan hal tidak baik,
Dialogue: 0,0:08:59.56,0:09:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tapi sebenarnya kamu sangat baik\N- Jazz!
Dialogue: 0,0:09:02.06,0:09:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan peduli pada yang lain.
Dialogue: 0,0:09:04.15,0:09:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau paling depan\Nsaat ada yang membutuhkan.
Dialogue: 0,0:09:08.49,0:09:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kurasa dia juga begitu.
Dialogue: 0,0:09:12.36,0:09:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan jadi familiar yang kuat\Ndan bisa diandalkan!
Dialogue: 0,0:09:17.16,0:09:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku orangnya begitu?
Dialogue: 0,0:09:21.00,0:09:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga agak haus perhatian, ya.
Dialogue: 0,0:09:24.79,0:09:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:09:29.76,0:09:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sisik di ekornya!
Dialogue: 0,0:09:32.76,0:09:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkilauan! Mirip permata!
Dialogue: 0,0:09:35.39,0:09:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, serius?
Dialogue: 0,0:09:37.93,0:09:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sadar karena dia mengibaskan
Dialogue: 0,0:09:39.52,0:09:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ekornya dengan cepat!
Dialogue: 0,0:09:40.77,0:09:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini hebat!\NMirip dengan di gambar!
Dialogue: 0,0:09:44.56,0:09:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang dalam masa pertumbuhan!
Dialogue: 0,0:09:52.28,0:09:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia bakal jadi besar, ya?
Dialogue: 0,0:09:54.57,0:09:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti! Bakal jadi keren!
Dialogue: 0,0:09:56.53,0:09:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau taruhan?
Dialogue: 0,0:09:58.16,0:10:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku taruhan dia bakal jadi besar.
Dialogue: 0,0:10:01.41,0:10:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, taruhannya batal.
Dialogue: 0,0:10:04.54,0:10:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Benar juga.\N- Tuan Iruma!
Dialogue: 0,0:10:06.92,0:10:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ada di mana?\NAyo makan siang!
Dialogue: 0,0:10:10.63,0:10:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma!
Dialogue: 0,0:10:13.09,0:10:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, polisi camilan sudah datang.
Dialogue: 0,0:10:15.85,0:10:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu, ya.
Dialogue: 0,0:10:17.60,0:10:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:10:27.31,0:10:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumbuh perlahan.
Dialogue: 0,0:10:36.37,0:10:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kan...
Dialogue: 0,0:10:44.21,0:10:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, camilanku hilang.
Dialogue: 0,0:10:47.21,0:10:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:10:48.29,0:10:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Camilan?
Dialogue: 0,0:10:49.25,0:10:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.\NBukan apa-apa.
Dialogue: 0,0:10:51.46,0:10:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang mirip tuanmu.
Dialogue: 0,0:11:05.85,0:11:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Di Antara Teman Dekat".
Dialogue: 0,0:11:09.32,0:11:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu istirahat!
Dialogue: 0,0:11:16.57,0:11:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ngobrol tiga kali\Ndengan Mbak hari ini!
Dialogue: 0,0:11:20.53,0:11:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seri baru dari gim favoritku pun\Nbakal keluar!
Dialogue: 0,0:11:23.37,0:11:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuacanya juga cerah!\NHari ini benar-bena—
Dialogue: 0,0:11:28.54,0:11:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shax Lied.
Dialogue: 0,0:11:31.09,0:11:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berduellah denganku.
Dialogue: 0,0:11:34.59,0:11:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepada Ayah, Ibu, dan juga Kakak,
Dialogue: 0,0:11:39.43,0:11:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mungkin akan mati hari ini.
Dialogue: 0,0:11:43.60,0:11:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepulang sekolah!
Dialogue: 0,0:11:45.48,0:11:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz di mana?
Dialogue: 0,0:11:48.02,0:11:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia ada urusan,\Njadi kita disuruh pulang duluan.
Dialogue: 0,0:11:50.52,0:11:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:11:51.73,0:11:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya sesuatu yang penting.
Dialogue: 0,0:11:56.90,0:11:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:11:58.68,0:12:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shax Lied.
Dialogue: 0,0:12:01.33,0:12:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka,\Nkamu bisa sampai sejauh ini.
Dialogue: 0,0:12:05.12,0:12:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan aku.
Dialogue: 0,0:12:07.16,0:12:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:12:08.42,0:12:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap!
Dialogue: 0,0:12:09.79,0:12:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:12:15.55,0:12:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah— Ap—\NSialan.
Dialogue: 0,0:12:19.34,0:12:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:12:23.31,0:12:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu menang!\N- Hore!
Dialogue: 0,0:12:24.47,0:12:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}66 kemenangan beruntun!
Dialogue: 0,0:12:26.56,0:12:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi!
Dialogue: 0,0:12:29.10,0:12:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentar, istirahat dulu, dong.
Dialogue: 0,0:12:32.15,0:12:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama itu, aku akan\Nmelatih ulang kemampuanku.
Dialogue: 0,0:12:35.32,0:12:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:12:36.94,0:12:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bilangnya duel,\Nkupikir akhirnya aku bakal jadi abu.
Dialogue: 0,0:12:44.99,0:12:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka, aku akan bertarung\Nlewat gim dengan Asmodeus.
Dialogue: 0,0:12:50.29,0:12:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz...
Dialogue: 0,0:12:53.50,0:12:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kemajuan luar biasa\Ndibanding saat pertama masuk dulu.
Dialogue: 0,0:12:57.13,0:13:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa tiba-tiba\Nmengajakku duel main gim?
Dialogue: 0,0:13:01.39,0:13:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, saat seri baru\Ngimnya rilis nanti,
Dialogue: 0,0:13:04.35,0:13:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berjanji akan main\Ndengan Tuan Iruma!
Dialogue: 0,0:13:07.27,0:13:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo main bareng, ya!\NGim ini!
Dialogue: 0,0:13:09.81,0:13:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku harus membiasakan diri\Ndengan berbagai gim sebelum hari itu tiba!
Dialogue: 0,0:13:13.52,0:13:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi benar soal Iruma, ya.\NAku cuma samsak, toh.
Dialogue: 0,0:13:17.94,0:13:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, begitulah.
Dialogue: 0,0:13:21.16,0:13:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:13:22.91,0:13:26.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz, kamu terlalu fokus menyerang!\NKamu harus memikirkan soal pertahanan juga!
Dialogue: 0,0:13:26.74,0:13:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, duelnya akan jadi lama, dong.\NSerangan lemah—
Dialogue: 0,0:13:31.42,0:13:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Bukankah itu serunya?
Dialogue: 0,0:13:33.75,0:13:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepuasan mengurangi HP lawan\Nsecara perlahan dan mengalahkannya!
Dialogue: 0,0:13:36.92,0:13:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kuajari strategi yang optimal?
Dialogue: 0,0:13:39.72,0:13:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau perlu, kamu bisa\Nmemanggilku "Profesor".
Dialogue: 0,0:13:42.05,0:13:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat, deh.
Dialogue: 0,0:13:44.14,0:13:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maafkan aku.
Dialogue: 0,0:13:48.72,0:13:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz.
Dialogue: 0,0:13:50.81,0:13:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu seperti apa saat kecil?
Dialogue: 0,0:13:57.32,0:14:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kurasa kamu bukan\Ntipe anak yang main gim saat kecil.
Dialogue: 0,0:14:03.91,0:14:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lingkunganku...
Dialogue: 0,0:14:06.58,0:14:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak seperti itu.
Dialogue: 0,0:14:10.45,0:14:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mau membicarakannya?\NMengejutkan.
Dialogue: 0,0:14:13.50,0:14:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejauh yang kuingat,
Dialogue: 0,0:14:18.42,0:14:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang-orang di sekitarku\Nmemujiku "berbakat".
Dialogue: 0,0:14:21.84,0:14:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menghabiskan waktuku untuk latihan
Dialogue: 0,0:14:24.59,0:14:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi memperdalam pengetahuan\Ndan kemampuanku.
Dialogue: 0,0:14:27.85,0:14:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup sebagai iblis\Nyang menjunjung tinggi tata krama.
Dialogue: 0,0:14:31.60,0:14:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ah, hari ini Alice pun imut! Imut! Imut!\N- Agak berisik saat ada ibuku, sih.
Dialogue: 0,0:14:35.48,0:14:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat itu.
Dialogue: 0,0:14:36.19,0:14:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang dirumorkan itu.
Dialogue: 0,0:14:37.40,0:14:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Tuan Asmodeus.
Dialogue: 0,0:14:38.52,0:14:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah kita sapa dia?
Dialogue: 0,0:14:39.73,0:14:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia di luar jangkauan kita.
Dialogue: 0,0:14:41.94,0:14:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat dunia di sekitarku\Nsangatlah sunyi.
Dialogue: 0,0:14:49.74,0:14:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah menganggapnya kesialan.\NAku malah menyukainya.
Dialogue: 0,0:14:54.75,0:15:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku sadar kalau\Naku berbeda dari yang lain.
Dialogue: 0,0:15:02.38,0:15:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku kurang bisa berinteraksi\Ndengan iblis lain.
Dialogue: 0,0:15:12.18,0:15:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu memanggilku hari ini\Nuntuk mengajarimu soal itu?
Dialogue: 0,0:15:18.69,0:15:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu katakan?\NMana mungkin!
Dialogue: 0,0:15:26.07,0:15:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak mungkin.
Dialogue: 0,0:15:29.20,0:15:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pewaris dari keluarga Asmodeus,
Dialogue: 0,0:15:32.33,0:15:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekaligus sahabat Tuan Iruma,\Ntindakanku tidak boleh memalukan.
Dialogue: 0,0:15:37.17,0:15:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:15:40.38,0:15:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit, hanya sedikit saja.
Dialogue: 0,0:15:44.21,0:15:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedekatanmu dengan Tuan Iruma
Dialogue: 0,0:15:47.34,0:15:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terkadang membuatku iri.
Dialogue: 0,0:15:52.43,0:15:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja aku iblis biasa,
Dialogue: 0,0:15:55.77,0:16:01.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa mengobrol lebih bebas\Ndan lebih dekat dengan Tuan Iruma.
Dialogue: 0,0:16:01.94,0:16:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:16:05.94,0:16:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, kamu cukup normal, kok.
Dialogue: 0,0:16:12.62,0:16:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu murid terbaik di kelas\Ndan menyebalkannya
Dialogue: 0,0:16:16.83,0:16:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tampan.
Dialogue: 0,0:16:17.87,0:16:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah peringkat Daleth dari awal.\NMenurutku kamu hebat.
Dialogue: 0,0:16:22.34,0:16:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:16:23.80,0:16:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mau makan siang di mana?\N- Saat bersama Iruma dan Clarin,
Dialogue: 0,0:16:25.55,0:16:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Karena cuacanya sedang cerah,\N- kamu tampak seperti
Dialogue: 0,0:16:26.92,0:16:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- bagaimana kalau di luar?\N- teman kelas biasa yang ceria.
Dialogue: 0,0:16:28.72,0:16:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau begitu,\N- teman kelas biasa yang ceria.
Dialogue: 0,0:16:29.35,0:16:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo makan buah\Nyang aku dan Mami petik di hutan.
Dialogue: 0,0:16:31.75,0:16:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sebaiknya lebih santai saja?
Dialogue: 0,0:16:34.81,0:16:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan dan katakan\Napa yang kamu inginkan.
Dialogue: 0,0:16:38.31,0:16:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersikaplah di luar kebiasaanmu.
Dialogue: 0,0:16:41.56,0:16:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, kita ini murid sekolah.
Dialogue: 0,0:16:49.82,0:16:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:16:50.86,0:16:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:16:51.87,0:16:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, mau minum teh di mana?
Dialogue: 0,0:16:53.62,0:16:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama kayak cinta, bikin bingung saja.
Dialogue: 0,0:16:56.04,0:16:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Dosa.
Dialogue: 0,0:17:04.42,0:17:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh begitu?
Dialogue: 0,0:17:07.58,0:17:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kok.
Dialogue: 0,0:17:09.30,0:17:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, lebih tepatnya,\Naku harus bagaimana? Begini?
Dialogue: 0,0:17:13.14,0:17:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan sesukamu saja!
Dialogue: 0,0:17:15.64,0:17:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, main ke arena permainan\Natau makan ramen.
Dialogue: 0,0:17:17.93,0:17:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikmati camilan\Ndan melihat-lihat barang jualan.
Dialogue: 0,0:17:20.34,0:17:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main boling di aula teriak.
Dialogue: 0,0:17:23.94,0:17:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekomendasiku mungkin DeviBurger!\NPorsinya besar dan enak!
Dialogue: 0,0:17:28.86,0:17:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget, lo.
Dialogue: 0,0:17:30.45,0:17:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}DeviBurger?
Dialogue: 0,0:17:33.28,0:17:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan pinjamkan gim\Ndari batra kami.
Dialogue: 0,0:17:37.16,0:17:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:17:38.95,0:17:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas bahas yang mesum-mesum!
Dialogue: 0,0:17:41.83,0:17:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Obrolan cowok jelas itu, dong!\N- Terus, ini luar biasa, lo!
Dialogue: 0,0:17:44.46,0:17:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya, aku bicarakan dengan Iruma
Dialogue: 0,0:17:46.34,0:17:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa bisa luar biasa?\N- dan dia cukup tertarik.
Dialogue: 0,0:17:51.47,0:17:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kamu membicarakan\Ntopik vulgar ke Tuan Iruma!
Dialogue: 0,0:17:56.22,0:17:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu...
Dialogue: 0,0:17:59.35,0:18:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbakarlah!
Dialogue: 0,0:18:00.93,0:18:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi abu!
Dialogue: 0,0:18:03.60,0:18:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa hari kemudian.
Dialogue: 0,0:18:05.19,0:18:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kue tar!
Dialogue: 0,0:18:06.86,0:18:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz, kamu sudah beli seri baru gimnya?
Dialogue: 0,0:18:09.74,0:18:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja! Aku juga sudah\Nmenaikkan status juga!
Dialogue: 0,0:18:13.70,0:18:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat!\NJadi tidak sabar bermain misi bersama, ya!
Dialogue: 0,0:18:17.37,0:18:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu gim?
Dialogue: 0,0:18:19.54,0:18:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru, lo.
Dialogue: 0,0:18:20.91,0:18:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau main!
Dialogue: 0,0:18:22.33,0:18:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mau coba?
Dialogue: 0,0:18:23.75,0:18:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau! Mau!
Dialogue: 0,0:18:25.88,0:18:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, tekan ini.
Dialogue: 0,0:18:28.46,0:18:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyala!
Dialogue: 0,0:18:29.63,0:18:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, setelah tekan mulai,\Nbuat karaktermu sendiri dan kasih nama.
Dialogue: 0,0:18:34.22,0:18:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Moimoi!
Dialogue: 0,0:18:35.64,0:18:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selanjutnya, tentukan poin kemampuan awalmu.\N- Ahem!
Dialogue: 0,0:18:38.47,0:18:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Iruma!
Dialogue: 0,0:18:40.72,0:18:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya, perangkat gim baru ini\Npunya mode pengalaman nyata
Dialogue: 0,0:18:43.89,0:18:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membuat kita merasa\Nseperti benar-benar bertualang.
Dialogue: 0,0:18:48.32,0:18:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu...
Dialogue: 0,0:18:50.48,0:18:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana kalau kita main\Nke arena permainan sekarang
Dialogue: 0,0:18:53.53,0:18:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan makan DeviBurger?
Dialogue: 0,0:18:58.78,0:19:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku mau ikut!
Dialogue: 0,0:19:00.62,0:19:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben Azz-Azz mau pergi ke tempat lain!
Dialogue: 0,0:19:04.12,0:19:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau ikut!
Dialogue: 0,0:19:06.08,0:19:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, berisik!
Dialogue: 0,0:19:08.38,0:19:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kamu menghubungi orang tuamu!
Dialogue: 0,0:19:10.67,0:19:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:19:15.55,0:19:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap difoto!\NTiga, dua, satu!
Dialogue: 0,0:19:21.22,0:19:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:19:23.93,0:19:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap!
Dialogue: 0,0:19:25.48,0:19:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lakukan penyesuaian gambar!
Dialogue: 0,0:19:27.69,0:19:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ambil foto di sini bersama\Nkeluargaku tempo hari lalu!
Dialogue: 0,0:19:30.48,0:19:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata kita bisa jadi gede banget!
Dialogue: 0,0:19:33.19,0:19:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lakukan itu.
Dialogue: 0,0:19:37.24,0:19:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam rencanaku, kita akan\Ntahan diri dulu untuk jajan.
Dialogue: 0,0:19:41.24,0:19:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menemukan\Ngim itu secepatnya.
Dialogue: 0,0:19:46.46,0:19:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu?
Dialogue: 0,0:19:47.87,0:19:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kelihatan menarik banget!
Dialogue: 0,0:19:49.88,0:19:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo main ini!
Dialogue: 0,0:19:52.00,0:19:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kita tidak punya waktu untuk—
Dialogue: 0,0:19:55.09,0:19:57.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga suka\Npermainan kelelawar capit.
Dialogue: 0,0:19:57.26,0:19:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lakukan.
Dialogue: 0,0:19:58.55,0:20:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma, di situ!
Dialogue: 0,0:20:00.93,0:20:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini pasti akan dapat!
Dialogue: 0,0:20:02.72,0:20:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda berhasil balas dendam!
Dialogue: 0,0:20:04.77,0:20:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz, nice!
Dialogue: 0,0:20:06.44,0:20:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih, Azz!
Dialogue: 0,0:20:08.52,0:20:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi Tuan Iruma,\Ntidak akan kubiarkan kalian lolos!
Dialogue: 0,0:20:11.23,0:20:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Sempurna!
Dialogue: 0,0:20:12.94,0:20:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh!
Dialogue: 0,0:20:14.32,0:20:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan untuk melatih\Nkemampuan, ya, Tuan Iruma.
Dialogue: 0,0:20:17.45,0:20:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya, iya!
Dialogue: 0,0:20:19.32,0:20:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permennya banyak sekali!
Dialogue: 0,0:20:21.74,0:20:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini, pasti bisa dapat!
Dialogue: 0,0:20:23.66,0:20:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:20:25.20,0:20:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, sebelah situ!
Dialogue: 0,0:20:26.87,0:20:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju! Maju!
Dialogue: 0,0:20:29.42,0:20:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berburu monster?
Dialogue: 0,0:20:30.96,0:20:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jadi enggak sabar!
Dialogue: 0,0:20:32.63,0:20:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tak kusangka antreannya seramai ini.\N- Antrean VR-nya sebelah sini!
Dialogue: 0,0:20:35.17,0:20:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, makan permen dulu!
Dialogue: 0,0:20:37.67,0:20:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdiri di antrean bertiga juga seru, ya!
Dialogue: 0,0:20:40.68,0:20:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya!\N- Ya!
Dialogue: 0,0:20:44.72,0:20:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak sepenuhnya\Nberjalan sesuai rencana,
Dialogue: 0,0:20:47.43,0:20:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asmodeus akhirnya sampai\Ndi gim yang dicari.
Dialogue: 0,0:20:54.94,0:20:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat!\NSeperti sungguhan!
Dialogue: 0,0:20:59.45,0:21:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cocok sekali, Tuan Iruma!
Dialogue: 0,0:21:03.78,0:21:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:21:05.45,0:21:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu memilih itu?
Dialogue: 0,0:21:07.50,0:21:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, kan?
Dialogue: 0,0:21:12.17,0:21:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ada gua!
Dialogue: 0,0:21:13.96,0:21:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo masuk!
Dialogue: 0,0:21:17.51,0:21:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini...
Dialogue: 0,0:21:19.88,0:21:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menikmati petualang\Nsepulang sekolah dengan sepuas hati.
Dialogue: 0,0:21:29.10,0:21:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengasyikkan, ya!
Dialogue: 0,0:21:31.23,0:21:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya!\N- Ya!
Dialogue: 0,0:21:32.94,0:21:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau agak menyesal rasanya\Ntidak sempat beli DeviBurger.
Dialogue: 0,0:21:38.15,0:21:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita simpan untuk lain waktu, ya.
Dialogue: 0,0:21:40.20,0:21:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma, itu artinya...
Dialogue: 0,0:21:44.95,0:21:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, nanti mampir lagi, yuk!
Dialogue: 0,0:21:47.08,0:21:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti mampir lagi, yuk!
Dialogue: 0,0:21:50.83,0:21:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Ayo, ayo!
Dialogue: 0,0:21:53.58,0:21:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:21:54.83,0:21:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:22:02.18,0:22:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:22:03.59,0:22:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bersama Iruma dan Clarin,
Dialogue: 0,0:22:07.68,0:22:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tampak seperti\Nteman kelas biasa yang ceria.
Dialogue: 0,0:22:10.14,0:22:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Azz-Azz, peralatanmu\Nenggak terlalu kuat, tuh?
Dialogue: 0,0:22:13.69,0:22:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu strategi menyerang dan bertahan\Nyang sempurna, kan?
Dialogue: 0,0:22:16.86,0:22:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri jadi makhluk apa?
Dialogue: 0,0:22:19.07,0:22:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua cocok.
Dialogue: 0,0:22:20.32,0:22:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima ka—
Dialogue: 0,0:23:51.53,0:23:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan-han-han-han!
Dialogue: 0,0:23:55.16,0:23:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz, kamu pergi ke arena permainan\Nbersama Iruma dan Clarin, ya?
Dialogue: 0,0:23:58.75,0:24:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:24:00.21,0:24:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma juga tampak menikmatinya.
Dialogue: 0,0:24:04.05,0:24:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, ajak aku juga, dong.
Dialogue: 0,0:24:06.34,0:24:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang murid biasa, ya.
Dialogue: 0,0:24:09.01,0:24:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, butuh satu lagi, ya.
Dialogue: 0,0:24:11.51,0:24:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh satu lagi?
Dialogue: 0,0:24:12.97,0:24:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena harus antre\Nkalau main di arena permainan,
Dialogue: 0,0:24:15.98,0:24:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku beli tiga mesin.
Dialogue: 0,0:24:18.98,0:24:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:24:21.98,0:24:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dia seorang murid,\NLied jadi sadar kalau dia tidak biasa.
Dialogue: 0,0:24:27.11,0:24:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat main di rumah?
Dialogue: 0,0:24:29.99,0:24:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan di dunia iblis,
Dialogue: 0,0:24:31.20,0:24:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada acara penting\Nyang terjadi di akhir tahun.
Dialogue: 0,0:24:33.79,0:24:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu, pesta akhir tahun.
Dialogue: 0,0:24:35.37,0:24:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan, minum, dan bersenang-senang.
Dialogue: 0,0:24:37.12,0:24:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentunya, karena Iruma dan yang lain\Nmasih di bawah umur,
Dialogue: 0,0:24:39.62,0:24:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tidak bisa minum alkohol.
Dialogue: 0,0:24:41.38,0:24:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bisa, ya tidak bisa.\NHanya bisa minuman biasa.
Dialogue: 0,0:24:44.25,0:24:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya minuman biasa\Ndan hanya untuk iblis.
Dialogue: 0,0:24:46.30,0:24:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:48.63,0:24:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pesta Liar Kelas Abnormal"\Ndan "Pelayan Dunia Iblis".
Dialogue: 0,0:24:52.10,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tampaknya situasi\Npesta akhir tahunnya...
