Dialogue: 0,0:00:36.47,0:00:38.98,tanda_srt,,0,0,0,,(Selamat Datang di Sekolah Iblis, Iruma)
Dialogue: 0,0:00:38.98,0:00:43.77,tanda_srt,,0,0,0,,(Selamat Datang di Sekolah Iblis, Iruma)\N(Musim ke-4)
Dialogue: 0,0:01:58.01,0:02:02.52,tanda_srt,,0,0,0,,(Esensi Idola Iblis)
Dialogue: 0,0:02:17.20,0:02:19.95,tanda_srt,,0,0,0,,(Pendukung Piano: Iruma)
Dialogue: 0,0:02:22.76,0:02:24.23,On Top,,0,0,0,,Ya!
Dialogue: 0,0:03:00.99,0:03:02.33,tanda_srt,,0,0,0,,(Minta Tolong)
Dialogue: 0,0:03:06.96,0:03:08.53,On Top,,0,0,0,,Orang yang cocok untuk itu!
Dialogue: 0,0:03:08.98,0:03:11.59,On Top,,0,0,0,,Kalau kau lelah, biar aku pijat jarimu.
Dialogue: 0,0:03:36.61,0:03:39.62,tanda_srt,,0,0,0,,(Tim Musik - Tim Tari)
Dialogue: 0,0:03:42.24,0:03:44.25,tanda_srt,,0,0,0,,(Ruang Pertunjukan)
Dialogue: 0,0:04:53.61,0:04:55.61,tanda_srt,,0,0,0,,(Ruang Olahraga)
Dialogue: 0,0:05:10.62,0:05:13.13,tanda_srt,,0,0,0,,(Hell Dance - Tarian Neraka)
Dialogue: 0,0:05:45.88,0:05:47.37,On Top,,0,0,0,,Bikin kesal.
Dialogue: 0,0:05:47.37,0:05:49.90,On Top,,0,0,0,,Mbak lebih anggun lagi!
Dialogue: 0,0:07:19.94,0:07:22.07,On Top,,0,0,0,,Yang barusan itu apa?!
Dialogue: 0,0:07:27.89,0:07:29.41,On Top,,0,0,0,,Indah nan glamor.
Dialogue: 0,0:08:08.73,0:08:10.62,On Top,,0,0,0,,Ayo, ayo, ayo!
Dialogue: 0,0:08:33.93,0:08:36.83,On Top,,0,0,0,,Aku keren.
Dialogue: 0,0:08:36.83,0:08:38.83,tanda_srt,,0,0,0,,(Ruang Pertunjukan)
Dialogue: 0,0:10:44.71,0:10:47.21,tanda_srt,,0,0,0,,(Wruuur)
Dialogue: 0,0:10:59.10,0:11:01.10,tanda_srt,,0,0,0,,(Hehe)
Dialogue: 0,0:11:26.71,0:11:31.50,tanda_srt,,0,0,0,,(Aku Clara, lo!)
Dialogue: 0,0:11:48.31,0:11:49.31,tanda_srt,,0,0,0,,(Kelas E: Orkestra Iblis)
Dialogue: 0,0:11:49.31,0:11:50.31,tanda_srt,,0,0,0,,(Kelas E: Orkestra Iblis - Komposisi Raja Iblis ke-6)
Dialogue: 0,0:11:50.31,0:11:52.94,tanda_srt,,0,0,0,,(Kelas E: Orkestra Iblis - Komposisi Raja Iblis ke-6)\N(Perwakilan: Naberius Kalego)
Dialogue: 0,0:12:35.53,0:12:37.36,On Top,,0,0,0,,Aduh!
Dialogue: 0,0:13:33.67,0:13:37.71,tanda_srt,,0,0,0,,(Karpet Lilith)
Dialogue: 0,0:14:00.24,0:14:01.11,tanda_srt,,0,0,0,,(Hmf)
Dialogue: 0,0:17:30.11,0:17:36.16,tanda_srt,,0,0,0,,(Borgol Peniru)
Dialogue: 0,0:20:44.76,0:20:47.39,tanda_srt,,0,0,0,,(Waa)
Dialogue: 0,0:21:33.94,0:21:34.81,On Top,,0,0,0,,Hah?!
Dialogue: 0,0:21:34.81,0:21:37.47,On Top,,0,0,0,,Dia sudah bagus!\NNah, ayo coba lagi!
Dialogue: 0,0:24:08.51,0:24:10.18,tanda_srt,,0,0,0,,(Tambahan)
Dialogue: 0,0:24:19.02,0:24:20.52,tanda_srt,,0,0,0,,(Piano yang Menyakitkan)
Dialogue: 0,0:24:29.99,0:24:35.29,tanda_srt,,0,0,0,,(Cuplikan)
Dialogue: 0,0:24:35.29,0:24:51.18,tanda_srt,,0,0,0,,(Cuplikan)\N(Ini bukan kesalahan siaran)
Dialogue: 0,0:24:51.18,0:24:55.01,tanda_srt,,0,0,0,,(Cuplikan)
Dialogue: 0,0:00:00.00,0:00:01.04,Default,,0,0,0,,
Dialogue: 0,0:00:01.04,0:00:02.82,Default,,0,0,0,,Aku sudah tidak sanggup.
Dialogue: 0,0:00:02.82,0:00:04.57,Default,,0,0,0,,Aku tidak bisa mengimbangi.
Dialogue: 0,0:00:04.57,0:00:05.61,Default,,0,0,0,,Tunggu dulu!
Dialogue: 0,0:00:05.61,0:00:06.61,Default,,0,0,0,,Mari berjuang—
Dialogue: 0,0:00:06.61,0:00:07.93,Default,,0,0,0,,Sampai jumpa.
Dialogue: 0,0:00:13.20,0:00:14.62,Default,,0,0,0,,Kenapa?
Dialogue: 0,0:00:14.62,0:00:17.31,Default,,0,0,0,,Kalau latihan lebih lagi, pasti...
Dialogue: 0,0:00:17.68,0:00:20.51,Default,,0,0,0,,Padahal... aku...
Dialogue: 0,0:00:20.67,0:00:27.66,Default,,0,0,0,,pengin ngelihat Idola Iblis nan imut\Nbernyanyi dan menari bersama-sama!
Dialogue: 0,0:00:32.72,0:00:34.60,Default,,0,0,0,,Bangkit! Bangkit! Bangkit! Bangkit!♪
Dialogue: 0,0:00:34.60,0:00:36.47,Default,,0,0,0,,Mari buat keributan\Ndan egois hingga fajar♪
Dialogue: 0,0:00:43.77,0:00:45.57,Default,,0,0,0,,Murid berprestasi,\Nkau tahu maksudku?♪
Dialogue: 0,0:00:45.57,0:00:48.11,Default,,0,0,0,,Kutak tahu apa-apa sejak awal♪
Dialogue: 0,0:00:48.11,0:00:51.49,Default,,0,0,0,,Abaikan saja perdamaian dan keadilan♪
Dialogue: 0,0:00:52.03,0:00:53.62,Default,,0,0,0,,Ah, lelah rasanya♪
Dialogue: 0,0:00:53.62,0:00:55.95,Default,,0,0,0,,Saat ingin menangis,♪
Dialogue: 0,0:00:55.95,0:00:58.08,Default,,0,0,0,,tujulah panggung nan megah♪
Dialogue: 0,0:00:58.08,0:00:59.91,Default,,0,0,0,,Bangkit! Bangkit! Bangkit! Bangkit!♪
Dialogue: 0,0:00:59.91,0:01:00.87,Default,,0,0,0,,Egois hingga akhir♪
Dialogue: 0,0:01:00.87,0:01:04.71,Default,,0,0,0,,Deru seketika jadi anggun♪
Dialogue: 0,0:01:04.71,0:01:09.47,Default,,0,0,0,,Saat menggenggam tangan itu,\Nsemuanya dimulai♪
Dialogue: 0,0:01:09.47,0:01:11.43,Default,,0,0,0,,Kala lampu menyala lagi,\Nmahatahu dan mahakuasa♪
Dialogue: 0,0:01:11.43,0:01:12.97,Default,,0,0,0,,akan buat keributan♪
Dialogue: 0,0:01:12.97,0:01:16.51,Default,,0,0,0,,Jadi ayo kita meriahkan♪
Dialogue: 0,0:01:18.31,0:01:19.31,Default,,0,0,0,,Tiketnya habis ludes♪
Dialogue: 0,0:01:19.31,0:01:22.77,Default,,0,0,0,,Pestanya dimulai dalam\Nhitungan satu, dua, dan tiga♪
Dialogue: 0,0:01:22.77,0:01:24.94,Default,,0,0,0,,Mari berkumpul dan bersorak meriah♪
Dialogue: 0,0:01:24.94,0:01:26.94,tanda_srt,,0,0,0,,(Semua! Semua! Semuanya!♪)
Dialogue: 0,0:01:26.94,0:01:30.57,Default,,0,0,0,,Dua, tiga, empat!\NMari bermimpi bersama, Sayang♪
Dialogue: 0,0:01:30.82,0:01:32.74,Default,,0,0,0,,Buang jauh-jauh rasa khawatir itu♪
Dialogue: 0,0:01:32.74,0:01:36.91,tanda_srt,,0,0,0,,(Semua! Semua! Semuanya!♪)
Dialogue: 0,0:01:37.74,0:01:40.96,tanda_srt,,0,0,0,,(Semuanya!♪)
Dialogue: 0,0:01:41.75,0:01:46.71,tanda_srt,,0,0,0,,(Semuanya!♪)
Dialogue: 0,0:01:46.71,0:01:50.51,Default,,0,0,0,,Pestanya dimulai dalam\Nhitungan satu, dua, dan tiga♪
Dialogue: 0,0:01:58.66,0:02:00.87,Default,,0,0,0,,"Esensi Idola Iblis".
Dialogue: 0,0:02:02.52,0:02:05.60,Default,,0,0,0,,Mulai hari ini sampai festival musik,\Nkelas akan ditiadakan.
Dialogue: 0,0:02:05.60,0:02:08.47,Default,,0,0,0,,Artinya kita bisa pakai waktu kita\Nuntuk berlatih seharian!
Dialogue: 0,0:02:08.79,0:02:10.15,Default,,0,0,0,,Hell Dance.
Dialogue: 0,0:02:10.15,0:02:14.41,Default,,0,0,0,,Mari bagi jadi tim musik dan tim tari\Nuntuk penampilan di karpet Lilith
Dialogue: 0,0:02:14.41,0:02:16.07,Default,,0,0,0,,dan berjuang masing-masing.
Dialogue: 0,0:02:16.07,0:02:17.20,Default,,0,0,0,,Tunggu!
Dialogue: 0,0:02:17.20,0:02:19.95,Default,,0,0,0,,Kenapa Tuan Iruma jadi pendukung?!
Dialogue: 0,0:02:19.95,0:02:22.62,Default,,0,0,0,,Irumachi juga jago nari, lo!
Dialogue: 0,0:02:22.62,0:02:24.97,Default,,0,0,0,,Jago banget, lo! Lo! Lo! Lo!
Dialogue: 0,0:02:24.97,0:02:26.28,Default,,0,0,0,,Aku tahu.
Dialogue: 0,0:02:26.64,0:02:31.21,Default,,0,0,0,,Tapi, kalau dia ikut menari,\Nsemuanya bakal ngelihat ke dia, dong.
Dialogue: 0,0:02:31.21,0:02:33.34,Default,,0,0,0,,Wajar saja semuanya melihat ke Tuan Iruma!
Dialogue: 0,0:02:33.34,0:02:36.22,Default,,0,0,0,,Bintang kali ini adalah\NMbak dan Purson, tahu!
Dialogue: 0,0:02:36.82,0:02:38.22,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:02:38.22,0:02:39.22,Default,,0,0,0,,Gitu, gitu.
Dialogue: 0,0:02:39.22,0:02:43.52,Default,,0,0,0,,Aku pengin memilih mereka yang sudah Daleth\Nuntuk berperan jadi pendukung.
Dialogue: 0,0:02:43.52,0:02:46.23,Default,,0,0,0,,Kunci menghasilkan suara, piano,
Dialogue: 0,0:02:46.54,0:02:48.23,Default,,0,0,0,,membutuhkan kepekaan ritme yang baik,
Dialogue: 0,0:02:48.23,0:02:50.75,Default,,0,0,0,,kemampuan untuk bekerja sama\Nsebaik mungkin dengan Purson,
Dialogue: 0,0:02:50.75,0:02:54.26,Default,,0,0,0,,dan juga, sosok iblis yang mampu\Nmemimpin semuanya.
Dialogue: 0,0:02:54.99,0:02:57.62,Default,,0,0,0,,Jadi, aku minta tolong padamu.
Dialogue: 0,0:02:57.62,0:02:59.85,Default,,0,0,0,,Apa kamu mau melakukannya, Iruma?
Dialogue: 0,0:03:02.33,0:03:04.83,Default,,0,0,0,,Ya! Aku mau!
Dialogue: 0,0:03:04.83,0:03:06.96,Default,,0,0,0,,Iruma main piano! Keren, tuh!
Dialogue: 0,0:03:06.96,0:03:10.49,Default,,0,0,0,,Iruma pasti bisa memberikan\Npenampilan yang luar biasa!
Dialogue: 0,0:03:11.59,0:03:13.84,Default,,0,0,0,,Irumachi, berjuang! Semangat!
Dialogue: 0,0:03:13.84,0:03:16.84,Default,,0,0,0,,Berperan sebagai pembimbing?\NTuan Iruma memang hebat!
Dialogue: 0,0:03:16.84,0:03:18.99,Default,,0,0,0,,Ya! Aku akan berjuang!
Dialogue: 0,0:03:20.32,0:03:21.82,Default,,0,0,0,,Kenapa ini?
Dialogue: 0,0:03:21.82,0:03:26.09,Default,,0,0,0,,Ini pertama kalinya permintaan tolong\Nterasa semendebarkan ini!
Dialogue: 0,0:03:28.25,0:03:30.42,Default,,0,0,0,,Purson?
Dialogue: 0,0:03:33.29,0:03:34.76,Default,,0,0,0,,Mohon kerja samanya, ya!
Dialogue: 0,0:03:35.13,0:03:36.61,Default,,0,0,0,,Kalau begitu, Iruma.
Dialogue: 0,0:03:36.61,0:03:39.62,Default,,0,0,0,,Belajarlah dasarnya dari ahlinya.
Dialogue: 0,0:03:39.62,0:03:41.48,Default,,0,0,0,,Ahlinya?
Dialogue: 0,0:03:49.63,0:03:52.56,Default,,0,0,0,,Hebat! Sabnock jago!
Dialogue: 0,0:03:52.56,0:03:54.38,Default,,0,0,0,,Ini hanya etika wajib Raja Iblis.
Dialogue: 0,0:03:57.94,0:04:02.05,Default,,0,0,0,,Bentuk piano ini akan berubah\Nsesuai dengan pemainnya.
Dialogue: 0,0:04:02.05,0:04:04.14,Default,,0,0,0,,Piano dunia bawah keren!
Dialogue: 0,0:04:04.14,0:04:05.52,Default,,0,0,0,,Dunia bawah?
Dialogue: 0,0:04:05.52,0:04:07.75,Default,,0,0,0,,Ah, tidak.\NBukan apa-apa.
Dialogue: 0,0:04:08.27,0:04:11.90,Default,,0,0,0,,Pianonya jelas marah\Nkalau dirimu langsung sentuh.
Dialogue: 0,0:04:11.90,0:04:14.02,Default,,0,0,0,,Pertama-tama, beri salam dulu.
Dialogue: 0,0:04:14.02,0:04:15.40,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:04:17.90,0:04:19.20,Default,,0,0,0,,Cobalah duduk.
Dialogue: 0,0:04:19.20,0:04:21.52,Default,,0,0,0,,Be-Bentuknya akan seperti apa...
Dialogue: 0,0:04:26.72,0:04:30.17,Default,,0,0,0,,Yah, sepertinya sudah\Nmencerminkan kepribadian dirimu.
Dialogue: 0,0:04:30.17,0:04:32.17,Default,,0,0,0,,Nanti juga stabil sendiri.
Dialogue: 0,0:04:33.19,0:04:34.30,Default,,0,0,0,,Bunyi!
Dialogue: 0,0:04:34.30,0:04:38.17,Default,,0,0,0,,Jika bisa membayangkan musiknya,\Npianonya akan menuntun dirimu.
Dialogue: 0,0:04:40.03,0:04:44.68,Default,,0,0,0,,Makin kuat dirimu membayangkan,\Nmakin indah pula suaranya.
Dialogue: 0,0:04:44.68,0:04:48.64,Default,,0,0,0,,Sekarang, dirimu tinggal terus\Nbermain sampai mahir!
Dialogue: 0,0:04:48.64,0:04:50.06,Default,,0,0,0,,Tiada lain selain berlatih!
Dialogue: 0,0:04:50.06,0:04:51.44,Default,,0,0,0,,Ya! Aku mengerti!
Dialogue: 0,0:04:51.44,0:04:53.61,Default,,0,0,0,,Terima kasih, Sabnock!
Dialogue: 0,0:04:54.21,0:04:55.61,Default,,0,0,0,,Jadi...
Dialogue: 0,0:04:56.17,0:05:00.36,Default,,0,0,0,,Aku ingin kalian yang ada di tim tari\Nmenjadi Idola Iblis!
Dialogue: 0,0:05:04.87,0:05:07.12,Default,,0,0,0,,I-Idola Iblis?
Dialogue: 0,0:05:07.38,0:05:09.25,Default,,0,0,0,,- Maksudnya apa?\N- Maksudnya apa, ya?
Dialogue: 0,0:05:09.25,0:05:10.46,Default,,0,0,0,,Nihil paham.
Dialogue: 0,0:05:10.46,0:05:13.13,Default,,0,0,0,,Yang akan kita tampilkan itu\NHell Dance, 'kan?
Dialogue: 0,0:05:13.13,0:05:14.88,Default,,0,0,0,,Kalian ini...
Dialogue: 0,0:05:14.88,0:05:17.96,Default,,0,0,0,,Idola Iblis adalah puncak\Ndari pertunjukan, tahu.
Dialogue: 0,0:05:17.96,0:05:19.88,Default,,0,0,0,,Tidak ada alasan untuk\Ntak menjadikannya referensi.
Dialogue: 0,0:05:20.48,0:05:22.97,Default,,0,0,0,,Koreografi, musik, penampilan...
Dialogue: 0,0:05:22.97,0:05:26.68,Default,,0,0,0,,Semuanya diperhitungkan dan disempurnakan\Nuntuk memancarkan daya tarik!
Dialogue: 0,0:05:26.89,0:05:29.02,Default,,0,0,0,,Terlebih lagi, mereka imut!
Dialogue: 0,0:05:29.02,0:05:30.52,Default,,0,0,0,,Begitu, ya.\NItu artinya...
Dialogue: 0,0:05:30.52,0:05:32.02,Default,,0,0,0,,Tiada paham.
Dialogue: 0,0:05:32.02,0:05:33.15,Default,,0,0,0,,Kalian tidak mengerti, ya?!
Dialogue: 0,0:05:33.44,0:05:36.22,Default,,0,0,0,,Ada idola yang cowok juga, kok!
Dialogue: 0,0:05:44.88,0:05:46.53,Default,,0,0,0,,Itu idola yang cowok, ya?
Dialogue: 0,0:05:46.53,0:05:47.74,Default,,0,0,0,,Duh, anggunnya.
Dialogue: 0,0:05:47.74,0:05:48.87,Default,,0,0,0,,Mereka berkilauan!
Dialogue: 0,0:05:48.87,0:05:50.16,Default,,0,0,0,,Iya, 'kan?
Dialogue: 0,0:05:50.16,0:05:53.08,Default,,0,0,0,,Bukan hanya kostum,\Ntapi juga riasan dan kuku kalian!
Dialogue: 0,0:05:53.08,0:05:55.75,Default,,0,0,0,,Aku akan siapkan kalian\Ndari kepala sampai kaki!
Dialogue: 0,0:05:55.75,0:05:57.50,Default,,0,0,0,,Kita pakai kostum modis\Ndengan kuku hitam!
Dialogue: 0,0:05:57.50,0:05:59.17,Default,,0,0,0,,Terus, penlight dan sorakan!
Dialogue: 0,0:05:59.17,0:06:00.67,Default,,0,0,0,,Kau serius, ya.
Dialogue: 0,0:06:01.44,0:06:02.38,Default,,0,0,0,,Tapi...
Dialogue: 0,0:06:02.38,0:06:03.84,Default,,0,0,0,,Daku tak bisa bayangkan.
Dialogue: 0,0:06:03.84,0:06:05.18,Default,,0,0,0,,Diriku malu.
Dialogue: 0,0:06:06.28,0:06:07.68,Default,,0,0,0,,Malu?
Dialogue: 0,0:06:08.53,0:06:11.06,Default,,0,0,0,,Tidak, bukan Idola Iblisnya!
Dialogue: 0,0:06:11.06,0:06:12.23,Default,,0,0,0,,Tenanglah, Ratu!
Dialogue: 0,0:06:12.23,0:06:13.42,Default,,0,0,0,,Baiklah!
Dialogue: 0,0:06:14.25,0:06:18.19,Default,,0,0,0,,Yang kalian lihat di video tak ada apa-apa\Njika dibandingkan dengan yang asli.
Dialogue: 0,0:06:18.96,0:06:20.63,Default,,0,0,0,,Lihat baik-baik.
Dialogue: 0,0:06:20.96,0:06:22.95,Default,,0,0,0,,Aku hanya akan perlihatkan sekali.
Dialogue: 0,0:06:24.84,0:06:25.61,Default,,0,0,0,,Apa ini?!
Dialogue: 0,0:06:25.61,0:06:26.96,Default,,0,0,0,,Tiba-tiba...
Dialogue: 0,0:06:26.96,0:06:28.89,Default,,0,0,0,,Auranya...
Dialogue: 0,0:06:39.27,0:06:40.34,Default,,0,0,0,,Ingat ini.
Dialogue: 0,0:06:40.34,0:06:41.74,Default,,0,0,0,,Idola Iblis itu...
Dialogue: 0,0:06:44.65,0:06:46.18,Default,,0,0,0,,imut,
Dialogue: 0,0:06:48.20,0:06:49.93,Default,,0,0,0,,cantik,
Dialogue: 0,0:06:52.12,0:06:52.93,Default,,0,0,0,,dan...
Dialogue: 0,0:06:54.58,0:06:56.23,Default,,0,0,0,,keren.
Dialogue: 0,0:07:17.42,0:07:18.25,Default,,0,0,0,,Apa itu yang tadi?!
Dialogue: 0,0:07:18.25,0:07:20.46,Default,,0,0,0,,- Ratu!\N- Luar biasa!
Dialogue: 0,0:07:20.46,0:07:23.17,Default,,0,0,0,,Kau sekilas terlihat jadi cowok!
Dialogue: 0,0:07:23.17,0:07:23.92,Default,,0,0,0,,Iya, 'kan?
Dialogue: 0,0:07:23.92,0:07:26.57,Default,,0,0,0,,Gila! Keren banget!
Dialogue: 0,0:07:26.57,0:07:27.89,Default,,0,0,0,,Iya, 'kan?
Dialogue: 0,0:07:28.15,0:07:31.43,Default,,0,0,0,,Berasa Idola Iblis sungguhan!
Dialogue: 0,0:07:33.35,0:07:36.77,Default,,0,0,0,,Gawat! Aku kasih fanservis berlebihan!
Dialogue: 0,0:07:36.77,0:07:39.76,Default,,0,0,0,,Hampir saja aku memikat mereka!\NBahaya, bahaya!
Dialogue: 0,0:07:40.19,0:07:43.40,Default,,0,0,0,,- Luar biasa, ya!\N- Megah dan indah.
Dialogue: 0,0:07:43.40,0:07:46.11,Default,,0,0,0,,- Gawat banget.\N- Tak kusangka Ratu punya keahlian begitu.
Dialogue: 0,0:07:46.11,0:07:47.70,Default,,0,0,0,,Po-Pokoknya!
Dialogue: 0,0:07:47.95,0:07:49.93,Default,,0,0,0,,Coba kalian bayangkan...
Dialogue: 0,0:07:51.05,0:07:55.09,Default,,0,0,0,,Hanya dengan sedikit gerakan\Nujung jari kalian,
Dialogue: 0,0:07:55.09,0:07:57.98,Default,,0,0,0,,semuanya bersorak gembira dan kegirangan!
Dialogue: 0,0:07:58.47,0:08:01.74,Default,,0,0,0,,Itu sangat mendebarkan, bukan?
Dialogue: 0,0:08:04.46,0:08:05.55,Default,,0,0,0,,Idola Iblis, ya?
Dialogue: 0,0:08:05.55,0:08:06.42,Default,,0,0,0,,Boleh juga.
Dialogue: 0,0:08:06.42,0:08:07.97,Default,,0,0,0,,Ayo kita lakukan.
Dialogue: 0,0:08:07.97,0:08:08.63,Default,,0,0,0,,Diriku juga!
Dialogue: 0,0:08:08.63,0:08:09.80,Default,,0,0,0,,Tak ada usaha, tak ada hasil.
Dialogue: 0,0:08:09.80,0:08:10.97,Default,,0,0,0,,Kalau tak masalah denganku.
Dialogue: 0,0:08:11.32,0:08:13.41,Default,,0,0,0,,Bagus.
Dialogue: 0,0:08:13.95,0:08:17.18,Default,,0,0,0,,Mbak dan Clara akan berada\Ndi tengah bersamaku,
Dialogue: 0,0:08:17.18,0:08:19.39,Default,,0,0,0,,jadi latihan kita bakal lumayan berat, lo.
Dialogue: 0,0:08:19.39,0:08:20.06,Default,,0,0,0,,Siap!
Dialogue: 0,0:08:20.06,0:08:21.40,Default,,0,0,0,,Kalau kami?
Dialogue: 0,0:08:21.53,0:08:26.05,Default,,0,0,0,,Pertama-tama, katakan "Aku keren!"\Nsebanyak 666 kali.
Dialogue: 0,0:08:26.32,0:08:33.93,Default,,0,0,0,,Aku keren.
Dialogue: 0,0:08:33.93,0:08:35.91,Default,,0,0,0,,Bentar, Azz-Azz jangan ikutan.
Dialogue: 0,0:08:35.91,0:08:36.83,Default,,0,0,0,,Kenapa coba?
Dialogue: 0,0:08:50.07,0:08:51.18,Default,,0,0,0,,Iruma...
Dialogue: 0,0:08:51.18,0:08:52.59,Default,,0,0,0,,Kau payah banget, ya.
Dialogue: 0,0:08:52.59,0:08:55.06,Default,,0,0,0,,Maafkan hamba!
Dialogue: 0,0:08:55.06,0:08:58.10,Default,,0,0,0,,Yah, ini pertama kalinya buatmu,\Njadi mau bagaimana lagi.
Dialogue: 0,0:08:58.10,0:09:00.38,Default,,0,0,0,,Sudah sewajarnya kau payah.
Dialogue: 0,0:09:00.74,0:09:03.40,Default,,0,0,0,,Bayi pun kesusahan saat pertama kali\Nmenggunakan sayapnya.
Dialogue: 0,0:09:03.40,0:09:06.40,Default,,0,0,0,,Kau hanya bisa berlatih, ya.\NMeski kau payah banget, sih.
Dialogue: 0,0:09:06.67,0:09:07.61,Default,,0,0,0,,Berjuanglah.
Dialogue: 0,0:09:07.61,0:09:10.90,Default,,0,0,0,,A-Aku harus berjuang lebih lagi, ya?
Dialogue: 0,0:09:10.90,0:09:13.24,Default,,0,0,0,,Karena aku sudah dapat peran penting.
Dialogue: 0,0:09:13.63,0:09:15.70,Default,,0,0,0,,Karena sudah latihan dengan guru,
Dialogue: 0,0:09:15.70,0:09:19.79,Default,,0,0,0,,aku jadi percaya diri dengan\Nkonsentrasi dan keberanianku...
Dialogue: 0,0:09:22.79,0:09:25.29,Default,,0,0,0,,Tapi, suara yang kuingin\Ntidak keluar dengan benar!
Dialogue: 0,0:09:25.29,0:09:27.59,Default,,0,0,0,,Dan lagi, kalau lengah,\Npianonya balik jadi empuk!
Dialogue: 0,0:09:27.59,0:09:30.01,Default,,0,0,0,,Suaranya juga jadi lembek!
Dialogue: 0,0:09:30.30,0:09:34.70,Default,,0,0,0,,Tidak bisa!\NAku harus minta tips lagi ke Sabnock!
Dialogue: 0,0:09:36.53,0:09:39.14,Default,,0,0,0,,Musik ternyata sulit, ya.
Dialogue: 0,0:09:39.14,0:09:41.50,Default,,0,0,0,,Aku harus latihan lebih lagi.
Dialogue: 0,0:09:41.91,0:09:43.30,Default,,0,0,0,,Ini akan berat.
Dialogue: 0,0:09:43.58,0:09:45.61,Default,,0,0,0,,Tapi, kau malah senyum-senyum begitu.
Dialogue: 0,0:09:45.86,0:09:46.90,Default,,0,0,0,,Eh?
Dialogue: 0,0:09:46.90,0:09:48.98,Default,,0,0,0,,Apa kau baik-baik saja?\NApa otot wajahmu terluka?
Dialogue: 0,0:09:48.98,0:09:50.86,Default,,0,0,0,,Mau istirahat?\NApa tidak lebih baik kau rebahan dulu?
Dialogue: 0,0:09:50.86,0:09:52.03,Default,,0,0,0,,Butuh kasur?\NMau minum obat?
Dialogue: 0,0:09:52.03,0:09:54.53,Default,,0,0,0,,Tidak, tidak perlu. Eng...
Dialogue: 0,0:09:55.09,0:09:59.91,Default,,0,0,0,,Aku sering kali menuruti\Nberbagai macam permintaan tolong.
Dialogue: 0,0:09:59.91,0:10:03.29,Default,,0,0,0,,Tapi, permintaan Kerori kali ini\Nmembuat hatiku berdebar-debar.
Dialogue: 0,0:10:05.27,0:10:12.26,Default,,0,0,0,,Pasti karena dia bilang tidak bisa\Nsembarang orang, tapi harus aku.
Dialogue: 0,0:10:12.26,0:10:15.35,Default,,0,0,0,,Kurasa aku senang mendengarnya.
Dialogue: 0,0:10:15.35,0:10:19.56,Default,,0,0,0,,Karena ini pertama kalinya buatku,\Naku jadi ingin berjuang.
Dialogue: 0,0:10:19.77,0:10:24.04,Default,,0,0,0,,Tapi, kau mengatakan\Nhal yang sama padaku.
Dialogue: 0,0:10:24.50,0:10:28.20,Default,,0,0,0,,Aku ingin melihatmu\Ndipuji oleh semua orang!
Dialogue: 0,0:10:28.20,0:10:30.69,Default,,0,0,0,,Dia tidak sadar apa yang dia katakan, ya?
Dialogue: 0,0:10:30.69,0:10:32.24,Default,,0,0,0,,Itu hebat, sih.
Dialogue: 0,0:10:32.24,0:10:34.32,Default,,0,0,0,,Aku paham perasaanmu, sih.
Dialogue: 0,0:10:34.32,0:10:36.31,Default,,0,0,0,,Be-Begitukah?
Dialogue: 0,0:10:37.38,0:10:40.45,Default,,0,0,0,,Maaf, tapi tim tari sedang sibuk.
Dialogue: 0,0:10:40.45,0:10:42.20,Default,,0,0,0,,Termasuk Sabnock juga.
Dialogue: 0,0:10:42.60,0:10:44.71,Default,,0,0,0,,Anu, apa yang sedang mereka lakukan?
Dialogue: 0,0:10:44.71,0:10:47.21,Default,,0,0,0,,Mereka sedang sibuk.
Dialogue: 0,0:10:47.47,0:10:49.34,Default,,0,0,0,,Syukurlah kita ada di tim musik.
Dialogue: 0,0:10:49.34,0:10:49.96,Default,,0,0,0,,Iya.
Dialogue: 0,0:10:49.96,0:10:51.46,Default,,0,0,0,,Tapi tenang saja!
Dialogue: 0,0:10:51.46,0:10:53.88,Default,,0,0,0,,Aku tidak melupakan kalian, kok!
Dialogue: 0,0:10:53.88,0:10:58.62,Default,,0,0,0,,Aku sudah menemukan Instruktur\Nyang sempurna untuk membantu kalian!
Dialogue: 0,0:11:01.70,0:11:03.60,Default,,0,0,0,,Cepat kembali ke ruangan kalian.
Dialogue: 0,0:11:03.78,0:11:05.60,Default,,0,0,0,,Beliau mungkin sudah ada di sana.
Dialogue: 0,0:11:07.70,0:11:09.21,Default,,0,0,0,,Soalnya...
Dialogue: 0,0:11:09.61,0:11:10.86,Default,,0,0,0,,beliau adalah...
Dialogue: 0,0:11:11.17,0:11:12.23,Default,,0,0,0,,Kalian telat.
Dialogue: 0,0:11:12.23,0:11:14.24,Default,,0,0,0,,iblis yang bermartabat!
Dialogue: 0,0:11:16.96,0:11:18.22,Default,,0,0,0,,Jangan kabur!
Dialogue: 0,0:11:20.80,0:11:24.98,Default,,0,0,0,,Cepat mulai, para pemula.
Dialogue: 0,0:11:32.94,0:11:36.43,Default,,0,0,0,,Tapi, rasanya kurang meyakinkan\Nkalau hanya dari kami saja.
Dialogue: 0,0:11:36.43,0:11:37.30,Default,,0,0,0,,Jadi...
Dialogue: 0,0:11:37.30,0:11:38.86,Default,,0,0,0,,Tolong kami!
Dialogue: 0,0:11:38.86,0:11:41.68,Default,,0,0,0,,Tolong latih Iruma bermain piano!
Dialogue: 0,0:11:44.37,0:11:46.18,Default,,0,0,0,,Kenapa aku?
Dialogue: 0,0:11:46.44,0:11:50.06,Default,,0,0,0,,Aku melihat daftar kelas pemenang\Nfestival musik terdahulu.
Dialogue: 0,0:11:50.06,0:11:52.94,Default,,0,0,0,,Aku juga sudah memastikannya\Ndengan Pak Balam!
Dialogue: 0,0:11:52.94,0:11:57.28,Default,,0,0,0,,Pak Kalego? Dia bisa memainkan\Nsemua instrumen, kok.
Dialogue: 0,0:11:57.28,0:11:58.82,Default,,0,0,0,,Dia itu...
Dialogue: 0,0:11:58.82,0:12:02.87,Default,,0,0,0,,Jujur saja, aku tak bisa\Nmembimbing semuanya sendirian.
Dialogue: 0,0:12:02.87,0:12:05.75,Default,,0,0,0,,Kami butuh bantuan Bapak!\NJadi, tolong bantu...
Dialogue: 0,0:12:05.75,0:12:06.87,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:12:06.87,0:12:07.86,Default,,0,0,0,,Eh?
Dialogue: 0,0:12:09.98,0:12:11.04,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:12:11.04,0:12:14.25,Default,,0,0,0,,Ti-Tidak, tak kusangka\NBapak akan langsung setuju...
Dialogue: 0,0:12:14.73,0:12:17.02,Default,,0,0,0,,Kode Etik Guru Babyls:
Dialogue: 0,0:12:17.02,0:12:19.99,Default,,0,0,0,,"Selalu prioritaskan perkembangan murid."
Dialogue: 0,0:12:19.99,0:12:22.41,Default,,0,0,0,,Kemauan untuk belajar\Nadalah hal yang benar.
Dialogue: 0,0:12:22.57,0:12:24.00,Default,,0,0,0,,Itu karena...
Dialogue: 0,0:12:24.97,0:12:27.67,Default,,0,0,0,,aku adalah guru yang bermartabat.
Dialogue: 0,0:12:32.83,0:12:35.53,Default,,0,0,0,,Chase! Flow! Flow! Beelze! Quattreu!
Dialogue: 0,0:12:36.04,0:12:37.36,Default,,0,0,0,,Gerakan jarimu salah!
Dialogue: 0,0:12:37.36,0:12:39.53,Default,,0,0,0,,Gerakan sesuai yang kuajarkan,\Ndasar bodoh!
Dialogue: 0,0:12:40.09,0:12:42.45,Default,,0,0,0,,Tempomu terlalu cepat!\NJangan improvisasi!
Dialogue: 0,0:12:42.45,0:12:44.28,Default,,0,0,0,,Samakan suaramu\Ndengan suara rekanmu!
Dialogue: 0,0:12:44.50,0:12:47.04,Default,,0,0,0,,Aku tak akan mengizinkan kalian\Nmemainkan sebuah lagu.
Dialogue: 0,0:12:47.04,0:12:50.79,Default,,0,0,0,,Aku akan buat tubuh kalian mengingat\Nmulai dari hal paling dasar.
Dialogue: 0,0:12:50.79,0:12:52.51,Default,,0,0,0,,Tenang saja.
Dialogue: 0,0:12:52.51,0:12:55.67,Default,,0,0,0,,Meski jarimu patah,\Nmeski tenggorokanmu serasa terbakar,
Dialogue: 0,0:12:55.67,0:12:58.92,Default,,0,0,0,,aku tak akan meninggalkan kalian.
Dialogue: 0,0:12:58.92,0:13:01.18,Default,,0,0,0,,Tidak!
Dialogue: 0,0:13:01.18,0:13:03.68,Default,,0,0,0,,Sepulang sekolah!
Dialogue: 0,0:13:05.28,0:13:07.56,Default,,0,0,0,,E-Enam jam nonstop...
Dialogue: 0,0:13:07.56,0:13:09.18,Default,,0,0,0,,Bangun.\NWaktunya pelajaran selanjutnya.
Dialogue: 0,0:13:09.18,0:13:10.59,Default,,0,0,0,,Bapak pasti bercanda, 'kan?
Dialogue: 0,0:13:11.95,0:13:14.87,Default,,0,0,0,,Kalian sama sekali\Ntak memahami lagunya.
Dialogue: 0,0:13:14.87,0:13:18.69,Default,,0,0,0,,Yah, lagu yang kalian pilih\Nmemang cukup sulit.
Dialogue: 0,0:13:20.84,0:13:24.70,Default,,0,0,0,,Sosok iblis cantik yang dulunya\Nberkuasa di dunia bawah,
Dialogue: 0,0:13:24.70,0:13:27.94,Default,,0,0,0,,iblis pemikat, Lilith.
Dialogue: 0,0:13:28.51,0:13:34.13,Default,,0,0,0,,Jalan yang ia lalui dipenuhi dengan\Nmayat pria yang berjuang untuknya.
Dialogue: 0,0:13:34.13,0:13:36.65,Default,,0,0,0,,Jalan itu pun disebut Karpet Lilith.
Dialogue: 0,0:13:37.71,0:13:39.71,Default,,0,0,0,,Lengkapnya tertulis dalam situ.
Dialogue: 0,0:13:39.71,0:13:43.59,Default,,0,0,0,,Bacalah berulang-ulang sampai hafal\Ndan perdalam pemahaman kalian.
Dialogue: 0,0:13:43.59,0:13:46.47,Default,,0,0,0,,Ba-Baca semuanya?
Dialogue: 0,0:13:46.78,0:13:50.68,Default,,0,0,0,,Lagu ini adalah bentuk penghormatan\Ndan kerinduan kepada Lilith.
Dialogue: 0,0:13:50.68,0:13:54.52,Default,,0,0,0,,Lagu tentang pria-pria bodoh\Nyang mencoba memenangkan hatinya.
Dialogue: 0,0:13:54.52,0:13:56.42,Default,,0,0,0,,Dengan kata lain, temanya adalah...
Dialogue: 0,0:13:57.46,0:13:58.93,Default,,0,0,0,,"cinta".
Dialogue: 0,0:14:02.17,0:14:04.49,Default,,0,0,0,,Aku minta maaf.\NAku sungguh minta maaf.
Dialogue: 0,0:14:04.49,0:14:08.33,Default,,0,0,0,,Tapi, kata "cinta" keluar dari\Nmulut Pak Kalego itu aneh banget.
Dialogue: 0,0:14:08.33,0:14:10.66,Default,,0,0,0,,Otot perutku tak sanggup menahan...
Dialogue: 0,0:14:12.10,0:14:15.25,Default,,0,0,0,,Aku juga tidak mengatakannya karena ingin!
Dialogue: 0,0:14:15.64,0:14:16.75,Default,,0,0,0,,Dengar.
Dialogue: 0,0:14:16.94,0:14:21.51,Default,,0,0,0,,Tari adalah pemeran dari suatu cerita\Ndan musik adalah "dunia" dari cerita itu.
Dialogue: 0,0:14:21.51,0:14:23.01,Default,,0,0,0,,"Dunia"?
Dialogue: 0,0:14:24.94,0:14:28.97,Default,,0,0,0,,Melalui suara, bayangkan dunia Lilith.
Dialogue: 0,0:14:45.59,0:14:48.48,Default,,0,0,0,,Lilith ialah perwujudan kecantikan tiada tara.
Dialogue: 0,0:14:54.18,0:14:58.15,Default,,0,0,0,,Sang pria mendambakannya\Ndan mempersembahkan cinta padanya.
Dialogue: 0,0:14:58.92,0:15:02.66,Default,,0,0,0,,Karena ingin memilikinya,\Nsang pria mencoba merayunya.
Dialogue: 0,0:15:06.69,0:15:08.68,Default,,0,0,0,,Namun, tetap saja...
Dialogue: 0,0:15:12.03,0:15:14.25,Default,,0,0,0,,Lilith tidak beranjak.
Dialogue: 0,0:15:19.58,0:15:21.69,Default,,0,0,0,,Begitulah kisah dari lagunya.
Dialogue: 0,0:15:21.95,0:15:23.19,Default,,0,0,0,,Apa kalian paham?
Dialogue: 0,0:15:26.46,0:15:29.82,Default,,0,0,0,,Ce-Ceritanya dewasa banget!
Dialogue: 0,0:15:29.82,0:15:31.08,Default,,0,0,0,,Iya, 'kan, Purson?
Dialogue: 0,0:15:31.08,0:15:31.70,Default,,0,0,0,,Tenanglah.
Dialogue: 0,0:15:31.70,0:15:34.20,Default,,0,0,0,,Ya. Lagunya sangat eroti—
Dialogue: 0,0:15:34.20,0:15:36.96,Default,,0,0,0,,Maksudku, sangat cantik dan indah.
Dialogue: 0,0:15:37.14,0:15:40.79,Default,,0,0,0,,Terus, aku tak tahu kenapa,\Nlagunya membuatku jijik.
Dialogue: 0,0:15:40.79,0:15:42.46,Default,,0,0,0,,Kau orang yang jujur, ya.
Dialogue: 0,0:15:43.65,0:15:45.97,Default,,0,0,0,,Yang barusan adalah dunia yang kuciptakan.
Dialogue: 0,0:15:45.97,0:15:48.55,Default,,0,0,0,,Kaulah yang sebenarnya\Nakan bermain, Iruma.
Dialogue: 0,0:15:48.55,0:15:53.14,Default,,0,0,0,,Kau harus menciptakan duniamu sendiri,\Nbukan meniruku.
Dialogue: 0,0:15:53.14,0:15:54.64,Default,,0,0,0,,Ba-Baik.
Dialogue: 0,0:15:54.64,0:15:58.90,Default,,0,0,0,,Tunjukkanlah caramu\Nuntuk merayu Lilith!
Dialogue: 0,0:15:58.90,0:16:00.48,Default,,0,0,0,,Ba-Baik!
Dialogue: 0,0:16:02.98,0:16:05.72,Default,,0,0,0,,Merayu...
Dialogue: 0,0:16:09.17,0:16:11.53,Default,,0,0,0,,Menciptakan dunia...
Dialogue: 0,0:16:11.53,0:16:12.89,Default,,0,0,0,,Merayu...
Dialogue: 0,0:16:13.99,0:16:15.44,Default,,0,0,0,,Bayangkan!
Dialogue: 0,0:16:17.22,0:16:20.57,Default,,0,0,0,,Lilith ialah perwujudan kecantikan tiada tara.
Dialogue: 0,0:16:21.94,0:16:24.49,Default,,0,0,0,,Karena ingin dirinya bersenang-senang,
Dialogue: 0,0:16:27.65,0:16:29.76,Default,,0,0,0,,sang pria mencoba...
Dialogue: 0,0:16:31.61,0:16:33.26,Default,,0,0,0,,merayunya.
Dialogue: 0,0:16:35.45,0:16:38.75,Default,,0,0,0,,Tolong tunggu sebentar.\NSekali lagi.
Dialogue: 0,0:16:41.12,0:16:43.25,Default,,0,0,0,,Sang pria mencoba...
Dialogue: 0,0:16:43.25,0:16:44.88,Default,,0,0,0,,merayunya.
Dialogue: 0,0:16:45.08,0:16:47.94,Default,,0,0,0,,me-me-me-me...
Dialogue: 0,0:16:47.94,0:16:49.74,Default,,0,0,0,,Makan bareng!
Dialogue: 0,0:16:49.74,0:16:54.74,Default,,0,0,0,,Berkali-kali kumencoba,\Nselalu berakhir jadi makan bareng.
Dialogue: 0,0:16:55.00,0:16:57.20,Default,,0,0,0,,Kau ini!
Dialogue: 0,0:16:57.20,0:17:00.21,Default,,0,0,0,,Sepertinya pola pikirmu perlu diubah, ya.
Dialogue: 0,0:17:00.21,0:17:01.79,Default,,0,0,0,,Ma-Maafkan aku!
Dialogue: 0,0:17:01.79,0:17:04.13,Default,,0,0,0,,Saat berpikir "senang-senang,"\Naku jadi kelepasan!
Dialogue: 0,0:17:04.13,0:17:05.84,Default,,0,0,0,,Hubungi wali kalian!
Dialogue: 0,0:17:05.84,0:17:07.71,Default,,0,0,0,,Kalian akan menginap untuk sementara!
Dialogue: 0,0:17:07.71,0:17:09.59,Default,,0,0,0,,Baik.
Dialogue: 0,0:17:10.40,0:17:12.09,Default,,0,0,0,,Bakal bergadang, ya.
Dialogue: 0,0:17:12.28,0:17:15.31,Default,,0,0,0,,Semangat latihan pianonya, Tuan Iruma!
Dialogue: 0,0:17:15.31,0:17:18.18,Default,,0,0,0,,Kami juga bakal berjuang! Yuk, yuk!
Dialogue: 0,0:17:18.18,0:17:20.44,Default,,0,0,0,,Azz, Clara.
Dialogue: 0,0:17:20.60,0:17:22.98,Default,,0,0,0,,Mereka berdua berjuang.
Dialogue: 0,0:17:22.98,0:17:27.05,Default,,0,0,0,,Aku juga harus makin jago!
Dialogue: 0,0:17:29.54,0:17:31.37,Default,,0,0,0,,Borgol Peniru.
Dialogue: 0,0:17:31.37,0:17:36.03,Default,,0,0,0,,Saat diresapi energi sihir, borgol tersebut\Nakan menyinkronkan gerakan penggunanya.
Dialogue: 0,0:17:36.16,0:17:39.25,Default,,0,0,0,,Dalam Hell Dance, di mana gerakan\Nsemuanya harus sinkron sempurna,
Dialogue: 0,0:17:39.25,0:17:41.21,Default,,0,0,0,,itu adalah alat latihan yang penting.
Dialogue: 0,0:17:41.21,0:17:45.49,Default,,0,0,0,,Tapi, awalnya alat magis itu digunakan\Nuntuk mengendalikan makhluk magis,
Dialogue: 0,0:17:45.85,0:17:48.46,Default,,0,0,0,,jadi cukup sulit menggunakannya.
Dialogue: 0,0:17:48.46,0:17:49.70,Default,,0,0,0,,Aduh.
Dialogue: 0,0:17:49.86,0:17:52.18,Default,,0,0,0,,Beginilah yang terjadi kalau\Ntidak digunakan dengan benar.
Dialogue: 0,0:17:54.19,0:17:56.68,Default,,0,0,0,,Pertama-tama, mari bagi dua-tiga orang\Nperkelompok di ruangan berbeda,
Dialogue: 0,0:17:56.68,0:17:59.14,Default,,0,0,0,,lalu latihan menyinkronkan gerakan kita.
Dialogue: 0,0:17:59.14,0:18:01.73,Default,,0,0,0,,Pastikan kalian mengingat\Nsetiap langkahnya.
Dialogue: 0,0:18:01.73,0:18:03.35,Default,,0,0,0,,Baik!
Dialogue: 0,0:18:03.35,0:18:04.31,Default,,0,0,0,,Terutama...
Dialogue: 0,0:18:04.31,0:18:05.80,Default,,0,0,0,,kalian berdua.
Dialogue: 0,0:18:06.21,0:18:08.11,Default,,0,0,0,,Latihan intensif di halaman dalam!
Dialogue: 0,0:18:08.11,0:18:09.38,Default,,0,0,0,,Baik!
Dialogue: 0,0:18:09.86,0:18:12.90,Default,,0,0,0,,Ingat, Valac.\NDimulai dengan tangan kanan.
Dialogue: 0,0:18:12.90,0:18:14.49,Default,,0,0,0,,Kau tahu mana tangan kananmu, 'kan?
Dialogue: 0,0:18:14.49,0:18:15.37,Default,,0,0,0,,Ya.
Dialogue: 0,0:18:15.37,0:18:16.41,Default,,0,0,0,,Yang ini.
Dialogue: 0,0:18:16.41,0:18:18.12,Default,,0,0,0,,Bagus, kau genius.
Dialogue: 0,0:18:18.12,0:18:20.70,Default,,0,0,0,,Bisa, bisa!\NKita pasti bisa!
Dialogue: 0,0:18:20.70,0:18:23.04,Default,,0,0,0,,Kalau tidak tahu,\Njangan dipaksa bergerak.
Dialogue: 0,0:18:23.04,0:18:24.87,Default,,0,0,0,,Oke, mas bro!
Dialogue: 0,0:18:24.87,0:18:26.63,Default,,0,0,0,,Let's dance!
Dialogue: 0,0:18:30.23,0:18:31.78,Default,,0,0,0,,Sudah kubilang...
Dialogue: 0,0:18:32.13,0:18:35.47,Default,,0,0,0,,Ayunanmu terlalu lebar, tahu!\NHarus berapa kali kubilang!
Dialogue: 0,0:18:35.47,0:18:37.85,Default,,0,0,0,,Harusnya 60 derajat, tahu! Begini!
Dialogue: 0,0:18:37.85,0:18:40.14,Default,,0,0,0,,Eh? Lebih keren begini, tahu!
Dialogue: 0,0:18:40.14,0:18:41.98,Default,,0,0,0,,Jangan ditarik!\NLakukan dengan benar!
Dialogue: 0,0:18:41.98,0:18:45.94,Default,,0,0,0,,Aku sudah benar!\NGya, bukbuk, terus parampampam, 'kan?
Dialogue: 0,0:18:45.94,0:18:48.27,Default,,0,0,0,,Aku sama sekali tak mengerti omonganmu!
Dialogue: 0,0:18:48.27,0:18:50.59,Default,,0,0,0,,Kenapa kau tak mengerti—
Dialogue: 0,0:18:50.83,0:18:54.03,Default,,0,0,0,,Begitu, ya.\NAzz-Azz lumayan bodoh, sih.
Dialogue: 0,0:18:54.03,0:18:56.91,Default,,0,0,0,,Oi, kau barusan memikirkan\Nhal yang tak sopan, 'kan?
Dialogue: 0,0:18:56.91,0:19:00.87,Default,,0,0,0,,Pokoknya, kalau begini terus,\Nkita bakal jadi aib abadi!
Dialogue: 0,0:19:00.87,0:19:01.62,Default,,0,0,0,,Gawat!
Dialogue: 0,0:19:01.62,0:19:04.01,Default,,0,0,0,,Kita tak akan bisa menatap\Nwajah Tuan Iruma lagi!
Dialogue: 0,0:19:04.16,0:19:06.17,Default,,0,0,0,,Nah, waktunya mengintai!
Dialogue: 0,0:19:06.17,0:19:07.67,Default,,0,0,0,,Oi! Tunggu! Jangan lari!
Dialogue: 0,0:19:16.68,0:19:18.18,Default,,0,0,0,,Mereka sinkron.
Dialogue: 0,0:19:18.18,0:19:19.68,Default,,0,0,0,,Jago.
Dialogue: 0,0:19:19.68,0:19:22.68,Default,,0,0,0,,Kita tak boleh buat kesalahan!
Dialogue: 0,0:19:22.68,0:19:23.58,Default,,0,0,0,,Hah?
Dialogue: 0,0:19:24.16,0:19:27.81,Default,,0,0,0,,Apakah tiada cara untuk\Nmeningkatkan konsentrasi kita?
Dialogue: 0,0:19:27.81,0:19:29.11,Default,,0,0,0,,Benar juga.
Dialogue: 0,0:19:29.11,0:19:32.90,Default,,0,0,0,,Akan lebih baik kalau ada aturan\Nagar konsentrasi kita meningkat, 'kan?
Dialogue: 0,0:19:32.90,0:19:35.47,Default,,0,0,0,,Itu ide yang bagus.
Dialogue: 0,0:19:36.34,0:19:38.45,Default,,0,0,0,,Dihukum kalau salah?
Dialogue: 0,0:19:38.45,0:19:40.70,Default,,0,0,0,,Oh, mau bertanding?
Dialogue: 0,0:19:40.70,0:19:47.21,Default,,0,0,0,,Kalau begitu, yang salah harus beberkan\Ninfo yang ia punya tentang murid cewek.
Dialogue: 0,0:19:47.21,0:19:51.09,Default,,0,0,0,,Apa?! Aku tak bisa membicarakan\Nmereka dari belakang!
Dialogue: 0,0:19:51.09,0:19:54.30,Default,,0,0,0,,Aku akan bawa mati tentang\Napa yang terjadi pada kencan buta!
Dialogue: 0,0:19:54.30,0:19:58.13,Default,,0,0,0,,Kalian pasti akan membeberkannya!
Dialogue: 0,0:19:58.13,0:19:59.87,Default,,0,0,0,,Aku tak boleh kalah!
Dialogue: 0,0:20:07.58,0:20:09.38,Default,,0,0,0,,Ayo lanjut.
Dialogue: 0,0:20:14.33,0:20:17.35,Default,,0,0,0,,Aku bisa merasakan debaran hati Mbak.
Dialogue: 0,0:20:19.46,0:20:21.31,Default,,0,0,0,,Berdebar.
Dialogue: 0,0:20:22.97,0:20:26.33,Default,,0,0,0,,Bagaikan Waltz kita berdua...
Dialogue: 0,0:20:27.83,0:20:31.00,Default,,0,0,0,,Bagus! Mulai stabil, ya!
Dialogue: 0,0:20:31.25,0:20:34.28,Default,,0,0,0,,Malah muncul makhluk gede\Ndi tengah-tengah kami!
Dialogue: 0,0:20:35.27,0:20:38.80,Default,,0,0,0,,Lied jago, tapi Sabnock juga jago!
Dialogue: 0,0:20:38.80,0:20:40.13,Default,,0,0,0,,Hebat!
Dialogue: 0,0:20:40.13,0:20:44.76,Default,,0,0,0,,Seorang Raja Iblis harus punya pendengaran\Ndan kekuatan inti tubuh yang bagus!
Dialogue: 0,0:20:44.76,0:20:47.23,Default,,0,0,0,,Aku lebih cocok untuk Mbak!
Dialogue: 0,0:20:47.23,0:20:47.64,Default,,0,0,0,,Eh?
Dialogue: 0,0:20:47.64,0:20:50.77,Default,,0,0,0,,Ah, maksudnya,\Naku lebih mahir mengajari.
Dialogue: 0,0:20:50.77,0:20:53.11,Default,,0,0,0,,Aku jago banget\Nmain Devil Dance Revolution!
Dialogue: 0,0:20:53.11,0:20:53.90,Default,,0,0,0,,Hebat.
Dialogue: 0,0:20:54.75,0:20:56.72,Default,,0,0,0,,Semuanya jago.
Dialogue: 0,0:21:03.34,0:21:05.66,Default,,0,0,0,,Yak, tahan sebentar.
Dialogue: 0,0:21:05.66,0:21:08.83,Default,,0,0,0,,Sudah kubilang,\Nkamu harus senyum! Senyum!
Dialogue: 0,0:21:08.83,0:21:09.58,Default,,0,0,0,,Begini.
Dialogue: 0,0:21:09.58,0:21:12.88,Default,,0,0,0,,Yang harus kupelajari itu tariannya, 'kan?\NBodoh amat dengan ekspresiku!
Dialogue: 0,0:21:12.88,0:21:13.92,Default,,0,0,0,,Tidak boleh begitu!
Dialogue: 0,0:21:13.92,0:21:15.17,Default,,0,0,0,,Kenapa coba?
Dialogue: 0,0:21:15.17,0:21:17.67,Default,,0,0,0,,Sudah, sudah.\NMari bicarakan dengan tenang.
Dialogue: 0,0:21:17.67,0:21:20.51,Default,,0,0,0,,Wajahmu itu seperti\Ntelur yang berkilauan, tahu!
Dialogue: 0,0:21:20.51,0:21:20.97,Default,,0,0,0,,Hah?
Dialogue: 0,0:21:20.97,0:21:21.68,Default,,0,0,0,,Dengar, ya.
Dialogue: 0,0:21:22.19,0:21:26.95,Default,,0,0,0,,Mereka yang terlahir indah punya kewajiban\Nuntuk menyebarkan keindahannya!
Dialogue: 0,0:21:26.95,0:21:28.02,Default,,0,0,0,,Kewajiban?
Dialogue: 0,0:21:28.02,0:21:29.06,Default,,0,0,0,,Sudah, sudah.
Dialogue: 0,0:21:29.06,0:21:30.52,Default,,0,0,0,,Jazz juga!\NLangkahmu terlalu lambat!
Dialogue: 0,0:21:30.52,0:21:32.35,Default,,0,0,0,,Bentar! Suruh dia tersenyum juga, dong!
Dialogue: 0,0:21:32.35,0:21:33.94,Default,,0,0,0,,Dia sudah bagus begitu!
Dialogue: 0,0:21:36.12,0:21:39.94,Default,,0,0,0,,Mungkin begini rasanya punya dua adik\Nyang keduanya sedang dalam siklus jahat.
Dialogue: 0,0:21:40.95,0:21:42.95,Default,,0,0,0,,Sudah kubilang, tersenyum!
Dialogue: 0,0:21:42.95,0:21:45.16,Default,,0,0,0,,Mana bisa aku tiba-tiba tersenyum!
Dialogue: 0,0:21:45.16,0:21:46.87,Default,,0,0,0,,Mereka berantem sambil menari.
Dialogue: 0,0:21:46.87,0:21:47.95,Default,,0,0,0,,Jago.
Dialogue: 0,0:21:52.47,0:21:55.53,Default,,0,0,0,,Tiap tim memang berisik, tapi...
Dialogue: 0,0:21:55.98,0:21:59.77,Default,,0,0,0,,Mereka jago, ya.\NJago, jigi, jugu.
Dialogue: 0,0:21:59.77,0:22:01.59,Default,,0,0,0,,Mungkin, kita juga perlu...
Dialogue: 0,0:22:01.59,0:22:04.89,Default,,0,0,0,,Eng, saling bicara blak-blakan.
Dialogue: 0,0:22:04.89,0:22:06.10,Default,,0,0,0,,Eh? Belalak?
Dialogue: 0,0:22:06.10,0:22:07.39,Default,,0,0,0,,Bukan.
Dialogue: 0,0:22:07.39,0:22:10.39,Default,,0,0,0,,Untuk saling memahami dengan baik,
Dialogue: 0,0:22:10.39,0:22:12.98,Default,,0,0,0,,kita harus saling jujur satu sama lain.
Dialogue: 0,0:22:12.98,0:22:14.23,Default,,0,0,0,,Dengar, Valac.
Dialogue: 0,0:22:14.91,0:22:15.98,Default,,0,0,0,,Y-Ya!
Dialogue: 0,0:22:22.96,0:22:25.18,Default,,0,0,0,,Kalau begitu, dari aku dulu.
Dialogue: 0,0:22:40.09,0:22:42.13,Default,,0,0,0,,Sip, ayo mulai!♪
Dialogue: 0,0:22:42.13,0:22:43.51,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:43.51,0:22:44.63,Default,,0,0,0,,Pasti menang!♪
Dialogue: 0,0:22:44.63,0:22:45.89,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:45.89,0:22:47.14,Default,,0,0,0,,Menang dengan gemilang♪
Dialogue: 0,0:22:47.14,0:22:48.39,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:48.39,0:22:49.64,Default,,0,0,0,,Menang dengan iseng♪
Dialogue: 0,0:22:49.64,0:22:50.97,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:50.97,0:22:52.68,Default,,0,0,0,,Kamilah pemenangnya!♪
Dialogue: 0,0:22:52.68,0:22:54.89,Default,,0,0,0,,Kemenangan luar biasa!♪
Dialogue: 0,0:22:54.89,0:22:57.44,Default,,0,0,0,,Ya! Ya! Ya! Menang lagi hari ini!♪
Dialogue: 0,0:22:57.44,0:22:59.86,Default,,0,0,0,,Senang! Senang! Duar! Terbaik!♪
Dialogue: 0,0:22:59.86,0:23:02.53,Default,,0,0,0,,Ya! Ya! Ya! Kemenangan sempurna!♪
Dialogue: 0,0:23:02.53,0:23:04.70,Default,,0,0,0,,Senang! Senang! Duar! Jempolan!♪
Dialogue: 0,0:23:04.70,0:23:07.53,Default,,0,0,0,,Bukannya enggak bakal kalah,\Ntapi mustahil kalah♪
Dialogue: 0,0:23:07.53,0:23:10.08,Default,,0,0,0,,Berjuang tuh rasanya mengasyikkan♪
Dialogue: 0,0:23:10.08,0:23:12.58,Default,,0,0,0,,Makanan enak pun\Nbuat kualitas hidup naik♪
Dialogue: 0,0:23:12.58,0:23:15.37,Default,,0,0,0,,Pertumbuhan pesat tak terbendung!\NMantap! Kawan!♪
Dialogue: 0,0:23:15.37,0:23:16.37,Default,,0,0,0,,Hei! Yo!♪
Dialogue: 0,0:23:16.37,0:23:19.17,Default,,0,0,0,,Punya teman 'tuk berlomba tuh terbaik!♪
Dialogue: 0,0:23:19.17,0:23:21.88,Default,,0,0,0,,Bisa melampaui batasan\Ndiri sendiri tuh terkuat!♪
Dialogue: 0,0:23:21.88,0:23:24.47,Default,,0,0,0,,Imutnya bukan main! Bodoh!♪
Dialogue: 0,0:23:24.47,0:23:27.59,Default,,0,0,0,,Itu sudah pasti aku!♪
Dialogue: 0,0:23:27.59,0:23:28.51,Default,,0,0,0,,Tentu, dong!♪
Dialogue: 0,0:23:28.51,0:23:31.18,Default,,0,0,0,,Raih kemenangan dengan\Nsegenap kekuatan♪
Dialogue: 0,0:23:31.18,0:23:33.39,Default,,0,0,0,,Kami 'kan tokoh utama,\Njadi pasti memimpin!♪
Dialogue: 0,0:23:33.64,0:23:36.27,Default,,0,0,0,,Hidup bersama jadi pusat perhatian♪
Dialogue: 0,0:23:36.27,0:23:37.73,Default,,0,0,0,,Heroine dijamin menang!♪
Dialogue: 0,0:23:37.73,0:23:38.73,Default,,0,0,0,,Kami menang!♪
Dialogue: 0,0:23:38.73,0:23:39.94,Default,,0,0,0,,Duk, duk, tok, tok♪
Dialogue: 0,0:23:39.94,0:23:40.90,Default,,0,0,0,,La, la, la, la, yey♪
Dialogue: 0,0:23:40.90,0:23:42.78,Default,,0,0,0,,Kisah kita berempat!!♪
Dialogue: 0,0:23:42.78,0:23:43.78,Default,,0,0,0,,Sip, menang!♪
Dialogue: 0,0:23:43.78,0:23:44.36,Default,,0,0,0,,Wus, wus, dor, dor♪
Dialogue: 0,0:23:44.36,0:23:44.99,Default,,0,0,0,,Buk, buk, blar, blar♪
Dialogue: 0,0:23:44.99,0:23:46.07,Default,,0,0,0,,Berdebar dengan kencangnya♪
Dialogue: 0,0:23:46.07,0:23:48.66,Default,,0,0,0,,Motivasiku melambung tinggi!!♪
Dialogue: 0,0:23:48.66,0:23:50.70,Default,,0,0,0,,Tu, wa, lalu maju♪
Dialogue: 0,0:23:50.70,0:23:51.16,Default,,0,0,0,,Demi aku♪
Dialogue: 0,0:23:51.16,0:23:53.20,Default,,0,0,0,,Ditambah lagi, runaway♪
Dialogue: 0,0:23:53.20,0:23:53.66,Default,,0,0,0,,Demi aku♪
Dialogue: 0,0:23:53.66,0:23:55.04,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:55.04,0:23:56.12,Default,,0,0,0,,Pasti menang!♪
Dialogue: 0,0:23:56.12,0:23:57.46,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:57.46,0:23:58.58,Default,,0,0,0,,Menang dengan gemilang♪
Dialogue: 0,0:23:58.58,0:24:00.04,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:24:00.04,0:24:01.04,Default,,0,0,0,,Menang dengan iseng♪
Dialogue: 0,0:24:01.04,0:24:02.50,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:24:02.50,0:24:05.97,Default,,0,0,0,,Kamilah pemenangnya!♪
Dialogue: 0,0:24:06.40,0:24:09.37,Default,,0,0,0,,Akulah tambahan!\NTambahan! Tambahan!
Dialogue: 0,0:24:10.32,0:24:15.15,Default,,0,0,0,,Piano dunia bawah berubah bentuk\Nmenyesuaikan pemainnya.
Dialogue: 0,0:24:15.15,0:24:16.77,Default,,0,0,0,,Saat disentuh Eiko...
Dialogue: 0,0:24:19.02,0:24:20.52,Default,,0,0,0,,Piano yang menyakitkan.
Dialogue: 0,0:24:23.83,0:24:25.78,Default,,0,0,0,,Senyuman yang bagus!\NImut banget!
Dialogue: 0,0:24:25.78,0:24:27.78,Default,,0,0,0,,Yang ini juga mantap!\NAh, sudut ini sempurna!
Dialogue: 0,0:24:27.78,0:24:29.99,Default,,0,0,0,,Ah, kami saling bertatapan!
Dialogue: 0,0:24:30.38,0:24:33.72,Default,,0,0,0,,Dengar, tema dari karpet Lilith adalah...
Dialogue: 0,0:24:33.72,0:24:46.26,Default,,0,0,0,,cinta.
Dialogue: 0,0:24:46.26,0:24:48.72,Default,,0,0,0,,Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:48.93,0:24:50.34,Default,,0,0,0,,"Meski Tak Terlihat".
Dialogue: 0,0:24:50.84,0:24:52.16,Default,,0,0,0,,Cinta.
Dialogue: 0,0:24:52.49,0:24:55.01,Default,,0,0,0,,Yang barusan tertawa akan dihukum.
