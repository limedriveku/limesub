Dialogue: 0,0:00:42.44,0:00:44.44,tanda,,0000,0000,0000,,PIXIE (PERI)
Dialogue: 0,0:01:19.43,0:01:26.73,tanda,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:02:41.02,0:02:45.52,tanda,,0000,0000,0000,,SATU IBLIS LAINNYA DARI KELAS ABNORMAL
Dialogue: 0,0:03:13.71,0:03:15.76,tanda,,0000,0000,0000,,KACAMATA ANTIDETEKSI
Dialogue: 0,0:03:30.73,0:03:33.31,tanda,,0000,0000,0000,,SEKOLAH IBLIS BABYLS
Dialogue: 0,0:03:34.24,0:03:38.28,tanda,,0000,0000,0000,,KELAS RAJA (ROYAL ONE)
Dialogue: 0,0:03:49.88,0:03:52.30,tanda,,0000,0000,0000,,PERINGKAT 4 (DALETH)
Dialogue: 0,0:04:02.31,0:04:02.97,tanda,,0000,0000,0000,,FESTIVAL MUSIK
Dialogue: 0,0:04:28.25,0:04:28.87,tanda,,0000,0000,0000,,PERINGKAT SAAT INI!!\NGIMEL (3) - DALETH (4)
Dialogue: 0,0:04:39.84,0:04:40.26,tanda,,0000,0000,0000,,BET (2)
Dialogue: 0,0:06:59.61,0:07:02.11,tanda,,0000,0000,0000,,PENGHALAU DETEKSI
Dialogue: 0,0:07:14.96,0:07:16.46,tanda,,0000,0000,0000,,PURSON SOI
Dialogue: 0,0:07:18.96,0:07:19.71,tanda,,0000,0000,0000,,BET (2)
Dialogue: 0,0:07:21.67,0:07:26.30,tanda,,0000,0000,0000,,SERAHKAN PADAKU!
Dialogue: 0,0:07:56.87,0:08:01.71,tanda,,0000,0000,0000,,TINGKAT MENCOLOK
Dialogue: 0,0:08:10.26,0:08:12.01,tanda,,0000,0000,0000,,SIAP!
Dialogue: 0,0:08:12.01,0:08:13.14,tanda,,0000,0000,0000,,PURSON, FESTIVAL MUSIK ITU ASYIK!
Dialogue: 0,0:14:24.38,0:14:25.26,tanda,,0000,0000,0000,,SELAMAT TINGGAL
Dialogue: 0,0:14:52.37,0:14:53.91,tanda,,0000,0000,0000,,ITU BUKAN PERCAKAPAN
Dialogue: 0,0:15:06.80,0:15:07.72,tanda,,0000,0000,0000,,ANONIMITAS TANPA BATAS
Dialogue: 0,0:15:28.20,0:15:30.24,tanda,,0000,0000,0000,,ANONIMITAS TANPA BATAS
Dialogue: 0,0:17:55.57,0:17:57.85,tanda,,0000,0000,0000,,SEDANG MENCARI PURSON.
Dialogue: 0,0:18:32.42,0:18:35.14,tanda,,0000,0000,0000,,GURU LICIK
Dialogue: 0,0:24:07.51,0:24:09.05,tanda,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:24:14.52,0:24:16.64,tanda,,0000,0000,0000,,TROMPET
Dialogue: 0,0:24:27.95,0:24:29.24,tanda,,0000,0000,0000,,SENYUM
Dialogue: 0,0:24:29.99,0:24:30.49,tanda,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:00:38.27,0:00:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pukul 5, ya?
Dialogue: 0,0:00:39.64,0:00:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini cukup sampai sini.
Dialogue: 0,0:00:41.19,0:00:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainan Pixie hari ini juga luar biasa, ya!
Dialogue: 0,0:00:44.44,0:00:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sampai lupa waktu juga.
Dialogue: 0,0:00:47.57,0:00:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus!\NSampai jumpa besok!
Dialogue: 0,0:00:49.20,0:00:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa besok!
Dialogue: 0,0:02:41.02,0:02:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Satu Iblis Lainnya dari Kelas Abnormal".
Dialogue: 0,0:02:46.02,0:02:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi!
Dialogue: 0,0:02:50.02,0:02:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:02:51.43,0:02:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat!
Dialogue: 0,0:02:54.15,0:02:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu!
Dialogue: 0,0:02:55.49,0:02:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irumachi, pagi!\NPagu! Pagi!
Dialogue: 0,0:02:59.03,0:03:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Tuan Iruma.
Dialogue: 0,0:03:01.54,0:03:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Clara, Azz!
Dialogue: 0,0:03:04.21,0:03:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seragam musim dinginmu keren, Irumachi!
Dialogue: 0,0:03:06.58,0:03:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang Anda pakai pasti cocok!
Dialogue: 0,0:03:13.71,0:03:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacamata antideteksi.
Dialogue: 0,0:03:15.76,0:03:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, kita pasti tak akan mencolok!
Dialogue: 0,0:03:17.97,0:03:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi,\NTuan Iruma adalah Raja Muda!
Dialogue: 0,0:03:20.76,0:03:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mencolok,\Nsemuanya pasti mendekati Anda!
Dialogue: 0,0:03:23.47,0:03:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kembaran!
Dialogue: 0,0:03:25.27,0:03:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga ke-ke-kembar...
Dialogue: 0,0:03:30.73,0:03:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah Iblis Babyls.
Dialogue: 0,0:03:34.24,0:03:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Royal One yang digunakan
Dialogue: 0,0:03:36.57,0:03:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}murid kelas abnormal.
Dialogue: 0,0:03:38.28,0:03:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma dan kawan-kawan yang berhasil\Nmasuk ke Kelas Raja itu,
Dialogue: 0,0:03:41.24,0:03:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diberikan suatu perintah.
Dialogue: 0,0:03:43.29,0:03:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perintah mengikuti pelajaran istimewa Babyls!
Dialogue: 0,0:03:46.29,0:03:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh murid kelas abnormal
Dialogue: 0,0:03:49.88,0:03:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus naik ke Daleth sebelum naik kelas!
Dialogue: 0,0:03:53.30,0:03:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian gagal,
Dialogue: 0,0:03:55.30,0:03:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langsung diusir dari Royal One!
Dialogue: 0,0:03:59.05,0:04:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan terakhir bagi mereka\Nuntuk naik peringkat ialah...
Dialogue: 0,0:04:02.97,0:04:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival Musik!
Dialogue: 0,0:04:05.10,0:04:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paduan suara, band, teater, apa pun boleh\Nselama bisa dinikmati suaranya.
Dialogue: 0,0:04:09.44,0:04:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dengan penampilan terbaik\Nyang akan jadi pemenangnya!
Dialogue: 0,0:04:13.07,0:04:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keenam kelas pun akan bersaing\Ndalam pertarungan musik!
Dialogue: 0,0:04:18.52,0:04:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival musik...
Dialogue: 0,0:04:20.36,0:04:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang perlu kita utamakan adalah...
Dialogue: 0,0:04:24.87,0:04:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo kita pikirkan bersama!
Dialogue: 0,0:04:27.08,0:04:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkumpul!
Dialogue: 0,0:04:28.87,0:04:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku satu peringkat dengan Tuan Iruma...
Dialogue: 0,0:04:31.08,0:04:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lead mencolok banget, ya.
Dialogue: 0,0:04:32.71,0:04:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya janggal.
Dialogue: 0,0:04:33.84,0:04:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak begitu, kok!
Dialogue: 0,0:04:35.51,0:04:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Raja Muda, lo!
Dialogue: 0,0:04:37.05,0:04:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tahu, kok.
Dialogue: 0,0:04:38.13,0:04:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang tersisa...
Dialogue: 0,0:04:40.26,0:04:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, ya.
Dialogue: 0,0:04:42.01,0:04:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja!
Dialogue: 0,0:04:43.30,0:04:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak sudah seperti Daleth, kok!
Dialogue: 0,0:04:47.02,0:04:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain...
Dialogue: 0,0:04:48.39,0:04:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah rencana yang kuciptakan!
Dialogue: 0,0:04:51.27,0:04:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan buat Mbak\Nmencolok di festival musik,
Dialogue: 0,0:04:54.82,0:04:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekaligus membuat\Nyang lain naik ke Daleth!
Dialogue: 0,0:04:59.15,0:05:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:05:00.53,0:05:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita buat Mbak jadi pusat perhatian,
Dialogue: 0,0:05:03.99,0:05:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan lakukan sebisanya\Nagar kita bisa ikut mencolok!
Dialogue: 0,0:05:11.54,0:05:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Tuan Iruma?
Dialogue: 0,0:05:13.96,0:05:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, rasanya aku melupakan\Nsesuatu yang penting...
Dialogue: 0,0:05:18.55,0:05:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa yang kalian ributkan?
Dialogue: 0,0:05:22.47,0:05:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian tidak bisa tenang sejenak saja?
Dialogue: 0,0:05:26.06,0:05:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Pak Kalego!
Dialogue: 0,0:05:28.72,0:05:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diamlah sejenak! Ini masih pagi!
Dialogue: 0,0:05:31.81,0:05:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bukan begitu, kami sedang rapat strategi!\N- Pak Eggy!
Dialogue: 0,0:05:34.36,0:05:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strategi?
Dialogue: 0,0:05:35.31,0:05:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang membahas festival musik!
Dialogue: 0,0:05:37.44,0:05:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berniat membuat Mbak\Nyang masih Bet jadi pusat perhatian!
Dialogue: 0,0:05:40.78,0:05:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore, putri panggung kami!
Dialogue: 0,0:05:42.74,0:05:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:05:44.16,0:05:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nbagaimana dengan yang satu lagi?
Dialogue: 0,0:05:48.20,0:05:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu lagi?
Dialogue: 0,0:05:50.04,0:05:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu lagi yang masih Bet, kan?
Dialogue: 0,0:05:53.21,0:05:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, siapa yang turun peringkat?
Dialogue: 0,0:05:56.34,0:05:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dan di mana dia?
Dialogue: 0,0:05:58.42,0:06:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ada di situ.
Dialogue: 0,0:06:03.13,0:06:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:10.47,0:06:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan Iruma, dia menghilang!\N- Hebat!
Dialogue: 0,0:06:12.35,0:06:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bagaimana bisa?\N- Hebat!
Dialogue: 0,0:06:13.27,0:06:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di luar dugaan!\N- Ilusi?
Dialogue: 0,0:06:14.65,0:06:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah, semuanya.
Dialogue: 0,0:06:17.61,0:06:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson, ya?
Dialogue: 0,0:06:20.61,0:06:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:21.74,0:06:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia adalah salah satu murid kelas abnormal.\N- Purson?
Dialogue: 0,0:06:23.95,0:06:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia adalah salah satu murid kelas abnormal.\N- Pur?
Dialogue: 0,0:06:26.24,0:06:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pembagian kelas,
Dialogue: 0,0:06:28.41,0:06:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat balapan terbang,
Dialogue: 0,0:06:29.91,0:06:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat ujian peluru meriam kematian,
Dialogue: 0,0:06:31.79,0:06:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat pindah ke Royal One,\Ndan saat ujian akhir semester...
Dialogue: 0,0:06:34.58,0:06:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengikuti semuanya.
Dialogue: 0,0:06:38.59,0:06:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sepertinya memang ada...
Dialogue: 0,0:06:42.47,0:06:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada?
Dialogue: 0,0:06:42.97,0:06:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, dia masih Bet, kan?
Dialogue: 0,0:06:45.05,0:06:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Ndia harus mencolok bersama Mbak!
Dialogue: 0,0:06:47.35,0:06:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu agak sulit.
Dialogue: 0,0:06:51.35,0:06:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama soal "mencolok".
Dialogue: 0,0:06:56.56,0:06:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson Soi dari kelas abnormal.
Dialogue: 0,0:06:59.61,0:07:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan keluarganya "Penghalau Deteksi".
Dialogue: 0,0:07:02.65,0:07:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia...
Dialogue: 0,0:07:04.86,0:07:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia iblis yang punya keyakinan\Ntidak boleh mencolok.
Dialogue: 0,0:07:11.95,0:07:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:14.96,0:07:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson Soi.
Dialogue: 0,0:07:17.67,0:07:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkatnya...
Dialogue: 0,0:07:19.71,0:07:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bet.
Dialogue: 0,0:07:27.72,0:07:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang sekolah!
Dialogue: 0,0:07:34.23,0:07:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, apa hobimu?
Dialogue: 0,0:07:45.36,0:07:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:07:46.86,0:07:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, jangan menghilang dulu!
Dialogue: 0,0:07:49.03,0:07:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena pertanyaannya aneh!
Dialogue: 0,0:07:50.53,0:07:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengikatnya nanti!
Dialogue: 0,0:07:52.58,0:07:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Hampir saja!
Dialogue: 0,0:07:54.91,0:07:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia menghilang,\Nberakhir sudah nasib kita!
Dialogue: 0,0:07:56.87,0:07:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya semua murid kelas abnormal
Dialogue: 0,0:07:59.83,0:08:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa mencapai Daleth di festival musik,
Dialogue: 0,0:08:01.71,0:08:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dua murid yang masih Bet\Nwajib aktif berpartisipasi!
Dialogue: 0,0:08:05.13,0:08:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, kita harus meyakinkan dia
Dialogue: 0,0:08:08.01,0:08:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar mau jadi pusat perhatian\Ndi festival musik!
Dialogue: 0,0:08:10.26,0:08:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:08:13.14,0:08:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ayo kita ikut festival musik bersama!
Dialogue: 0,0:08:17.69,0:08:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival musik pasti sangat\Nmendebarkan, meriah,
Dialogue: 0,0:08:21.69,0:08:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyenangkan, lo!
Dialogue: 0,0:08:22.61,0:08:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan bernyanyi dan menari bersama-sama!
Dialogue: 0,0:08:25.69,0:08:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegiatannya pasti ada banyak sekali!
Dialogue: 0,0:08:29.53,0:08:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau pilih yang menabuh atau mendenting?
Dialogue: 0,0:08:31.99,0:08:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau tarian berkilau?
Dialogue: 0,0:08:40.08,0:08:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dihiraukan?
Dialogue: 0,0:08:41.00,0:08:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara!
Dialogue: 0,0:08:43.03,0:08:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sama sekali tidak bergerak.
Dialogue: 0,0:08:44.59,0:08:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu takut.
Dialogue: 0,0:08:45.63,0:08:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia sama sekali tidak bicara.\N- Musik saja tidak cukup, ya?
Dialogue: 0,0:08:47.17,0:08:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya.\N- Musik saja tidak cukup, ya?
Dialogue: 0,0:08:49.63,0:08:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ini waktunya\Ndrama aksi Raja Iblis!
Dialogue: 0,0:08:53.47,0:08:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sukses besar saat Pesta Battler, lo!
Dialogue: 0,0:08:56.39,0:08:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah Raja Iblis\Nyang diceritakan melalui lagu!
Dialogue: 0,0:08:59.89,0:09:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu stimulan terbaik!
Dialogue: 0,0:09:02.15,0:09:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!\NPeran Raja Iblisnya—
Dialogue: 0,0:09:04.19,0:09:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bintang utamanya harus Purson.
Dialogue: 0,0:09:09.15,0:09:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, batalkan saja!
Dialogue: 0,0:09:10.78,0:09:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi!
Dialogue: 0,0:09:11.41,0:09:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali ke awal, ya?
Dialogue: 0,0:09:12.74,0:09:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:13.87,0:09:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar...
Dialogue: 0,0:09:15.16,0:09:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bahkan tak bisa\Nmembujuk dengan benar...
Dialogue: 0,0:09:19.83,0:09:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ini demi Tuan Iruma,
Dialogue: 0,0:09:23.33,0:09:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku rela mempertaruhkan nyawa\Ndemi mencapainya!
Dialogue: 0,0:09:25.59,0:09:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja, Tuan Iruma!
Dialogue: 0,0:09:27.34,0:09:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alice Asmodeus ini\Nakan menjelaskan secara rinci
Dialogue: 0,0:09:30.34,0:09:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}betapa pentingnya festival musik\Ndan betapa hebatnya Tuan Iruma—
Dialogue: 0,0:09:35.68,0:09:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar!
Dialogue: 0,0:09:37.85,0:09:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan belum mulai sama sekali!
Dialogue: 0,0:09:40.43,0:09:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerita Iruma-nya si Azz-Azz\Npanjang banget, sih.
Dialogue: 0,0:09:43.98,0:09:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pasti akan menghilang...
Dialogue: 0,0:09:45.56,0:09:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bicara musik,
Dialogue: 0,0:09:48.94,0:09:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus buat grup musik!
Dialogue: 0,0:09:51.46,0:09:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak sama Purson duet jadi vokalisnya!
Dialogue: 0,0:09:53.95,0:09:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti mencolok dan keren!
Dialogue: 0,0:09:56.70,0:09:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide yang bagus!
Dialogue: 0,0:09:59.95,0:10:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:10:02.50,0:10:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga.
Dialogue: 0,0:10:04.21,0:10:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bakal seru\Nkalau bisa nyanyi bareng Purson.
Dialogue: 0,0:10:08.75,0:10:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melirik ke sini!
Dialogue: 0,0:10:11.47,0:10:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson, vokalis pasti terkenal!
Dialogue: 0,0:10:13.26,0:10:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pasti akan membantu!
Dialogue: 0,0:10:14.84,0:10:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau?
Dialogue: 0,0:10:15.89,0:10:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:10:16.60,0:10:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:10:17.89,0:10:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami butuh bantuanmu, Purson!
Dialogue: 0,0:10:20.72,0:10:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik Mbak maupun kamu...
Dialogue: 0,0:10:22.85,0:10:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar semuanya bisa naik\Nke Daleth! Kumohon!
Dialogue: 0,0:10:25.56,0:10:28.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tampil mencolok bersama!\NTolong kami, ya!
Dialogue: 0,0:10:28.11,0:10:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memohon dengan sangat!
Dialogue: 0,0:10:38.37,0:10:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson!
Dialogue: 0,0:10:40.83,0:10:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi!
Dialogue: 0,0:10:42.16,0:10:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson?
Dialogue: 0,0:10:44.37,0:10:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghilang total!
Dialogue: 0,0:10:46.08,0:10:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, padahal kita sudah berusaha!
Dialogue: 0,0:10:48.63,0:10:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, ayo ikat dia kalau ketemu!
Dialogue: 0,0:10:51.84,0:10:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:10:52.59,0:10:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seperti mempermainkan kita.
Dialogue: 0,0:10:54.93,0:10:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, negosiasinya akan sulit.
Dialogue: 0,0:10:57.64,0:11:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, ini waktunya menunjukkan\Ntangan ahli menggelitik ini!
Dialogue: 0,0:11:00.72,0:11:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mungkin bisa pakai sihir\Ndan sedikit keras padanya...
Dialogue: 0,0:11:04.27,0:11:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan ide yang bagus—
Dialogue: 0,0:11:09.40,0:11:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang keluar...
Dialogue: 0,0:11:10.90,0:11:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson mau kabur, ya?
Dialogue: 0,0:11:13.07,0:11:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejar dia!
Dialogue: 0,0:11:14.53,0:11:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma,\Naku pasti akan menangkap Purson!
Dialogue: 0,0:11:17.95,0:11:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu saja di sini!
Dialogue: 0,0:11:19.24,0:11:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:19.78,0:11:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson, di mana kamu?
Dialogue: 0,0:11:29.71,0:11:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson...
Dialogue: 0,0:11:31.42,0:11:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di situ?
Dialogue: 0,0:11:35.22,0:11:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benaran ada!
Dialogue: 0,0:11:37.76,0:11:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Tunggu!\NJangan menghilang—
Dialogue: 0,0:11:40.26,0:11:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak apa-apa\Nkalau tidak mau dengar.
Dialogue: 0,0:11:50.02,0:11:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja aku bicara sendiri.
Dialogue: 0,0:11:56.78,0:12:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, maaf karena tidak menyadarimu.
Dialogue: 0,0:12:00.28,0:12:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sekelas,\Nkita tidak banyak bicara, ya?
Dialogue: 0,0:12:04.04,0:12:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan yang lain bingung harus berkata apa.
Dialogue: 0,0:12:08.08,0:12:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu alasannya kami panik.
Dialogue: 0,0:12:10.71,0:12:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permintaan kami juga agak berlebihan\Nuntuk festival musik.
Dialogue: 0,0:12:13.80,0:12:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku...
Dialogue: 0,0:12:15.84,0:12:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, kalau tidak mau,\Nkamu tidak perlu tampil!
Dialogue: 0,0:12:21.80,0:12:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sulit saat harus menolak\Npermintaan seseorang...
Dialogue: 0,0:12:28.10,0:12:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jujur pada keinginanmu\Nsendiri juga penting.
Dialogue: 0,0:12:34.40,0:12:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin menolak, katakan saja.
Dialogue: 0,0:12:36.82,0:12:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jadi masalah kalau sedikit egois.
Dialogue: 0,0:12:40.34,0:12:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru belajar hal itu\Nbelakangan ini, sih.
Dialogue: 0,0:12:45.37,0:12:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa keinginanmu?
Dialogue: 0,0:12:53.59,0:12:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:12:56.38,0:13:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat ditanya mau apa dan butuh waktu.\NJujur saja, aku masih panik
Dialogue: 0,0:13:00.30,0:13:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski disuruh ikut festival musik,\Nrasanya masih terlalu mendadak.
Dialogue: 0,0:13:03.14,0:13:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu harus tampil, sih.
Dialogue: 0,0:13:04.51,0:13:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang juga?
Dialogue: 0,0:13:05.60,0:13:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil juga jadi pusat perhatian.
Dialogue: 0,0:13:07.06,0:13:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berpikir untuk menolak dengan halus.
Dialogue: 0,0:13:08.81,0:13:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu persiapan mental?
Dialogue: 0,0:13:09.98,0:13:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menghilang saat gugup\Ndan bisa muncul tiba-tiba.
Dialogue: 0,0:13:12.06,0:13:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga berlawanan dengan keluargaku,\Njadi agak sulit.
Dialogue: 0,0:13:14.15,0:13:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang bingung\Nkarena berhadapan dengan pilihan.
Dialogue: 0,0:13:16.11,0:13:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah berusaha,
Dialogue: 0,0:13:17.11,0:13:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku terdiam memikirkannya.
Dialogue: 0,0:13:18.44,0:13:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bilangnya, ya?
Dialogue: 0,0:13:19.65,0:13:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit bagiku untuk berbaur dengan kalian.
Dialogue: 0,0:13:21.78,0:13:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga tidak bicara.
Dialogue: 0,0:13:22.70,0:13:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka musik, tapi itu beda cerita.
Dialogue: 0,0:13:24.16,0:13:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan terlalu gamblang.
Dialogue: 0,0:13:25.62,0:13:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayangkan seperti menyentuh gelembung.
Dialogue: 0,0:13:27.16,0:13:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pendiam dan ramai.
Dialogue: 0,0:13:28.16,0:13:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pendiam dan kalian ramai.
Dialogue: 0,0:13:29.25,0:13:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku kesulitan\Nmenyesuaikan dengan kalian.
Dialogue: 0,0:13:31.17,0:13:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam hati, aku sudah siap bilang,\N"Mustahil! Mustahil!"
Dialogue: 0,0:13:33.33,0:13:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mengucapkannya, aku mulai hilang lagi.
Dialogue: 0,0:13:35.00,0:13:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga terkejut.
Dialogue: 0,0:13:35.96,0:13:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:13:37.96,0:13:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar!
Dialogue: 0,0:13:39.21,0:13:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Purson tidak ada!
Dialogue: 0,0:13:43.22,0:13:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat datang kembali.\N- Irumachi.
Dialogue: 0,0:13:45.97,0:13:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pulang.
Dialogue: 0,0:13:47.22,0:13:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak bisa menemukan Purson.
Dialogue: 0,0:13:50.60,0:13:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku barusan bicara dengannya.
Dialogue: 0,0:13:53.31,0:13:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bicara dengan Purson?
Dialogue: 0,0:13:55.73,0:13:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, anu...
Dialogue: 0,0:13:58.23,0:14:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat cerewet.
Dialogue: 0,0:14:00.57,0:14:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong!
Dialogue: 0,0:14:01.49,0:14:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet?
Dialogue: 0,0:14:02.61,0:14:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak bicara?
Dialogue: 0,0:14:03.82,0:14:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kamu berkhayal.
Dialogue: 0,0:14:04.87,0:14:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu meragukan Tuan Iruma?
Dialogue: 0,0:14:07.28,0:14:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:14:07.99,0:14:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang apa?
Dialogue: 0,0:14:09.41,0:14:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya, sulit baginya untuk mencolok.
Dialogue: 0,0:14:13.87,0:14:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ditolak, ya?
Dialogue: 0,0:14:16.00,0:14:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kita tidak bisa apa-apa\Nkalau dia menghilang.
Dialogue: 0,0:14:19.67,0:14:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:20.76,0:14:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin agak berlebihan baginya\Nuntuk mencolok, ya?
Dialogue: 0,0:14:25.26,0:14:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak punya pilihan selain mengucapkan\Nselamat tinggal pada Royal One, ya!
Dialogue: 0,0:14:28.56,0:14:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal.
Dialogue: 0,0:14:30.47,0:14:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini...
Dialogue: 0,0:14:33.23,0:14:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia tampaknya tertarik\Npada festival musik.
Dialogue: 0,0:14:50.24,0:14:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu banyak bercakap-cakap.
Dialogue: 0,0:14:52.37,0:14:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan percakapan.
Dialogue: 0,0:14:53.91,0:14:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sejak aku ngobrol dengan\Nselain keluargaku, jadi kelepasan.
Dialogue: 0,0:14:58.67,0:15:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, rambut Pak Balam menjeratku.
Dialogue: 0,0:15:03.17,0:15:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, kamu sial banget, ya.\N- Tidak boleh.
Dialogue: 0,0:15:04.30,0:15:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, kamu sial banget, ya.\N- Aku harus menahan diri.
Dialogue: 0,0:15:07.72,0:15:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marga keluarga kita ialah Purson.
Dialogue: 0,0:15:10.01,0:15:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang tak boleh mencolok.
Dialogue: 0,0:15:13.02,0:15:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan keluarga kita adalah\N"Penghalau Deteksi".
Dialogue: 0,0:15:15.60,0:15:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita selalu "tidak mencolok", "tidak bising",\Ndan "tidak menarik perhatian".
Dialogue: 0,0:15:19.65,0:15:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga terhormat para penyendiri.
Dialogue: 0,0:15:22.53,0:15:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbanggalah pada warisan kita\Ndan bertindaklah tanpa lupa akan hal itu.
Dialogue: 0,0:15:27.07,0:15:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah.
Dialogue: 0,0:15:28.20,0:15:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah di mana?
Dialogue: 0,0:15:30.24,0:15:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:15:31.83,0:15:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang Purson harus selalu\Ntak mencolok dan tak terlihat.
Dialogue: 0,0:15:35.58,0:15:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar sana, kita berfokus dalam\Npengembangan alat antideteksi.
Dialogue: 0,0:15:38.71,0:15:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di baliknya, kita berkontribusi\Nuntuk dunia bawah dalam misi rahasia.
Dialogue: 0,0:15:44.01,0:15:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita adalah "Kelelawar yang Netral".
Dialogue: 0,0:15:47.84,0:15:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan kita berbahaya.
Dialogue: 0,0:15:50.14,0:15:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau disalahgunakan, bisa membahayakan\Nkeseimbangan dunia bawah.
Dialogue: 0,0:15:54.85,0:15:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentunya, kakakmu sendiri sangat terampil.
Dialogue: 0,0:15:58.48,0:16:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang bisa menemukannya\Ndan tak diketahui keberadaannya.
Dialogue: 0,0:16:01.98,0:16:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas keluarga yang diemban kakakmu\Ntelah turun kepadamu, Soi.
Dialogue: 0,0:16:09.20,0:16:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:16:10.99,0:16:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai hafal dengan perkataannya.
Dialogue: 0,0:16:13.24,0:16:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan belum pernah\Nlihat wajah Kakak.
Dialogue: 0,0:16:14.83,0:16:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekanannya terlalu tinggi.
Dialogue: 0,0:16:16.16,0:16:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin Ayah lebih lembut lagi.
Dialogue: 0,0:16:17.41,0:16:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai aku bisa menikahi futon lembut ini.
Dialogue: 0,0:16:18.87,0:16:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku mau pacar imut.
Dialogue: 0,0:16:19.75,0:16:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin perlu sayap atau...
Dialogue: 0,0:16:20.71,0:16:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu di hadapan ayahmu, ya.
Dialogue: 0,0:16:23.46,0:16:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu ada di sini?
Dialogue: 0,0:16:25.51,0:16:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:16:26.22,0:16:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan?
Dialogue: 0,0:16:26.92,0:16:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kamu bilang, "Berisik."
Dialogue: 0,0:16:28.97,0:16:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, dari awal, dong.
Dialogue: 0,0:16:30.64,0:16:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soi, aku paham kamu kerepotan.
Dialogue: 0,0:16:33.97,0:16:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sulit menahan diri\Nuntuk tidak bicara, kan?
Dialogue: 0,0:16:37.31,0:16:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ayahmu menginginkan\Nyang terbaik untukmu.
Dialogue: 0,0:16:40.65,0:16:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu.
Dialogue: 0,0:16:42.19,0:16:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja, kok.
Dialogue: 0,0:16:46.86,0:16:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat ini, Soi.
Dialogue: 0,0:16:49.32,0:16:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali kamu sangat ingin bicara,
Dialogue: 0,0:16:57.45,0:17:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}salurkan semuanya ke sini.
Dialogue: 0,0:17:05.21,0:17:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:17:30.90,0:17:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pukul 5, ya?
Dialogue: 0,0:17:32.16,0:17:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara Pixie hari ini juga luar biasa, ya!
Dialogue: 0,0:17:34.87,0:17:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainan trompet\Nyang menggerakkan hati!
Dialogue: 0,0:17:37.49,0:17:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira siapa yang main, ya?
Dialogue: 0,0:17:39.45,0:17:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena kita tidak tahu,\Ndia dijuluki Pixie, kan?
Dialogue: 0,0:17:48.13,0:17:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan hari ini\Nlebih bersemangat dari biasanya, ya?
Dialogue: 0,0:17:51.76,0:17:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:55.57,0:17:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya si Pixie itu, ya?
Dialogue: 0,0:17:57.85,0:17:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah, ya.
Dialogue: 0,0:17:59.18,0:18:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku melayang sendiri!
Dialogue: 0,0:18:02.19,0:18:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tampil di festival musik,\NAndai saja Pixie mau ikut kita
Dialogue: 0,0:18:05.23,0:18:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kelas abnormal pasti bakal menang.
Dialogue: 0,0:18:08.90,0:18:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, Mbak, Purson,\Ndan yang lain bisa naik ke Daleth.
Dialogue: 0,0:18:13.95,0:18:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, berakhir bahagia.
Dialogue: 0,0:18:28.88,0:18:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak hal yang ingin\Nkulampiaskan hari ini...
Dialogue: 0,0:18:32.42,0:18:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, si guru licik, Pak Kalego.
Dialogue: 0,0:18:35.14,0:18:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di situ.\N- Eh?
Dialogue: 0,0:18:36.47,0:18:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dibocorkan.
Dialogue: 0,0:18:37.89,0:18:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget, jadi tolong jangan diulangi.
Dialogue: 0,0:18:40.81,0:18:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa merusak suasana\Nkalau tidak ikut festival.
Dialogue: 0,0:18:43.10,0:18:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak akan ikut.
Dialogue: 0,0:18:45.94,0:18:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong...
Dialogue: 0,0:18:47.61,0:18:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya tiba-tiba jadi terlalu dekat.
Dialogue: 0,0:18:50.61,0:18:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ketakutan.
Dialogue: 0,0:18:53.15,0:18:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang ada yang peduli padaku...
Dialogue: 0,0:18:56.07,0:18:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:59.28,0:19:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, aku mungkin bisa\Nsangat bersinar di festival musik.
Dialogue: 0,0:19:03.21,0:19:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, keluarga Purson tidak boleh mencolok.
Dialogue: 0,0:19:05.29,0:19:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah aturan mutlak!
Dialogue: 0,0:19:10.84,0:19:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan mengungkap\Nbakat musikku pada siapa pun.
Dialogue: 0,0:19:15.03,0:19:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku harus tetap netral.
Dialogue: 0,0:19:18.35,0:19:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Layaknya kelelawar yang sedang terbang.
Dialogue: 0,0:19:27.35,0:19:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa?\NTunggu dulu.
Dialogue: 0,0:19:29.48,0:19:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku harus segera menghilang—
Dialogue: 0,0:19:30.86,0:19:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:19:36.49,0:19:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hebat, Purson!
Dialogue: 0,0:19:38.53,0:19:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang keluar sangat keren!
Dialogue: 0,0:19:43.37,0:19:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat berkilauan,\Nbergemerlap, dan menyilaukan!
Dialogue: 0,0:19:46.46,0:19:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu—
Dialogue: 0,0:19:47.37,0:19:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ini hanya caraku\Nuntuk menghilangkan stres.
Dialogue: 0,0:19:49.58,0:19:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kenapa kamu ada di sini?
Dialogue: 0,0:19:51.42,0:19:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bukan penggemar musik.
Dialogue: 0,0:19:52.80,0:19:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma pemula yang belum pernah tampil.
Dialogue: 0,0:19:54.30,0:19:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasiakan dan lupakan tentang ini.
Dialogue: 0,0:19:55.76,0:19:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan saja.
Dialogue: 0,0:19:56.43,0:19:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah sangka.
Dialogue: 0,0:19:57.22,0:19:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, ini cuma mimpi...
Dialogue: 0,0:19:59.55,0:20:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, waktunya bangun dari tidur!
Dialogue: 0,0:20:02.35,0:20:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanku mungkin agak berlebihan...
Dialogue: 0,0:20:08.48,0:20:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, begitu ceritanya.
Dialogue: 0,0:20:17.74,0:20:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu—
Dialogue: 0,0:20:18.41,0:20:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:20:19.74,0:20:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:20:20.70,0:20:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi dengarkan aku dulu.
Dialogue: 0,0:20:23.29,0:20:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus minta maaf padamu.
Dialogue: 0,0:20:27.16,0:20:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tak tahu apa yang ingin kamu lakukan.
Dialogue: 0,0:20:32.29,0:20:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargamu juga punya aturan\Ntak boleh mencolok.
Dialogue: 0,0:20:34.80,0:20:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kamu kerepotan\Nsaat semuanya memintamu tampil.
Dialogue: 0,0:20:39.26,0:20:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kupikir kamu tidak perlu tampil\Nkalau tidak mau.
Dialogue: 0,0:20:43.81,0:20:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:47.43,0:20:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat permainan trompetmu barusan...
Dialogue: 0,0:20:51.77,0:20:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar tersentuh!
Dialogue: 0,0:20:55.98,0:21:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, meski aku barusan bilang\Ntidak perlu tampil kalau tidak mau.
Dialogue: 0,0:21:00.03,0:21:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang hal yang egois,
Dialogue: 0,0:21:02.41,0:21:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tolong kesampingkan dulu\Naturan keluargamu.
Dialogue: 0,0:21:05.41,0:21:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini egois,
Dialogue: 0,0:21:07.58,0:21:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua orang mendengar musikmu!\Ntapi aku hanya ingin
Dialogue: 0,0:21:12.67,0:21:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo buat mereka mendengarkannya!
Dialogue: 0,0:21:15.21,0:21:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihatmu dipuji\Noleh semua orang!
Dialogue: 0,0:21:18.75,0:21:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:21:20.43,0:21:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ayo ikut festival musik\Nbersama-sama!
Dialogue: 0,0:21:24.26,0:21:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Lakukan untuk kami."\Natau "Enak kalau kamu mau ikut."
Dialogue: 0,0:21:28.10,0:21:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku bisa kabur dengan mudah\Ndari permohonan semacam itu.
Dialogue: 0,0:21:33.52,0:21:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa?
Dialogue: 0,0:21:35.44,0:21:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku tak bisa berkata-kata?
Dialogue: 0,0:21:41.24,0:21:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihatmu
Dialogue: 0,0:21:48.50,0:21:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipuji oleh semua orang!
Dialogue: 0,0:21:55.96,0:22:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh hanya musikku saja.
Dialogue: 0,0:22:04.97,0:22:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:22:07.22,0:22:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:22:08.72,0:22:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yay! Hore!\N- Eh, padahal aku tidak boleh mencolok.
Dialogue: 0,0:22:11.77,0:22:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terima kasih!\N- Eh, padahal aku tidak boleh mencolok.
Dialogue: 0,0:22:13.10,0:22:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku tahu itu dilarang, tapi kenapa?\N- Purson, kamu bilang iya, kan?
Dialogue: 0,0:22:15.94,0:22:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gara-gara terseret semangatnya,\N- Terima kasih!
Dialogue: 0,0:22:17.27,0:22:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- aku jadi kelepasan.\N- Hore!
Dialogue: 0,0:22:18.98,0:22:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak, tidak boleh!\N- Hore!
Dialogue: 0,0:22:20.40,0:22:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, dia berisik sekali.
Dialogue: 0,0:22:21.82,0:22:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Anu, jadi...\N- Purson, janji, ya!
Dialogue: 0,0:22:25.45,0:22:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku akan tampil di festival musik?\N- Terima kasih!
Dialogue: 0,0:22:26.87,0:22:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terima kasih, Purson!\N- Aku akan tampil di festival musik?
Dialogue: 0,0:22:30.00,0:22:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara keegoisan dia?
Dialogue: 0,0:24:05.51,0:24:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan!
Dialogue: 0,0:24:09.72,0:24:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat ini, Soi.
Dialogue: 0,0:24:11.26,0:24:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali kamu sangat ingin bicara,
Dialogue: 0,0:24:14.52,0:24:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}salurkan semuanya ke sini.
Dialogue: 0,0:24:16.64,0:24:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:24:17.77,0:24:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trompet.
Dialogue: 0,0:24:19.15,0:24:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi hangat.
Dialogue: 0,0:24:20.31,0:24:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuala selimut.
Dialogue: 0,0:24:21.52,0:24:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur kocok.
Dialogue: 0,0:24:22.65,0:24:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kano karet.
Dialogue: 0,0:24:23.82,0:24:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Telolet.
Dialogue: 0,0:24:25.36,0:24:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa semuanya berakhiran huruf "T"?
Dialogue: 0,0:24:30.49,0:24:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sadar, aku malah setuju\Nikut tampil di festival musik.
Dialogue: 0,0:24:32.74,0:24:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau ikut tampil,\Naku pasti akan sangat bersinar
Dialogue: 0,0:24:35.12,0:24:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dibanjiri pujian, sih.
Dialogue: 0,0:24:36.50,0:24:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, keluarga Purson tidak boleh mencolok.
Dialogue: 0,0:24:38.29,0:24:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah aturannya.
Dialogue: 0,0:24:39.12,0:24:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa aku setuju mau tampil\Nmeski hanya musikku saja?
Dialogue: 0,0:24:42.75,0:24:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara terseret keegoisan Iruma,\Naku jadi kelepasan.
Dialogue: 0,0:24:46.05,0:24:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya di Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:48.38,0:24:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tantangan 13 Orang".
Dialogue: 0,0:24:50.39,0:24:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu bilang ingin melihatku\Ndipuji oleh semua orang,
Dialogue: 0,0:24:52.89,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan hanya seoktaf,\Ntapi semangatku naik drastis!
