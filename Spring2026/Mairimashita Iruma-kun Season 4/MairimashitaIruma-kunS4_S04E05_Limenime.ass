Dialogue: 0,0:00:00.31,0:00:03.90,tanda,,0000,0000,0000,,BERSAMA GURU
Dialogue: 0,0:00:07.57,0:00:11.70,tanda,,0000,0000,0000,,PAK ROBIN
Dialogue: 0,0:00:11.70,0:00:15.83,tanda,,0000,0000,0000,,PAK ORIAS - PAK MARBAS
Dialogue: 0,0:00:20.25,0:00:22.25,tanda,,0000,0000,0000,,FESTIVAL MUSIK/VIDEO INFORMASI
Dialogue: 0,0:00:22.25,0:00:25.51,tanda,,0000,0000,0000,,~BERSAMA GURU~
Dialogue: 0,0:00:40.27,0:00:41.10,tanda,,0000,0000,0000,,BAGUS!
Dialogue: 0,0:00:41.10,0:00:42.44,tanda,,0000,0000,0000,,LEBIH MENONJOL LAGI!
Dialogue: 0,0:00:49.95,0:00:50.95,tanda,,0000,0000,0000,,FESTIVAL DIADAKAN DI AULA BABYLS
Dialogue: 0,0:00:59.21,0:01:03.36,tanda,,0000,0000,0000,,JURI SPESIAL AKAN DITENTUKAN!!
Dialogue: 0,0:01:03.36,0:01:05.09,tanda,,0000,0000,0000,,TAMU KEHORMATAN!
Dialogue: 0,0:01:19.10,0:01:20.48,tanda,,0000,0000,0000,,PAK MARBAS!
Dialogue: 0,0:01:26.86,0:01:31.07,tanda,,0000,0000,0000,,SEMUANYA, BERJUANGLAH!!
Dialogue: 0,0:01:44.46,0:01:51.76,tanda,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:03:05.96,0:03:06.92,tanda,,0000,0000,0000,,MENGOBROL
Dialogue: 0,0:03:12.96,0:03:14.88,tanda,,0000,0000,0000,,PAK MARBAS
Dialogue: 0,0:03:47.96,0:03:50.46,tanda,,0000,0000,0000,,PANDUAN MENARI
Dialogue: 0,0:04:02.72,0:04:05.39,tanda,,0000,0000,0000,,IDOLA IBLIS ABADI
Dialogue: 0,0:04:34.38,0:04:36.59,tanda,,0000,0000,0000,,LINGKARAN PUJIAN
Dialogue: 0,0:08:58.43,0:08:59.89,tanda,,0000,0000,0000,,LAPORAN PENGADUAN RAHASIA
Dialogue: 0,0:15:36.17,0:15:37.67,tanda,,0000,0000,0000,,HARI FESTIVAL MUSIK
Dialogue: 0,0:16:36.68,0:16:39.94,tanda,,0000,0000,0000,,CAP BALAM
Dialogue: 0,0:17:25.48,0:17:26.94,tanda,,0000,0000,0000,,KYUPA
Dialogue: 0,0:17:33.28,0:17:35.62,tanda,,0000,0000,0000,,MEI MEI
Dialogue: 0,0:17:41.87,0:17:43.71,tanda,,0000,0000,0000,,AMDUSCIAS
Dialogue: 0,0:21:08.91,0:21:11.92,tanda,,0000,0000,0000,,MEMAINKAN
Dialogue: 0,0:24:07.59,0:24:09.05,tanda,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:24:29.99,0:24:30.74,tanda,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:00:03.90,0:00:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Daging segar manusia ialah makanan kita ♪
Dialogue: 0,0:00:11.70,0:00:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita harus nikmati darah, jiwa ♪
Dialogue: 0,0:00:15.83,0:00:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ serta daging mereka tanpa sisa ♪
Dialogue: 0,0:00:20.25,0:00:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertanda kalau...
Dialogue: 0,0:00:22.25,0:00:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival musik akan dimulai!
Dialogue: 0,0:00:24.00,0:00:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ho-Hore!
Dialogue: 0,0:00:25.51,0:00:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, hari esok akhirnya hampir tiba!
Dialogue: 0,0:00:27.80,0:00:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Presentasi terakhir bagi murid kelas satu!
Dialogue: 0,0:00:32.25,0:00:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Festival musik!\N- Kamu terlalu dekat!
Dialogue: 0,0:00:34.81,0:00:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Setiap tahun, guru muda seperti kami\N- Kelihatan? Kelihatan? Semuanya?
Dialogue: 0,0:00:37.64,0:00:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- bertugas untuk memandu festival musik.\N- Kelihatan? Kelihatan? Semuanya?
Dialogue: 0,0:00:40.27,0:00:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:00:41.10,0:00:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halaman enam naskah!
Dialogue: 0,0:00:42.44,0:00:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Ya! Aku mau membacanya!
Dialogue: 0,0:00:45.11,0:00:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjelasan nomor satu.
Dialogue: 0,0:00:46.94,0:00:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festivalnya akan diadakan di aula Babyls.
Dialogue: 0,0:00:50.95,0:00:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal ada penonton juga, lo.
Dialogue: 0,0:00:52.70,0:00:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid kelas dua dan tiga\Nakan menyaksikan keberanian kalian.
Dialogue: 0,0:00:57.50,0:00:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk para keluarga juga.
Dialogue: 0,0:00:59.21,0:01:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, akan ada juri spesial!
Dialogue: 0,0:01:03.36,0:01:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun ini juga bakal meriah!
Dialogue: 0,0:01:05.09,0:01:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka adalah iblis kelas atas!
Dialogue: 0,0:01:07.63,0:01:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap juri dapat memberi skor\Nhingga enam poin.
Dialogue: 0,0:01:10.97,0:01:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urutan penampilannya akan diundi!
Dialogue: 0,0:01:12.84,0:01:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang curang akan langsung ketahuan!
Dialogue: 0,0:01:15.97,0:01:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi kelas yang menang...
Dialogue: 0,0:01:19.10,0:01:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentunya...
Dialogue: 0,0:01:22.60,0:01:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan dapat kenaikan peringkat!
Dialogue: 0,0:01:26.86,0:01:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingannya akan dimulai besok!
Dialogue: 0,0:01:28.61,0:01:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksimalkan daya tarik kalian!
Dialogue: 0,0:01:31.07,0:01:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berusahalah tampil mencolok,\Nmurid kelas satu!
Dialogue: 0,0:03:06.92,0:03:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mengobrol".
Dialogue: 0,0:03:10.46,0:03:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar lagi.
Dialogue: 0,0:03:12.96,0:03:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira kelas mana yang akan menang...
Dialogue: 0,0:03:15.30,0:03:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu...
Dialogue: 0,0:03:17.30,0:03:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya besok\Nfestival musik akan dimulai.
Dialogue: 0,0:03:20.81,0:03:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kita hanya satu, yaitu menang.
Dialogue: 0,0:03:24.06,0:03:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan segala yang telah\Nkalian peroleh dari latihan.
Dialogue: 0,0:03:27.59,0:03:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah lakukan segala yang kita bisa.
Dialogue: 0,0:03:30.19,0:03:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya...
Dialogue: 0,0:03:32.73,0:03:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, tenang sedikit!
Dialogue: 0,0:03:35.45,0:03:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kami sama sekali tidak gugup, kok.
Dialogue: 0,0:03:37.99,0:03:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang, gampang.
Dialogue: 0,0:03:39.57,0:03:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaki kalian gemetaran.
Dialogue: 0,0:03:41.20,0:03:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya!
Dialogue: 0,0:03:42.20,0:03:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu festivalnya besok...
Dialogue: 0,0:03:43.95,0:03:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lebih menyeramkan dari latihan!
Dialogue: 0,0:03:46.46,0:03:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, tenanglah.
Dialogue: 0,0:03:47.96,0:03:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Allocer, bukumu terbalik!
Dialogue: 0,0:03:49.21,0:03:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang harusnya tenang!
Dialogue: 0,0:03:50.46,0:03:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan Iruma sudah bergabung!
Dialogue: 0,0:03:52.42,0:03:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma jadi tergencet!
Dialogue: 0,0:03:53.96,0:03:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putarannya ke sini, kan?
Dialogue: 0,0:03:55.67,0:03:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pitaku di mana?
Dialogue: 0,0:03:57.72,0:04:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contoh asli demam panggung.
Dialogue: 0,0:04:00.85,0:04:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi, ya.
Dialogue: 0,0:04:02.72,0:04:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai (penggemar) Idola Iblis,
Dialogue: 0,0:04:05.39,0:04:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan ajari kalian\Nritual agar percaya diri!
Dialogue: 0,0:04:08.98,0:04:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jazz, coba kemari.
Dialogue: 0,0:04:10.77,0:04:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:04:11.86,0:04:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, jangan bergerak.
Dialogue: 0,0:04:18.74,0:04:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Formasinya selesai.
Dialogue: 0,0:04:20.74,0:04:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:04:21.99,0:04:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puji dia tanpa ampun!
Dialogue: 0,0:04:23.99,0:04:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak yang bisa diandalkan!
Dialogue: 0,0:04:25.41,0:04:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terampil!
Dialogue: 0,0:04:26.00,0:04:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:04:26.91,0:04:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seleranya bagus.
Dialogue: 0,0:04:27.87,0:04:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerdas dan tanggap!
Dialogue: 0,0:04:28.75,0:04:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintar!
Dialogue: 0,0:04:29.54,0:04:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewasa banget.
Dialogue: 0,0:04:30.75,0:04:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakan jarimu luar biasa!
Dialogue: 0,0:04:32.71,0:04:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Genius maling!
Dialogue: 0,0:04:34.38,0:04:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya "Lingkaran Pujian"!
Dialogue: 0,0:04:36.59,0:04:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melingkari sang idola\Ndan memujinya sepenuh hati!
Dialogue: 0,0:04:40.38,0:04:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beginilah yang harus dilakukan\Nkalau ingin percaya diri.
Dialogue: 0,0:04:43.60,0:04:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu neraka, ya?
Dialogue: 0,0:04:44.89,0:04:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjut!
Dialogue: 0,0:04:46.43,0:04:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengendali angin terkuat!
Dialogue: 0,0:04:48.02,0:04:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbakat!
Dialogue: 0,0:04:49.19,0:04:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakannya enak!
Dialogue: 0,0:04:50.39,0:04:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang perhatian!
Dialogue: 0,0:04:52.06,0:04:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas usahamu selama ini!
Dialogue: 0,0:04:54.86,0:04:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja iblis selanjutnya!
Dialogue: 0,0:04:55.94,0:04:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laki banget!
Dialogue: 0,0:04:57.11,0:04:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang dipanjat!
Dialogue: 0,0:04:57.99,0:04:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si otot nomor satu!
Dialogue: 0,0:04:59.45,0:05:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makan apa\Nsampai bisa sebesar itu?
Dialogue: 0,0:05:02.62,0:05:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganteng!
Dialogue: 0,0:05:03.45,0:05:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata baik hati!
Dialogue: 0,0:05:04.45,0:05:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdosa karena cantik!\NHarus dihukum karena terlalu cantik!
Dialogue: 0,0:05:06.83,0:05:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut banget!
Dialogue: 0,0:05:09.54,0:05:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria jantan!\NTata kramanya bagus!
Dialogue: 0,0:05:11.46,0:05:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum!
Dialogue: 0,0:05:12.21,0:05:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serakahnya bukan main!
Dialogue: 0,0:05:14.13,0:05:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih lanjut lagi!
Dialogue: 0,0:05:16.55,0:05:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:05:18.55,0:05:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si pembuat suasana!
Dialogue: 0,0:05:19.88,0:05:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jago main gim!
Dialogue: 0,0:05:21.01,0:05:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sederhana!
Dialogue: 0,0:05:21.76,0:05:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Muda!
Dialogue: 0,0:05:22.47,0:05:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceria dan berjiwa besar.
Dialogue: 0,0:05:23.72,0:05:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Bijaksana kami!
Dialogue: 0,0:05:25.14,0:05:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Pengetahuan!
Dialogue: 0,0:05:26.14,0:05:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu segalanya!
Dialogue: 0,0:05:26.97,0:05:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kamu memang populer?
Dialogue: 0,0:05:28.39,0:05:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ratu nan indah!
Dialogue: 0,0:05:29.60,0:05:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengetahuan Idola Iblis\Ndan tariannya luar biasa!
Dialogue: 0,0:05:31.77,0:05:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut!
Dialogue: 0,0:05:32.56,0:05:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemimpin alami!
Dialogue: 0,0:05:33.35,0:05:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain "Imut!"\Nsemuanya membuatku gelisah.
Dialogue: 0,0:05:36.07,0:05:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sosok mulia yang terhormat,\N- Pusat perhatian!
Dialogue: 0,0:05:37.53,0:05:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- memiliki kualitas Raja Iblis selanjutnya,\N- Baik hati!
Dialogue: 0,0:05:38.44,0:05:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- memiliki kualitas Raja Iblis selanjutnya,\N- Tuan Pembuat Masalah!
Dialogue: 0,0:05:39.86,0:05:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sungguh sosok yang—\N- Azz-Azz berisik.
Dialogue: 0,0:05:40.99,0:05:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, selanjutnya Azz-Azz.
Dialogue: 0,0:05:46.78,0:05:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Tuan Iruma.
Dialogue: 0,0:05:49.41,0:05:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ru-Ruang pribadi?
Dialogue: 0,0:05:53.42,0:05:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menganggap lengan Iruma\Nsebagai ruang pribadimu, ya!
Dialogue: 0,0:05:58.92,0:06:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:06:01.30,0:06:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz curang!\NAku juga mau masuk!
Dialogue: 0,0:06:05.89,0:06:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz bisa diandalkan, kuat, dan hebat.
Dialogue: 0,0:06:09.85,0:06:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara imut, ceria, dan hangat.
Dialogue: 0,0:06:13.31,0:06:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat menyenangkan bisa bersama kalian.
Dialogue: 0,0:06:17.69,0:06:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemujinya malah tersipu malu.
Dialogue: 0,0:06:19.28,0:06:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujud baru dari pujian, ya?
Dialogue: 0,0:06:22.55,0:06:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kalau kita bersama-sama!
Dialogue: 0,0:06:25.70,0:06:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gudang pengetahuan!
Dialogue: 0,0:06:27.03,0:06:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master sejati!
Dialogue: 0,0:06:28.95,0:06:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak yang tidur\Nakan tumbuh dengan baik!
Dialogue: 0,0:06:30.83,0:06:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski suka ikut campur,\Nonigiri buatanmu enak.
Dialogue: 0,0:06:33.46,0:06:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuh dengan bakat!
Dialogue: 0,0:06:35.33,0:06:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rival yang hebat!
Dialogue: 0,0:06:36.83,0:06:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik hati! Keren!
Dialogue: 0,0:06:38.75,0:06:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman kelas kebanggaan!
Dialogue: 0,0:06:40.96,0:06:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut bukan main!
Dialogue: 0,0:06:42.59,0:06:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pandai memuji!
Dialogue: 0,0:06:43.97,0:06:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puji! Puji! Puji!
Dialogue: 0,0:06:46.97,0:06:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, sebagai penutup!
Dialogue: 0,0:06:49.97,0:06:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antara kecemasan akan\Nfestival musik dan kecantikanku,
Dialogue: 0,0:06:54.23,0:06:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manakah yang lebih kuat?
Dialogue: 0,0:06:56.40,0:07:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecantikan Mbak!
Dialogue: 0,0:07:03.86,0:07:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mbak! Mbak!\N- Mbak kami!
Dialogue: 0,0:07:08.66,0:07:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego ikut juga, yuk!
Dialogue: 0,0:07:10.03,0:07:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:07:11.37,0:07:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego, ayo ke tengah.
Dialogue: 0,0:07:12.83,0:07:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Cepat pulang sana!
Dialogue: 0,0:07:16.08,0:07:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kita semua istirahat.
Dialogue: 0,0:07:18.67,0:07:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok jam enam, ya.
Dialogue: 0,0:07:19.96,0:07:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:07:20.63,0:07:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal datang setelah makan banyak.
Dialogue: 0,0:07:22.42,0:07:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma.
Dialogue: 0,0:07:23.59,0:07:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo buat penampilan besok lancar.
Dialogue: 0,0:07:26.68,0:07:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan melakukannya bersama semuanya.
Dialogue: 0,0:07:28.96,0:07:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:07:30.10,0:07:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahatlah dengan tenang malam ini.
Dialogue: 0,0:07:33.31,0:07:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:07:34.68,0:07:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski semuanya cemas,\Nmereka tidak khawatir.
Dialogue: 0,0:07:49.62,0:07:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka percaya dan menunggu.
Dialogue: 0,0:07:54.41,0:07:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunggu dirimu.
Dialogue: 0,0:08:05.13,0:08:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di sini, kan?
Dialogue: 0,0:08:07.93,0:08:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang untuk mengobrol, Purson.
Dialogue: 0,0:08:14.89,0:08:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sudah lewat jam 5.
Dialogue: 0,0:08:18.31,0:08:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, waktunya pulang.
Dialogue: 0,0:08:20.65,0:08:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:08:23.27,0:08:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, Pixie tidak bermain, ya.
Dialogue: 0,0:08:28.07,0:08:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya jadi ada yang kurang, ya.
Dialogue: 0,0:08:31.24,0:08:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:08:36.00,0:08:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu ada di sini saat sore, kan?
Dialogue: 0,0:08:39.29,0:08:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atap Royal One.
Dialogue: 0,0:08:41.90,0:08:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pertama kali bertemu\Ndenganmu juga di sini.
Dialogue: 0,0:08:46.13,0:08:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di sini, kan?
Dialogue: 0,0:08:49.88,0:08:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti...
Dialogue: 0,0:08:51.76,0:08:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di sini.
Dialogue: 0,0:08:58.43,0:08:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu,
Dialogue: 0,0:08:59.89,0:09:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari kita mulai\Nsesi bongkar rahasia Purson.
Dialogue: 0,0:09:04.94,0:09:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, informasi dari seorang anonim,\Nyakni S dari kelas abnormal.
Dialogue: 0,0:09:09.95,0:09:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Purson bersikap dewasa,
Dialogue: 0,0:09:13.37,0:09:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia masih bocil\Ndan tidak bisa minum kopi.
Dialogue: 0,0:09:15.95,0:09:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, informasi dari A,\Nkelas abnormal.
Dialogue: 0,0:09:19.43,0:09:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pernah bilang "meong"\Ndan langsung dikoreksi jadi "kucing".
Dialogue: 0,0:09:23.54,0:09:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari E.
Dialogue: 0,0:09:24.96,0:09:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bisa main lompat tali.
Dialogue: 0,0:09:27.30,0:09:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Pak K. Dia pernah datang\Npadaku dengan wajah serius,
Dialogue: 0,0:09:31.38,0:09:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu bertanya cara jadi populer\Ndi kalangan gadi—
Dialogue: 0,0:09:33.72,0:09:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar.
Dialogue: 0,0:09:34.64,0:09:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu kenapa, sih?
Dialogue: 0,0:09:36.31,0:09:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejam sekali!
Dialogue: 0,0:09:37.64,0:09:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini reuni saat senja, lo.\NHarusnya lebih dari itu.
Dialogue: 0,0:09:39.77,0:09:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, hal nostalgia\Natau kenangan indah, begitu?
Dialogue: 0,0:09:42.81,0:09:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa semuanya pada mengadu?
Dialogue: 0,0:09:44.69,0:09:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa minum kopi, kok.\NKalau pakai susu, itu gampang.
Dialogue: 0,0:09:47.53,0:09:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa main lompat tali.
Dialogue: 0,0:09:49.19,0:09:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah dianggap bisa.
Dialogue: 0,0:09:51.32,0:09:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama, si guru licik.\NJangan bercanda, dong.
Dialogue: 0,0:09:54.41,0:09:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, itu artinya...
Dialogue: 0,0:09:55.99,0:09:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:09:57.20,0:09:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapan untuk mengobrol.
Dialogue: 0,0:09:59.95,0:10:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya saat mengobrol di kelas sebelumnya,\Nrasanya kayak mengobrol searah.
Dialogue: 0,0:10:06.02,0:10:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ayo mengobrol.\NKeluarkan semuanya.
Dialogue: 0,0:10:09.76,0:10:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kamu punya banyak hal\Nyang ingin dikatakan.
Dialogue: 0,0:10:24.47,0:10:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak marah?
Dialogue: 0,0:10:28.38,0:10:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tiba-tiba keluar dari sekolah...
Dialogue: 0,0:10:31.03,0:10:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tiba-tiba menghilang tanpa\Nbilang apa-apa ke teman-teman...
Dialogue: 0,0:10:35.78,0:10:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kaget, sih.
Dialogue: 0,0:10:37.99,0:10:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kami lebih khawatir\Ndaripada marah.
Dialogue: 0,0:10:44.42,0:10:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya ingin mengobrol denganmu.
Dialogue: 0,0:10:46.38,0:10:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mengobrol\Nlebih banyak denganmu.
Dialogue: 0,0:10:51.63,0:10:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kamu main trompet?
Dialogue: 0,0:10:57.77,0:11:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, Ibu memberikanku trompet.
Dialogue: 0,0:11:00.89,0:11:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu bilang, saat ingin bicara,\Ntuangkan semuanya ke situ.
Dialogue: 0,0:11:05.18,0:11:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu sangat baik.
Dialogue: 0,0:11:06.69,0:11:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukai ibuku.
Dialogue: 0,0:11:08.94,0:11:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku juga menyukai ayahku.
Dialogue: 0,0:11:12.67,0:11:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Ayah keras kepala dan kaku,\Nbeliau peduli pada keluarganya.
Dialogue: 0,0:11:17.28,0:11:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau juga berharap padaku.
Dialogue: 0,0:11:20.11,0:11:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun sebenarnya berbakat\Ndalam bersembunyi.
Dialogue: 0,0:11:25.33,0:11:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahagia terlahir di keluarga Purson.
Dialogue: 0,0:11:29.88,0:11:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun bangga\Nuntuk melanjutkan tugas keluargaku.
Dialogue: 0,0:11:33.92,0:11:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:11:35.13,0:11:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju berpartisipasi\Ndi festival musik.
Dialogue: 0,0:11:38.01,0:11:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlatih dengan kalian\Nsangatlah menyenangkan.
Dialogue: 0,0:11:42.26,0:11:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku dipuji\Nkarena bermain trompet.
Dialogue: 0,0:11:48.15,0:11:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:11:50.81,0:11:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku disuruh pulang ke rumah.
Dialogue: 0,0:11:54.82,0:11:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tak tahu...
Dialogue: 0,0:11:56.99,0:11:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus berbuat apa.
Dialogue: 0,0:12:00.01,0:12:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:01.83,0:12:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bersama kalian,\Naku merasa sangat senang.
Dialogue: 0,0:12:05.25,0:12:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aturan keluargaku mutlak,\Nayahku pun jadi kerepotan.
Dialogue: 0,0:12:09.67,0:12:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku pasti juga khawatir.
Dialogue: 0,0:12:12.38,0:12:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku malah di sini...
Dialogue: 0,0:12:15.51,0:12:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:12:17.97,0:12:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:20.14,0:12:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:12:21.76,0:12:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dengar semua\Nyang ingin kamu katakan.
Dialogue: 0,0:12:29.46,0:12:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya akan kudengarkan.
Dialogue: 0,0:12:37.78,0:12:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama kali merasakan ini.
Dialogue: 0,0:12:40.53,0:12:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:41.73,0:12:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, aku ketakutan\Nkarena sosokku sudah ketahuan,
Dialogue: 0,0:12:46.04,0:12:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi semuanya sangat menyenangkan,\Nmendebarkan, dan terasa baru.
Dialogue: 0,0:12:51.08,0:12:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:51.83,0:12:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa kamu itu hebat dan ajaib.
Dialogue: 0,0:12:55.30,0:12:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu melihatmu sejak awal masuk,\Njadi aku tahu semuanya.
Dialogue: 0,0:12:58.34,0:13:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setelah mengobrol lama,\Nternyata kamu juga lucu dan aneh.
Dialogue: 0,0:13:02.89,0:13:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu memaksa dan egois, tahu.
Dialogue: 0,0:13:05.51,0:13:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan orang lain, dong.\NItu pemaksaan, tahu.
Dialogue: 0,0:13:09.14,0:13:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:13:10.23,0:13:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena selalu bermain terompet sendirian,\Naku tidak tahu sehebat apa kemampuanku.
Dialogue: 0,0:13:14.90,0:13:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lihai, kok.
Dialogue: 0,0:13:16.15,0:13:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mahir bermain piano.
Dialogue: 0,0:13:19.19,0:13:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berlatih dengan keras.
Dialogue: 0,0:13:20.57,0:13:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena aku latihan bersamamu.
Dialogue: 0,0:13:23.41,0:13:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hubunganmu\Ndengan Ketua OSIS?
Dialogue: 0,0:13:25.74,0:13:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pergi ke akuarium.
Dialogue: 0,0:13:27.70,0:13:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembang apinya sangat indah, ya.
Dialogue: 0,0:13:30.46,0:13:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:31.50,0:13:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejadian di Walter Park merepotkan, ya.
Dialogue: 0,0:13:33.88,0:13:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merepotkan sekali.
Dialogue: 0,0:13:52.49,0:13:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma, aku memang...
Dialogue: 0,0:13:55.81,0:13:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:57.98,0:14:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin ikut festival musik.
Dialogue: 0,0:14:00.62,0:14:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tak bisa melanggar janjiku\Ndengan keluargaku.
Dialogue: 0,0:14:04.38,0:14:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa memilih.
Dialogue: 0,0:14:07.95,0:14:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tak punya jawabannya.
Dialogue: 0,0:14:19.21,0:14:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham perasaanmu.
Dialogue: 0,0:14:24.72,0:14:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti betapa\Nsayangnya kamu pada keluargamu,
Dialogue: 0,0:14:27.47,0:14:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}betapa sulitnya bagimu\Nmembuat keputusan saat ini,
Dialogue: 0,0:14:31.81,0:14:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan betapa sulitnya ikut dalam\Nfestival musik bagimu.
Dialogue: 0,0:14:36.63,0:14:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, maaf.
Dialogue: 0,0:14:38.44,0:14:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang ingin kukatakan\Ntetap tidak berubah.
Dialogue: 0,0:14:43.49,0:14:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi,\Nkamu tetaplah orangnya.
Dialogue: 0,0:14:54.33,0:14:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama Purson Soi...
Dialogue: 0,0:14:57.67,0:15:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kita bertiga belas\Nnaik ke atas panggung.
Dialogue: 0,0:15:02.42,0:15:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa kalau bukan Soi.
Dialogue: 0,0:15:06.68,0:15:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami selalu menunggumu.
Dialogue: 0,0:15:38.63,0:15:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kicauan para burung.
Dialogue: 0,0:15:41.21,0:15:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langit biru yang cerah.
Dialogue: 0,0:15:44.05,0:15:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya matahari yang hangat dan...
Dialogue: 0,0:15:46.97,0:15:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan yang bergerak?
Dialogue: 0,0:15:49.93,0:15:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kencang sekali?
Dialogue: 0,0:15:51.72,0:15:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Opera?
Dialogue: 0,0:15:53.31,0:15:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Tuan Iruma.
Dialogue: 0,0:15:54.98,0:15:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:15:56.19,0:15:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas, kan?
Dialogue: 0,0:15:58.19,0:16:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda mengirim pesan kalau akan\Nmengobrol dengan teman.
Dialogue: 0,0:16:00.36,0:16:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena tidak pulang semalaman,\Nsaya menemukan Anda di atap.
Dialogue: 0,0:16:03.94,0:16:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, saya sedang membawa\NAnda pulang ke rumah.
Dialogue: 0,0:16:06.65,0:16:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maafkan aku.
Dialogue: 0,0:16:08.70,0:16:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini adalah hari besar,\Nhari festival musik.
Dialogue: 0,0:16:11.28,0:16:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda harus pulihkan kondisi Anda\Nsecepat mungkin.
Dialogue: 0,0:16:13.41,0:16:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara ini agak kasar,\Njadi persiapkan diri Anda.
Dialogue: 0,0:16:18.58,0:16:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma! Selamat datang kembali!
Dialogue: 0,0:16:22.09,0:16:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kepsek, tolong siapkan sarapan.
Dialogue: 0,0:16:23.75,0:16:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan ke kamar mandi.
Dialogue: 0,0:16:30.51,0:16:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sisir semuanya.\N- Sarapan, sarapan.
Dialogue: 0,0:16:34.63,0:16:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma, silakan.
Dialogue: 0,0:16:36.68,0:16:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ramuan khusus dari Balam.
Dialogue: 0,0:16:39.94,0:16:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah minum,\NAnda akan merasa agak lemas.
Dialogue: 0,0:16:42.15,0:16:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok seperti ada letupan?
Dialogue: 0,0:16:45.28,0:16:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong diminum.
Dialogue: 0,0:16:47.95,0:16:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kepsek, Anda juga harap bersiap.
Dialogue: 0,0:16:50.03,0:16:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bisa telat menyambut para juri, lo.
Dialogue: 0,0:17:02.21,0:17:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:17:04.33,0:17:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lewat sini.
Dialogue: 0,0:17:14.43,0:17:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga juri telah tiba!
Dialogue: 0,0:17:17.47,0:17:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka iblis kelas atas, kan?
Dialogue: 0,0:17:22.27,0:17:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Presiden dari "Devimuse",\Nperusahaan besar Idola Iblis.
Dialogue: 0,0:17:25.48,0:17:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kyupa!
Dialogue: 0,0:17:28.35,0:17:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiket konsernya selalu ludes!
Dialogue: 0,0:17:30.86,0:17:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquestra dari grup Dande!
Dialogue: 0,0:17:33.28,0:17:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Mei Mei dari ras Bertelinga Banyak.
Dialogue: 0,0:17:36.99,0:17:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantan anggota 13 Mahkota!\NMusisi legendaris eksklusif Tuan Delkira!
Dialogue: 0,0:17:41.87,0:17:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Amduscias!
Dialogue: 0,0:17:45.00,0:17:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya iblis terkenal semua.
Dialogue: 0,0:17:46.75,0:17:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hebat.\N- Benaran, dong.
Dialogue: 0,0:17:48.26,0:17:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Auranya hebat sekali!
Dialogue: 0,0:17:50.01,0:17:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama Tuan Amduscias,\Nmantan anggota 13 Mahkota!
Dialogue: 0,0:17:52.80,0:17:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musisi legendaris yang menjelajahi dunia.
Dialogue: 0,0:17:56.10,0:17:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai bisa memanggil beliau...
Dialogue: 0,0:17:57.43,0:17:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kepala Sekolah Sullivan memang hebat!
Dialogue: 0,0:17:59.22,0:18:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria yang paling mungkin jadi Raja Iblis!
Dialogue: 0,0:18:02.02,0:18:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:18:03.27,0:18:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berharap ada penampilan musik\Nyang menarik tahun ini, ya.
Dialogue: 0,0:18:08.82,0:18:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun mencari\NIdola Iblis nan berbakat.
Dialogue: 0,0:18:13.28,0:18:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun lalu, penampilan\NRonove luar biasa, ya.
Dialogue: 0,0:18:17.78,0:18:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun ini juga luar biasa, lo!
Dialogue: 0,0:18:19.66,0:18:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak iblis muda yang berbakat...
Dialogue: 0,0:18:22.65,0:18:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Tuan Amduscias.
Dialogue: 0,0:18:24.92,0:18:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan duduk.
Dialogue: 0,0:18:28.13,0:18:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Amduscias?
Dialogue: 0,0:18:31.55,0:18:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sully!
Dialogue: 0,0:18:34.80,0:18:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kamu? Cepat keluar!
Dialogue: 0,0:18:38.06,0:18:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada apa?\N- Sully!
Dialogue: 0,0:18:39.43,0:18:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah mulai, ya.\N- Sully!
Dialogue: 0,0:18:41.31,0:18:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia punya dendam kuat\Npada Sullivan, sih, ya.
Dialogue: 0,0:18:45.06,0:18:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Amduscias,\Napa yang Anda lakukan?
Dialogue: 0,0:18:47.65,0:18:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil aku Poro!
Dialogue: 0,0:18:49.57,0:18:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang kesal saat ini!
Dialogue: 0,0:18:52.07,0:18:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak peduli dengan festival musik!
Dialogue: 0,0:18:54.99,0:18:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, mantan anggota 13 Mahkota,\NAmduscias Poro,
Dialogue: 0,0:18:58.03,0:19:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}datang untuk menghajar\Nsi Sullivan bodoh itu!
Dialogue: 0,0:19:03.21,0:19:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:19:09.09,0:19:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih saja berisik, ya, Poro.
Dialogue: 0,0:19:13.84,0:19:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang juga kamu, Sull—
Dialogue: 0,0:19:18.47,0:19:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian macam apa itu?
Dialogue: 0,0:19:20.81,0:19:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadi buru-buru.
Dialogue: 0,0:19:22.72,0:19:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cucuku ikut festival musik,\Njadi aku membuatkannya sarapan.
Dialogue: 0,0:19:26.44,0:19:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, begitu rupanya.\NJadi tidak sabar, ya.
Dialogue: 0,0:19:29.61,0:19:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, ada banyak\Nyang ingin kukatakan padamu.
Dialogue: 0,0:19:34.82,0:19:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cucu?
Dialogue: 0,0:19:35.86,0:19:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu! Sebentar!\NApa maksudnya cucu?
Dialogue: 0,0:19:38.95,0:19:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak menikah, kan?
Dialogue: 0,0:19:41.24,0:19:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?
Dialogue: 0,0:19:43.54,0:19:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pakai trik rahasia untuk itu.
Dialogue: 0,0:19:47.29,0:19:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:19:50.13,0:19:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan anak Tuan Delkira, kan?
Dialogue: 0,0:19:52.63,0:19:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin!
Dialogue: 0,0:19:53.84,0:19:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan hal yang mustahil bagimu!
Dialogue: 0,0:19:56.05,0:20:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap aku mencoba mendekati beliau,\Nkamu selalu menempel padanya!
Dialogue: 0,0:20:02.06,0:20:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan banget, tahu!
Dialogue: 0,0:20:05.31,0:20:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Del milikku!\NPadahal Del adalah milikku!
Dialogue: 0,0:20:09.40,0:20:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak pernah melirik\Nsecantik apa pun wanita itu,
Dialogue: 0,0:20:12.90,0:20:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya kupikir ada yang aneh!
Dialogue: 0,0:20:14.90,0:20:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia sudah punya wanita, toh!
Dialogue: 0,0:20:16.90,0:20:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Tuan Delkira!
Dialogue: 0,0:20:18.53,0:20:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Orang ini benar-benar berisik, ya.\N- Tapi, bukan masalah! Aku masih mencintaimu!
Dialogue: 0,0:20:20.95,0:20:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mood-nya cepat berubah.\N- Aku masih mencintaimu!
Dialogue: 0,0:20:23.87,0:20:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sangat berbeda dari bayanganku.\N- Tetap mencintaimu!
Dialogue: 0,0:20:26.16,0:20:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bicara soal Tuan Amduscias,
Dialogue: 0,0:20:29.33,0:20:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentu tentang resital legenda masa lalunya!
Dialogue: 0,0:20:31.42,0:20:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau mampu menahan pasukan musuh\Nselama 666 jam hanya dengan musiknya!
Dialogue: 0,0:20:35.80,0:20:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Iblis Musik legendaris!
Dialogue: 0,0:20:40.18,0:20:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar!
Dialogue: 0,0:20:41.26,0:20:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hal yang mudah kalau bersama Del!
Dialogue: 0,0:20:43.60,0:20:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan diingatkan lagi!
Dialogue: 0,0:20:45.98,0:20:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya Tuan Delkira\Nyang boleh mendengar musikku.
Dialogue: 0,0:20:50.19,0:20:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua musikku tercipta karena beliau.
Dialogue: 0,0:20:54.98,0:20:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah kenapa aku datang menemuimu.
Dialogue: 0,0:21:01.70,0:21:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu membuka Royal One?
Dialogue: 0,0:21:05.81,0:21:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung dari jawabanmu,
Dialogue: 0,0:21:08.91,0:21:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mungkin akan membunuhmu.
Dialogue: 0,0:21:11.92,0:21:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, orang bodoh mana\Nyang menggunakan ruangan itu?
Dialogue: 0,0:21:14.50,0:21:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat keluarkan!
Dialogue: 0,0:21:15.42,0:21:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas abnormal.
Dialogue: 0,0:21:19.01,0:21:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelasku.
Dialogue: 0,0:21:20.84,0:21:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan Iruma sebagai ketuanya,
Dialogue: 0,0:21:22.97,0:21:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kelas abnormal memang berisi\Nmurid-murid yang berisik.
Dialogue: 0,0:21:25.35,0:21:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka mendapatkan Royal One\Ndengan prosedur yang semestinya.
Dialogue: 0,0:21:30.23,0:21:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Kalego!
Dialogue: 0,0:21:32.90,0:21:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kamu masih saja imut!
Dialogue: 0,0:21:37.03,0:21:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma pria muda!
Dialogue: 0,0:21:39.07,0:21:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hentikan!
Dialogue: 0,0:21:40.70,0:21:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Poro masih saja menyukainya, ya.\N- Lepaskan aku! Lepaskan aku!
Dialogue: 0,0:21:43.87,0:21:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, Kalego.\NBerkorba— Tolong urus dia.
Dialogue: 0,0:21:47.79,0:21:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kepala sekolah bodoh!
Dialogue: 0,0:21:49.96,0:21:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kelas abnormal, ya?\NKasih tahu, dong.
Dialogue: 0,0:21:53.42,0:21:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi wali kelasnya?
Dialogue: 0,0:21:55.13,0:21:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:56.46,0:21:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa Iruma?
Dialogue: 0,0:21:59.71,0:22:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma itu cucu Pak Kepala Sullivan.
Dialogue: 0,0:22:02.38,0:22:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:05.64,0:22:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dialah orang yang membuka Royal One.
Dialogue: 0,0:22:14.35,0:22:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma, ya?
Dialogue: 0,0:22:18.32,0:22:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empuk, empuk~
Dialogue: 0,0:22:21.44,0:22:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupu-kupu.
Dialogue: 0,0:22:23.36,0:22:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan yang benar, ya.
Dialogue: 0,0:22:27.74,0:22:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obatnya terlalu kuat, ya?
Dialogue: 0,0:22:31.79,0:22:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima jam lagi sebelum penampilan.
Dialogue: 0,0:24:05.51,0:24:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan seru yang disukai semuanya!
Dialogue: 0,0:24:09.39,0:24:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari mundur sejenak,\Ntepat di ruang olahraga Royal One.
Dialogue: 0,0:24:13.97,0:24:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antara kecemasan akan\Nfestival musik dan kecantikanku,
Dialogue: 0,0:24:18.06,0:24:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manakah yang lebih kuat?
Dialogue: 0,0:24:19.98,0:24:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecantikan Mbak!
Dialogue: 0,0:24:23.19,0:24:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, saat itu, Purson Soi...
Dialogue: 0,0:24:25.40,0:24:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecantikan Mbak!
Dialogue: 0,0:24:27.07,0:24:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- juga ikut serta.\N- Terima kasih.
Dialogue: 0,0:24:30.74,0:24:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, akhirnya festival musik dimulai!
Dialogue: 0,0:24:33.37,0:24:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bagaimana ini?
Dialogue: 0,0:24:36.75,0:24:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku yang gugup?
Dialogue: 0,0:24:39.17,0:24:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, ini festival musik\Npertamanya Iruma, lo.
Dialogue: 0,0:24:41.79,0:24:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan bermain piano, lo!
Dialogue: 0,0:24:43.17,0:24:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamera barunya sudah siap?\NKamera video juga!
Dialogue: 0,0:24:46.58,0:24:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:48.17,0:24:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Hari Festival Musik!"
Dialogue: 0,0:24:49.76,0:24:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan berkedip dan mengabadikan\Nsetiap momen heroik Iruma!
