Dialogue: 0,0:00:01.04,0:00:02.46,Default,,0,0,0,,Devirum.
Dialogue: 0,0:00:02.46,0:00:07.51,Default,,0,0,0,,Itu adalah pertemuan rutin\Npara iblis bangsawan.
Dialogue: 0,0:00:08.24,0:00:10.49,Default,,0,0,0,,Di antara Devirum itu,
Dialogue: 0,0:00:10.49,0:00:14.72,Default,,0,0,0,,ada pertemuan yang hanya boleh\Ndihadiri oleh iblis kelas atas.
Dialogue: 0,0:00:14.72,0:00:16.75,Default,,0,0,0,,Itu disebut Deviculum.
Dialogue: 0,0:00:20.00,0:00:21.96,Default,,0,0,0,,Benar begitu.
Dialogue: 0,0:00:21.96,0:00:23.92,Default,,0,0,0,,Kau jago, Ameri.
Dialogue: 0,0:00:24.73,0:00:27.47,Default,,0,0,0,,Devirum yang kemarin asik, ya.
Dialogue: 0,0:00:27.47,0:00:28.93,Default,,0,0,0,,Mau ikut lagi?
Dialogue: 0,0:00:28.93,0:00:29.88,Default,,0,0,0,,Iya!
Dialogue: 0,0:00:29.88,0:00:34.06,Default,,0,0,0,,Tapi, Ayah, aku juga\Npengin ikut Deviculum!
Dialogue: 0,0:00:34.06,0:00:36.95,Default,,0,0,0,,Kalau kelak peringkatku naik,\Nmaukah Ayah mengajakku ke sana?
Dialogue: 0,0:00:36.95,0:00:38.18,Default,,0,0,0,,Tentu saja.
Dialogue: 0,0:00:38.18,0:00:41.31,Default,,0,0,0,,Hore! Hore!\NAku akan berjuang!
Dialogue: 0,0:00:41.57,0:00:43.48,Default,,0,0,0,,Kalau Ameri pergi ke Deviculum,
Dialogue: 0,0:00:43.48,0:00:48.57,Default,,0,0,0,,pasti kau akan diajak\Nberdansa dengan banyak iblis.
Dialogue: 0,0:00:48.57,0:00:50.07,Default,,0,0,0,,Anu, Ayah.
Dialogue: 0,0:00:50.55,0:00:55.27,Default,,0,0,0,,Saat pertama kali berdansa,\Naku pasti akan berdansa dengan Ayah.
Dialogue: 0,0:00:57.55,0:00:59.19,Default,,0,0,0,,Ameri!
Dialogue: 0,0:00:59.81,0:01:02.15,Default,,0,0,0,,Ada apa, Ayah?
Dialogue: 0,0:01:02.64,0:01:04.42,Default,,0,0,0,,Tidak apa.
Dialogue: 0,0:01:04.42,0:01:08.09,Default,,0,0,0,,Aku menantikan hari\Nkita bisa ke Deviculum bersama.
Dialogue: 0,0:01:08.77,0:01:11.66,Default,,0,0,0,,Putriku tersayang, Ameri.
Dialogue: 0,0:01:15.99,0:01:17.29,Default,,0,0,0,,Ameri...
Dialogue: 0,0:01:18.10,0:01:21.75,Default,,0,0,0,,Akhirnya aku dapat undangan\Nuntuk ikut Deviculum.
Dialogue: 0,0:01:22.08,0:01:25.63,Default,,0,0,0,,Aku bisa membayangkan wajah bahagiamu!
Dialogue: 0,0:01:33.53,0:01:37.62,Default,,0,0,0,,Iruma dkk dari kelas abnormal\Nberhasil memenangkan festival musik.
Dialogue: 0,0:01:37.62,0:01:43.42,Default,,0,0,0,,Semuanya berhasil naik ke peringkat Daleth\Ndan menyelesaikan tugas mereka.
Dialogue: 0,0:01:43.42,0:01:47.50,Default,,0,0,0,,Mereka pun bisa tetap\Nmenggunakan Kelas Raja, Royal One.
Dialogue: 0,0:01:48.00,0:01:51.38,Default,,0,0,0,,Acara untuk murid kelas satu\Ntelah selesai semua.
Dialogue: 0,0:01:51.38,0:01:57.01,Default,,0,0,0,,Akankah Iruma dkk dapat menikmati kehidupan\Nsekolah yang tenang untuk sementara?
Dialogue: 0,0:02:01.73,0:02:03.60,Default,,0,0,0,,Bangkit! Bangkit! Bangkit! Bangkit!♪
Dialogue: 0,0:02:03.60,0:02:05.48,Default,,0,0,0,,Mari buat keributan\Ndan egois hingga fajar♪
Dialogue: 0,0:02:12.78,0:02:14.57,Default,,0,0,0,,Murid berprestasi,\Nkau tahu maksudku?♪
Dialogue: 0,0:02:14.57,0:02:17.12,Default,,0,0,0,,Kutak tahu apa-apa sejak awal♪
Dialogue: 0,0:02:17.12,0:02:20.49,Default,,0,0,0,,Abaikan saja perdamaian dan keadilan♪
Dialogue: 0,0:02:21.04,0:02:22.62,Default,,0,0,0,,Ah, lelah rasanya♪
Dialogue: 0,0:02:22.62,0:02:24.96,Default,,0,0,0,,Saat ingin menangis,♪
Dialogue: 0,0:02:24.96,0:02:27.08,Default,,0,0,0,,tujulah panggung nan megah♪
Dialogue: 0,0:02:27.08,0:02:28.92,Default,,0,0,0,,Bangkit! Bangkit! Bangkit! Bangkit!♪
Dialogue: 0,0:02:28.92,0:02:29.88,Default,,0,0,0,,Egois hingga akhir♪
Dialogue: 0,0:02:29.88,0:02:33.72,Default,,0,0,0,,Deru seketika jadi anggun♪
Dialogue: 0,0:02:33.72,0:02:38.47,Default,,0,0,0,,Saat menggenggam tangan itu,\Nsemuanya dimulai♪
Dialogue: 0,0:02:38.47,0:02:40.43,Default,,0,0,0,,Kala lampu menyala lagi,\Nmahatahu dan mahakuasa♪
Dialogue: 0,0:02:40.43,0:02:41.97,Default,,0,0,0,,akan buat keributan♪
Dialogue: 0,0:02:41.97,0:02:45.52,Default,,0,0,0,,Jadi ayo kita meriahkan♪
Dialogue: 0,0:02:47.31,0:02:48.31,Default,,0,0,0,,Tiketnya habis ludes♪
Dialogue: 0,0:02:48.31,0:02:51.78,Default,,0,0,0,,Pestanya dimulai dalam\Nhitungan satu, dua, dan tiga♪
Dialogue: 0,0:02:51.78,0:02:53.94,Default,,0,0,0,,Mari berkumpul dan bersorak meriah♪
Dialogue: 0,0:02:53.94,0:02:55.95,Default,,0,0,0,,(Semua! Semua! Semuanya!♪)
Dialogue: 0,0:02:55.95,0:02:59.58,Default,,0,0,0,,Dua, tiga, empat!\NMari bermimpi bersama, Sayang♪
Dialogue: 0,0:02:59.83,0:03:01.74,Default,,0,0,0,,Buang jauh-jauh rasa khawatir itu♪
Dialogue: 0,0:03:01.74,0:03:05.92,Default,,0,0,0,,(Semua! Semua! Semuanya!♪)
Dialogue: 0,0:03:06.79,0:03:09.96,Default,,0,0,0,,(Semuanya!♪)
Dialogue: 0,0:03:10.71,0:03:15.72,Default,,0,0,0,,(Semuanya!♪)
Dialogue: 0,0:03:15.72,0:03:19.51,Default,,0,0,0,,Pestanya dimulai dalam\Nhitungan satu, dua, dan tiga♪
Dialogue: 0,0:03:27.50,0:03:30.21,Default,,0,0,0,,"Selisih Satu Tahun dan Satu Senti".
Dialogue: 0,0:03:32.04,0:03:33.48,Default,,0,0,0,,Hei, Iruma.
Dialogue: 0,0:03:34.50,0:03:37.24,Default,,0,0,0,,Soal yang aku bicarakan\Ntempo hari itu, lo.
Dialogue: 0,0:03:37.59,0:03:41.37,Default,,0,0,0,,Teman adalah mereka yang akrab.
Dialogue: 0,0:03:41.37,0:03:44.91,Default,,0,0,0,,Makan bersama, main bersama,\Nrasanya senang bersama dengannya.
Dialogue: 0,0:03:44.91,0:03:48.58,Default,,0,0,0,,Mereka adalah sosok yang berharga.
Dialogue: 0,0:03:48.58,0:03:52.13,Default,,0,0,0,,Yang peringkatnya lebih tinggi\Njuga bisa jadi teman?
Dialogue: 0,0:03:52.13,0:03:54.38,Default,,0,0,0,,Iya. Menurutku peringkat\Ntidak ada hubungannya.
Dialogue: 0,0:03:54.38,0:03:57.81,Default,,0,0,0,,Kalau begitu, bagimu,\Nbagaimana dengan dia?
Dialogue: 0,0:03:57.93,0:03:58.84,Default,,0,0,0,,Siapa?
Dialogue: 0,0:03:59.53,0:04:01.85,Default,,0,0,0,,Ketua pengurus OSIS, Azazel Ameri.
Dialogue: 0,0:04:03.41,0:04:06.64,Default,,0,0,0,,Bagiku, Kak Ameri itu...
Dialogue: 0,0:04:06.64,0:04:08.85,Default,,0,0,0,,Oh, baru juga dibahas.
Dialogue: 0,0:04:09.87,0:04:11.36,Default,,0,0,0,,Ketua!
Dialogue: 0,0:04:13.46,0:04:16.05,Default,,0,0,0,,Kamu!\NPitamu miring, tuh.
Dialogue: 0,0:04:16.36,0:04:17.38,Default,,0,0,0,,Kamu!
Dialogue: 0,0:04:17.38,0:04:18.95,Default,,0,0,0,,Dilarang terbang di wilayah sekolah.
Dialogue: 0,0:04:18.95,0:04:20.18,Default,,0,0,0,,Baik!
Dialogue: 0,0:04:20.49,0:04:24.24,Default,,0,0,0,,Ketua, saya ingin mewawancaraimu\Nuntuk batra penyiaran lain waktu.
Dialogue: 0,0:04:24.64,0:04:27.96,Default,,0,0,0,,Baiklah.\NTolong atur jadwalnya.
Dialogue: 0,0:04:27.96,0:04:30.25,Default,,0,0,0,,Siap, Bu!\NAkan segera aku atur.
Dialogue: 0,0:04:30.93,0:04:33.09,Default,,0,0,0,,Cantik banget, ya.
Dialogue: 0,0:04:33.09,0:04:35.75,Default,,0,0,0,,Hah? Jelas, dong.\NDia itu ketua pengurus OSIS, lo.
Dialogue: 0,0:04:35.75,0:04:40.43,Default,,0,0,0,,Yah, dulunya dia berasa\Nterpelajar tapi berdarah dingin,
Dialogue: 0,0:04:40.43,0:04:42.76,Default,,0,0,0,,tapi sekarang tampak\Nkayak bersinar.
Dialogue: 0,0:04:42.76,0:04:45.14,Default,,0,0,0,,Ah, aku mengerti.
Dialogue: 0,0:04:45.14,0:04:48.14,Default,,0,0,0,,Itu, lo. Sejak duel seleksi\Npembubaran waktu itu.
Dialogue: 0,0:04:50.74,0:04:54.44,Default,,0,0,0,,Dia memang berbeda dari iblis biasa, ya.
Dialogue: 0,0:04:54.44,0:04:56.94,Default,,0,0,0,,Berasa beda dunia dengan kita.
Dialogue: 0,0:04:56.94,0:05:00.10,Default,,0,0,0,,Benar-benar sosok iblis elit penyendiri.
Dialogue: 0,0:05:03.59,0:05:04.91,Default,,0,0,0,,Ayo pulang.
Dialogue: 0,0:05:04.91,0:05:06.29,Default,,0,0,0,,Sampai besok!
Dialogue: 0,0:05:09.29,0:05:12.54,Default,,0,0,0,,Ketua, ini dokumen tambahan\Nbeserta jadwalnya.
Dialogue: 0,0:05:12.54,0:05:13.71,Default,,0,0,0,,Baik.
Dialogue: 0,0:05:13.71,0:05:17.46,Default,,0,0,0,,Kegiatan tahunan sudah mereda\Ndan akhirnya tiba akhir tahun ajaran.
Dialogue: 0,0:05:17.46,0:05:20.34,Default,,0,0,0,,Rapat pun makin banyak,\Nkita bakal makin sibuk, ya.
Dialogue: 0,0:05:20.34,0:05:21.51,Default,,0,0,0,,Kamu benar.
Dialogue: 0,0:05:21.51,0:05:24.76,Default,,0,0,0,,Tapi, ingin rasanya istirahat\Ndi suatu tempat, ya.
Dialogue: 0,0:05:24.76,0:05:27.00,Default,,0,0,0,,Misalnya buat minum teh\Ndan baca buku.
Dialogue: 0,0:05:28.70,0:05:30.14,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:05:30.14,0:05:31.69,Default,,0,0,0,,Tidak, tidak apa.
Dialogue: 0,0:05:31.69,0:05:35.02,Default,,0,0,0,,Aku masih ada kerjaan,\Njadi kamu boleh pulang duluan.
Dialogue: 0,0:05:35.02,0:05:36.07,Default,,0,0,0,,Siap, Bu!
Dialogue: 0,0:05:36.07,0:05:37.52,Default,,0,0,0,,Kalau begitu, aku permisi.
Dialogue: 0,0:05:37.52,0:05:38.59,Default,,0,0,0,,Ya.
Dialogue: 0,0:05:47.30,0:05:50.50,Default,,0,0,0,,Untuk Kak Ameri,\Nperihal sesi membaca.
Dialogue: 0,0:06:06.01,0:06:09.52,Default,,0,0,0,,Akhirnya sesi membaca dengan\NIruma yang telah lama kunanti.
Dialogue: 0,0:06:09.87,0:06:11.02,Default,,0,0,0,,Pekerjaan, beres!
Dialogue: 0,0:06:11.27,0:06:12.64,Default,,0,0,0,,Camilan, siap!
Dialogue: 0,0:06:12.99,0:06:14.40,Default,,0,0,0,,Buku terlarang, siap!
Dialogue: 0,0:06:14.40,0:06:16.19,Default,,0,0,0,,Persiapannya sudah sempurna!
Dialogue: 0,0:06:16.19,0:06:20.47,Default,,0,0,0,,Habisnya, aku dan Iruma sama-sama sibuk\Ndan tidak sempat bertemu.
Dialogue: 0,0:06:20.88,0:06:22.07,Default,,0,0,0,,Iruma sibuk...
Dialogue: 0,0:06:22.88,0:06:26.29,Default,,0,0,0,,Perayaan setelah latihan festival musik.
Dialogue: 0,0:06:26.29,0:06:28.08,Default,,0,0,0,,Aku juga sibuk...
Dialogue: 0,0:06:29.68,0:06:32.27,Default,,0,0,0,,Kegiatan akhir tahun pengurus OSIS.
Dialogue: 0,0:06:34.35,0:06:38.46,Default,,0,0,0,,Akhirnya ada waktu seharian kosong!\NIni luar biasa!
Dialogue: 0,0:06:39.69,0:06:45.30,Default,,0,0,0,,Tapi, beraninya Iruma menolak ajakanku\Ndan berpesta dengan teman kelasnya.
Dialogue: 0,0:06:45.30,0:06:47.87,Default,,0,0,0,,Begini-begini, aku ketua pengurus OSIS, tahu.
Dialogue: 0,0:06:52.62,0:06:56.44,Default,,0,0,0,,Penampilan kelas abnormal memang...
Dialogue: 0,0:06:57.33,0:06:59.09,Default,,0,0,0,,sangat luar biasa.
Dialogue: 0,0:06:59.67,0:07:02.48,Default,,0,0,0,,Sungguh memukau dan indah.
Dialogue: 0,0:07:03.75,0:07:04.99,Default,,0,0,0,,Dan juga...
Dialogue: 0,0:07:05.30,0:07:09.18,Default,,0,0,0,,Mereka semua tampak bersenang-senang.
Dialogue: 0,0:07:14.50,0:07:18.17,Default,,0,0,0,,Aku juga akrab dengan Iruma.
Dialogue: 0,0:07:18.17,0:07:20.84,Default,,0,0,0,,Kami pernah kerja bareng.
Dialogue: 0,0:07:20.84,0:07:25.17,Default,,0,0,0,,Ba-Ba-Bahkan pernah kencan bareng.
Dialogue: 0,0:07:25.17,0:07:27.01,Default,,0,0,0,,Selain itu...
Dialogue: 0,0:07:27.44,0:07:29.58,Default,,0,0,0,,Dunia ini sudah hancur...
Dialogue: 0,0:07:29.99,0:07:31.08,Default,,0,0,0,,Eh?!
Dialogue: 0,0:07:32.56,0:07:35.23,Default,,0,0,0,,Apa katamu?\NTerus, terus?
Dialogue: 0,0:07:36.29,0:07:38.06,Default,,0,0,0,,Terus...
Dialogue: 0,0:07:38.95,0:07:42.76,Default,,0,0,0,,Hanya pada saat itulah\NIruma jadi milikku seorang.
Dialogue: 0,0:07:43.04,0:07:46.57,Default,,0,0,0,,Benar-benar sosok iblis elit penyendiri.
Dialogue: 0,0:07:46.57,0:07:51.56,Default,,0,0,0,,Hanya pada saat itulah\Naku bukan sosok iblis elit,
Dialogue: 0,0:07:52.08,0:07:54.58,Default,,0,0,0,,Mohon bantuannya untuk besok.
Dialogue: 0,0:07:55.30,0:07:57.31,Default,,0,0,0,,tapi hanya Ameri.
Dialogue: 0,0:07:58.27,0:08:00.65,Default,,0,0,0,,Mari bicarakan banyak hal.
Dialogue: 0,0:08:00.81,0:08:03.92,Default,,0,0,0,,Setelah merayakan kemenangannya\Ndi festival musik.
Dialogue: 0,0:08:03.92,0:08:06.99,Default,,0,0,0,,Kami saling akan bicarakan\Napa saja yang telah kami lewati.
Dialogue: 0,0:08:07.32,0:08:10.37,Default,,0,0,0,,Dan besok... Besok...
Dialogue: 0,0:08:19.73,0:08:21.34,Default,,0,0,0,,Besok?
Dialogue: 0,0:08:22.25,0:08:26.49,Default,,0,0,0,,Syukurlah, Ameri.\NIni Deviculum pertamamu.
Dialogue: 0,0:08:26.49,0:08:28.40,Default,,0,0,0,,I-Iya.
Dialogue: 0,0:08:28.40,0:08:32.14,Default,,0,0,0,,Tapi, anu, aku ada janji besok.
Dialogue: 0,0:08:32.49,0:08:33.85,Default,,0,0,0,,Ameri.
Dialogue: 0,0:08:34.26,0:08:38.73,Default,,0,0,0,,Seperti yang kau tahu,\NDeviculum berbeda dari Devirum.
Dialogue: 0,0:08:39.01,0:08:44.25,Default,,0,0,0,,Itu bukan pertemuan bangsawan biasa,\Nmelainkan pertemuan khusus iblis kelas atas.
Dialogue: 0,0:08:44.25,0:08:45.82,Default,,0,0,0,,Ini kesempatan berharga.
Dialogue: 0,0:08:46.44,0:08:49.84,Default,,0,0,0,,Karena kau akan membantu\Npekerjaan Ayah di masa depan,
Dialogue: 0,0:08:49.84,0:08:51.79,Default,,0,0,0,,jadi ini pertemuan yang penting.
Dialogue: 0,0:08:52.07,0:08:55.26,Default,,0,0,0,,Apa ambisimu terlalu rendah\Ndan mudah digapai...
Dialogue: 0,0:08:55.26,0:08:59.08,Default,,0,0,0,,sampai kau mau\Nmelewatkan kesempatan ini?
Dialogue: 0,0:09:02.77,0:09:05.13,Default,,0,0,0,,Tidak, maafkan aku.
Dialogue: 0,0:09:05.42,0:09:08.47,Default,,0,0,0,,Besok, aku akan ikut serta\Ndalam Deviculum.
Dialogue: 0,0:09:20.79,0:09:24.88,Default,,0,0,0,,Maaf, aku tiba-tiba ada urusan besok.
Dialogue: 0,0:09:24.88,0:09:26.21,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:09:26.21,0:09:27.80,Default,,0,0,0,,Kalau begitu, di lain kesempatan saja.
Dialogue: 0,0:09:29.77,0:09:31.74,Default,,0,0,0,,Tinggal satu tahun lagi.
Dialogue: 0,0:09:43.25,0:09:44.81,Default,,0,0,0,,Kak Ameri!
Dialogue: 0,0:09:45.54,0:09:47.98,Default,,0,0,0,,Andai saja kita punya satu tahun lagi...
Dialogue: 0,0:09:47.98,0:09:52.18,Default,,0,0,0,,Entah kamu yang masuk duluan\Natau aku yang telat masuk...
Dialogue: 0,0:09:53.05,0:09:58.52,Default,,0,0,0,,Apa aku bisa lebih dekat denganmu\Ndengan lebih natural?
Dialogue: 0,0:10:02.83,0:10:04.48,Default,,0,0,0,,Itu...
Dialogue: 0,0:10:04.89,0:10:07.11,Default,,0,0,0,,khayalan yang konyol.
Dialogue: 0,0:10:08.94,0:10:12.45,Default,,0,0,0,,Aku ingin bertemu denganmu, Iruma.
Dialogue: 0,0:10:17.26,0:10:19.85,Default,,0,0,0,,Ingatan Cinta Pertama, bab Feniks.
Dialogue: 0,0:10:19.85,0:10:22.27,Default,,0,0,0,,Aku dan kamu yang ingin terbang\Nke luar angkasa, aroma—
Dialogue: 0,0:10:24.27,0:10:26.00,Default,,0,0,0,,Aku ingin bertemu Rin.
Dialogue: 0,0:10:26.16,0:10:30.53,Default,,0,0,0,,Tapi Rin terlempar\Nke 1 juta tahun yang lalu.
Dialogue: 0,0:10:30.53,0:10:33.03,Default,,0,0,0,,Kakeru... Aku ingin ketemu.
Dialogue: 0,0:10:33.03,0:10:37.38,Default,,0,0,0,,Tapi aku dan Kakeru terpisah\Ndi ujung ruang dan waktu.
Dialogue: 0,0:10:37.53,0:10:39.56,Default,,0,0,0,,Apa kami tak akan bisa bertemu lagi?
Dialogue: 0,0:10:42.08,0:10:43.04,Default,,0,0,0,,Rin...
Dialogue: 0,0:10:43.25,0:10:44.94,Default,,0,0,0,,Kami tak bisa bertemu lagi?
Dialogue: 0,0:10:45.42,0:10:47.31,Default,,0,0,0,,Kakeru...
Dialogue: 0,0:10:47.31,0:10:49.03,Default,,0,0,0,,- Aku ingin bertemu denganmu.\N- Aku ingin bertemu denganmu.
Dialogue: 0,0:11:16.15,0:11:17.72,Default,,0,0,0,,Nona Ameri.
Dialogue: 0,0:11:19.03,0:11:21.05,Default,,0,0,0,,Aku sudah dengar banyak tentangmu.
Dialogue: 0,0:11:21.05,0:11:24.12,Default,,0,0,0,,Ayahmu sudah banyak membantuku.
Dialogue: 0,0:11:24.12,0:11:28.42,Default,,0,0,0,,Aku juga berterima kasih\Nkarena telah banyak membantu Ayah.
Dialogue: 0,0:11:28.42,0:11:32.59,Default,,0,0,0,,Aku telah lama menjalin hubungan\Ndengan keluarga Azazel.
Dialogue: 0,0:11:32.59,0:11:35.09,Default,,0,0,0,,Aku harap tetap dapat melanjutkannya.
Dialogue: 0,0:11:35.09,0:11:36.93,Default,,0,0,0,,Ya. Kami juga.
Dialogue: 0,0:11:36.93,0:11:42.01,Default,,0,0,0,,Omong-omong, kau jadi makin cantik\Nsejak terakhir kali kita bertemu.
Dialogue: 0,0:11:42.01,0:11:43.58,Default,,0,0,0,,Tidak, itu berlebihan.
Dialogue: 0,0:11:45.81,0:11:48.31,Default,,0,0,0,,Apalagi kau peringkat Vav\Ndi umur semuda ini.
Dialogue: 0,0:11:48.31,0:11:51.27,Default,,0,0,0,,Lalu, kau juga ketua pengurus OSIS di Babyls.
Dialogue: 0,0:11:51.27,0:11:55.82,Default,,0,0,0,,Sungguh mengejutkan\Nsampai membuatku merinding.
Dialogue: 0,0:11:55.82,0:11:56.82,Default,,0,0,0,,Tidak juga, kok.
Dialogue: 0,0:11:56.82,0:11:59.32,Default,,0,0,0,,Jadi, kau akan lanjut masuk\NKepolisian Iblis?
Dialogue: 0,0:11:59.32,0:12:03.58,Default,,0,0,0,,Ya, itu tujuanku.\NAku ingin membantu pekerjaan Ayahku.
Dialogue: 0,0:12:03.58,0:12:06.46,Default,,0,0,0,,Ayahmu pasti sangat bangga.
Dialogue: 0,0:12:06.46,0:12:09.71,Default,,0,0,0,,Aku akan berusaha keras\Nuntuk memenuhi harapannya.
Dialogue: 0,0:12:18.72,0:12:23.66,Default,,0,0,0,,Karena isinya iblis kelas atas semua,\Nsuasananya jadi tegang.
Dialogue: 0,0:12:23.86,0:12:26.98,Default,,0,0,0,,Tapi aku harus menyapa semuanya\Ndengan sopan.
Dialogue: 0,0:12:26.98,0:12:29.23,Default,,0,0,0,,Itulah kewajibanku.
Dialogue: 0,0:12:30.79,0:12:32.67,Default,,0,0,0,,Berdansa, ya?
Dialogue: 0,0:12:33.12,0:12:35.09,Default,,0,0,0,,Kalau aku harus berdansa,
Dialogue: 0,0:12:35.42,0:12:37.24,Default,,0,0,0,,untuk yang pertama kali,
Dialogue: 0,0:12:38.84,0:12:40.72,Default,,0,0,0,,aku ingin bersama orang yang kusuka.
Dialogue: 0,0:12:43.93,0:12:45.14,Default,,0,0,0,,Anu...
Dialogue: 0,0:12:45.66,0:12:49.92,Default,,0,0,0,,Kau Nona Ameri, 'kan?\NPutri dari keluarga Azazel?
Dialogue: 0,0:12:50.97,0:12:53.67,Default,,0,0,0,,Kau semenawan yang dirumorkan.
Dialogue: 0,0:12:53.67,0:12:55.95,Default,,0,0,0,,Tidak juga.
Dialogue: 0,0:12:57.05,0:13:00.43,Default,,0,0,0,,Maukah kau berdansa denganku?
Dialogue: 0,0:13:08.74,0:13:12.04,Default,,0,0,0,,Telan dalam-dalam, Azazel Ameri.
Dialogue: 0,0:13:12.04,0:13:15.84,Default,,0,0,0,,Ini hal yang perlu aku lakukan.
Dialogue: 0,0:13:27.16,0:13:28.79,Default,,0,0,0,,I-Itu...
Dialogue: 0,0:13:28.79,0:13:30.41,Default,,0,0,0,,Jangan-jangan, beliau...
Dialogue: 0,0:13:34.58,0:13:35.99,Default,,0,0,0,,Tunggu dulu.
Dialogue: 0,0:13:36.42,0:13:37.82,Default,,0,0,0,,Kenapa...
Dialogue: 0,0:13:40.94,0:13:42.72,Default,,0,0,0,,hal ini...
Dialogue: 0,0:13:42.88,0:13:43.68,Default,,0,0,0,,bisa terjadi?
Dialogue: 0,0:13:52.37,0:13:54.63,Default,,0,0,0,,No-Nona Ameri.
Dialogue: 0,0:14:00.46,0:14:02.30,Default,,0,0,0,,Maukah kau...
Dialogue: 0,0:14:02.71,0:14:04.26,Default,,0,0,0,,berdansa denganku?
Dialogue: 0,0:14:21.34,0:14:24.41,Default,,0,0,0,,Mari kita mundurkan waktunya sedikit.
Dialogue: 0,0:14:27.11,0:14:28.79,Default,,0,0,0,,Aku pulang.
Dialogue: 0,0:14:29.22,0:14:33.73,Default,,0,0,0,,Apa benar rencanamu hari ini batal, Iruma?
Dialogue: 0,0:14:36.23,0:14:39.69,Default,,0,0,0,,Kalau begitu, aku ingin\Nkau menemani Kakek hari ini!
Dialogue: 0,0:14:39.69,0:14:42.19,Default,,0,0,0,,Kebetulan Kakek baru dapat undangan!
Dialogue: 0,0:14:42.19,0:14:43.49,Default,,0,0,0,,Tunggu dulu!
Dialogue: 0,0:14:46.07,0:14:47.45,Default,,0,0,0,,Berangkat!
Dialogue: 0,0:14:47.45,0:14:49.58,Default,,0,0,0,,Ke mana?!
Dialogue: 0,0:14:55.67,0:14:57.58,Default,,0,0,0,,Hebat!
Dialogue: 0,0:14:57.58,0:14:59.46,Default,,0,0,0,,Debut Devirum!
Dialogue: 0,0:14:59.46,0:15:03.28,Default,,0,0,0,,Terlebih lagi, pengalaman pertamanya\Nlangsung Deviculum!
Dialogue: 0,0:15:04.98,0:15:07.29,Default,,0,0,0,,Ma-Makanannya juga banyak!
Dialogue: 0,0:15:07.90,0:15:09.85,Default,,0,0,0,,Apa aku boleh makan semuanya?
Dialogue: 0,0:15:09.85,0:15:10.76,Default,,0,0,0,,Tentu saja.
Dialogue: 0,0:15:10.76,0:15:11.97,Default,,0,0,0,,Hore!
Dialogue: 0,0:15:11.97,0:15:15.52,Default,,0,0,0,,Kakek, terima kasih\Nsudah mengajakku ke sini!
Dialogue: 0,0:15:15.52,0:15:16.10,Default,,0,0,0,,Wah.
Dialogue: 0,0:15:16.50,0:15:17.80,Default,,0,0,0,,Tuan Iruma.
Dialogue: 0,0:15:18.61,0:15:21.55,Default,,0,0,0,,Ada Nona Ameri di sana, lo.
Dialogue: 0,0:15:22.63,0:15:24.11,Default,,0,0,0,,Kau benar.
Dialogue: 0,0:15:24.11,0:15:25.82,Default,,0,0,0,,Kalau begitu, aku akan menyapanya.
Dialogue: 0,0:15:25.82,0:15:27.11,Default,,0,0,0,,Tunggu sebentar.
Dialogue: 0,0:15:27.11,0:15:29.78,Default,,0,0,0,,Ini bukan di sekolah, lo.
Dialogue: 0,0:15:29.78,0:15:33.12,Default,,0,0,0,,Ada etika salam yang tepat\Nuntuk situasi seperti ini.
Dialogue: 0,0:15:33.54,0:15:35.00,Default,,0,0,0,,Dengar baik-baik.
Dialogue: 0,0:15:35.00,0:15:37.52,Default,,0,0,0,,Ba-Baik.
Dialogue: 0,0:15:37.71,0:15:39.86,Default,,0,0,0,,Lalu, saat ini.
Dialogue: 0,0:15:40.73,0:15:42.63,Default,,0,0,0,,Maukah kau...
Dialogue: 0,0:15:43.15,0:15:44.63,Default,,0,0,0,,berdansa denganku?
Dialogue: 0,0:15:50.64,0:15:55.21,Default,,0,0,0,,Iru— Hah? Kok? Eh?!\NKenapa Iruma ada di sini?!
Dialogue: 0,0:15:56.14,0:15:57.81,Default,,0,0,0,,Itu cucu Tuan Sullivan.
Dialogue: 0,0:15:57.81,0:16:00.15,Default,,0,0,0,,Dia yang dirumorkan\Nmendapat Royal One itu?
Dialogue: 0,0:16:00.15,0:16:01.94,Default,,0,0,0,,Dia peringkat He di umur semuda itu.
Dialogue: 0,0:16:01.94,0:16:03.27,Default,,0,0,0,,Ada ribut-ribut apa?
Dialogue: 0,0:16:03.27,0:16:06.15,Default,,0,0,0,,Ah, Tuan Henri.\NLihat itu.
Dialogue: 0,0:16:06.15,0:16:07.76,Default,,0,0,0,,Putrimu...
Dialogue: 0,0:16:15.60,0:16:18.42,Default,,0,0,0,,Saat pertama kali berdansa,\Naku pasti...
Dialogue: 0,0:16:18.67,0:16:20.94,Default,,0,0,0,,akan berdansa dengan Ayah.
Dialogue: 0,0:16:22.42,0:16:23.84,Default,,0,0,0,,Berdansa dengan Ayah!
Dialogue: 0,0:16:23.84,0:16:24.92,Default,,0,0,0,,Tuan Henri!
Dialogue: 0,0:16:25.23,0:16:26.78,Default,,0,0,0,,Iru—
Dialogue: 0,0:16:27.40,0:16:29.26,Default,,0,0,0,,Hai, Henri.
Dialogue: 0,0:16:29.26,0:16:31.14,Default,,0,0,0,,Tu-Tuan Sullivan?!
Dialogue: 0,0:16:31.14,0:16:33.64,Default,,0,0,0,,Halo, selamat malam.\NKau sehat?
Dialogue: 0,0:16:33.64,0:16:37.73,Default,,0,0,0,,Tak kusangka, Anda bersama\NIru— cucu Anda.
Dialogue: 0,0:16:37.74,0:16:40.66,Default,,0,0,0,,Sesekali aku ingin melihat\Nwajah semuanya.
Dialogue: 0,0:16:40.66,0:16:42.40,Default,,0,0,0,,Terlebih lagi...
Dialogue: 0,0:16:44.40,0:16:49.61,Default,,0,0,0,,Aku pengin pamer cucuku yang sudah\Nperingkat He pada semua orang!
Dialogue: 0,0:16:49.61,0:16:50.53,Default,,0,0,0,,Tepat sekali.
Dialogue: 0,0:16:50.53,0:16:52.66,Default,,0,0,0,,Mau lihat foto Iruma?
Dialogue: 0,0:16:52.66,0:16:53.91,Default,,0,0,0,,Mau, 'kan?
Dialogue: 0,0:16:54.89,0:16:57.37,Default,,0,0,0,,Tidak, aku punya Ameri—
Dialogue: 0,0:16:59.85,0:17:02.61,Default,,0,0,0,,Kita cukup menarik perhatian di sini, ya.
Dialogue: 0,0:17:03.35,0:17:04.69,Default,,0,0,0,,Ikutlah denganku.
Dialogue: 0,0:17:40.87,0:17:43.21,Default,,0,0,0,,Kalau begitu, Kak Ameri.
Dialogue: 0,0:17:46.98,0:17:49.61,Default,,0,0,0,,Tu, wa.
Dialogue: 0,0:17:54.57,0:17:55.70,Default,,0,0,0,,Maaf...
Dialogue: 0,0:17:57.99,0:18:00.43,Default,,0,0,0,,Maaf, aku tak bisa berdansa!
Dialogue: 0,0:18:00.43,0:18:02.23,Default,,0,0,0,,Hah? I-Iya!
Dialogue: 0,0:18:02.23,0:18:07.15,Default,,0,0,0,,Ka-Kata Opera, cara menyapa wanita yang baik\Nadalah mengajaknya berdansa.
Dialogue: 0,0:18:07.15,0:18:10.15,Default,,0,0,0,,Tapi, setelah kuingat-ingat,\Naku tak pernah diajari berdansa.
Dialogue: 0,0:18:10.15,0:18:14.61,Default,,0,0,0,,Aku tak ingin membuatmu malu,\Njadi aku mengajakmu ke tempat sepi.
Dialogue: 0,0:18:14.61,0:18:17.89,Default,,0,0,0,,Anu, eng, maafkan aku!
Dialogue: 0,0:18:22.14,0:18:23.76,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:18:23.76,0:18:26.36,Default,,0,0,0,,Yah, Iruma banget.
Dialogue: 0,0:18:29.77,0:18:32.82,Default,,0,0,0,,Kemari, akan kuajarkan berdansa.
Dialogue: 0,0:18:35.94,0:18:37.26,Default,,0,0,0,,Baik.
Dialogue: 0,0:18:44.39,0:18:47.44,Default,,0,0,0,,Tu, ga, nam.
Dialogue: 0,0:18:47.44,0:18:50.15,Default,,0,0,0,,Tu, ga, nam.
Dialogue: 0,0:18:50.15,0:18:52.53,Default,,0,0,0,,Tu, ga, nam.
Dialogue: 0,0:18:52.65,0:18:55.41,Default,,0,0,0,,Tu, ga, nam.
Dialogue: 0,0:18:55.41,0:18:59.03,Default,,0,0,0,,Benar begitu. Bagus.\NRilekskan lagi bahumu.
Dialogue: 0,0:18:59.51,0:19:01.04,Default,,0,0,0,,Ba-Baik.
Dialogue: 0,0:19:03.22,0:19:05.32,Default,,0,0,0,,Aku berdansa dengan Iruma.
Dialogue: 0,0:19:06.73,0:19:08.36,Default,,0,0,0,,Hebat.
Dialogue: 0,0:19:10.81,0:19:12.74,Default,,0,0,0,,Hebat sekali!
Dialogue: 0,0:19:16.23,0:19:17.55,Default,,0,0,0,,Sebenarnya...
Dialogue: 0,0:19:17.77,0:19:21.83,Default,,0,0,0,,Selama tak bisa bertemu denganmu,\Naku selalu memikirkannya.
Dialogue: 0,0:19:23.32,0:19:27.56,Default,,0,0,0,,Bagiku, Kak Ameri itu siapa?
Dialogue: 0,0:19:30.33,0:19:35.35,Default,,0,0,0,,Tapi, dengan bertemu lagi setelah sekian lama,\Naku merasa mengerti jawabannya.
Dialogue: 0,0:19:35.96,0:19:39.85,Default,,0,0,0,,Perjuangan Kak Ameri dalam\Nmeraih mimpi sungguh luar biasa.
Dialogue: 0,0:19:40.01,0:19:43.81,Default,,0,0,0,,Saat bersama denganmu,\Naku juga jadi ingin berjuang.
Dialogue: 0,0:19:45.35,0:19:48.67,Default,,0,0,0,,Kau menunjukkan padaku\Ntujuan yang harus kukejar.
Dialogue: 0,0:19:48.67,0:19:51.67,Default,,0,0,0,,Kau juga menungguku di ujung tujuan itu.
Dialogue: 0,0:19:59.53,0:20:01.68,Default,,0,0,0,,Bagiku, Kak Ameri itu...
Dialogue: 0,0:20:01.99,0:20:06.13,Default,,0,0,0,,sosok iblis yang ingin kudekati lebih lagi.
Dialogue: 0,0:20:34.77,0:20:38.41,Default,,0,0,0,,Aku juga... selalu...
Dialogue: 0,0:20:38.73,0:20:42.29,Default,,0,0,0,,memikirkan hal yang sama.
Dialogue: 0,0:20:53.36,0:20:55.11,Default,,0,0,0,,Be-Bercanda.
Dialogue: 0,0:20:55.83,0:21:00.68,Default,,0,0,0,,Ka-Karena kamu terlalu memujiku,\Naku jadi malu dan kelepasan.
Dialogue: 0,0:21:33.69,0:21:35.61,Default,,0,0,0,,Ketua OSIS!
Dialogue: 0,0:21:35.61,0:21:38.69,Default,,0,0,0,,Kamu! Pitamu miring lagi, tuh.
Dialogue: 0,0:21:38.69,0:21:39.69,Default,,0,0,0,,Kamu!
Dialogue: 0,0:21:39.69,0:21:40.80,Default,,0,0,0,,Dilarang terbang—
Dialogue: 0,0:21:42.36,0:21:45.37,Default,,0,0,0,,Ketua, kami ingin mewawancaraimu\Nsaat istirahat siang nanti.
Dialogue: 0,0:21:45.58,0:21:47.69,Default,,0,0,0,,Ya, baiklah.
Dialogue: 0,0:21:48.43,0:21:51.89,Default,,0,0,0,,Ah, hari ini pun cantik banget!
Dialogue: 0,0:21:51.89,0:21:54.19,Default,,0,0,0,,Sudah jelas.
Dialogue: 0,0:21:55.27,0:21:57.13,Default,,0,0,0,,Omong-omong... rasanya...
Dialogue: 0,0:21:57.56,0:22:01.13,Default,,0,0,0,,Beliau jadi lebih bersinar\Ndari sebelumnya.
Dialogue: 0,0:22:01.44,0:22:03.48,Default,,0,0,0,,Wah, itu Ketua OSIS!
Dialogue: 0,0:22:03.63,0:22:07.16,Default,,0,0,0,,Jadi, bagaimana dengan jawaban\Ndari pertanyaanku waktu itu?
Dialogue: 0,0:22:07.49,0:22:10.27,Default,,0,0,0,,Apakah Ketua OSIS temanmu atau bukan?
Dialogue: 0,0:22:10.27,0:22:12.14,Default,,0,0,0,,Eh? Eng...
Dialogue: 0,0:22:12.79,0:22:18.05,Default,,0,0,0,,Kupikir aku sudah tahu jawabannya,\Ntapi jadi balik enggak tahu.
Dialogue: 0,0:22:19.04,0:22:22.22,Default,,0,0,0,,Eh? Apaan coba?
Dialogue: 0,0:22:30.08,0:22:32.12,Default,,0,0,0,,Sip, ayo mulai!♪
Dialogue: 0,0:22:32.12,0:22:33.50,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:33.50,0:22:34.62,Default,,0,0,0,,Pasti menang!♪
Dialogue: 0,0:22:34.62,0:22:35.88,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:35.88,0:22:37.13,Default,,0,0,0,,Menang dengan gemilang♪
Dialogue: 0,0:22:37.13,0:22:38.38,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:38.38,0:22:39.63,Default,,0,0,0,,Menang dengan iseng♪
Dialogue: 0,0:22:39.63,0:22:40.96,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:40.96,0:22:42.67,Default,,0,0,0,,Kamilah pemenangnya!♪
Dialogue: 0,0:22:42.67,0:22:44.88,Default,,0,0,0,,Kemenangan luar biasa!♪
Dialogue: 0,0:22:44.88,0:22:47.43,Default,,0,0,0,,Ya! Ya! Ya! Menang lagi hari ini!♪
Dialogue: 0,0:22:47.43,0:22:49.85,Default,,0,0,0,,Senang! Senang! Duar! Terbaik!♪
Dialogue: 0,0:22:49.85,0:22:52.52,Default,,0,0,0,,Ya! Ya! Ya! Kemenangan sempurna!♪
Dialogue: 0,0:22:52.52,0:22:54.69,Default,,0,0,0,,Senang! Senang! Duar! Jempolan!♪
Dialogue: 0,0:22:54.69,0:22:57.52,Default,,0,0,0,,Bukannya enggak bakal kalah,\Ntapi mustahil kalah♪
Dialogue: 0,0:22:57.52,0:23:00.07,Default,,0,0,0,,Berjuang tuh rasanya mengasyikkan♪
Dialogue: 0,0:23:00.07,0:23:02.57,Default,,0,0,0,,Makanan enak pun\Nbuat kualitas hidup naik♪
Dialogue: 0,0:23:02.57,0:23:05.36,Default,,0,0,0,,Pertumbuhan pesat tak terbendung!\NMantap! Kawan!♪
Dialogue: 0,0:23:05.36,0:23:06.36,Default,,0,0,0,,Hei! Yo!♪
Dialogue: 0,0:23:06.36,0:23:09.16,Default,,0,0,0,,Punya teman 'tuk berlomba tuh terbaik!♪
Dialogue: 0,0:23:09.16,0:23:11.87,Default,,0,0,0,,Bisa melampaui batasan\Ndiri sendiri tuh terkuat!♪
Dialogue: 0,0:23:11.87,0:23:14.46,Default,,0,0,0,,Imutnya bukan main! Bodoh!♪
Dialogue: 0,0:23:14.46,0:23:17.58,Default,,0,0,0,,Itu sudah pasti aku!♪
Dialogue: 0,0:23:17.58,0:23:18.50,Default,,0,0,0,,Tentu, dong!♪
Dialogue: 0,0:23:18.50,0:23:21.17,Default,,0,0,0,,Raih kemenangan dengan\Nsegenap kekuatan♪
Dialogue: 0,0:23:21.17,0:23:23.38,Default,,0,0,0,,Kami 'kan tokoh utama,\Njadi pasti memimpin!♪
Dialogue: 0,0:23:23.63,0:23:26.26,Default,,0,0,0,,Hidup bersama jadi pusat perhatian♪
Dialogue: 0,0:23:26.26,0:23:27.72,Default,,0,0,0,,Heroine dijamin menang!♪
Dialogue: 0,0:23:27.72,0:23:28.72,Default,,0,0,0,,Kami menang!♪
Dialogue: 0,0:23:28.72,0:23:29.93,Default,,0,0,0,,Duk, duk, tok, tok♪
Dialogue: 0,0:23:29.93,0:23:30.89,Default,,0,0,0,,La, la, la, la, yey♪
Dialogue: 0,0:23:30.89,0:23:32.77,Default,,0,0,0,,Kisah kita berempat!!♪
Dialogue: 0,0:23:32.77,0:23:33.77,Default,,0,0,0,,Sip, menang!♪
Dialogue: 0,0:23:33.77,0:23:34.35,Default,,0,0,0,,Wus, wus, dor, dor♪
Dialogue: 0,0:23:34.35,0:23:34.98,Default,,0,0,0,,Buk, buk, blar, blar♪
Dialogue: 0,0:23:34.98,0:23:36.06,Default,,0,0,0,,Berdebar dengan kencangnya♪
Dialogue: 0,0:23:36.06,0:23:38.65,Default,,0,0,0,,Motivasiku melambung tinggi!!♪
Dialogue: 0,0:23:38.65,0:23:40.69,Default,,0,0,0,,Tu, wa, lalu maju♪
Dialogue: 0,0:23:40.69,0:23:41.15,Default,,0,0,0,,Demi aku♪
Dialogue: 0,0:23:41.15,0:23:43.19,Default,,0,0,0,,Ditambah lagi, runaway♪
Dialogue: 0,0:23:43.19,0:23:43.65,Default,,0,0,0,,Demi aku♪
Dialogue: 0,0:23:43.65,0:23:45.03,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:45.03,0:23:46.11,Default,,0,0,0,,Pasti menang!♪
Dialogue: 0,0:23:46.11,0:23:47.45,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:47.45,0:23:48.57,Default,,0,0,0,,Menang dengan gemilang♪
Dialogue: 0,0:23:48.57,0:23:50.03,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:50.03,0:23:51.03,Default,,0,0,0,,Menang dengan iseng♪
Dialogue: 0,0:23:51.03,0:23:52.49,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:52.49,0:23:56.00,Default,,0,0,0,,Kamilah pemenangnya!♪
Dialogue: 0,0:23:56.64,0:23:59.61,Default,,0,0,0,,Tamba! Tamba! Tambahan!
Dialogue: 0,0:24:06.57,0:24:08.47,Default,,0,0,0,,Ha, Hai, Iruma.
Dialogue: 0,0:24:08.47,0:24:10.47,Default,,0,0,0,,Ka-Kak Ameri.
Dialogue: 0,0:24:10.47,0:24:12.18,Default,,0,0,0,,Ka-Kamu sehat?
Dialogue: 0,0:24:12.18,0:24:15.12,Default,,0,0,0,,I-Iya. Kak Ameri bagaimana?
Dialogue: 0,0:24:25.49,0:24:29.99,Default,,0,0,0,,Enaknya! Enak banget!
Dialogue: 0,0:24:30.67,0:24:32.95,Default,,0,0,0,,Enaknya Iruma dan Ketua OSIS.
Dialogue: 0,0:24:32.95,0:24:36.20,Default,,0,0,0,,Aku juga pengin begitu dengan seseorang.
Dialogue: 0,0:24:36.20,0:24:38.29,Default,,0,0,0,,Padahal selalu bertengkar\Nkalau bertemu,
Dialogue: 0,0:24:38.29,0:24:40.50,Default,,0,0,0,,tapi saat tangan mereka\Ntak sengaja bersentuhan,
Dialogue: 0,0:24:40.50,0:24:43.21,Default,,0,0,0,,keduanya merasa malu dan terdiam.
Dialogue: 0,0:24:43.21,0:24:45.63,Default,,0,0,0,,Enaknya. Yang begitu enak banget.
Dialogue: 0,0:24:45.63,0:24:48.09,Default,,0,0,0,,Apa aku masih bisa punya\Nteman masa kecil dari sekarang, ya?
Dialogue: 0,0:24:48.09,0:24:49.97,Default,,0,0,0,,Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:49.97,0:24:51.84,Default,,0,0,0,,"Ritual Iblis Suzuki Iruma".
Dialogue: 0,0:24:51.84,0:24:53.51,Default,,0,0,0,,Eh? Iruma ulang tahun?
Dialogue: 0,0:24:53.51,0:24:55.01,Default,,0,0,0,,Aku harus siap-siap.
