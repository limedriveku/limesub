Dialogue: 0,0:00:19.46,0:00:26.76,sign,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:01:41.00,0:01:41.83,sign,,0000,0000,0000,,PERAYAAN UNTUK PEMENANG
Dialogue: 0,0:11:51.86,0:11:52.36,sign,,0000,0000,0000,,PERINGKAT 4 (DALETH)
Dialogue: 0,0:12:20.09,0:12:22.10,sign,,0000,0000,0000,,PERINGKAT 5 (HE)
Dialogue: 0,0:12:59.43,0:13:01.18,sign,,0000,0000,0000,,MINUMAN BIASA
Dialogue: 0,0:15:19.48,0:15:20.90,sign,,0000,0000,0000,,WAH
Dialogue: 0,0:16:27.13,0:16:28.13,sign,,0000,0000,0000,,RAJA IBLIS
Dialogue: 0,0:16:34.10,0:16:35.31,sign,,0000,0000,0000,,BULU LEMBUT (KHUSUS PEREMPUAN)
Dialogue: 0,0:18:05.52,0:18:06.69,sign,,0000,0000,0000,,KELUARGA VALAC SANGAT MIRIP
Dialogue: 0,0:24:03.51,0:24:05.13,sign,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:24:22.90,0:24:29.36,sign,,0000,0000,0000,,SELAMAT DATANG ANGGOTA ALIANSI "BOKU" NO. 3
Dialogue: 0,0:24:29.99,0:24:30.99,sign,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:01:41.83,0:01:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Perayaan untuk Pemenang".
Dialogue: 0,0:01:48.44,0:01:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya...
Dialogue: 0,0:01:52.01,0:01:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:01:55.80,0:01:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya begitu, toh.\NTerus, begini.
Dialogue: 0,0:02:01.14,0:02:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, tegas sekali.
Dialogue: 0,0:02:03.73,0:02:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menggabungnya.
Dialogue: 0,0:02:05.56,0:02:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini!
Dialogue: 0,0:02:08.78,0:02:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kamu ini.
Dialogue: 0,0:02:10.36,0:02:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua iblis itu centil, tahu.
Dialogue: 0,0:02:12.74,0:02:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kalau begitu...
Dialogue: 0,0:02:15.28,0:02:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan ini?
Dialogue: 0,0:02:16.95,0:02:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, berani sekali!\NBagaimana kalau ini?
Dialogue: 0,0:02:21.04,0:02:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita coba ini.
Dialogue: 0,0:02:22.83,0:02:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kita lanjutkan dengan ini.
Dialogue: 0,0:02:25.63,0:02:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu memang hebat.
Dialogue: 0,0:02:27.79,0:02:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selesai!
Dialogue: 0,0:02:29.30,0:02:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:02:30.30,0:02:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita mainkan.
Dialogue: 0,0:02:33.26,0:02:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sullivan berisik!
Dialogue: 0,0:02:35.18,0:02:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah, Sully cerewet!
Dialogue: 0,0:02:36.89,0:02:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang sana! Berisik! Berisik!
Dialogue: 0,0:02:42.06,0:02:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sully!
Dialogue: 0,0:02:42.98,0:02:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:02:43.98,0:02:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:02:52.03,0:02:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, kamu mau ke mana?
Dialogue: 0,0:02:53.74,0:02:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana, ya?\NMungkin ke utara.
Dialogue: 0,0:02:56.66,0:02:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari instrumen baru lagi, ya?
Dialogue: 0,0:02:59.12,0:03:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya.
Dialogue: 0,0:03:01.45,0:03:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bawa oleh-oleh yang banyak.
Dialogue: 0,0:03:04.08,0:03:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, aku akan selalu pulang.
Dialogue: 0,0:03:07.75,0:03:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku pergi bertualang\Ndan kagum pada berbagai macam suara,
Dialogue: 0,0:03:10.67,0:03:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan selalu kembali ke tempatmu.
Dialogue: 0,0:03:14.47,0:03:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar aku bisa bermain musik\Ndenganmu di sini, di Royal One.
Dialogue: 0,0:03:21.35,0:03:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo mainkan satu lagu lagi.
Dialogue: 0,0:03:22.97,0:03:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati.
Dialogue: 0,0:03:24.39,0:03:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau main lagu apa?
Dialogue: 0,0:03:26.89,0:03:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang paling kusukai.
Dialogue: 0,0:03:29.27,0:03:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:03:30.57,0:03:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengumuman hasil festival musik!
Dialogue: 0,0:03:33.94,0:03:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari ulas kembali!\NInilah skor sejauh ini!
Dialogue: 0,0:03:37.95,0:03:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap kelasnya dapat skor tinggi!
Dialogue: 0,0:03:41.08,0:03:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kita barusan telah menyaksikan\Npenampilan terakhir dari kelas abnormal!
Dialogue: 0,0:03:46.46,0:03:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik senang maupun sedih,\Npemenangnya akan muncul di sini!
Dialogue: 0,0:03:50.29,0:03:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari kita liat skor\Nuntuk kelas abnormal...
Dialogue: 0,0:03:58.97,0:04:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Hebat!\NSkor terbaik!
Dialogue: 0,0:04:02.18,0:04:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Mei Mei dan Nona Kyupa\Nmemberikan skor sempurna!
Dialogue: 0,0:04:06.23,0:04:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hell Dance memang layak ditonton.
Dialogue: 0,0:04:09.23,0:04:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang memesona!
Dialogue: 0,0:04:11.02,0:04:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa merasakan betapa\Ntersentuhnya para penonton, ya.
Dialogue: 0,0:04:14.57,0:04:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akankah skor tertinggi akan muncul?
Dialogue: 0,0:04:17.95,0:04:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakni enam,
Dialogue: 0,0:04:19.24,0:04:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}enam,
Dialogue: 0,0:04:20.74,0:04:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}enam?
Dialogue: 0,0:04:22.70,0:04:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kalau begitu,\Nskor terakhir dari Tuan Amduscias...
Dialogue: 0,0:04:33.63,0:04:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:04:37.30,0:04:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:04:38.63,0:04:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:04:39.93,0:04:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong...
Dialogue: 0,0:04:40.72,0:04:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagai petir di siang bolong.
Dialogue: 0,0:04:42.39,0:04:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Anda benar-benar tidak ingin\Nmenyerahkan Royal One?
Dialogue: 0,0:04:45.35,0:04:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu alasannya pada kami!
Dialogue: 0,0:04:48.23,0:04:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:04:49.73,0:04:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, para penari.
Dialogue: 0,0:04:52.27,0:04:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakan yang halus\Ndan momentum yang sempurna.
Dialogue: 0,0:04:56.57,0:04:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Instrukturnya...
Dialogue: 0,0:04:58.86,0:05:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, ya?
Dialogue: 0,0:05:00.74,0:05:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat kamu bisa melatih mereka\Nsampai sejauh ini.
Dialogue: 0,0:05:03.12,0:05:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar-benar luar biasa.
Dialogue: 0,0:05:06.37,0:05:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama kamu, Nona Penari Utama!
Dialogue: 0,0:05:09.00,0:05:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosokmu sebagai wanita\Nsangat sempurna dan anggun.
Dialogue: 0,0:05:11.37,0:05:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:05:12.79,0:05:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak seanggun diriku, sih!
Dialogue: 0,0:05:15.92,0:05:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabnock Saburo!\NKosongkan jadwalmu akhir pekan nanti!
Dialogue: 0,0:05:19.80,0:05:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Digoda?
Dialogue: 0,0:05:20.88,0:05:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tipe beliau yang begitu, ya?\N- Beliau ingat namanya.
Dialogue: 0,0:05:23.01,0:05:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang patut diperhatikan ialah teknik\Ndan bakat bermusik yang luar biasa.
Dialogue: 0,0:05:28.98,0:05:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit percaya kalau kamu masih sekolah.
Dialogue: 0,0:05:31.31,0:05:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Purson Soi.
Dialogue: 0,0:05:36.82,0:05:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua digabungkan dan menghasilkan\Npenampilan tingkat tinggi.
Dialogue: 0,0:05:39.99,0:05:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka penampilan murid\Ndi festival musik bisa sampai sejauh ini.
Dialogue: 0,0:05:47.03,0:05:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, masalahnya...
Dialogue: 0,0:05:49.20,0:05:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu!
Dialogue: 0,0:05:50.83,0:05:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding permainan trompet,\Nritme dan nadamu hampir tidak bisa ditoleransi!
Dialogue: 0,0:05:55.00,0:05:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jari-jarimu juga berisik!\NKamu jelas masih pemula!
Dialogue: 0,0:05:58.05,0:06:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesonamu sebagai pemusik\Nmasih sangat kurang!
Dialogue: 0,0:06:00.26,0:06:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesimpulannya...
Dialogue: 0,0:06:01.26,0:06:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu payah!
Dialogue: 0,0:06:05.51,0:06:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maafkan aku.\NGara-gara aku...
Dialogue: 0,0:06:09.52,0:06:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena itu!
Dialogue: 0,0:06:11.52,0:06:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyebalkan!\NPadahal payah!
Dialogue: 0,0:06:14.15,0:06:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu pendek, tidak jantan,\Ndan masih pemula!
Dialogue: 0,0:06:17.52,0:06:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa...
Dialogue: 0,0:06:24.70,0:06:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:06:44.09,0:06:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:06:48.55,0:06:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu mengingatkanku padanya?
Dialogue: 0,0:06:53.64,0:06:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak percaya!
Dialogue: 0,0:06:55.77,0:06:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlihat sangat bahagia\Nsampai aku tidak percaya!
Dialogue: 0,0:07:00.52,0:07:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu seperti memperlihatkan\Nkebahagiaan itu padaku!
Dialogue: 0,0:07:05.78,0:07:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara hatimu persis dengannya.
Dialogue: 0,0:07:10.99,0:07:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mukamu sama sekali tidak mirip, sih!
Dialogue: 0,0:07:15.96,0:07:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berkata padaku kalau\Nsuara yang paling dia sukai adalah...
Dialogue: 0,0:07:20.38,0:07:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang paling baru\Ndan menyenangkan.
Dialogue: 0,0:07:25.38,0:07:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara akan kubalas dengan suara.
Dialogue: 0,0:07:27.64,0:07:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, mantan 13 Mahkota, Amduscias Poro\Nakan memberikan kalian "not musik".
Dialogue: 0,0:07:38.40,0:07:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah ini!
Dialogue: 0,0:07:39.65,0:07:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, berbanggalah!
Dialogue: 0,0:07:46.65,0:07:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang luar biasa,\Nbocah-bocah!
Dialogue: 0,0:07:51.12,0:07:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenang festival musik\Ndengan skor enam, enam, enam,
Dialogue: 0,0:07:54.58,0:07:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jatuh pada kelas abnormal!
Dialogue: 0,0:08:00.33,0:08:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarian kalian luar biasa, lo!
Dialogue: 0,0:08:01.84,0:08:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma!
Dialogue: 0,0:08:03.00,0:08:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson!
Dialogue: 0,0:08:04.34,0:08:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:07.38,0:08:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa Purson baik-baik saja\Nmencolok begini?
Dialogue: 0,0:08:12.22,0:08:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, tuh.
Dialogue: 0,0:08:14.06,0:08:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya malah kelihatan bahagia, tuh.
Dialogue: 0,0:08:16.18,0:08:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah bebas, ya.
Dialogue: 0,0:08:17.77,0:08:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pur, Pur, Purson!
Dialogue: 0,0:08:19.10,0:08:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar datang, ya.
Dialogue: 0,0:08:20.81,0:08:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:21.94,0:08:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyenangkan, ya.
Dialogue: 0,0:08:23.52,0:08:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:26.53,0:08:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:08:27.57,0:08:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tertarik bergabung\Ndengan Orkestra Iblis?
Dialogue: 0,0:08:30.07,0:08:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia direkrut!
Dialogue: 0,0:08:31.24,0:08:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direkrut langsung Nona Mei Mei!
Dialogue: 0,0:08:32.70,0:08:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:08:33.95,0:08:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka aku bisa\Nmelihat Hell Dance di sini.
Dialogue: 0,0:08:38.33,0:08:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Kuromu.
Dialogue: 0,0:08:42.27,0:08:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas kesuksesan Hell Dance-nya.
Dialogue: 0,0:08:45.67,0:08:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Bos.
Dialogue: 0,0:08:48.38,0:08:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, siapakah rekomendasimu\Nuntuk direkrut?
Dialogue: 0,0:08:51.43,0:08:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:08:57.52,0:09:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua, Iruma ada di situ, lo.
Dialogue: 0,0:09:02.15,0:09:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu, anu...
Dialogue: 0,0:09:04.65,0:09:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu banyak yang ingin kukatakan...
Dialogue: 0,0:09:09.61,0:09:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Ha-Hatiku belum siap!
Dialogue: 0,0:09:12.45,0:09:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah.
Dialogue: 0,0:09:13.62,0:09:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berhasil lagi, kelas abnormal!
Dialogue: 0,0:09:15.08,0:09:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin naik karpet Lilith!
Dialogue: 0,0:09:16.95,0:09:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Asmodeus!
Dialogue: 0,0:09:19.12,0:09:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan tarik-tarik!\N- Kita selalu berakhir begini, ya.
Dialogue: 0,0:09:21.87,0:09:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuanku!\N- Tersenyum, dong!
Dialogue: 0,0:09:23.96,0:09:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia malu-malu, ya.
Dialogue: 0,0:09:25.50,0:09:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iruma bisa main piano, toh!\N- Kita tak bisa mengalihkan pandangan
Dialogue: 0,0:09:28.55,0:09:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalian sampai diakui Tuan Amduscias, ya!\N- dari kelas abnormal, ya!
Dialogue: 0,0:09:33.51,0:09:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hell Dance kalian keren banget!
Dialogue: 0,0:09:34.93,0:09:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kelas abnormal, apa yang akan\N- Festivalnya meriah sekali, ya.
Dialogue: 0,0:09:36.56,0:09:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- kalian lakukan selanjutnya?\N- Festivalnya meriah sekali, ya.
Dialogue: 0,0:09:38.02,0:09:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cucuku hebat, kan?
Dialogue: 0,0:09:43.02,0:09:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih sangat payah, sih.
Dialogue: 0,0:09:46.52,0:09:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tahu kamu menyukai Iruma.
Dialogue: 0,0:09:53.57,0:09:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikapmu itu...
Dialogue: 0,0:09:56.03,0:09:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikapmu yang sok tahu itu\Nmengesalkan, tahu!
Dialogue: 0,0:09:59.75,0:10:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sakit! Berat! Aduh, aduh, aduh!\N- Hah, lancang sekali kamu!
Dialogue: 0,0:10:05.04,0:10:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh.\N- Yah,
Dialogue: 0,0:10:06.34,0:10:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak keberatan\Nmakan malam dengannya.
Dialogue: 0,0:10:09.63,0:10:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu...
Dialogue: 0,0:10:11.13,0:10:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat!
Dialogue: 0,0:10:13.43,0:10:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma dan Purson mau dimakan!
Dialogue: 0,0:10:16.47,0:10:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum mau kumakan, kok!
Dialogue: 0,0:10:17.81,0:10:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum?
Dialogue: 0,0:10:20.31,0:10:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikuti aku, bocah-bocah tengik.
Dialogue: 0,0:10:27.44,0:10:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:10:28.94,0:10:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kita adakan\Nupacara penghargaan!
Dialogue: 0,0:10:32.19,0:10:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pur, pinjamkan aku kekasihmu.
Dialogue: 0,0:10:39.95,0:10:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik, bocah!
Dialogue: 0,0:10:42.00,0:10:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Royal One adalah sarang cintaku dan Del!
Dialogue: 0,0:10:46.21,0:10:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipakai sembarangan,\Nakan kucincang dan jadikan kalian alat musik!
Dialogue: 0,0:10:50.30,0:10:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengerti?
Dialogue: 0,0:11:00.76,0:11:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah perayaan.\NDengarkan baik-baik.
Dialogue: 0,0:11:13.19,0:11:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya...
Dialogue: 0,0:11:14.65,0:11:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengalir di udara.
Dialogue: 0,0:11:17.57,0:11:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini...
Dialogue: 0,0:11:18.91,0:11:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:11:19.99,0:11:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sungai di langit?
Dialogue: 0,0:11:21.74,0:11:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah!
Dialogue: 0,0:11:23.79,0:11:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dengan satu suara...
Dialogue: 0,0:11:26.21,0:11:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:11:27.83,0:11:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara Raja harus bisa begini.
Dialogue: 0,0:11:40.35,0:11:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ulurkan tangan kalian.
Dialogue: 0,0:11:42.35,0:11:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas nama Amduscias Poro,\Nmantan anggota 13 Mahkota,
Dialogue: 0,0:11:48.35,0:11:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berikan peringkat Daleth pada kalian!
Dialogue: 0,0:11:53.86,0:11:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lencana Daleth!
Dialogue: 0,0:11:55.49,0:11:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil! Hebat!
Dialogue: 0,0:11:57.36,0:11:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya dapat Daleth?
Dialogue: 0,0:11:58.82,0:11:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:11:59.45,0:12:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daleth! Daleth!
Dialogue: 0,0:12:00.57,0:12:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak diragukan lagi!
Dialogue: 0,0:12:02.33,0:12:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil, ya, Tuan Iruma!
Dialogue: 0,0:12:04.33,0:12:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dengan ini,\Nkita semuanya sudah Daleth!
Dialogue: 0,0:12:06.62,0:12:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, siapa yang bilang semuanya Daleth?
Dialogue: 0,0:12:11.59,0:12:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya Daleth akan membosankan,
Dialogue: 0,0:12:14.34,0:12:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku membuat Iruma berbeda.
Dialogue: 0,0:12:22.10,0:12:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:54.38,0:12:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai, ya?\NSatu, dua...
Dialogue: 0,0:12:57.38,0:12:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:13:01.18,0:13:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo makan!
Dialogue: 0,0:13:02.43,0:13:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya enak!
Dialogue: 0,0:13:03.47,0:13:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sajian istimewa!
Dialogue: 0,0:13:04.68,0:13:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pesta!
Dialogue: 0,0:13:05.89,0:13:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:13:06.81,0:13:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, terima kasih\Natas kerja kerasnya!
Dialogue: 0,0:13:18.53,0:13:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya pesta kelas lain juga meriah.
Dialogue: 0,0:13:21.32,0:13:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Agares dapat pesan dari perempuan!
Dialogue: 0,0:13:24.74,0:13:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pinjam.
Dialogue: 0,0:13:26.66,0:13:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuanku dan Gapp, silakan bergabung kalau mau.\N- Balikin, dong.
Dialogue: 0,0:13:30.41,0:13:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan!
Dialogue: 0,0:13:32.96,0:13:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak bilang mau pergi, lo!
Dialogue: 0,0:13:35.84,0:13:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat pesan selamat\Ndari banyak orang.
Dialogue: 0,0:13:38.38,0:13:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:13:40.22,0:13:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival musiknya luar biasa, ya.
Dialogue: 0,0:13:42.89,0:13:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin merayakannya\Nlangsung denganmu.
Dialogue: 0,0:13:45.14,0:13:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu ada waktu?
Dialogue: 0,0:13:46.72,0:13:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu...
Dialogue: 0,0:13:48.47,0:13:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kami biarkan pergi!
Dialogue: 0,0:13:53.31,0:13:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menjalani latihan\Npanjang dan melelahkan...
Dialogue: 0,0:13:56.86,0:13:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil meraih\Nkemenangan yang luar biasa!
Dialogue: 0,0:13:59.86,0:14:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, kita semua naik ke Daleth.
Dialogue: 0,0:14:02.20,0:14:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan, Iruma naik ke He.
Dialogue: 0,0:14:03.91,0:14:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banjir pujian.
Dialogue: 0,0:14:05.28,0:14:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badai wawancara.
Dialogue: 0,0:14:09.37,0:14:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:14:11.50,0:14:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada iblis yang harusnya memuji kita!
Dialogue: 0,0:14:15.63,0:14:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:14:16.67,0:14:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ada yang harus Anda\Nkatakan sebagai wali kelas?
Dialogue: 0,0:14:19.17,0:14:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersikap tegas bukanlah\Nsatu-satunya tugas seorang guru!
Dialogue: 0,0:14:22.13,0:14:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari dengarkan pujian dari Anda!
Dialogue: 0,0:14:24.38,0:14:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian benar juga.
Dialogue: 0,0:14:26.72,0:14:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kelas naik ke tingkat Daleth di kelas satu
Dialogue: 0,0:14:29.35,0:14:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah hal yang tidak biasa terjadi\Ndalam sejarah Babyls.
Dialogue: 0,0:14:32.23,0:14:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan sesuatu yang bisa digapai\Nhanya dengan disuruh.
Dialogue: 0,0:14:36.15,0:14:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang biasa kukatakan.
Dialogue: 0,0:14:38.48,0:14:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan sungguh\Nmerupakan prestasi besar.
Dialogue: 0,0:14:43.15,0:14:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kelas bermasalah\Nbisa berkembang sejauh ini...
Dialogue: 0,0:14:46.95,0:14:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar bangga.
Dialogue: 0,0:14:49.33,0:14:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego...
Dialogue: 0,0:14:50.54,0:14:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar...
Dialogue: 0,0:14:52.45,0:14:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajaranku memang luar biasa, ya.
Dialogue: 0,0:14:55.79,0:14:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memuji diri sendiri?
Dialogue: 0,0:14:56.92,0:14:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tidak dewasa!
Dialogue: 0,0:14:58.04,0:15:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puji kami lebih jujur lagi, dong!
Dialogue: 0,0:15:00.13,0:15:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar!
Dialogue: 0,0:15:00.96,0:15:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pujian itu bisa memotivasi kami, tahu!\N- Bapak terlalu tegas, tahu!
Dialogue: 0,0:15:03.42,0:15:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, setidaknya tolong puji tim dari musik.
Dialogue: 0,0:15:09.14,0:15:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan mereka.
Dialogue: 0,0:15:10.43,0:15:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar!
Dialogue: 0,0:15:20.90,0:15:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memuji?
Dialogue: 0,0:15:22.40,0:15:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kelihatan senang, sih.
Dialogue: 0,0:15:24.11,0:15:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma...
Dialogue: 0,0:15:25.61,0:15:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, ini masih kurang!
Dialogue: 0,0:15:27.95,0:15:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson, kemarilah.
Dialogue: 0,0:15:30.66,0:15:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, Pixie!
Dialogue: 0,0:15:32.08,0:15:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemain trompet genius!
Dialogue: 0,0:15:33.62,0:15:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duta musik!
Dialogue: 0,0:15:35.29,0:15:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bintang kami!
Dialogue: 0,0:15:36.58,0:15:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius tapi santai!
Dialogue: 0,0:15:38.71,0:15:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jagonya menghilang!
Dialogue: 0,0:15:39.67,0:15:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria jantan luar dalam!
Dialogue: 0,0:15:41.59,0:15:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaramu kayak senapan mesin,\Ntapi jelas banget.
Dialogue: 0,0:15:43.51,0:15:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, deh.
Dialogue: 0,0:15:44.84,0:15:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilanmu saat naik\Nke panggung juga luar biasa!
Dialogue: 0,0:15:47.93,0:15:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bikin malu...
Dialogue: 0,0:15:50.01,0:15:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:15:51.31,0:15:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:15:52.60,0:15:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat senang saat kamu kembali.
Dialogue: 0,0:15:57.52,0:16:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mau\Nnaik ke panggung bersama kami, Soi.
Dialogue: 0,0:16:02.44,0:16:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Sama-sama.
Dialogue: 0,0:16:04.86,0:16:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaianmu itu bikin terkejut,\Npadahal kami sudah mengukur kostum lain.
Dialogue: 0,0:16:10.24,0:16:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mungkin lebih mencolok daripada aku.
Dialogue: 0,0:16:12.53,0:16:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia serbaputih!
Dialogue: 0,0:16:13.49,0:16:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pakaian khusus dari warisan keluargaku.
Dialogue: 0,0:16:16.41,0:16:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memakainya sebagai\Ntanda ketetapan hatiku.
Dialogue: 0,0:16:18.79,0:16:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku memang berpikir
Dialogue: 0,0:16:19.79,0:16:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- itu mungkin agak keren,\N- Wah, mirip senapan mesin.
Dialogue: 0,0:16:20.92,0:16:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tapi bukan itu maksudnya.\N- Wah, mirip senapan mesin.
Dialogue: 0,0:16:21.88,0:16:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ayo main gim Raja Iblis!
Dialogue: 0,0:16:24.88,0:16:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku Rajanya, ya!
Dialogue: 0,0:16:31.09,0:16:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya perempuan yang boleh\Nmembelai buluku yang lembut ini!
Dialogue: 0,0:16:34.10,0:16:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu lembut...
Dialogue: 0,0:16:35.31,0:16:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil sebanyak mungkin!
Dialogue: 0,0:16:37.98,0:16:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo buat campuran orisinal kita.
Dialogue: 0,0:16:40.69,0:16:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, tuh.
Dialogue: 0,0:16:41.90,0:16:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau tambah ini juga?
Dialogue: 0,0:16:43.27,0:16:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang bakal minum itu?
Dialogue: 0,0:16:44.65,0:16:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Eggy.
Dialogue: 0,0:16:49.70,0:16:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jago!\N- Luar biasa!
Dialogue: 0,0:16:55.41,0:16:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hebat, ya.
Dialogue: 0,0:16:57.08,0:16:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat banget!
Dialogue: 0,0:16:58.66,0:16:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Megah dan berkilau.
Dialogue: 0,0:16:59.96,0:17:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, langsung mulai sombong.
Dialogue: 0,0:17:03.54,0:17:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya menyenangkan dan mengasyikkan.
Dialogue: 0,0:17:05.92,0:17:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma.
Dialogue: 0,0:17:07.51,0:17:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, kamu tidak boleh lengah.
Dialogue: 0,0:17:11.47,0:17:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid kelas satu mendapat peringkat He\Nsangatlah langka di dunia iblis.
Dialogue: 0,0:17:16.27,0:17:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kewajiban yang sepadan\Ntelah menantimu di masa depan.
Dialogue: 0,0:17:21.48,0:17:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kewajiban?
Dialogue: 0,0:17:22.90,0:17:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chercille.
Dialogue: 0,0:17:25.73,0:17:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh!
Dialogue: 0,0:17:27.60,0:17:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fu yang berenda-renda.
Dialogue: 0,0:17:30.74,0:17:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chercille.
Dialogue: 0,0:17:32.74,0:17:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kalian berbuat begitu\Npada Tuan Iruma!
Dialogue: 0,0:17:35.20,0:17:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lengah, sih.
Dialogue: 0,0:17:37.29,0:17:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Purson?
Dialogue: 0,0:17:40.46,0:17:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan Purson berubah jadi perempuan?
Dialogue: 0,0:17:43.50,0:17:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:17:44.84,0:17:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?
Dialogue: 0,0:17:50.51,0:17:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ibunya Soi, senang bertemu kalian.
Dialogue: 0,0:17:54.34,0:17:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kami juga.
Dialogue: 0,0:17:56.26,0:17:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sejak kapan Ibu ada di sini?
Dialogue: 0,0:17:58.43,0:18:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sejak kalian bersulang.
Dialogue: 0,0:18:00.52,0:18:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti sejak awal?
Dialogue: 0,0:18:02.52,0:18:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kelihatan mirip, ya.
Dialogue: 0,0:18:04.27,0:18:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga sama.
Dialogue: 0,0:18:05.52,0:18:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Valac!
Dialogue: 0,0:18:07.35,0:18:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu sangat senang dikira anak sekolah.
Dialogue: 0,0:18:10.61,0:18:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu pulang saja sana.
Dialogue: 0,0:18:12.24,0:18:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Ibu baru sampai.
Dialogue: 0,0:18:13.53,0:18:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu sudah di sini dari tadi, kan?
Dialogue: 0,0:18:14.91,0:18:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soi.
Dialogue: 0,0:18:16.58,0:18:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untukmu.
Dialogue: 0,0:18:18.58,0:18:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahmu ingin bicara denganmu.
Dialogue: 0,0:18:38.17,0:18:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soi.
Dialogue: 0,0:18:39.10,0:18:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Ayah.
Dialogue: 0,0:18:46.61,0:18:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kamu tampil di festival musik, ya.
Dialogue: 0,0:18:49.82,0:18:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:51.23,0:18:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya sukses besar, ya.
Dialogue: 0,0:18:56.91,0:19:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka kamu punya\Nbakat musik sehebat itu.
Dialogue: 0,0:19:01.43,0:19:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:19:03.75,0:19:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:19:05.53,0:19:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:19:07.04,0:19:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar tetaplah keluar.
Dialogue: 0,0:19:09.00,0:19:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulanglah ke rumah besok.
Dialogue: 0,0:19:13.26,0:19:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesampainya di rumah,\Nmari bicarakan tentang pekerjaan.
Dialogue: 0,0:19:16.21,0:19:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aturan keluarga tetap mutlak.
Dialogue: 0,0:19:18.39,0:19:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya kamu dapat hukuman,
Dialogue: 0,0:19:22.18,0:19:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku buat pengecualian\Nuntuk kali ini.
Dialogue: 0,0:19:25.98,0:19:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah puas dengan\Nambisi musikmu, kan?
Dialogue: 0,0:19:30.57,0:19:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengerti?
Dialogue: 0,0:19:39.37,0:19:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:19:43.50,0:19:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:44.54,0:19:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin aku berhenti setelah ini.
Dialogue: 0,0:19:46.33,0:19:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya Ayah sudah rela\Nuntuk membiarkanku.
Dialogue: 0,0:19:49.04,0:19:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayah keras kepala.\N- Eh?
Dialogue: 0,0:19:50.04,0:19:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah sudah masuk level tidak peka.
Dialogue: 0,0:19:51.71,0:19:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah sampai tingkat tidak wajar,\Njadi lebih baik Ayah sadar diri.
Dialogue: 0,0:19:54.67,0:19:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya karena tampan,\Nbukan berarti Ayah bisa abai.
Dialogue: 0,0:19:57.13,0:19:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cewek cantik bukan masalah.
Dialogue: 0,0:19:58.59,0:19:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak penting, sih.
Dialogue: 0,0:19:59.55,0:20:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya...
Dialogue: 0,0:20:01.05,0:20:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara bicara dan pemikiran Ayah\Nsudah usang.
Dialogue: 0,0:20:05.43,0:20:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyerah baik dalam bermusik\Nmaupun jadi pemimpin keluarga.
Dialogue: 0,0:20:10.27,0:20:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:20:11.44,0:20:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, aku jadi lumayan rakus.
Dialogue: 0,0:20:16.61,0:20:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara seseorang.
Dialogue: 0,0:20:18.53,0:20:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah tidak perlu khawatir.
Dialogue: 0,0:20:20.95,0:20:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi pemimpin\Nyang hebat dan ambisius.
Dialogue: 0,0:20:24.62,0:20:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soi!
Dialogue: 0,0:20:25.54,0:20:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berniat lebih menonjol dari ini?
Dialogue: 0,0:20:27.75,0:20:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menonjol di festival musik?
Dialogue: 0,0:20:30.00,0:20:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:20:31.71,0:20:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena...
Dialogue: 0,0:20:33.38,0:20:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pixie luar biasa, ya!
Dialogue: 0,0:20:35.13,0:20:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku jadi bersemangat!
Dialogue: 0,0:20:38.88,0:20:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah Purson Soi dari kelas abnormal.
Dialogue: 0,0:20:44.85,0:20:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi ada orang lain?
Dialogue: 0,0:20:46.68,0:20:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:20:53.77,0:20:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang.
Dialogue: 0,0:20:55.86,0:21:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya Soi\Nmengatakan pendapatnya padaku.
Dialogue: 0,0:21:04.28,0:21:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifat keras kepalanya\Nbenar-benar mirip denganmu.
Dialogue: 0,0:21:10.00,0:21:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, dia anak kita berdua.
Dialogue: 0,0:21:13.79,0:21:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti akan jadi pemimpin\Nyang kuat dan hebat.
Dialogue: 0,0:21:30.44,0:21:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah kembali, ya.
Dialogue: 0,0:21:32.31,0:21:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego, mereka semua ke mana?
Dialogue: 0,0:21:36.32,0:21:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ada, kok.
Dialogue: 0,0:21:37.98,0:21:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situ.
Dialogue: 0,0:21:40.95,0:21:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soi!
Dialogue: 0,0:21:42.66,0:21:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jebakan antideteksi sukses besar!
Dialogue: 0,0:21:44.70,0:21:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali!
Dialogue: 0,0:21:51.92,0:21:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu Pixie.
Dialogue: 0,0:21:53.83,0:21:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson Soi dari kelas abnormal.
Dialogue: 0,0:21:57.96,0:22:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang menyadarinya\Nsampai festival musik, ya.
Dialogue: 0,0:22:00.88,0:22:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia ada di kelas\Nyang mencolok begitu.
Dialogue: 0,0:22:02.84,0:22:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu lagi murid yang luar biasa.
Dialogue: 0,0:22:05.26,0:22:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembilan, sepuluh, sebelas, dua belas.
Dialogue: 0,0:22:09.72,0:22:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Totalnya ada tiga belas!
Dialogue: 0,0:22:12.31,0:22:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas abnormal adalah\N13 Mahkotanya Babyls, ya!
Dialogue: 0,0:22:23.11,0:22:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival musik telah berakhir.
Dialogue: 0,0:22:25.24,0:22:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua murid kelas abnormal\Nberhasil naik ke Daleth.
Dialogue: 0,0:22:28.70,0:22:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecuali satu murid.
Dialogue: 0,0:24:08.39,0:24:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma, sebenarnya\Naku telah menyadari sesuatu.
Dialogue: 0,0:24:12.26,0:24:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku juga.
Dialogue: 0,0:24:13.64,0:24:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson, aku mau tanya!
Dialogue: 0,0:24:16.48,0:24:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarapan di rumahmu pakai nasi atau roti?
Dialogue: 0,0:24:20.56,0:24:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarapan di rumahku pakai nasi...
Dialogue: 0,0:24:22.90,0:24:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Aliansi "Boku"!
Dialogue: 0,0:24:25.69,0:24:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:24:26.24,0:24:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itulah Aliansi "Boku" terbentuk.
Dialogue: 0,0:24:30.99,0:24:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka semua murid\Nkelas abnormal bisa naik ke Daleth!
Dialogue: 0,0:24:35.91,0:24:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini tentu berkat Tuan Iruma!
Dialogue: 0,0:24:38.29,0:24:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ada Tuan Iruma,\Nkami jadi berhasil naik peringkat!
Dialogue: 0,0:24:42.09,0:24:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Tuan Iruma pun\Nberhasil naik ke peringkat He!
Dialogue: 0,0:24:45.80,0:24:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh mengesankan, Tuan Iruma.
Dialogue: 0,0:24:48.13,0:24:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:49.76,0:24:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Di Balik Tatapan".
Dialogue: 0,0:24:51.34,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Amy sudah kembali ke Babyls?
