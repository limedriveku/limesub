Dialogue: 0,0:00:08.95,0:00:16.25,sign,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:01:29.99,0:01:30.99,sign,,0000,0000,0000,,RAPAT SAHABAT
Dialogue: 0,0:02:55.28,0:03:00.00,sign,,0000,0000,0000,,MULIA, AGUNG, LUHUR
Dialogue: 0,0:03:16.51,0:03:17.43,sign,,0000,0000,0000,,RAPAT UNTUK MEMBAHAS\NARTI DARI "TEMAN" DAN "SAHABAT"!
Dialogue: 0,0:03:20.93,0:03:21.97,sign,,0000,0000,0000,,MENURUT AZZPEDIA - KUMPULAN KUTIPAN\NTENTANG IRUMA DISUSUN
Dialogue: 0,0:03:21.97,0:03:23.63,sign,,0000,0000,0000,,BERDASARKAN OPINI ASMODEUS
Dialogue: 0,0:03:23.63,0:03:24.89,sign,,0000,0000,0000,,YANG SEENAKNYA DAN BIAS
Dialogue: 0,0:03:54.17,0:03:56.97,sign,,0000,0000,0000,,MENURUT AZZPEDIA
Dialogue: 0,0:03:56.97,0:03:59.76,sign,,0000,0000,0000,,KUMPULAN KUTIPAN TENTANG IRUMA DISUSUN
Dialogue: 0,0:03:59.76,0:04:01.15,sign,,0000,0000,0000,,BERDASARKAN OPINI ASMODEUS
Dialogue: 0,0:04:01.15,0:04:02.05,sign,,0000,0000,0000,,YANG SEENAKNYA DAN BIAS
Dialogue: 0,0:04:18.99,0:04:21.91,sign,,0000,0000,0000,,SEMUANYA ADALAH TEMAN
Dialogue: 0,0:06:41.26,0:06:45.09,sign,,0000,0000,0000,,TEMAN
Dialogue: 0,0:09:53.11,0:09:54.99,sign,,0000,0000,0000,,PELINDUNG SAHABAT
Dialogue: 0,0:10:25.81,0:10:30.19,sign,,0000,0000,0000,,SERAHKAN PADAKU!
Dialogue: 0,0:10:31.78,0:10:32.61,sign,,0000,0000,0000,,RAPAT MESRA LIED
Dialogue: 0,0:11:42.35,0:11:47.35,sign,,0000,0000,0000,,SIING
Dialogue: 0,0:12:51.33,0:12:53.38,sign,,0000,0000,0000,,RAPAT PARA COWOK
Dialogue: 0,0:12:53.38,0:12:55.88,sign,,0000,0000,0000,,RAPAT COWOK - CARA LIED BISA\NBERMESRAAN DENGAN MBAK
Dialogue: 0,0:15:56.77,0:16:02.27,sign,,0000,0000,0000,,PERKUMPULAN BANGSAWAN - DEVIRUM
Dialogue: 0,0:16:13.66,0:16:14.54,sign,,0000,0000,0000,,IBLIS KELAS ATAS - COWOK TAMPAN
Dialogue: 0,0:17:03.29,0:17:05.25,sign,,0000,0000,0000,,SIDANG IBLIS
Dialogue: 0,0:18:17.83,0:18:19.58,sign,,0000,0000,0000,,BERSALAH
Dialogue: 0,0:18:47.65,0:18:49.15,sign,,0000,0000,0000,,BERSALAH
Dialogue: 0,0:19:19.81,0:19:21.56,sign,,0000,0000,0000,,BERSALAH
Dialogue: 0,0:19:30.32,0:19:31.90,sign,,0000,0000,0000,,BERSALAH KARENA MESUM
Dialogue: 0,0:19:31.90,0:19:33.49,sign,,0000,0000,0000,,BERSALAH KARENA MERAYU
Dialogue: 0,0:19:33.49,0:19:35.32,sign,,0000,0000,0000,,SUPER BERSALAH
Dialogue: 0,0:20:03.93,0:20:07.14,sign,,0000,0000,0000,,ZONA TERLARANG COWOK SEKOLAH IBLIS
Dialogue: 0,0:20:49.44,0:20:52.44,sign,,0000,0000,0000,,KONTAK DITAMBAHKAN
Dialogue: 0,0:21:40.74,0:21:43.95,sign,,0000,0000,0000,,KONTAK BARU
Dialogue: 0,0:21:56.54,0:21:59.46,sign,,0000,0000,0000,,KIRIM PESAN KE ELIZA!
Dialogue: 0,0:22:21.53,0:22:24.32,sign,,0000,0000,0000,,RAPAT PARA COWOK
Dialogue: 0,0:22:24.32,0:22:28.74,sign,,0000,0000,0000,,RAPAT PARA COWOK KE 2 - PESAN PERTAMA
Dialogue: 0,0:24:06.05,0:24:09.39,sign,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:24:29.99,0:24:32.20,sign,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:01:30.99,0:01:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Rapat Sahabat".
Dialogue: 0,0:01:35.33,0:01:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas satu sekolah iblis Babyls,\Nkelas abnormal.
Dialogue: 0,0:01:39.37,0:01:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sempat diperlakukan\Nsebagai murid buangan,
Dialogue: 0,0:01:43.67,0:01:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka sekelas berhasil naik\Nke peringkat Daleth di kelas satu.
Dialogue: 0,0:01:49.67,0:01:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja mereka jadi\Npusat perhatian di Babyls.
Dialogue: 0,0:01:54.51,0:01:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berita tentang mereka...
Dialogue: 0,0:01:58.18,0:02:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersebar ke penjuru dunia iblis.
Dialogue: 0,0:02:00.81,0:02:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak iblis yang tahu\Ntentang keberadaan mereka.
Dialogue: 0,0:02:09.86,0:02:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas abnormal memang luar biasa, ya.
Dialogue: 0,0:02:13.65,0:02:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang kita tidak menang,
Dialogue: 0,0:02:17.03,0:02:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Karpet Lilith luar biasa.
Dialogue: 0,0:02:20.62,0:02:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dicintai seperti Lilith,\Nwanita pasti akan bahagia.
Dialogue: 0,0:02:26.29,0:02:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi daripada dicintai,\Nlebih baik mencintai.
Dialogue: 0,0:02:31.13,0:02:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti saat musim dingin saat itu...
Dialogue: 0,0:02:39.89,0:02:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menduganya,\Ntapi mereka memang beda!
Dialogue: 0,0:02:44.06,0:02:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang pakai\Nkelas Royal One, sih, ya.
Dialogue: 0,0:02:46.31,0:02:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran apa yang iblis kelas atas\Nseperti mereka biasanya bicarakan.
Dialogue: 0,0:02:50.82,0:02:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas melampaui imajinasi kita.
Dialogue: 0,0:02:55.28,0:03:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja hal yang mulia, agung, dan luhur.
Dialogue: 0,0:03:03.79,0:03:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita akan mulai...
Dialogue: 0,0:03:11.92,0:03:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rapat untuk membahas\Narti dari "teman" dan "sahabat"!
Dialogue: 0,0:03:18.43,0:03:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, "teman".
Dialogue: 0,0:03:21.97,0:03:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menghabiskan waktu bersama,
Dialogue: 0,0:03:23.63,0:03:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik suka dan duka.
Dialogue: 0,0:03:24.89,0:03:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu merupakan perjanjian darah\Nuntuk mempertaruhkan nyawa demi orang itu.
Dialogue: 0,0:03:28.56,0:03:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sumpah Azz-Azz dan Clarin\Npada Iruma, kan?
Dialogue: 0,0:03:32.48,0:03:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata lebih serius dari dugaanku.
Dialogue: 0,0:03:34.94,0:03:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, "sahabat" jauh lebih tinggi dari itu!
Dialogue: 0,0:03:39.99,0:03:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukti yang hanya bisa didapat\Noleh "teman" yang terpilih.
Dialogue: 0,0:03:44.20,0:03:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, tul.
Dialogue: 0,0:03:51.50,0:03:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:54.17,0:03:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu merupakan perjanjian jiwa
Dialogue: 0,0:03:56.97,0:03:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melayani orang itu seumur hidup.
Dialogue: 0,0:03:59.76,0:04:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu perjanjian selama-lamanya.
Dialogue: 0,0:04:02.05,0:04:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Be-Berat!
Dialogue: 0,0:04:03.72,0:04:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa enggak gawat, tuh?
Dialogue: 0,0:04:04.89,0:04:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat sekali.
Dialogue: 0,0:04:05.64,0:04:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi genting.
Dialogue: 0,0:04:07.06,0:04:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu paham, kan?
Dialogue: 0,0:04:09.81,0:04:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sahabat" adalah hak khusus untukku\Ndan Clara bodoh saja.
Dialogue: 0,0:04:13.44,0:04:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berbahagialah!
Dialogue: 0,0:04:14.94,0:04:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma berkata padaku.
Dialogue: 0,0:04:17.45,0:04:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menganggap semua yang ada
Dialogue: 0,0:04:18.99,0:04:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di kelas abnormal adalah temannya.
Dialogue: 0,0:04:21.91,0:04:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membuat perjanjian\Ntanpa persetujuan kita?
Dialogue: 0,0:04:24.99,0:04:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali.
Dialogue: 0,0:04:27.66,0:04:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma!
Dialogue: 0,0:04:28.79,0:04:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali, Irumachi.
Dialogue: 0,0:04:30.42,0:04:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah selesai memetik bunganya.
Dialogue: 0,0:04:33.17,0:04:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai oleh-oleh, aku bawa—
Dialogue: 0,0:04:34.80,0:04:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma, apa benar kami temanmu?
Dialogue: 0,0:04:38.55,0:04:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu benar?
Dialogue: 0,0:04:39.72,0:04:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah?
Dialogue: 0,0:04:41.26,0:04:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dengar dari Azz-Azz, sih.
Dialogue: 0,0:04:43.39,0:04:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NKalian sudah dengar, ya.
Dialogue: 0,0:04:47.10,0:04:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:04:49.69,0:04:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menganggap\Nkalian semua temanku sejak lama.
Dialogue: 0,0:04:55.57,0:04:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyuman polos?
Dialogue: 0,0:04:57.57,0:04:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengatakan\Nhal yang tidak masuk akal!
Dialogue: 0,0:05:00.32,0:05:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemikiran iblis peringkat He\Nmemang beda, ya.
Dialogue: 0,0:05:04.08,0:05:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau mempertaruhkan nyawa\Nagak berlebihan.
Dialogue: 0,0:05:06.58,0:05:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya akan mempertaruhkan\Nnyawa pada wanita!
Dialogue: 0,0:05:09.83,0:05:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:05:12.38,0:05:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga termasuk temanmu?
Dialogue: 0,0:05:16.92,0:05:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:05:19.59,0:05:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, koreksi!
Dialogue: 0,0:05:21.55,0:05:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada aku jadi temanmu,\Naku mau kamu yang jadi temanku!
Dialogue: 0,0:05:25.10,0:05:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau mempertaruhkan nyawa,\Nlebih baik kamu yang melakukan!
Dialogue: 0,0:05:28.22,0:05:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nya-Nyawa?
Dialogue: 0,0:05:29.89,0:05:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau demi Ratu, aku rela!
Dialogue: 0,0:05:31.60,0:05:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita adalah rival, bukan teman!
Dialogue: 0,0:05:36.11,0:05:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, ayo latih tanding!
Dialogue: 0,0:05:38.87,0:05:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Aku juga!
Dialogue: 0,0:05:40.11,0:05:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau ikut.
Dialogue: 0,0:05:43.61,0:05:44.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma—
Dialogue: 0,0:05:44.99,0:05:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-teman, apa yang kalian lakukan?
Dialogue: 0,0:05:46.95,0:05:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu beliau!
Dialogue: 0,0:05:47.74,0:05:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:49.75,0:05:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kami lakukan?
Dialogue: 0,0:05:51.00,0:05:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beliau!
Dialogue: 0,0:05:52.00,0:05:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, ada apa ini?\NTunggu!
Dialogue: 0,0:05:53.71,0:05:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma yang maju duluan,\Nayo mulai!
Dialogue: 0,0:05:56.09,0:05:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:05:56.79,0:05:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku saja yang maju!
Dialogue: 0,0:05:58.17,0:05:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi, sih?
Dialogue: 0,0:05:59.46,0:06:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irumachi, rasakan ini!
Dialogue: 0,0:06:00.63,0:06:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:01.42,0:06:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma!
Dialogue: 0,0:06:03.80,0:06:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:06:06.76,0:06:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:06:07.68,0:06:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aksi melempar misterius sebagai bentuk\Nperayaan itu berlangsung 666 detik.
Dialogue: 0,0:06:12.81,0:06:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kalian tenang\Nsebelum ada yang terluka.
Dialogue: 0,0:06:16.81,0:06:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:06:18.23,0:06:19.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami terbawa suasana.
Dialogue: 0,0:06:19.94,0:06:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelepasan.
Dialogue: 0,0:06:20.90,0:06:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang ada kalanya kita\Ntiba-tiba semangat tanpa alasan.
Dialogue: 0,0:06:24.07,0:06:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kesempatan ini, aku akan jelaskan\Napa itu artinya "teman"!
Dialogue: 0,0:06:27.74,0:06:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik, ya!
Dialogue: 0,0:06:29.33,0:06:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irumachi, semangat.
Dialogue: 0,0:06:30.83,0:06:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Iruma.
Dialogue: 0,0:06:41.26,0:06:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman adalah sebutan bagi mereka yang akrab.
Dialogue: 0,0:06:45.09,0:06:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya seperti makan\Ndan bermain bersama.
Dialogue: 0,0:06:48.64,0:06:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka adalah sosok yang berharga.
Dialogue: 0,0:06:59.19,0:07:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu saja?
Dialogue: 0,0:07:00.73,0:07:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:03.19,0:07:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan?
Dialogue: 0,0:07:04.95,0:07:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata cuma begitu.
Dialogue: 0,0:07:07.95,0:07:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nkita sudah lama jadi teman.
Dialogue: 0,0:07:10.79,0:07:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:07:11.49,0:07:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:12.16,0:07:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:07:14.71,0:07:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:07:17.96,0:07:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlalu wajar, jadi agak kecewa.
Dialogue: 0,0:07:21.42,0:07:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat seperti perkataan Ratu.
Dialogue: 0,0:07:23.26,0:07:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat alami.
Dialogue: 0,0:07:24.80,0:07:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak mengejutkan.
Dialogue: 0,0:07:26.84,0:07:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rival sekaligus teman, ya.\NBegitu, toh.
Dialogue: 0,0:07:31.39,0:07:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman.
Dialogue: 0,0:07:33.02,0:07:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya...
Dialogue: 0,0:07:37.77,0:07:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjelasanmu yang berlebihan!
Dialogue: 0,0:07:40.86,0:07:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai perjanjian selama-lamanya!\NBerlebihan sekali!
Dialogue: 0,0:07:43.23,0:07:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah?
Dialogue: 0,0:07:45.07,0:07:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sebelah mana?
Dialogue: 0,0:07:46.53,0:07:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, aku jadi bingung kita ini\Nbicara bahasa yang sama atau tidak.
Dialogue: 0,0:07:50.99,0:07:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz kadang bodoh, sih.
Dialogue: 0,0:07:53.74,0:07:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.
Dialogue: 0,0:07:54.62,0:07:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:07:56.91,0:07:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bertarung?
Dialogue: 0,0:07:58.87,0:08:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:08:00.54,0:08:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman dan sahabat?
Dialogue: 0,0:08:04.42,0:08:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengetahuan Iruma agak beda, ya.
Dialogue: 0,0:08:06.67,0:08:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga tidak tahu Idola Iblis.
Dialogue: 0,0:08:08.88,0:08:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berasal dari tempat terpencil?
Dialogue: 0,0:08:10.80,0:08:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kurang lebih begitu.
Dialogue: 0,0:08:16.18,0:08:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tradisi dan semboyan\Nmemang beda tiap daerah, sih.
Dialogue: 0,0:08:20.19,0:08:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bumbu makanan mereka juga.
Dialogue: 0,0:08:22.69,0:08:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Napa Pak Kalego juga teman?
Dialogue: 0,0:08:29.41,0:08:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sepertinya beda dari teman.
Dialogue: 0,0:08:32.53,0:08:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau terlalu mulia.
Dialogue: 0,0:08:33.70,0:08:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Kakek bersih-bersih?
Dialogue: 0,0:08:35.28,0:08:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa teman.
Dialogue: 0,0:08:37.00,0:08:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mastermu?
Dialogue: 0,0:08:38.03,0:08:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master ya master.
Dialogue: 0,0:08:40.03,0:08:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan empat cewek\Ndari kelas sebelah?
Dialogue: 0,0:08:45.05,0:08:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada disebut temanku,
Dialogue: 0,0:08:47.76,0:08:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa mereka lebih cocok disebut\Ntemannya Gapp dan Agares.
Dialogue: 0,0:08:53.22,0:08:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman, ya?
Dialogue: 0,0:08:59.06,0:09:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantas, "sahabat" itu apa?
Dialogue: 0,0:09:03.36,0:09:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, teman yang lebih dekat denganmu.
Dialogue: 0,0:09:08.86,0:09:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:09:09.99,0:09:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bukan sahabatmu?
Dialogue: 0,0:09:18.33,0:09:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:09:19.41,0:09:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding anak kelas lain yang temanmu,\Nkami adalah sahabatmu!
Dialogue: 0,0:09:22.63,0:09:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Lebih tinggi, lebih baik!
Dialogue: 0,0:09:27.46,0:09:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sahabat" terdengar menakjubkan!
Dialogue: 0,0:09:29.42,0:09:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu boleh jadi sahabatku, lo.
Dialogue: 0,0:09:32.18,0:09:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ratu merasa senang!
Dialogue: 0,0:09:33.47,0:09:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sahabat!
Dialogue: 0,0:09:34.76,0:09:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sahabat abadi!
Dialogue: 0,0:09:36.18,0:09:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master juga.
Dialogue: 0,0:09:41.23,0:09:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mau, Tuan Iruma!
Dialogue: 0,0:09:43.10,0:09:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dengarkan perkataan mereka!
Dialogue: 0,0:09:45.73,0:09:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sahabat" cukup dua orang saja!
Dialogue: 0,0:09:47.78,0:09:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya tidak boleh!
Dialogue: 0,0:09:48.90,0:09:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang bisa diputuskan begitu?
Dialogue: 0,0:09:50.24,0:09:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelindung Sahabat!
Dialogue: 0,0:09:55.74,0:09:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sulit untuk melewati mereka berdua.
Dialogue: 0,0:09:59.25,0:10:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:10:01.50,0:10:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kelas abnormal pun entah bagaimana\Nakhirnya paham apa arti teman dan sahabat.
Dialogue: 0,0:10:07.84,0:10:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pun merayakan dengan...
Dialogue: 0,0:10:09.51,0:10:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Hore!
Dialogue: 0,0:10:12.97,0:10:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Teman.\N- Sahabat.
Dialogue: 0,0:10:13.93,0:10:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melempar Iruma selama\N666 detik sebanyak enam set.
Dialogue: 0,0:10:20.35,0:10:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:32.61,0:10:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Rapat Mesra Lied".
Dialogue: 0,0:10:39.20,0:10:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei.
Dialogue: 0,0:10:40.29,0:10:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gapp, Tuan, kapan-kapan ke Devicon, yuk.
Dialogue: 0,0:10:43.91,0:10:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, suaramu terlalu besar.
Dialogue: 0,0:10:46.88,0:10:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Repot kalau sampai ada yang dengar, kan?
Dialogue: 0,0:10:49.75,0:10:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:10:51.71,0:10:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, setelah melihat aksi kalian\Ndi festival musik,
Dialogue: 0,0:10:54.68,0:10:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak yang ingin mengajak\NTuan dan Gapp ke Devicon.
Dialogue: 0,0:10:58.01,0:11:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu, ya?
Dialogue: 0,0:11:00.14,0:11:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman kita jadi bertambah lagi.
Dialogue: 0,0:11:03.31,0:11:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kan?
Dialogue: 0,0:11:06.06,0:11:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:07.02,0:11:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:11:08.27,0:11:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan bertemu dan berpisah\Ndengan berbagai macam cinta.
Dialogue: 0,0:11:11.69,0:11:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang kelak jadi bekal hidupmu.
Dialogue: 0,0:11:14.53,0:11:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, malam itu kami\Nbertemu di tepi laut,
Dialogue: 0,0:11:18.87,0:11:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pun tenggelam
Dialogue: 0,0:11:20.45,0:11:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dalam lautan yang adalah diriku\N- Mishima.
Dialogue: 0,0:11:22.29,0:11:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tak pernah kembali lagi.
Dialogue: 0,0:11:25.04,0:11:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesampingkan itu.
Dialogue: 0,0:11:26.33,0:11:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita akan main gim raja iblis?
Dialogue: 0,0:11:28.92,0:11:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Gapp, kamu terlalu buru-buru.
Dialogue: 0,0:11:31.88,0:11:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku terlalu buru-buru, ya.
Dialogue: 0,0:11:47.35,0:11:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mesra-mesraan.
Dialogue: 0,0:11:53.78,0:11:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Lied.
Dialogue: 0,0:11:57.20,0:11:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh.
Dialogue: 0,0:12:00.03,0:12:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak juga tetap Mbak.
Dialogue: 0,0:12:02.45,0:12:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, Mbak adalah Mbak, sih.
Dialogue: 0,0:12:08.12,0:12:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lied.
Dialogue: 0,0:12:10.54,0:12:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak.
Dialogue: 0,0:12:13.21,0:12:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pengin mesra-mesraan\Ndengan Mbak.
Dialogue: 0,0:12:16.67,0:12:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colek-colek atau peluk-peluk.
Dialogue: 0,0:12:19.26,0:12:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kami harus tukar\Nkontak Mine dulu, terus...
Dialogue: 0,0:12:26.27,0:12:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson.
Dialogue: 0,0:12:27.60,0:12:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di sini, kan?\NDi sekitar sini! Hei!
Dialogue: 0,0:12:30.31,0:12:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, cuma perasaanmu.
Dialogue: 0,0:12:31.69,0:12:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran ada, dong!
Dialogue: 0,0:12:34.36,0:12:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, aku tidak dengar kalau kamu\Ningin mesra-mesraan dengan Mbak,
Dialogue: 0,0:12:37.36,0:12:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menyeringai seperti orang bodoh\Ndengan imajinasi liarnya,
Dialogue: 0,0:12:40.49,0:12:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau ingin bertukar kontak Mine!\NAku sama sekali tidak dengar!
Dialogue: 0,0:12:43.62,0:12:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo—\NJangan keras-keras!
Dialogue: 0,0:12:45.41,0:12:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colek-colek atau peluk-peluk.
Dialogue: 0,0:12:46.70,0:12:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah cukup!\N- Ribut sekali, ya.
Dialogue: 0,0:12:49.04,0:12:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:12:51.33,0:12:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu...
Dialogue: 0,0:12:55.88,0:13:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah kenapa aku mengumpulkan\Nsemua cowok dari kelas abnormal.
Dialogue: 0,0:13:02.14,0:13:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang, Tuan Iruma.
Dialogue: 0,0:13:04.51,0:13:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan langsung tinggalkan aku, dong!
Dialogue: 0,0:13:06.39,0:13:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temanmu sedang kesusahan, nih!
Dialogue: 0,0:13:08.56,0:13:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaramu terlalu besar.
Dialogue: 0,0:13:09.89,0:13:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:13:11.40,0:13:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak, Gapp.
Dialogue: 0,0:13:13.06,0:13:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedari awal, apa dirimu suka Elizabetta?
Dialogue: 0,0:13:27.29,0:13:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditanya suka...
Dialogue: 0,0:13:29.12,0:13:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku tertarik, sih.
Dialogue: 0,0:13:32.79,0:13:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau ditanya...
Dialogue: 0,0:13:36.75,0:13:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jadi goyah, ya.
Dialogue: 0,0:13:38.09,0:13:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara yang jelas.
Dialogue: 0,0:13:39.26,0:13:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jelaskan dengan jelas dan logis.
Dialogue: 0,0:13:41.09,0:13:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kutanya balik!
Dialogue: 0,0:13:42.34,0:13:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada di antara kalian yang benci Mbak?
Dialogue: 0,0:13:44.43,0:13:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada!\NKami suka Mbak!
Dialogue: 0,0:13:46.39,0:13:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:13:47.51,0:13:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka semua wanita\Ndari segala makhluk hidup!
Dialogue: 0,0:13:51.02,0:13:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tanya sampai sejauh itu, sih.
Dialogue: 0,0:13:54.52,0:13:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya kamu ingin akrab dengan Eliza?
Dialogue: 0,0:13:59.11,0:14:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana\Nkalau kalian pergi main berdua?
Dialogue: 0,0:14:06.83,0:14:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi main berdua...
Dialogue: 0,0:14:09.29,0:14:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama Mbak?
Dialogue: 0,0:14:12.87,0:14:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan-jalan.
Dialogue: 0,0:14:15.42,0:14:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan.
Dialogue: 0,0:14:17.92,0:14:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertualang.
Dialogue: 0,0:14:20.55,0:14:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terdampar.
Dialogue: 0,0:14:28.06,0:14:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikah.
Dialogue: 0,0:14:31.48,0:14:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dibanjiri fantasi hanya\Ndalam beberapa detik.
Dialogue: 0,0:14:35.10,0:14:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yap, fantasi adalah\Nnutrisi bagi seorang pria.
Dialogue: 0,0:14:38.48,0:14:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ada beberapa hal yang aneh?
Dialogue: 0,0:14:41.36,0:14:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau mengajak Mbak berbelanja?
Dialogue: 0,0:14:43.74,0:14:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia mungkin suka—
Dialogue: 0,0:14:45.24,0:14:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu dulu.
Dialogue: 0,0:14:46.49,0:14:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belanja adalah medan perang wanita.
Dialogue: 0,0:14:50.70,0:14:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medan perang wanita?
Dialogue: 0,0:14:54.25,0:14:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemimpinnya pasti wanita.
Dialogue: 0,0:14:56.92,0:14:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan fokus ke pakaian\Ndan mengurangi waktu kalian bersama.
Dialogue: 0,0:14:59.67,0:15:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi...
Dialogue: 0,0:15:02.34,0:15:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selera kita akan diuji!
Dialogue: 0,0:15:05.26,0:15:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu benar.
Dialogue: 0,0:15:10.97,0:15:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu ke Walter Park saja?
Dialogue: 0,0:15:13.77,0:15:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pernah ke sana sekali.
Dialogue: 0,0:15:16.73,0:15:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:15:18.48,0:15:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Aquacase?
Dialogue: 0,0:15:21.11,0:15:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana menyenangkan, lo.
Dialogue: 0,0:15:22.73,0:15:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil memulai\Ndengan rintangan setinggi itu!
Dialogue: 0,0:15:26.24,0:15:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini bilang apa, sih?
Dialogue: 0,0:15:28.12,0:15:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, bakal pakai pakaian renang, lo!
Dialogue: 0,0:15:29.99,0:15:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ngajak dia ke sana,\Nrasanya mesum banget!
Dialogue: 0,0:15:32.24,0:15:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa!
Dialogue: 0,0:15:33.25,0:15:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum.
Dialogue: 0,0:15:34.37,0:15:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.
Dialogue: 0,0:15:35.12,0:15:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu malu.
Dialogue: 0,0:15:36.21,0:15:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otak kotor.
Dialogue: 0,0:15:38.04,0:15:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku mesum, ya?
Dialogue: 0,0:15:39.71,0:15:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Tuan Iruma tidak terbiasa\Ndengan interaksi semacam itu!
Dialogue: 0,0:15:43.59,0:15:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu fakta.
Dialogue: 0,0:15:45.84,0:15:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Tuan Iruma.
Dialogue: 0,0:15:47.76,0:15:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau mengajak perempuan,\NAnda harus mengatur janji temu
Dialogue: 0,0:15:51.47,0:15:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengajaknya makan bersama\Nsetelah melakukannya berulang kali.
Dialogue: 0,0:15:56.77,0:15:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, ikut "Devirum"
Dialogue: 0,0:15:59.61,0:16:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memastikan kecocokan kalian.
Dialogue: 0,0:16:02.27,0:16:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, memperkenalkan diri ke orang tua\Nmasing-masing di saat yang tepat...
Dialogue: 0,0:16:05.74,0:16:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu berat.
Dialogue: 0,0:16:07.53,0:16:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya mengajak perempuan\Nitu gampang?
Dialogue: 0,0:16:12.16,0:16:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar cowok ganteng.
Dialogue: 0,0:16:16.08,0:16:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mengajak Mbak memang agak sulit.
Dialogue: 0,0:16:20.21,0:16:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak bahkan makin cantik\Nsetelah festival musik.
Dialogue: 0,0:16:23.17,0:16:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Layaknya dewi meski dia iblis!
Dialogue: 0,0:16:26.01,0:16:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cantik banget, ya.
Dialogue: 0,0:16:28.55,0:16:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adu batu, gunting, kertas untuk camilan?\NAku juga mau ikut!
Dialogue: 0,0:16:31.64,0:16:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepribadiannya juga bagus\Ndan senang ada di dekatnya.
Dialogue: 0,0:16:34.10,0:16:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cantik, akrab pula.
Dialogue: 0,0:16:36.60,0:16:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ganti warna kukuku!
Dialogue: 0,0:16:38.77,0:16:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya pun enak.\NAromanya harum.
Dialogue: 0,0:16:44.11,0:16:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:47.36,0:16:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak sangat berkilau\Nsaat festival musik,
Dialogue: 0,0:16:51.03,0:16:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi...
Dialogue: 0,0:16:53.66,0:16:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa dari kalian\Nada yang dekat dengannya, kan?
Dialogue: 0,0:16:59.29,0:17:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita akan\Nmulai sidang iblis!
Dialogue: 0,0:17:06.05,0:17:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejahatan, "terlalu banyak\Nbersenang-senang dengan Mbak."
Dialogue: 0,0:17:09.51,0:17:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini, aku menuduh tiga iblis.
Dialogue: 0,0:17:14.89,0:17:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga?
Dialogue: 0,0:17:16.27,0:17:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siapa?\N- Ini apa sih?
Dialogue: 0,0:17:21.06,0:17:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap tenang!
Dialogue: 0,0:17:22.77,0:17:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, Sabnock Saburo!
Dialogue: 0,0:17:29.53,0:17:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terdakwa telah melakukan\Nkejahatan serius.
Dialogue: 0,0:17:34.16,0:17:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan apa?
Dialogue: 0,0:17:36.54,0:17:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memiliki bukti yang jelas!
Dialogue: 0,0:17:40.25,0:17:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Chet ♪
Dialogue: 0,0:17:41.46,0:17:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dirinya pria yang amat rakus ♪
Dialogue: 0,0:17:44.88,0:17:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menggenggam tangannya!\NLihat, ini!
Dialogue: 0,0:17:50.22,0:17:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi, pria ini...\Nmenaruh Mbak di pangkuannya!
Dialogue: 0,0:17:54.76,0:17:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal penampilanku\Nlangsung kelar setelah ditolak.
Dialogue: 0,0:18:02.89,0:18:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah skenarionya memang begitu?
Dialogue: 0,0:18:05.56,0:18:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, hanya aku\Nyang bisa menggendong Eliza.
Dialogue: 0,0:18:10.03,0:18:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:11.19,0:18:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai fraktal, aku juga bisa\Nmelakukannya dengan mudah!
Dialogue: 0,0:18:14.99,0:18:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada rasa penyesalan!\NBersalah!
Dialogue: 0,0:18:17.83,0:18:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjut!
Dialogue: 0,0:18:19.58,0:18:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson Soi!
Dialogue: 0,0:18:22.37,0:18:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, kamu yang ambil\Nsemua bagian enaknya.
Dialogue: 0,0:18:26.00,0:18:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti lukisan saja!\NSungguh penampilan yang sempurna!
Dialogue: 0,0:18:30.46,0:18:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu kamu sedang\Nmarah atau memujinya.
Dialogue: 0,0:18:32.76,0:18:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:18:34.34,0:18:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hasil dari upayaku yang telah berusaha\Nsemaksimal mungkin sebagai tim musik.
Dialogue: 0,0:18:38.21,0:18:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja...
Dialogue: 0,0:18:41.43,0:18:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat merasakan\Nhati kami terhubung, sih.
Dialogue: 0,0:18:44.69,0:18:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, Purson!\NJangan terbawa suasana begitu!
Dialogue: 0,0:18:47.65,0:18:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersalah.
Dialogue: 0,0:18:50.73,0:18:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tenang dulu, Lied.
Dialogue: 0,0:18:53.28,0:18:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu berekspresi\Nseolah tidak bersalah?
Dialogue: 0,0:18:57.78,0:19:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketiga, Iruma.
Dialogue: 0,0:19:03.62,0:19:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irumachi.
Dialogue: 0,0:19:06.21,0:19:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma.
Dialogue: 0,0:19:08.29,0:19:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? A-Aku juga?
Dialogue: 0,0:19:10.80,0:19:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu sudah dekat\Ndengan banyak cewek,
Dialogue: 0,0:19:14.76,0:19:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu masih menyerahkan\Nsurat cinta ke Mbak!
Dialogue: 0,0:19:19.81,0:19:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bersalah.
Dialogue: 0,0:19:21.56,0:19:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersalah.
Dialogue: 0,0:19:27.48,0:19:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukum mati!
Dialogue: 0,0:19:28.52,0:19:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz juga?
Dialogue: 0,0:19:35.32,0:19:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:19:38.41,0:19:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak melupakanmu, Jazz.
Dialogue: 0,0:19:41.58,0:19:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sidang iblis ditunda dulu!
Dialogue: 0,0:19:52.55,0:19:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar.
Dialogue: 0,0:19:54.09,0:19:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak adalah sosok mulia dan terhormat.
Dialogue: 0,0:19:57.43,0:19:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu...
Dialogue: 0,0:19:59.34,0:20:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah zona terlarang\Nbagi para murid Babyls!
Dialogue: 0,0:20:07.14,0:20:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo buat kesepakatan bersama\Nagar tidak ada yang curi start.
Dialogue: 0,0:20:10.15,0:20:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya!
Dialogue: 0,0:20:13.28,0:20:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, silakan.
Dialogue: 0,0:20:18.36,0:20:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:20:20.95,0:20:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Lied ada?
Dialogue: 0,0:20:27.54,0:20:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:29.46,0:20:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Clara bilang...
Dialogue: 0,0:20:33.42,0:20:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bertukar kontak Mine denganku.
Dialogue: 0,0:20:40.43,0:20:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kupikir ayo kita bertukar kontak.
Dialogue: 0,0:20:44.43,0:20:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh?
Dialogue: 0,0:20:47.39,0:20:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:20:49.44,0:20:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, selesai.
Dialogue: 0,0:20:52.44,0:20:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:21:14.96,0:21:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai bulan,
Dialogue: 0,0:21:17.30,0:21:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harapan masa lalu\Ndan kini telah tercapai,
Dialogue: 0,0:21:21.09,0:21:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bila kupikirkan ponsel ini bersama dirimu.
Dialogue: 0,0:21:25.06,0:21:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lied!
Dialogue: 0,0:21:28.18,0:21:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membuat perjanjian\Ndan melanggarnya dalam lima detik.
Dialogue: 0,0:21:31.27,0:21:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya bahagia sekali.
Dialogue: 0,0:21:32.81,0:21:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang, Tuan Iruma.
Dialogue: 0,0:21:35.48,0:21:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, Lied berhasil mendekat\Nsatu langkah dengan Elizabetta.
Dialogue: 0,0:21:40.74,0:21:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lied!
Dialogue: 0,0:21:48.20,0:21:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat kontak Mbak!
Dialogue: 0,0:21:51.54,0:21:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya ponselku jadi lebih berkilauan!
Dialogue: 0,0:21:55.29,0:21:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:21:56.54,0:21:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari kirim pesan pertama.
Dialogue: 0,0:22:03.09,0:22:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan pertama?
Dialogue: 0,0:22:17.07,0:22:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus kirim apa?
Dialogue: 0,0:22:21.53,0:22:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu...
Dialogue: 0,0:22:24.32,0:22:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari mulai rapat "Bagaimana Lied harus
Dialogue: 0,0:22:26.20,0:22:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengirim pesan pertamanya ke Mbak?"
Dialogue: 0,0:22:28.74,0:22:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang, Tuan Iruma.
Dialogue: 0,0:22:32.71,0:22:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, kembali ke awal.
Dialogue: 0,0:24:06.05,0:24:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tam-Tam-Tam, ba-ba-ba, han-han-han!
Dialogue: 0,0:24:13.85,0:24:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah...
Dialogue: 0,0:24:16.77,0:24:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenggelamlah dalam lautan\Nyang adalah diriku.
Dialogue: 0,0:24:21.02,0:24:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibalut cinta tak berujung,
Dialogue: 0,0:24:24.65,0:24:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlelaplah dengan nyenyak.
Dialogue: 0,0:24:29.99,0:24:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Dosanko di sini.
Dialogue: 0,0:24:32.20,0:24:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pipiku memerah saat melihat orang itu.
Dialogue: 0,0:24:34.37,0:24:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang kamu ingin lebih dekat\Ndan menggenggam tangannya, kan?
Dialogue: 0,0:24:39.08,0:24:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan buru-buru.
Dialogue: 0,0:24:41.63,0:24:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu dan jaraklah yang membuat\Nperasaan makin matang.
Dialogue: 0,0:24:45.42,0:24:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:47.34,0:24:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Selisih Satu Tahun dan Satu Senti".
Dialogue: 0,0:24:49.38,0:24:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mereka yang pernah\Nlewat di hadapanku,
Dialogue: 0,0:24:52.89,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi terbayang\Nsaat kupejamkan mata.
