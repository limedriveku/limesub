Dialogue: 0,0:00:45.48,0:00:52.78,tanda,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:02:06.98,0:02:07.98,tanda,,0000,0000,0000,,MESKI TIDAK TERLIHAT
Dialogue: 0,0:07:29.68,0:07:30.10,tanda,,0000,0000,0000,,BALME
Dialogue: 0,0:07:58.17,0:07:59.79,tanda,,0000,0000,0000,,CUACA HARI INI SANGAT INDAH.
Dialogue: 0,0:07:59.79,0:08:00.88,tanda,,0000,0000,0000,,BICARA SESUATU TENTANG CUACA INDAH...
Dialogue: 0,0:11:35.72,0:11:40.47,tanda,,0000,0000,0000,,WELCOME TO DEMON SCHOOL!
Dialogue: 0,0:11:50.27,0:11:54.28,tanda,,0000,0000,0000,,RUANG TIDUR SIANG - DILARANG BEKERJA
Dialogue: 0,0:12:24.64,0:12:26.39,tanda,,0000,0000,0000,,TERANG!
Dialogue: 0,0:12:28.27,0:12:29.85,tanda,,0000,0000,0000,,GELAP
Dialogue: 0,0:12:40.61,0:12:41.49,tanda,,0000,0000,0000,,CADAR MISTERI - SECRET VEIL
Dialogue: 0,0:12:43.70,0:12:46.75,tanda,,0000,0000,0000,,PERKUMPULAN BANGSAWAN - DEVIRUM
Dialogue: 0,0:15:23.44,0:15:25.70,tanda,,0000,0000,0000,,MENGERJAKAN PR
Dialogue: 0,0:18:25.71,0:18:26.63,tanda,,0000,0000,0000,,SURAT PENGUNDURAN DIRI
Dialogue: 0,0:22:26.49,0:22:27.33,tanda,,0000,0000,0000,,FESTIVAL MUSIK: BESOK!
Dialogue: 0,0:24:05.09,0:24:06.30,tanda,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:24:29.99,0:24:31.07,tanda,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:00:03.09,0:00:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin, kita juga perlu...
Dialogue: 0,0:00:04.93,0:00:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, saling bicara blakblakan.
Dialogue: 0,0:00:08.24,0:00:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belalak?
Dialogue: 0,0:00:09.49,0:00:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:00:10.70,0:00:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk saling memahami dengan baik,
Dialogue: 0,0:00:13.66,0:00:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus saling jujur satu sama lain.
Dialogue: 0,0:00:16.32,0:00:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Valac.
Dialogue: 0,0:00:18.33,0:00:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya!
Dialogue: 0,0:00:26.31,0:00:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, dari aku dulu.
Dialogue: 0,0:00:34.06,0:00:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diamlah.
Dialogue: 0,0:00:35.18,0:00:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah.
Dialogue: 0,0:02:07.98,0:02:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Meski Tidak Terlihat".
Dialogue: 0,0:02:11.49,0:02:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu bergerak sesuka hati!\NSpontan banget, tahu!
Dialogue: 0,0:02:15.87,0:02:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, padahal aku anak\Npaling tenang di rumah.
Dialogue: 0,0:02:18.66,0:02:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong!
Dialogue: 0,0:02:19.87,0:02:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bohong!
Dialogue: 0,0:02:21.20,0:02:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu ceroboh\Ndan cobalah kendalikan dirimu!
Dialogue: 0,0:02:24.46,0:02:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz juga ceroboh!
Dialogue: 0,0:02:26.42,0:02:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sering memutar-mutar kepalaku!
Dialogue: 0,0:02:28.21,0:02:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Rambutku jadi berantakan!\N- Bukan salahku!
Dialogue: 0,0:02:29.96,0:02:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu banyak bergerak!
Dialogue: 0,0:02:32.42,0:02:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat kesepian, kan, Azz-Azz?
Dialogue: 0,0:02:34.51,0:02:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah ke sana?
Dialogue: 0,0:02:37.05,0:02:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu seenaknya saja!
Dialogue: 0,0:02:37.93,0:02:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memanggilku Valac!
Dialogue: 0,0:02:39.18,0:02:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka main gigit!
Dialogue: 0,0:02:40.18,0:02:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku tidak nyaman!
Dialogue: 0,0:02:41.43,0:02:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hubungannya?
Dialogue: 0,0:02:42.56,0:02:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bego!
Dialogue: 0,0:02:43.48,0:02:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bodoh!\N- Dongo!
Dialogue: 0,0:02:44.73,0:02:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bodoh! Bodoh! Bodoh!\N- Si bego kepala kosong!
Dialogue: 0,0:02:46.65,0:02:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Super duper bodoh!\N- Si bego kepala kosong!
Dialogue: 0,0:02:55.59,0:02:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma, kalau kita setidak akur ini...
Dialogue: 0,0:03:00.28,0:03:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil kita bisa sinkron\Nseperti yang lain...
Dialogue: 0,0:03:10.38,0:03:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku kangen Tuan Iruma.\N- Aku kangen Irumachi.
Dialogue: 0,0:03:19.10,0:03:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, barusan...
Dialogue: 0,0:03:21.22,0:03:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan lucu, ya?
Dialogue: 0,0:03:23.35,0:03:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sentuh, sentuh.
Dialogue: 0,0:03:24.27,0:03:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:03:25.89,0:03:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz, aku baru saja\Nmenyadari hal besar.
Dialogue: 0,0:03:30.79,0:03:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, aku yakin...
Dialogue: 0,0:03:34.49,0:03:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin...
Dialogue: 0,0:03:36.40,0:03:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada Irumachi,\Nkita pasti tidak akan bertemu.
Dialogue: 0,0:03:46.55,0:03:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, ya.
Dialogue: 0,0:03:48.33,0:03:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Azz-Azz, kita sangat beruntung, ya.
Dialogue: 0,0:03:54.77,0:03:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:03:56.55,0:03:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu!
Dialogue: 0,0:03:57.80,0:04:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irumachi lebih hebat karena bisa\Nmempertemukan kita berdua!
Dialogue: 0,0:04:01.10,0:04:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, beliau adalah jawabannya!
Dialogue: 0,0:04:03.01,0:04:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma memang sosok yang mampu\Nmelakukan apa yang tidak bisa kita lakukan!
Dialogue: 0,0:04:10.15,0:04:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita temannya Irumachi yang hebat,
Dialogue: 0,0:04:13.52,0:04:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}artinya kita harus\Nsuper jago menari, kan?
Dialogue: 0,0:04:17.57,0:04:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:04:21.45,0:04:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara bodoh.
Dialogue: 0,0:04:25.99,0:04:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara...
Dialogue: 0,0:04:30.92,0:04:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara! Ya, aku Clara!\NNamaku Clara! Clara!
Dialogue: 0,0:04:35.21,0:04:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus berjuang! Juang, juang!\NAku Clara! Clara, nih!
Dialogue: 0,0:04:41.05,0:04:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku mengerti, kok!
Dialogue: 0,0:04:44.10,0:04:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku harus memanggilmu\Ndengan nama juga, ya.
Dialogue: 0,0:04:47.10,0:04:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu...
Dialogue: 0,0:04:50.44,0:04:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu siapa?
Dialogue: 0,0:04:52.81,0:04:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:04:53.56,0:04:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andragoras, kan?
Dialogue: 0,0:04:55.19,0:04:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kasih aku nama aneh begitu!
Dialogue: 0,0:04:56.61,0:04:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asmodeus Andragoras!
Dialogue: 0,0:04:58.19,0:05:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya aku peliharaan!
Dialogue: 0,0:05:00.40,0:05:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salaman!
Dialogue: 0,0:05:00.82,0:05:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah dibilang aku bukan peliharaan!\N- Duduk!
Dialogue: 0,0:05:03.70,0:05:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:05:23.47,0:05:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain tidak akur,\Npemikiran kami pun berbeda.
Dialogue: 0,0:05:26.22,0:05:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya membuatku kesal,\Nbahkan sampai bertengkar.
Dialogue: 0,0:05:29.73,0:05:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi...
Dialogue: 0,0:05:35.73,0:05:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:05:39.24,0:05:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berhasil!\N- Persiapan kita sudah oke.
Dialogue: 0,0:05:40.44,0:05:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kelihatan mantap!\N- Persiapan kita sudah oke.
Dialogue: 0,0:05:41.49,0:05:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Makasih, kalian semua juga luar biasa.\N- Nah, waktunya bergabung dengan tim musik.
Dialogue: 0,0:05:44.24,0:05:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Gya" yang terakhir salah, tuh!
Dialogue: 0,0:05:46.58,0:05:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andragoras juga salah sudut!\NMalah jadi 50 derajat!
Dialogue: 0,0:05:50.25,0:05:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada, Clara bodoh!\NJangan panggil aku dengan nama aneh itu!
Dialogue: 0,0:05:54.75,0:05:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya kita latihan\Nbareng tim musik, ya.
Dialogue: 0,0:05:57.63,0:06:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Iruma sudah makin jago?
Dialogue: 0,0:06:00.42,0:06:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja! Aku tak sabar mendengar\Npermainan piano Irumachi!
Dialogue: 0,0:06:03.18,0:06:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas akan menakjubkan!
Dialogue: 0,0:06:09.64,0:06:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:06:13.23,0:06:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iruma, pakaianmu itu...
Dialogue: 0,0:06:23.70,0:06:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama terpikat\Noleh senyum indahmu,
Dialogue: 0,0:06:27.07,0:06:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta tawa kecilmu\Nyang bagaikan kicauan burung.
Dialogue: 0,0:06:30.39,0:06:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok bunga yang anggun, suci,\Ndan teramat cantik.
Dialogue: 0,0:06:35.29,0:06:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surat cinta yang kutulis\Nkala memikirkanmu ini...
Dialogue: 0,0:06:39.84,0:06:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong diterima.
Dialogue: 0,0:06:46.84,0:06:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak.
Dialogue: 0,0:06:50.81,0:06:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:06:52.81,0:06:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa maksudnya itu, Iruma?\N- Bentar, bentar, bentar.
Dialogue: 0,0:06:54.60,0:06:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Irumachi!\N- Bentar, bentar, bentar.
Dialogue: 0,0:06:55.44,0:06:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oi, dasar pengkhianat!\N- Bentar, bentar, bentar.
Dialogue: 0,0:06:58.31,0:07:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, senangnya.
Dialogue: 0,0:07:00.82,0:07:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tolong putuskan\Nsetelah musiknya berakhir.
Dialogue: 0,0:07:05.53,0:07:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama...
Dialogue: 0,0:07:07.49,0:07:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong dengarkan.
Dialogue: 0,0:07:15.33,0:07:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karpet Lilith.
Dialogue: 0,0:07:17.25,0:07:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah lagu tentang para pria\Nyang berebut cinta seorang wanita cantik.
Dialogue: 0,0:07:21.88,0:07:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok Lilith bak dewi yang diperankan Mbak\Ndan para pria yang memujanya.
Dialogue: 0,0:07:27.18,0:07:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa Balme?
Dialogue: 0,0:07:30.10,0:07:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian pembuka tentang perjuangan cinta\Npara pria dimainkan selembut ini...
Dialogue: 0,0:07:35.21,0:07:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia memutuskan\Nuntuk memainkannya begini?
Dialogue: 0,0:07:47.54,0:07:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang belajar?
Dialogue: 0,0:07:49.82,0:07:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego bilang...
Dialogue: 0,0:07:51.62,0:07:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mainkan seolah kamu akan\Nmemberi Lilith surat cinta!
Dialogue: 0,0:07:55.41,0:07:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau bilang begitu,\Nmakanya aku lagi buat surat cinta.
Dialogue: 0,0:07:58.17,0:07:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah jadi begitu?
Dialogue: 0,0:07:59.79,0:08:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit sekali.
Dialogue: 0,0:08:00.88,0:08:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirkan lebih tentang\Napa yang diinginkan Lilith!
Dialogue: 0,0:08:04.13,0:08:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ucapannya seperti itu,\Nberarti makan bersama saja tidak boleh, ya?
Dialogue: 0,0:08:08.30,0:08:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:08:10.00,0:08:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang diinginkan Lilith, ya?
Dialogue: 0,0:08:13.82,0:08:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melihat ke sini!
Dialogue: 0,0:08:16.60,0:08:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson, vokalis pasti terkenal!
Dialogue: 0,0:08:18.27,0:08:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pasti akan membantu!
Dialogue: 0,0:08:19.81,0:08:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau, ya?
Dialogue: 0,0:08:20.90,0:08:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:08:21.65,0:08:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:08:22.90,0:08:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami butuh bantuanmu, Purson!
Dialogue: 0,0:08:25.69,0:08:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik Mbak maupun kamu...
Dialogue: 0,0:08:27.78,0:08:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar semuanya bisa naik\Nke Daleth! Kumohon!
Dialogue: 0,0:08:30.53,0:08:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tampil mencolok bersama!\NTolong kami, ya!
Dialogue: 0,0:08:33.15,0:08:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon dengan sangat!
Dialogue: 0,0:08:35.77,0:08:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaan Lilith\Nsaat digeromboli para pria, ya?
Dialogue: 0,0:08:42.89,0:08:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia senang atau justru benci?
Dialogue: 0,0:08:48.34,0:08:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bintang kali ini adalah\NMbak dan Purson, tahu!
Dialogue: 0,0:08:51.93,0:08:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya!
Dialogue: 0,0:08:53.51,0:08:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa menciptakan Karpet Lilith\Nversi sendiri!
Dialogue: 0,0:08:57.27,0:09:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego juga bilang\Nkalau aku tak boleh menirunya.
Dialogue: 0,0:09:02.30,0:09:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami coba bermain dengan\Nmembayangkan bagaimana perasaan Lilith.
Dialogue: 0,0:09:11.86,0:09:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, bintang dari karpet Lilith kami...
Dialogue: 0,0:09:15.55,0:09:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukanlah para pria yang tunduk padanya.
Dialogue: 0,0:09:19.71,0:09:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Lilith itu sendiri!
Dialogue: 0,0:09:40.48,0:09:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Pergilah menjauh ♪
Dialogue: 0,0:09:43.02,0:09:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sosokmu memanglah rupawan dan memesona ♪
Dialogue: 0,0:09:45.90,0:09:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tapi hati ini tiada berdebar ♪
Dialogue: 0,0:09:48.82,0:09:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, hari ini pun kunaiki\Ntangga penuh hadiah ♪
Dialogue: 0,0:09:52.57,0:09:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ dan terlelap di ranjang penuh cinta ♪
Dialogue: 0,0:09:57.62,0:10:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, kuingin rasakan cinta\Nyang lebih membara lagi ♪
Dialogue: 0,0:10:21.47,0:10:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak, maukah kamu\Nmenerima surat cintaku ini?
Dialogue: 0,0:10:33.24,0:10:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:10:35.20,0:10:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Naku akan jatuh hati pada tulisanmu
Dialogue: 0,0:10:38.49,0:10:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tak akan pernah\Nbicara denganmu lagi.
Dialogue: 0,0:10:41.20,0:10:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kamu keberatan?
Dialogue: 0,0:10:43.46,0:10:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lilith memang hebat!
Dialogue: 0,0:10:46.21,0:10:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak keren banget!
Dialogue: 0,0:10:47.88,0:10:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lilith memang hebat!
Dialogue: 0,0:10:49.13,0:10:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surat cintanya palsu, kan?
Dialogue: 0,0:10:51.17,0:10:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya alat peraga.
Dialogue: 0,0:10:52.30,0:10:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tenang.
Dialogue: 0,0:10:53.88,0:10:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski masih kasar,\Nsudah mulai terbentuk, ya.
Dialogue: 0,0:10:58.47,0:11:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, setidaknya kalian\Nsudah berdiri di garis awal.
Dialogue: 0,0:11:01.47,0:11:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadaku jadi panas setelah\Nmendengar musik Iruma dan Purson.
Dialogue: 0,0:11:07.35,0:11:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serasa jadi sosok Lilith itu sendiri.
Dialogue: 0,0:11:10.48,0:11:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:11.98,0:11:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bisa berakting\Nlebih memikat lagi.
Dialogue: 0,0:11:15.86,0:11:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar seperti Lilith yang sesungguhnya.
Dialogue: 0,0:11:20.28,0:11:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!\NAku akan menemanimu sampai akhir!
Dialogue: 0,0:11:23.58,0:11:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:11:24.75,0:11:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainanmu hebat sekali.
Dialogue: 0,0:11:27.36,0:11:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan sang Pixie memang luar biasa!
Dialogue: 0,0:11:42.47,0:11:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, kita pilih kostum.
Dialogue: 0,0:11:44.35,0:11:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:11:50.27,0:11:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali seperti santapan penutup.
Dialogue: 0,0:11:51.94,0:11:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, apa aku bisa makan semuanya?
Dialogue: 0,0:11:54.28,0:11:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma, jangan dimakan.
Dialogue: 0,0:11:56.28,0:11:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cocok pakai apa saja,\Njadi bingung, deh.
Dialogue: 0,0:11:59.11,0:12:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:12:00.78,0:12:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini terlalu\Nmencolok untukmu, Gapp?
Dialogue: 0,0:12:02.70,0:12:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan rewel, cepat pilih!
Dialogue: 0,0:12:05.12,0:12:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bagus!
Dialogue: 0,0:12:06.25,0:12:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini lebih bagus.
Dialogue: 0,0:12:08.54,0:12:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin yang ini?
Dialogue: 0,0:12:09.54,0:12:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:12:10.50,0:12:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang jangan mencolok, kan?
Dialogue: 0,0:12:12.04,0:12:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mbak yang harus mencolok, kan?\N- Menurutku... cocok, sih.
Dialogue: 0,0:12:15.55,0:12:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mau yang agak kecil ukurannya.\N- Yang ini juga bagus!
Dialogue: 0,0:12:18.13,0:12:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ah, lengannya sempit.\N- Yang ini juga bagus!
Dialogue: 0,0:12:20.05,0:12:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan ini?
Dialogue: 0,0:12:21.22,0:12:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Venus! Dewi! Perwujudan kecantikan!
Dialogue: 0,0:12:24.64,0:12:26.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manifestasi kecantikan!
Dialogue: 0,0:12:26.39,0:12:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson pakai ini.
Dialogue: 0,0:12:28.27,0:12:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempurnaan mutlak.
Dialogue: 0,0:12:32.27,0:12:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pakai yang begini?
Dialogue: 0,0:12:34.11,0:12:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kostum yang penting, lo.
Dialogue: 0,0:12:36.69,0:12:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok, tuh!
Dialogue: 0,0:12:38.20,0:12:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strategi agar tidak mencolok\Nsudah sempurna.
Dialogue: 0,0:12:41.49,0:12:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secret Veil.
Dialogue: 0,0:12:43.70,0:12:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu digunakan para bangsawan
Dialogue: 0,0:12:45.12,0:12:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyembunyikan wajah di Devirum.
Dialogue: 0,0:12:46.75,0:12:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghalangnya dibuat dengan\Nsihir penghalau deteksi.
Dialogue: 0,0:12:50.62,0:12:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu bisa ikut festival musik\Ntanpa dikenali siapa pun.
Dialogue: 0,0:12:55.13,0:12:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi penonton, kamu akan terlihat\Nseperti bayangan bergoyang.
Dialogue: 0,0:12:59.80,0:13:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari veil yang bergoyang itu,\Nsuara emas meluap keluar!
Dialogue: 0,0:13:05.64,0:13:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Pixie akan cocok!
Dialogue: 0,0:13:07.64,0:13:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengaruhnya di festival musik\Nsangatlah besar.
Dialogue: 0,0:13:10.06,0:13:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Identitasmu tak akan\Nketahuan para murid!
Dialogue: 0,0:13:11.98,0:13:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga cocok dengan\Npandangan dunia Lilith!
Dialogue: 0,0:13:13.94,0:13:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:13:15.38,0:13:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini,
Dialogue: 0,0:13:17.10,0:13:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa tampil bertiga belas!
Dialogue: 0,0:13:22.57,0:13:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena identitasmu sudah disembunyikan,
Dialogue: 0,0:13:24.95,0:13:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong berikan penampilan terbaik, ya!
Dialogue: 0,0:13:29.91,0:13:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan sisanya padaku!
Dialogue: 0,0:13:32.37,0:13:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pesan latar belakang\Nartistiknya dari Studio Jack!
Dialogue: 0,0:13:35.75,0:13:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat peraga kita juga banyak!
Dialogue: 0,0:13:37.30,0:13:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Periasnya pakai yang profesional.
Dialogue: 0,0:13:38.92,0:13:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas kita sepertinya butuh modal besar, ya?
Dialogue: 0,0:13:40.97,0:13:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tidak dibatasi, sih.
Dialogue: 0,0:13:42.84,0:13:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa boleh, ya?
Dialogue: 0,0:13:44.43,0:13:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kamu pikir kita curang, ya?
Dialogue: 0,0:13:46.68,0:13:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak curang, tahu!
Dialogue: 0,0:13:49.56,0:13:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengetahuan, uang, koneksi...
Dialogue: 0,0:13:51.64,0:13:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya adalah aset\Nyang telah kukumpulkan selama ini.
Dialogue: 0,0:13:54.35,0:13:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil dari jerih payahku.
Dialogue: 0,0:13:57.36,0:14:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salahnya menggunakan\Napa yang kudapat selama ini
Dialogue: 0,0:14:00.19,0:14:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk diriku yang sekarang?
Dialogue: 0,0:14:04.20,0:14:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Begitu, toh.\N- Benar juga.
Dialogue: 0,0:14:06.24,0:14:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ratu memang hebat!\N- Gunakan segalanya yang bisa dipakai, kan?
Dialogue: 0,0:14:07.99,0:14:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Perkataan bijak.\N- Gunakan segalanya yang bisa dipakai, kan?
Dialogue: 0,0:14:09.83,0:14:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Perkataan bijak.\N- Jangan melihatku!
Dialogue: 0,0:14:11.21,0:14:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Eggy juga mau pakai?
Dialogue: 0,0:14:13.21,0:14:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:14:13.87,0:14:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru, lo!
Dialogue: 0,0:14:15.42,0:14:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hentikan!\N- Ayo, ayo!
Dialogue: 0,0:14:16.99,0:14:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hentikan!\N- Aset...
Dialogue: 0,0:14:18.38,0:14:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hentikan!\N- Apa jarimu sudah gatal, ya?
Dialogue: 0,0:14:19.92,0:14:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jariku juga sering begitu.
Dialogue: 0,0:14:20.88,0:14:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mainkan sesuatu\Nuntuk memeriahkan suasana, dong.
Dialogue: 0,0:14:23.93,0:14:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau dengar yang biasanya!
Dialogue: 0,0:14:25.64,0:14:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasanya!
Dialogue: 0,0:14:26.72,0:14:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Resital Pixie.
Dialogue: 0,0:14:28.10,0:14:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:14:29.22,0:14:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, kalau begitu...
Dialogue: 0,0:14:33.19,0:14:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segala yang telah kupendam selama ini...
Dialogue: 0,0:14:37.48,0:14:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi diriku saat ini.
Dialogue: 0,0:15:30.20,0:15:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chase. Flow. Flow.
Dialogue: 0,0:15:32.70,0:15:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Chase. Flow. Flow.\N- Katanya kelas A bakal menampilkan
Dialogue: 0,0:15:35.29,0:15:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Flow. Flow. Chase.\N- sesuatu yang bagus, lo.
Dialogue: 0,0:15:36.71,0:15:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Beelze. Quattreu.\N- Wah.
Dialogue: 0,0:15:37.83,0:15:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Beelze. Quattreu.\N- Aku sudah lihat latihan kelas E.
Dialogue: 0,0:15:39.54,0:15:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini pertama kalinya aku latihan sebanyak ini.\N- Permainan mereka gila banget.
Dialogue: 0,0:15:43.38,0:15:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku selalu bermain\Nsesuka hatiku selama ini.
Dialogue: 0,0:15:47.55,0:15:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, menyesuaikan diri dengan\Norang lain tidaklah mudah.
Dialogue: 0,0:15:52.68,0:15:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:15:57.27,0:15:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku akan latihan bersama Iruma
Dialogue: 0,0:15:59.81,0:16:01.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyelesaikannya bersama teman-teman.
Dialogue: 0,0:16:01.94,0:16:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Lied bawa camilan lagi, ya?
Dialogue: 0,0:16:04.90,0:16:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus hati-hati dengan\Nserangan dadakan Clara.
Dialogue: 0,0:16:09.62,0:16:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin Anda mengirim\Nputraku pulang sekarang.
Dialogue: 0,0:16:14.70,0:16:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membiarkan putraku tampil di festival musik\Nadalah hal yang keterlaluan.
Dialogue: 0,0:16:19.06,0:16:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda dengar langsung darinya?
Dialogue: 0,0:16:20.83,0:16:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kami adalah iblis bayangan.
Dialogue: 0,0:16:23.46,0:16:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menguak rahasia adalah hal sepele.
Dialogue: 0,0:16:26.63,0:16:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, alasan aku mengirim\Nputraku ke sekolah kalian
Dialogue: 0,0:16:29.68,0:16:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah untuk melatih kemampuannya\Nsebagai seorang pengintai.
Dialogue: 0,0:16:32.67,0:16:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada gunanya dia sekolah di sana\Nkalau akhirnya mencolok.
Dialogue: 0,0:16:37.60,0:16:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babyls selalu berupaya\Nmemberikan pendidikan terbaik
Dialogue: 0,0:16:41.77,0:16:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar dapat meningkatkan kemampuan\Ndan karakter pada murid.
Dialogue: 0,0:16:45.61,0:16:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam kasus ini, kami menjunjung tinggi\Nbakat musik dan kemandirian putra Anda.
Dialogue: 0,0:16:50.49,0:16:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemandirian?
Dialogue: 0,0:16:53.24,0:16:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak butuh pendapat pribadi.
Dialogue: 0,0:16:56.41,0:16:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mendidik dengan\Ncara selembek itu, ya?
Dialogue: 0,0:16:59.92,0:17:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putraku pasti tak akan\Nberkembang di sekolah kalian.
Dialogue: 0,0:17:05.83,0:17:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksud Anda...
Dialogue: 0,0:17:11.43,0:17:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda keberatan dengan kebijakan\Npendidikan sekolah kami?
Dialogue: 0,0:17:18.56,0:17:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi sekolah kami selalu\Nmemprioritaskan keinginan murid kami.
Dialogue: 0,0:17:23.40,0:17:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak bisa berbuat apa-apa\Ntanpa persetujuan dari yang bersangkutan.
Dialogue: 0,0:17:27.28,0:17:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, panggil dia.
Dialogue: 0,0:17:29.24,0:17:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:30.57,0:17:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan mengundurkan diri\Nsecara sukarela.
Dialogue: 0,0:17:32.53,0:17:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuminta dia pulang besok.
Dialogue: 0,0:17:36.58,0:17:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ding, dong, ding, dong.
Dialogue: 0,0:17:40.08,0:17:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson Soi harap segera\Nmenuju ke ruang guru.
Dialogue: 0,0:17:50.13,0:17:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada telepon dari ayahmu.
Dialogue: 0,0:17:55.97,0:17:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:58.10,0:17:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:00.35,0:18:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:10.94,0:18:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...suratnya.
Dialogue: 0,0:18:12.49,0:18:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu yakin?
Dialogue: 0,0:18:13.45,0:18:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:15.99,0:18:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:18:22.83,0:18:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson lama, ya.
Dialogue: 0,0:18:25.71,0:18:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat liburan nanti,
Dialogue: 0,0:18:26.63,0:18:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau ke toko lucu\Nyang kita kunjungi tempo hari lalu?
Dialogue: 0,0:18:28.84,0:18:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Magical Street?
Dialogue: 0,0:18:30.59,0:18:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapan festival musik kalian lancar?
Dialogue: 0,0:18:32.34,0:18:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya sama sekali tidak cukup.
Dialogue: 0,0:18:34.26,0:18:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sampai jumpa besok.
Dialogue: 0,0:18:35.59,0:18:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sampai jumpa.
Dialogue: 0,0:18:37.85,0:18:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian.
Dialogue: 0,0:18:38.93,0:18:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena suatu alasan, Purson Soi sedang\Ndalam persiapan untuk keluar dari sekolah.
Dialogue: 0,0:18:47.65,0:18:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:18:49.98,0:18:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson bilang apa?
Dialogue: 0,0:18:53.11,0:18:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tidak apa-apa."
Dialogue: 0,0:18:54.70,0:18:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:56.58,0:19:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, karena Purson keluar,\Ntingkat kesulitan tugas kalian jadi turun.
Dialogue: 0,0:19:02.17,0:19:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keuntungan buat kalian, kan?
Dialogue: 0,0:19:04.50,0:19:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu...
Dialogue: 0,0:19:05.50,0:19:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma melihat peringkat, mungkin benar.
Dialogue: 0,0:19:08.63,0:19:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini salah!
Dialogue: 0,0:19:10.00,0:19:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita sudah sampai sejauh ini...
Dialogue: 0,0:19:15.01,0:19:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarnya Purson bukan alasan\Nuntuk kalian bersikap lembek.
Dialogue: 0,0:19:20.30,0:19:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada lima hari sebelum festival.
Dialogue: 0,0:19:22.39,0:19:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak bisa habiskan waktuku\Nmelatih kalian terus.
Dialogue: 0,0:19:27.02,0:19:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena aku sangat sibuk saat ini.
Dialogue: 0,0:19:30.77,0:19:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mempersiapkan\Nfestival musik, melatih kalian,
Dialogue: 0,0:19:34.74,0:19:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mencari Purson yang menghilang.
Dialogue: 0,0:19:40.28,0:19:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghilang?
Dialogue: 0,0:19:42.49,0:19:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berkali-kali ditanya\Noleh pihak keluarganya.
Dialogue: 0,0:19:45.58,0:19:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soi ada di mana?
Dialogue: 0,0:19:47.17,0:19:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, jawab aku!
Dialogue: 0,0:19:48.46,0:19:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:19:49.63,0:19:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau anaknya jago sembunyi,\Nmereka harusnya senang.
Dialogue: 0,0:19:53.92,0:19:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya...
Dialogue: 0,0:19:55.22,0:19:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson kabur dari rumah?
Dialogue: 0,0:19:57.93,0:19:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:19:58.84,0:20:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita menyinggung perasaannya, ya?
Dialogue: 0,0:20:01.56,0:20:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cari dia!
Dialogue: 0,0:20:02.76,0:20:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari di mana?
Dialogue: 0,0:20:03.52,0:20:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku khawatir.\N- Tenanglah!
Dialogue: 0,0:20:04.93,0:20:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku bisa menebak\Ndi mana dia berada.
Dialogue: 0,0:20:08.94,0:20:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:09.90,0:20:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di-Di mana?
Dialogue: 0,0:20:16.40,0:20:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang bingung harus berbuat apa.
Dialogue: 0,0:20:20.24,0:20:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson pasti ingin tampil\Ndi festival musik.
Dialogue: 0,0:20:23.83,0:20:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia sedang bingung sendiri\Nkarena disuruh pulang.
Dialogue: 0,0:20:27.37,0:20:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bingung dan menghilang...
Dialogue: 0,0:20:29.96,0:20:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson yang terjebak tanpa arah...
Dialogue: 0,0:20:32.17,0:20:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan akhir yang ia capai...
Dialogue: 0,0:20:34.21,0:20:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ia ingin berada...
Dialogue: 0,0:20:40.09,0:20:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia di sini.
Dialogue: 0,0:20:40.97,0:20:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tak terlihat, tapi dia pasti di sini.
Dialogue: 0,0:20:45.09,0:20:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ruangan ini.
Dialogue: 0,0:20:50.23,0:20:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purson!
Dialogue: 0,0:20:52.48,0:20:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:20:53.57,0:20:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin tampil\Ndi festival musik bersamamu!
Dialogue: 0,0:21:01.74,0:21:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar! Soalnya seru sekali!
Dialogue: 0,0:21:04.99,0:21:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sendirian itu tidak baik!
Dialogue: 0,0:21:06.95,0:21:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau berhenti\Nsetelah latihan dengan Tuan Iruma?
Dialogue: 0,0:21:10.37,0:21:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jelas tidak boleh.
Dialogue: 0,0:21:13.96,0:21:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemeran utama kali ini adalah kita berdua.
Dialogue: 0,0:21:17.92,0:21:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tidak sopan\Nmeninggalkan wanita sendirian?
Dialogue: 0,0:21:21.72,0:21:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang kalau kamu bolos sendiri.
Dialogue: 0,0:21:25.18,0:21:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa membantu,\Nkami akan melakukannya segera.
Dialogue: 0,0:21:29.64,0:21:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sesama pria jantan,\Nkita masih kurang mengobrol.
Dialogue: 0,0:21:33.98,0:21:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah memberikan\Nperan utama padamu!
Dialogue: 0,0:21:36.27,0:21:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat kalau kamu tidak keren!
Dialogue: 0,0:21:38.74,0:21:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbuatan mengikuti keinginan,\Nbukan pemikiran.
Dialogue: 0,0:21:42.78,0:21:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bertaruh\Nkalau kamu akan datang.
Dialogue: 0,0:21:46.28,0:21:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan kita bertiga belas itu\Nsempurna dan luar biasa, lo!
Dialogue: 0,0:21:55.21,0:21:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan latihan agar tidak kalah denganmu!
Dialogue: 0,0:22:00.22,0:22:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya kita bertiga belas\Nbisa tampil di panggung!
Dialogue: 0,0:22:08.97,0:22:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo latihan!
Dialogue: 0,0:22:10.98,0:22:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:22:12.39,0:22:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:22:17.48,0:22:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, dia pasti...
Dialogue: 0,0:22:22.90,0:22:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah beberapa waktu...
Dialogue: 0,0:22:27.33,0:22:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya tirai festival musik pun terbuka.
Dialogue: 0,0:24:02.46,0:24:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara! Clara! Clara!
Dialogue: 0,0:24:05.09,0:24:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan.
Dialogue: 0,0:24:09.26,0:24:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini cuma alat peraga,\Nberarti isinya kosong?
Dialogue: 0,0:24:13.18,0:24:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:24:14.47,0:24:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya benar-benar terasa tulus,\Na-aku menulis banyak hal
Dialogue: 0,0:24:17.81,0:24:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menurutku indah\Ndan patut dihormati dari Mbak!
Dialogue: 0,0:24:24.48,0:24:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, setelah kubaca,\Nakan kupasang bingkai dan kupajang.
Dialogue: 0,0:24:27.86,0:24:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi malu.
Dialogue: 0,0:24:31.07,0:24:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival musik akan segera dimulai.
Dialogue: 0,0:24:32.95,0:24:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas Iruma terus berlatih dengan tekun,\Nmeski berkurang satu orang.
Dialogue: 0,0:24:37.00,0:24:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka tetap percaya.
Dialogue: 0,0:24:39.12,0:24:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tak terlihat,\NPurson ada di dekat mereka.
Dialogue: 0,0:24:42.50,0:24:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:44.88,0:24:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mengobrol".
Dialogue: 0,0:24:46.09,0:24:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Purson akan muncul?
Dialogue: 0,0:24:48.59,0:24:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian kenaikan peringkat,\Nacara terakhir tahun pertama.
Dialogue: 0,0:24:51.64,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tirai festival musik akan terbuka,\Njadi nantikan saja!
