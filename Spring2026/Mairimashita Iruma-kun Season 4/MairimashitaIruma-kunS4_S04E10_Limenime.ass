Dialogue: 0,0:00:01.52,0:00:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma dan kelas abnormal\Nberhasil memenangkan festival musik.
Dialogue: 0,0:00:05.68,0:00:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berhasil naik ke peringkat Daleth\Ndan menyelesaikan tugas mereka.
Dialogue: 0,0:00:11.41,0:00:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pun bisa tetap\Nmenggunakan Kelas Raja, Royal One.
Dialogue: 0,0:00:16.00,0:00:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Acara untuk murid kelas satu\Ntelah selesai semua.
Dialogue: 0,0:00:19.21,0:00:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akankah Iruma dan yang lain bisa menikmati\Nsekolah dengan tenang untuk sementara?
Dialogue: 0,0:01:55.89,0:01:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Trio Kesayangan".
Dialogue: 0,0:01:59.52,0:02:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival musik ditutup\Ndengan kemenangan kelas abnormal.
Dialogue: 0,0:02:04.19,0:02:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:02:05.77,0:02:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para murid kelas satu pun kembali\Nke keseharian normal mereka.
Dialogue: 0,0:02:10.03,0:02:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, gawat!
Dialogue: 0,0:02:12.95,0:02:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keseharian normal?
Dialogue: 0,0:02:16.03,0:02:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iru— Panas!
Dialogue: 0,0:02:17.41,0:02:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perisai api Tuan Asmodeus?
Dialogue: 0,0:02:19.83,0:02:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa mendekati Iruma!
Dialogue: 0,0:02:27.88,0:02:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:02:29.13,0:02:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas! Panas banget, Azz-Azz!
Dialogue: 0,0:02:31.92,0:02:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuacanya cerah, ya.
Dialogue: 0,0:02:34.18,0:02:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, dia tidak bisa diajak ngobrol.
Dialogue: 0,0:02:36.64,0:02:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Clarin jadi liar\Nkarena tidak bisa mendekati mereka.
Dialogue: 0,0:02:40.89,0:02:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aneh banget.
Dialogue: 0,0:02:42.48,0:02:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Azz, ada apa hari ini?
Dialogue: 0,0:02:45.94,0:02:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma,\Naku hanya mencoba melindungi Anda.
Dialogue: 0,0:02:51.48,0:02:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak tahu kapan iblis berkacamata,\Ntampak ramah, dan beraksen aneh itu menyerang!
Dialogue: 0,0:02:57.03,0:02:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spesifik banget!
Dialogue: 0,0:03:01.45,0:03:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkacamata dan tampak ramah...
Dialogue: 0,0:03:06.54,0:03:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin, kan?
Dialogue: 0,0:03:09.38,0:03:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi,\Naku akan melindungi Tuan Iruma!
Dialogue: 0,0:03:12.63,0:03:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada Asmodeus Alice ini!
Dialogue: 0,0:03:15.84,0:03:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lagi mode siklus jahat?
Dialogue: 0,0:03:19.10,0:03:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia jadi aneh begitu\Nkarena festival musik, ya?
Dialogue: 0,0:03:27.77,0:03:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:03:29.27,0:03:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?
Dialogue: 0,0:03:32.78,0:03:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:34.78,0:03:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Valac, tolong duduk.
Dialogue: 0,0:03:37.28,0:03:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asmodeus, tolong kecilkan apimu sedikit.
Dialogue: 0,0:03:40.45,0:03:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, halaman 33, ya?
Dialogue: 0,0:03:56.30,0:03:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap, ya?
Dialogue: 0,0:03:59.89,0:04:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bahaya!
Dialogue: 0,0:04:01.80,0:04:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hell Blast!
Dialogue: 0,0:04:10.02,0:04:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apinya luar biasa!
Dialogue: 0,0:04:11.52,0:04:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak pagi begitu?
Dialogue: 0,0:04:13.02,0:04:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maaf telah menunggu.\N- Panas sekali!
Dialogue: 0,0:04:14.32,0:04:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma sedang makan yakiniku.
Dialogue: 0,0:04:15.94,0:04:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma yang sedang\Nmengunyah imut banget!
Dialogue: 0,0:04:18.02,0:04:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi keringatnya.
Dialogue: 0,0:04:28.33,0:04:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembok mutlak, ya.
Dialogue: 0,0:04:30.50,0:04:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apinya sama sekali tidak meredup,\Nmalahan tambah kuat.
Dialogue: 0,0:04:36.59,0:04:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Azz...
Dialogue: 0,0:04:44.31,0:04:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Tuan Iruma.
Dialogue: 0,0:04:46.52,0:04:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau menemui Pak Balam sebentar.
Dialogue: 0,0:04:49.73,0:04:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin menjauh dari Tuan Iruma,\Ntapi aku harus pergi!
Dialogue: 0,0:04:54.07,0:04:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal yang harus\Nkutanyakan pada Pak Balam!
Dialogue: 0,0:04:57.44,0:05:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku segera kembali,\Njadi jangan bergerak dari situ!
Dialogue: 0,0:05:02.95,0:05:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:05:03.70,0:05:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badainya sudah pergi.
Dialogue: 0,0:05:05.58,0:05:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz bertingkah aneh, ya.
Dialogue: 0,0:05:12.08,0:05:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, aku dapat Irumachi!
Dialogue: 0,0:05:16.46,0:05:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara?
Dialogue: 0,0:05:20.09,0:05:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pergi.
Dialogue: 0,0:05:21.80,0:05:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran kayak badai, ya.
Dialogue: 0,0:05:27.97,0:05:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, tidak ada yang akan\Nmenemukan kita di sini.
Dialogue: 0,0:05:32.02,0:05:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara, apa yang—
Dialogue: 0,0:05:37.40,0:05:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengisi ulang energi Irumachi!
Dialogue: 0,0:05:39.94,0:05:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Azz-Azz terus mengurungmu\Ndalam perisai apinya.
Dialogue: 0,0:05:44.16,0:05:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bisa nempel padamu.
Dialogue: 0,0:05:46.45,0:05:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga beda tim saat festival musik!
Dialogue: 0,0:05:50.29,0:05:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kekurangan dosis Irumachi!
Dialogue: 0,0:05:54.54,0:05:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, permainan piano Irumachi\Nbenar-benar keren!
Dialogue: 0,0:05:59.51,0:06:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren banget!
Dialogue: 0,0:06:03.80,0:06:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini sertifikatmu.
Dialogue: 0,0:06:05.85,0:06:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar hebat,
Dialogue: 0,0:06:07.85,0:06:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku mengagumimu!
Dialogue: 0,0:06:09.81,0:06:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, terima kasih!
Dialogue: 0,0:06:13.31,0:06:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tariannya Clara juga cantik dan keren!
Dialogue: 0,0:06:17.90,0:06:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini penghargaan untukmu!
Dialogue: 0,0:06:19.48,0:06:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar hebat,\Njadi aku mengagumimu!
Dialogue: 0,0:06:24.11,0:06:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:06:25.41,0:06:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sama-sama.
Dialogue: 0,0:06:28.08,0:06:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiahmu!
Dialogue: 0,0:06:35.08,0:06:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz juga luar biasa, ya?
Dialogue: 0,0:06:38.29,0:06:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berkilauan!
Dialogue: 0,0:06:39.96,0:06:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia keren, ya?
Dialogue: 0,0:06:42.51,0:06:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:06:46.59,0:06:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu, ya?
Dialogue: 0,0:06:50.47,0:06:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat baik-baik saja,
Dialogue: 0,0:06:52.52,0:06:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tampak memikirkan\Nsesuatu sejak kemarin.
Dialogue: 0,0:06:56.23,0:06:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia baik-baik saja?
Dialogue: 0,0:06:58.44,0:07:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irumachi.
Dialogue: 0,0:07:09.70,0:07:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sayang Irumachi, lo.
Dialogue: 0,0:07:16.21,0:07:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku juga sayang Azz-Azz!
Dialogue: 0,0:07:19.84,0:07:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, Azz-Azz sayang Irumachi\Ndan juga aku, kan?
Dialogue: 0,0:07:25.22,0:07:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:26.22,0:07:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, Irumachi juga sayang\Naku dan Azz-Azz, kan?
Dialogue: 0,0:07:30.18,0:07:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:07:31.60,0:07:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,\Nkita adalah Trio Kesayangan!
Dialogue: 0,0:07:35.60,0:07:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trio Kesayangan?
Dialogue: 0,0:07:41.11,0:07:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rapat rahasia Trio Kesayangan!
Dialogue: 0,0:07:43.90,0:07:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Profesor!
Dialogue: 0,0:07:46.90,0:07:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau salah satu dari\NTrio Kesayangan kesulitan,
Dialogue: 0,0:07:50.12,0:07:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sisanya akan membuat rencana\Nuntuk menghiburnya.
Dialogue: 0,0:07:53.99,0:07:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebenarnya...
Dialogue: 0,0:07:57.37,0:08:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pikir Azz-Azz yang memonopoli\NIrumachi hari ini itu curang.
Dialogue: 0,0:08:02.50,0:08:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sebagai Mbak Trio Kesayangan,\Naku akan mengalah kali ini.
Dialogue: 0,0:08:07.88,0:08:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian berdua harus\Nbermain sepuasnya!
Dialogue: 0,0:08:11.89,0:08:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdua?
Dialogue: 0,0:08:13.93,0:08:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian berdua menghabiskan\Nwaktu seharian bersama,
Dialogue: 0,0:08:17.14,0:08:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz akan kembali ceria lagi.
Dialogue: 0,0:08:19.48,0:08:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa benar begitu?
Dialogue: 0,0:08:22.40,0:08:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, memang benar.
Dialogue: 0,0:08:24.19,0:08:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah ada waktu bermain\Ndengan Azz berdua saja.
Dialogue: 0,0:08:28.40,0:08:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga hal yang ingin\Nkubicarakan berdua dengannya.
Dialogue: 0,0:08:32.74,0:08:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:33.90,0:08:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba ajak dia!
Dialogue: 0,0:08:36.00,0:08:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Clara!
Dialogue: 0,0:08:39.16,0:08:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak tahu harus main apa.
Dialogue: 0,0:08:44.92,0:08:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi.
Dialogue: 0,0:08:48.80,0:08:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada Mbak Clara,\Nsi genius bermain.
Dialogue: 0,0:08:54.26,0:08:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Mbak Clara!
Dialogue: 0,0:08:56.56,0:09:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, setelah itu, kalian akan gantian\Nmain berdua denganku.
Dialogue: 0,0:09:01.15,0:09:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ce-Cerdas!
Dialogue: 0,0:09:02.65,0:09:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:09:08.11,0:09:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata lebih memakan\Nwaktu dari dugaanku.
Dialogue: 0,0:09:12.87,0:09:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang aku
Dialogue: 0,0:09:14.09,0:09:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang meminta petunjuk soal Iblis Asal,
Dialogue: 0,0:09:16.55,0:09:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku terlalu larut.
Dialogue: 0,0:09:19.87,0:09:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak ada yang berlebihan\Nkalau menyangkut ilmu.
Dialogue: 0,0:09:25.46,0:09:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus lebih mempersiapkan diri\Nuntuk apa yang akan datang.
Dialogue: 0,0:09:28.84,0:09:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:09:30.97,0:09:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz!
Dialogue: 0,0:09:32.97,0:09:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma!
Dialogue: 0,0:09:34.97,0:09:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, tunggulah di kelas.
Dialogue: 0,0:09:37.10,0:09:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terjadi sesuatu\Nsaat Tuan ke sini?
Dialogue: 0,0:09:39.56,0:09:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku baik-baik saja, kok.
Dialogue: 0,0:09:41.48,0:09:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi ada yang ingin\Nkutanyakan padamu.
Dialogue: 0,0:09:45.36,0:09:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanya?
Dialogue: 0,0:09:46.48,0:09:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz, kamu senggang akhir pekan ini?
Dialogue: 0,0:09:48.98,0:09:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari jalan-jalan bareng!
Dialogue: 0,0:09:53.49,0:09:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik?
Dialogue: 0,0:09:54.62,0:10:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana bersenang-senang sepuasnya\Ndi Magical Street.
Dialogue: 0,0:10:00.04,0:10:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo main bareng.
Dialogue: 0,0:10:14.26,0:10:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama tidak ke Magical Street.
Dialogue: 0,0:10:19.31,0:10:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramai sekali, ya.
Dialogue: 0,0:10:21.27,0:10:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang beliau mengajakku,
Dialogue: 0,0:10:23.85,0:10:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku harus ekstra hati-hati\Ndi tempat seramai ini.
Dialogue: 0,0:10:27.27,0:10:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo.
Dialogue: 0,0:10:29.28,0:10:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayo!
Dialogue: 0,0:10:40.16,0:10:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Clara bodoh mana?
Dialogue: 0,0:10:42.79,0:10:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak ikut.
Dialogue: 0,0:10:43.91,0:10:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kita berdua hari ini.
Dialogue: 0,0:10:45.04,0:10:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, cuma kita berdua, ya?
Dialogue: 0,0:10:49.25,0:10:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdua...
Dialogue: 0,0:10:51.46,0:10:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdua...
Dialogue: 0,0:10:54.80,0:10:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, hanya berdua?
Dialogue: 0,0:10:56.51,0:10:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi gugup!
Dialogue: 0,0:10:59.03,0:11:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kita bakal bertiga seperti biasa!
Dialogue: 0,0:11:02.64,0:11:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jadi gugup! Jadi gugup!\N- Azz, kemari!
Dialogue: 0,0:11:07.98,0:11:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko pakaian?
Dialogue: 0,0:11:09.77,0:11:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:11.31,0:11:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu ingin datang ke sini.
Dialogue: 0,0:11:13.86,0:11:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:11:17.87,0:11:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata cuma penjaga toko, ya?
Dialogue: 0,0:11:20.49,0:11:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apanya?
Dialogue: 0,0:11:22.75,0:11:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek yang selalu membelikan pakaianku,
Dialogue: 0,0:11:30.59,0:11:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku ingin memilih dengan teman.
Dialogue: 0,0:11:33.51,0:11:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kan?
Dialogue: 0,0:11:34.88,0:11:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, serahkan padaku!
Dialogue: 0,0:11:37.38,0:11:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, langsung saja.
Dialogue: 0,0:11:42.22,0:11:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka aku akan memilih\Npakaian untuk Tuan Iruma.
Dialogue: 0,0:11:46.77,0:11:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murah!
Dialogue: 0,0:11:49.40,0:11:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa harganya tidak salah?
Dialogue: 0,0:11:51.77,0:11:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga!
Dialogue: 0,0:11:55.78,0:11:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa semurah ini?
Dialogue: 0,0:11:58.78,0:12:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa pakaian ini ada kutukannya?
Dialogue: 0,0:12:00.32,0:12:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz, lihat.
Dialogue: 0,0:12:02.66,0:12:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang begini juga.
Dialogue: 0,0:12:05.16,0:12:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh Anda bisa remuk nanti!
Dialogue: 0,0:12:08.33,0:12:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat.
Dialogue: 0,0:12:10.13,0:12:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pilihan yang bagus.
Dialogue: 0,0:12:11.88,0:12:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bekas, itu cukup langka, lo.
Dialogue: 0,0:12:13.71,0:12:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lepaskan!
Dialogue: 0,0:12:15.59,0:12:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, bawakan\Npakaian bermerek Akumani kemari!
Dialogue: 0,0:12:18.30,0:12:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak punya itu.
Dialogue: 0,0:12:19.80,0:12:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Louis Devilton!\N- Tidak punya.
Dialogue: 0,0:12:21.26,0:12:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Devimess!\N- Tidak punya.
Dialogue: 0,0:12:22.22,0:12:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Akumada!\N- Tidak punya.
Dialogue: 0,0:12:23.18,0:12:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Devil Smith!\N- Tidak punya.
Dialogue: 0,0:12:24.31,0:12:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Deviall!\N- Tidak punya.
Dialogue: 0,0:12:25.27,0:12:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- DeviFunny!\N- Tidak punya.
Dialogue: 0,0:12:26.23,0:12:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Akunell!\N- Tidak punya.
Dialogue: 0,0:12:27.23,0:12:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- DeviGaba?\N- Tidak punya.
Dialogue: 0,0:12:30.35,0:12:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana?
Dialogue: 0,0:12:33.77,0:12:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak aneh?
Dialogue: 0,0:12:35.61,0:12:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok banget!\NTuan Iruma memang hebat!
Dialogue: 0,0:12:39.15,0:12:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok banget.
Dialogue: 0,0:12:40.57,0:12:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok banget!
Dialogue: 0,0:12:42.99,0:12:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok banget!
Dialogue: 0,0:12:45.20,0:12:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:12:48.00,0:12:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, selanjutnya kamu, Azz.
Dialogue: 0,0:12:56.46,0:13:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, cocok banget, Azz.
Dialogue: 0,0:13:00.22,0:13:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak biasa bergaya seperti ini.
Dialogue: 0,0:13:03.89,0:13:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga cocok.
Dialogue: 0,0:13:06.39,0:13:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga boleh.
Dialogue: 0,0:13:08.93,0:13:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma selalu cocok\Nmau pakai apa pun.
Dialogue: 0,0:13:12.27,0:13:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz juga keren.
Dialogue: 0,0:13:14.06,0:13:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena Tuan Iruma yang pilihkan.
Dialogue: 0,0:13:19.74,0:13:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:13:21.91,0:13:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok banget!
Dialogue: 0,0:13:23.49,0:13:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma juga cocok banget.
Dialogue: 0,0:13:26.91,0:13:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan seperti anak nakal, ya?
Dialogue: 0,0:13:28.75,0:13:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nakal banget!
Dialogue: 0,0:13:30.50,0:13:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, biar aku yang bayar.
Dialogue: 0,0:13:33.00,0:13:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kartu platinum!
Dialogue: 0,0:13:34.92,0:13:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:13:37.00,0:13:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bayar punyaku sendiri.
Dialogue: 0,0:13:40.01,0:13:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eng, 60 Vill, ya.\N- Begitu, ya.
Dialogue: 0,0:13:43.34,0:13:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayar juga termasuk pengalaman\Nbelajar bagi Tuan Iruma, ya.
Dialogue: 0,0:13:46.68,0:13:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ambisi beliau memang luar biasa.\N- Yang ini... Terus, yang ini.
Dialogue: 0,0:13:50.43,0:13:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, silakan datang lagi!
Dialogue: 0,0:13:56.86,0:13:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah belanja!
Dialogue: 0,0:13:58.44,0:14:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, barangnya luar biasa!
Dialogue: 0,0:14:01.86,0:14:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada umanju!
Dialogue: 0,0:14:03.28,0:14:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat banget!
Dialogue: 0,0:14:04.36,0:14:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau enam.
Dialogue: 0,0:14:06.20,0:14:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Totalnya 780 Vill, ya?
Dialogue: 0,0:14:08.37,0:14:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhitungan beliau jauh lebih cepat!
Dialogue: 0,0:14:10.70,0:14:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh perkembangan yang luar biasa!
Dialogue: 0,0:14:13.37,0:14:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz juga makan, yuk.
Dialogue: 0,0:14:14.75,0:14:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, baik.
Dialogue: 0,0:14:19.55,0:14:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gim ini seru banget, lo.
Dialogue: 0,0:14:22.01,0:14:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering main lawan Lied,
Dialogue: 0,0:14:25.01,0:14:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku belum pernah menang sekalipun.
Dialogue: 0,0:14:27.51,0:14:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan beli.
Dialogue: 0,0:14:29.22,0:14:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, nih?
Dialogue: 0,0:14:30.10,0:14:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kalahkan dia berdua.
Dialogue: 0,0:14:37.52,0:14:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ini bisa jadi referensi tidak, ya?
Dialogue: 0,0:14:40.53,0:14:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah kelas dua,\Npelajarannya bakal tambah susah, ya.
Dialogue: 0,0:14:44.53,0:14:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mempelajarinya sebelumnya,\Njadi tanyakan saja jika bingung.
Dialogue: 0,0:14:48.53,0:14:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Azz memang hebat!
Dialogue: 0,0:14:50.66,0:14:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengandalkanmu!
Dialogue: 0,0:14:53.21,0:14:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:14:57.50,0:15:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma, hati-hati!
Dialogue: 0,0:15:29.66,0:15:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa sudah sore, ya!
Dialogue: 0,0:15:31.95,0:15:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkat Clara.
Dialogue: 0,0:15:33.83,0:15:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak yang belum kita coba, sih.
Dialogue: 0,0:15:36.42,0:15:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda benar.
Dialogue: 0,0:15:38.46,0:15:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharian ini...
Dialogue: 0,0:15:40.25,0:15:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah bermain seperti biasa!
Dialogue: 0,0:15:43.17,0:15:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa gagal,\Ntapi rasanya menyenangkan!
Dialogue: 0,0:15:49.22,0:15:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Enak.\N- Meski begitu...
Dialogue: 0,0:15:51.93,0:15:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma jadi lebih berani.
Dialogue: 0,0:15:56.02,0:16:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pertama bertemu,\Nbeliau jauh lebih tenang.
Dialogue: 0,0:16:01.82,0:16:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak ada Clara, si Ratu Cerewet,
Dialogue: 0,0:16:05.49,0:16:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu jadi tampak jelas.
Dialogue: 0,0:16:08.53,0:16:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Normalnya, tertawa beliau juga keras, ya.
Dialogue: 0,0:16:15.41,0:16:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu putih polos, ya.
Dialogue: 0,0:16:20.25,0:16:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking putih dan polosnya\Nsampai tidak tahu apa-apa.
Dialogue: 0,0:16:25.21,0:16:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu bukan masalah.
Dialogue: 0,0:16:27.38,0:16:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa mengagumi Iruma\Nsebagai iblis hebat berperingkat He.
Dialogue: 0,0:16:31.64,0:16:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat sosoknya yang kamu suka\Ndan terpesona olehnya.
Dialogue: 0,0:16:36.02,0:16:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku...
Dialogue: 0,0:16:37.77,0:16:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan mengungkap sisi dirinya\Nyang tidak ingin dirinya tunjukkan
Dialogue: 0,0:16:42.65,0:16:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menikmatinya sepenuh hati.
Dialogue: 0,0:16:48.20,0:16:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Tuan Iruma\Nmengajakku keluar hari ini?
Dialogue: 0,0:16:54.79,0:16:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku sampai lupa.
Dialogue: 0,0:16:57.58,0:17:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kubicarakan denganmu.
Dialogue: 0,0:17:02.04,0:17:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz, kamu ingat pernah bilang,\N"Naik peringkat adalah kebanggaan iblis?"
Dialogue: 0,0:17:08.08,0:17:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, saat ujian meriam\Npeluru kematian, kan?
Dialogue: 0,0:17:11.26,0:17:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah aku naik ke peringkat He,
Dialogue: 0,0:17:13.59,0:17:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya ikut merayakan.
Dialogue: 0,0:17:19.69,0:17:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:21.34,0:17:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku terus berpikir.
Dialogue: 0,0:17:27.85,0:17:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berat juga, ya.
Dialogue: 0,0:17:31.37,0:17:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:32.36,0:17:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat?
Dialogue: 0,0:17:33.20,0:17:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku sangat senang tentang hal ini.
Dialogue: 0,0:17:36.87,0:17:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini memang\Nmasih terlalu dini buatku.
Dialogue: 0,0:17:41.87,0:17:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga menang festival musik\Nbersama-sama.
Dialogue: 0,0:17:46.34,0:17:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, ini He!
Dialogue: 0,0:17:47.92,0:17:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daleth saja sudah hebat!\NApa ini tidak terlalu dini?
Dialogue: 0,0:17:51.68,0:17:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:17:54.64,0:17:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, awalnya kupikir "Aku hebat!"
Dialogue: 0,0:17:59.18,0:18:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saat sadar soal tanggung jawab\Ndan melihat reaksi sekitar,
Dialogue: 0,0:18:03.56,0:18:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi berpikir
Dialogue: 0,0:18:05.23,0:18:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Apa aku tidak terlalu hebat?"
Dialogue: 0,0:18:06.65,0:18:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terus-terusan berpikiran begitu.
Dialogue: 0,0:18:11.19,0:18:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tertawa?
Dialogue: 0,0:18:13.16,0:18:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:15.16,0:18:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tertawa, tuh!
Dialogue: 0,0:18:17.41,0:18:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, maafkan aku.
Dialogue: 0,0:18:21.08,0:18:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku jadi sadar kalau ini berat.
Dialogue: 0,0:18:25.58,0:18:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:27.96,0:18:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:31.59,0:18:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski berat,
Dialogue: 0,0:18:35.01,0:18:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dapat banyak pengalaman\Ndi dunia iblis ini.
Dialogue: 0,0:18:38.01,0:18:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap naik peringkat, aku merasa\Nmenemukan diriku yang tak kukenal.
Dialogue: 0,0:18:44.77,0:18:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, saat ini, aku...
Dialogue: 0,0:18:50.07,0:18:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin melepas lencana ini.
Dialogue: 0,0:18:52.82,0:18:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mengincar\Nperingkat lebih tinggi lagi.
Dialogue: 0,0:19:00.04,0:19:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rakus, ya?
Dialogue: 0,0:19:02.70,0:19:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, karena cemas, aku ingin\Nkamu dan Clara tetap bersamaku...
Dialogue: 0,0:19:08.34,0:19:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, sebagai "Trio Kesayangan",\Nagar kita bisa saling mendukung.
Dialogue: 0,0:19:17.43,0:19:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:19:20.31,0:19:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:22.06,0:19:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadaku terasa panas serasa terbakar.
Dialogue: 0,0:19:26.40,0:19:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpikir "Aku harus melindungi beliau."
Dialogue: 0,0:19:29.02,0:19:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau marah karena merasa\Ntidak tahu apa-apa.
Dialogue: 0,0:19:33.11,0:19:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu takutkan, Asmodeus Alice?
Dialogue: 0,0:19:37.24,0:19:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peduli siapa yang berusaha\Nmenghancurkan semangat beliau,
Dialogue: 0,0:19:41.66,0:19:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau siapa yang mengerti\Npertumbuhan beliau,
Dialogue: 0,0:19:46.67,0:19:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada iblis yang seberuntung diriku.
Dialogue: 0,0:19:51.00,0:19:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku dapat melihat Tuan Iruma\Nmembuka jalannya dari dekat.
Dialogue: 0,0:19:56.84,0:20:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku dapat melihat\Nsosok beliau menggapai puncak!
Dialogue: 0,0:20:04.64,0:20:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz?
Dialogue: 0,0:20:07.14,0:20:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan ragu lagi.
Dialogue: 0,0:20:09.56,0:20:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau demi melihat sosok beliau...
Dialogue: 0,0:20:13.53,0:20:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Azz...
Dialogue: 0,0:20:17.53,0:20:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan mengikuti Anda\Nke mana pun itu!
Dialogue: 0,0:20:23.03,0:20:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:20:25.37,0:20:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku adalah teman Anda!
Dialogue: 0,0:20:29.71,0:20:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:20:31.79,0:20:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman adalah sosok yang bisa\Nkamu ajak main bersama.
Dialogue: 0,0:20:37.22,0:20:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:20:41.76,0:20:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang saling membantu\Ndan saling percaya...
Dialogue: 0,0:20:47.35,0:20:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski juga termasuk teman...
Dialogue: 0,0:20:50.44,0:20:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:20:53.52,0:20:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara menyebut kita "Trio Kesayangan."
Dialogue: 0,0:20:57.36,0:20:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagiku...
Dialogue: 0,0:20:58.74,0:21:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku...
Dialogue: 0,0:21:03.95,0:21:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita adalah sahabat.
Dialogue: 0,0:21:12.00,0:21:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sahabat?
Dialogue: 0,0:21:15.00,0:21:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sahabat.
Dialogue: 0,0:21:18.01,0:21:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya "sahabat",\NTuan Iruma?
Dialogue: 0,0:21:20.76,0:21:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, aku agak malu!
Dialogue: 0,0:21:22.18,0:21:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya aku dan Clara itu bodoh?
Dialogue: 0,0:21:26.35,0:21:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tolong jelaskan!\N- I-Iya!
Dialogue: 0,0:21:28.27,0:21:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri tahu aku, Tuan Iruma!
Dialogue: 0,0:23:02.82,0:23:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua "sahabat" setelah itu...
Dialogue: 0,0:23:06.36,0:23:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau "teman" sebegini,\Nkami kira-kira sebegini?
Dialogue: 0,0:23:10.54,0:23:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, mungkin lebih tinggi.
Dialogue: 0,0:23:14.04,0:23:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebegini?
Dialogue: 0,0:23:15.96,0:23:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit lagi.
Dialogue: 0,0:23:16.92,0:23:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebegini?
Dialogue: 0,0:23:18.21,0:23:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit lagi.
Dialogue: 0,0:23:26.09,0:23:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sahabat" itu lebih tinggi\Nsejauh mana dari "teman"?
Dialogue: 0,0:23:30.97,0:23:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- A-Azz?\N- A-Apa lebih tinggi lagi?
Dialogue: 0,0:23:34.98,0:23:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ah, sungguh sebutan yang merdu!\N- Azz!
Dialogue: 0,0:23:38.73,0:23:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sahabat!\N- Azz!
Dialogue: 0,0:23:43.99,0:23:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan!
Dialogue: 0,0:23:48.07,0:23:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rapat pergi main berdua.
Dialogue: 0,0:23:51.16,0:23:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:23:52.87,0:23:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, meski tiba-tiba disuruh\Npergi main berdua,
Dialogue: 0,0:23:56.25,0:23:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sama sekali tidak sadar.
Dialogue: 0,0:23:57.50,0:23:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:23:58.79,0:24:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Clara, si genius bermain,\Nakan menuntunmu.
Dialogue: 0,0:24:03.05,0:24:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pilih yang mana?
Dialogue: 0,0:24:06.80,0:24:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tur hutan selama tiga hari untuk menjelajahi\Nhutan Ingayagaya secara maksimal.
Dialogue: 0,0:24:10.55,0:24:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompetisi renang di rawa Bebe
Dialogue: 0,0:24:11.76,0:24:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- rekomendasi keluarga Valac.\N- Tidak.
Dialogue: 0,0:24:13.64,0:24:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eksplorasi bawah tanah\Nbersama raksasa Mogumogu.
Dialogue: 0,0:24:16.68,0:24:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihannya ada banyak.
Dialogue: 0,0:24:20.15,0:24:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu akan pergi\Nmain berdua dengan Clara?
Dialogue: 0,0:24:24.03,0:24:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau aku ikut juga?
Dialogue: 0,0:24:27.24,0:24:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditunda!
Dialogue: 0,0:24:29.99,0:24:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah Irumachi dan Azz-Azz
Dialogue: 0,0:24:31.53,0:24:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menikmati waktu berdua mereka.
Dialogue: 0,0:24:34.24,0:24:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, waktunya aku\Ndan Azz-Azz main berdua!
Dialogue: 0,0:24:37.00,0:24:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz tak tahu apa-apa soal main, sih.
Dialogue: 0,0:24:39.50,0:24:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara si Profesor Bermain harus\Nmengajarinya dengan baik!
Dialogue: 0,0:24:42.67,0:24:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:44.38,0:24:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Rapat Sahabat" dan "Rapat Mesra Lied".
Dialogue: 0,0:24:46.92,0:24:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, ayo main rumah-rumahan!
Dialogue: 0,0:24:49.01,0:24:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz, selamat datang!
Dialogue: 0,0:24:50.14,0:24:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti lapar, kan?\NMau makan dulu?
Dialogue: 0,0:24:52.39,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mandi? Mau apa?\NMau yang mana?
