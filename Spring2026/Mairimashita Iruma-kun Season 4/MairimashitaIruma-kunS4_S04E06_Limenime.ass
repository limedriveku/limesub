Dialogue: 0,0:00:30.69,0:00:35.01,On Top,,0,0,0,,Apa aku bisa makan semuanya, ya?
Dialogue: 0,0:00:43.48,0:00:45.98,tanda_srt,,0,0,0,,(Selamat Datang di Sekolah Iblis, Iruma)
Dialogue: 0,0:00:45.98,0:00:50.78,tanda_srt,,0,0,0,,(Selamat Datang di Sekolah Iblis, Iruma)\N(Musim ke-4)
Dialogue: 0,0:02:04.98,0:02:09.48,tanda_srt,,0,0,0,,(Hari Festival Musik!!)
Dialogue: 0,0:02:09.48,0:02:12.49,tanda_srt,,0,0,0,,(Hari Festival Musik)
Dialogue: 0,0:02:24.47,0:02:28.25,tanda_srt,,0,0,0,,(Mungkin)
Dialogue: 0,0:03:31.23,0:03:35.99,tanda_srt,,0,0,0,,(Romansa Rahasia)
Dialogue: 0,0:03:35.99,0:03:37.45,tanda_srt,,0,0,0,,(Romansa Rahasia)\N(*Imajinasinya sendiri)
Dialogue: 0,0:03:48.35,0:03:49.12,On Top,,0,0,0,,Dia orangnya.
Dialogue: 0,0:04:30.29,0:04:34.25,tanda_srt,,0,0,0,,(Daleth (4))
Dialogue: 0,0:08:32.01,0:08:37.29,On Top,,0,0,0,,Tiap juri memiliki enam poin\Nuntuk memberikan evaluasi yang ketat!
Dialogue: 0,0:08:58.06,0:09:01.81,tanda_srt,,0,0,0,,(Pertandingan Suara)
Dialogue: 0,0:10:21.14,0:10:25.15,tanda_srt,,0,0,0,,(Penampilan Kelas A\N~Bangkitnya Pangeran Roh~)
Dialogue: 0,0:12:23.95,0:12:32.65,On Top,,0,0,0,,Serunya meledak-ledak! Duar!\NBergemerlap! Blar!
Dialogue: 0,0:12:54.25,0:12:55.46,tanda_srt,,0,0,0,,(Penggemar Berat!!)
Dialogue: 0,0:14:31.35,0:14:33.81,tanda_srt,,0,0,0,,(Kelas C - Ansambel Chaos)
Dialogue: 0,0:14:46.07,0:14:51.04,tanda_srt,,0,0,0,,(Yang akur, ya)
Dialogue: 0,0:16:02.36,0:16:04.69,tanda_srt,,0,0,0,,(Festival Musik)
Dialogue: 0,0:16:52.24,0:16:55.54,tanda_srt,,0,0,0,,(Festival Musik)
Dialogue: 0,0:18:39.49,0:18:41.02,On Top,,0,0,0,,Tu-Tunggu dulu...
Dialogue: 0,0:18:41.02,0:18:42.60,On Top,,0,0,0,,I-Ibu...
Dialogue: 0,0:19:38.70,0:19:41.70,tanda_srt,,0,0,0,,(Kelas B - Tragedi: Pernikahan Berlumur Darah)
Dialogue: 0,0:24:06.51,0:24:08.13,tanda_srt,,0,0,0,,(Tambahan)
Dialogue: 0,0:24:29.99,0:24:55.01,tanda_srt,,0,0,0,,(Cuplikan)
Dialogue: 0,0:00:00.00,0:00:00.96,Default,,0,0,0,,
Dialogue: 0,0:00:00.96,0:00:04.44,Default,,0,0,0,,Jadi, kelas abnormal, ya?\NKasih tahu, dong.
Dialogue: 0,0:00:04.44,0:00:06.15,Default,,0,0,0,,Kau jadi wali kelasnya?
Dialogue: 0,0:00:06.15,0:00:07.49,Default,,0,0,0,,Ya.
Dialogue: 0,0:00:07.49,0:00:09.16,Default,,0,0,0,,Siapa Iruma?
Dialogue: 0,0:00:10.80,0:00:13.41,Default,,0,0,0,,Iruma itu cucu Pak Kepsek.
Dialogue: 0,0:00:13.41,0:00:14.66,Default,,0,0,0,,Eh?
Dialogue: 0,0:00:16.68,0:00:19.92,Default,,0,0,0,,Dialah orang yang membuka Royal One.
Dialogue: 0,0:00:24.92,0:00:26.63,Default,,0,0,0,,Kupu-kupu.
Dialogue: 0,0:00:26.63,0:00:28.51,Default,,0,0,0,,Terbang-terbang.
Dialogue: 0,0:00:28.51,0:00:30.69,Default,,0,0,0,,Wah.
Dialogue: 0,0:00:31.74,0:00:34.54,Default,,0,0,0,,Iruma, ya?
Dialogue: 0,0:00:39.73,0:00:41.60,Default,,0,0,0,,Bangkit! Bangkit! Bangkit! Bangkit!♪
Dialogue: 0,0:00:41.60,0:00:43.48,Default,,0,0,0,,Mari buat keributan\Ndan egois hingga fajar♪
Dialogue: 0,0:00:50.78,0:00:52.57,Default,,0,0,0,,Murid berprestasi,\Nkau tahu maksudku?♪
Dialogue: 0,0:00:52.57,0:00:55.12,Default,,0,0,0,,Kutak tahu apa-apa sejak awal♪
Dialogue: 0,0:00:55.12,0:00:58.50,Default,,0,0,0,,Abaikan saja perdamaian dan keadilan♪
Dialogue: 0,0:00:59.04,0:01:00.62,Default,,0,0,0,,Ah, lelah rasanya♪
Dialogue: 0,0:01:00.62,0:01:02.96,Default,,0,0,0,,Saat ingin menangis,♪
Dialogue: 0,0:01:02.96,0:01:05.09,Default,,0,0,0,,tujulah panggung nan megah♪
Dialogue: 0,0:01:05.09,0:01:06.92,Default,,0,0,0,,Bangkit! Bangkit! Bangkit! Bangkit!♪
Dialogue: 0,0:01:06.92,0:01:07.88,Default,,0,0,0,,Egois hingga akhir♪
Dialogue: 0,0:01:07.88,0:01:11.72,Default,,0,0,0,,Deru seketika jadi anggun♪
Dialogue: 0,0:01:11.72,0:01:16.47,Default,,0,0,0,,Saat menggenggam tangan itu,\Nsemuanya dimulai♪
Dialogue: 0,0:01:16.47,0:01:18.43,Default,,0,0,0,,Kala lampu menyala lagi,\Nmahatahu dan mahakuasa♪
Dialogue: 0,0:01:18.43,0:01:19.98,Default,,0,0,0,,akan buat keributan♪
Dialogue: 0,0:01:19.98,0:01:23.52,Default,,0,0,0,,Jadi ayo kita meriahkan♪
Dialogue: 0,0:01:25.31,0:01:26.32,Default,,0,0,0,,Tiketnya habis ludes♪
Dialogue: 0,0:01:26.32,0:01:29.78,Default,,0,0,0,,Pestanya dimulai dalam\Nhitungan satu, dua, dan tiga♪
Dialogue: 0,0:01:29.78,0:01:31.95,Default,,0,0,0,,Mari berkumpul dan bersorak meriah♪
Dialogue: 0,0:01:31.95,0:01:33.95,tanda_srt,,0,0,0,,(Semua! Semua! Semuanya!♪)
Dialogue: 0,0:01:33.95,0:01:37.58,Default,,0,0,0,,Dua, tiga, empat!\NMari bermimpi bersama, Sayang♪
Dialogue: 0,0:01:37.83,0:01:39.75,Default,,0,0,0,,Buang jauh-jauh rasa khawatir itu♪
Dialogue: 0,0:01:39.75,0:01:43.92,tanda_srt,,0,0,0,,(Semua! Semua! Semuanya!♪)
Dialogue: 0,0:01:44.75,0:01:47.96,tanda_srt,,0,0,0,,(Semuanya!♪)
Dialogue: 0,0:01:48.75,0:01:53.72,tanda_srt,,0,0,0,,(Semuanya!♪)
Dialogue: 0,0:01:53.72,0:01:57.51,Default,,0,0,0,,Pestanya dimulai dalam\Nhitungan satu, dua, dan tiga♪
Dialogue: 0,0:02:05.73,0:02:08.07,Default,,0,0,0,,"Hari Festival Musik!"
Dialogue: 0,0:02:12.88,0:02:15.10,Default,,0,0,0,,Eng...
Dialogue: 0,0:02:17.99,0:02:20.49,Default,,0,0,0,,Iruma bakal baik-baik saja, 'kan?
Dialogue: 0,0:02:20.49,0:02:22.12,Default,,0,0,0,,Te-Tentu saja!
Dialogue: 0,0:02:22.12,0:02:26.63,Default,,0,0,0,,Menurut Opera, Tuan Iruma harusnya\Nakan kembali normal dalam sejam
Dialogue: 0,0:02:26.63,0:02:27.90,Default,,0,0,0,,Harusnya?
Dialogue: 0,0:02:28.56,0:02:30.80,Default,,0,0,0,,Yah, tak ada gunanya\Nmemaksa dia bangun.
Dialogue: 0,0:02:30.80,0:02:32.51,Default,,0,0,0,,Mari biarkan dia istirahat\Nsampai waktunya tampil—
Dialogue: 0,0:02:35.01,0:02:38.76,Default,,0,0,0,,Hai! Poro telah tiba!
Dialogue: 0,0:02:42.56,0:02:46.27,Default,,0,0,0,,Wah, Royal One! Bikin nostalgia!
Dialogue: 0,0:02:46.27,0:02:49.82,Default,,0,0,0,,Aku jadi ingat banyak\Nkenangan bersama Del.
Dialogue: 0,0:02:49.82,0:02:51.44,Default,,0,0,0,,Hentikan, Tuan Amdus—
Dialogue: 0,0:02:51.44,0:02:53.49,Default,,0,0,0,,- Poro.\N- Tuan Poro.
Dialogue: 0,0:02:53.49,0:02:54.86,Default,,0,0,0,,Festivalnya sebentar lagi—
Dialogue: 0,0:02:54.86,0:02:57.77,Default,,0,0,0,,Tidak masalah.\NAku hanya...
Dialogue: 0,0:02:59.05,0:03:01.70,Default,,0,0,0,,Apa yang kalian lakukan,\Nbocah ingusan?!
Dialogue: 0,0:03:01.70,0:03:03.37,Default,,0,0,0,,Larva apaan ini?!
Dialogue: 0,0:03:03.37,0:03:07.44,Default,,0,0,0,,Tolong jangan kotori\Nsinggasana Del! Hus! Hus!
Dialogue: 0,0:03:07.93,0:03:11.96,Default,,0,0,0,,Singgasana Del!\NJahat banget!
Dialogue: 0,0:03:11.96,0:03:14.26,Default,,0,0,0,,Pak, beliau itu...
Dialogue: 0,0:03:14.26,0:03:15.59,Default,,0,0,0,,Orang asing?
Dialogue: 0,0:03:15.90,0:03:17.16,Default,,0,0,0,,Tidak.
Dialogue: 0,0:03:17.40,0:03:21.39,Default,,0,0,0,,Beliau adalah salah satu juri\Nfestival kali ini, Tuan Amduscias.
Dialogue: 0,0:03:21.39,0:03:23.35,Default,,0,0,0,,Yang mantan anggota 13 Mahkota itu?
Dialogue: 0,0:03:23.35,0:03:26.35,Default,,0,0,0,,Betul sekali!\NAku datang ke sini untuk melihatnya!
Dialogue: 0,0:03:26.35,0:03:30.86,Default,,0,0,0,,Melihat sosok pria yang merebut\Nruang kelas Tuan Delkira tercintaku!
Dialogue: 0,0:03:30.86,0:03:36.80,Default,,0,0,0,,Royal One adalah sarang cinta\Npenuh kenangan diriku dan Tuan Delkira!
Dialogue: 0,0:03:37.24,0:03:41.37,Default,,0,0,0,,Mana mungkin kuberikan begitu saja\Nke bocah-bocah nakal!
Dialogue: 0,0:03:41.37,0:03:43.91,Default,,0,0,0,,Nah, tunjukkan dirimu, Iruma!
Dialogue: 0,0:03:43.91,0:03:49.12,Default,,0,0,0,,Aku akan putuskan apakah dirimu\Nlayak untuk kelas ini—
Dialogue: 0,0:03:49.12,0:03:51.13,Default,,0,0,0,,Tunggu! Bentar!\NKau bercanda, 'kan?!
Dialogue: 0,0:04:07.28,0:04:10.98,Default,,0,0,0,,Dia lembek banget!\NBerbeda jauh dari bayanganku!
Dialogue: 0,0:04:10.98,0:04:13.48,Default,,0,0,0,,Berubahnya cepat banget, ya.
Dialogue: 0,0:04:13.48,0:04:18.24,Default,,0,0,0,,Apaan, sih?!\NSi lembek itu pakai kelas Del?!
Dialogue: 0,0:04:18.24,0:04:21.24,Default,,0,0,0,,Aku jadi kayak orang bodoh\Nkarena datang untuk ngajak perang!
Dialogue: 0,0:04:21.24,0:04:23.24,Default,,0,0,0,,- Ngajak perang?\N- Ngajak perang?
Dialogue: 0,0:04:24.05,0:04:27.10,Default,,0,0,0,,Aku tahu tentang tugas kalian.
Dialogue: 0,0:04:27.50,0:04:31.46,Default,,0,0,0,,Kalau kalian semua tidak naik\Nke Daleth di festival musik,
Dialogue: 0,0:04:31.46,0:04:34.25,Default,,0,0,0,,kalian akan diusir dari kelas ini, 'kan?
Dialogue: 0,0:04:34.25,0:04:39.23,Default,,0,0,0,,Lalu, jurinya adalah aku,\Nyang tak ingin menyerahkan Royal One.
Dialogue: 0,0:04:39.23,0:04:41.89,Default,,0,0,0,,Waduh, sama sekali\Ntak ada harapan!
Dialogue: 0,0:04:41.89,0:04:43.79,Default,,0,0,0,,Mohon maaf, ya.
Dialogue: 0,0:04:47.52,0:04:51.08,Default,,0,0,0,,Tuanku, terlalu cepat memutuskan hal itu.
Dialogue: 0,0:04:51.08,0:04:54.15,Default,,0,0,0,,Terus terang memang tidak salah,
Dialogue: 0,0:04:54.15,0:04:58.15,Default,,0,0,0,,tapi bukankah salah jika langsung\Nmenyimpulkan begitu saja?
Dialogue: 0,0:04:59.21,0:05:00.80,Default,,0,0,0,,Kau...
Dialogue: 0,0:05:01.16,0:05:02.91,Default,,0,0,0,,pria tampan!
Dialogue: 0,0:05:03.12,0:05:03.91,Default,,0,0,0,,Hah?!
Dialogue: 0,0:05:03.91,0:05:06.20,Default,,0,0,0,,Ah! Sabro bakal dimakan!
Dialogue: 0,0:05:06.20,0:05:07.70,Default,,0,0,0,,Belum akan kumakan, kok!
Dialogue: 0,0:05:07.70,0:05:08.66,Default,,0,0,0,,Belum?!
Dialogue: 0,0:05:15.44,0:05:17.20,Default,,0,0,0,,"Suara Kecemasan."
Dialogue: 0,0:05:19.02,0:05:21.91,Default,,0,0,0,,Daripada gugup,\Nkalian lebih cemas.
Dialogue: 0,0:05:23.19,0:05:25.50,Default,,0,0,0,,Kalian tak punya apa yang kalian ingin.
Dialogue: 0,0:05:25.95,0:05:28.18,Default,,0,0,0,,Suara seperti itu yang kudengar.
Dialogue: 0,0:05:29.74,0:05:31.31,Default,,0,0,0,,Kalian...
Dialogue: 0,0:05:31.31,0:05:33.81,Default,,0,0,0,,belum sepenuhnya siap, 'kan?
Dialogue: 0,0:05:34.54,0:05:38.57,Default,,0,0,0,,Entah kalian kekurangan apa,\Ntapi dengan kondisi berantakan begini...
Dialogue: 0,0:05:38.57,0:05:43.82,Default,,0,0,0,,Bagaimana cara kalian menciptakan\Nsuara yang dapat memuaskanku?!
Dialogue: 0,0:05:44.08,0:05:46.58,Default,,0,0,0,,Purson pasti akan datang.
Dialogue: 0,0:05:46.58,0:05:47.58,Default,,0,0,0,,Eh?
Dialogue: 0,0:05:47.58,0:05:49.58,Default,,0,0,0,,Kau bilang apa, sih?
Dialogue: 0,0:05:54.18,0:05:55.98,Default,,0,0,0,,Suaranya berubah.
Dialogue: 0,0:06:01.59,0:06:05.59,Default,,0,0,0,,Tuan Amduscias, kami hargai\Nperingatan Anda.
Dialogue: 0,0:06:05.78,0:06:09.08,Default,,0,0,0,,Tapi Anda tak perlu khawatir.
Dialogue: 0,0:06:14.06,0:06:19.78,Default,,0,0,0,,Kami pasti akan menusuk Anda\Ndengan suara terbaik.
Dialogue: 0,0:06:28.99,0:06:30.33,Default,,0,0,0,,Oh?
Dialogue: 0,0:06:30.33,0:06:33.83,Default,,0,0,0,,Kalian menantangku, ya!\NBoleh juga!
Dialogue: 0,0:06:35.58,0:06:39.49,Default,,0,0,0,,Kalau merasa bisa merayuku,\Nsilakan coba saja.
Dialogue: 0,0:06:54.87,0:06:58.27,Default,,0,0,0,,Kalau kalian bisa, sih,\Ndasar bocah-bocah tengik.
Dialogue: 0,0:06:58.27,0:07:00.42,Default,,0,0,0,,Kenapa aku digendong lagi?
Dialogue: 0,0:07:02.92,0:07:04.64,Default,,0,0,0,,Masih belum?!
Dialogue: 0,0:07:05.25,0:07:08.03,Default,,0,0,0,,Iblis harusnya bisa cepat!
Dialogue: 0,0:07:08.03,0:07:10.77,Default,,0,0,0,,Buruan, sialan!
Dialogue: 0,0:07:12.59,0:07:14.16,Default,,0,0,0,,Kasar sekali.
Dialogue: 0,0:07:14.16,0:07:16.33,Default,,0,0,0,,Kalian jangan jadi iblis seperti itu.
Dialogue: 0,0:07:16.33,0:07:18.69,Default,,0,0,0,,- Buruan, sialan!\N- Buruan, sialan!
Dialogue: 0,0:07:24.19,0:07:29.20,Default,,0,0,0,,Iruma, kejutan apa yang kali ini\Nakan kamu tunjukkan padaku?
Dialogue: 0,0:07:29.95,0:07:33.12,Default,,0,0,0,,Kira-kira penampilan seperti apa\Nyang akan kamu tampilkan?
Dialogue: 0,0:07:34.41,0:07:35.67,Default,,0,0,0,,Yang begini?
Dialogue: 0,0:07:35.99,0:07:37.10,Default,,0,0,0,,Begini?
Dialogue: 0,0:07:37.10,0:07:38.55,Default,,0,0,0,,Atau...
Dialogue: 0,0:07:38.87,0:07:40.36,Default,,0,0,0,,begini...
Dialogue: 0,0:07:40.65,0:07:44.28,Default,,0,0,0,,Lah! Kok semuanya\Nmalah jadi wajahku, sih?!
Dialogue: 0,0:07:44.28,0:07:45.94,Default,,0,0,0,,Sampai jadi naga juga?!
Dialogue: 0,0:07:45.94,0:07:51.03,Default,,0,0,0,,Naganya enggak! Enggak!\NTapi Iruma jadi pahlawan itu mantap!
Dialogue: 0,0:07:51.25,0:07:52.74,Default,,0,0,0,,Sudah hampir waktunya, ya.
Dialogue: 0,0:07:52.74,0:07:53.99,Default,,0,0,0,,Jadi tidak sabar.
Dialogue: 0,0:08:05.61,0:08:08.88,Default,,0,0,0,,Ah, devi, devi.\NOke, oke.
Dialogue: 0,0:08:08.88,0:08:10.18,Default,,0,0,0,,Kalau begitu,
Dialogue: 0,0:08:10.18,0:08:12.22,Default,,0,0,0,,mari mulai festival musiknya!
Dialogue: 0,0:08:12.22,0:08:15.43,Default,,0,0,0,,Keenam kelas satu\Nbebas menampilkan apa saja!
Dialogue: 0,0:08:15.43,0:08:17.64,Default,,0,0,0,,Para penonton juga boleh bersorak, lo!
Dialogue: 0,0:08:20.41,0:08:24.32,Default,,0,0,0,,Menurut hasil dari undian,\Nurutannya mulai dari kelas A,
Dialogue: 0,0:08:24.32,0:08:28.53,Default,,0,0,0,,kelas C, kelas B, kelas E, kelas D,
Dialogue: 0,0:08:28.53,0:08:31.53,Default,,0,0,0,,lalu kelas abnormal.
Dialogue: 0,0:08:32.47,0:08:34.62,Default,,0,0,0,,Kamu habis dari mana?
Dialogue: 0,0:08:34.62,0:08:36.60,Default,,0,0,0,,Rahasia.
Dialogue: 0,0:08:37.29,0:08:38.29,Default,,0,0,0,,Kalau begitu...
Dialogue: 0,0:08:38.29,0:08:39.96,Default,,0,0,0,,Penampilan pertama!
Dialogue: 0,0:08:39.96,0:08:42.79,Default,,0,0,0,,Dimulai dari kelas A\Ndengan puisi musikalnya!
Dialogue: 0,0:08:48.80,0:08:52.05,Default,,0,0,0,,Duh, mereka tampil terakhir.
Dialogue: 0,0:08:52.05,0:08:54.83,Default,,0,0,0,,Kelas abnormal, ya?
Dialogue: 0,0:08:55.86,0:08:59.69,Default,,0,0,0,,Yah, ini pertandingan suara\Npara murid-murid tercinta.
Dialogue: 0,0:08:59.69,0:09:01.81,Default,,0,0,0,,Mari kita berhatikan baik-baik.
Dialogue: 0,0:09:48.21,0:09:51.51,Default,,0,0,0,,Ini adalah kisah kuno dari dunia iblis.
Dialogue: 0,0:09:52.63,0:09:58.06,Default,,0,0,0,,Kebaikan seorang pangeran dikhianati\Nhingga dia diusir dari takhtanya.
Dialogue: 0,0:09:58.97,0:10:01.94,Default,,0,0,0,,Dirinya pun berakhir di Dunia Roh.
Dialogue: 0,0:10:03.06,0:10:07.28,Default,,0,0,0,,Pangeran itu penakut, pemalu,\Nkecil, dan rapuh.
Dialogue: 0,0:10:08.52,0:10:11.95,Default,,0,0,0,,Tapi para roh mendekapnya.
Dialogue: 0,0:10:12.32,0:10:16.08,Default,,0,0,0,,"Dengarlah perkataan kami.\NJikalau ingin mencapai puncak,"
Dialogue: 0,0:10:18.35,0:10:21.14,Default,,0,0,0,,"dirimu harus lebih rakus lagi!"
Dialogue: 0,0:10:28.37,0:10:30.93,Default,,0,0,0,,Para roh berkata pada sang pangeran.
Dialogue: 0,0:10:32.50,0:10:36.81,Default,,0,0,0,,"Kami akan mengajarimu\Ncara balas dendam."
Dialogue: 0,0:10:41.43,0:10:46.81,Default,,0,0,0,,Membuang rasa malu, rakus akan kekuatan,\Nrakus akan pengetahuan.
Dialogue: 0,0:10:46.81,0:10:49.50,Default,,0,0,0,,Mereka yang memandang rendah dirimu...
Dialogue: 0,0:10:50.75,0:10:52.99,Default,,0,0,0,,Tunjukkan taringmu pada mereka!
Dialogue: 0,0:10:54.19,0:10:58.22,Default,,0,0,0,,Dirimu kuat♪
Dialogue: 0,0:10:58.22,0:11:03.02,Default,,0,0,0,,Dirimu mulia♪
Dialogue: 0,0:11:03.02,0:11:08.69,Default,,0,0,0,,Rakuslah, wahai pemuda♪
Dialogue: 0,0:11:08.69,0:11:14.22,Default,,0,0,0,,Nah, menjeritlah♪
Dialogue: 0,0:11:15.20,0:11:18.85,Default,,0,0,0,,Berikan segalanya padaku!
Dialogue: 0,0:11:25.56,0:11:27.77,Default,,0,0,0,,Dia pun menjadi penguasa.
Dialogue: 0,0:11:29.14,0:11:34.20,Default,,0,0,0,,Dia membangun negeri bersama para roh\Nyang mengajarkan kekuatan padanya.
Dialogue: 0,0:11:35.15,0:11:38.45,Default,,0,0,0,,Mereka pun menjalani hidup\Ndengan sepenuh hati.
Dialogue: 0,0:11:39.01,0:11:40.26,Default,,0,0,0,,Mengesankan banget!
Dialogue: 0,0:11:40.26,0:11:42.01,Default,,0,0,0,,Bikin merinding!
Dialogue: 0,0:11:42.01,0:11:43.06,Default,,0,0,0,,Luar biasa!
Dialogue: 0,0:11:43.06,0:11:44.14,Default,,0,0,0,,Siapa murid kelas satu itu?
Dialogue: 0,0:11:44.14,0:11:45.23,Default,,0,0,0,,Itu Orobas!
Dialogue: 0,0:11:45.23,0:11:47.52,Default,,0,0,0,,Suaranya sungguh luar biasa!
Dialogue: 0,0:11:47.52,0:11:49.90,Default,,0,0,0,,Meriah sekali, ya.
Dialogue: 0,0:11:49.90,0:11:52.73,Default,,0,0,0,,Serasa sudah kalah sejak awal.
Dialogue: 0,0:11:52.73,0:11:54.63,Default,,0,0,0,,Mereka memang luar biasa, sih.
Dialogue: 0,0:11:55.00,0:11:56.90,Default,,0,0,0,,Kita mungkin dalam bahaya.
Dialogue: 0,0:11:56.90,0:11:59.66,Default,,0,0,0,,Hebat!
Dialogue: 0,0:11:59.66,0:12:01.49,Default,,0,0,0,,Iruma, kau sudah bangun?
Dialogue: 0,0:12:01.49,0:12:02.12,Default,,0,0,0,,Tuan Iruma!
Dialogue: 0,0:12:02.12,0:12:03.91,Default,,0,0,0,,Saking luar biasanya,
Dialogue: 0,0:12:04.22,0:12:05.90,Default,,0,0,0,,jadi kelihatan hebat banget!
Dialogue: 0,0:12:06.62,0:12:09.67,Default,,0,0,0,,Semua murid dari kelas lain juga\Nmemikirkan idenya sendiri,
Dialogue: 0,0:12:09.67,0:12:14.42,Default,,0,0,0,,berlatih keras, menampilkannya,\Ndan membuat semuanya bersorak meriah.
Dialogue: 0,0:12:14.42,0:12:17.42,Default,,0,0,0,,Membuat semuanya\Nberpikir mereka luar biasa.
Dialogue: 0,0:12:17.42,0:12:20.91,Default,,0,0,0,,Festival musik mengasyikkan, ya!
Dialogue: 0,0:12:23.95,0:12:27.10,Default,,0,0,0,,Tapi kita yang akan menang!
Dialogue: 0,0:12:27.10,0:12:27.77,Default,,0,0,0,,Ya!
Dialogue: 0,0:12:27.77,0:12:30.06,Default,,0,0,0,,Jadi makin semangat, ya!
Dialogue: 0,0:12:30.06,0:12:33.23,Default,,0,0,0,,Tidak seru kalau lawannya tidak kuat, ya!
Dialogue: 0,0:12:33.23,0:12:37.44,Default,,0,0,0,,Nah, mari kita lihat\Npenilaian dari para juri!
Dialogue: 0,0:12:37.44,0:12:42.68,Default,,0,0,0,,Para juri sekalian,\Nsilakan memberi nilai!
Dialogue: 0,0:12:44.70,0:12:46.79,Default,,0,0,0,,Lima dari enam poin!
Dialogue: 0,0:12:46.79,0:12:49.46,Default,,0,0,0,,Nona Kyupa langsung\Nmemberi nilai tinggi!
Dialogue: 0,0:12:49.46,0:12:52.92,Default,,0,0,0,,Sungguh penampilan yang memukau!
Dialogue: 0,0:12:52.92,0:12:54.57,Default,,0,0,0,,Sangat berharga!
Dialogue: 0,0:12:55.81,0:12:59.38,Default,,0,0,0,,Oh! Nona Mei Mei\Nmemberi empat poin!
Dialogue: 0,0:12:59.38,0:13:01.97,Default,,0,0,0,,Apakah kita sudah bisa tahu\Ncalon juaranya di awal?
Dialogue: 0,0:13:02.74,0:13:06.72,Default,,0,0,0,,Eh? Tuan Amduscias\Nmemberi ti-tiga poin?
Dialogue: 0,0:13:06.72,0:13:08.89,Default,,0,0,0,,Bukankah itu terlalu berlebihan?
Dialogue: 0,0:13:08.89,0:13:11.35,Default,,0,0,0,,Tidak, ini penilaian yang adil, kok.
Dialogue: 0,0:13:11.83,0:13:14.23,Default,,0,0,0,,Baris kedua, ketiga dari kanan.
Dialogue: 0,0:13:14.96,0:13:18.24,Default,,0,0,0,,Lirik yang kau nyanyikan\Nsalah sedikit, 'kan?
Dialogue: 0,0:13:18.24,0:13:21.05,Default,,0,0,0,,Yang di sebelahnya pun telat bernyanyi.
Dialogue: 0,0:13:21.30,0:13:24.81,Default,,0,0,0,,Penampilan kau yang di situ\Nberantakan sekali, ya.
Dialogue: 0,0:13:25.43,0:13:28.23,Default,,0,0,0,,Ada beberapa anak\Nyang suaranya serak.
Dialogue: 0,0:13:28.85,0:13:32.42,Default,,0,0,0,,Pemeran utama, Mas Kuda,\Nsuaranya memang bagus,
Dialogue: 0,0:13:32.42,0:13:34.08,Default,,0,0,0,,tapi terlalu banyak gerak.
Dialogue: 0,0:13:34.08,0:13:38.76,Default,,0,0,0,,Aku tak benci kau egois,\Ntapi bukankah sepi kalau main sendiri?
Dialogue: 0,0:13:39.11,0:13:41.30,Default,,0,0,0,,Suaramu masih muda.
Dialogue: 0,0:13:41.30,0:13:44.26,Default,,0,0,0,,Tapi kau punya potensi,\Njadi rajinlah berlatih.
Dialogue: 0,0:13:45.32,0:13:46.36,Default,,0,0,0,,Baik!
Dialogue: 0,0:13:46.51,0:13:48.64,Default,,0,0,0,,Terus, kalian yang ada\Ndi baris kedua sebelah kanan!
Dialogue: 0,0:13:48.64,0:13:50.14,Default,,0,0,0,,Berikan kontak kalian!
Dialogue: 0,0:13:50.14,0:13:51.13,Default,,0,0,0,,Eh?
Dialogue: 0,0:13:51.45,0:13:54.06,Default,,0,0,0,,Mantan anggota 13 Mahkota\Nmemang keras, ya.
Dialogue: 0,0:13:54.06,0:13:55.44,Default,,0,0,0,,Dia cuma kasih tiga poin.
Dialogue: 0,0:13:55.44,0:13:57.90,Default,,0,0,0,,Jadi tambah semangat, ya, Tuan Iruma!
Dialogue: 0,0:13:57.90,0:13:58.80,Default,,0,0,0,,Iya.
Dialogue: 0,0:14:00.04,0:14:01.30,Default,,0,0,0,,Orang itu...
Dialogue: 0,0:14:01.59,0:14:04.28,Default,,0,0,0,,kayaknya ketat banget, ya.
Dialogue: 0,0:14:06.76,0:14:10.12,Default,,0,0,0,,Kau tadi menantangnya.
Dialogue: 0,0:14:10.12,0:14:11.02,Default,,0,0,0,,Eh?
Dialogue: 0,0:14:11.54,0:14:16.69,Default,,0,0,0,,Berikutnya kelas C, Ansambel Chaos,\Nmusik rock versus musik klasik!
Dialogue: 0,0:14:16.69,0:14:20.57,Default,,0,0,0,,Tapi yang level tinggi\Nlangsung muncul di awal, ya.
Dialogue: 0,0:14:21.11,0:14:23.72,Default,,0,0,0,,Yang barusan mungkin\Nyang terbaik, lo.
Dialogue: 0,0:14:23.72,0:14:26.18,Default,,0,0,0,,Artinya, kelas selanjutnya...
Dialogue: 0,0:14:26.18,0:14:28.71,Default,,0,0,0,,Mungkin kurang enak dipandang, ya.
Dialogue: 0,0:14:41.59,0:14:44.85,Default,,0,0,0,,Setelah mendengar saran\Ndari Kak Ronove,
Dialogue: 0,0:14:46.59,0:14:50.39,Default,,0,0,0,,kami jadi lebih banyak berkompromi\Ndan saling mengobrol.
Dialogue: 0,0:14:51.18,0:14:53.65,Default,,0,0,0,,Mengenali kemampuan rekanmu.
Dialogue: 0,0:14:54.68,0:14:57.32,Default,,0,0,0,,Mengobrol dan tertawa bersama.
Dialogue: 0,0:14:58.48,0:15:02.01,Default,,0,0,0,,- Lalu, kesimpulan yang kami dapat...\N- Lalu, kesimpulan yang kami dapat...
Dialogue: 0,0:15:02.73,0:15:06.08,Default,,0,0,0,,- Musikku memang lebih baik!\N- Musik diriku memang lebih baik!
Dialogue: 0,0:15:06.40,0:15:10.96,Default,,0,0,0,,Ya! Semua ini terjadi karena kami\Nbenar-benar mengenal lawan kami!
Dialogue: 0,0:15:11.93,0:15:13.88,Default,,0,0,0,,Ini adalah pertarungan!
Dialogue: 0,0:15:15.02,0:15:17.87,Default,,0,0,0,,Tak ada musik yang membakar jiwa\Nselain musik rock!
Dialogue: 0,0:15:17.87,0:15:19.52,Default,,0,0,0,,Musik rock!
Dialogue: 0,0:15:20.27,0:15:22.82,Default,,0,0,0,,Tak ada musik yang menggetarkan hati\Nselain musik klasik!
Dialogue: 0,0:15:22.82,0:15:24.78,Default,,0,0,0,,Jangan remehkan tradisi!
Dialogue: 0,0:15:24.78,0:15:27.28,Default,,0,0,0,,Rock and roll!
Dialogue: 0,0:15:35.75,0:15:38.75,Default,,0,0,0,,Mereka serasa saling adu jotos.
Dialogue: 0,0:16:30.61,0:16:32.12,Default,,0,0,0,,Kau di sini, ya.
Dialogue: 0,0:16:36.07,0:16:37.46,Default,,0,0,0,,Ibu.
Dialogue: 0,0:16:39.58,0:16:40.80,Default,,0,0,0,,Ibu di sini.
Dialogue: 0,0:16:41.87,0:16:46.42,Default,,0,0,0,,Ibu di sini sejak kamu mondar-mandir\Ndi depan gerbang 30 menit lalu.
Dialogue: 0,0:16:46.42,0:16:49.74,Default,,0,0,0,,Berarti dari awal, dong.
Dialogue: 0,0:16:52.24,0:16:55.27,Default,,0,0,0,,Ibu hanya penasaran\Nkamu sedang apa.
Dialogue: 0,0:16:57.76,0:16:59.90,Default,,0,0,0,,Ibu senang kamu baik-baik saja.
Dialogue: 0,0:17:01.31,0:17:04.40,Default,,0,0,0,,Maaf aku membuat Ibu khawatir.
Dialogue: 0,0:17:05.85,0:17:07.24,Default,,0,0,0,,Bagaimana dengan Ayah?
Dialogue: 0,0:17:07.73,0:17:09.26,Default,,0,0,0,,Dia menunggumu.
Dialogue: 0,0:17:10.03,0:17:12.22,Default,,0,0,0,,Sebagai ganti kakakmu\Nyang menghilang,
Dialogue: 0,0:17:12.22,0:17:15.50,Default,,0,0,0,,hanya kamulah yang bisa\Nmemimpin keluarga Purson.
Dialogue: 0,0:17:15.95,0:17:19.85,Default,,0,0,0,,Kamu pasti bisa menjadi pemimpin\Nyang ditakuti setiap iblis.
Dialogue: 0,0:17:19.85,0:17:22.42,Default,,0,0,0,,Itulah kenapa dia ingin kamu pulang.
Dialogue: 0,0:17:23.77,0:17:26.34,Default,,0,0,0,,Apa yang ayahmu katakan itu benar.
Dialogue: 0,0:17:26.88,0:17:29.05,Default,,0,0,0,,Kamu punya bakat.
Dialogue: 0,0:17:29.42,0:17:31.78,Default,,0,0,0,,Aku juga ingin kamu pulang.
Dialogue: 0,0:17:32.26,0:17:33.47,Default,,0,0,0,,Jadi...
Dialogue: 0,0:17:35.26,0:17:38.81,Default,,0,0,0,,Kalau ingin memilih,\Npilihlah dengan yakin, Soi.
Dialogue: 0,0:17:42.10,0:17:44.48,Default,,0,0,0,,Dengan segala risikonya.
Dialogue: 0,0:17:48.15,0:17:50.70,Default,,0,0,0,,Meski begitu,\Nkalau kamu tetap memilih musik,
Dialogue: 0,0:17:52.19,0:17:53.80,Default,,0,0,0,,Ibu akan mendukungmu.
Dialogue: 0,0:17:54.06,0:17:55.95,Default,,0,0,0,,Tapi aturan keluarga kita...
Dialogue: 0,0:17:56.55,0:17:58.62,Default,,0,0,0,,Soi, menurut Ibu...
Dialogue: 0,0:17:59.31,0:18:03.06,Default,,0,0,0,,Jujur saja, aturan itu\Nmenjengkelkan banget.
Dialogue: 0,0:18:04.08,0:18:05.06,Default,,0,0,0,,Eh?
Dialogue: 0,0:18:05.58,0:18:08.82,Default,,0,0,0,,Habisnya, netral itu subjektif, 'kan?
Dialogue: 0,0:18:09.17,0:18:12.07,Default,,0,0,0,,Meski seseorang berpikir\Ndia sudah berada di tengah,
Dialogue: 0,0:18:12.46,0:18:15.93,Default,,0,0,0,,tapi bagi orang lain, mungkin\Norang lain itulah yang ada di tengah.
Dialogue: 0,0:18:18.43,0:18:19.70,Default,,0,0,0,,Omong-omong...
Dialogue: 0,0:18:20.05,0:18:23.73,Default,,0,0,0,,Kalau kamu penasaran\Nkenapa Ibu memihak ayahmu.
Dialogue: 0,0:18:24.77,0:18:27.46,Default,,0,0,0,,Itu karena Ibu sangat cinta\Npada ayahmu.
Dialogue: 0,0:18:29.96,0:18:31.34,Default,,0,0,0,,Dia tampak keras kepala\Nkarena dia payah dalam berbicara.
Dialogue: 0,0:18:31.34,0:18:32.63,Default,,0,0,0,,Dia sering bingung harus bilang apa.
Dialogue: 0,0:18:32.63,0:18:33.93,Default,,0,0,0,,Ekspresinya saat terdiam itu, lo.
Dialogue: 0,0:18:33.93,0:18:36.68,Default,,0,0,0,,Dia bilang tidak bisa makan\Ntanpa Ibu karena kesepian.
Dialogue: 0,0:18:36.68,0:18:38.22,Default,,0,0,0,,Bukankah imut?\NIbu pun berakhir masak banyak.
Dialogue: 0,0:18:38.22,0:18:41.02,Default,,0,0,0,,Dia tertidur sambil memegang\Ndagunya saat kelelahan, lo.
Dialogue: 0,0:18:41.02,0:18:42.98,Default,,0,0,0,,Dia sangat jantan\Ndan membuat hati Ibu berdebar-debar.
Dialogue: 0,0:18:43.28,0:18:45.65,Default,,0,0,0,,Dia keras kepala, ceroboh,\Ndan tak bisa lompat tali.
Dialogue: 0,0:18:45.65,0:18:46.98,Default,,0,0,0,,Ibu!
Dialogue: 0,0:18:46.98,0:18:48.77,Default,,0,0,0,,Tolong ampuni aku.
Dialogue: 0,0:18:48.77,0:18:52.15,Default,,0,0,0,,Aku tidak tahan orang tuaku\Npamer kemesraan di gerbang sekolah.
Dialogue: 0,0:18:52.15,0:18:53.74,Default,,0,0,0,,Emosiku jadi mati.
Dialogue: 0,0:18:53.74,0:18:54.99,Default,,0,0,0,,Ah, maafkan Ibu.
Dialogue: 0,0:18:55.59,0:18:56.89,Default,,0,0,0,,Dengan kata lain...
Dialogue: 0,0:18:57.66,0:19:01.19,Default,,0,0,0,,Kamu boleh memilih "tengahmu" sendiri.
Dialogue: 0,0:19:06.47,0:19:07.61,Default,,0,0,0,,Soi.
Dialogue: 0,0:19:15.03,0:19:18.37,Default,,0,0,0,,Yang mana yang kamu inginkan?
Dialogue: 0,0:19:21.03,0:19:22.33,Default,,0,0,0,,Keinginanku...
Dialogue: 0,0:19:26.04,0:19:30.19,Default,,0,0,0,,Keinginanku adalah\Nbisa bersama denganmu.
Dialogue: 0,0:19:30.75,0:19:34.30,Default,,0,0,0,,Kalau itu bisa terwujud,\Naku tak butuh apa-apa lagi.
Dialogue: 0,0:19:41.89,0:19:47.86,Default,,0,0,0,,Aku yang terperangkap di kastel ini,\Ntanpa rumah, keluarga, dan harta benda...
Dialogue: 0,0:19:48.56,0:19:52.74,Default,,0,0,0,,Akankah kamu memilihku\Ndan membuang segalanya?
Dialogue: 0,0:19:53.23,0:19:57.34,Default,,0,0,0,,Masa hidupku sangat panjang\Nhingga bisa dianggap abadi.
Dialogue: 0,0:19:57.34,0:19:59.72,Default,,0,0,0,,Kau pasti akan menyesal.
Dialogue: 0,0:20:00.11,0:20:01.47,Default,,0,0,0,,Ketemu!
Dialogue: 0,0:20:01.82,0:20:05.23,Default,,0,0,0,,Naga yang dibenci!\NPersiapkan dirimu!
Dialogue: 0,0:20:05.23,0:20:06.54,Default,,0,0,0,,Tenang saja.
Dialogue: 0,0:20:07.23,0:20:09.98,Default,,0,0,0,,Aku tak akan menyesal!
Dialogue: 0,0:20:09.98,0:20:11.73,Default,,0,0,0,,Itu pasti!
Dialogue: 0,0:20:16.25,0:20:17.90,Default,,0,0,0,,Chercille.
Dialogue: 0,0:20:22.55,0:20:26.65,Default,,0,0,0,,Kita akan selalu bersama selamanya!
Dialogue: 0,0:20:35.61,0:20:38.45,Default,,0,0,0,,Kita akan bersama selamanya.
Dialogue: 0,0:20:38.94,0:20:41.54,Default,,0,0,0,,Kita akan selalu bersama.
Dialogue: 0,0:20:44.91,0:20:48.67,Default,,0,0,0,,- Aku percaya pada cinta nan abadi.\N- Aku percaya pada cinta nan abadi.
Dialogue: 0,0:20:54.83,0:20:56.55,Default,,0,0,0,,Kamulah...
Dialogue: 0,0:21:00.46,0:21:02.85,Default,,0,0,0,,duniaku.
Dialogue: 0,0:21:24.64,0:21:27.60,Default,,0,0,0,,Wah! Tuan Amduscias\Nmemberi empat poin!
Dialogue: 0,0:21:27.60,0:21:30.14,Default,,0,0,0,,Ini poin tertinggi dari beliau!
Dialogue: 0,0:21:31.41,0:21:33.65,Default,,0,0,0,,Wah!
Dialogue: 0,0:21:34.00,0:21:36.27,Default,,0,0,0,,Aku benar-benar tersentuh.
Dialogue: 0,0:21:36.27,0:21:39.28,Default,,0,0,0,,Benar-benar luar biasa.
Dialogue: 0,0:21:39.28,0:21:43.32,Default,,0,0,0,,Berikutnya, kelas E, kelas D,\Nlalu kelas abnormal.
Dialogue: 0,0:21:43.32,0:21:46.41,Default,,0,0,0,,Kelas yang akan tampil di paruh akhir,\Nmohon segera berpindah.
Dialogue: 0,0:21:48.97,0:21:50.44,Default,,0,0,0,,Sudah waktunya.
Dialogue: 0,0:21:52.43,0:21:53.69,Default,,0,0,0,,Berdiri.
Dialogue: 0,0:21:58.21,0:21:59.51,Default,,0,0,0,,Akhirnya, ya.
Dialogue: 0,0:21:59.51,0:22:00.80,Default,,0,0,0,,Sudah paruh akhir.
Dialogue: 0,0:22:00.80,0:22:03.22,Default,,0,0,0,,Kelas abnormal bakal nampilin apa?
Dialogue: 0,0:22:03.22,0:22:04.97,Default,,0,0,0,,Kakak!
Dialogue: 0,0:22:04.97,0:22:07.37,Default,,0,0,0,,Semuanya, berjuanglah!
Dialogue: 0,0:22:08.72,0:22:12.38,Default,,0,0,0,,Iruma, gapailah kemenangan!
Dialogue: 0,0:22:13.12,0:22:18.93,Default,,0,0,0,,Kuulangi lagi, kelas yang akan tampil\Ndi paruh akhir, mohon segera bersiap.
Dialogue: 0,0:22:38.09,0:22:40.13,Default,,0,0,0,,Sip, ayo mulai!♪
Dialogue: 0,0:22:40.13,0:22:41.51,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:41.51,0:22:42.64,Default,,0,0,0,,Pasti menang!♪
Dialogue: 0,0:22:42.64,0:22:43.89,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:43.89,0:22:45.14,Default,,0,0,0,,Menang dengan gemilang♪
Dialogue: 0,0:22:45.14,0:22:46.39,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:46.39,0:22:47.64,Default,,0,0,0,,Menang dengan iseng♪
Dialogue: 0,0:22:47.64,0:22:48.97,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:48.97,0:22:50.68,Default,,0,0,0,,Kamilah pemenangnya!♪
Dialogue: 0,0:22:50.68,0:22:52.90,Default,,0,0,0,,Kemenangan luar biasa!♪
Dialogue: 0,0:22:52.90,0:22:55.44,Default,,0,0,0,,Ya! Ya! Ya! Menang lagi hari ini!♪
Dialogue: 0,0:22:55.44,0:22:57.86,Default,,0,0,0,,Senang! Senang! Duar! Terbaik!♪
Dialogue: 0,0:22:57.86,0:23:00.53,Default,,0,0,0,,Ya! Ya! Ya! Kemenangan sempurna!♪
Dialogue: 0,0:23:00.53,0:23:02.70,Default,,0,0,0,,Senang! Senang! Duar! Jempolan!♪
Dialogue: 0,0:23:02.70,0:23:05.53,Default,,0,0,0,,Bukannya enggak bakal kalah,\Ntapi mustahil kalah♪
Dialogue: 0,0:23:05.53,0:23:08.08,Default,,0,0,0,,Berjuang tuh rasanya mengasyikkan♪
Dialogue: 0,0:23:08.08,0:23:10.58,Default,,0,0,0,,Makanan enak pun\Nbuat kualitas hidup naik♪
Dialogue: 0,0:23:10.58,0:23:13.37,Default,,0,0,0,,Pertumbuhan pesat tak terbendung!\NMantap! Kawan!♪
Dialogue: 0,0:23:13.37,0:23:14.38,Default,,0,0,0,,Hei! Yo!♪
Dialogue: 0,0:23:14.38,0:23:17.17,Default,,0,0,0,,Punya teman 'tuk berlomba tuh terbaik!♪
Dialogue: 0,0:23:17.17,0:23:19.88,Default,,0,0,0,,Bisa melampaui batasan\Ndiri sendiri tuh terkuat!♪
Dialogue: 0,0:23:19.88,0:23:22.47,Default,,0,0,0,,Imutnya bukan main! Bodoh!♪
Dialogue: 0,0:23:22.47,0:23:25.59,Default,,0,0,0,,Itu sudah pasti aku!♪
Dialogue: 0,0:23:25.59,0:23:26.51,Default,,0,0,0,,Tentu, dong!♪
Dialogue: 0,0:23:26.51,0:23:29.18,Default,,0,0,0,,Raih kemenangan dengan\Nsegenap kekuatan♪
Dialogue: 0,0:23:29.18,0:23:31.39,Default,,0,0,0,,Kami 'kan tokoh utama,\Njadi pasti memimpin!♪
Dialogue: 0,0:23:31.64,0:23:34.27,Default,,0,0,0,,Hidup bersama jadi pusat perhatian♪
Dialogue: 0,0:23:34.27,0:23:35.73,Default,,0,0,0,,Heroine dijamin menang!♪
Dialogue: 0,0:23:35.73,0:23:36.73,Default,,0,0,0,,Kami menang!♪
Dialogue: 0,0:23:36.73,0:23:37.94,Default,,0,0,0,,Duk, duk, tok, tok♪
Dialogue: 0,0:23:37.94,0:23:38.90,Default,,0,0,0,,La, la, la, la, yey♪
Dialogue: 0,0:23:38.90,0:23:40.78,Default,,0,0,0,,Kisah kita berempat!!♪
Dialogue: 0,0:23:40.78,0:23:41.78,Default,,0,0,0,,Sip, menang!♪
Dialogue: 0,0:23:41.78,0:23:42.36,Default,,0,0,0,,Wus, wus, dor, dor♪
Dialogue: 0,0:23:42.36,0:23:42.99,Default,,0,0,0,,Buk, buk, blar, blar♪
Dialogue: 0,0:23:42.99,0:23:44.07,Default,,0,0,0,,Berdebar dengan kencangnya♪
Dialogue: 0,0:23:44.07,0:23:46.66,Default,,0,0,0,,Motivasiku melambung tinggi!!♪
Dialogue: 0,0:23:46.66,0:23:48.70,Default,,0,0,0,,Tu, wa, lalu maju♪
Dialogue: 0,0:23:48.70,0:23:49.16,Default,,0,0,0,,Demi aku♪
Dialogue: 0,0:23:49.16,0:23:51.20,Default,,0,0,0,,Ditambah lagi, runaway♪
Dialogue: 0,0:23:51.20,0:23:51.66,Default,,0,0,0,,Demi aku♪
Dialogue: 0,0:23:51.66,0:23:53.04,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:53.04,0:23:54.12,Default,,0,0,0,,Pasti menang!♪
Dialogue: 0,0:23:54.12,0:23:55.46,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:55.46,0:23:56.58,Default,,0,0,0,,Menang dengan gemilang♪
Dialogue: 0,0:23:56.58,0:23:58.04,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:58.04,0:23:59.04,Default,,0,0,0,,Menang dengan iseng♪
Dialogue: 0,0:23:59.04,0:24:00.50,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:24:00.50,0:24:03.97,Default,,0,0,0,,Kamilah pemenangnya!♪
Dialogue: 0,0:24:04.40,0:24:08.45,Default,,0,0,0,,Tambahan!
Dialogue: 0,0:24:09.74,0:24:11.51,Default,,0,0,0,,Irumachi, bangun!
Dialogue: 0,0:24:11.51,0:24:14.08,Default,,0,0,0,,Festival musiknya sudah mau mulai!
Dialogue: 0,0:24:14.78,0:24:16.69,Default,,0,0,0,,- Tidak berhasil, ya.\N- Tidak berhasil, ya.
Dialogue: 0,0:24:16.69,0:24:17.98,Default,,0,0,0,,- Tapi...\N- Tapi...
Dialogue: 0,0:24:19.73,0:24:22.73,Default,,0,0,0,,- Beliau imut kalau begini, jadi biarlah.\N- Dia imut kalau begini, jadi biarlah.
Dialogue: 0,0:24:23.17,0:24:26.03,Default,,0,0,0,,Aku yang akan menggendong\NTuan Iruma!
Dialogue: 0,0:24:26.03,0:24:28.39,Default,,0,0,0,,Irumachi itu punyaku!
Dialogue: 0,0:24:30.34,0:24:33.16,Default,,0,0,0,,Penampilan kelas-kelas lain\Nsangat luar biasa, ya.
Dialogue: 0,0:24:33.16,0:24:36.50,Default,,0,0,0,,Tapi kita juga tidak boleh kalah.\NKita sudah banyak latihan.
Dialogue: 0,0:24:36.50,0:24:39.12,Default,,0,0,0,,Kita tak akan biarkan tangis\Ndan keringat terbuang sia-sia.
Dialogue: 0,0:24:39.12,0:24:42.73,Default,,0,0,0,,Pasti akan baik-baik saja!\NKita akan buat lebih meriah lagi!
Dialogue: 0,0:24:42.73,0:24:44.88,Default,,0,0,0,,Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:44.88,0:24:46.13,Default,,0,0,0,,"Karpet Lilith".
Dialogue: 0,0:24:46.13,0:24:47.38,Default,,0,0,0,,Nah, ayo!
Dialogue: 0,0:24:47.38,0:24:52.05,Default,,0,0,0,,Mari kita satukan kekuatan,\Nbermain musik, bernyanyi, dan menari.
Dialogue: 0,0:24:52.05,0:24:55.01,Default,,0,0,0,,Selain itu, kita juga punya Purson.
