Dialogue: 0,0:08:30.70,0:08:31.99,On Top,,0,0,0,,Gawat, ada guru!
Dialogue: 0,0:08:31.99,0:08:33.66,On Top,,0,0,0,,Ayo lari!
Dialogue: 0,0:09:02.23,0:09:06.23,On Top,,0,0,0,,(Ruang Pengurus OSIS)
Dialogue: 0,0:09:11.86,0:09:15.87,On Top,,0,0,0,,(Ronove Romiere)
Dialogue: 0,0:09:16.62,0:09:21.37,On Top,,0,0,0,,(Ampsey Nafura)
Dialogue: 0,0:09:23.50,0:09:25.75,On Top,,0,0,0,,(RoNOve!!)
Dialogue: 0,0:09:34.68,0:09:39.52,On Top,,0,0,0,,(Pekerjaan Kasar)
Dialogue: 0,0:09:39.52,0:09:41.45,On Top,,0,0,0,,Ini pelanggaran!
Dialogue: 0,0:09:41.45,0:09:43.33,On Top,,0,0,0,,Ini kejahatan!
Dialogue: 0,0:09:47.02,0:09:50.78,On Top,,0,0,0,,Apa? Mau gelud? Gelud kita?
Dialogue: 0,0:10:08.84,0:10:10.11,On Top,,0,0,0,,Nagyo?!
Dialogue: 0,0:10:17.68,0:10:20.18,On Top,,0,0,0,,(Festival Musik)
Dialogue: 0,0:10:26.81,0:10:28.19,On Top,,0,0,0,,(Iruma Penyanyi)
Dialogue: 0,0:10:28.19,0:10:29.57,On Top,,0,0,0,,(Iruma Berakting)
Dialogue: 0,0:10:29.57,0:10:30.82,On Top,,0,0,0,,(Iruma Main Band)
Dialogue: 0,0:10:41.83,0:10:44.33,On Top,,0,0,0,,(Manga Bonus di Akhir Volume\NIngatan Cinta Pertama - 2)
Dialogue: 0,0:11:25.25,0:11:27.04,On Top,,0,0,0,,(Kelas 1-A)
Dialogue: 0,0:11:27.68,0:11:31.29,On Top,,0,0,0,,Lihatlah aku!
Dialogue: 0,0:11:38.55,0:11:41.57,On Top,,0,0,0,,Ini aku! Ini aku!
Dialogue: 0,0:11:41.72,0:11:44.31,On Top,,0,0,0,,Lihatlah... Lihatlah...
Dialogue: 0,0:11:44.81,0:11:47.44,On Top,,0,0,0,,Lihatlah aku!
Dialogue: 0,0:11:47.44,0:11:52.82,On Top,,0,0,0,,(Kami Pengurus OSIS)
Dialogue: 0,0:12:04.16,0:12:05.77,On Top,,0,0,0,,Biasa saja, kok.
Dialogue: 0,0:12:29.10,0:12:30.77,On Top,,0,0,0,,(Maafkan kami)
Dialogue: 0,0:12:31.61,0:12:33.57,On Top,,0,0,0,,(Kelas 1-B)
Dialogue: 0,0:12:50.29,0:12:54.69,On Top,,0,0,0,,Takdirku yang turun dari langit...
Dialogue: 0,0:13:11.35,0:13:13.19,On Top,,0,0,0,,(Maaf)
Dialogue: 0,0:13:13.90,0:13:15.44,On Top,,0,0,0,,(Kelas 1-C)
Dialogue: 0,0:13:15.82,0:13:19.44,On Top,,0,0,0,,(Pemimpin Tim Musik Rock - Gyatz)
Dialogue: 0,0:13:22.45,0:13:27.33,On Top,,0,0,0,,(Pemimpin Tim Musik Klasik - Boni)
Dialogue: 0,0:13:53.33,0:13:55.63,On Top,,0,0,0,,Aku cinta kalian!♪
Dialogue: 0,0:13:56.37,0:13:57.65,On Top,,0,0,0,,Fabulous!♪
Dialogue: 0,0:13:57.92,0:14:01.40,On Top,,0,0,0,,Ronove! Ronove! Romiere!♪
Dialogue: 0,0:14:01.84,0:14:04.26,On Top,,0,0,0,,Namaku! Namaku!♪
Dialogue: 0,0:14:04.72,0:14:07.12,On Top,,0,0,0,,Ronove Romiere!♪
Dialogue: 0,0:14:07.12,0:14:09.08,On Top,,0,0,0,,(Jangan bertengkar)
Dialogue: 0,0:14:09.08,0:14:10.29,On Top,,0,0,0,,Cinta!♪
Dialogue: 0,0:14:10.91,0:14:12.04,On Top,,0,0,0,,(Kelas D)
Dialogue: 0,0:14:12.66,0:14:13.79,On Top,,0,0,0,,(Kelas E)
Dialogue: 0,0:14:27.05,0:14:29.18,On Top,,0,0,0,,(Festival Musik)
Dialogue: 0,0:16:07.61,0:16:11.12,On Top,,0,0,0,,(Penampilan yang membuat semuanya bersinar\Ntanpa menjadikan Purson pusat perhatian.)
Dialogue: 0,0:17:34.62,0:17:36.20,On Top,,0,0,0,,(Bagai Neraka...)
Dialogue: 0,0:17:43.04,0:17:47.09,On Top,,0,0,0,,Ayo, Ronove! Ayo, Ronove!
Dialogue: 0,0:17:53.09,0:17:55.10,On Top,,0,0,0,,(- Band - Paduan Suara\N- Drama Raja Iblis - Devicon - Njaraka)
Dialogue: 0,0:20:07.85,0:20:11.11,On Top,,0,0,0,,(Senam Siksaan)
Dialogue: 0,0:20:49.98,0:20:51.60,On Top,,0,0,0,,(Hell Dance)
Dialogue: 0,0:22:02.43,0:22:05.97,On Top,,0,0,0,,Ayo, ayo! Ayo lakukan!
Dialogue: 0,0:22:33.75,0:22:37.00,On Top,,0,0,0,,(Hell Dance)
Dialogue: 0,0:24:09.51,0:24:11.18,On Top,,0,0,0,,(Tambahan)
