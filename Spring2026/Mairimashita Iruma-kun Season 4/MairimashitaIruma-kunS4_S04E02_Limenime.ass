Dialogue: 0,0:24:29.99,0:24:55.01,On Top,,0,0,0,,(Cuplikan)
Dialogue: 0,0:00:00.00,0:00:01.25,Default,,0,0,0,,
Dialogue: 0,0:00:01.25,0:00:04.11,Default,,0,0,0,,Kelas abnormal diberi suatu perintah.
Dialogue: 0,0:00:04.11,0:00:08.78,Default,,0,0,0,,Jika sebelum naik kelas,\Nseluruh muridnya gagal naik ke Daleth,
Dialogue: 0,0:00:08.78,0:00:12.66,Default,,0,0,0,,maka mereka akan diusir\Ndari Kelas Raja, Royal One.
Dialogue: 0,0:00:13.01,0:00:16.20,Default,,0,0,0,,Akankah murid kelas abnormal\Nselain Iruma, Asmodeus, Lied,
Dialogue: 0,0:00:16.20,0:00:18.66,Default,,0,0,0,,bisa naik ke Daleth?
Dialogue: 0,0:00:19.06,0:00:21.79,Default,,0,0,0,,Iruma dan kawan-kawan\Nakan menghadapi ujian kenaikan peringkat,
Dialogue: 0,0:00:21.79,0:00:23.99,Default,,0,0,0,,yakni Festival Musik!
Dialogue: 0,0:00:29.72,0:00:31.59,Default,,0,0,0,,Bangkit! Bangkit! Bangkit! Bangkit!♪
Dialogue: 0,0:00:31.59,0:00:33.47,Default,,0,0,0,,Mari buat keributan\Ndan egois hingga fajar♪
Dialogue: 0,0:00:40.77,0:00:42.56,Default,,0,0,0,,Murid berprestasi,\Nkau tahu maksudku?♪
Dialogue: 0,0:00:42.56,0:00:45.11,Default,,0,0,0,,Kutak tahu apa-apa sejak awal♪
Dialogue: 0,0:00:45.11,0:00:48.49,Default,,0,0,0,,Abaikan saja perdamaian dan keadilan♪
Dialogue: 0,0:00:49.03,0:00:50.61,Default,,0,0,0,,Ah, lelah rasanya♪
Dialogue: 0,0:00:50.61,0:00:52.95,Default,,0,0,0,,Saat ingin menangis,♪
Dialogue: 0,0:00:52.95,0:00:55.08,Default,,0,0,0,,tujulah panggung nan megah♪
Dialogue: 0,0:00:55.08,0:00:56.91,Default,,0,0,0,,Bangkit! Bangkit! Bangkit! Bangkit!♪
Dialogue: 0,0:00:56.91,0:00:57.87,Default,,0,0,0,,Egois hingga akhir♪
Dialogue: 0,0:00:57.87,0:01:01.71,Default,,0,0,0,,Deru seketika jadi anggun♪
Dialogue: 0,0:01:01.71,0:01:06.46,Default,,0,0,0,,Saat menggenggam tangan itu,\Nsemuanya dimulai♪
Dialogue: 0,0:01:06.46,0:01:08.42,Default,,0,0,0,,Kala lampu menyala lagi,\Nmahatahu dan mahakuasa♪
Dialogue: 0,0:01:08.42,0:01:09.97,Default,,0,0,0,,akan buat keributan♪
Dialogue: 0,0:01:09.97,0:01:13.51,Default,,0,0,0,,Jadi ayo kita meriahkan♪
Dialogue: 0,0:01:15.30,0:01:16.31,Default,,0,0,0,,Tiketnya habis ludes♪
Dialogue: 0,0:01:16.31,0:01:19.77,Default,,0,0,0,,Pestanya dimulai dalam\Nhitungan satu, dua, dan tiga♪
Dialogue: 0,0:01:19.77,0:01:21.94,Default,,0,0,0,,Mari berkumpul dan bersorak meriah♪
Dialogue: 0,0:01:21.94,0:01:23.94,Default,,0,0,0,,(Semua! Semua! Semuanya!♪)
Dialogue: 0,0:01:23.94,0:01:27.57,Default,,0,0,0,,Dua, tiga, empat!\NMari bermimpi bersama, Sayang♪
Dialogue: 0,0:01:27.82,0:01:29.74,Default,,0,0,0,,Buang jauh-jauh rasa khawatir itu♪
Dialogue: 0,0:01:29.74,0:01:33.91,Default,,0,0,0,,(Semua! Semua! Semuanya!♪)
Dialogue: 0,0:01:34.74,0:01:37.95,Default,,0,0,0,,(Semuanya!♪)
Dialogue: 0,0:01:38.74,0:01:43.71,Default,,0,0,0,,(Semuanya!♪)
Dialogue: 0,0:01:43.71,0:01:47.50,Default,,0,0,0,,Pestanya dimulai dalam\Nhitungan satu, dua, dan tiga♪
Dialogue: 0,0:01:55.74,0:01:58.16,Default,,0,0,0,,"Tantangan 13 Orang".
Dialogue: 0,0:02:07.44,0:02:09.79,Default,,0,0,0,,Melihat bunga sakura, ya?
Dialogue: 0,0:02:12.82,0:02:16.70,Default,,0,0,0,,Jarang-jarang Iruma\Nmembuat rencana begini.
Dialogue: 0,0:02:16.70,0:02:20.04,Default,,0,0,0,,Ke sekolah di malam hari\Nbikin deg-degan, ya!
Dialogue: 0,0:02:20.04,0:02:24.65,Default,,0,0,0,,Bunga sakura! Bunga sakura!
Dialogue: 0,0:02:25.64,0:02:28.46,Default,,0,0,0,,Terus, kita mau ngapain di sini?
Dialogue: 0,0:02:37.15,0:02:38.35,Default,,0,0,0,,Itu, 'kan?!
Dialogue: 0,0:02:38.35,0:02:39.76,Default,,0,0,0,,Pixie?!
Dialogue: 0,0:02:39.76,0:02:41.02,Default,,0,0,0,,Di jam segini?!
Dialogue: 0,0:02:41.02,0:02:43.35,Default,,0,0,0,,Azz, bisa tolong\Nberi kami pencahayaan?
Dialogue: 0,0:02:43.35,0:02:45.06,Default,,0,0,0,,Ya! Serahkan padaku!
Dialogue: 0,0:03:09.08,0:03:10.75,Default,,0,0,0,,Purson Soi?!
Dialogue: 0,0:03:10.75,0:03:12.99,Default,,0,0,0,,Itu artinya, Pixie adalah...
Dialogue: 0,0:03:15.01,0:03:17.51,Default,,0,0,0,,Eh?!
Dialogue: 0,0:03:18.11,0:03:19.51,Default,,0,0,0,,Eng...
Dialogue: 0,0:03:19.73,0:03:21.51,Default,,0,0,0,,Jadi...
Dialogue: 0,0:03:21.51,0:03:23.91,Default,,0,0,0,,Dia Purson.
Dialogue: 0,0:03:23.91,0:03:26.27,Default,,0,0,0,,Dia berada jauh di belakangmu, tuh.
Dialogue: 0,0:03:26.44,0:03:30.13,Default,,0,0,0,,Itu karena kalian\Nmenggerombolinya sekaligus.
Dialogue: 0,0:03:30.54,0:03:31.69,Default,,0,0,0,,Purson!
Dialogue: 0,0:03:31.69,0:03:33.36,Default,,0,0,0,,Kau beneran ada, ya!
Dialogue: 0,0:03:33.36,0:03:35.65,Default,,0,0,0,,Sungguh mengagumkan.\NTubuh nan misterius.
Dialogue: 0,0:03:35.96,0:03:37.28,Default,,0,0,0,,Dia ketakutan.
Dialogue: 0,0:03:37.28,0:03:38.70,Default,,0,0,0,,Maafkan kami.
Dialogue: 0,0:03:38.70,0:03:40.95,Default,,0,0,0,,Kami tak akan menyentuhmu lagi, kok.
Dialogue: 0,0:03:49.89,0:03:51.04,Default,,0,0,0,,Aku mengerti.
Dialogue: 0,0:03:51.25,0:03:52.59,Default,,0,0,0,,Katanya dia gugup.
Dialogue: 0,0:03:52.59,0:03:54.76,Default,,0,0,0,,Aneh banget, tuh!\NDia jelas ngomong lama!
Dialogue: 0,0:03:55.01,0:03:57.05,Default,,0,0,0,,Kami pasti akan\Nmendengarkanmu, kok.
Dialogue: 0,0:03:57.05,0:03:59.26,Default,,0,0,0,,Tidak, kalau kau gugup,\Nserahkan saja padaku.
Dialogue: 0,0:03:59.26,0:04:02.64,Default,,0,0,0,,Aku akan mengobrol denganmu.\NBerduaan saja.
Dialogue: 0,0:04:02.64,0:04:05.02,Default,,0,0,0,,Katakan saja jika\Nada yang ingin kau katakan.
Dialogue: 0,0:04:05.22,0:04:06.33,Default,,0,0,0,,Kalau begitu...
Dialogue: 0,0:04:07.64,0:04:10.48,Default,,0,0,0,,Shax Lied, kau terlalu sok dekat.\NDekat banget.
Dialogue: 0,0:04:10.48,0:04:13.27,Default,,0,0,0,,Kau boleh saja makan mie sepulang sekolah,\Ntapi tolong dibersihkan, dong.
Dialogue: 0,0:04:13.27,0:04:14.19,Default,,0,0,0,,Tumpah-tumpah di lantai, tahu.
Dialogue: 0,0:04:14.19,0:04:15.99,Default,,0,0,0,,Sebaiknya kau tak bawa\Nmajalah mesum ke sekolah.
Dialogue: 0,0:04:15.99,0:04:16.82,Default,,0,0,0,,Pakaianmu berserakan di mana-mana.
Dialogue: 0,0:04:16.82,0:04:18.53,Default,,0,0,0,,Kau biarkan karena tahu\NGaap bakal merapikannya, 'kan?
Dialogue: 0,0:04:18.53,0:04:20.16,Default,,0,0,0,,Terus, kau terlalu ngelihatin\NMbak saat pelajaran.
Dialogue: 0,0:04:21.66,0:04:23.33,Default,,0,0,0,,Apa yang terjadi?
Dialogue: 0,0:04:23.33,0:04:25.20,Default,,0,0,0,,Dia benar-benar cerewet, ya.
Dialogue: 0,0:04:25.37,0:04:26.50,Default,,0,0,0,,Selanjutnya...
Dialogue: 0,0:04:26.50,0:04:27.81,Default,,0,0,0,,Allocer.
Dialogue: 0,0:04:28.46,0:04:32.26,Default,,0,0,0,,Kau pergi kencan buta dengan\Ngadis dari sekolah lain tempo hari, 'kan?
Dialogue: 0,0:04:32.26,0:04:35.17,Default,,0,0,0,,Kau pergi sendiri atas undangan\Ndari putrinya Bu Furcas.
Dialogue: 0,0:04:35.17,0:04:36.34,Default,,0,0,0,,Apa?!
Dialogue: 0,0:04:36.34,0:04:39.09,Default,,0,0,0,,Kukira kau tidak tertarik hal begituan!
Dialogue: 0,0:04:39.09,0:04:40.97,Default,,0,0,0,,Lihat ke sini, sialan!
Dialogue: 0,0:04:40.97,0:04:42.59,Default,,0,0,0,,Diam itu emas.
Dialogue: 0,0:04:42.59,0:04:44.35,Default,,0,0,0,,Kami tak akan tertipu!
Dialogue: 0,0:04:44.56,0:04:45.58,Default,,0,0,0,,Terus...
Dialogue: 0,0:04:45.99,0:04:49.31,Default,,0,0,0,,Sabnock, kau kadang tidur\Ndi Royal One tanpa izin.
Dialogue: 0,0:04:49.31,0:04:50.85,Default,,0,0,0,,Ah! Ketahuan!
Dialogue: 0,0:04:50.85,0:04:52.35,Default,,0,0,0,,Kamar daku!
Dialogue: 0,0:04:52.79,0:04:57.32,Default,,0,0,0,,Asmodeus, kau terkadang diam-diam\Nmemotret Iruma dan Clara.
Dialogue: 0,0:05:00.92,0:05:04.66,Default,,0,0,0,,Duh, Azz-Azz, harusnya kamu bilang saja.
Dialogue: 0,0:05:04.66,0:05:09.25,Default,,0,0,0,,Kau salah! Tuan Iru—\NAku cuma—
Dialogue: 0,0:05:09.25,0:05:10.25,Default,,0,0,0,,Kalau Iruma...
Dialogue: 0,0:05:10.25,0:05:11.37,Default,,0,0,0,,Aku juga?
Dialogue: 0,0:05:11.97,0:05:15.92,Default,,0,0,0,,Sebaiknya kau berhenti nyemil diam-diam\Nsaat sedang pelajaran.
Dialogue: 0,0:05:16.81,0:05:18.13,Default,,0,0,0,,Tuan Iruma!
Dialogue: 0,0:05:18.13,0:05:21.13,Default,,0,0,0,,Irumachi, jangan nyemil\Nsebelum makan malam!
Dialogue: 0,0:05:21.13,0:05:24.39,Default,,0,0,0,,Cukup, Purson!\NCewek-cewek ketakutan, nih!
Dialogue: 0,0:05:24.57,0:05:27.47,Default,,0,0,0,,Tidak, aku tidak akan\Nmembeberkan rahasia cewek.
Dialogue: 0,0:05:27.47,0:05:28.31,Default,,0,0,0,,Laki banget!
Dialogue: 0,0:05:28.31,0:05:29.79,Default,,0,0,0,,Kau ini...!
Dialogue: 0,0:05:30.39,0:05:31.96,Default,,0,0,0,,Dia ke sini!
Dialogue: 0,0:05:35.15,0:05:37.44,Default,,0,0,0,,Ka-Kau sungguh menyeramkan, Purson.
Dialogue: 0,0:05:37.44,0:05:39.23,Default,,0,0,0,,Dia melewati kita dengan mudah.
Dialogue: 0,0:05:39.23,0:05:41.90,Default,,0,0,0,,Buluku rasanya mau rontok.
Dialogue: 0,0:05:42.07,0:05:45.12,Default,,0,0,0,,Kamu beneran selalu ada di kelas kita, ya.
Dialogue: 0,0:05:45.12,0:05:47.79,Default,,0,0,0,,Semuanya, mari lupakan\Napa yang barusan kita dengar.
Dialogue: 0,0:05:47.79,0:05:49.20,Default,,0,0,0,,Demi kebaikan masing-masing.
Dialogue: 0,0:05:49.20,0:05:51.54,Default,,0,0,0,,Tapi, Pixie memang hebat.
Dialogue: 0,0:05:51.54,0:05:54.63,Default,,0,0,0,,Kau bisa ngomong secepat itu,\Nparu-parumu luar biasa!
Dialogue: 0,0:05:54.63,0:05:56.84,Default,,0,0,0,,Penampilan tidak selalu\Nmencerminkan diri.
Dialogue: 0,0:05:56.84,0:05:59.84,Default,,0,0,0,,Peringkatmu masih Beth,\Ntapi dengan kemampuanmu,
Dialogue: 0,0:05:59.84,0:06:02.26,Default,,0,0,0,,kau pasti bisa bersinar\Ndi festival musik, ya.
Dialogue: 0,0:06:02.26,0:06:04.22,Default,,0,0,0,,Naik ke Daleth bukan mimpi belaka.
Dialogue: 0,0:06:07.03,0:06:08.60,Default,,0,0,0,,Soal itu...
Dialogue: 0,0:06:08.60,0:06:12.79,Default,,0,0,0,,Ada 2 syarat kalau kalian\Ningin aku ikut festival musik.
Dialogue: 0,0:06:13.33,0:06:14.73,Default,,0,0,0,,Syarat?
Dialogue: 0,0:06:17.83,0:06:19.98,Default,,0,0,0,,Kontribusiku hanya musik saja.
Dialogue: 0,0:06:19.98,0:06:22.03,Default,,0,0,0,,Aku takkan menampakkan wujud.
Dialogue: 0,0:06:22.03,0:06:25.80,Default,,0,0,0,,Lalu, tak ada yang boleh tahu\Nkalau aku yang bermain musik.
Dialogue: 0,0:06:25.80,0:06:30.02,Default,,0,0,0,,Kalau kalian bisa janjikan 2 hal itu,\Naku akan ikut festival musik.
Dialogue: 0,0:06:36.17,0:06:39.77,Default,,0,0,0,,Waktunya enggak tepat!
Dialogue: 0,0:06:39.77,0:06:42.97,Default,,0,0,0,,Waktunya benar-benar enggak tepat.
Dialogue: 0,0:06:42.97,0:06:46.26,Default,,0,0,0,,Ini ide yang buruk.\NSemuanya jadi membatu, tuh.
Dialogue: 0,0:06:46.57,0:06:49.76,Default,,0,0,0,,Padahal aku akhirnya bisa\Nngobrol asyik dengan mereka.
Dialogue: 0,0:06:49.76,0:06:53.77,Default,,0,0,0,,Kemampuan komunikasiku yang payah\Nmalah merusak semuanya.
Dialogue: 0,0:06:54.02,0:06:56.94,Default,,0,0,0,,Habisnya, dengan syarat begitu,\Naku jadi tidak bisa naik ke Daleth.
Dialogue: 0,0:06:56.94,0:06:58.19,Default,,0,0,0,,Tidak ada gunanya, dong.
Dialogue: 0,0:06:58.19,0:07:00.44,Default,,0,0,0,,Menaikkan harapan mereka\Ndengan bilang mau ikut,
Dialogue: 0,0:07:00.44,0:07:02.65,Default,,0,0,0,,lalu menjatuhkan mereka\Ndengan memberi syarat begitu.
Dialogue: 0,0:07:02.65,0:07:04.78,Default,,0,0,0,,Normal memberi syarat begitu\Ndi situasi begini?
Dialogue: 0,0:07:04.95,0:07:06.53,Default,,0,0,0,,Aku pengin banget ngilang.
Dialogue: 0,0:07:06.53,0:07:08.57,Default,,0,0,0,,Menghilang saja?\NJangan, deh.
Dialogue: 0,0:07:08.57,0:07:10.53,Default,,0,0,0,,Tidak boleh.\NGimana ini?
Dialogue: 0,0:07:12.43,0:07:15.13,Default,,0,0,0,,Apa aku mengecewakan mereka?
Dialogue: 0,0:07:15.13,0:07:18.04,Default,,0,0,0,,Aku harusnya tidak ikut festival musik.
Dialogue: 0,0:07:18.04,0:07:20.54,Default,,0,0,0,,Semuanya, jangan berekspresi begitu.
Dialogue: 0,0:07:23.05,0:07:25.30,Default,,0,0,0,,Aku tahu kalian bersemangat, sih.
Dialogue: 0,0:07:26.30,0:07:31.05,Default,,0,0,0,,Yah, habisnya,\Nkalau dikasih syarat begitu,
Dialogue: 0,0:07:31.05,0:07:33.06,Default,,0,0,0,,semangat kami jadi makin membara!
Dialogue: 0,0:07:34.24,0:07:37.56,Default,,0,0,0,,Naik ke Daleth tanpa terlihat, ya?
Dialogue: 0,0:07:37.75,0:07:39.81,Default,,0,0,0,,Hei, Purson.
Dialogue: 0,0:07:40.21,0:07:41.90,Default,,0,0,0,,Benar juga.
Dialogue: 0,0:07:42.25,0:07:43.82,Default,,0,0,0,,Mereka...
Dialogue: 0,0:08:08.19,0:08:11.62,Default,,0,0,0,,malah tersenyum di saat-saat sulit.
Dialogue: 0,0:08:13.20,0:08:17.68,Default,,0,0,0,,Kita semua, yang abnormal,\Nberkumpul jadi satu.
Dialogue: 0,0:08:17.95,0:08:20.10,Default,,0,0,0,,Tidak ada hal yang mustahil bagi kita, 'kan?
Dialogue: 0,0:08:20.10,0:08:22.77,Default,,0,0,0,,Ayo menangkan\Ndan naik ke Daleth bersama!
Dialogue: 0,0:08:23.03,0:08:24.90,Default,,0,0,0,,Termasuk kau juga, Purson!
Dialogue: 0,0:08:27.40,0:08:28.86,Default,,0,0,0,,Hei!
Dialogue: 0,0:08:28.86,0:08:31.99,Default,,0,0,0,,Siapa yang seenaknya\Nmelihat bunga sakura tanpa izin?!
Dialogue: 0,0:08:34.34,0:08:37.16,Default,,0,0,0,,Sungguh kelas yang tidak biasa.
Dialogue: 0,0:08:38.01,0:08:39.23,Default,,0,0,0,,Namun...
Dialogue: 0,0:08:39.77,0:08:40.86,Default,,0,0,0,,Tapi...
Dialogue: 0,0:08:45.56,0:08:49.72,Default,,0,0,0,,Ayo kita guncang festival musik!\NBertiga belas!
Dialogue: 0,0:08:49.72,0:08:51.97,Default,,0,0,0,,Ya!
Dialogue: 0,0:08:58.99,0:09:02.23,Default,,0,0,0,,Sepulang sekolah di hari lain.
Dialogue: 0,0:09:02.23,0:09:06.23,Default,,0,0,0,,Memastikan kelancaran festival adalah\Ntanggung jawab kita, pengurus OSIS.
Dialogue: 0,0:09:06.45,0:09:11.86,Default,,0,0,0,,Jadi, aku ingin kalian mewawancarai\Nrencana penampilan murid kelas satu.
Dialogue: 0,0:09:12.17,0:09:16.18,Default,,0,0,0,,Batra pengurus OSIS,\Nmurid kelas dua, Ronove Romiere.
Dialogue: 0,0:09:16.72,0:09:20.19,Default,,0,0,0,,Batra pengurus OSIS,\Nmurid kelas satu, Ampsey Nafura.
Dialogue: 0,0:09:21.37,0:09:23.38,Default,,0,0,0,,Aku mengandalkan kalian berdua!
Dialogue: 0,0:09:23.38,0:09:25.28,Default,,0,0,0,,Ronove meNOlak!
Dialogue: 0,0:09:25.75,0:09:30.17,Default,,0,0,0,,Keahlianku ini lebih cocok\Nuntuk sesuatu yang lebih memesona!
Dialogue: 0,0:09:30.17,0:09:32.68,Default,,0,0,0,,Sesuatu yang lebih indah dan mewah!
Dialogue: 0,0:09:32.68,0:09:35.01,Default,,0,0,0,,Yang lebih kaya dan menakjubkan!
Dialogue: 0,0:09:35.01,0:09:39.52,Default,,0,0,0,,Ronove sudah muak dengan tugas-tugas\Nmembosankan pengurus OSIS!
Dialogue: 0,0:09:39.52,0:09:42.23,Default,,0,0,0,,Omong-omong, dia ini...\NMakhluk apa ini?!
Dialogue: 0,0:09:42.23,0:09:46.34,Default,,0,0,0,,Ini tidak cocok dengan estetika Ronove!\NKami jelas-jelas tidak cocok!
Dialogue: 0,0:09:47.02,0:09:50.78,Default,,0,0,0,,Yah, aku tidak memaksa,\Ntapi ini kesempatan, lo.
Dialogue: 0,0:09:50.78,0:09:51.74,Default,,0,0,0,,Ro?
Dialogue: 0,0:09:51.92,0:09:55.97,Default,,0,0,0,,Berinteraksi dengan para murid\Nadalah tugas penting bagi pengurus OSIS.
Dialogue: 0,0:09:55.97,0:09:59.66,Default,,0,0,0,,Kupikir festival musik akan jadi\Nkesempatan untuk memperkenalkan
Dialogue: 0,0:09:59.66,0:10:02.01,Default,,0,0,0,,nama Ronove ke murid kelas satu, tapi...
Dialogue: 0,0:10:02.01,0:10:05.21,Default,,0,0,0,,Maksudnya, kayak parade?
Dialogue: 0,0:10:05.21,0:10:06.48,Default,,0,0,0,,Salah.
Dialogue: 0,0:10:06.48,0:10:08.84,Default,,0,0,0,,Bilang itu dari awal, dong!
Dialogue: 0,0:10:08.84,0:10:11.26,Default,,0,0,0,,Nah, ayo kita pergi, Natasha.
Dialogue: 0,0:10:13.72,0:10:15.99,Default,,0,0,0,,Mudah sekali ditebak.
Dialogue: 0,0:10:18.20,0:10:20.18,Default,,0,0,0,,Festival musik, ya?
Dialogue: 0,0:10:20.62,0:10:23.88,Default,,0,0,0,,Kira-kira apa yang akan\NIruma tampilkan?
Dialogue: 0,0:10:24.20,0:10:26.81,Default,,0,0,0,,Kira-kira apa?
Dialogue: 0,0:10:26.81,0:10:28.19,Default,,0,0,0,,Iruma penyanyi!
Dialogue: 0,0:10:28.19,0:10:29.57,Default,,0,0,0,,Iruma berakting!
Dialogue: 0,0:10:29.57,0:10:30.82,Default,,0,0,0,,Iruma main band!
Dialogue: 0,0:10:30.82,0:10:32.32,Default,,0,0,0,,Sulit kalau harus memilih!
Dialogue: 0,0:10:32.88,0:10:35.70,Default,,0,0,0,,Jangan-jangan, akan terjadi kejadian\Nseperti pada halaman bonus
Dialogue: 0,0:10:35.70,0:10:38.33,Default,,0,0,0,,dari "Ingatan Cinta Pertama" jilid kedua?
Dialogue: 0,0:10:38.84,0:10:41.83,Default,,0,0,0,,Kalau tidak salah,\Nitu saat babak final turnamen.
Dialogue: 0,0:10:42.26,0:10:44.15,Default,,0,0,0,,"Ingatan Cinta Pertama".
Dialogue: 0,0:10:45.56,0:10:47.08,Default,,0,0,0,,Kakeru!
Dialogue: 0,0:10:47.08,0:10:49.13,Default,,0,0,0,,Terimalah perasaanku ini.
Dialogue: 0,0:10:49.13,0:10:51.84,Default,,0,0,0,,Akan kupersembahkan\N"pukulan" cintaku ini!
Dialogue: 0,0:10:52.01,0:10:53.32,Default,,0,0,0,,Rin...
Dialogue: 0,0:10:53.82,0:10:54.84,Default,,0,0,0,,Lakukan!
Dialogue: 0,0:10:54.84,0:10:57.09,Default,,0,0,0,,- Pukul!\N- Cenut!
Dialogue: 0,0:10:57.31,0:11:01.10,Default,,0,0,0,,Pukulan Rin telah kuterima!
Dialogue: 0,0:11:05.83,0:11:09.17,Default,,0,0,0,,Akan kupersembahkan\N"lantunan cinta" ini pada Ameri!
Dialogue: 0,0:11:09.58,0:11:11.53,Default,,0,0,0,,Jadi, tolong diterima.
Dialogue: 0,0:11:11.73,0:11:13.19,Default,,0,0,0,,Ya?
Dialogue: 0,0:11:13.19,0:11:15.20,Default,,0,0,0,,- Pukul!\N- Cenut!
Dialogue: 0,0:11:15.49,0:11:19.70,Default,,0,0,0,,Perasaan Iruma telah kuterima!
Dialogue: 0,0:11:20.80,0:11:23.12,Default,,0,0,0,,Dia berani berbuat begitu\Ndi hadapan para murid!
Dialogue: 0,0:11:23.12,0:11:24.48,Default,,0,0,0,,Wah, wah.
Dialogue: 0,0:11:27.04,0:11:29.23,Default,,0,0,0,,Ronove!
Dialogue: 0,0:11:31.29,0:11:34.42,Default,,0,0,0,,Hai, hai, wahai murid\Nkelas satu nan jelata!
Dialogue: 0,0:11:34.42,0:11:36.05,Default,,0,0,0,,Ini aku!
Dialogue: 0,0:11:36.05,0:11:38.72,Default,,0,0,0,,Dan yang berlumuran\Nparfum ini adalah Natasha!
Dialogue: 0,0:11:38.72,0:11:42.25,Default,,0,0,0,,Tiap murid hanya boleh\Nambil enam foto saja!
Dialogue: 0,0:11:44.31,0:11:46.31,Default,,0,0,0,,Ronove!
Dialogue: 0,0:11:47.94,0:11:50.81,Default,,0,0,0,,Ah, wawancara dari pengurus OSIS, ya.
Dialogue: 0,0:11:50.81,0:11:52.82,Default,,0,0,0,,Kelas A akan membacakan\Npuisi secara musikal.
Dialogue: 0,0:11:53.25,0:11:56.82,Default,,0,0,0,,Kami menulis ulang legenda\Ndan dongeng sebagai liriknya,
Dialogue: 0,0:11:56.82,0:11:59.07,Default,,0,0,0,,lalu menyampaikannya melalui nyanyian.
Dialogue: 0,0:12:01.84,0:12:04.58,Default,,0,0,0,,Habisnya, Orobas punya\Nsuara yang luar biasa!
Dialogue: 0,0:12:04.58,0:12:06.71,Default,,0,0,0,,Kayaknya kami punya peluang menang, deh.
Dialogue: 0,0:12:06.71,0:12:08.71,Default,,0,0,0,,Pasaran!
Dialogue: 0,0:12:08.71,0:12:11.29,Default,,0,0,0,,Ronove pengin yang lebih nendang!
Dialogue: 0,0:12:11.29,0:12:13.59,Default,,0,0,0,,Kenapa tidak coba pecahkan balon\Ndengan suara kalian?
Dialogue: 0,0:12:13.90,0:12:15.34,Default,,0,0,0,,Kisah legendanya juga pasaran!
Dialogue: 0,0:12:15.34,0:12:19.47,Default,,0,0,0,,Lebih baik kalian gunakan 666 ayat\Npilihan yang memuji Ronove!
Dialogue: 0,0:12:19.47,0:12:22.68,Default,,0,0,0,,Tambahkan juga properti!\NTambahkan mawar ke langit!
Dialogue: 0,0:12:22.68,0:12:25.56,Default,,0,0,0,,Mawar! Mawar! Mawar!
Dialogue: 0,0:12:25.56,0:12:26.98,Default,,0,0,0,,Rose!
Dialogue: 0,0:12:29.10,0:12:30.77,Default,,0,0,0,,Sip, lanjut!
Dialogue: 0,0:12:34.33,0:12:37.57,Default,,0,0,0,,Jika demi dirimu, aku rela\Nmeninggalkan istana ini!
Dialogue: 0,0:12:37.57,0:12:39.45,Default,,0,0,0,,Jangan, Tuan Putri!
Dialogue: 0,0:12:39.45,0:12:41.70,Default,,0,0,0,,Kita tidak ditakdirkan untuk bersama!
Dialogue: 0,0:12:41.70,0:12:45.20,Default,,0,0,0,,Tapi, Ronove sudah datang,\Njadi kalian tak perlu risau!
Dialogue: 0,0:12:45.59,0:12:47.70,Default,,0,0,0,,Wah, ada cogan.
Dialogue: 0,0:12:48.71,0:12:50.29,Default,,0,0,0,,Drama teater itu bagus!
Dialogue: 0,0:12:50.29,0:12:52.98,Default,,0,0,0,,Tapi, cinta terlarang antara\Nsang putri dan pengawalnya?
Dialogue: 0,0:12:54.96,0:12:56.38,Default,,0,0,0,,Membosankan, ya!
Dialogue: 0,0:12:56.38,0:12:56.96,Default,,0,0,0,,Eh?!
Dialogue: 0,0:12:57.48,0:13:01.34,Default,,0,0,0,,Ronove pengin perkembangan\Nyang lebih dramatis.
Dialogue: 0,0:13:01.34,0:13:03.89,Default,,0,0,0,,Bagaimana kalau membuat\Nsang putri jadi naga?
Dialogue: 0,0:13:03.89,0:13:05.72,Default,,0,0,0,,Istana yang dilalap api membuat
Dialogue: 0,0:13:06.16,0:13:09.23,Default,,0,0,0,,cinta antara sang putri\Ndan pengawalnya bersemi!
Dialogue: 0,0:13:09.23,0:13:11.56,Default,,0,0,0,,Putrinya mengamuk!
Dialogue: 0,0:13:11.56,0:13:13.19,Default,,0,0,0,,Lanjut!
Dialogue: 0,0:13:15.67,0:13:19.44,Default,,0,0,0,,Ini eranya musik rock!\NJangan ikut campur, dasar bayi!
Dialogue: 0,0:13:22.30,0:13:24.45,Default,,0,0,0,,Jangan bercanda, dasar buruk rupa!
Dialogue: 0,0:13:24.45,0:13:27.33,Default,,0,0,0,,Musik klasik yang terhormat\Nialah yang terbaik!
Dialogue: 0,0:13:27.33,0:13:28.54,Default,,0,0,0,,Apa?
Dialogue: 0,0:13:28.54,0:13:29.58,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:13:29.80,0:13:31.42,Default,,0,0,0,,Ole...
Dialogue: 0,0:13:31.58,0:13:35.25,Default,,0,0,0,,Jikalau berseteru,\Nberpalinglah padaku♪
Dialogue: 0,0:13:35.25,0:13:39.17,Default,,0,0,0,,Berpalinglah pada Ronove,\Nsang bintang nan memesona♪
Dialogue: 0,0:13:39.17,0:13:43.93,Default,,0,0,0,,Ronove yang dikagumi semua orang♪
Dialogue: 0,0:13:43.93,0:13:46.89,Default,,0,0,0,,Sang pahlawan telah tiba!\NNah, mari mulai♪
Dialogue: 0,0:13:46.89,0:13:51.02,Default,,0,0,0,,Panggillah namanya, yakni Ronove♪
Dialogue: 0,0:13:51.02,0:13:53.02,Default,,0,0,0,,Parade!♪
Dialogue: 0,0:13:53.33,0:13:57.65,Default,,0,0,0,,Hentikan perseteruan kalian\Ndan kagumi keindahanku♪
Dialogue: 0,0:13:57.65,0:14:01.40,Default,,0,0,0,,Ronove, Ronove,\Nbenar, Ronove♪
Dialogue: 0,0:14:01.40,0:14:05.82,Default,,0,0,0,,Namaku, namaku,\Nnamaku Ronove♪
Dialogue: 0,0:14:05.82,0:14:10.29,Default,,0,0,0,,Namaku Ronove Romiere♪
Dialogue: 0,0:14:10.91,0:14:15.04,Default,,0,0,0,,Ole!
Dialogue: 0,0:14:15.04,0:14:16.92,Default,,0,0,0,,Ketua! Ini gawat!
Dialogue: 0,0:14:17.52,0:14:20.63,Default,,0,0,0,,Ronove dan Nafura\Nmenggila di menara kelas satu!
Dialogue: 0,0:14:20.63,0:14:22.92,Default,,0,0,0,,Mereka menyanyikan\Nlagu yang menjengkelkan!
Dialogue: 0,0:14:23.11,0:14:24.43,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:14:24.78,0:14:26.14,Default,,0,0,0,,Mau dibiarkan?
Dialogue: 0,0:14:26.14,0:14:27.05,Default,,0,0,0,,Iya.
Dialogue: 0,0:14:27.27,0:14:29.18,Default,,0,0,0,,Ini kesempatan.
Dialogue: 0,0:14:29.99,0:14:34.13,Default,,0,0,0,,Ronove tidak suka bergaul\Ndengan murid biasa lainnya.
Dialogue: 0,0:14:34.69,0:14:39.19,Default,,0,0,0,,Kalau tidak begini, murid kelas satu\Ntidak akan pernah mengobrol dengannya.
Dialogue: 0,0:14:39.75,0:14:43.80,Default,,0,0,0,,Kenapa Ronove diizinkan bebas\Nberbuat sesukanya di sekolah ini?
Dialogue: 0,0:14:44.30,0:14:46.32,Default,,0,0,0,,Itu karena kemampuannya.
Dialogue: 0,0:14:46.51,0:14:49.25,Default,,0,0,0,,Kalian tahu jelas soal itu, 'kan?
Dialogue: 0,0:14:49.25,0:14:52.83,Default,,0,0,0,,Kalian pasti merasakannya,\Ntepat setahun yang lalu.
Dialogue: 0,0:14:53.39,0:14:54.58,Default,,0,0,0,,Benar.
Dialogue: 0,0:14:56.60,0:14:57.83,Default,,0,0,0,,Dialah...
Dialogue: 0,0:14:59.44,0:15:03.30,Default,,0,0,0,,pria yang telah membawa kelasnya\Npada kemenangan festival musik tahun lalu!
Dialogue: 0,0:15:03.30,0:15:06.79,Default,,0,0,0,,Ronove Romiere, peringkat He.
Dialogue: 0,0:15:08.40,0:15:13.04,Default,,0,0,0,,Dia orang menyebalkan pertama yang mencoreng\N"kekalahan" pada catatan akademisku.
Dialogue: 0,0:15:13.53,0:15:16.48,Default,,0,0,0,,Dia pasti jadi sumber inspirasi bagus\Nuntuk para murid kelas satu.
Dialogue: 0,0:15:16.48,0:15:21.73,Default,,0,0,0,,Dan lagi, terlepas dari kemampuannya,\Nkarisma Ronove itu nyata.
Dialogue: 0,0:15:22.21,0:15:24.32,Default,,0,0,0,,Tapi, kita juga menerima banyak keluhan.
Dialogue: 0,0:15:24.32,0:15:26.68,Default,,0,0,0,,Yah, tentu saja akan begitu!
Dialogue: 0,0:15:27.59,0:15:29.53,Default,,0,0,0,,Royal One.
Dialogue: 0,0:15:29.53,0:15:34.65,Default,,0,0,0,,Mulanya aku berniat menjadikannya\Nvilaku, tapi malah keduluan.
Dialogue: 0,0:15:35.96,0:15:39.40,Default,,0,0,0,,Kabarnya ini kelasnya Iruminati.
Dialogue: 0,0:15:40.14,0:15:42.21,Default,,0,0,0,,Natasha juga kenal, ya?
Dialogue: 0,0:15:42.21,0:15:45.09,Default,,0,0,0,,Sip! Kami teman akrab\Nsaat main di Taman Walter!
Dialogue: 0,0:15:45.09,0:15:48.16,Default,,0,0,0,,Aku akan kasih dia saran!
Dialogue: 0,0:15:49.22,0:15:51.10,Default,,0,0,0,,Permisi!
Dialogue: 0,0:15:54.98,0:15:57.60,Default,,0,0,0,,A-Apa yang telah terjadi?
Dialogue: 0,0:15:59.12,0:16:01.78,Default,,0,0,0,,Kak Ronove, Nafura.
Dialogue: 0,0:16:01.78,0:16:07.11,Default,,0,0,0,,Sebenarnya, saat sedang membahas apa\Nyang akan kami tampilkan di festival musik...
Dialogue: 0,0:16:11.12,0:16:14.31,Default,,0,0,0,,Berujung buntu, ya.
Dialogue: 0,0:16:14.76,0:16:17.75,Default,,0,0,0,,Kalau begitu, biarkan aku\Nmemberikan sebuah ide.
Dialogue: 0,0:16:19.25,0:16:24.30,Default,,0,0,0,,Sederhana. Cukup ada yang lebih\Nmencolok dibanding Purson.
Dialogue: 0,0:16:24.30,0:16:27.76,Default,,0,0,0,,Di situlah nyala apiku yang\Nmenakjubkan ini berperan.
Dialogue: 0,0:16:29.26,0:16:33.05,Default,,0,0,0,,Aku akan melempar ini, jadi semua\Nmurid cowok harus menghindar.
Dialogue: 0,0:16:33.05,0:16:34.14,Default,,0,0,0,,Apa tidak terlalu sederhana?!
Dialogue: 0,0:16:34.14,0:16:36.22,Default,,0,0,0,,Para cowok jadi penari latar\Nsembari menghindar,
Dialogue: 0,0:16:36.22,0:16:38.89,Default,,0,0,0,,para cewek akan bernyanyi,\Ndan Purson bermain musik.
Dialogue: 0,0:16:38.89,0:16:40.98,Default,,0,0,0,,Mana bisa kami menghindarinya semudah itu!
Dialogue: 0,0:16:40.98,0:16:42.90,Default,,0,0,0,,Bagai neraka!
Dialogue: 0,0:16:42.90,0:16:45.51,Default,,0,0,0,,Tuan Iruma bisa menghindarinya\Ndengan mudah, lo!
Dialogue: 0,0:16:46.59,0:16:48.15,Default,,0,0,0,,Kenapa kau malah kelihatan bangga?
Dialogue: 0,0:16:48.15,0:16:49.36,Default,,0,0,0,,Mustahil, tahu!
Dialogue: 0,0:16:49.36,0:16:51.89,Default,,0,0,0,,Aku tak bisa mengorbankan nyawaku\Nuntuk festival musik!
Dialogue: 0,0:16:52.55,0:16:55.48,Default,,0,0,0,,Tak bisa mengorbankan nyawa?
Dialogue: 0,0:16:57.51,0:17:01.36,Default,,0,0,0,,Kalian meremehkan penampilan?
Dialogue: 0,0:17:01.98,0:17:03.88,Default,,0,0,0,,Ada apa?!\NKenapa kau marah?!
Dialogue: 0,0:17:03.88,0:17:07.38,Default,,0,0,0,,Eng, Kerori penggemar Idola Iblis...
Dialogue: 0,0:17:07.38,0:17:09.17,Default,,0,0,0,,Ratuku! Harap tenang!
Dialogue: 0,0:17:09.43,0:17:11.18,Default,,0,0,0,,Ah! Purson mulai ngilang!
Dialogue: 0,0:17:11.18,0:17:12.68,Default,,0,0,0,,Tunggu! Itu curang!
Dialogue: 0,0:17:12.68,0:17:15.10,Default,,0,0,0,,Pak Balam juga pernah bilang...
Dialogue: 0,0:17:15.68,0:17:18.10,Default,,0,0,0,,Pengalaman adalah guru terbaik!
Dialogue: 0,0:17:18.10,0:17:20.44,Default,,0,0,0,,Akan kuredakan panas apimu.
Dialogue: 0,0:17:20.44,0:17:22.85,Default,,0,0,0,,Nah, menarilah!
Dialogue: 0,0:17:31.70,0:17:34.22,Default,,0,0,0,,Jadi, begitulah ceritanya.
Dialogue: 0,0:17:36.43,0:17:38.20,Default,,0,0,0,,Begitu rupanya.
Dialogue: 0,0:17:38.20,0:17:43.04,Default,,0,0,0,,Kalau begitu, akan kulaporkan\Nkalau kelas abnormal tidak ikut tampil!
Dialogue: 0,0:17:43.04,0:17:45.34,Default,,0,0,0,,Ah! Tunggu! Tunggu! Tunggu!
Dialogue: 0,0:17:45.34,0:17:47.09,Default,,0,0,0,,Harus dihentikan.
Dialogue: 0,0:17:47.52,0:17:49.21,Default,,0,0,0,,Setelah itu!
Dialogue: 0,0:17:50.02,0:17:53.09,Default,,0,0,0,,Jadi, ide yang kalian punya...
Dialogue: 0,0:17:53.57,0:17:55.10,Default,,0,0,0,,Ini...
Dialogue: 0,0:17:55.10,0:17:56.68,Default,,0,0,0,,Membosankan!
Dialogue: 0,0:17:56.68,0:17:57.35,Default,,0,0,0,,Eh?!
Dialogue: 0,0:17:57.35,0:17:58.93,Default,,0,0,0,,Langsung blak-blakan begitu?!
Dialogue: 0,0:17:58.93,0:18:01.14,Default,,0,0,0,,Ini omong kosong yang\Nbahkan tak perlu dibahas!
Dialogue: 0,0:18:01.14,0:18:02.23,Default,,0,0,0,,Coba kalian lihat!
Dialogue: 0,0:18:02.23,0:18:06.23,Default,,0,0,0,,Saking membosankannya,\NRonove sampai sudah ganti baju 3 kali.
Dialogue: 0,0:18:06.62,0:18:08.22,Default,,0,0,0,,Kalian ini...
Dialogue: 0,0:18:08.86,0:18:12.36,Default,,0,0,0,,Kalian merancang ini dengan tujuan\Nmenarik minat para murid, 'kan?
Dialogue: 0,0:18:13.71,0:18:17.08,Default,,0,0,0,,Habisnya, kami tak bisa menang\Nkalau tak populer,
Dialogue: 0,0:18:17.08,0:18:19.20,Default,,0,0,0,,jadi lebih baik mengikuti tren, 'kan?
Dialogue: 0,0:18:19.20,0:18:20.62,Default,,0,0,0,,Itu benar.
Dialogue: 0,0:18:20.62,0:18:21.87,Default,,0,0,0,,NON!
Dialogue: 0,0:18:21.87,0:18:24.29,Default,,0,0,0,,Dengar baik-baik, adik kelas jelataku!
Dialogue: 0,0:18:24.29,0:18:26.38,Default,,0,0,0,,Keinginan dangkal kalian pasti terbongkar!
Dialogue: 0,0:18:26.38,0:18:30.76,Default,,0,0,0,,Pada festival musik terdahulu, tak pernah ada\Nkelas yang menang karena popularitas!
Dialogue: 0,0:18:31.05,0:18:34.53,Default,,0,0,0,,Bagaimana jika dibandingkan\Nlima kelas yang lain, Natasha?
Dialogue: 0,0:18:35.03,0:18:36.26,Default,,0,0,0,,Tuh, lihat.
Dialogue: 0,0:18:36.26,0:18:39.89,Default,,0,0,0,,Lakukan dengan serius\Napa yang ingin kalian lakukan!
Dialogue: 0,0:18:39.89,0:18:43.94,Default,,0,0,0,,Jika kalian benar iblis, maka tunjukkan\Nbetapa besarnya keinginan kalian
Dialogue: 0,0:18:43.94,0:18:46.40,Default,,0,0,0,,dan gunakan itu untuk bersaing\Ndengan lawan kalian!
Dialogue: 0,0:18:47.00,0:18:52.22,Default,,0,0,0,,Hanya iblis yang benar-benar menikmati\Npenampilannya yang layak berada di puncak.
Dialogue: 0,0:19:01.47,0:19:03.06,Default,,0,0,0,,Dia...
Dialogue: 0,0:19:03.66,0:19:06.12,Default,,0,0,0,,Dia ngomong hal yang sangat masuk akal!
Dialogue: 0,0:19:06.12,0:19:08.17,Default,,0,0,0,,Padahal dia Kak Ronove!
Dialogue: 0,0:19:08.81,0:19:11.84,Default,,0,0,0,,Iruminati, apa tidak ada\Nhal yang ingin kau lakukan?
Dialogue: 0,0:19:11.84,0:19:13.80,Default,,0,0,0,,Eh? A-Aku?
Dialogue: 0,0:19:13.97,0:19:15.99,Default,,0,0,0,,Apa yang ingin kau lakukan?
Dialogue: 0,0:19:16.48,0:19:18.33,Default,,0,0,0,,Eng...
Dialogue: 0,0:19:19.57,0:19:20.81,Default,,0,0,0,,Aku...
Dialogue: 0,0:19:21.45,0:19:22.92,Default,,0,0,0,,Aku...
Dialogue: 0,0:19:27.50,0:19:30.26,Default,,0,0,0,,Aku ingin sama dengan semuanya.
Dialogue: 0,0:19:33.57,0:19:36.89,Default,,0,0,0,,So-Soalnya kita bertiga belas\Nsudah berkumpul.
Dialogue: 0,0:19:37.26,0:19:42.08,Default,,0,0,0,,Kurasa aku ingin melakukan sesuatu\Nyang sama dengan semuanya.
Dialogue: 0,0:19:42.08,0:19:43.87,Default,,0,0,0,,Se-Sekian.
Dialogue: 0,0:19:43.87,0:19:46.79,Default,,0,0,0,,I-Iya. Kenapa jadi formal?
Dialogue: 0,0:19:46.79,0:19:50.42,Default,,0,0,0,,Aku sudah Daleth, jadi sudah sama\Ndengan Tuan Iruma, ya.
Dialogue: 0,0:19:50.42,0:19:51.00,Default,,0,0,0,,Ya.
Dialogue: 0,0:19:51.00,0:19:54.09,Default,,0,0,0,,Aku juga! Berteman!
Dialogue: 0,0:19:55.36,0:19:58.59,Default,,0,0,0,,Samaan di festival musik itu tidak biasa.
Dialogue: 0,0:20:00.95,0:20:04.89,Default,,0,0,0,,Tapi, mau samaan apanya?\NSamaan kostumnya?
Dialogue: 0,0:20:04.89,0:20:07.39,Default,,0,0,0,,Apa tidak terlalu dangkal?
Dialogue: 0,0:20:07.39,0:20:09.48,Default,,0,0,0,,Bagaimana kalau Senam Siksaan?
Dialogue: 0,0:20:09.48,0:20:11.11,Default,,0,0,0,,Tolong jangan.
Dialogue: 0,0:20:13.37,0:20:14.61,Default,,0,0,0,,Ada satu...
Dialogue: 0,0:20:15.79,0:20:19.11,Default,,0,0,0,,Ada satu hal bagus\Nyang bisa kita tampilkan.
Dialogue: 0,0:20:20.11,0:20:23.84,Default,,0,0,0,,Anggun, mencolok, dan sangat berat.
Dialogue: 0,0:20:23.84,0:20:26.69,Default,,0,0,0,,"Tarian Terlarang" di dunia Idola Iblis.
Dialogue: 0,0:20:27.47,0:20:30.23,Default,,0,0,0,,Idola Iblis yang menghibur para iblis...
Dialogue: 0,0:20:31.14,0:20:34.56,Default,,0,0,0,,"Grup Idola Iblis" yang terlahir\Nsebagai bentuk evolusi dari hal tersebut.
Dialogue: 0,0:20:34.56,0:20:38.13,Default,,0,0,0,,Keenamnya menari\Ndengan serempak sempurna!
Dialogue: 0,0:20:38.13,0:20:39.63,Default,,0,0,0,,Wah, terdengar anggun.
Dialogue: 0,0:20:39.63,0:20:42.26,Default,,0,0,0,,Me-Menari
Dialogue: 0,0:20:42.26,0:20:43.64,Default,,0,0,0,,berenam?
Dialogue: 0,0:20:44.82,0:20:46.02,Default,,0,0,0,,Benar.
Dialogue: 0,0:20:46.02,0:20:47.48,Default,,0,0,0,,Nama tarian itu ialah...
Dialogue: 0,0:20:48.87,0:20:50.40,Default,,0,0,0,,Hell Dance!
Dialogue: 0,0:20:51.60,0:20:54.88,Default,,0,0,0,,Iblis memang sedari awal\Nsangat buruk dalam berkonsentrasi.
Dialogue: 0,0:20:55.61,0:21:00.41,Default,,0,0,0,,Sekelompok iblis menari\Nserempak dalam waktu lama
Dialogue: 0,0:21:00.41,0:21:03.72,Default,,0,0,0,,dan dipaksa melakukan\Nkoreografi yang sama...
Dialogue: 0,0:21:04.80,0:21:07.20,Default,,0,0,0,,Penderitaan yang tak terbayangkan!
Dialogue: 0,0:21:08.93,0:21:13.63,Default,,0,0,0,,Pada akhirnya, yang bertahan hanyalah\Naku dan satu anggota lainnya...
Dialogue: 0,0:21:13.63,0:21:14.71,Default,,0,0,0,,"Aku"?
Dialogue: 0,0:21:14.71,0:21:15.92,Default,,0,0,0,,Ah, bukan!
Dialogue: 0,0:21:15.92,0:21:21.09,Default,,0,0,0,,Pokoknya, berenam saja gagal,\Napalagi bertiga belas.
Dialogue: 0,0:21:21.09,0:21:23.01,Default,,0,0,0,,Normalnya itu tindakan gila.
Dialogue: 0,0:21:23.32,0:21:26.85,Default,,0,0,0,,Hell Dance hanya akan berhasil\Njika semuanya selaras sempurna.
Dialogue: 0,0:21:27.03,0:21:29.77,Default,,0,0,0,,Jika satu orang saja salah bergerak\Nmeski hanya sedetik,
Dialogue: 0,0:21:29.77,0:21:32.55,Default,,0,0,0,,semuanya akan berantakan!
Dialogue: 0,0:21:32.95,0:21:34.56,Default,,0,0,0,,Bagai pedang bermata dua...
Dialogue: 0,0:21:34.56,0:21:38.28,Default,,0,0,0,,Kalau tidak hati-hati, peringkat kita\Nmungkin akan terkena dampaknya.
Dialogue: 0,0:21:38.28,0:21:40.53,Default,,0,0,0,,Tapi! Justru karena itu!
Dialogue: 0,0:21:40.53,0:21:42.16,Default,,0,0,0,,Hanya itu caranya!
Dialogue: 0,0:21:43.66,0:21:46.03,Default,,0,0,0,,Telat kalau mau bilang\Nitu tidak masuk akal, 'kan?
Dialogue: 0,0:21:46.03,0:21:46.78,Default,,0,0,0,,Sudah telat!
Dialogue: 0,0:21:46.78,0:21:48.24,Default,,0,0,0,,Risiko tinggi, untung tinggi!
Dialogue: 0,0:21:48.24,0:21:50.20,Default,,0,0,0,,Kalau tidak begitu,\Nkita tidak bisa jadi juara!
Dialogue: 0,0:21:50.20,0:21:50.96,Default,,0,0,0,,Daku jadi semangat!
Dialogue: 0,0:21:50.96,0:21:52.92,Default,,0,0,0,,Mari kita berjuang, Ratuku!
Dialogue: 0,0:21:52.92,0:21:55.04,Default,,0,0,0,,- Siapa yang berani, dia yang menang.\N- Jadi tidak sabar, ya.
Dialogue: 0,0:21:55.04,0:21:56.29,Default,,0,0,0,,- Ayo lakukan.\N- Ayo, ayo.
Dialogue: 0,0:21:56.29,0:21:57.36,Default,,0,0,0,,Ya.
Dialogue: 0,0:21:58.40,0:21:59.55,Default,,0,0,0,,Tuan Iruma!
Dialogue: 0,0:21:59.55,0:22:00.80,Default,,0,0,0,,Iya, ayo lakukan!
Dialogue: 0,0:22:00.80,0:22:02.43,Default,,0,0,0,,Ayo, ayo!
Dialogue: 0,0:22:03.82,0:22:05.97,Default,,0,0,0,,Ayo kita sikat.
Dialogue: 0,0:22:06.18,0:22:07.97,Default,,0,0,0,,Kedengaran merepotkan.
Dialogue: 0,0:22:07.97,0:22:11.02,Default,,0,0,0,,Yah, tugasku main alat musik,\Njadi tidak masalah, sih.
Dialogue: 0,0:22:11.02,0:22:13.19,Default,,0,0,0,,Tapi, tampaknya\Nsemuanya bakal kerepotan.
Dialogue: 0,0:22:13.19,0:22:15.38,Default,,0,0,0,,Sudah diputuskan, ya.
Dialogue: 0,0:22:19.57,0:22:21.25,Default,,0,0,0,,Festival Musik.
Dialogue: 0,0:22:21.25,0:22:23.97,Default,,0,0,0,,Yang akan ditampilkan\Noleh kelas abnormal adalah...
Dialogue: 0,0:22:34.35,0:22:36.28,Default,,0,0,0,,Hell Dance!
Dialogue: 0,0:22:41.09,0:22:43.13,Default,,0,0,0,,Sip, ayo mulai!♪
Dialogue: 0,0:22:43.13,0:22:44.51,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:44.51,0:22:45.64,Default,,0,0,0,,Pasti menang!♪
Dialogue: 0,0:22:45.64,0:22:46.89,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:46.89,0:22:48.14,Default,,0,0,0,,Menang dengan gemilang♪
Dialogue: 0,0:22:48.14,0:22:49.39,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:49.39,0:22:50.64,Default,,0,0,0,,Menang dengan iseng♪
Dialogue: 0,0:22:50.64,0:22:51.97,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:22:51.97,0:22:53.68,Default,,0,0,0,,Kamilah pemenangnya!♪
Dialogue: 0,0:22:53.68,0:22:55.90,Default,,0,0,0,,Kemenangan luar biasa!♪
Dialogue: 0,0:22:55.90,0:22:58.44,Default,,0,0,0,,Ya! Ya! Ya! Menang lagi hari ini!♪
Dialogue: 0,0:22:58.44,0:23:00.86,Default,,0,0,0,,Senang! Senang! Duar! Terbaik!♪
Dialogue: 0,0:23:00.86,0:23:03.53,Default,,0,0,0,,Ya! Ya! Ya! Kemenangan sempurna!♪
Dialogue: 0,0:23:03.53,0:23:05.70,Default,,0,0,0,,Senang! Senang! Duar! Jempolan!♪
Dialogue: 0,0:23:05.70,0:23:08.53,Default,,0,0,0,,Bukannya enggak bakal kalah,\Ntapi mustahil kalah♪
Dialogue: 0,0:23:08.53,0:23:11.08,Default,,0,0,0,,Berjuang tuh rasanya mengasyikkan♪
Dialogue: 0,0:23:11.08,0:23:13.58,Default,,0,0,0,,Makanan enak pun\Nbuat kualitas hidup naik♪
Dialogue: 0,0:23:13.58,0:23:16.37,Default,,0,0,0,,Pertumbuhan pesat tak terbendung!\NMantap! Kawan!♪
Dialogue: 0,0:23:16.37,0:23:17.38,Default,,0,0,0,,Hei! Yo!♪
Dialogue: 0,0:23:17.38,0:23:20.17,Default,,0,0,0,,Punya teman 'tuk berlomba tuh terbaik!♪
Dialogue: 0,0:23:20.17,0:23:22.88,Default,,0,0,0,,Bisa melampaui batasan\Ndiri sendiri tuh terkuat!♪
Dialogue: 0,0:23:22.88,0:23:25.47,Default,,0,0,0,,Imutnya bukan main! Bodoh!♪
Dialogue: 0,0:23:25.47,0:23:28.59,Default,,0,0,0,,Itu sudah pasti aku!♪
Dialogue: 0,0:23:28.59,0:23:29.51,Default,,0,0,0,,Tentu, dong!♪
Dialogue: 0,0:23:29.51,0:23:32.18,Default,,0,0,0,,Raih kemenangan dengan\Nsegenap kekuatan♪
Dialogue: 0,0:23:32.18,0:23:34.39,Default,,0,0,0,,Kami 'kan tokoh utama,\Njadi pasti memimpin!♪
Dialogue: 0,0:23:34.64,0:23:37.27,Default,,0,0,0,,Hidup bersama jadi pusat perhatian♪
Dialogue: 0,0:23:37.27,0:23:38.73,Default,,0,0,0,,Heroine dijamin menang!♪
Dialogue: 0,0:23:38.73,0:23:39.73,Default,,0,0,0,,Kami menang!♪
Dialogue: 0,0:23:39.73,0:23:40.94,Default,,0,0,0,,Duk, duk, tok, tok♪
Dialogue: 0,0:23:40.94,0:23:41.90,Default,,0,0,0,,La, la, la, la, yey♪
Dialogue: 0,0:23:41.90,0:23:43.78,Default,,0,0,0,,Kisah kita berempat!!♪
Dialogue: 0,0:23:43.78,0:23:44.78,Default,,0,0,0,,Sip, menang!♪
Dialogue: 0,0:23:44.78,0:23:45.36,Default,,0,0,0,,Wus, wus, dor, dor♪
Dialogue: 0,0:23:45.36,0:23:45.99,Default,,0,0,0,,Buk, buk, blar, blar♪
Dialogue: 0,0:23:45.99,0:23:47.07,Default,,0,0,0,,Berdebar dengan kencangnya♪
Dialogue: 0,0:23:47.07,0:23:49.66,Default,,0,0,0,,Motivasiku melambung tinggi!!♪
Dialogue: 0,0:23:49.66,0:23:51.70,Default,,0,0,0,,Tu, wa, lalu maju♪
Dialogue: 0,0:23:51.70,0:23:52.16,Default,,0,0,0,,Demi aku♪
Dialogue: 0,0:23:52.16,0:23:54.20,Default,,0,0,0,,Ditambah lagi, runaway♪
Dialogue: 0,0:23:54.20,0:23:54.66,Default,,0,0,0,,Demi aku♪
Dialogue: 0,0:23:54.66,0:23:56.04,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:56.04,0:23:57.12,Default,,0,0,0,,Pasti menang!♪
Dialogue: 0,0:23:57.12,0:23:58.46,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:23:58.46,0:23:59.58,Default,,0,0,0,,Menang dengan gemilang♪
Dialogue: 0,0:23:59.58,0:24:01.04,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:24:01.04,0:24:02.04,Default,,0,0,0,,Menang dengan iseng♪
Dialogue: 0,0:24:02.04,0:24:03.50,Default,,0,0,0,,Menang! Menang!♪
Dialogue: 0,0:24:03.50,0:24:06.97,Default,,0,0,0,,Kamilah pemenangnya!♪
Dialogue: 0,0:24:09.51,0:24:10.85,Default,,0,0,0,,Tambahan!
Dialogue: 0,0:24:12.41,0:24:14.25,Default,,0,0,0,,"Ingatan Cinta Pertama".
Dialogue: 0,0:24:16.33,0:24:18.73,Default,,0,0,0,,Tinjuku ialah cinta!
Dialogue: 0,0:24:18.73,0:24:20.40,Default,,0,0,0,,Terima tinjuku, Kakeru!
Dialogue: 0,0:24:20.40,0:24:20.98,Default,,0,0,0,,Maju!
Dialogue: 0,0:24:20.98,0:24:22.19,Default,,0,0,0,,Duak!
Dialogue: 0,0:24:22.19,0:24:24.98,Default,,0,0,0,,Syut!
Dialogue: 0,0:24:24.98,0:24:25.99,Default,,0,0,0,,Set!
Dialogue: 0,0:24:26.34,0:24:27.49,Default,,0,0,0,,Aku kembali!
Dialogue: 0,0:24:27.80,0:24:29.56,Default,,0,0,0,,Selamat datang kembali.
Dialogue: 0,0:24:29.99,0:24:32.20,Default,,0,0,0,,Hell Dance!
Dialogue: 0,0:24:32.20,0:24:35.91,Default,,0,0,0,,Kelas abnormal telah memutuskan\Npenampilan mereka di festival musik!
Dialogue: 0,0:24:35.91,0:24:37.79,Default,,0,0,0,,Melakukan gerakan serempak bersama...
Dialogue: 0,0:24:37.79,0:24:40.67,Default,,0,0,0,,Itu hal yang dibenci seorang iblis!
Dialogue: 0,0:24:40.67,0:24:42.79,Default,,0,0,0,,Semangat mereka yang berani\Nmenghadapi tantangan itu
Dialogue: 0,0:24:42.79,0:24:45.21,Default,,0,0,0,,membuat Ronove terkesan dan terharu!
Dialogue: 0,0:24:45.21,0:24:47.05,Default,,0,0,0,,Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
