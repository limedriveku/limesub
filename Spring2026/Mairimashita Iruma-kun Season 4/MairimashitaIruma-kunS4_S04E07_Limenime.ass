Dialogue: 0,0:00:28.47,0:00:35.77,tanda,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:01:50.01,0:01:54.51,tanda,,0000,0000,0000,,KARPET LILITH
Dialogue: 0,0:03:41.70,0:03:43.54,tanda,,0000,0000,0000,,IRUMA
Dialogue: 0,0:04:21.62,0:04:22.62,tanda,,0000,0000,0000,,KURSI KELUARGA
Dialogue: 0,0:08:05.26,0:08:08.26,tanda,,0000,0000,0000,,KELAS ABNORMAL - HELL DANCE
Dialogue: 0,0:08:09.47,0:08:12.26,tanda,,0000,0000,0000,,KARPET LILITH
Dialogue: 0,0:22:31.50,0:22:33.75,tanda,,0000,0000,0000,,HELL DANCE ~KARPET LILITH~
Dialogue: 0,0:22:33.75,0:22:34.54,tanda,,0000,0000,0000,,PEMERAN
Dialogue: 0,0:22:34.54,0:22:35.88,tanda,,0000,0000,0000,,PENJUAL BUNGA - SHAX LIED\NPENARI ULAR HITAM - ANDRO M JAZZ
Dialogue: 0,0:22:35.88,0:22:37.25,tanda,,0000,0000,0000,,PENARI ULAR PUTIH - ASMODEUS ALICE\NSAMURAI BAIK HATI - GAPP GOEMON
Dialogue: 0,0:22:37.25,0:22:38.59,tanda,,0000,0000,0000,,PRIA PENUH GAIRAH - CAIM KAMUI\NCENDEKIAWAN BIJAK - ALLOCER SCHNEIDER
Dialogue: 0,0:22:38.59,0:22:40.46,tanda,,0000,0000,0000,,PANGERAN EGOIS - AGARES PICERO\NMILIARDER RAKUS - SABNOCK SABURO
Dialogue: 0,0:22:40.46,0:22:41.84,tanda,,0000,0000,0000,,ISI HATI LILITH - CROCELL KERORI & VALAC CLARA
Dialogue: 0,0:22:41.84,0:22:43.72,tanda,,0000,0000,0000,,LILITH - IX ELIZABETTA
Dialogue: 0,0:22:43.72,0:22:45.26,tanda,,0000,0000,0000,,TROMPET - PURSON SOI\NPIANO - IRUMA
Dialogue: 0,0:22:45.26,0:22:48.81,tanda,,0000,0000,0000,,KOREOGRAFI - CROCELL KERORI
Dialogue: 0,0:24:29.99,0:24:32.37,tanda,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:00:01.27,0:00:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuulangi lagi.
Dialogue: 0,0:00:02.73,0:00:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas yang akan tampil di paruh akhir,\Nmohon segera berpindah.
Dialogue: 0,0:00:16.70,0:00:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menunggumu, Purson.
Dialogue: 0,0:01:58.77,0:02:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini memang yang terbaik.
Dialogue: 0,0:02:02.69,0:02:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kumainkan hari ini?
Dialogue: 0,0:02:04.44,0:02:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat musik yang mana?
Dialogue: 0,0:02:06.65,0:02:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak yang paling kamu suka saja?
Dialogue: 0,0:02:09.32,0:02:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, benar juga...
Dialogue: 0,0:02:12.40,0:02:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Suara yang paling kusuka...\N- Tuan Poro.
Dialogue: 0,0:02:16.28,0:02:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Poro.
Dialogue: 0,0:02:19.04,0:02:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu merasa tidak enak badan?
Dialogue: 0,0:02:21.20,0:02:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku baik-baik saja.
Dialogue: 0,0:02:24.04,0:02:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh,
Dialogue: 0,0:02:25.58,0:02:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku langsung teringat kenangan\Nbersama Tuan Delkira tiba-tiba.
Dialogue: 0,0:02:30.46,0:02:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak nakal.
Dialogue: 0,0:02:31.67,0:02:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baik-baik saja?
Dialogue: 0,0:02:35.01,0:02:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pria yang hebat.
Dialogue: 0,0:02:36.97,0:02:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sungguh terkejut.
Dialogue: 0,0:02:39.35,0:02:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival musik tahun ini sungguh berkelas!
Dialogue: 0,0:02:42.06,0:02:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh memuaskan!
Dialogue: 0,0:02:43.48,0:02:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya tersisa kelas abnormal saja.
Dialogue: 0,0:02:46.81,0:02:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, aku sudah puas tanpa perlu\Nmelihat penampilan terakhir.
Dialogue: 0,0:02:52.94,0:02:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:02:54.49,0:02:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berpikir demikian, tapi...
Dialogue: 0,0:03:01.66,0:03:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Akhirnya kelas abnormal!\N- Akhirnya! Akhirnya!
Dialogue: 0,0:03:04.66,0:03:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iruma, semangat!\N- Ratuku!
Dialogue: 0,0:03:05.87,0:03:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iruma, semangat!\N- Raja Muda!
Dialogue: 0,0:03:07.17,0:03:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan kelas abnormal akan dimulai.
Dialogue: 0,0:03:09.67,0:03:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar, Coco.
Dialogue: 0,0:03:11.17,0:03:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku!
Dialogue: 0,0:03:12.67,0:03:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tak sabar, ya.
Dialogue: 0,0:03:14.42,0:03:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Namaku! Namaku Ronove Romiere!\N- Ronove!
Dialogue: 0,0:03:17.93,0:03:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan mencolok di festival murid kelas satu!\N- Hari ini pun Ronove Romiere
Dialogue: 0,0:03:20.64,0:03:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pengurus OSIS adalah contoh bagi para murid!\N- tampak memesona dan luar biasa!
Dialogue: 0,0:03:22.56,0:03:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bertindaklah lebih tertib lagi!\N- tampak memesona dan luar biasa!
Dialogue: 0,0:03:24.43,0:03:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo! Ayo!
Dialogue: 0,0:03:28.69,0:03:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingginya sungguh pas!
Dialogue: 0,0:03:30.19,0:03:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Ketua, apa yang Anda lakukan?
Dialogue: 0,0:03:32.69,0:03:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pengurus OSIS,
Dialogue: 0,0:03:34.78,0:03:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus menikmati\Nfestival musik lebih dari siapa pun!
Dialogue: 0,0:03:37.95,0:03:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga tugas yang penting!
Dialogue: 0,0:03:39.95,0:03:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu, toh!
Dialogue: 0,0:03:41.70,0:03:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapannya sudah beres.
Dialogue: 0,0:03:43.54,0:03:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya lebih gugup\Ndaripada saat aku yang tampil.
Dialogue: 0,0:03:46.58,0:03:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen besar Iruma.
Dialogue: 0,0:03:49.29,0:03:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen besar...
Dialogue: 0,0:03:51.92,0:03:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang kusuka.
Dialogue: 0,0:03:56.13,0:03:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ki-Kita tidak tahu apa yang akan terjadi!
Dialogue: 0,0:03:59.47,0:04:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, harus direkam dengan jelas.
Dialogue: 0,0:04:01.26,0:04:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:04:02.76,0:04:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma!
Dialogue: 0,0:04:04.77,0:04:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kepala Sekolah!
Dialogue: 0,0:04:05.68,0:04:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat yang sempurna untuk merekam!
Dialogue: 0,0:04:08.27,0:04:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengabadikan\Nsosok Iruma yang pemberani
Dialogue: 0,0:04:11.11,0:04:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengambil banyak foto!
Dialogue: 0,0:04:14.15,0:04:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:04:19.11,0:04:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:04:20.62,0:04:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clara, semangat!
Dialogue: 0,0:04:22.62,0:04:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abnormal!
Dialogue: 0,0:04:36.01,0:04:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah semuanya!
Dialogue: 0,0:04:38.09,0:04:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tenang, ya!
Dialogue: 0,0:04:39.51,0:04:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lo, kenapa malah Pak Robin?\N- Harap tenang!
Dialogue: 0,0:04:41.05,0:04:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pak Robin!\N- Harap tenang!
Dialogue: 0,0:04:42.76,0:04:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, penampilan kelas D\Njuga luar biasa, ya.
Dialogue: 0,0:04:46.02,0:04:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kelas memperoleh\Nnilai di atas rata-rata tahun ini!
Dialogue: 0,0:04:50.56,0:04:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akankah kelas abnormal juga mendapatkannya?
Dialogue: 0,0:04:54.02,0:04:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya berikutnya\Nadalah penampilan terakhir!
Dialogue: 0,0:04:59.32,0:05:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka selalu jadi pusat\Nkekacauan di Babyls!
Dialogue: 0,0:05:02.49,0:05:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang telah mendapatkan\NKelas Raja yang terlarang, Royal One!
Dialogue: 0,0:05:07.62,0:05:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka jadi pusat perhatian saat di Walter Park\Nmaupun saat festival panen!
Dialogue: 0,0:05:12.58,0:05:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pun akhirnya\Nakan tampil di festival musik!
Dialogue: 0,0:05:17.80,0:05:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas abnormal telah tiba!
Dialogue: 0,0:05:25.68,0:05:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:05:32.65,0:05:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lied, kamu kenapa?
Dialogue: 0,0:05:35.82,0:05:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak tidak ada!\NKamu pergi ke mana, Mbak?
Dialogue: 0,0:05:39.74,0:05:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:05:41.82,0:05:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:43.07,0:05:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada apa?\N- Itu Lied si Raja Muda!
Dialogue: 0,0:05:43.74,0:05:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mbak?\N- Itu Lied si Raja Muda!
Dialogue: 0,0:05:44.45,0:05:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Elizabetta?\N- Itu Lied si Raja Muda!
Dialogue: 0,0:05:45.45,0:05:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada masalah?\N- Penampilannya batal?
Dialogue: 0,0:05:47.33,0:05:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:05:51.21,0:05:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jazzy!
Dialogue: 0,0:05:52.50,0:05:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kamu menemukannya,
Dialogue: 0,0:05:54.88,0:05:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa ada gunanya?
Dialogue: 0,0:05:58.21,0:05:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu Jazz!\N- Keren banget!
Dialogue: 0,0:06:04.05,0:06:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:06:07.14,0:06:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas, kan?
Dialogue: 0,0:06:08.76,0:06:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang akan dipilihnya adalah...
Dialogue: 0,0:06:10.64,0:06:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku!
Dialogue: 0,0:06:12.06,0:06:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:12.89,0:06:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pertengkaran asmara?\N- Ada apa ini?
Dialogue: 0,0:06:14.73,0:06:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:06:17.15,0:06:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa tinggal diam!
Dialogue: 0,0:06:19.61,0:06:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Diriku juga!\N- Aku juga!
Dialogue: 0,0:06:21.40,0:06:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mundur sana!\N- Mundur yang jauh!
Dialogue: 0,0:06:23.40,0:06:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu milikku!
Dialogue: 0,0:06:33.91,0:06:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:06:34.92,0:06:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia sudah datang!\N- Mari kita sambut!
Dialogue: 0,0:06:36.17,0:06:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok tercinta kita...
Dialogue: 0,0:06:59.44,0:07:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang
Dialogue: 0,0:07:01.19,0:07:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Karpet Lilith milikku.
Dialogue: 0,0:07:19.46,0:07:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti akan datang.
Dialogue: 0,0:07:27.47,0:07:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:07:32.64,0:07:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu tentang dirinya yang didambakan\Ndan dicintai oleh para pria.
Dialogue: 0,0:07:36.44,0:07:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu tentang perwujudan\Nkecantikan tiada tara.
Dialogue: 0,0:07:41.73,0:07:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu, ada sosok iblis cantik\Nyang berkuasa di dunia bawah,
Dialogue: 0,0:07:46.61,0:07:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}iblis pemikat, Lilith.
Dialogue: 0,0:07:50.62,0:07:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan yang ia lalui
Dialogue: 0,0:07:52.95,0:07:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipenuhi dengan mayat pria\Nyang berjuang merayunya.
Dialogue: 0,0:07:57.33,0:08:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan itu pun disebut Karpet Lilith.
Dialogue: 0,0:08:19.69,0:08:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Pergilah menjauh ♪
Dialogue: 0,0:08:21.23,0:08:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sosokmu memanglah rupawan dan memesona ♪
Dialogue: 0,0:08:26.90,0:08:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tapi hati ini tiada berdebar♪
Dialogue: 0,0:08:29.86,0:08:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, hari ini pun kunaiki\Ntangga penuh hadiah ♪
Dialogue: 0,0:08:38.37,0:08:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ dan terlelap di ranjang penuh cinta ♪
Dialogue: 0,0:08:44.30,0:08:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, kuingin rasakan cinta\Nyang lebih membara lagi ♪
Dialogue: 0,0:09:02.98,0:09:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chercille.
Dialogue: 0,0:09:15.79,0:09:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Nona, silakan bunganya ♪
Dialogue: 0,0:09:19.83,0:09:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, terima kasih.
Dialogue: 0,0:09:22.33,0:09:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aleph.
Dialogue: 0,0:09:27.55,0:09:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pemuda sederhana penjual bunga.
Dialogue: 0,0:09:30.42,0:09:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyenangkan, tulus, dan lugas!\NCinta yang menggemaskan!
Dialogue: 0,0:09:39.73,0:09:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyingkir!
Dialogue: 0,0:09:42.14,0:09:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tapi, hati yang buruk rupa pun\Ndiperlukan dalam cinta ♪
Dialogue: 0,0:09:50.15,0:09:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal.
Dialogue: 0,0:09:51.45,0:09:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lilith!
Dialogue: 0,0:09:54.70,0:09:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, berikutnya\Nadalah aroma yang berbahaya.
Dialogue: 0,0:09:58.20,0:09:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chercille.
Dialogue: 0,0:10:02.08,0:10:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penari Ular Hitam dan Ular Putih!
Dialogue: 0,0:10:13.05,0:10:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bet.
Dialogue: 0,0:10:14.13,0:10:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ular Hitam adalah pria berbahaya\Nyang mengenal cinta dan kesenangan.
Dialogue: 0,0:10:27.11,0:10:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kemarilah, Lilith ♪
Dialogue: 0,0:10:33.24,0:10:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mari lakukan banyak\Nhal nakal bersamaku ♪
Dialogue: 0,0:10:45.21,0:10:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tapi, dirinya masih belum\Npernah jatuh cinta ♪
Dialogue: 0,0:10:48.25,0:10:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tak berpengalaman ♪
Dialogue: 0,0:10:55.38,0:10:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gimmel.
Dialogue: 0,0:10:56.55,0:11:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Ular Putih sangat indah\Nbagaikan permata.
Dialogue: 0,0:11:02.18,0:11:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kamu menari denganku?
Dialogue: 0,0:11:12.48,0:11:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Ular Putih sangatlah indah.
Dialogue: 0,0:11:14.86,0:11:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang lebih berkilau\Ndibanding dirinya.
Dialogue: 0,0:11:17.32,0:11:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sangat indah!
Dialogue: 0,0:11:28.17,0:11:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, kamu!
Dialogue: 0,0:11:29.42,0:11:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Karena dirimu terlalu indah ♪
Dialogue: 0,0:11:32.84,0:11:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dirimu bukanlah sosok yang rela kotor ♪
Dialogue: 0,0:11:37.43,0:11:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ demi orang yang ia dambakan ♪
Dialogue: 0,0:11:41.81,0:11:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lilith!
Dialogue: 0,0:11:46.81,0:11:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Nah, kalau begitu,\Nbagaimana dengan mereka? ♪
Dialogue: 0,0:11:50.98,0:11:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tiga kesatria yang akan\Nmelindungi dirimu dari bahaya ♪
Dialogue: 0,0:11:57.20,0:11:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daleth, kebaikan.
Dialogue: 0,0:12:02.62,0:12:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He, gairah.
Dialogue: 0,0:12:07.29,0:12:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vav, pengetahuan.
Dialogue: 0,0:12:14.25,0:12:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku ialah pedang\Nyang akan melindungi dirimu.
Dialogue: 0,0:12:38.32,0:12:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku akan turuti segala keinginanmu.
Dialogue: 0,0:12:40.74,0:12:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku tiada akan pernah melawan.
Dialogue: 0,0:12:43.24,0:12:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendekar yang baik hati.\NKita bisa saling mengerti.
Dialogue: 0,0:12:47.12,0:12:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak punya kekuatan\Nuntuk menahanku.
Dialogue: 0,0:12:55.42,0:12:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dirikulah pria sejatimu ♪
Dialogue: 0,0:12:58.13,0:13:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dirimu teramat mulia dan cantik ♪
Dialogue: 0,0:13:01.68,0:13:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Engkau yang paling mulia! ♪
Dialogue: 0,0:13:05.26,0:13:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria sejati yang penuh gairah.\NKamu selalu memujiku.
Dialogue: 0,0:13:09.44,0:13:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kamu tak berani memarahiku.
Dialogue: 0,0:13:35.29,0:13:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah pengetahuanmu.
Dialogue: 0,0:13:38.38,0:13:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mencintai,\Nkamu jadi tahu sisi buruknya.
Dialogue: 0,0:13:40.51,0:13:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan membenci,\Nkamu jadi tahu sisi baiknya.
Dialogue: 0,0:13:42.47,0:13:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi penuntun jalanmu.
Dialogue: 0,0:13:44.93,0:13:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cendekiawan yang bijak.
Dialogue: 0,0:13:46.43,0:13:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu memberiku\Njawaban yang benar.
Dialogue: 0,0:13:48.89,0:13:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak bisa bertualang, dong.
Dialogue: 0,0:13:56.52,0:13:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilindungi saja tidak cukup!
Dialogue: 0,0:14:04.07,0:14:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu...
Dialogue: 0,0:14:07.74,0:14:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran egois, Zayin!
Dialogue: 0,0:14:20.21,0:14:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya diriku yang bisa\Nmemuaskan cinta dan hasratnya!
Dialogue: 0,0:14:36.19,0:14:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucurahkan cintaku padanya!
Dialogue: 0,0:14:37.86,0:14:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama bisa melihat senyumannya...
Dialogue: 0,0:14:39.86,0:14:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berikanlah cintamu ♪
Dialogue: 0,0:14:42.19,0:14:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berikan segala cintamu padaku ♪
Dialogue: 0,0:14:46.62,0:14:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Apa benar ♪
Dialogue: 0,0:14:48.83,0:14:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ aku puas dengan itu? ♪
Dialogue: 0,0:14:56.67,0:15:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Cinta searah ♪
Dialogue: 0,0:15:00.55,0:15:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ membosankan ♪
Dialogue: 0,0:15:02.67,0:15:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Keraguanlah ♪
Dialogue: 0,0:15:06.55,0:15:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ bumbu cinta yang sesungguhnya ♪
Dialogue: 0,0:15:09.68,0:15:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lilith! Lilith! Lilith! Lilith! ♪
Dialogue: 0,0:15:19.36,0:15:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Chet ♪
Dialogue: 0,0:15:20.36,0:15:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dirinya pria yang amat rakus ♪
Dialogue: 0,0:15:24.24,0:15:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Status dan kehormatan ♪
Dialogue: 0,0:15:27.66,0:15:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Segala yang ia inginkan ♪
Dialogue: 0,0:15:32.37,0:15:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ pasti akan ia dapatkan,\Nsang miliarder ♪
Dialogue: 0,0:15:38.63,0:15:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh cinta yang rakus dan maskulin.
Dialogue: 0,0:15:46.97,0:15:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena itu,
Dialogue: 0,0:15:49.39,0:15:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak boleh jatuh hati padanya.
Dialogue: 0,0:15:52.72,0:15:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena terlalu rakus,\Nsetelah mendapatkanku,
Dialogue: 0,0:15:56.23,0:15:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cintanya mulai memudar.
Dialogue: 0,0:16:19.33,0:16:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Yang ini tak cocok,\Nyang itu tak cocok ♪
Dialogue: 0,0:16:23.88,0:16:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Cukup sudah ♪
Dialogue: 0,0:16:27.17,0:16:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku tak butuh cinta dari orang lain♪
Dialogue: 0,0:16:37.18,0:16:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:16:39.27,0:16:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya diriku sendiri.
Dialogue: 0,0:16:44.27,0:16:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tet.
Dialogue: 0,0:16:46.44,0:16:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencintai diriku saja sudah cukup.
Dialogue: 0,0:17:01.29,0:17:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Tidak cukup!
Dialogue: 0,0:17:07.05,0:17:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh...
Dialogue: 0,0:17:13.26,0:17:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berakhir begini!
Dialogue: 0,0:17:16.81,0:17:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Pasti bisa ♪
Dialogue: 0,0:17:19.23,0:17:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku pasti bisa mendapatkan cinta ♪
Dialogue: 0,0:17:38.33,0:17:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Pergilah menjauh ♪
Dialogue: 0,0:17:40.83,0:17:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sosokmu memanglah rupawan dan memesona ♪
Dialogue: 0,0:17:44.46,0:17:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tapi, hati ini tiada berdebar ♪
Dialogue: 0,0:17:47.50,0:17:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, hari ini pun kunaiki\Ntangga penuh hadiah ♪
Dialogue: 0,0:17:51.01,0:17:56.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ dan terlelap di ranjang penuh cinta ♪
Dialogue: 0,0:17:56.60,0:18:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, kuingin rasakan cinta\Nyang lebih membara lagi ♪
Dialogue: 0,0:18:11.78,0:18:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu dengar, Purson?
Dialogue: 0,0:18:14.28,0:18:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hebat, lo.
Dialogue: 0,0:18:16.24,0:18:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Segala yang kita pupuk\Nhampir mencapai klimaksnya!
Dialogue: 0,0:18:22.04,0:18:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kemarilah! Aku ada di sini! ♪
Dialogue: 0,0:18:26.63,0:18:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kemarilah! Kemarilah! Kemarilah! ♪
Dialogue: 0,0:18:30.05,0:18:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Datanglah ke sisiku! ♪
Dialogue: 0,0:18:35.80,0:18:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku sangat ingin, ingin,\Ningin bertemu denganmu! ♪
Dialogue: 0,0:19:19.10,0:19:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang akan memilih adalah kamu.
Dialogue: 0,0:19:21.49,0:19:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah memilih, kan?
Dialogue: 0,0:19:24.43,0:19:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu sudah bilang, kan?
Dialogue: 0,0:19:26.77,0:19:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada yang ingin kamu katakan,
Dialogue: 0,0:19:29.48,0:19:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}salurkan semuanya ke sini.
Dialogue: 0,0:19:47.50,0:19:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pixie!
Dialogue: 0,0:19:48.58,0:19:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pixie?
Dialogue: 0,0:19:49.50,0:19:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara trompet Pixie!
Dialogue: 0,0:20:11.27,0:20:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berikan aku cinta\Ndan romansa lebih lagi ♪
Dialogue: 0,0:20:15.57,0:20:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ hingga tubuh ini menggeliat\Nkesakitan dan sirna ♪
Dialogue: 0,0:20:23.54,0:20:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku pun akan terlahir kembali ♪
Dialogue: 0,0:20:26.83,0:20:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Cinta itu ada di sini ♪
Dialogue: 0,0:20:30.04,0:20:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Bagai permata murni ♪
Dialogue: 0,0:20:34.71,0:20:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ yang tersembunyi jauh\Ndi dalam lapisan bumi ♪
Dialogue: 0,0:20:40.55,0:20:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, Yodh ♪
Dialogue: 0,0:20:43.05,0:20:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dirimu yang belum kutemui ♪
Dialogue: 0,0:20:51.44,0:20:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, kuingin rasakan lebih lagi ♪
Dialogue: 0,0:20:56.86,0:21:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, kuingin rasakan cinta\Nyang lebih membara lagi ♪
Dialogue: 0,0:21:34.40,0:21:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pixie!
Dialogue: 0,0:21:36.57,0:21:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Menakjubkan!\N- Kamu luar biasa!
Dialogue: 0,0:21:39.28,0:21:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siapa kamu?\N- Pixie!
Dialogue: 0,0:21:41.49,0:21:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikahi aku!
Dialogue: 0,0:23:05.28,0:23:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Pasti bisa ♪
Dialogue: 0,0:23:07.53,0:23:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku pasti bisa mendapatkan cinta ♪
Dialogue: 0,0:23:32.93,0:23:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kemarilah! Aku ada di sini! ♪
Dialogue: 0,0:23:37.56,0:23:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kemarilah! Kemarilah! Kemarilah! ♪
Dialogue: 0,0:23:41.36,0:23:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Datanglah ke sisiku! ♪
Dialogue: 0,0:23:46.70,0:23:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku sangat ingin, ingin,\Ningin bertemu denganmu! ♪
Dialogue: 0,0:24:02.50,0:24:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, kuingin rasakan lebih lagi ♪
Dialogue: 0,0:24:08.05,0:24:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah, kuingin rasakan cinta\Nyang lebih membara lagi ♪
Dialogue: 0,0:24:29.99,0:24:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, festival musiknya meriah sekali, ya.
Dialogue: 0,0:24:32.37,0:24:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepuk tangan untuk para murid kelas satu.
Dialogue: 0,0:24:34.37,0:24:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku MVP kali ini adalah aku!
Dialogue: 0,0:24:37.00,0:24:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang sukses jadi pembawa acara!
Dialogue: 0,0:24:39.29,0:24:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, beri tepuk tangan untukku!\NAduh, duh, duh!
Dialogue: 0,0:24:42.13,0:24:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pak Kalego, tolong berhenti\Nmencengkeram wajahku!
Dialogue: 0,0:24:46.21,0:24:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:48.13,0:24:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Perayaan untuk Pemenang".
Dialogue: 0,0:24:49.30,0:24:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, waktunya pengumuman!
Dialogue: 0,0:24:51.39,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenang dari festival musik adalah...
