Dialogue: 0,0:00:55.49,0:01:02.79,sign,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:02:16.99,0:02:17.74,sign,,0000,0000,0000,,PESTA LIAR KELAS ABNORMAL
Dialogue: 0,0:04:57.78,0:04:59.95,sign,,0000,0000,0000,,JUS RELAKS
Dialogue: 0,0:06:03.18,0:06:04.47,sign,,0000,0000,0000,,BLA BLA BLA BLA
Dialogue: 0,0:11:08.86,0:11:11.48,sign,,0000,0000,0000,,JANTAN
Dialogue: 0,0:13:36.71,0:13:41.51,sign,,0000,0000,0000,,SELAMAT DATANG!
Dialogue: 0,0:13:42.76,0:13:43.60,sign,,0000,0000,0000,,PELAYAN DUNIA IBLIS
Dialogue: 0,0:16:30.84,0:16:32.60,sign,,0000,0000,0000,,PEKERJAAN ADMINISTRATIF
Dialogue: 0,0:16:35.43,0:16:37.52,sign,,0000,0000,0000,,MEMERIKSA KUNCI-KUNCI
Dialogue: 0,0:16:42.15,0:16:44.57,sign,,0000,0000,0000,,MEMPERSIAPKAN MAKANAN
Dialogue: 0,0:16:49.20,0:16:50.32,sign,,0000,0000,0000,,TIDAK BOLEH MEMASAK
Dialogue: 0,0:16:50.57,0:16:52.53,sign,,0000,0000,0000,,PENATAAN MEJA
Dialogue: 0,0:19:00.45,0:19:02.79,sign,,0000,0000,0000,,SECURITY DEVIL
Dialogue: 0,0:22:03.89,0:22:05.30,sign,,0000,0000,0000,,THIRTEEN'S DINNER
Dialogue: 0,0:22:13.14,0:22:17.02,sign,,0000,0000,0000,,MENARA BABEL
Dialogue: 0,0:24:01.34,0:24:02.25,sign,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:24:05.88,0:24:07.88,sign,,0000,0000,0000,,KAMULAH RAJA IBLIS
Dialogue: 0,0:24:29.99,0:24:31.78,sign,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:00:01.65,0:00:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun di dunia iblis\Nakhirnya akan segera berakhir.
Dialogue: 0,0:00:05.84,0:00:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah ini terjadi sesaat sebelum\Nbulan Desember berganti jadi bulan ke-13.
Dialogue: 0,0:00:11.82,0:00:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bulan ke-13?
Dialogue: 0,0:00:14.45,0:00:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu tahun di dunia iblis\Npunya 13 bulan.
Dialogue: 0,0:00:17.37,0:00:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peralihan dari tanggal 31 Desember\Nke tanggal 1 bulan ke-13
Dialogue: 0,0:00:21.88,0:00:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}disebut "Persilangan Bulan".
Dialogue: 0,0:00:24.17,0:00:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu "Malam Tahun Baru"!
Dialogue: 0,0:00:26.46,0:00:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia iblis, tahun baru\Ndimulai dari bulan ke-13, ya!
Dialogue: 0,0:00:29.30,0:00:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma benar!\NArtinya, sekarang sudah akhir tahun!
Dialogue: 0,0:00:33.18,0:00:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu, tidak apa-apa\Nuntuk bersantai sedikit di saat seperti ini.
Dialogue: 0,0:00:38.18,0:00:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:00:42.94,0:00:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah jadi seperti ini?
Dialogue: 0,0:02:17.74,0:02:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pesta Liar Kelas Abnormal".
Dialogue: 0,0:02:23.71,0:02:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi!
Dialogue: 0,0:02:30.05,0:02:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:02:38.22,0:02:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, selamat datang.
Dialogue: 0,0:02:40.35,0:02:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami telah menanti kalian.
Dialogue: 0,0:02:42.27,0:02:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas undangannya.
Dialogue: 0,0:02:44.23,0:02:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seenaknya memutuskan semuanya...
Dialogue: 0,0:02:46.81,0:02:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berpesta akhir tahun bersama?
Dialogue: 0,0:02:49.02,0:02:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita berpesta!
Dialogue: 0,0:02:50.61,0:02:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, di rumah Iruma.
Dialogue: 0,0:02:52.40,0:02:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan tanya Kakek dan Opera.
Dialogue: 0,0:02:55.45,0:02:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikut.
Dialogue: 0,0:02:57.24,0:03:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersyukurlah atas\Nkemurahan hati Tuan Iruma.
Dialogue: 0,0:03:00.99,0:03:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga sikap dan perilaku kalian!
Dialogue: 0,0:03:04.25,0:03:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, jangan membuat masalah!
Dialogue: 0,0:03:08.13,0:03:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya!
Dialogue: 0,0:03:09.92,0:03:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:03:13.30,0:03:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, duduklah\Ndi mana pun kalian suka.
Dialogue: 0,0:03:15.63,0:03:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan membantu.
Dialogue: 0,0:03:17.47,0:03:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Azz.
Dialogue: 0,0:03:20.64,0:03:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membagikan ini!
Dialogue: 0,0:03:24.31,0:03:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi bulan ke-13, kan?
Dialogue: 0,0:03:26.98,0:03:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalian menghabiskan waktu?
Dialogue: 0,0:03:29.19,0:03:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku mungkin bersama keluarga.
Dialogue: 0,0:03:32.44,0:03:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku menghubungi adikku.
Dialogue: 0,0:03:36.03,0:03:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kumpul bersama keluarga.
Dialogue: 0,0:03:37.82,0:03:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin tidur.
Dialogue: 0,0:03:39.74,0:03:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan bersama ayahku!
Dialogue: 0,0:03:42.08,0:03:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara tentang bulan ke-13,\Npastinya menyaksikan Turnamen Olahraga Iblis!
Dialogue: 0,0:03:46.02,0:03:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku juga nonton tiap tahun!
Dialogue: 0,0:03:48.08,0:03:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival impian yang menjadi tempat\Nidola iblis populer tampil bersama!
Dialogue: 0,0:03:51.59,0:03:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak sabar, ya!
Dialogue: 0,0:03:53.09,0:03:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira siapa yang akan\Nberkompetisi tahun ini?
Dialogue: 0,0:03:56.42,0:03:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira siapa, ya?
Dialogue: 0,0:03:57.59,0:03:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, siapa idola kalian?
Dialogue: 0,0:03:59.80,0:04:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mengobrol tentang idola iblis
Dialogue: 0,0:04:01.76,0:04:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- lebih dalam bersama?\N- Sip!
Dialogue: 0,0:04:03.72,0:04:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, tetap di tempat kalian!
Dialogue: 0,0:04:06.81,0:04:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bersulang!
Dialogue: 0,0:04:14.48,0:04:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, meski masih lama,
Dialogue: 0,0:04:16.89,0:04:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terima kasih atas usahanya\Nuntuk tahun ini!
Dialogue: 0,0:04:20.45,0:04:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!
Dialogue: 0,0:04:26.25,0:04:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah dan mewah.
Dialogue: 0,0:04:27.96,0:04:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya disiapkan oleh Opera.
Dialogue: 0,0:04:30.96,0:04:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Pera memang hebat! Mantap!
Dialogue: 0,0:04:35.76,0:04:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak sekali!
Dialogue: 0,0:04:41.59,0:04:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perpaduan rasa yang luar biasa!
Dialogue: 0,0:04:43.80,0:04:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti butuh upaya yang besar!
Dialogue: 0,0:04:49.69,0:04:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:04:50.81,0:04:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung minum, ya!
Dialogue: 0,0:04:54.98,0:04:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya unik, ya.\NIni kan...
Dialogue: 0,0:04:57.78,0:04:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jus Relaks!
Dialogue: 0,0:04:59.95,0:05:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman berkarbonasi yang bisa\Ndinikmati semua kalangan!
Dialogue: 0,0:05:03.32,0:05:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari meriahkan pesta ini!
Dialogue: 0,0:05:05.79,0:05:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini minuman yang membuatmu\Nsenang saat meminumnya.
Dialogue: 0,0:05:08.79,0:05:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu aman?
Dialogue: 0,0:05:11.12,0:05:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, ini minuman pesta.
Dialogue: 0,0:05:13.00,0:05:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma untuk menaikkan semangat,\Njadi tak apa-apa.
Dialogue: 0,0:05:16.17,0:05:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bawa!
Dialogue: 0,0:05:17.92,0:05:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma minuman unik, bukan alkohol.
Dialogue: 0,0:05:20.59,0:05:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan alkohol, ya?\NKalau begitu—
Dialogue: 0,0:05:25.64,0:05:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya bersantai...
Dialogue: 0,0:05:27.18,0:05:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya apa?\NEng, Clara, apa kamu baik—
Dialogue: 0,0:05:32.31,0:05:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenceng!
Dialogue: 0,0:05:32.94,0:05:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Irumachi, kamu jadi gemuk, ya?
Dialogue: 0,0:05:35.31,0:05:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, perutmu empuk-empuk.
Dialogue: 0,0:05:38.61,0:05:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Empuk-empuk.\N- Itu pelecehan seksual!
Dialogue: 0,0:05:40.19,0:05:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak gemuk!
Dialogue: 0,0:05:41.36,0:05:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma, sekarang masalahnya bukan itu!
Dialogue: 0,0:05:44.70,0:05:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak, kan?
Dialogue: 0,0:05:46.03,0:05:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Azz-Azz, hentikan dia!\NIruma—
Dialogue: 0,0:05:52.75,0:05:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma...
Dialogue: 0,0:05:57.00,0:05:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecil.
Dialogue: 0,0:05:59.46,0:06:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang paling paham\Nbetapa kuatnya Anda,
Dialogue: 0,0:06:03.18,0:06:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Anda kecil.
Dialogue: 0,0:06:04.47,0:06:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh Anda terlalu kecil!
Dialogue: 0,0:06:06.22,0:06:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak menahan kekuatanku,\NAnda bisa hancur, dong!
Dialogue: 0,0:06:08.76,0:06:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sahabat Anda,\Nini membuatku khawatir!
Dialogue: 0,0:06:11.27,0:06:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segeralah jadi besar!
Dialogue: 0,0:06:12.98,0:06:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Anda kecil sekali?
Dialogue: 0,0:06:15.27,0:06:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz-Azz, kamu kenapa?
Dialogue: 0,0:06:16.98,0:06:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar!
Dialogue: 0,0:06:19.48,0:06:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Encerkan dengan air sebelum diminum, ya.
Dialogue: 0,0:06:21.49,0:06:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringatan! Meminumnya langsung\Ndapat membuat terlalu hiperaktif!
Dialogue: 0,0:06:25.62,0:06:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, ini harus diencerkan!
Dialogue: 0,0:06:27.41,0:06:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertulis harus diencerkan dengan air dulu!
Dialogue: 0,0:06:29.49,0:06:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, Iruma!\NMereka akan jadi—
Dialogue: 0,0:06:34.00,0:06:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma, Anda itu kecil!\NAnda harus hati-hati!
Dialogue: 0,0:06:37.00,0:06:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak kecil.
Dialogue: 0,0:06:38.21,0:06:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, Anda terlalu menempel\Ndengan Shax belakangan ini.
Dialogue: 0,0:06:41.13,0:06:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena kalian sama-sama kecil?
Dialogue: 0,0:06:43.01,0:06:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lied memang kecil,\Ntapi aku tidak kecil.
Dialogue: 0,0:06:45.97,0:06:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:06:47.01,0:06:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga mau bilang!
Dialogue: 0,0:06:49.68,0:06:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azz dan Clara juga\Njadi makin akrab, kan?
Dialogue: 0,0:06:52.68,0:06:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba sudah memanggil\NClara dengan namanya!
Dialogue: 0,0:06:54.69,0:06:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia minum langsung!
Dialogue: 0,0:06:56.52,0:06:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Clara Bodoh bersama\Nkarena itu diperlukan!
Dialogue: 0,0:06:59.77,0:07:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:07:01.53,0:07:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku kesepian!
Dialogue: 0,0:07:03.28,0:07:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma sendiri juga meninggalkan kami\Nsaat festival panen dan saat main gim!
Dialogue: 0,0:07:08.16,0:07:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Anda selalu bersama Shax!
Dialogue: 0,0:07:11.54,0:07:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku pun pernah merasa kesulitan\Nmengobrol dengan kalian berdua!
Dialogue: 0,0:07:15.54,0:07:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajak kami mengobrol tanpa ragu!\NKami ini sahabat Anda!
Dialogue: 0,0:07:20.29,0:07:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, gawat.\NAku tidak bisa mengatasi ini sendiri.
Dialogue: 0,0:07:23.92,0:07:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, geng Iruma...
Dialogue: 0,0:07:26.30,0:07:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bertarung?\NAku tak akan kalah!
Dialogue: 0,0:07:28.84,0:07:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, nah, silakan.
Dialogue: 0,0:07:30.60,0:07:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari nikmati.
Dialogue: 0,0:07:34.81,0:07:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, ini mahakarya, lo.
Dialogue: 0,0:07:37.52,0:07:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saburo, apa yang—
Dialogue: 0,0:07:44.86,0:07:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:07:46.32,0:07:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roti lapis abnormal!
Dialogue: 0,0:07:47.82,0:07:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu baik-baik saja?
Dialogue: 0,0:07:50.62,0:07:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cewek benar-benar susah dimengerti, ya.
Dialogue: 0,0:07:52.58,0:07:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa suka cowok keren yang tak ramah?\NMembosankan, bukan?
Dialogue: 0,0:07:55.20,0:07:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku tidak populer,\Ntapi Pak Kalego yang licik justru populer?
Dialogue: 0,0:07:58.29,0:08:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir, ada yang namanya\Nkecocokan antara pria dan wanita.
Dialogue: 0,0:08:01.71,0:08:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa kalian mengobrol\Ntentang cinta di puncak situ?
Dialogue: 0,0:08:05.72,0:08:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, penderitaan adalah\Nbagian dari pengalaman.
Dialogue: 0,0:08:08.55,0:08:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persamaan itu lebih sulit dipecahkan\Ndaripada persamaan lain.
Dialogue: 0,0:08:11.89,0:08:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah hati wanita.
Dialogue: 0,0:08:14.20,0:08:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Allocer.
Dialogue: 0,0:08:15.64,0:08:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah punya pacar, kan?
Dialogue: 0,0:08:18.69,0:08:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akui saja.
Dialogue: 0,0:08:20.27,0:08:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akui saja! Akui saja!
Dialogue: 0,0:08:23.94,0:08:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roboh!
Dialogue: 0,0:08:26.28,0:08:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini apa?
Dialogue: 0,0:08:27.74,0:08:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan, aku yang akan merawat semuanya!
Dialogue: 0,0:08:32.15,0:08:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, biar aku saja!\NKamu lebih baik tidur!
Dialogue: 0,0:08:35.07,0:08:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjagamu juga!
Dialogue: 0,0:08:36.75,0:08:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membuat onigiri!
Dialogue: 0,0:08:39.37,0:08:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa membuat ramen!
Dialogue: 0,0:08:41.50,0:08:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas merawat adalah tugas diriku!
Dialogue: 0,0:08:43.25,0:08:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas merawat adalah tugas kakak, kan?
Dialogue: 0,0:08:46.01,0:08:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah aku sangat yakin\Ndengan potensi Irumi dan Lindy.
Dialogue: 0,0:08:50.97,0:08:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membayangkan\Nlagu debut mereka.
Dialogue: 0,0:08:55.01,0:08:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, serahkan saja—
Dialogue: 0,0:08:59.98,0:09:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, tidurlah.
Dialogue: 0,0:09:03.56,0:09:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya bersantai.
Dialogue: 0,0:09:06.23,0:09:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada lagi yang kerepotan?
Dialogue: 0,0:09:08.07,0:09:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jazz, apa yang kamu lakukan?
Dialogue: 0,0:09:09.82,0:09:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya juga kamu serahkan pada Gapp.
Dialogue: 0,0:09:11.74,0:09:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi, kan?
Dialogue: 0,0:09:13.49,0:09:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini kakak kalian!
Dialogue: 0,0:09:16.29,0:09:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ngomong apa, sih?
Dialogue: 0,0:09:17.50,0:09:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakaknya siapa?
Dialogue: 0,0:09:19.12,0:09:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menganggap\Nkalian semua adik-adikku, kok.
Dialogue: 0,0:09:24.54,0:09:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jazz, kamu berasa kakak banget.
Dialogue: 0,0:09:26.00,0:09:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu muncul dari mana?
Dialogue: 0,0:09:27.67,0:09:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Lied?
Dialogue: 0,0:09:29.34,0:09:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kamu memang seperti kakak, sih.
Dialogue: 0,0:09:32.76,0:09:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah gembira?
Dialogue: 0,0:09:35.64,0:09:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku lebih kakak dibanding Lied!
Dialogue: 0,0:09:38.18,0:09:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku yang tertua\Ndan Iruma yang kedua.
Dialogue: 0,0:09:41.39,0:09:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:09:42.14,0:09:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan setuju!
Dialogue: 0,0:09:43.40,0:09:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu anak ke-66.
Dialogue: 0,0:09:45.31,0:09:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan anak ketiga?
Dialogue: 0,0:09:47.15,0:09:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak ada yang bisa diajak ngobrol?
Dialogue: 0,0:09:50.69,0:09:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak bagaimana? Mbak!
Dialogue: 0,0:09:56.53,0:09:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa melengkung\Nsampai sejauh mana, ya?
Dialogue: 0,0:09:59.91,0:10:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak...
Dialogue: 0,0:10:01.37,0:10:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polos dan imut, ya.
Dialogue: 0,0:10:03.17,0:10:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, daripada polos...
Dialogue: 0,0:10:08.00,0:10:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatapan kami bertemu.
Dialogue: 0,0:10:17.30,0:10:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:10:30.73,0:10:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak...
Dialogue: 0,0:10:35.03,0:10:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak, aku selalu...
Dialogue: 0,0:10:40.29,0:10:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu me—
Dialogue: 0,0:10:45.02,0:10:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}me—
Dialogue: 0,0:10:47.81,0:10:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}me—
Dialogue: 0,0:10:51.46,0:10:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang jago main lompat tali, ya.
Dialogue: 0,0:10:56.43,0:10:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih belum bisa bilang\Nmeski sudah minum?
Dialogue: 0,0:10:59.22,0:11:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak mungkin tidak akan ingat,\Njadi lebih baik bilang saja.
Dialogue: 0,0:11:02.18,0:11:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak...
Dialogue: 0,0:11:03.60,0:11:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat!
Dialogue: 0,0:11:04.48,0:11:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencoba melakukan sesuatu pada wanita\Nyang sedang lengah itu tak bisa diterima!
Dialogue: 0,0:11:08.86,0:11:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pantas disebut pria sejati.
Dialogue: 0,0:11:11.48,0:11:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah kamu yang sadar?
Dialogue: 0,0:11:15.86,0:11:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hore! Pesta liar!\N- Dia sampai mengeluarkan familiar.
Dialogue: 0,0:11:19.37,0:11:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kamu sudah kelewatan!
Dialogue: 0,0:11:29.67,0:11:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah!
Dialogue: 0,0:11:30.84,0:11:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir bisa menandingi kakakmu?
Dialogue: 0,0:11:33.84,0:11:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:39.09,0:11:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, itu gawat sekali!
Dialogue: 0,0:11:42.10,0:11:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin sudah cukup minum?
Dialogue: 0,0:11:44.63,0:11:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat di atas panggung!\NTetap terhidrasi sangatlah penting
Dialogue: 0,0:11:47.14,0:11:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada banyak!\NNih, silakan!
Dialogue: 0,0:11:51.19,0:11:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggung Raja Iblis, ya?\NItu lumayan juga!
Dialogue: 0,0:11:55.49,0:11:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang! Selamat datang!
Dialogue: 0,0:11:58.91,0:12:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga! Aku hanya cukup\Nmembuat Tuan Iruma jadi besar!
Dialogue: 0,0:12:02.37,0:12:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurlah aliansi kecil!
Dialogue: 0,0:12:07.16,0:12:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah besar.
Dialogue: 0,0:12:31.90,0:12:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria sejati tidak boleh lupa sopan santun\Ndan martabat, apa pun keadaannya!
Dialogue: 0,0:12:37.07,0:12:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa tidur apa pun keadaannya.
Dialogue: 0,0:12:40.28,0:12:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik, ya.
Dialogue: 0,0:12:42.24,0:12:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah begini...
Dialogue: 0,0:12:47.16,0:12:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya bersantai.
Dialogue: 0,0:12:49.21,0:12:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lied.
Dialogue: 0,0:12:51.04,0:12:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma juga minum jus?
Dialogue: 0,0:12:54.50,0:12:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu di pinggangmu, lo.
Dialogue: 0,0:12:57.55,0:12:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik, ya.
Dialogue: 0,0:12:59.09,0:13:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:01.26,0:13:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di masa depan...
Dialogue: 0,0:13:03.60,0:13:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ketika sudah dewasa...
Dialogue: 0,0:13:07.39,0:13:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita semua berkumpul...
Dialogue: 0,0:13:09.77,0:13:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama-sama.
Dialogue: 0,0:13:26.12,0:13:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka jelas perlu dinasihati, ya.
Dialogue: 0,0:13:29.91,0:13:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu, semuanya diminta\Nmenulis 666 halaman makalah refleksi diri.
Dialogue: 0,0:13:43.60,0:13:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pelayan Dunia Iblis".
Dialogue: 0,0:13:50.77,0:13:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir-akhir ini, Tuan Iruma...
Dialogue: 0,0:13:53.52,0:13:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda tampaknya agak melampaui batas.
Dialogue: 0,0:13:58.65,0:14:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berawal dari menginap tanpa izin\Nsaat festival musik.
Dialogue: 0,0:14:03.11,0:14:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berakhir dengan berbuat gaduh\Nbersama teman-teman kelas Anda.
Dialogue: 0,0:14:05.95,0:14:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Anda harus kembali\Nmenjalani gaya hidup disiplin.
Dialogue: 0,0:14:12.66,0:14:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat seperti perkataanmu.
Dialogue: 0,0:14:14.37,0:14:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu,
Dialogue: 0,0:14:15.67,0:14:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah berkonsultasi dengan Tuan Sullivan...
Dialogue: 0,0:14:17.88,0:14:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin dia disiplin,\Ncukup suruh dia menirumu!
Dialogue: 0,0:14:21.09,0:14:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berkesimpulan demikian.
Dialogue: 0,0:14:25.59,0:14:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu, Anda akan\Njadi pelayan seharian ini.
Dialogue: 0,0:14:29.85,0:14:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya, Opera.\NAura disiplinnya sangat terasa.
Dialogue: 0,0:14:34.94,0:14:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana, selera kakek...
Dialogue: 0,0:14:37.61,0:14:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Ada sedikit selera Opera?
Dialogue: 0,0:14:40.61,0:14:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, saya yang pilih.\NItu dipesan khusus.
Dialogue: 0,0:14:44.11,0:14:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipesan khusus?
Dialogue: 0,0:14:46.28,0:14:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, mari mulai dengan\Nmembersihkan ruang tamu.
Dialogue: 0,0:14:48.61,0:14:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:14:49.41,0:14:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, saya akan\Nmemindahkan perabotannya, ya.
Dialogue: 0,0:14:52.20,0:14:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:14:55.87,0:14:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:14:58.23,0:14:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:14:59.42,0:15:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, baik.
Dialogue: 0,0:15:02.92,0:15:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa fraktal, ya?
Dialogue: 0,0:15:04.93,0:15:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, sebelah sini.
Dialogue: 0,0:15:06.72,0:15:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:08.10,0:15:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, sebelah sini.
Dialogue: 0,0:15:09.72,0:15:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:10.18,0:15:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, sebelah sini.
Dialogue: 0,0:15:11.43,0:15:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:15:12.27,0:15:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, sebelah sini.
Dialogue: 0,0:15:13.43,0:15:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:15:14.52,0:15:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Opera memang luar biasa.
Dialogue: 0,0:15:17.52,0:15:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efisien dan cepat.
Dialogue: 0,0:15:21.53,0:15:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu punya tips bersih-bersih?
Dialogue: 0,0:15:24.70,0:15:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:15:26.32,0:15:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba curahkan dengan sepenuh hati.
Dialogue: 0,0:15:28.66,0:15:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Terima kasih sudah selalu\Nmembiarkanku main gim."
Dialogue: 0,0:15:31.70,0:15:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah selalu\Nmembiarkanku main gim.
Dialogue: 0,0:15:34.04,0:15:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku akan membatasi waktu\Nmain gim jadi sejam sehari."
Dialogue: 0,0:15:36.33,0:15:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku akan membatasi waktu\Nmain gim jadi sejam sehari.
Dialogue: 0,0:15:39.92,0:15:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, mencuci pakaian.
Dialogue: 0,0:15:41.92,0:15:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaket ke sebelah sana.
Dialogue: 0,0:15:43.21,0:15:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celana dan pakaian sebelah sini\Ndan saputangan dicuci dengan tangan.
Dialogue: 0,0:15:46.55,0:15:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detergennya, dari kanan: untuk jaket,\Npakaian dalam, cucian tangan, lalu sepatu,
Dialogue: 0,0:15:51.14,0:15:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk pakaian modis atau dry cleaning,
Dialogue: 0,0:15:53.31,0:15:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}khusus untuk syal Tuan Sullivan\Nagar tetap lembut, untuk noda berat,
Dialogue: 0,0:15:57.14,0:16:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan untuk noda yang sangat membandel\Ntambahkan setetes DeviCleanser super kuat.
Dialogue: 0,0:16:01.23,0:16:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, jenisnya ada banyak.
Dialogue: 0,0:16:04.07,0:16:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama pakaian Tuan Sullivan,\Nharus dicuci dengan hati-hati.
Dialogue: 0,0:16:07.99,0:16:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya semuanya\Nadalah produk kelas atas.
Dialogue: 0,0:16:10.07,0:16:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, harganya kira-kira sebegini.
Dialogue: 0,0:16:15.41,0:16:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasur dicuci dengan cara diinjak.
Dialogue: 0,0:16:17.41,0:16:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ini favorit saya.
Dialogue: 0,0:16:20.54,0:16:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Opera lompat-lompat.
Dialogue: 0,0:16:24.30,0:16:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang asyik, sih.
Dialogue: 0,0:16:27.38,0:16:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa magangnya sebagai pelayan\Nmasih akan terus berlanjut!
Dialogue: 0,0:16:30.84,0:16:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan administratif.
Dialogue: 0,0:16:32.60,0:16:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang akan dibuang.
Dialogue: 0,0:16:34.26,0:16:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yes, sir!
Dialogue: 0,0:16:35.43,0:16:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memeriksa kunci-kunci.
Dialogue: 0,0:16:37.52,0:16:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya normal!
Dialogue: 0,0:16:40.56,0:16:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, lo.
Dialogue: 0,0:16:42.15,0:16:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mempersiapkan makanan.
Dialogue: 0,0:16:44.57,0:16:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Sullivan tidak suka terong,\Njadi selipkan tanpa ketahuan.
Dialogue: 0,0:16:49.20,0:16:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, toh.
Dialogue: 0,0:16:50.57,0:16:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penataan meja.
Dialogue: 0,0:16:52.53,0:16:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peralatan makannya digunakan dari sisi luar,
Dialogue: 0,0:16:55.24,0:16:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi cara menatanya begini.
Dialogue: 0,0:16:56.66,0:16:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serbetnya di sebelah kiri,
Dialogue: 0,0:16:58.33,0:17:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiap piring diberi jarak enam senti,\Ndan gelasnya dua.
Dialogue: 0,0:17:02.17,0:17:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:03.04,0:17:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Etiket meja makan sangat penting\Ndi tempat umum, jadi sebaiknya diingat.
Dialogue: 0,0:17:08.30,0:17:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak iblis bangsawan\Nyang memiliki peralatan makan khusus
Dialogue: 0,0:17:11.93,0:17:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kebanyakannya cukup berharga, lo.
Dialogue: 0,0:17:14.14,0:17:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu, karena sering berkelahi\Ndengan Tuan Sullivan,
Dialogue: 0,0:17:18.34,0:17:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya pun sering\Nmenyembunyikan garpu beliau.
Dialogue: 0,0:17:20.56,0:17:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu melakukan itu?
Dialogue: 0,0:17:22.69,0:17:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda tidak perlu mencatat itu.
Dialogue: 0,0:17:27.10,0:17:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembari bekerja,\Naku jadi tahu banyak tentang Opera.
Dialogue: 0,0:17:31.20,0:17:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya menyenangkan.
Dialogue: 0,0:17:34.12,0:17:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:17:46.71,0:17:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak makan—\NMaksudku, ada banyak tanaman, ya.
Dialogue: 0,0:17:50.97,0:17:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya panen?
Dialogue: 0,0:17:52.22,0:17:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:53.34,0:17:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:17:53.84,0:17:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kita akan lakukan itu nanti.
Dialogue: 0,0:17:56.26,0:17:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah di sini, mari istirahat\Ndan nikmati buah-buah yang baru dipetik.
Dialogue: 0,0:18:08.23,0:18:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:18:09.94,0:18:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buah yang baru dipetik\Nrasanya mewah banget, ya.
Dialogue: 0,0:18:12.74,0:18:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas seorang pelayan ada banyak, ya.
Dialogue: 0,0:18:15.95,0:18:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sangat terbantu\Nkarena Tuan Iruma cepat ingatnya.
Dialogue: 0,0:18:19.12,0:18:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengalaman Anda sebagai\Npengurus OSIS benar bermanfaat.
Dialogue: 0,0:18:22.79,0:18:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi teringat kembali.
Dialogue: 0,0:18:25.33,0:18:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, setelah bekerja denganmu,\Naku jadi menyadari...
Dialogue: 0,0:18:31.72,0:18:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar mengurus semuanya, ya.
Dialogue: 0,0:18:39.51,0:18:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dengan cara ini,\Nkamu melindungi kehidupan kami...
Dialogue: 0,0:18:47.81,0:18:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap harinya.
Dialogue: 0,0:18:53.45,0:18:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia iblis...
Dialogue: 0,0:18:56.11,0:19:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis yang melayani iblis lain\Nseperti saya disebut SD.
Dialogue: 0,0:19:00.45,0:19:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami disebut Security Devil.
Dialogue: 0,0:19:02.79,0:19:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain melindungi nyawa tuannya,\Nkami juga menjaga dan mendukung
Dialogue: 0,0:19:07.63,0:19:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}segala hal mulai dari reputasi dan status\Nhingga penampilan tuan kami.
Dialogue: 0,0:19:13.17,0:19:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak pernah setengah hati\Ndalam menjalankan tugas harian.
Dialogue: 0,0:19:18.47,0:19:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya kakek\Nsangat penting bagimu, kan?
Dialogue: 0,0:19:22.64,0:19:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:23.81,0:19:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!\NKita sudah seperti keluarga, sih.
Dialogue: 0,0:19:28.65,0:19:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda benar.
Dialogue: 0,0:19:30.77,0:19:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ini adalah\Nkasih sayang, kesetiaan,
Dialogue: 0,0:19:34.32,0:19:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan...
Dialogue: 0,0:19:37.53,0:19:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketergantungan.
Dialogue: 0,0:19:40.45,0:19:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketergantungan?
Dialogue: 0,0:19:42.70,0:19:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia iblis, rasa belas kasih\Nterhadap sesama sangat rendah
Dialogue: 0,0:19:46.37,0:19:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga saya belajar apa artinya "melayani".
Dialogue: 0,0:19:52.50,0:19:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh keberadaan saya...
Dialogue: 0,0:19:54.09,0:19:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari setetes darah\Nhingga ujung kuku jari,
Dialogue: 0,0:19:58.18,0:20:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekalipun saya menyerahkan\Ndan mencurahkan segalanya,
Dialogue: 0,0:20:02.89,0:20:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau pasti akan merespons\Nlebih dari harapan saya.
Dialogue: 0,0:20:06.85,0:20:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya terus percaya hal itu.
Dialogue: 0,0:20:12.32,0:20:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Hakikat dari mengabdi terletak pada\Nketergantungan yang disebut harapan."
Dialogue: 0,0:20:18.20,0:20:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya selalu melayani Tuan Sullivan\Ndengan pola pikir itu.
Dialogue: 0,0:20:25.12,0:20:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya pun berharap kelak dapat melayani\NTuan Iruma dengan cara yang sama.
Dialogue: 0,0:20:43.76,0:20:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma.
Dialogue: 0,0:20:46.27,0:20:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sebelumnya pernah bilang,\Nuntuk hidup di dunia iblis,
Dialogue: 0,0:20:49.73,0:20:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda perlu tekad yang kuat.
Dialogue: 0,0:20:53.82,0:20:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda mengingatnya?
Dialogue: 0,0:20:56.57,0:21:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama jika Tuan Iruma terus hidup\Nsebagai anggota keluarga Sullivan,
Dialogue: 0,0:21:02.24,0:21:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda akan menghadapi banyak posisi\Ndan kesulitan yang berat.
Dialogue: 0,0:21:08.62,0:21:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kalau Anda\Ntetap memilih tempat ini...
Dialogue: 0,0:21:14.38,0:21:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Iruma, bolehkah saya\Nmenaruh "harapan" pada Anda?
Dialogue: 0,0:21:33.52,0:21:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:21:37.11,0:21:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kalau begitu,
Dialogue: 0,0:21:38.53,0:21:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tugas Anda telah selesai.
Dialogue: 0,0:21:40.82,0:21:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita telah mengatasi kelemahan Anda\Ndan pola pikir Anda pun sudah siap.
Dialogue: 0,0:21:44.41,0:21:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelemahan?
Dialogue: 0,0:21:45.78,0:21:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, saya bisa tenang sekarang.
Dialogue: 0,0:21:48.62,0:21:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap yang bermartabat diperlukan\Ndalam lingkungan formal.
Dialogue: 0,0:21:54.08,0:21:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cucu dari keluarga Sullivan, Tuan Iruma.
Dialogue: 0,0:21:57.92,0:22:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini undangan Anda untuk hadir\Ndi Thirteen's Dinner.
Dialogue: 0,0:22:22.53,0:22:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thirteen's Dinner?
Dialogue: 0,0:23:58.63,0:24:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan!
Dialogue: 0,0:24:05.88,0:24:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gim Raja Iblis!
Dialogue: 0,0:24:07.88,0:24:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama lima menit ke depan,\Naku memberimu hak untuk jadi kakak!
Dialogue: 0,0:24:12.56,0:24:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap! Aku kakak kalian!
Dialogue: 0,0:24:15.18,0:24:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, wahai adik-adikku.
Dialogue: 0,0:24:18.65,0:24:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak! Kakak! Kakak!
Dialogue: 0,0:24:22.63,0:24:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang mustahil buatku!
Dialogue: 0,0:24:25.53,0:24:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang anak ke-66.
Dialogue: 0,0:24:28.28,0:24:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:24:29.99,0:24:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thirteen's Dinner.
Dialogue: 0,0:24:31.78,0:24:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah jamuan agung tempat\Npara pahlawan dunia iblis berkumpul.
Dialogue: 0,0:24:35.12,0:24:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kesempatan ini, Tuan Iruma telah diundang\Nuntuk bertemu para pahlawan itu.
Dialogue: 0,0:24:39.75,0:24:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena Tuan Iruma telah diajukan\Nsebagai calon Raja Iblis selanjutnya.
Dialogue: 0,0:24:45.13,0:24:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:47.09,0:24:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pertemuan Para Pahlawan".
Dialogue: 0,0:24:48.88,0:24:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, juga ada kandidat\Ncalon Raja Iblis lainnya.
Dialogue: 0,0:24:51.85,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apakah mereka?\NNantikan di episode selanjutnya.
