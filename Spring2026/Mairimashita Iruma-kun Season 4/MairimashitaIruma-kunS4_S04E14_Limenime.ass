Dialogue: 0,0:00:33.47,0:00:40.77,sign,,0000,0000,0000,,WELCOME TO DEMON SCHOOL! IRUMA-KUN SEASON 4
Dialogue: 0,0:01:55.01,0:01:55.85,sign,,0000,0000,0000,,MENYUSUP KE ASRAMA GURU!
Dialogue: 0,0:01:59.77,0:02:04.52,sign,,0000,0000,0000,,ASRAMA GURU BABYLS
Dialogue: 0,0:02:09.47,0:02:11.57,sign,,0000,0000,0000,,RUANG REKREASI
Dialogue: 0,0:02:54.15,0:02:55.15,sign,,0000,0000,0000,,PI?
Dialogue: 0,0:02:59.37,0:03:03.66,sign,,0000,0000,0000,,PEMANDU
Dialogue: 0,0:03:35.90,0:03:38.49,sign,,0000,0000,0000,,PERINTAH KEPSEK
Dialogue: 0,0:03:45.08,0:03:47.25,sign,,0000,0000,0000,,PEMANDU
Dialogue: 0,0:04:00.72,0:04:03.85,sign,,0000,0000,0000,,PEMANDU
Dialogue: 0,0:04:10.27,0:04:12.61,sign,,0000,0000,0000,,PEMANDU
Dialogue: 0,0:04:25.79,0:04:30.17,sign,,0000,0000,0000,,PEMANDU
Dialogue: 0,0:04:50.90,0:04:52.98,sign,,0000,0000,0000,,KAMAR PENGHUNI
Dialogue: 0,0:05:11.08,0:05:12.46,sign,,0000,0000,0000,,KAMAR MANDI UMUM
Dialogue: 0,0:05:35.31,0:05:37.82,sign,,0000,0000,0000,,PEMANDU
Dialogue: 0,0:05:40.95,0:05:41.61,sign,,0000,0000,0000,,KAMAR 106
Dialogue: 0,0:05:47.03,0:05:49.04,sign,,0000,0000,0000,,GURU PENYIKSAAN - MARBAS MARCH
Dialogue: 0,0:06:59.86,0:07:01.16,sign,,0000,0000,0000,,PEMANDIAN UMUM
Dialogue: 0,0:07:06.11,0:07:09.20,sign,,0000,0000,0000,,PEMANDU
Dialogue: 0,0:12:04.37,0:12:05.37,sign,,0000,0000,0000,,KYA
Dialogue: 0,0:13:01.68,0:13:06.35,sign,,0000,0000,0000,,DIAM!
Dialogue: 0,0:13:07.73,0:13:11.23,sign,,0000,0000,0000,,ANGGOTA BARU ACARA PERKUMPULAN PEREMPUAN?
Dialogue: 0,0:13:13.31,0:13:16.28,sign,,0000,0000,0000,,ASRAMA MURID BABYLS
Dialogue: 0,0:14:13.12,0:14:15.33,sign,,0000,0000,0000,,BATRA PERALATAN SIHIR
Dialogue: 0,0:14:30.23,0:14:31.35,sign,,0000,0000,0000,,KEWALAHAN KERJA
Dialogue: 0,0:15:36.04,0:15:37.29,sign,,0000,0000,0000,,TANDUK - PAKAIAN - EKOR - SEPATU
Dialogue: 0,0:16:04.04,0:16:07.15,sign,,0000,0000,0000,,IKAT EKOR
Dialogue: 0,0:23:48.53,0:23:52.49,sign,,0000,0000,0000,,TAMBAHAN
Dialogue: 0,0:23:56.21,0:23:58.50,sign,,0000,0000,0000,,PEMANDU
Dialogue: 0,0:24:29.99,0:24:30.36,sign,,0000,0000,0000,,CUPLIKAN
Dialogue: 0,0:00:00.98,0:00:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya manusia\Nyang tinggal di dunia para iblis.
Dialogue: 0,0:00:04.19,0:00:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki Iruma, 15 tahun.
Dialogue: 0,0:00:06.86,0:00:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi Iruma menikmati\Nkehidupan sekolahnya di Babyls,
Dialogue: 0,0:00:10.78,0:00:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia punya ambisi\Natau lebih tepatnya tujuan,
Dialogue: 0,0:00:13.70,0:00:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yaitu, naik tingkat.
Dialogue: 0,0:00:17.16,0:00:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantas, apakah yang menanti\Ndi akhir perjalanannya?
Dialogue: 0,0:01:55.85,0:01:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Menyusup ke Asrama Guru!"
Dialogue: 0,0:01:59.77,0:02:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, pemirsa akan dipandu
Dialogue: 0,0:02:02.64,0:02:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke asrama guru Babyls.
Dialogue: 0,0:02:04.52,0:02:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya para guru yang diizinkan masuk.
Dialogue: 0,0:02:07.07,0:02:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang luar umumnya dilarang memasuki
Dialogue: 0,0:02:09.47,0:02:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}properti budaya yang mulia ini.
Dialogue: 0,0:02:12.03,0:02:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah asrama\Nyang didambakan oleh para iblis.
Dialogue: 0,0:02:16.66,0:02:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:02:19.91,0:02:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang bertugas\Nmencuci pakaian hari ini?
Dialogue: 0,0:02:21.91,0:02:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau, tahu!
Dialogue: 0,0:02:23.29,0:02:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak lapar?
Dialogue: 0,0:02:25.17,0:02:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eito barusan pesan piza.
Dialogue: 0,0:02:27.79,0:02:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada piza!
Dialogue: 0,0:02:30.17,0:02:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang kalah akan traktir.
Dialogue: 0,0:02:32.30,0:02:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku payah kalau gim balapan.
Dialogue: 0,0:02:35.34,0:02:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Setelah makan,\Nayo lihat penampilan Kuromu!
Dialogue: 0,0:02:38.30,0:02:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan langka yang ada Irumi-nya!
Dialogue: 0,0:02:41.27,0:02:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka banget Idola Iblis, ya.
Dialogue: 0,0:02:43.98,0:02:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, siapa yang bertugas mencuci?
Dialogue: 0,0:02:46.31,0:02:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, akhirnya datang.
Dialogue: 0,0:02:48.06,0:02:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piza! Piza!
Dialogue: 0,0:02:49.82,0:02:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Selamat datang, pi—
Dialogue: 0,0:02:54.15,0:02:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pi?
Dialogue: 0,0:02:55.15,0:02:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego dan Iruma?
Dialogue: 0,0:02:57.66,0:02:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:02:59.37,0:03:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak, ini rombongan yang ikut tur asrama guru.
Dialogue: 0,0:03:03.66,0:03:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tur?
Dialogue: 0,0:03:05.16,0:03:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?
Dialogue: 0,0:03:06.17,0:03:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:03:09.79,0:03:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para guru tinggal di sini!
Dialogue: 0,0:03:12.09,0:03:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali!
Dialogue: 0,0:03:14.97,0:03:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin, aku menemukan pamflet\Ntentang asrama guru,
Dialogue: 0,0:03:18.72,0:03:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu...
Dialogue: 0,0:03:20.30,0:03:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:03:23.85,0:03:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa malah berakhir jadi tur.
Dialogue: 0,0:03:29.48,0:03:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Pak Dali jadi pemandunya\Ndan Pak Kalego...
Dialogue: 0,0:03:33.99,0:03:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemani mereka.
Dialogue: 0,0:03:35.90,0:03:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu,
Dialogue: 0,0:03:36.78,0:03:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai bagian dari perintah kepsek,
Dialogue: 0,0:03:38.49,0:03:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan secara serius mengamati\Nkehidupan asrama guru di hari libur
Dialogue: 0,0:03:42.20,0:03:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memastikan itu tidak memalukan.
Dialogue: 0,0:03:45.08,0:03:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ahlinya melampiaskan emosi pada orang lain!
Dialogue: 0,0:03:47.25,0:03:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah "pemeriksaan".
Dialogue: 0,0:03:49.25,0:03:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Aku harus bersih—\NAku ada urusan!
Dialogue: 0,0:03:52.38,0:03:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, aku juga!
Dialogue: 0,0:03:53.25,0:03:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam! Aku akan mulai\Ndari ruang rekreasi ini.
Dialogue: 0,0:03:58.72,0:04:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan segera kubersihkan!
Dialogue: 0,0:04:00.72,0:04:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ramai juga, ya.
Dialogue: 0,0:04:03.85,0:04:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam lebih seru lagi.
Dialogue: 0,0:04:06.77,0:04:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari menyusup\Nke sarang para iblis dewasa!
Dialogue: 0,0:04:17.39,0:04:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berapa lama sejak selain guru\Ndiizinkan masuk ke sini, ya?
Dialogue: 0,0:04:21.41,0:04:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat.
Dialogue: 0,0:04:23.41,0:04:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh masuk ke sana?
Dialogue: 0,0:04:25.79,0:04:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tur dari Pak Kepsek,
Dialogue: 0,0:04:27.83,0:04:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi bukan masalah!
Dialogue: 0,0:04:30.17,0:04:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otonja,
Dialogue: 0,0:04:32.50,0:04:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami pergi dulu.
Dialogue: 0,0:04:37.55,0:04:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma?
Dialogue: 0,0:04:39.09,0:04:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kemari.
Dialogue: 0,0:04:40.26,0:04:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya.
Dialogue: 0,0:04:44.14,0:04:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Liftnya besar.
Dialogue: 0,0:04:56.65,0:04:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atapnya tinggi!
Dialogue: 0,0:04:58.65,0:05:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada tempat tidur\Ngantung di koridor?
Dialogue: 0,0:05:01.41,0:05:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena terlalu malas\Nuntuk jauh-jauh ke kamar,
Dialogue: 0,0:05:04.45,0:05:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka sengaja taruh di sini\Nagar bisa langsung tidur.
Dialogue: 0,0:05:07.08,0:05:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya tempat ini luas.
Dialogue: 0,0:05:12.46,0:05:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini juga luas, ya.
Dialogue: 0,0:05:15.04,0:05:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada guru yang sayapnya besar juga, sih.
Dialogue: 0,0:05:17.92,0:05:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pekerjaan yang menuntut,\NMengajar adalah
Dialogue: 0,0:05:20.05,0:05:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi asrama ini benar-benar berfungsi\Nagar kami bisa melegakan sayap kami.
Dialogue: 0,0:05:25.81,0:05:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stok tidak terisi.
Dialogue: 0,0:05:27.52,0:05:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini tugasnya...
Dialogue: 0,0:05:29.48,0:05:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bars Robin.
Dialogue: 0,0:05:35.31,0:05:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncul juga!
Dialogue: 0,0:05:36.40,0:05:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelampiasan putaran kedua!
Dialogue: 0,0:05:37.82,0:05:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pemeriksaan.
Dialogue: 0,0:05:41.61,0:05:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:05:44.16,0:05:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran ada Pak Kalego dan Iruma.
Dialogue: 0,0:05:47.03,0:05:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya pada ribut, lo.
Dialogue: 0,0:05:49.04,0:05:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sedang mencoba alat baru\Nagar mudah dipahami
Dialogue: 0,0:05:52.58,0:05:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat digunakan di kelas nanti.
Dialogue: 0,0:05:54.79,0:05:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ruangannya agak kotor.
Dialogue: 0,0:05:56.63,0:05:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:57.46,0:06:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau memeriksa, kan?\NSilakan masuk!
Dialogue: 0,0:06:00.72,0:06:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:06:02.84,0:06:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tunggu di sini, Iruma.
Dialogue: 0,0:06:07.85,0:06:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:06:10.43,0:06:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Iruma.
Dialogue: 0,0:06:12.27,0:06:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, anak dari kerabatku\Nmasuk ke Babyls tahun depan.
Dialogue: 0,0:06:18.32,0:06:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagimu, dia akan jadi adik kelas.
Dialogue: 0,0:06:20.78,0:06:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ketemu, bisa tolong\Nyang akrab dengannya?
Dialogue: 0,0:06:23.90,0:06:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik kelas?
Dialogue: 0,0:06:25.32,0:06:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:06:26.32,0:06:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, sampai ketemu\Ndi kelas penyiksaan!
Dialogue: 0,0:06:28.70,0:06:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mapel yang dalam, lo!
Dialogue: 0,0:06:33.21,0:06:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar dalam banget, ya.
Dialogue: 0,0:06:36.21,0:06:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari kembali\Nke topik utama dan lanjutkan turnya!
Dialogue: 0,0:06:40.96,0:06:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Saat ini, aku sedang mengatur\Nbuku-buku yang penting...
Dialogue: 0,0:06:45.01,0:06:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan segera kubersihkan!
Dialogue: 0,0:06:48.72,0:06:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak ada hewan peliharaan...
Dialogue: 0,0:06:52.98,0:06:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hush, diam!
Dialogue: 0,0:06:55.48,0:06:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing?
Dialogue: 0,0:06:57.23,0:06:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kamu dapat izin, ya.
Dialogue: 0,0:07:01.16,0:07:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa temboknya retak?
Dialogue: 0,0:07:02.63,0:07:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mencoba meriam kematian bawah air,\Nkami jadi kelepasan.
Dialogue: 0,0:07:06.11,0:07:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang terlibat akan diperiksa nanti.
Dialogue: 0,0:07:13.20,0:07:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:07:14.87,0:07:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cocok banget untuk tetap terjaga.
Dialogue: 0,0:07:17.12,0:07:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti.
Dialogue: 0,0:07:19.38,0:07:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:07:20.96,0:07:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Orias, kamu main gim\Nsemalam lagi, kan?
Dialogue: 0,0:07:24.88,0:07:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pak Orias?
Dialogue: 0,0:07:29.89,0:07:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bapak kelihatan berbeda.
Dialogue: 0,0:07:31.64,0:07:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ini hari libur.
Dialogue: 0,0:07:34.81,0:07:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi makan malam,\Njadi jangan makan dulu.
Dialogue: 0,0:07:37.10,0:07:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi camilan datang!
Dialogue: 0,0:07:38.69,0:07:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tertangkap basah!
Dialogue: 0,0:07:41.15,0:07:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, padahal sudah kubilang,\Njangan mengudap sebelum makan malam.
Dialogue: 0,0:07:45.36,0:07:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf,\Njadi tolong lepaskan.
Dialogue: 0,0:07:48.41,0:07:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini Pot-au-feu!\NPot-au-feu! Pot-Pot-Pot-Pot!
Dialogue: 0,0:07:52.91,0:07:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang masak?
Dialogue: 0,0:07:54.75,0:07:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cukup jago, lo.
Dialogue: 0,0:07:56.96,0:08:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian besar isinya sayuran,\Ntapi itu berkah bagi yang kekurangan nutrisi.
Dialogue: 0,0:08:01.00,0:08:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan...
Dialogue: 0,0:08:03.84,0:08:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:08:05.84,0:08:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Pak Kalego dan Iruma!
Dialogue: 0,0:08:08.80,0:08:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bumbu berbahan dasar tomat saja\Ntak apa-apa, kan?
Dialogue: 0,0:08:11.22,0:08:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, rasanya aku tadi\Ndiserang Cerberus.
Dialogue: 0,0:08:14.14,0:08:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar, deh.
Dialogue: 0,0:08:15.31,0:08:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu berasumsi\Nkami akan ikut makan?
Dialogue: 0,0:08:17.64,0:08:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menantikannya!
Dialogue: 0,0:08:18.81,0:08:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau mencicipinya sedikit?
Dialogue: 0,0:08:22.82,0:08:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei, hei, hei, hei.
Dialogue: 0,0:08:26.07,0:08:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan omongan orang lain.
Dialogue: 0,0:08:28.07,0:08:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya enak.
Dialogue: 0,0:08:29.91,0:08:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perutku keroncongan.
Dialogue: 0,0:08:31.24,0:08:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai juga bersih-bersihnya.
Dialogue: 0,0:08:33.45,0:08:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan enak!
Dialogue: 0,0:08:34.95,0:08:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah alasan kami tidak bisa membencimu.
Dialogue: 0,0:08:37.96,0:08:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari sajikan\Nmakanannya dan makan.
Dialogue: 0,0:08:40.50,0:08:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, akan kubantu!
Dialogue: 0,0:08:42.08,0:08:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Iruma!
Dialogue: 0,0:08:44.13,0:08:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego!
Dialogue: 0,0:08:45.59,0:08:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, aku tak bilang akan—
Dialogue: 0,0:08:47.47,0:08:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Dali, tolong urus rotinya.
Dialogue: 0,0:08:49.72,0:08:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:08:51.05,0:08:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:09:07.82,0:09:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sebelum makan,
Dialogue: 0,0:09:10.65,0:09:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dunia iblis kejam,\Nketika bertahan hidup adalah perjuangan,
Dialogue: 0,0:09:14.45,0:09:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari panjatkan rasa syukur kita.
Dialogue: 0,0:09:17.62,0:09:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita minta Iruma untuk memimpin hari ini.
Dialogue: 0,0:09:21.67,0:09:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau begitu...
Dialogue: 0,0:09:25.00,0:09:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:09:26.71,0:09:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan!
Dialogue: 0,0:09:30.88,0:09:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget!
Dialogue: 0,0:09:32.97,0:09:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tambah jago, ya?
Dialogue: 0,0:09:37.60,0:09:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego makan di asrama kita.
Dialogue: 0,0:09:41.35,0:09:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya, makanan biasa pun\Njadi kelihatan mewah, ya.
Dialogue: 0,0:09:45.48,0:09:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, kamu makan\Nmakanan seperti apa?
Dialogue: 0,0:09:48.11,0:09:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan biasa.
Dialogue: 0,0:09:50.53,0:09:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu belum pernah\Nmakan mi gelas.
Dialogue: 0,0:09:53.28,0:09:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, itu agak berle—
Dialogue: 0,0:09:55.91,0:09:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelas?
Dialogue: 0,0:10:01.12,0:10:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu tidak tahu?
Dialogue: 0,0:10:03.29,0:10:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bohong, kan?
Dialogue: 0,0:10:04.33,0:10:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, di sini kami butuh dokter!
Dialogue: 0,0:10:09.13,0:10:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba dimakan!
Dialogue: 0,0:10:10.55,0:10:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelewatan hal nikmat, lo!
Dialogue: 0,0:10:13.88,0:10:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya ramai, ya.
Dialogue: 0,0:10:15.80,0:10:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan menyenangkan.
Dialogue: 0,0:10:17.14,0:10:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, bagaimana tur asrama gurunya,
Dialogue: 0,0:10:21.27,0:10:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iruma?
Dialogue: 0,0:10:23.06,0:10:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua guru tampak berbeda\Ndari biasanya saat di sekolah.
Dialogue: 0,0:10:30.28,0:10:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan beri mereka makan\Nyang aneh-aneh!
Dialogue: 0,0:10:32.65,0:10:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kalego juga mau coba?
Dialogue: 0,0:10:34.86,0:10:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, lo.
Dialogue: 0,0:10:36.16,0:10:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:10:37.78,0:10:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal enak.
Dialogue: 0,0:10:39.66,0:10:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, jangan kasih\Nmakan ke Cerberus.
Dialogue: 0,0:10:46.29,0:10:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku dapat\Nkesempatan yang luar biasa.
Dialogue: 0,0:10:48.71,0:10:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:00.22,0:11:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:11:02.27,0:11:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kekenyangan dan berakhir ketiduran.
Dialogue: 0,0:11:06.23,0:11:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, semuanya ada di mana?
Dialogue: 0,0:11:16.86,0:11:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya kita mengadopsi format pengajaran\Nyang lebih efisien untuk tiap tingkat kelas.
Dialogue: 0,0:11:21.37,0:11:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendala utamanya adalah\Nmemindahkan menara, ya?
Dialogue: 0,0:11:24.37,0:11:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Pak Orias kosong di waktu ini?
Dialogue: 0,0:11:27.63,0:11:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau agak sulit?
Dialogue: 0,0:11:28.79,0:11:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah, kok.
Dialogue: 0,0:11:30.25,0:11:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku punya\Nmateri bagus untuk batra.
Dialogue: 0,0:11:33.13,0:11:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa tidak jadi masalah menambah\Nkegiatan untuk murid kelas 3?
Dialogue: 0,0:11:37.55,0:11:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak murid yang belum bisa terbang.
Dialogue: 0,0:11:39.39,0:11:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin agak berat kalau terlalu jauh.
Dialogue: 0,0:11:42.97,0:11:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan minta izin\Nuntuk memakai area hutan sisi timur.
Dialogue: 0,0:11:46.39,0:11:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga perlu menentukan mentor\Nuntuk para guru baru.
Dialogue: 0,0:11:50.02,0:11:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku!
Dialogue: 0,0:11:50.61,0:11:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kamu tidak bisa.
Dialogue: 0,0:11:52.27,0:11:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk sana.
Dialogue: 0,0:11:53.40,0:11:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sayap para murid baru\Nbakal sering patah, ya.
Dialogue: 0,0:11:57.15,0:11:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Phis di UKS bakal sibuk, ya.
Dialogue: 0,0:12:03.66,0:12:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi.
Dialogue: 0,0:12:05.37,0:12:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?\NAyo pulang.
Dialogue: 0,0:12:08.17,0:12:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:12:10.67,0:12:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para guru bahkan rapat\Ndi saat begini, ya.
Dialogue: 0,0:12:14.63,0:12:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal bilangnya hari ini hari libur.
Dialogue: 0,0:12:19.26,0:12:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:12:20.97,0:12:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka itu guru.
Dialogue: 0,0:12:25.14,0:12:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka melakukannya\Ndemi sekolah dan para murid.
Dialogue: 0,0:12:28.98,0:12:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka iblis yang memilih jalan itu.
Dialogue: 0,0:12:33.27,0:12:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru...
Dialogue: 0,0:12:36.15,0:12:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, ya.
Dialogue: 0,0:12:37.78,0:12:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku bisa menempuh\Njalan itu juga, ya?
Dialogue: 0,0:12:39.78,0:12:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, nanti aku kasihan dengan muridmu.
Dialogue: 0,0:12:42.20,0:12:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:43.56,0:12:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nmasa sekolah Bapak seperti apa?
Dialogue: 0,0:12:47.16,0:12:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu tahu soal itu.
Dialogue: 0,0:12:49.16,0:12:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tanya pada Opera saja.
Dialogue: 0,0:12:51.67,0:12:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini...
Dialogue: 0,0:12:52.88,0:12:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanya itu sesampainya di rumah!
Dialogue: 0,0:12:55.50,0:12:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanya Shichiro juga.
Dialogue: 0,0:12:57.76,0:13:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak, hentikan...
Dialogue: 0,0:13:07.73,0:13:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Anggota Baru Acara Perkumpulan Perempuan?"
Dialogue: 0,0:13:36.75,0:13:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datanglah ke ruang OSIS\Nsekarang juga.
Dialogue: 0,0:13:49.89,0:13:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu sudah datang, ya.
Dialogue: 0,0:13:52.27,0:13:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nafura.
Dialogue: 0,0:13:54.90,0:13:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai permintaanku, kamu berhasil\Nmenyamarkan aromamu, ya.
Dialogue: 0,0:13:58.53,0:13:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:14:00.90,0:14:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ada pertemuan penting,\Naku ingin kamu ikut denganku...
Dialogue: 0,0:14:07.08,0:14:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NLepaskan tudung itu.
Dialogue: 0,0:14:16.46,0:14:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jreng, jreng, jreng!
Dialogue: 0,0:14:18.59,0:14:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Perkumpulan Perempuan!
Dialogue: 0,0:14:21.22,0:14:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggota baru!
Dialogue: 0,0:14:22.93,0:14:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan, namanya Nafura.
Dialogue: 0,0:14:27.85,0:14:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, salah satu anggota kami
Dialogue: 0,0:14:30.23,0:14:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak bisa hadir.
Dialogue: 0,0:14:31.35,0:14:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga murid kelas satu,\Njadi kupikir kalian akan mudah akrab.
Dialogue: 0,0:14:35.52,0:14:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kupanggil Naf?
Dialogue: 0,0:14:37.48,0:14:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ternyata kamu secantik ini!
Dialogue: 0,0:14:41.49,0:14:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyoro! Gyoro! Mau makan permen?\NKamu suka rasa apa?
Dialogue: 0,0:14:47.16,0:14:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terlalu dekat!
Dialogue: 0,0:14:50.99,0:14:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari kita mulai ulang.
Dialogue: 0,0:14:52.62,0:14:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mau datang, ya, Gyoro.
Dialogue: 0,0:14:55.12,0:14:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koprol untuk mulai ulang!
Dialogue: 0,0:14:58.25,0:15:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa topik hari ini\Ncocok denganmu, Naf.
Dialogue: 0,0:15:03.38,0:15:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa topik hari ini?
Dialogue: 0,0:15:06.97,0:15:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sekali!
Dialogue: 0,0:15:08.35,0:15:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fesyen!
Dialogue: 0,0:15:13.93,0:15:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian modis!
Dialogue: 0,0:15:15.98,0:15:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Modis!
Dialogue: 0,0:15:17.73,0:15:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama ingin membicarakannya!
Dialogue: 0,0:15:20.94,0:15:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari bersenang-senang berdandan\Ndan rebut hati seseorang yang istimewa!
Dialogue: 0,0:15:24.82,0:15:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil memperhatikan hal-hal dasar,\Ncoba cari pakaian yang cocok dengan sifat kita!
Dialogue: 0,0:15:29.95,0:15:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Modis...
Dialogue: 0,0:15:31.74,0:15:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, langsung saja kita cek\Npoin-poin fesyen dari gadis iblis!
Dialogue: 0,0:15:37.75,0:15:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, tanduk.
Dialogue: 0,0:15:39.54,0:15:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa tambahkan hiasan,\Nbunga, atau bahkan ukiran!
Dialogue: 0,0:15:43.96,0:15:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya tarik juga termasuk poin penting.
Dialogue: 0,0:15:47.05,0:15:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya tarik beres!
Dialogue: 0,0:15:50.89,0:15:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, pakaian.
Dialogue: 0,0:15:52.51,0:15:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian iblis hadir dalam berbagai ukuran!
Dialogue: 0,0:15:55.23,0:15:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kamu memilih sesuai rasmu.
Dialogue: 0,0:15:59.06,0:16:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, toh.
Dialogue: 0,0:16:00.19,0:16:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai memilih!
Dialogue: 0,0:16:02.32,0:16:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya ekor!
Dialogue: 0,0:16:04.04,0:16:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa pakai ikat ekor atau mengecatnya.
Dialogue: 0,0:16:07.15,0:16:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiaslah semodis mungkin,\Ntapi jangan sampai mengganggu.
Dialogue: 0,0:16:10.70,0:16:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, Ekor!
Dialogue: 0,0:16:15.45,0:16:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah.
Dialogue: 0,0:16:16.83,0:16:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepatu juga penting, lo.
Dialogue: 0,0:16:19.25,0:16:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sepatu terlihat\Nsaat kalian terbang,
Dialogue: 0,0:16:22.42,0:16:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perhatikan juga desain solnya.
Dialogue: 0,0:16:27.17,0:16:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas perhatian kalian.
Dialogue: 0,0:16:33.35,0:16:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buldevi, Devitier...\NMereknya ada banyak macam, ya.
Dialogue: 0,0:16:38.19,0:16:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak harus bermerek,\Ncukup pilih yang kamu suka.
Dialogue: 0,0:16:42.11,0:16:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jubah Ame juga barang bermerek\Ndari Devian, kan?
Dialogue: 0,0:16:46.49,0:16:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik.
Dialogue: 0,0:16:47.69,0:16:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah dari ayahku.
Dialogue: 0,0:16:51.11,0:16:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara tentang jubah,\Npunya Nafura juga unik, lo.
Dialogue: 0,0:16:54.45,0:16:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:16:56.45,0:16:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu alat sihir yang memungkinkan\Npenggunanya mengontrol tinggi badannya.
Dialogue: 0,0:17:01.67,0:17:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu keren, Gyoro!
Dialogue: 0,0:17:04.58,0:17:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap saja, kalau mau berdandan,\Nlebih baik pakai yang imut-imut, kan?
Dialogue: 0,0:17:10.13,0:17:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok banget!
Dialogue: 0,0:17:12.14,0:17:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:17:13.39,0:17:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, karena kamu punya\Nrambut hitam yang cantik,
Dialogue: 0,0:17:16.27,0:17:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurutku hiasan bunga\Nberwarna terang akan cocok untukmu.
Dialogue: 0,0:17:28.65,0:17:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ame juga lebih baik sering\Npakai gaun terusan.
Dialogue: 0,0:17:32.61,0:17:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ga— te—
Dialogue: 0,0:17:34.12,0:17:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu...
Dialogue: 0,0:17:37.16,0:17:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya untuk momen spesial.
Dialogue: 0,0:17:39.96,0:17:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, momen spesial?
Dialogue: 0,0:17:42.25,0:17:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen seperti apa?
Dialogue: 0,0:17:44.58,0:17:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}So-Soal itu...
Dialogue: 0,0:17:50.13,0:17:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana bilangnya...
Dialogue: 0,0:17:53.76,0:17:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dada ini dipenuhi perasaan...
Dialogue: 0,0:17:56.68,0:17:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bergemerlap...
Dialogue: 0,0:17:58.60,0:17:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan selalu...
Dialogue: 0,0:18:00.77,0:18:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak bisa terlupakan.
Dialogue: 0,0:18:06.69,0:18:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya momen spesial\Nya momen spesial!
Dialogue: 0,0:18:11.28,0:18:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, gaun terusan adalah\Nsenjata perang Ame, ya.
Dialogue: 0,0:18:15.07,0:18:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata perang?
Dialogue: 0,0:18:16.99,0:18:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata perang Naf harus\Nsedikit lebih berani seperti ini!
Dialogue: 0,0:18:21.33,0:18:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh terlalu pendek!
Dialogue: 0,0:18:26.59,0:18:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya...
Dialogue: 0,0:18:30.42,0:18:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepi rasanya karena para cewek\Nberpakaian tebal saat musim dingin.
Dialogue: 0,0:18:33.34,0:18:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak mereka pakai rok pendek, ya.
Dialogue: 0,0:18:34.97,0:18:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi.
Dialogue: 0,0:18:36.22,0:18:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang enak pakai rok pendek\Nkalau belum pernah pakai.
Dialogue: 0,0:18:40.60,0:18:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya merepotkan!
Dialogue: 0,0:18:43.10,0:18:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Raja Muda?
Dialogue: 0,0:18:44.69,0:18:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tahu?
Dialogue: 0,0:18:45.85,0:18:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya...
Dialogue: 0,0:18:50.98,0:18:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak perempuanku pakai penghangat perut\Ndan bahkan menambahkan sesuatu agar hangat,
Dialogue: 0,0:18:55.53,0:18:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia tetap kedinginan!
Dialogue: 0,0:18:58.24,0:18:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:59.91,0:19:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia marah dan bilang\Ntidak boleh pakai rok pendek.
Dialogue: 0,0:19:03.04,0:19:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Lied lebih suka cewek\Nyang pakai rok panjang, ya?
Dialogue: 0,0:19:06.75,0:19:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga suka yang pakai rok pendek!
Dialogue: 0,0:19:08.38,0:19:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mulai dengan\Nsesuatu yang lebih sederhana.
Dialogue: 0,0:19:14.13,0:19:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana\Ndengan hiasan sayap?
Dialogue: 0,0:19:16.93,0:19:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, cantiknya.
Dialogue: 0,0:19:18.80,0:19:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba?\NBisa keluarkan sayapmu?
Dialogue: 0,0:19:21.14,0:19:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini?
Dialogue: 0,0:19:25.64,0:19:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik sekali!
Dialogue: 0,0:19:27.40,0:19:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:19:29.31,0:19:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warnanya merah banget, ya.
Dialogue: 0,0:19:31.15,0:19:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar...
Dialogue: 0,0:19:33.03,0:19:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, punyaku besar?
Dialogue: 0,0:19:36.28,0:19:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:37.16,0:19:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan sayapmu?
Dialogue: 0,0:19:39.78,0:19:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayapku...
Dialogue: 0,0:19:43.87,0:19:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Omong-omong soal sayap,\Nmewarnai sayap lagi tren, sih.
Dialogue: 0,0:19:49.04,0:19:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru-baru ini, aku diajari\Nsihir cantik oleh Bu Raim!
Dialogue: 0,0:19:53.30,0:19:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cherko.
Dialogue: 0,0:19:58.47,0:20:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Kamu bisa mengubah\Nwarna rambutmu sesuka hati!
Dialogue: 0,0:20:03.18,0:20:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak berambut hitam!
Dialogue: 0,0:20:06.31,0:20:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, warna terang\Njadi lebih menonjol, kan?
Dialogue: 0,0:20:08.94,0:20:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cherko.
Dialogue: 0,0:20:11.82,0:20:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa yang kamu lakukan?
Dialogue: 0,0:20:16.07,0:20:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makka jadi pirang!
Dialogue: 0,0:20:18.16,0:20:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:20:37.05,0:20:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, perkumpulan perempuan\Njadi makin meriah.
Dialogue: 0,0:20:44.89,0:20:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Kerori menerima laporan itu,
Dialogue: 0,0:20:47.77,0:20:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pun terkejut dengan\Nadanya anggota baru yang tidak dikenal.
Dialogue: 0,0:20:59.45,0:21:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naf, selamat datang\Ndi perkumpulan perempuan.
Dialogue: 0,0:21:02.45,0:21:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru banget, ya.
Dialogue: 0,0:21:04.41,0:21:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikutnya harus lengkap berlima.
Dialogue: 0,0:21:26.35,0:21:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengurus OSIS?
Dialogue: 0,0:21:27.93,0:21:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya ada dia, ya?
Dialogue: 0,0:21:33.44,0:21:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:21:43.95,0:21:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Nafura?
Dialogue: 0,0:21:47.99,0:21:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kalau aku salah.
Dialogue: 0,0:21:50.79,0:21:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, auranya...
Dialogue: 0,0:21:53.67,0:21:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nafura?
Dialogue: 0,0:22:01.34,0:22:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa?
Dialogue: 0,0:22:08.35,0:22:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok denganmu, Nafura.
Dialogue: 0,0:22:09.98,0:22:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar\Nikut acara perkumpulan perempuan lagi.
Dialogue: 0,0:22:13.81,0:22:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, dari perubahan kecil dulu.
Dialogue: 0,0:23:48.53,0:23:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan!
Dialogue: 0,0:23:52.91,0:23:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asrama guru benar-benar luas, ya!
Dialogue: 0,0:23:56.21,0:23:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupandu ke mana pun itu!
Dialogue: 0,0:23:58.50,0:24:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gedung di belakang itu boleh dikunjungi?
Dialogue: 0,0:24:01.42,0:24:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:24:02.46,0:24:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kami diam-diam\Nmenanam "pohon permen".
Dialogue: 0,0:24:08.09,0:24:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, ini juga rahasia, sih.
Dialogue: 0,0:24:10.05,0:24:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, Otonja adalah maneken\Nyang bereaksi terhadap suara!
Dialogue: 0,0:24:13.97,0:24:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:24:14.77,0:24:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kalau kamu menekan tombol\Nlantai 6 lift sebanyak 3 kali...
Dialogue: 0,0:24:20.44,0:24:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asrama ini akan berubah\Njadi robot raksasa!
Dialogue: 0,0:24:23.73,0:24:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh? Hebat! Keren!\N- Jangan percaya semua perkataannya!
Dialogue: 0,0:24:28.24,0:24:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku pengin lihat!\N- Dasar bodoh!
Dialogue: 0,0:24:30.36,0:24:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Selamat Datang\Ndi Sekolah Iblis, Iruma.
Dialogue: 0,0:24:32.74,0:24:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Meniru Tuan adalah Hukum Dunia Iblis"\Ndan "Di Antara Teman Dekat".
Dialogue: 0,0:24:36.12,0:24:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Familiar cenderung menyerupai tuannya.
Dialogue: 0,0:24:38.00,0:24:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan dan kepribadiannya juga persis\Nseperti orang tua dan anak.
Dialogue: 0,0:24:41.94,0:24:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tua dan anak?
Dialogue: 0,0:24:44.04,0:24:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau I-I-Iruma dan aku punya anak,\Nkira-kira akan mirip siapa?
Dialogue: 0,0:24:49.88,0:24:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, pertama, namanya dulu!
Dialogue: 0,0:24:51.55,0:24:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aruma atau Imeri?
Dialogue: 0,0:24:52.76,0:24:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku ini kenapa, sih?
