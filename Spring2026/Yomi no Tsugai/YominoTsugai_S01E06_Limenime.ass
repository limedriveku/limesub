Dialogue: 0,0:23:27.61,0:23:28.98,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:36.67,0:01:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba benda ini.
Dialogue: 0,0:01:47.39,0:01:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, masih belum terbiasa!
Dialogue: 0,0:01:54.15,0:01:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan, di situ ada penyerangan?
Dialogue: 0,0:01:57.36,0:01:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan ada.
Dialogue: 0,0:02:00.45,0:02:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah sejak kapan mereka memasuki wisma.
Dialogue: 0,0:02:03.83,0:02:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana juga ada?
Dialogue: 0,0:02:05.87,0:02:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Iya,\Nkami sedang melawan Tsugai tidak dikenal.{\i0}
Dialogue: 0,0:02:09.83,0:02:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bereskan mereka.
Dialogue: 0,0:02:11.84,0:02:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kakiku sedang cedera.{\i0}
Dialogue: 0,0:02:15.21,0:02:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar payah!
Dialogue: 0,0:02:16.71,0:02:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa ada di situ, kan?\NPokoknya lindungi dia!
Dialogue: 0,0:02:20.14,0:02:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yuru dan Tsugai miliknya\Nikut turun tangan.{\i0}
Dialogue: 0,0:02:22.89,0:02:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang mengalahkanku?
Dialogue: 0,0:02:24.81,0:02:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, bedebah itu! Berarti aman.
Dialogue: 0,0:02:28.64,0:02:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di sini boleh aku sikat, kan?
Dialogue: 0,0:02:31.73,0:02:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Silakan.
Dialogue: 0,0:02:33.90,0:02:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:02:38.90,0:02:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krauk.
Dialogue: 0,0:02:47.25,0:02:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipikir-pikir,
Dialogue: 0,0:02:49.16,0:02:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kasihan juga kalau kamu\Nditinggal sendirian.
Dialogue: 0,0:02:53.88,0:02:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krauk!
Dialogue: 0,0:03:11.48,0:03:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu beruntung, Gabriel,\Nmalam ini banyak camilan.
Dialogue: 0,0:03:16.36,0:03:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Gabuchan aman.
Dialogue: 0,0:03:18.69,0:03:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah! Biar kuhentikan makhluk itu.
Dialogue: 0,0:03:22.53,0:03:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu bisa?\N- Kalau bisa, kita pelukan, ya?
Dialogue: 0,0:03:25.74,0:03:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti tulang rusukku patah, ogah.
Dialogue: 0,0:03:27.49,0:03:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin, maaf kalau wismanya rusak.
Dialogue: 0,0:03:31.25,0:03:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Bos marah, aku siap diomeli.
Dialogue: 0,0:03:34.25,0:03:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin,\Naku juga minta maaf kalau wismanya rusak.
Dialogue: 0,0:03:38.38,0:03:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diomeli saja sana sendiri.
Dialogue: 0,0:03:40.38,0:03:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih kasih banget!
Dialogue: 0,0:03:45.35,0:03:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, bisa tolong pancing yang putih?
Dialogue: 0,0:03:49.14,0:03:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memerintahku! Baiklah!
Dialogue: 0,0:04:09.58,0:04:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa!
Dialogue: 0,0:04:13.00,0:04:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghilang.
Dialogue: 0,0:04:15.42,0:04:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Abang juga? Dia hilangkan ke mana?
Dialogue: 0,0:04:18.96,0:04:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabu--
Dialogue: 0,0:04:24.88,0:04:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau punya kemampuan\Nuntuk menghilangkan orang,
Dialogue: 0,0:04:29.60,0:04:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin saja dia tahu soal orang tua Asa!
Dialogue: 0,0:04:37.81,0:04:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wismanya boleh dirusak,\Ntapi biarkan mereka hidup, Haruo.
Dialogue: 0,0:04:40.82,0:04:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai maupun tuannya.
Dialogue: 0,0:04:43.11,0:04:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:04:45.41,0:04:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruo, kita dikepung banyak Tsugai.
Dialogue: 0,0:04:49.62,0:04:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin, tolong urus mereka!
Dialogue: 0,0:04:52.87,0:04:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku akan menjaga Haruo.
Dialogue: 0,0:04:59.21,0:05:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, Natsuki,\Ndan Fuyuki belum sampai juga.
Dialogue: 0,0:05:04.26,0:05:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana Hagure Sensei?
Dialogue: 0,0:05:05.63,0:05:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang tidur setelah dikejar tenggat,\Nkamu bakal dibunuh kalau membangunkannya.
Dialogue: 0,0:05:14.52,0:05:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada bantuan, ya.
Dialogue: 0,0:05:17.98,0:05:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita berjuang.
Dialogue: 0,0:05:20.69,0:05:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai, Makoto.
Dialogue: 0,0:05:24.61,0:05:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak! Kakak!
Dialogue: 0,0:05:27.74,0:05:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin! Haruo!
Dialogue: 0,0:05:30.99,0:05:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Sakurazawa!
Dialogue: 0,0:05:32.95,0:05:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai, Makoto, Kame, Usa…
Dialogue: 0,0:05:44.46,0:05:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sendirian…
Dialogue: 0,0:05:58.10,0:05:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak sendiri.
Dialogue: 0,0:06:01.19,0:06:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai-nya Kakak?
Dialogue: 0,0:06:02.73,0:06:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku Migi.
Dialogue: 0,0:06:06.65,0:06:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melihat karena gelap.
Dialogue: 0,0:06:08.78,0:06:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama, tapi kita berdekatan.
Dialogue: 0,0:06:13.12,0:06:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelap sekali di sini.
Dialogue: 0,0:06:16.08,0:06:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Desa Higashi tidak segelap ini.
Dialogue: 0,0:06:19.71,0:06:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku saja tidak terlihat.
Dialogue: 0,0:06:23.54,0:06:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencium bau keringat panik,\Nkamu takut gelap?
Dialogue: 0,0:06:34.51,0:06:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci sendirian di tempat gelap.
Dialogue: 0,0:06:39.77,0:06:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya dari sekitar sini.
Dialogue: 0,0:06:43.44,0:06:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut, aku di sini.\NKamu tidak sendirian.
Dialogue: 0,0:06:51.36,0:06:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kakak! Mana Kakak?
Dialogue: 0,0:06:54.58,0:06:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga di ruang ini?
Dialogue: 0,0:06:57.41,0:06:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya tidak di dekat sini.
Dialogue: 0,0:06:59.83,0:07:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Tsugai miliknya, kan?\NKenapa tidak menolongnya?
Dialogue: 0,0:07:04.54,0:07:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Hidari bersamanya,\Nseharusnya aman.
Dialogue: 0,0:07:09.30,0:07:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengikutimu karena\Ningin membahas sesuatu.
Dialogue: 0,0:07:13.47,0:07:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Denganku?
Dialogue: 0,0:07:15.10,0:07:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat pertama bertemu di desa,\Nkamu mendadak menyerangku, kan?{\i0}
Dialogue: 0,0:07:21.39,0:07:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan sejak aku datang kemari,\Nkita tidak bicara sedikit pun.
Dialogue: 0,0:07:27.65,0:07:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu bahwa kita musuh alami, kan?
Dialogue: 0,0:07:35.91,0:07:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kamu merespons…
Dialogue: 0,0:07:38.04,0:07:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, menetralkan?
Dialogue: 0,0:07:41.91,0:07:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mental?
Dialogue: 0,0:07:43.37,0:07:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku bingung menyebutnya…
Dialogue: 0,0:07:47.84,0:07:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menangkal…
Dialogue: 0,0:07:49.38,0:07:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, saat kamu menangkal kekuatan ini\Naku jadi teringat.
Dialogue: 0,0:07:54.18,0:07:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata ayahku,\Nmasing-masing Penjaga Ilahi Sayuu
Dialogue: 0,0:07:57.39,0:08:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}punya kekuatan\Nuntuk mengontrol Kai dan Fuu.
Dialogue: 0,0:08:01.18,0:08:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau sudah tahu.
Dialogue: 0,0:08:05.31,0:08:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah musuh alamimu.
Dialogue: 0,0:08:08.07,0:08:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal, Asa.
Dialogue: 0,0:08:10.94,0:08:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kalau Kakak\Nmendapatkan kekuatan Fuu,
Dialogue: 0,0:08:17.16,0:08:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka juga akan jadi musuh alami.{\i0}
Dialogue: 0,0:08:23.16,0:08:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di sini, Hidari?
Dialogue: 0,0:08:25.50,0:08:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini kosong melompong.
Dialogue: 0,0:08:28.96,0:08:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tempat apa ini?
Dialogue: 0,0:08:31.67,0:08:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, aku baru pertama mengalami ini
Dialogue: 0,0:08:35.09,0:08:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski sudah lama hidup.
Dialogue: 0,0:08:37.97,0:08:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pijakan, tapi warna serbaputih ini\Nmengganggu keseimbanganku.
Dialogue: 0,0:08:43.60,0:08:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalaku terbentur waktu terbang tadi.
Dialogue: 0,0:08:47.31,0:08:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti ada langit-langit.
Dialogue: 0,0:08:49.36,0:08:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku rasa,\Nini kurungan yang Tsugai itu buat.
Dialogue: 0,0:08:55.53,0:08:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kurungan?
Dialogue: 0,0:09:00.54,0:09:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada musuh di sekitar?
Dialogue: 0,0:09:02.62,0:09:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya di sini cuma ada kita.
Dialogue: 0,0:09:06.87,0:09:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, bantu aku berlatih\Npakai panah ini, Hidari.
Dialogue: 0,0:09:10.63,0:09:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang juga?
Dialogue: 0,0:09:12.46,0:09:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa yang terjadi,\Ntapi sayang kalau buang-buang waktu.
Dialogue: 0,0:09:17.09,0:09:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah selalu mengajarkanku
Dialogue: 0,0:09:19.76,0:09:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya siap bertarung kapan pun.
Dialogue: 0,0:09:23.43,0:09:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi tidak masuk akal ini\Ntidak membuatmu takut?
Dialogue: 0,0:09:27.81,0:09:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlalu banyak hal tidak masuk akal
Dialogue: 0,0:09:31.15,0:09:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak desa diserang.
Dialogue: 0,0:09:34.36,0:09:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku jadi terbiasa.
Dialogue: 0,0:09:39.03,0:09:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan.
Dialogue: 0,0:09:45.25,0:09:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdiri di sana dan angkat parangnya\Nbuat aku bidik.
Dialogue: 0,0:09:49.08,0:09:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini?
Dialogue: 0,0:09:50.50,0:09:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:09:59.72,0:10:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghindar, dong!
Dialogue: 0,0:10:01.76,0:10:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku menghindar,\Nnanti repot memungut panahnya.
Dialogue: 0,0:10:05.35,0:10:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih…
Dialogue: 0,0:10:07.10,0:10:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang aku berasal dari batu,\Njangan khawatir.
Dialogue: 0,0:10:13.02,0:10:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:10:14.86,0:10:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok susah, ya?
Dialogue: 0,0:10:17.24,0:10:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak khawatir sama adikmu?
Dialogue: 0,0:10:20.53,0:10:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia?
Dialogue: 0,0:10:21.78,0:10:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ditelan kurungan yang hitam\Nbersamaan dengan kita, lo.
Dialogue: 0,0:10:26.16,0:10:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia punya yang namanya Kai, kan?
Dialogue: 0,0:10:29.92,0:10:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini kurungan, tidak perlu khawatir.
Dialogue: 0,0:10:40.13,0:10:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Kame?
Dialogue: 0,0:10:48.39,0:10:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka keluar!
Dialogue: 0,0:10:50.48,0:10:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ternyata memang kurungan dia.
Dialogue: 0,0:10:54.19,0:10:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa, selamat datang!
Dialogue: 0,0:10:56.44,0:10:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali!
Dialogue: 0,0:10:58.57,0:11:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku akan memutus kontrak tuanmu!
Dialogue: 0,0:11:13.17,0:11:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa!
Dialogue: 0,0:11:15.50,0:11:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bilang tidak steril,\Nternyata kamu membawanya?
Dialogue: 0,0:11:20.22,0:11:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf pakai darah lama.
Dialogue: 0,0:11:27.26,0:11:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya ganti tuan.
Dialogue: 0,0:11:33.98,0:11:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah tuan barumu.
Dialogue: 0,0:11:38.86,0:11:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, manja banget.
Dialogue: 0,0:11:42.91,0:11:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa namamu?
Dialogue: 0,0:11:45.53,0:11:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak baik.
Dialogue: 0,0:11:47.66,0:11:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mohon bantuanmu untuk sementara.
Dialogue: 0,0:11:51.46,0:11:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya permintaan,\Napa kamu menelan kakakku?
Dialogue: 0,0:11:58.38,0:12:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarkan dia! Cepat keluarkan!
Dialogue: 0,0:12:08.18,0:12:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka keluar!
Dialogue: 0,0:12:09.22,0:12:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:12:13.81,0:12:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu! Dia sudah jadi rekan!
Dialogue: 0,0:12:16.15,0:12:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelaskan situasinya!
Dialogue: 0,0:12:18.27,0:12:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai yang mengurung kita\Nsudah jadi baik.
Dialogue: 0,0:12:22.15,0:12:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa melenyapkan dengan instan,
Dialogue: 0,0:12:25.57,0:12:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin saja tuannya tahu\Nkeberadaan orang tuamu!
Dialogue: 0,0:12:31.16,0:12:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat menangkap orang itu.
Dialogue: 0,0:12:34.08,0:12:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, caranya?
Dialogue: 0,0:12:37.79,0:12:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu permintaan lagi.
Dialogue: 0,0:12:40.67,0:12:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu lokasi tuanmu yang lama.
Dialogue: 0,0:12:46.59,0:12:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia disuruh mengkhianati tuan lamanya.
Dialogue: 0,0:12:50.31,0:12:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Remaja zaman sekarang memang ngeri.
Dialogue: 0,0:12:59.44,0:13:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kekuatannya curang!{\i0}
Dialogue: 0,0:13:01.36,0:13:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang banget berkhianat,\Ndasar Tsugai bodoh!
Dialogue: 0,0:13:05.61,0:13:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana? Tidak terlihat saking gelap--
Dialogue: 0,0:13:10.45,0:13:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Migi, tangkap dia!
Dialogue: 0,0:13:12.45,0:13:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siap laksanakan!\N- Sip.
Dialogue: 0,0:13:14.91,0:13:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lagi yang perlu ditangkap?
Dialogue: 0,0:13:16.50,0:13:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bisa melihat jurus andalan Kakak!{\i0}
Dialogue: 0,0:13:19.75,0:13:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Senang banget!{\i0}
Dialogue: 0,0:13:26.47,0:13:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin!
Dialogue: 0,0:13:28.55,0:13:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf bikin gaduh.
Dialogue: 0,0:13:30.47,0:13:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tidak bertempur,\Nharap sembunyi sampai perkara beres.
Dialogue: 0,0:13:37.60,0:13:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:13:42.15,0:13:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayo kemarilah, bakal kusodok dari bawah.{\i0}
Dialogue: 0,0:14:06.34,0:14:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, usaha yang bagus.
Dialogue: 0,0:14:11.85,0:14:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah mereka asing.
Dialogue: 0,0:14:14.64,0:14:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Jin.
Dialogue: 0,0:14:16.81,0:14:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membunuh lima pasang keroco.
Dialogue: 0,0:14:19.48,0:14:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bukan orang Kagemori.
Dialogue: 0,0:14:22.40,0:14:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tampaknya semuanya keroco.\N- Iya.
Dialogue: 0,0:14:31.28,0:14:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi orang asing.
Dialogue: 0,0:14:33.08,0:14:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh! Tsugai-ku dibunuh gigi palsu itu!
Dialogue: 0,0:14:37.25,0:14:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyerah!
Dialogue: 0,0:14:38.83,0:14:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panah ini…
Dialogue: 0,0:14:41.83,0:14:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya si Abang, ya?
Dialogue: 0,0:14:45.30,0:14:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memanah dari mana?
Dialogue: 0,0:15:00.64,0:15:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Wah, ngeri.{\i0}
Dialogue: 0,0:15:02.61,0:15:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau mencoba maju,\Naku pasti keburu kena panah.{\i0}
Dialogue: 0,0:15:08.36,0:15:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lainnya juga sudah kalah.
Dialogue: 0,0:15:11.20,0:15:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur dulu, deh.
Dialogue: 0,0:15:13.49,0:15:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau terluka.
Dialogue: 0,0:15:15.91,0:15:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup yang direkrut dadakan\Nmemang tidak efektif.
Dialogue: 0,0:15:20.37,0:15:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bubar, bubar.
Dialogue: 0,0:15:25.67,0:15:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:15:27.38,0:15:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira pekerjaan ini menguntungkan.
Dialogue: 0,0:15:31.05,0:15:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya cari Tsugai bar--
Dialogue: 0,0:16:11.67,0:16:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin, kerja bagus.
Dialogue: 0,0:16:14.43,0:16:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, hari ini melelahkan.
Dialogue: 0,0:16:18.14,0:16:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf melibatkanmu, Bang.
Dialogue: 0,0:16:21.60,0:16:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambutan kalian luar biasa.
Dialogue: 0,0:16:24.31,0:16:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tertolong.
Dialogue: 0,0:16:26.19,0:16:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak melakukannya demi kalian!
Dialogue: 0,0:16:29.19,0:16:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini demi petunjuk Ayah dan Ibu.
Dialogue: 0,0:16:32.86,0:16:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa, kamu aman?
Dialogue: 0,0:16:38.33,0:16:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bocah Tengik!\N- Bocah Cebol!
Dialogue: 0,0:16:41.41,0:16:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bocah,\Nkayaknya aku lebih tua darimu.
Dialogue: 0,0:16:43.87,0:16:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin!
Dialogue: 0,0:16:44.87,0:16:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hormati aku!
Dialogue: 0,0:16:47.17,0:16:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Meski waktu itu kulepaskan,\Njangan pikir kamu sudah dimaafkan!
Dialogue: 0,0:16:52.59,0:16:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tahan, tahan.
Dialogue: 0,0:16:55.34,0:16:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ditolong Kakak\Ndan Penjaga Ilahi Sayuu.
Dialogue: 0,0:16:58.39,0:17:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku tahu.
Dialogue: 0,0:17:01.72,0:17:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tawanannya banyak juga.
Dialogue: 0,0:17:07.10,0:17:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau diapakan?
Dialogue: 0,0:17:09.27,0:17:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar Bos yang memutuskan\Nkalau dia pulang nanti.
Dialogue: 0,0:17:13.61,0:17:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting,\Nkita peras dulu info dari mereka.
Dialogue: 0,0:17:17.49,0:17:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:17:19.66,0:17:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka cuma menjanjikan uang\Nkalau menangkap si kembar.
Dialogue: 0,0:17:23.08,0:17:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persetan soal identitasnya.
Dialogue: 0,0:17:27.58,0:17:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pakai cara klasik.
Dialogue: 0,0:17:35.72,0:17:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerikilnya sakit banget!
Dialogue: 0,0:17:40.05,0:17:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suruhan organisasi mana?\NOrang dari Kagemori?
Dialogue: 0,0:17:45.85,0:17:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu! Aku bersumpah!
Dialogue: 0,0:17:50.36,0:17:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kayak kerja sambilan!\NKami tidak saling kenal!
Dialogue: 0,0:17:55.94,0:17:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin semuanya cuma\Npengguna Tsugai biasa!
Dialogue: 0,0:17:59.03,0:18:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya ada yang memimpinmu, kan?\NTu-Tulangku hancur!
Dialogue: 0,0:18:03.62,0:18:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang pakai jaket kamuflase!\NYang berewokan!
Dialogue: 0,0:18:11.67,0:18:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin dia terkapar di gerbang depan.{\i0}
Dialogue: 0,0:18:15.38,0:18:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:18:18.59,0:18:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaan selanjutnya.
Dialogue: 0,0:18:20.76,0:18:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu soal pasutri yang kabur\Ndari Desa Higashi?
Dialogue: 0,0:18:25.85,0:18:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka orang tua si kembar yang hilang\Ndalam penerbangan ke Okinawa.
Dialogue: 0,0:18:30.31,0:18:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu soal itu!
Dialogue: 0,0:18:34.44,0:18:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebas, hal sepele juga boleh!
Dialogue: 0,0:18:36.99,0:18:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, tidak tahu!
Dialogue: 0,0:18:39.86,0:18:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu.
Dialogue: 0,0:18:42.07,0:18:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama.
Dialogue: 0,0:18:43.16,0:18:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tahu sesuatu?
Dialogue: 0,0:18:48.46,0:18:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada petunjuk soal Ayah dan Ibu.
Dialogue: 0,0:18:51.96,0:18:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kalau tidak sesuai harapanmu.
Dialogue: 0,0:19:00.59,0:19:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mau tanya lagi?
Dialogue: 0,0:19:03.68,0:19:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau. Boleh aku bertanya?
Dialogue: 0,0:19:07.06,0:19:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujawab semuanya,\Ntapi singkirkan kura-kura ini.
Dialogue: 0,0:19:11.65,0:19:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu nama mereka.
Dialogue: 0,0:19:14.23,0:19:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama?
Dialogue: 0,0:19:16.98,0:19:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dipanggil apa?
Dialogue: 0,0:19:18.82,0:19:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma "hei" atau "kalian".
Dialogue: 0,0:19:21.45,0:19:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasih nama yang benar, dong.
Dialogue: 0,0:19:24.03,0:19:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka seperti hewan ternak,
Dialogue: 0,0:19:26.45,0:19:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus dikasari supaya patuh.
Dialogue: 0,0:19:31.79,0:19:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa dikasih nama?
Dialogue: 0,0:19:44.55,0:19:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan.
Dialogue: 0,0:19:54.56,0:19:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ganti baju dulu.
Dialogue: 0,0:20:00.53,0:20:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, pantas saja kamu dikhianati.
Dialogue: 0,0:20:05.53,0:20:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, Tsugai juga punya perasaan.
Dialogue: 0,0:20:10.79,0:20:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya, kalian juga bilang\Nkalau tahu sesuatu.
Dialogue: 0,0:20:14.00,0:20:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku cuma kerja sambilan.\N- Sama!
Dialogue: 0,0:20:16.17,0:20:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menamai rekanku dengan benar!
Dialogue: 0,0:20:19.67,0:20:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kalian kunamai apa, ya?
Dialogue: 0,0:20:25.18,0:20:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:20:27.01,0:20:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tuan sementara kalian,\Njangan berharap banyak.
Dialogue: 0,0:20:33.52,0:20:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bisakah kalian mengecil?
Dialogue: 0,0:20:38.94,0:20:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu banget!
Dialogue: 0,0:20:42.82,0:20:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang sering diincar pembunuh, kan?
Dialogue: 0,0:20:47.37,0:20:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak turun gunung, selalu begini?
Dialogue: 0,0:20:50.08,0:20:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:20:51.79,0:20:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kali ini agak bahaya\Nkarena musuhnya banyak.
Dialogue: 0,0:20:57.71,0:20:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung ada Kakak.
Dialogue: 0,0:21:00.50,0:21:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:05.09,0:21:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lengah karena\Nselama ini wismanya aman.
Dialogue: 0,0:21:10.06,0:21:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus lebih waspada.
Dialogue: 0,0:21:11.77,0:21:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pantas saja tatapannya jadi garang.{\i0}
Dialogue: 0,0:21:16.23,0:21:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:21:18.56,0:21:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata kirimu terluka?
Dialogue: 0,0:21:28.91,0:21:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bisa dibilang begitu.
Dialogue: 0,0:21:35.33,0:21:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, aku harus jujur pada Kakak.{\i0}
Dialogue: 0,0:21:43.55,0:21:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah mati sekali.
Dialogue: 0,0:21:49.14,0:21:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh pembunuh Desa Higashi.
Dialogue: 0,0:23:28.99,0:23:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Terasa menyusup lewat pori-pori,{\i0}
Dialogue: 0,0:23:32.74,0:23:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menembus kulit, lalu menusuk langsung\Nke daging dan organ dalamku.{\i0}
