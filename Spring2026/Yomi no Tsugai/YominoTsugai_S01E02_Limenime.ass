Dialogue: 0,0:13:22.88,0:13:24.01,tanda,,0000,0000,0000,,{\an8}PINTU MASUK JALUR PENDAKIAN\NDESA HIGASHI LAMA
Dialogue: 0,0:15:39.02,0:15:39.93,tanda,,0000,0000,0000,,KAMI DI PAPAN PINTU MASUK JALUR\NPENDAKIAN DESA HIGASHI LAMA
Dialogue: 0,0:23:27.65,0:23:29.03,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:07.17,0:00:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, tempat apa ini?
Dialogue: 0,0:00:09.00,0:00:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lorong penghubung pusat kastel\Ndan Penjaga Ilahi Sayuu.
Dialogue: 0,0:00:12.13,0:00:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu.
Dialogue: 0,0:00:13.93,0:00:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu sekali, waktu desa ini\Nmasih berupa kastel gunung,
Dialogue: 0,0:00:17.10,0:00:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lorong rahasia ini dibangun\Npenguasa zaman itu.
Dialogue: 0,0:00:19.97,0:00:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sedikit orang yang tahu.
Dialogue: 0,0:00:23.39,0:00:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasiakan dari yang lain, ya.
Dialogue: 0,0:00:25.65,0:00:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan ini saat darurat saja.
Dialogue: 0,0:00:30.48,0:00:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas sana ada patung\NPenjaga Ilahi Sayuu,
Dialogue: 0,0:00:32.94,0:00:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pintu keluar desa.
Dialogue: 0,0:00:37.49,0:00:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah, Yuru.
Dialogue: 0,0:00:38.78,0:00:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu akan selalu\Nmengawasi kalian.
Dialogue: 0,0:00:45.04,0:00:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami selalu mengawasimu, lo, Yuru.
Dialogue: 0,0:00:48.13,0:00:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, kami Tsugai milikmu.
Dialogue: 0,0:00:52.80,0:00:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian, Penjaga Ilahi Sayuu?
Dialogue: 0,0:02:29.10,0:02:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa tuan kita bocah cengeng begini?
Dialogue: 0,0:02:32.36,0:02:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, Migi, jangan membuatnya bingung.
Dialogue: 0,0:02:36.11,0:02:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Penjaga Ilahi Sayuu.
Dialogue: 0,0:02:38.07,0:02:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:02:39.11,0:02:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Dera sang Abdi, ya.
Dialogue: 0,0:02:41.28,0:02:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga mengawasimu, lo.
Dialogue: 0,0:02:43.95,0:02:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting, kami menjatuhkannya\Nkarena tampak membahayakan kalian.
Dialogue: 0,0:02:48.41,0:02:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung macam apa itu?
Dialogue: 0,0:02:50.25,0:02:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kendaraan dataran rendah di zaman ini.
Dialogue: 0,0:02:52.75,0:02:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak ada waktu menjelaskan.
Dialogue: 0,0:02:55.63,0:02:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua orang berbahaya sedang mendekat.
Dialogue: 0,0:02:58.55,0:03:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bantu kami turun gunung.
Dialogue: 0,0:03:01.63,0:03:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera.
Dialogue: 0,0:03:03.14,0:03:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukanlah tuan kami.
Dialogue: 0,0:03:05.43,0:03:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan kami itu Yuru.
Dialogue: 0,0:03:07.77,0:03:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dialah yang kami patuhi.
Dialogue: 0,0:03:09.43,0:03:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, kok!
Dialogue: 0,0:03:10.94,0:03:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tidak sempat diberi penjelasan!
Dialogue: 0,0:03:15.82,0:03:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka terlihat kuat.
Dialogue: 0,0:03:18.19,0:03:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai siapa? Punya Om?
Dialogue: 0,0:03:20.32,0:03:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok ada monster gigi?
Dialogue: 0,0:03:22.16,0:03:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, kan, datang!
Dialogue: 0,0:03:23.95,0:03:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia segar bugar meski kulempar granat!
Dialogue: 0,0:03:27.20,0:03:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai-ku itu tangguh.
Dialogue: 0,0:03:29.45,0:03:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan jangan panggil dia monster.
Dialogue: 0,0:03:32.17,0:03:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, pemuda berusia 16 tahun.\NKamu Yuru, ya?
Dialogue: 0,0:03:36.63,0:03:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, usiaku 17.
Dialogue: 0,0:03:38.88,0:03:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di dataran rendah, usiamu 16.
Dialogue: 0,0:03:41.88,0:03:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok beda?
Dialogue: 0,0:03:42.84,0:03:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi kamu kakaknya Asa.
Dialogue: 0,0:03:47.01,0:03:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa?
Dialogue: 0,0:03:52.27,0:03:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh semua orang kecuali Kakak!
Dialogue: 0,0:03:55.77,0:03:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikutlah denganku.
Dialogue: 0,0:03:59.78,0:04:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian yang membunuh orang-orang desa?
Dialogue: 0,0:04:02.53,0:04:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dong.
Dialogue: 0,0:04:04.74,0:04:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Yuru, kami siap melakukan\Napa pun perintahmu.
Dialogue: 0,0:04:09.95,0:04:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan memerintah.
Dialogue: 0,0:04:13.12,0:04:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian adalah dewa pelindung,
Dialogue: 0,0:04:15.67,0:04:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak pantas diperintah olehku.
Dialogue: 0,0:04:20.05,0:04:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak memerintah,\Naku mau minta dua hal.
Dialogue: 0,0:04:23.88,0:04:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, seharusnya masih ada\Nwarga yang hidup.
Dialogue: 0,0:04:27.80,0:04:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong amankan mereka.
Dialogue: 0,0:04:30.97,0:04:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan yang kedua…
Dialogue: 0,0:04:34.60,0:04:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Cebol itu mangsaku, jangan ikut campur!
Dialogue: 0,0:04:39.27,0:04:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya terserah kalian,\NPenjaga Ilahi Sayuu.
Dialogue: 0,0:04:44.74,0:04:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita beruntung, Hidari.
Dialogue: 0,0:04:46.78,0:04:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan baru kita tidak banyak aturan.
Dialogue: 0,0:04:50.54,0:04:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Siap laksanakan!{\i0}
Dialogue: 0,0:05:02.46,0:05:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek Yamaha.
Dialogue: 0,0:05:04.67,0:05:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak akan pernah memaafkan kalian.
Dialogue: 0,0:05:08.30,0:05:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus terima hukumannya.
Dialogue: 0,0:05:25.74,0:05:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak banyak aturan.
Dialogue: 0,0:05:28.07,0:05:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap laksanakan!
Dialogue: 0,0:05:34.45,0:05:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencari warga desa.
Dialogue: 0,0:05:37.33,0:05:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, bau darahnya cukup banyak.
Dialogue: 0,0:05:44.67,0:05:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:48.05,0:05:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan telah berkata,
Dialogue: 0,0:05:50.72,0:05:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terserah aku mau apa.
Dialogue: 0,0:05:58.94,0:06:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memanah lagi!
Dialogue: 0,0:06:07.95,0:06:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai itu tangguh juga.
Dialogue: 0,0:06:09.99,0:06:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kukejar!
Dialogue: 0,0:06:10.95,0:06:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Astaga!
Dialogue: 0,0:06:12.95,0:06:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok jadi begini?\NKapan turun gunungnya, dong?
Dialogue: 0,0:06:26.46,0:06:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu masih hidup?
Dialogue: 0,0:06:33.39,0:06:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata hidup.
Dialogue: 0,0:06:38.68,0:06:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini darah orang lain, kamu tidak terluka.
Dialogue: 0,0:06:41.69,0:06:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:06:47.11,0:06:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, kamu tidak bisa melihatku, ya?
Dialogue: 0,0:06:53.20,0:06:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan monster, tenang saja.
Dialogue: 0,0:06:56.49,0:06:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan kubawa ke tempat aman.
Dialogue: 0,0:07:01.96,0:07:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah?
Dialogue: 0,0:07:06.42,0:07:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa coba, semuanya pingsan saat melihatku.
Dialogue: 0,0:07:10.76,0:07:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin sakit hati saja.
Dialogue: 0,0:07:13.72,0:07:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kejam ke orang dewasa,
Dialogue: 0,0:07:16.18,0:07:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tidak mengusik anak-anak.
Dialogue: 0,0:07:23.27,0:07:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa melihatku?
Dialogue: 0,0:07:39.91,0:07:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba amat, sih?
Dialogue: 0,0:07:42.54,0:07:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seranganmu bahaya, tahu!
Dialogue: 0,0:07:45.33,0:07:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja kalau mau gelut,\Ntapi tuanku bilang…
Dialogue: 0,0:07:52.34,0:07:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak zaman sekarang ogah mendengar, ya!
Dialogue: 0,0:08:00.85,0:08:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu…
Dialogue: 0,0:08:16.28,0:08:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mustahil! Padahal ini dua lawan satu!{\i0}
Dialogue: 0,0:08:40.89,0:08:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panah kedua!
Dialogue: 0,0:08:44.06,0:08:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa?
Dialogue: 0,0:08:54.24,0:08:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:08:56.24,0:08:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan!
Dialogue: 0,0:08:58.53,0:09:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa, terima kasih.
Dialogue: 0,0:09:00.87,0:09:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak!
Dialogue: 0,0:09:05.37,0:09:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kalian? Jawab!
Dialogue: 0,0:09:07.42,0:09:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Asa adikmu, Kakak.
Dialogue: 0,0:09:10.25,0:09:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong, Asa tidak sebongsor kamu!
Dialogue: 0,0:09:13.13,0:09:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan dataran rendah gizinya tinggi.
Dialogue: 0,0:09:16.68,0:09:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata Asa tidak segarang kamu!
Dialogue: 0,0:09:18.93,0:09:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keadaan membuatku banyak berubah.
Dialogue: 0,0:09:23.43,0:09:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:09:24.73,0:09:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik kakak jangan berantem!
Dialogue: 0,0:09:33.15,0:09:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis ini, bau darahnya sama dengan Yuru.
Dialogue: 0,0:09:37.20,0:09:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bersaudara, kan?
Dialogue: 0,0:09:40.28,0:09:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus siapa Asa yang bekerja\Ndi pusat kastel?
Dialogue: 0,0:09:43.91,0:09:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia palsu.
Dialogue: 0,0:09:48.21,0:09:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}10 tahun lalu, setelah Ayah dan Ibu\Nmembawaku kabur dari desa ini,{\i0}
Dialogue: 0,0:09:54.38,0:09:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Nenek dan warga desa takut\NKakak kabur juga.{\i0}
Dialogue: 0,0:10:01.14,0:10:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, mereka membuat Asa palsu\Nuntuk mengikatmu.{\i0}
Dialogue: 0,0:10:07.18,0:10:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rasa sayang kakak pada adiknya{\i0}
Dialogue: 0,0:10:09.69,0:10:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dimanfaatkan agar kamu\Ntidak meninggalkan desa.{\i0}
Dialogue: 0,0:10:14.86,0:10:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dia adalah Asa bohongan.
Dialogue: 0,0:10:29.62,0:10:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu reuni keluarganya.
Dialogue: 0,0:10:32.96,0:10:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bisakah kamu pergi dulu, Asa?
Dialogue: 0,0:10:36.30,0:10:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera?
Dialogue: 0,0:10:37.72,0:10:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kamulah target mereka.
Dialogue: 0,0:10:40.01,0:10:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kita belum tahu kekuatan penuh\NAsa yang asli.
Dialogue: 0,0:10:43.89,0:10:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tetap di sini,\Ndesanya bakal lebih hancur.
Dialogue: 0,0:10:49.06,0:10:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada warga yang hidup, kan?
Dialogue: 0,0:11:00.28,0:11:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:11:02.49,0:11:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melukai warga desa lagi.
Dialogue: 0,0:11:04.95,0:11:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Cebol juga akan kulepaskan, pergilah!
Dialogue: 0,0:11:10.50,0:11:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baiklah.\N- Asa!
Dialogue: 0,0:11:12.63,0:11:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:11:25.10,0:11:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak menangkapnya?
Dialogue: 0,0:11:27.56,0:11:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membiarkanmu terluka.
Dialogue: 0,0:11:30.27,0:11:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting aku tahu Kakak\Nbaik-baik saja.
Dialogue: 0,0:11:34.40,0:11:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:11:36.44,0:11:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakmu tidak kenal ampun.
Dialogue: 0,0:11:41.57,0:11:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:43.45,0:11:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hebat.
Dialogue: 0,0:11:45.12,0:11:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:46.62,0:11:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hidup, tuh.
Dialogue: 0,0:11:48.29,0:11:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:50.83,0:11:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hidup.
Dialogue: 0,0:11:56.54,0:11:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak masih hidup.
Dialogue: 0,0:12:19.69,0:12:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelindungnya muncul lagi.
Dialogue: 0,0:12:22.19,0:12:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita turun gunung.
Dialogue: 0,0:12:43.17,0:12:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kok helikopter tadi berisik banget, ya?
Dialogue: 0,0:12:46.55,0:12:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada orang tersesat.
Dialogue: 0,0:12:49.64,0:12:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sering ada orang hilang di gunung ini.
Dialogue: 0,0:12:53.18,0:12:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan banyak yang tidak ditemukan lagi.
Dialogue: 0,0:12:56.48,0:12:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu kisah misteri gunung…
Dialogue: 0,0:12:59.73,0:13:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya…
Dialogue: 0,0:13:00.82,0:13:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayoiga!
Dialogue: 0,0:13:01.78,0:13:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, iya.
Dialogue: 0,0:13:03.19,0:13:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah orang kesasar di dunia lain\Nwaktu berjalan di gunung.
Dialogue: 0,0:13:07.66,0:13:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menemukan desa tidak dikenal.
Dialogue: 0,0:13:10.49,0:13:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saat dicari lagi,\Ndesanya hilang bak ditelan bumi.
Dialogue: 0,0:13:14.96,0:13:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:13:18.21,0:13:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:13:19.54,0:13:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka porter gunung?
Dialogue: 0,0:13:21.21,0:13:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau pemburu tradisional?
Dialogue: 0,0:13:24.01,0:13:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anginnya brutal!
Dialogue: 0,0:13:25.22,0:13:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita turun gunung!
Dialogue: 0,0:13:30.47,0:13:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desanya sudah menghilang.
Dialogue: 0,0:13:32.31,0:13:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelindungnya sudah kembali.
Dialogue: 0,0:13:34.64,0:13:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah tidak bisa kembali?
Dialogue: 0,0:13:36.98,0:13:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau kembali, bisa saja.
Dialogue: 0,0:13:40.77,0:13:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi lokasi desa sudah ketahuan\Ndan ada yang bisa merusak pelindungnya.
Dialogue: 0,0:13:44.57,0:13:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamulah yang mereka incar,\Njadi percuma sembunyi di desa.
Dialogue: 0,0:13:48.86,0:13:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah kembali.
Dialogue: 0,0:13:50.49,0:13:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mending membaur ke dataran rendah.
Dialogue: 0,0:13:54.70,0:13:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini.
Dialogue: 0,0:14:05.59,0:14:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf lama, Hana.
Dialogue: 0,0:14:08.26,0:14:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini, Senior?
Dialogue: 0,0:14:10.14,0:14:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kamu bawa manusia,\Ntapi kok ada Tsugai juga?
Dialogue: 0,0:14:15.98,0:14:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa melihat.
Dialogue: 0,0:14:17.10,0:14:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sori, deh.
Dialogue: 0,0:14:19.56,0:14:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujelaskan sambil jalan.
Dialogue: 0,0:14:22.31,0:14:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya kita harus pergi dulu.
Dialogue: 0,0:14:24.86,0:14:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru sedang diincar.
Dialogue: 0,0:14:26.90,0:14:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia si kembar yang digosipkan?
Dialogue: 0,0:14:29.28,0:14:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan mereka Penjaga Ilahi Sayuu…
Dialogue: 0,0:14:32.74,0:14:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:14:34.37,0:14:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besinya besar.
Dialogue: 0,0:14:35.95,0:14:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mereka enggak dengar.
Dialogue: 0,0:14:38.29,0:14:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal, Yuru.
Dialogue: 0,0:14:40.00,0:14:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:14:41.58,0:14:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Hana.
Dialogue: 0,0:14:43.13,0:14:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Senior Dera bekerja sebagai Abdi.
Dialogue: 0,0:14:46.84,0:14:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu,\Nadakah pengguna Tsugai di dekat sini?
Dialogue: 0,0:14:51.18,0:14:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:14:52.80,0:14:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, saatnya pergi ke tempat ramai.
Dialogue: 0,0:14:56.39,0:14:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuklah, Yuru.
Dialogue: 0,0:14:57.64,0:14:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:14:59.31,0:15:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku disuruh masuk ke\Nbenda mencurigakan ini?
Dialogue: 0,0:15:02.77,0:15:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:15:03.90,0:15:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini disebut mobil,\Nkendaraan dataran rendah.
Dialogue: 0,0:15:08.57,0:15:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan terbuat dari besi.
Dialogue: 0,0:15:11.41,0:15:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak ini pengemudinya.
Dialogue: 0,0:15:13.49,0:15:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebutannya, ya…
Dialogue: 0,0:15:17.83,0:15:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kuda di dalam sini,\Njadi larinya kencang!
Dialogue: 0,0:15:22.33,0:15:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:15:23.38,0:15:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:15:24.92,0:15:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:26.88,0:15:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal banget.
Dialogue: 0,0:15:29.92,0:15:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jemputannya lama banget.
Dialogue: 0,0:15:33.09,0:15:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kita masih dalam pelindung?
Dialogue: 0,0:15:36.51,0:15:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya tidak, soalnya ada sinyal.
Dialogue: 0,0:15:39.93,0:15:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun masih di dalam,\Ntinggal aku buka lagi.
Dialogue: 0,0:15:44.98,0:15:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:15:46.94,0:15:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf lama, kelihatannya cukup kacau, ya.
Dialogue: 0,0:15:50.78,0:15:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin, makasih sudah datang.
Dialogue: 0,0:15:53.41,0:15:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf memintamu ke pelosok gunung begini.
Dialogue: 0,0:15:56.45,0:15:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya muncul Tsugai baru.
Dialogue: 0,0:15:59.20,0:16:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu begini, aku ikut dari awal.
Dialogue: 0,0:16:02.58,0:16:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong gelar tandunya.
Dialogue: 0,0:16:04.33,0:16:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan, bagaimana kondisimu?
Dialogue: 0,0:16:06.71,0:16:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak pendarahan.
Dialogue: 0,0:16:08.71,0:16:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong cabut anak panah di bahuku nanti.
Dialogue: 0,0:16:12.17,0:16:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku juga berlubang.
Dialogue: 0,0:16:14.26,0:16:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukamu parah sekali,\Njangan bicara seolah itu luka kecil.
Dialogue: 0,0:16:18.76,0:16:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja, aku terbiasa sama rasa sakit.
Dialogue: 0,0:16:23.77,0:16:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kalau si Abang tidak di sini…
Dialogue: 0,0:16:27.15,0:16:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur.
Dialogue: 0,0:16:28.69,0:16:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dipastikan hidup, kan?
Dialogue: 0,0:16:31.11,0:16:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sehat-sehat saja.
Dialogue: 0,0:16:33.15,0:16:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak berpapasan di jalan?
Dialogue: 0,0:16:35.70,0:16:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua jalan ke gunung ini\Nsudah kami blokir, sih.
Dialogue: 0,0:16:40.16,0:16:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka lewat jalan pintas?
Dialogue: 0,0:16:42.41,0:16:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau masih di sekitar sini?
Dialogue: 0,0:16:44.16,0:16:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai ada helikopter…
Dialogue: 0,0:16:47.29,0:16:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kehilangan dua helikopter\Ndan pasukan.
Dialogue: 0,0:16:50.42,0:16:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos pasti marah.
Dialogue: 0,0:16:52.26,0:16:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat, Jin.
Dialogue: 0,0:16:54.22,0:16:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakaknya Asa kabur sama\Nom-om bernama Dera.
Dialogue: 0,0:16:57.93,0:16:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera?
Dialogue: 0,0:16:59.05,0:17:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia yang menghabisi pasukan kita.
Dialogue: 0,0:17:01.72,0:17:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kagemori, bukankah Dera…
Dialogue: 0,0:17:05.35,0:17:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan Tadera, ya.
Dialogue: 0,0:17:07.73,0:17:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial sekali kita datang\Nwaktu dia ada di sini.
Dialogue: 0,0:17:12.57,0:17:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku memang membawa Tsugai-ku.
Dialogue: 0,0:17:18.03,0:17:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya,\Nkami membebaskan Penjaga Ilahi Sayuu,
Dialogue: 0,0:17:21.66,0:17:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjatuhkan helikopter,\Nmenghajar Tsugai musuh, dan kabur.
Dialogue: 0,0:17:26.04,0:17:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian pasukannya aku kalahkan,\Ntapi masih banyak.
Dialogue: 0,0:17:30.29,0:17:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukannya banyak?\NPasti mereka musuh merepotkan!
Dialogue: 0,0:17:34.51,0:17:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, kayaknya Klan Kagemori.
Dialogue: 0,0:17:37.97,0:17:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kagemori?
Dialogue: 0,0:17:39.01,0:17:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah dan namaku sudah dikenali.
Dialogue: 0,0:17:42.81,0:17:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bercukur dan pindah rumah.
Dialogue: 0,0:17:47.56,0:17:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku cuma pengin hidup damai.
Dialogue: 0,0:17:53.57,0:17:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Tsugai mendekat.
Dialogue: 0,0:17:56.32,0:17:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Serius?\N- Wah, kita dibuntuti?
Dialogue: 0,0:17:59.66,0:18:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat banget?
Dialogue: 0,0:18:02.37,0:18:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:18:05.41,0:18:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak dalam bahaya.
Dialogue: 0,0:18:09.12,0:18:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka teman lama kami.
Dialogue: 0,0:18:18.18,0:18:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa, Sayuu.
Dialogue: 0,0:18:21.01,0:18:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ada di sini,\Nberarti sudah dapat tuan baru, ya?
Dialogue: 0,0:18:25.27,0:18:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, saking lamanya tersegel\Nkami tidak tahu apa-apa.
Dialogue: 0,0:18:29.52,0:18:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 400 tahun.
Dialogue: 0,0:18:31.86,0:18:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan baru kami masih anak-anak.
Dialogue: 0,0:18:34.40,0:18:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bagus, aku suka anak-anak.
Dialogue: 0,0:18:37.99,0:18:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kembar yang memisah siang dan malam.
Dialogue: 0,0:18:43.99,0:18:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti berat, ya.
Dialogue: 0,0:18:47.45,0:18:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rencana kalian?
Dialogue: 0,0:18:49.21,0:18:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, tapi kami mau\Nsembunyi dulu di desa yang ramai.
Dialogue: 0,0:18:54.34,0:18:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:56.21,0:18:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kembali, ceritakan kisah kalian, ya.
Dialogue: 0,0:19:00.59,0:19:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat bertualang.
Dialogue: 0,0:19:05.43,0:19:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kali aku melihatnya!
Dialogue: 0,0:19:09.23,0:19:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benaran ada!
Dialogue: 0,0:19:11.06,0:19:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu apa?
Dialogue: 0,0:19:12.73,0:19:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak sopan!
Dialogue: 0,0:19:14.90,0:19:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Oshirasama!
Dialogue: 0,0:19:16.48,0:19:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu dewa,\Nenggak selevel sama Tsugai biasa!
Dialogue: 0,0:19:20.11,0:19:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Level?
Dialogue: 0,0:19:21.03,0:19:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkatan!
Dialogue: 0,0:19:22.82,0:19:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoki banget bisa melihatnya selagi hidup.
Dialogue: 0,0:19:25.66,0:19:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur masih hidup.
Dialogue: 0,0:19:29.50,0:19:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita juga dianggap dewa\Nkalau di desa.
Dialogue: 0,0:19:33.29,0:19:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlakuannya beda banget.
Dialogue: 0,0:19:36.67,0:19:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Tsugai itu beragam, ya.
Dialogue: 0,0:19:38.80,0:19:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:19:39.97,0:19:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya manusia melabeli mereka\Nsecara sepihak saja, sih.
Dialogue: 0,0:19:43.55,0:19:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melabeli?
Dialogue: 0,0:19:44.80,0:19:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membagi berdasarkan jenisnya.
Dialogue: 0,0:19:48.10,0:19:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang dianggap dewa maupun youkai.
Dialogue: 0,0:19:51.06,0:19:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayak Oshirasama tadi,\Nada yang hidup santai bareng manusia
Dialogue: 0,0:19:55.40,0:19:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sambil bawa hoki ke pemiliknya.
Dialogue: 0,0:19:57.77,0:20:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada juga yang memancing\Ntuannya untuk berbuat jahat.
Dialogue: 0,0:20:01.49,0:20:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin gigi palsu itu tipe petarung.
Dialogue: 0,0:20:05.41,0:20:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka Tsugai rahang atas\Ndan rahang bawah.
Dialogue: 0,0:20:08.49,0:20:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kudengar ada yang memakan\Ntuannya karena tidak suka.
Dialogue: 0,0:20:12.92,0:20:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku yang membiarkan Kakak kabur.
Dialogue: 0,0:20:17.04,0:20:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ikut menghadap Bos.
Dialogue: 0,0:20:19.38,0:20:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa tidak bersalah,\Ndia cuma mau melindungiku.
Dialogue: 0,0:20:23.93,0:20:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah khawatir.
Dialogue: 0,0:20:26.60,0:20:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laporan bahwa dia akan hidup\Ndi dataran rendah
Dialogue: 0,0:20:29.72,0:20:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah cukup buat Bos.
Dialogue: 0,0:20:31.73,0:20:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada Asa, aku pasti tertangkap.
Dialogue: 0,0:20:36.73,0:20:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai-nya sekuat itu?
Dialogue: 0,0:20:39.11,0:20:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuat, sih.
Dialogue: 0,0:20:41.65,0:20:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku begini karena panah kakaknya Asa.
Dialogue: 0,0:20:44.57,0:20:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melumpuhkan kaki dan tangan dominanku.
Dialogue: 0,0:20:48.16,0:20:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ngeri juga si Abang.
Dialogue: 0,0:20:50.41,0:20:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak memang pemburu sejati.
Dialogue: 0,0:21:03.51,0:21:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, hujannya deras.
Dialogue: 0,0:21:07.09,0:21:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak segera ketemu Pak Kagemori,\Nkita bakal ditinggal.
Dialogue: 0,0:21:11.31,0:21:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ber…
Dialogue: 0,0:21:13.85,0:21:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gegas…
Dialogue: 0,0:21:19.31,0:21:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lima kali lewat tempat ini.
Dialogue: 0,0:21:22.19,0:21:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita terjebak.
Dialogue: 0,0:23:29.03,0:23:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah buang hajat, siram.{\i0}
Dialogue: 0,0:23:32.24,0:23:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Prefektur Guntama.{\i0}
Dialogue: 0,0:23:34.53,0:23:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa aku harus menikah sama Senior?{\i0}
