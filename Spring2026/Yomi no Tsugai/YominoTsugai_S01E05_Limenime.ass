Dialogue: 0,0:10:04.85,0:10:06.43,tanda,,0000,0000,0000,,KAGEMORI
Dialogue: 0,0:13:05.36,0:13:06.20,tanda,,0000,0000,0000,,{\an8}RUANG MEDIS
Dialogue: 0,0:23:27.61,0:23:28.98,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:39.97,0:01:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bawa sinyal asap kecil itu, kan?
Dialogue: 0,0:01:44.22,0:01:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda untuk bicara dari jauh,
Dialogue: 0,0:01:46.68,0:01:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tadi kamu memakainya.
Dialogue: 0,0:01:48.85,0:01:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maksudmu ponsel?
Dialogue: 0,0:01:51.56,0:01:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh Asa datang kemari.
Dialogue: 0,0:01:54.90,0:01:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bicara dengannya.
Dialogue: 0,0:02:00.28,0:02:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma bicara?
Dialogue: 0,0:02:02.24,0:02:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukan menginginkannya?
Dialogue: 0,0:02:05.50,0:02:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Higashi tidak tertarik\Nmemiliki kedua kembar?
Dialogue: 0,0:02:09.58,0:02:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persetan tentang mereka,\Nini kehendakku sendiri.
Dialogue: 0,0:02:13.88,0:02:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, datanglah ke wisma Kagemori.
Dialogue: 0,0:02:17.42,0:02:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa juga ingin bertemu denganmu.
Dialogue: 0,0:02:20.51,0:02:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang mau kena jebakan beruang.
Dialogue: 0,0:02:23.64,0:02:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil dia kemari,\Nkalian tidak berhak tawar-menawar.
Dialogue: 0,0:02:28.85,0:02:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:02:30.56,0:02:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku membalut luka Jin.
Dialogue: 0,0:02:33.90,0:02:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa mati.
Dialogue: 0,0:02:35.73,0:02:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma menyayatnya sedikit,\Ntapi ya sudahlah.
Dialogue: 0,0:02:39.53,0:02:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sengaja?
Dialogue: 0,0:02:41.70,0:02:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kamu, eng… Jin, kan?
Dialogue: 0,0:02:45.20,0:02:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak punya niat membunuh.
Dialogue: 0,0:02:47.95,0:02:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang punya…\NSudah kupenggal dari tadi.
Dialogue: 0,0:02:52.58,0:02:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang gunung yang tidak kenal\Ndunia luar ngeri banget!{\i0}
Dialogue: 0,0:02:57.76,0:03:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terlebih,\Ndia bisa saja membunuhku sejak awal.{\i0}
Dialogue: 0,0:03:08.85,0:03:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikan itu milik si Kacamata.
Dialogue: 0,0:03:11.73,0:03:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci dan kura-kura, milik orang itu.
Dialogue: 0,0:03:15.36,0:03:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya ada sepasang lagi.
Dialogue: 0,0:03:18.36,0:03:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Milikmu, kan?
Dialogue: 0,0:03:19.99,0:03:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku juga punya.
Dialogue: 0,0:03:23.78,0:03:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak dipanggil?
Dialogue: 0,0:03:26.08,0:03:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan tipe petarung?
Dialogue: 0,0:03:28.37,0:03:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:03:29.54,0:03:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ada, kok.
Dialogue: 0,0:03:35.71,0:03:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak muat masuk ke sini.
Dialogue: 0,0:03:39.34,0:03:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa aku paksa masuk, sih.
Dialogue: 0,0:03:42.68,0:03:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa tidak akan kupanggil kemari.
Dialogue: 0,0:03:45.47,0:03:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Abang mau ikut ke wisma Kagemori,
Dialogue: 0,0:03:48.47,0:03:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami janji tidak akan macam-macam.
Dialogue: 0,0:03:52.89,0:03:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kamu sadar bahwa aku\Ntidak berniat membunuh, kan?
Dialogue: 0,0:03:59.98,0:04:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci, kura-kura, dan makhluk itu
Dialogue: 0,0:04:03.36,0:04:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakal berat buat Penjaga Ilahi Sayuu.
Dialogue: 0,0:04:09.24,0:04:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan ikut.
Dialogue: 0,0:04:13.00,0:04:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan lancang pada\NPenjaga Ilahi Sayuu!
Dialogue: 0,0:04:17.42,0:04:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:04:19.46,0:04:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan kami sambut sebagai tamu.
Dialogue: 0,0:04:22.72,0:04:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, cepat bawa aku ke Asa.
Dialogue: 0,0:04:26.05,0:04:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:04:27.55,0:04:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini harus dibereskan dulu.
Dialogue: 0,0:04:31.06,0:04:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai, tolong satu pekerjaan lagi.
Dialogue: 0,0:04:37.69,0:04:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Pengais yang bikin berantakan,\Nironis juga.
Dialogue: 0,0:04:41.61,0:04:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penga… Apa?
Dialogue: 0,0:04:43.86,0:04:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengais, tukang bersih-bersih.
Dialogue: 0,0:04:46.74,0:04:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai bisa menelan apa saja.
Dialogue: 0,0:04:49.58,0:04:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Makoto bisa memuntahkannya.
Dialogue: 0,0:04:54.62,0:04:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk jaga-jaga, aku memberinya makan\Nbenda yang mungkin berguna.
Dialogue: 0,0:04:59.92,0:05:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pembersih, dia juga memakan\Norang yang perlu disingkirkan.
Dialogue: 0,0:05:05.51,0:05:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat berguna.
Dialogue: 0,0:05:07.05,0:05:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk penyergapan,\Npembajakan, dan terorisme,
Dialogue: 0,0:05:10.35,0:05:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makoto jaminan lolos pemeriksaan.
Dialogue: 0,0:05:14.10,0:05:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak kata yang asing.
Dialogue: 0,0:05:16.73,0:05:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tahu dia berguna.
Dialogue: 0,0:05:19.69,0:05:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai milikmu…
Dialogue: 0,0:05:21.61,0:05:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya?\N- Berapa kan berat kura-kura itu?
Dialogue: 0,0:05:25.40,0:05:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kan"? Kalau ke kilogram jadi berapa, ya?
Dialogue: 0,0:05:29.91,0:05:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah menimbangnya.
Dialogue: 0,0:05:32.58,0:05:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia masih bisa lebih berat lagi, lo.
Dialogue: 0,0:05:41.42,0:05:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus berlatih lebih keras.
Dialogue: 0,0:05:46.22,0:05:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Mbak disiplin banget!
Dialogue: 0,0:05:56.35,0:05:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, kamu jago berburu kelinci?
Dialogue: 0,0:05:59.73,0:06:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Biasanya pakai jebakan, sih.
Dialogue: 0,0:06:03.02,0:06:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kelinci cocok dibuat kaldu.
Dialogue: 0,0:06:04.82,0:06:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar barbar!
Dialogue: 0,0:06:06.90,0:06:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya Tsugai bisa dimakan?
Dialogue: 0,0:06:10.20,0:06:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang?
Dialogue: 0,0:06:11.82,0:06:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Pak Satpam?
Dialogue: 0,0:06:14.87,0:06:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami terkejut tiba-tiba mati lampu.
Dialogue: 0,0:06:19.46,0:06:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, apa ini?
Dialogue: 0,0:06:21.67,0:06:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lampunya rusak semua.
Dialogue: 0,0:06:24.00,0:06:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin korsleting?\NSoalnya mendadak pecah.
Dialogue: 0,0:06:28.51,0:06:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:06:30.89,0:06:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangga ini lampunya hidup,\Nsilakan keluar lewat sini.
Dialogue: 0,0:06:35.68,0:06:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima kasih.
Dialogue: 0,0:06:54.45,0:06:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan, Gabuchan, Gabuchan!
Dialogue: 0,0:06:57.41,0:06:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada musuh?\N- Gawat!
Dialogue: 0,0:06:59.33,0:07:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin membawa Kakak kemari!
Dialogue: 0,0:07:01.62,0:07:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Serius? Kerjanya cepat juga.
Dialogue: 0,0:07:04.09,0:07:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini? Aku harus pakai apa?
Dialogue: 0,0:07:07.30,0:07:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana kutahu, dasar anak gadis.
Dialogue: 0,0:07:14.22,0:07:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Jin, maaf menghubungi malam-malam.
Dialogue: 0,0:07:18.43,0:07:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perihal kembar Desa Higashi…
Dialogue: 0,0:07:20.69,0:07:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, setelah sepakat dengan Yuru,\Nsekarang kami menuju wisma.
Dialogue: 0,0:07:25.61,0:07:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Guanya panjang sekali.{\i0}
Dialogue: 0,0:07:27.23,0:07:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Kerja bagus!
Dialogue: 0,0:07:30.61,0:07:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tunggu sampai aku pulang?
Dialogue: 0,0:07:33.57,0:07:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bos sedang berada di mana?{\i0}
Dialogue: 0,0:07:37.03,0:07:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen!
Dialogue: 0,0:07:39.62,0:07:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya mau berendam dulu sehabis bekerja.
Dialogue: 0,0:07:43.12,0:07:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang saja, deh!
Dialogue: 0,0:07:45.71,0:07:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersikaplah ramah pada Yuru.
Dialogue: 0,0:08:16.49,0:08:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sampai di kediaman Kagemori.
Dialogue: 0,0:08:39.01,0:08:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Klan Kagemori\Npunya banyak pengguna Tsugai.
Dialogue: 0,0:08:44.02,0:08:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak terasa?
Dialogue: 0,0:08:46.15,0:08:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak, kok.
Dialogue: 0,0:08:48.31,0:08:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi area ini masih untuk umum.
Dialogue: 0,0:08:51.28,0:08:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area?
Dialogue: 0,0:08:52.57,0:08:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawasan.
Dialogue: 0,0:08:54.49,0:08:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana batas pelindungnya.
Dialogue: 0,0:09:16.63,0:09:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:09:17.84,0:09:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:09:19.39,0:09:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali.
Dialogue: 0,0:09:21.35,0:09:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking banyaknya,\Nentah berapa jumlah mereka.
Dialogue: 0,0:09:28.60,0:09:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kakakmu tiba.
Dialogue: 0,0:09:30.57,0:09:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tiba?
Dialogue: 0,0:09:31.73,0:09:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau ikut ke sana?
Dialogue: 0,0:09:33.90,0:09:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah banget ketemu orang\Nyang melubangi tubuhku dua kali.
Dialogue: 0,0:09:37.74,0:09:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan juga masih susah.
Dialogue: 0,0:09:41.62,0:09:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu.
Dialogue: 0,0:09:43.24,0:09:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:09:45.29,0:09:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tidur.
Dialogue: 0,0:09:58.68,0:10:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunannya besar.
Dialogue: 0,0:10:00.39,0:10:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lahannya luas sekali.
Dialogue: 0,0:10:11.48,0:10:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia tertangkap.
Dialogue: 0,0:10:13.90,0:10:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira itu mustahil\Nkarena ada Penjaga Ilahi Sayuu.
Dialogue: 0,0:10:18.36,0:10:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:10:19.99,0:10:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya ayah menjemput putranya.
Dialogue: 0,0:10:22.99,0:10:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pakai mobil?
Dialogue: 0,0:10:24.83,0:10:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, mereka tidak boleh tahu\Nkalau kamu terlibat denganku.
Dialogue: 0,0:10:30.46,0:10:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku naik taksi saja.
Dialogue: 0,0:10:32.84,0:10:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulangnya?
Dialogue: 0,0:10:34.34,0:10:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik kereta.
Dialogue: 0,0:10:36.21,0:10:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan pulang sambil belajar\Ntentang kehidupan.
Dialogue: 0,0:10:47.77,0:10:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu masuknya gede banget!
Dialogue: 0,0:10:49.81,0:10:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip kastel tanah datar.
Dialogue: 0,0:10:52.52,0:10:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja sampai selarut ini.
Dialogue: 0,0:10:55.23,0:10:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu rajin sekali, Jin.
Dialogue: 0,0:10:57.53,0:10:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Asuma.
Dialogue: 0,0:11:00.03,0:11:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu di sini?
Dialogue: 0,0:11:02.57,0:11:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya si kembar datang kemari,\Naku mau menyapanya.
Dialogue: 0,0:11:08.33,0:11:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat pernah memberitahumu.
Dialogue: 0,0:11:11.83,0:11:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendengaranku tajam.
Dialogue: 0,0:11:14.13,0:11:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kamu terluka?
Dialogue: 0,0:11:16.96,0:11:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma luka ringan.
Dialogue: 0,0:11:19.51,0:11:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil bertarung dengan mereka, ya?
Dialogue: 0,0:11:22.39,0:11:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Tsugai yang hebat.
Dialogue: 0,0:11:25.64,0:11:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu kakaknya Asa?
Dialogue: 0,0:11:31.35,0:11:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kagemori Asuma, salam kenal.
Dialogue: 0,0:11:34.56,0:11:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kakak!
Dialogue: 0,0:11:42.32,0:11:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak…
Dialogue: 0,0:11:44.95,0:11:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih hidup, kan?
Dialogue: 0,0:11:46.87,0:11:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam macam apa itu?
Dialogue: 0,0:11:48.33,0:11:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku boleh memelukmu?\N- Enggak!
Dialogue: 0,0:11:51.71,0:11:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku bingung harus apa.
Dialogue: 0,0:11:54.46,0:11:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:11:57.50,0:12:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang buat bertanya padamu,\Nbukan bercengkerama.
Dialogue: 0,0:12:01.67,0:12:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanya saja apa pun!
Dialogue: 0,0:12:03.84,0:12:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah, boleh kupeluk?
Dialogue: 0,0:12:05.85,0:12:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana boleh!
Dialogue: 0,0:12:06.76,0:12:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, sikap cuek Kakak keren banget.
Dialogue: 0,0:12:10.52,0:12:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khawatirkanlah dia daripada diriku.
Dialogue: 0,0:12:14.77,0:12:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin, cepat ke ruang medis!
Dialogue: 0,0:12:16.61,0:12:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Jin terluka,
Dialogue: 0,0:12:19.19,0:12:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar aku saja yang mengantar.
Dialogue: 0,0:12:22.03,0:12:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, Asuma juga di sini?
Dialogue: 0,0:12:24.36,0:12:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, fokusmu cuma ke si Abang, nih.
Dialogue: 0,0:12:27.78,0:12:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru adalah tamuku dan Asa.
Dialogue: 0,0:12:31.29,0:12:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur.
Dialogue: 0,0:12:33.41,0:12:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, deh.
Dialogue: 0,0:12:35.37,0:12:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmati waktumu, Yuru.
Dialogue: 0,0:12:44.01,0:12:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akio, berjagalah di luar pelindung.
Dialogue: 0,0:12:47.01,0:12:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai ada yang masuk.
Dialogue: 0,0:12:48.97,0:12:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:50.47,0:12:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, tetaplah bersamaku selama di wisma.
Dialogue: 0,0:12:54.85,0:12:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut kamu tersesat.
Dialogue: 0,0:13:02.23,0:13:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Wah, ini harus dijahit.
Dialogue: 0,0:13:06.78,0:13:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:13:08.74,0:13:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena parang?
Dialogue: 0,0:13:10.03,0:13:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:11.83,0:13:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira ada apa malam-malam begini.
Dialogue: 0,0:13:15.66,0:13:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya kamu dibacok parang.
Dialogue: 0,0:13:19.17,0:13:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Remaja zaman sekarang menakutkan.
Dialogue: 0,0:13:21.96,0:13:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Remaja biasa tidak akan bawa parang.
Dialogue: 0,0:13:25.63,0:13:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa? Bukannya wajar pria bawa parang?
Dialogue: 0,0:13:29.64,0:13:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:13:31.14,0:13:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Adik kakak barbar!{\i0}
Dialogue: 0,0:13:32.81,0:13:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ini kukembalikan darahnya Asa.
Dialogue: 0,0:13:37.56,0:13:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan suka dibawa-bawa,\Nnanti tidak steril.
Dialogue: 0,0:13:42.02,0:13:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, darahnya!
Dialogue: 0,0:13:43.65,0:13:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengambil darah segar wanita muda,\Njahat sekali!
Dialogue: 0,0:13:46.70,0:13:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku yang memintanya.
Dialogue: 0,0:13:50.87,0:13:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di pengobatan modern, darah bisa diambil\Ntanpa memotong pembuluh darah.
Dialogue: 0,0:13:55.58,0:13:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa? Pakai sihir?
Dialogue: 0,0:13:58.62,0:14:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darahnya diambil langsung di ruangan ini.
Dialogue: 0,0:14:02.67,0:14:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal tancapkan benda ini.
Dialogue: 0,0:14:04.80,0:14:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau penggunanya jago,\Ntidak terasa sakit.
Dialogue: 0,0:14:07.80,0:14:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmu pengobatan? Kok bisa?
Dialogue: 0,0:14:10.47,0:14:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bacok-bacokan dia bisa,\Nambil darah malah tidak tega.{\i0}
Dialogue: 0,0:14:14.68,0:14:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Standar moralnya aneh.{\i0}
Dialogue: 0,0:14:17.39,0:14:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan Kagemori juga memberiku\Nmakan banyak setelahnya.
Dialogue: 0,0:14:20.65,0:14:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diambil darah sedikit bukan masalah.
Dialogue: 0,0:14:26.94,0:14:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak boleh kupeluk?
Dialogue: 0,0:14:28.70,0:14:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak!
Dialogue: 0,0:14:30.70,0:14:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu bongsor banget?
Dialogue: 0,0:14:32.70,0:14:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa seharusnya lebih mungil dan imut.
Dialogue: 0,0:14:35.74,0:14:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau makan makanan sini,\Nkamu juga akan tumbuh besar.
Dialogue: 0,0:14:40.17,0:14:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan dataran rendah keasinan.
Dialogue: 0,0:14:42.88,0:14:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:14:44.38,0:14:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya pekat.
Dialogue: 0,0:14:45.92,0:14:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kepalang terbiasa sama makanan sini.
Dialogue: 0,0:14:49.09,0:14:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasinya enak, sangat enak!
Dialogue: 0,0:14:51.72,0:14:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku bukan mau bahas makanan!
Dialogue: 0,0:14:54.47,0:14:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mau bertanya padaku, kan?\N- Iya!
Dialogue: 0,0:14:57.93,0:15:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau selesai, boleh kupeluk?
Dialogue: 0,0:15:00.02,0:15:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegigihanmu layak dipuji!
Dialogue: 0,0:15:03.19,0:15:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Entah kenapa mereka cocok.{\i0}
Dialogue: 0,0:15:10.40,0:15:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Di mana Ayah dan Ibu?
Dialogue: 0,0:15:14.07,0:15:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Pertemukan kami!\NKalian kabur bersama-sama, kan?
Dialogue: 0,0:15:22.12,0:15:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak ada di sini.
Dialogue: 0,0:15:25.04,0:15:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu di mana?
Dialogue: 0,0:15:27.25,0:15:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hilang.
Dialogue: 0,0:15:29.88,0:15:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang tahu mereka di mana.
Dialogue: 0,0:15:42.90,0:15:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mau cerita sejauh mana?\N- Semuanya.
Dialogue: 0,0:15:46.57,0:15:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau bohong pada Kakak.
Dialogue: 0,0:15:56.70,0:16:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang orang tua kalian lalui\Nsetelah kabur.
Dialogue: 0,0:16:00.91,0:16:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sempat dilindungi Klan Kagemori.
Dialogue: 0,0:16:05.17,0:16:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah situasinya reda,\Nibu kalian berniat pulang kampung.
Dialogue: 0,0:16:11.30,0:16:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, ibu berasal dari dataran rendah.
Dialogue: 0,0:16:15.97,0:16:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin membawaku ke sana.
Dialogue: 0,0:16:18.22,0:16:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibumu orang Okinawa.
Dialogue: 0,0:16:20.93,0:16:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulau Okinawa terletak\Ndi selatan dari sini.
Dialogue: 0,0:16:24.65,0:16:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus naik pesawat\Natau kapal laut untuk ke sana.
Dialogue: 0,0:16:27.31,0:16:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pesawat?{\i0}
Dialogue: 0,0:16:29.44,0:16:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang desa kita menyebutnya "naga".{\i0}
Dialogue: 0,0:16:31.94,0:16:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, itu kendaraan?{\i0}
Dialogue: 0,0:16:34.24,0:16:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Iya, bisa menampung 100 orang.{\i0}
Dialogue: 0,0:16:37.83,0:16:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu dianggap orang hilang\Ndi pegunungan Tohoku kalau di sini.
Dialogue: 0,0:16:43.41,0:16:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mengunjungi orang tua Ibu,
Dialogue: 0,0:16:46.54,0:16:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dititipkan ke Klan Kagemori.
Dialogue: 0,0:16:49.29,0:16:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saat naik pesawat menuju Okinawa,
Dialogue: 0,0:16:54.43,0:16:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka hilang.
Dialogue: 0,0:16:58.26,0:17:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naganya… Mereka jatuh dari pesawatnya?
Dialogue: 0,0:17:01.72,0:17:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak,\Nmereka hilang di tengah penerbangan.
Dialogue: 0,0:17:07.27,0:17:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jelas-jelas sudah naik pesawat dari Tokyo,{\i0}
Dialogue: 0,0:17:10.32,0:17:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi mereka hilang setibanya di Okinawa.{\i0}
Dialogue: 0,0:17:14.78,0:17:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin diculik?
Dialogue: 0,0:17:16.45,0:17:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah.
Dialogue: 0,0:17:17.78,0:17:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak dikawal?
Dialogue: 0,0:17:19.41,0:17:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikawal.
Dialogue: 0,0:17:21.70,0:17:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang pengguna Tsugai telah diutus\NKlan Kagemori untuk mengawal mereka.
Dialogue: 0,0:17:27.46,0:17:29.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia pun ikut hilang.
Dialogue: 0,0:17:30.71,0:17:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawal itu mencurigakan!
Dialogue: 0,0:17:34.09,0:17:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:17:36.63,0:17:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa saja dia pengkhianat.
Dialogue: 0,0:17:40.05,0:17:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia pengikut Desa Higashi
Dialogue: 0,0:17:43.02,0:17:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang pura-pura jadi pengawal.
Dialogue: 0,0:17:47.19,0:17:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah dia musuh atau bukan,\Nini kesalahan kami.
Dialogue: 0,0:17:52.65,0:17:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memercayai mereka\Nyang membiarkan orang tua kita hilang?
Dialogue: 0,0:17:58.20,0:18:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak berhasil kabur, kami diincar\Npara pembunuh yang dikirim desa.
Dialogue: 0,0:18:04.20,0:18:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menolong kami cuma Master, Jin,\Ndan para Klan Kagemori.
Dialogue: 0,0:18:12.92,0:18:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memercayai Klan Kagemori.
Dialogue: 0,0:18:30.85,0:18:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bocah itu memasuki wisma Kagemori.{\i0}
Dialogue: 0,0:18:33.94,0:18:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jin hebat juga.{\i0}
Dialogue: 0,0:18:36.90,0:18:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kembar yang memisah siang dan malam,{\i0}
Dialogue: 0,0:18:39.61,0:18:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}terakhir muncul\N400 tahun lalu di desa Timur.{\i0}
Dialogue: 0,0:18:41.82,0:18:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}400 tahun lalu!{\i0}
Dialogue: 0,0:18:45.91,0:18:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan keduanya berada di dataran rendah.{\i0}
Dialogue: 0,0:18:49.08,0:18:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kaki si gadis\Npengguna rahang sedang cedera.{\i0}
Dialogue: 0,0:18:53.54,0:18:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jin juga.{\i0}
Dialogue: 0,0:18:54.67,0:18:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kepala Klan tidak ada pula.{\i0}
Dialogue: 0,0:18:56.51,0:19:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini kesempatan emas\Nuntuk merebut mereka sekaligus!{\i0}
Dialogue: 0,0:19:01.18,0:19:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalian yakin?\NAnak lelaki dan Tsugai miliknya{\i0}
Dialogue: 0,0:19:05.01,0:19:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}cukup hebat, lo.{\i0}
Dialogue: 0,0:19:06.56,0:19:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau yang perempuan?{\i0}
Dialogue: 0,0:19:10.23,0:19:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini malam hari,\Ndia tidak akan sekuat di siang hari.{\i0}
Dialogue: 0,0:19:13.65,0:19:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang lelaki dibunuh pun boleh.{\i0}
Dialogue: 0,0:19:17.40,0:19:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang perempuan\Nbebas diapakan asal masih hidup.{\i0}
Dialogue: 0,0:19:48.77,0:19:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Masih larut malam, tahu.
Dialogue: 0,0:19:59.78,0:20:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu, nih.
Dialogue: 0,0:20:10.50,0:20:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Jin! Ternyata kamu menjebak kami?
Dialogue: 0,0:20:14.25,0:20:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu bukan Tsugai milik Kagemori.
Dialogue: 0,0:20:17.84,0:20:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang menyusup ke wisma ini.
Dialogue: 0,0:20:21.26,0:20:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai itu boleh kuhajar?
Dialogue: 0,0:20:23.93,0:20:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, tangkap saja tuannya.
Dialogue: 0,0:20:27.43,0:20:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:20:29.47,0:20:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bakal repot mencarinya\Ndi wisma seluas ini.
Dialogue: 0,0:20:34.56,0:20:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau harus, bunuh saja tuan Tsugai itu.
Dialogue: 0,0:20:38.40,0:20:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar tidak usah repot-repot diobati.
Dialogue: 0,0:20:40.82,0:20:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Sakurazawa, itu sudah tugasmu!
Dialogue: 0,0:20:44.07,0:20:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana nasib Tsugai yang tuannya mati?
Dialogue: 0,0:20:46.82,0:20:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan jadi Tsugai liar\Nkalau tidak diwariskan.
Dialogue: 0,0:20:50.58,0:20:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya Tsugai mengutamakan\Nkeselamatan tuannya.
Dialogue: 0,0:20:58.75,0:21:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai liar?
Dialogue: 0,0:21:00.80,0:21:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kontraknya putus,\Nmereka akan terjebak di tempat.
Dialogue: 0,0:21:05.01,0:21:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terlupakan\Ndan tidak dapat tuan baru,
Dialogue: 0,0:21:08.68,0:21:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya mereka akan lenyap\Ndalam beberapa dekade atau abad.
Dialogue: 0,0:21:13.31,0:21:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan juga.
Dialogue: 0,0:21:15.19,0:21:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku putuskan\Ntidak jadi membunuh tuannya.
Dialogue: 0,0:21:18.98,0:21:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya mau?
Dialogue: 0,0:21:20.61,0:21:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak baik banget!
Dialogue: 0,0:21:22.61,0:21:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin, apa dia punya panah?
Dialogue: 0,0:21:24.99,0:21:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makoto.
Dialogue: 0,0:21:29.74,0:21:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Senjatanya asing semua!
Dialogue: 0,0:21:40.59,0:21:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba benda ini.
Dialogue: 0,0:23:28.99,0:23:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ka-Kakak!{\i0}
Dialogue: 0,0:23:30.99,0:23:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami juga boleh pakai cara sendiri, kan?{\i0}
Dialogue: 0,0:23:34.07,0:23:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau Kakak mendapatkan kekuatan Fuu…{\i0}
