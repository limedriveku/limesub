Dialogue: 0,0:04:50.03,0:04:50.87,sign,,0000,0000,0000,,DILARANG MEMANCING! TIDAK BOLEH!
Dialogue: 0,0:14:16.43,0:14:19.60,sign,,0000,0000,0000,,BAR WANITA CINTA DAN KETULUSAN
Dialogue: 0,0:15:06.32,0:15:07.15,sign,,0000,0000,0000,,RAPI DAN TERATUR
Dialogue: 0,0:23:27.57,0:23:28.86,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:33.76,0:01:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:01:35.76,0:01:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang. Kerja bagus.
Dialogue: 0,0:01:39.01,0:01:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lapar.
Dialogue: 0,0:01:42.47,0:01:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru ke mana?
Dialogue: 0,0:01:43.56,0:01:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi mencari tempat sepi\Nbuat menguji panahnya.
Dialogue: 0,0:01:47.52,0:01:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken dan Penjaga Ilahi Sayuu juga ikut.
Dialogue: 0,0:01:49.31,0:01:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Mereka tidak akan pergi jauh\Ndan tertangkap lagi, kan?
Dialogue: 0,0:01:53.53,0:01:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Kotetsu bersama mereka.
Dialogue: 0,0:01:55.53,0:01:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami lagi melacak keberadaanya.
Dialogue: 0,0:01:58.24,0:01:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:01:59.78,0:02:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisi Mbah Dukun?
Dialogue: 0,0:02:01.87,0:02:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gede banget jadi susah membereskannya.
Dialogue: 0,0:02:04.45,0:02:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang membunuhnya? Klan Kagemori?
Dialogue: 0,0:02:07.37,0:02:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, tujuannya pun aku tidak tahu.
Dialogue: 0,0:02:12.75,0:02:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang memintamu menguburnya?
Dialogue: 0,0:02:15.13,0:02:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para bandit.
Dialogue: 0,0:02:16.55,0:02:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang apa?
Dialogue: 0,0:02:17.72,0:02:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:02:18.93,0:02:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat tiba di toko si Dukun,\Ndia sudah terbunuh.
Dialogue: 0,0:02:22.39,0:02:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada kaitannya dengan Yuru.
Dialogue: 0,0:02:24.89,0:02:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, semoga tidak makin merepotkan.
Dialogue: 0,0:02:31.35,0:02:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:02:32.81,0:02:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan hotpot yang disiapkan\Nbuat makan malam kemarin?
Dialogue: 0,0:02:36.28,0:02:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum dimakan?
Dialogue: 0,0:02:37.28,0:02:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, soalnya kami pikir mending\Nmenunggu kamu pulang dulu.
Dialogue: 0,0:02:41.16,0:02:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akhirnya cuma makan makanan sisa.
Dialogue: 0,0:02:43.32,0:02:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal langsung dimakan saja\Ntidak apa-apa.
Dialogue: 0,0:02:46.62,0:02:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru bilang, hotpot harus dimakan\Nramai-ramai layaknya keluarga.
Dialogue: 0,0:02:57.92,0:03:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lagi bicara sendiri, nih.
Dialogue: 0,0:03:01.09,0:03:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tulisan di tubuhnya Mbah Dukun.
Dialogue: 0,0:03:04.97,0:03:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Datanglah ke gudang\NFujimurayama nomor satu
Dialogue: 0,0:03:07.43,0:03:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di purnama selanjutnya\Npada jam babi hutan."
Dialogue: 0,0:03:12.31,0:03:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}"Kami menyandera adik palsumu\Ndan anak dari desa."
Dialogue: 0,0:03:16.11,0:03:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pesan yang ditujukan untuk Yuru.
Dialogue: 0,0:03:18.15,0:03:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku disuruh merahasiakannya darimu\Ndan Yuru oleh para bandit.
Dialogue: 0,0:03:26.12,0:03:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bisa jadi orang\Nyang meninggalkan pesan ini
Dialogue: 0,0:03:28.41,0:03:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}tahu keberadaan orang tua Yuru.
Dialogue: 0,0:03:32.67,0:03:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu?
Dialogue: 0,0:03:34.17,0:03:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Mine dan Nagisa ada di tangannya,
Dialogue: 0,0:03:36.88,0:03:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pasti akan menjadikannya sandera\Nuntuk memancing Yuru.
Dialogue: 0,0:03:40.01,0:03:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya kemungkinan orang tuanya\Nditangkap pelaku kali ini sangat kecil.
Dialogue: 0,0:03:46.55,0:03:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:03:47.56,0:03:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinannya juga tidak nol, kan?
Dialogue: 0,0:03:51.98,0:03:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dibantah juga, sih.
Dialogue: 0,0:03:55.06,0:03:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara sendirinya sudah selesai.
Dialogue: 0,0:03:57.36,0:04:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, aku tidak mau terlibat.
Dialogue: 0,0:04:00.24,0:04:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keputusannya kuserahkan padamu.
Dialogue: 0,0:04:04.99,0:04:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi merepotkan begini.
Dialogue: 0,0:04:08.37,0:04:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:04:10.37,0:04:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Purnama selanjutnya\Npada jam babi hutan itu kapan?
Dialogue: 0,0:04:13.25,0:04:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggal 14 bulan ini, jam 10 malam.
Dialogue: 0,0:04:17.13,0:04:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya tidak mau terlibat.
Dialogue: 0,0:04:19.30,0:04:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Malah sudah riset duluan.{\i0}
Dialogue: 0,0:04:23.80,0:04:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah banget cari tempat\Nbuat mengetes panah, ya.
Dialogue: 0,0:04:27.85,0:04:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:29.72,0:04:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana-mana ada orang.
Dialogue: 0,0:04:33.52,0:04:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut anak panahnya nyasar nanti.
Dialogue: 0,0:04:37.06,0:04:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berlatih di dalam Tsugai-nya Asa lagi?
Dialogue: 0,0:04:40.19,0:04:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:04:45.03,0:04:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Ken! Ikannya gede!
Dialogue: 0,0:04:47.70,0:04:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kita tangkap!\N- Jangan, Yuru!
Dialogue: 0,0:04:50.95,0:04:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, dilarang memancing di sini!
Dialogue: 0,0:04:53.45,0:04:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi,\Nmasih bisa dengan tangan kosong, kan?
Dialogue: 0,0:04:55.87,0:04:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bukan cara mengambilnya!
Dialogue: 0,0:04:58.04,0:05:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mencari bahan\Nuntuk hotpot di rumah Hana.
Dialogue: 0,0:05:01.17,0:05:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya alasan pun tetap tidak boleh!
Dialogue: 0,0:05:04.22,0:05:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia memang barbar, tapi baik!{\i0}
Dialogue: 0,0:05:07.72,0:05:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa orang dataran rendah
Dialogue: 0,0:05:09.72,0:05:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mengambil\Nbahan makanan dari sekitarnya?
Dialogue: 0,0:05:12.89,0:05:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya itu gampang banget ditangkap?
Dialogue: 0,0:05:15.44,0:05:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak boleh menangkap burung\Natau binatang tanpa izin!
Dialogue: 0,0:05:18.65,0:05:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar memang butuh izin berburu, sih.
Dialogue: 0,0:05:21.82,0:05:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu aturan di negara ini.
Dialogue: 0,0:05:24.32,0:05:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dataran rendah tidak ada\Nyang bawa panah apalagi parang.
Dialogue: 0,0:05:28.11,0:05:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mereka melindungi diri\Ndari binatang atau penjahat?
Dialogue: 0,0:05:31.08,0:05:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini ada yang namanya polisi,\Npelindung warga.
Dialogue: 0,0:05:35.66,0:05:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti sudah tahu, tapi di sini
Dialogue: 0,0:05:37.92,0:05:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membunuh orang, ada alasan atau tidak,\Nakan ditangkap dan diadili.
Dialogue: 0,0:05:43.17,0:05:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Eh?{\i0}
Dialogue: 0,0:05:44.34,0:05:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Eh? Jangan bilang…{\i0}
Dialogue: 0,0:05:47.34,0:05:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Padahal sedasar ini…{\i0}
Dialogue: 0,0:05:49.97,0:05:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada yang mengajari Yuru\Naturan dasar dataran rendah?{\i0}
Dialogue: 0,0:05:55.35,0:05:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang berkaitan Desa Higashi\Ntidak ada yang normal.
Dialogue: 0,0:05:59.60,0:06:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Akulah yang harus mendidik Yuru!{\i0}
Dialogue: 0,0:06:02.86,0:06:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, bukannya itu tidak wajar?
Dialogue: 0,0:06:05.15,0:06:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya aku tidak boleh melawan\Norang yang ingin membunuhku?
Dialogue: 0,0:06:09.99,0:06:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu boleh membela diri,\Ntapi kalau berlebihan, bisa dipidana!
Dialogue: 0,0:06:16.62,0:06:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, ada Tsugai di sekitar sini.
Dialogue: 0,0:06:20.04,0:06:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Musuh?\N- Entah.
Dialogue: 0,0:06:21.71,0:06:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena senjataku belum optimal,\Njangan sampai berpapasan.
Dialogue: 0,0:06:26.30,0:06:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo menjauh dari sini.
Dialogue: 0,0:06:28.63,0:06:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:30.30,0:06:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keputusan yang tepat!
Dialogue: 0,0:06:52.70,0:06:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengikuti kita.
Dialogue: 0,0:06:54.70,0:06:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka juga menyadari kita.
Dialogue: 0,0:06:58.75,0:07:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka siapa? Kawan atau lawan?{\i0}
Dialogue: 0,0:07:06.59,0:07:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pindah ke tempat sepi.
Dialogue: 0,0:07:09.97,0:07:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka menyadari kita?\NPadahal akhirnya ketemu.
Dialogue: 0,0:07:14.18,0:07:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan kabur.
Dialogue: 0,0:07:17.27,0:07:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka benar-benar mengincar kita.
Dialogue: 0,0:07:20.81,0:07:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mengincar Yuru?
Dialogue: 0,0:07:24.36,0:07:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:07:29.28,0:07:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hadapi di sini.
Dialogue: 0,0:07:30.86,0:07:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu musuh,\Nlangsung tempur sungguhan saja.
Dialogue: 0,0:07:34.12,0:07:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken,\Naku mungkin tidak sempat melindungimu.
Dialogue: 0,0:07:38.41,0:07:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha…
Dialogue: 0,0:07:40.08,0:07:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Nah.
Dialogue: 0,0:07:41.62,0:07:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Siapa dan dari mana mereka?
Dialogue: 0,0:07:52.43,0:07:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai dan tuannya, ya?
Dialogue: 0,0:07:58.22,0:07:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baju hitam itu…{\i0}
Dialogue: 0,0:08:00.52,0:08:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dari Klan Kagemori?\NTapi tidak ada niat membunuh.{\i0}
Dialogue: 0,0:08:04.19,0:08:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukan.{\i0}
Dialogue: 0,0:08:05.10,0:08:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi bagaimana kalau aku mendadak\Ningin membunuhmu?{\i0}
Dialogue: 0,0:08:11.32,0:08:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa?
Dialogue: 0,0:08:12.90,0:08:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung jawaban,\Nkalian akan terima akibatnya.
Dialogue: 0,0:08:15.11,0:08:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:08:16.45,0:08:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak berniat melukai kalian!
Dialogue: 0,0:08:19.62,0:08:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan kami lepas penyamaran dulu.
Dialogue: 0,0:08:22.54,0:08:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamaran?
Dialogue: 0,0:08:23.62,0:08:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tuan kami dibiarkan sendirian,\Ndia bisa dirundung
Dialogue: 0,0:08:26.92,0:08:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau dibawa ke dinas hewan.
Dialogue: 0,0:08:29.59,0:08:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, biar bisa tetap jadi\Npeliharaan dan tuannya,
Dialogue: 0,0:08:33.72,0:08:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami mencuri…
Dialogue: 0,0:08:35.47,0:08:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya meminjam baju dan wig,\Nterus menyamar jadi manusia.
Dialogue: 0,0:08:45.39,0:08:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah wujud asli kami.
Dialogue: 0,0:08:48.27,0:08:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, bikin takut saja!
Dialogue: 0,0:08:50.94,0:08:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip Tenaga dan Ashinaga.
Dialogue: 0,0:08:53.19,0:08:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih ke alien, sih.
Dialogue: 0,0:08:55.91,0:08:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami Tsugai.
Dialogue: 0,0:08:57.74,0:09:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kita selalu disangka alien, ya?
Dialogue: 0,0:09:01.49,0:09:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sopan sekali mereka,\Npadahal kita Tsugai asli sini.
Dialogue: 0,0:09:05.96,0:09:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, jadi siapa nama kalian?
Dialogue: 0,0:09:10.42,0:09:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ****.
Dialogue: 0,0:09:12.59,0:09:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Bahasa alien?
Dialogue: 0,0:09:14.88,0:09:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian **** ternyata.
Dialogue: 0,0:09:17.01,0:09:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama yang tidak bisa dilafalkan manusia.
Dialogue: 0,0:09:19.85,0:09:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu. Itu alasannya.
Dialogue: 0,0:09:22.64,0:09:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti alien!
Dialogue: 0,0:09:27.73,0:09:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami sudah lama dipuja diam-diam\Ndi daerah Noto,{\i0}
Dialogue: 0,0:09:32.90,0:09:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi lama-kelamaan dilupakan orang-orang.{\i0}
Dialogue: 0,0:09:35.49,0:09:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada lagi yang datang berkunjung.{\i0}
Dialogue: 0,0:09:38.11,0:09:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kupikir kami akan lapuk begitu saja,{\i0}
Dialogue: 0,0:09:42.58,0:09:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lalu tuan kami yang dulunya\Nanjing liar jatuh dari atas.{\i0}
Dialogue: 0,0:09:46.33,0:09:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kontrak pun terjalin begitu saja.{\i0}
Dialogue: 0,0:09:49.38,0:09:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, anjing ini tuan kita?
Dialogue: 0,0:09:52.88,0:09:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:09:54.13,0:09:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kami belum diberi nama,\Njadi cukup merepotkan.
Dialogue: 0,0:09:58.55,0:10:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa juga harus anjing\Nyang jadi tuan kami.
Dialogue: 0,0:10:02.64,0:10:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mau kukenalkan orang yang bisa\Nmembatalkan kontrak kalian?
Dialogue: 0,0:10:07.06,0:10:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:10:08.31,0:10:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tuan yang ini!
Dialogue: 0,0:10:10.35,0:10:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sayang banget sama tuan kalian, ya!
Dialogue: 0,0:10:13.40,0:10:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sepertinya kalian Tsugai yang bisa\Ndiajak bicara dengan tenang.
Dialogue: 0,0:10:18.11,0:10:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami belum menemukan Tsugai\Nyang bisa diajak curhat.
Dialogue: 0,0:10:22.28,0:10:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berkenan,\Nmaukah kalian menjadi teman kami?
Dialogue: 0,0:10:25.37,0:10:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, boleh saja.
Dialogue: 0,0:10:27.25,0:10:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal kalian tidak membahayakan tuanku.
Dialogue: 0,0:10:29.92,0:10:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman Tsugai?
Dialogue: 0,0:10:30.96,0:10:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentu saja!\N- Senangnya!
Dialogue: 0,0:10:33.59,0:10:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa beri tahu nama kalian?
Dialogue: 0,0:10:36.01,0:10:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu.
Dialogue: 0,0:10:38.26,0:10:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih! Bohong?\NPenjaga Ilahi Sayuu dari Desa Higashi?
Dialogue: 0,0:10:41.34,0:10:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kan legenda!
Dialogue: 0,0:10:44.10,0:10:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh minta jabat tangan?
Dialogue: 0,0:10:45.77,0:10:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur lahir ke dunia ini!
Dialogue: 0,0:10:47.48,0:10:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuannya juga keren, ya!
Dialogue: 0,0:10:50.35,0:10:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apaan ini?
Dialogue: 0,0:10:52.98,0:10:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bisa kenakan pakaian dulu?
Dialogue: 0,0:10:55.65,0:10:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terkesan lagi telanjang.
Dialogue: 0,0:10:57.28,0:10:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maafkan kami.
Dialogue: 0,0:11:01.41,0:11:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, Tenaga dan Ashinaga\Nmemakai fundoshi, ya?
Dialogue: 0,0:11:06.29,0:11:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata mereka lumayan beretika juga.
Dialogue: 0,0:11:23.05,0:11:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kabar baik, sepertinya kalian\Nakan dapat teman baru.
Dialogue: 0,0:11:27.81,0:11:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayuu!
Dialogue: 0,0:11:38.82,0:11:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang.
Dialogue: 0,0:11:40.61,0:11:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oshirasama,\Nada apa sampai menyusul kemari?
Dialogue: 0,0:11:44.24,0:11:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi di kampung halamanmu?
Dialogue: 0,0:11:46.95,0:11:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oshirasama? Legenda lagi!
Dialogue: 0,0:11:50.29,0:11:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terlalu mulia sampai bikin mata perih!\N- Danji!
Dialogue: 0,0:11:54.08,0:11:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru… Syukurlah…
Dialogue: 0,0:12:00.67,0:12:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bertemu.
Dialogue: 0,0:12:02.63,0:12:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danji! Hei!
Dialogue: 0,0:12:04.72,0:12:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu ada di sini?
Dialogue: 0,0:12:06.76,0:12:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang menyerang desa lagi!
Dialogue: 0,0:12:10.77,0:12:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi?
Dialogue: 0,0:12:12.94,0:12:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya jadi kacau…
Dialogue: 0,0:12:15.27,0:12:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa maksudnya ini?{\i0}
Dialogue: 0,0:12:16.90,0:12:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku sudah ada di dataran rendah,{\i0}
Dialogue: 0,0:12:19.07,0:12:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}seharusnya tidak perlu lagi\Nmenyerang desa!{\i0}
Dialogue: 0,0:12:21.65,0:12:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mustahil juga Asa membuka\Npenghalang itu lagi.{\i0}
Dialogue: 0,0:12:25.53,0:12:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berarti…{\i0}
Dialogue: 0,0:12:28.78,0:12:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini siapa yang menyerang?\NSama seperti sebelumnya?
Dialogue: 0,0:12:32.29,0:12:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bukan.
Dialogue: 0,0:12:34.50,0:12:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma lihat dari jauh, tapi sepertinya\Ncuma satu pria bersenjata dua pedang
Dialogue: 0,0:12:38.75,0:12:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menyerbu sendirian.
Dialogue: 0,0:12:41.80,0:12:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang dewasa yang terbunuh…
Dialogue: 0,0:12:44.51,0:12:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin desa kita sudah\Ntidak tertolong lagi…
Dialogue: 0,0:12:47.76,0:12:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu menyuruhku turun gunung\Ndan melindungimu.
Dialogue: 0,0:12:52.27,0:12:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu keluar desa,\NOshirasama yang menemukanku…
Dialogue: 0,0:12:56.73,0:12:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disuruh siapa katamu?
Dialogue: 0,0:12:59.90,0:13:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu yang menyuruhku.
Dialogue: 0,0:13:01.65,0:13:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku juga selalu mengkhawatirkanmu!\N- Tunggu!
Dialogue: 0,0:13:04.82,0:13:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:13:06.86,0:13:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kupastikan\Nsebelum mendengar penjelasanmu.
Dialogue: 0,0:13:12.62,0:13:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danji, kamu itu…
Dialogue: 0,0:13:16.50,0:13:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai, kan?
Dialogue: 0,0:13:21.13,0:13:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan manusia.
Dialogue: 0,0:13:31.31,0:13:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:36.81,0:13:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa tahu?
Dialogue: 0,0:13:40.23,0:13:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak punya bayangan di tanah.
Dialogue: 0,0:13:47.11,0:13:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, Kotetsu, Jirou,\Ndan semua Tsugai yang kutemui,
Dialogue: 0,0:13:53.54,0:13:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tidak punya bayangan.
Dialogue: 0,0:13:58.04,0:14:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Semua benda dan manusia di dunia ini\Nmemiliki bayangan,
Dialogue: 0,0:14:02.21,0:14:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya wujud asli Tsugai tidak bisa\Nmembentuk bayangan di dunia ini?
Dialogue: 0,0:14:10.09,0:14:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berarti kamu juga\Ntelah menipuku selama ini.{\i0}
Dialogue: 0,0:14:19.69,0:14:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran, kok!
Dialogue: 0,0:14:21.44,0:14:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku yang paling manis!
Dialogue: 0,0:14:25.19,0:14:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin! Haruo!
Dialogue: 0,0:14:28.36,0:14:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:14:29.91,0:14:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aoi, apa kabar?
Dialogue: 0,0:14:32.12,0:14:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin, terima kasih untuk waktu itu.
Dialogue: 0,0:14:34.70,0:14:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Penguntit itu tidak pernah muncul lagi.
Dialogue: 0,0:14:38.29,0:14:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:14:39.37,0:14:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia sekeras kepala itu,\Nkamu apakan dia?
Dialogue: 0,0:14:42.71,0:14:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dihajar sampai babak belur?
Dialogue: 0,0:14:45.09,0:14:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sampai begitu.
Dialogue: 0,0:14:46.71,0:14:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kujadikan pelet ikan.
Dialogue: 0,0:14:49.38,0:14:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, bercandamu berlebihan.
Dialogue: 0,0:14:52.68,0:14:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Omong-omong…
Dialogue: 0,0:14:53.93,0:14:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Oh, iya.
Dialogue: 0,0:14:55.85,0:14:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Orang yang bernama Tadera itu datang,\Njadi langsung kusuruh masuk saja.
Dialogue: 0,0:15:01.31,0:15:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei, hei.
Dialogue: 0,0:15:03.90,0:15:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini, Jin?
Dialogue: 0,0:15:07.23,0:15:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku dibawa masuk ke sini,\Nbukan ke tempat cewek-cewek?
Dialogue: 0,0:15:12.53,0:15:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada sake gratis untukmu.
Dialogue: 0,0:15:16.16,0:15:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan kopinya.
Dialogue: 0,0:15:19.62,0:15:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak ada sake untuk disuguhkan,\Ntapi aku mau minta maaf.
Dialogue: 0,0:15:23.58,0:15:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin, orang kami membuntutimu, kan?
Dialogue: 0,0:15:26.92,0:15:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, bibi itu dan kupu-kupu.
Dialogue: 0,0:15:30.47,0:15:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan keputusan resmi Klan Kagemori.
Dialogue: 0,0:15:33.14,0:15:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa juga tidak tahu soal ini.
Dialogue: 0,0:15:36.18,0:15:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ulah segelintir orang saja.
Dialogue: 0,0:15:38.68,0:15:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:15:41.19,0:15:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini serius banget, ya.
Dialogue: 0,0:15:44.10,0:15:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang suka melanggar aturan,\Ntapi soal kepercayaan aku tegas.
Dialogue: 0,0:15:49.90,0:15:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku akan percaya padamu.
Dialogue: 0,0:15:53.53,0:15:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kamu datang karena ada info, kan?
Dialogue: 0,0:15:56.70,0:15:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ada masalah merepotkan.
Dialogue: 0,0:16:00.70,0:16:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku.
Dialogue: 0,0:16:05.21,0:16:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayangan, ya?
Dialogue: 0,0:16:06.96,0:16:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku bisa membuat bayangan.
Dialogue: 0,0:16:13.22,0:16:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak kepikiran\Nkarena terlalu ingin bertemu denganmu.
Dialogue: 0,0:16:17.60,0:16:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah main bersama sejak kecil, kan?
Dialogue: 0,0:16:23.39,0:16:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keterlaluan.
Dialogue: 0,0:16:25.44,0:16:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti aku tertipu lebih lama\Ndari Asa di ruang tugas.
Dialogue: 0,0:16:35.57,0:16:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Tsugai,\Nberarti ada pasangannya, kan?
Dialogue: 0,0:16:40.83,0:16:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu betul siapa pasanganku.
Dialogue: 0,0:16:45.92,0:16:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa palsu, ya?
Dialogue: 0,0:16:49.04,0:16:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:50.96,0:16:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Asa palsu, sepasang Tsugai\Nanak laki-laki dan perempuan.
Dialogue: 0,0:16:55.76,0:16:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah wujudku sebenarnya.
Dialogue: 0,0:17:04.85,0:17:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah sepasang Zashiki Warashi.
Dialogue: 0,0:17:12.03,0:17:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, Nenek,
Dialogue: 0,0:17:14.32,0:17:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oshirasama sedang pergi?
Dialogue: 0,0:17:16.74,0:17:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau bilang mau pergi ke Tokyo.
Dialogue: 0,0:17:18.95,0:17:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku juga mau ke Tokyo!
Dialogue: 0,0:17:21.95,0:17:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau juga bawa teman.
Dialogue: 0,0:17:24.33,0:17:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu, mungkin Zashiki Warashi.
Dialogue: 0,0:17:27.67,0:17:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, ya? Dari keluarga mana?
Dialogue: 0,0:17:30.88,0:17:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, padahal dulu ada di mana-mana.
Dialogue: 0,0:17:34.76,0:17:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Zashiki Warashi sampai pergi,\Nkeluarga itu akan runtuh, ya?
Dialogue: 0,0:17:39.89,0:17:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, sih, begitu.
Dialogue: 0,0:17:42.77,0:17:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku bukan keluarga runtuh\Nkarena Zashiki Warashi pergi,
Dialogue: 0,0:17:48.35,0:17:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi keluarga mulai kacau,{\i0}
Dialogue: 0,0:17:50.40,0:17:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}makanya Zashiki Warashi jadi sedih\Ndan tidak betah tinggal.{\i0}
Dialogue: 0,0:17:57.24,0:18:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tuannya juga pasti tidak mau\Nmelihat partnernya sesedih itu.{\i0}
Dialogue: 0,0:18:01.03,0:18:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, entah memutuskan kontrak,{\i0}
Dialogue: 0,0:18:03.37,0:18:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}atau diam-diam pergi bersama\Ntuannya dari rumah itu.{\i0}
Dialogue: 0,0:18:09.08,0:18:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak mau nasib baik-buruk{\i0}
Dialogue: 0,0:18:11.17,0:18:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sebuah keluarga\Nhanya ditimpakan ke Zashiki Warashi saja.{\i0}
Dialogue: 0,0:18:16.47,0:18:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Yuru?
Dialogue: 0,0:18:18.80,0:18:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru sadar dia Tsugai?
Dialogue: 0,0:18:21.18,0:18:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru sadar?
Dialogue: 0,0:18:22.60,0:18:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, kalian selalu memperhatikan dia\Nketika masih di pintu masuk desa, kan?
Dialogue: 0,0:18:27.94,0:18:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tahu bahwa dia Tsugai,\Ntapi tidak bilang padaku?
Dialogue: 0,0:18:31.48,0:18:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kalian juga…
Dialogue: 0,0:18:32.77,0:18:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, soalnya kamu sering main\Nsama Danji dari kecil.
Dialogue: 0,0:18:37.44,0:18:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kamu sudah lama tahu dia Tsugai,\Nmakanya tetap berteman dengannya.
Dialogue: 0,0:18:41.87,0:18:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu kalau sampai sekarang\Nkamu belum sadar wujud asli Danji.
Dialogue: 0,0:18:47.37,0:18:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:18:49.92,0:18:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kalian ada benarnya juga.
Dialogue: 0,0:18:54.88,0:18:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah meragukan kalian.
Dialogue: 0,0:18:57.13,0:18:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:58.76,0:19:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas aku tidak pernah lihat pasanganmu,
Dialogue: 0,0:19:01.34,0:19:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata dikurung di ruangan\Nsemacam penjara kuil.
Dialogue: 0,0:19:04.72,0:19:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang merasakan keberadaannya,\Njadi aku tahu dia ada di dalam desa.
Dialogue: 0,0:19:12.02,0:19:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tuanmu sebenarnya?
Dialogue: 0,0:19:14.69,0:19:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang menggunakan Asa palsu\Nuntuk menahanku di desa,
Dialogue: 0,0:19:17.99,0:19:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menggunakanmu untuk mengawasiku?
Dialogue: 0,0:19:21.32,0:19:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengawasimu? Aku tidak seperti itu.
Dialogue: 0,0:19:26.12,0:19:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga.
Dialogue: 0,0:19:28.08,0:19:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu bersikeras minta ikut\Ntiap kali aku ke gunung.
Dialogue: 0,0:19:33.63,0:19:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kamu berniat membunuhku\Ndi gunung begitu ada celah,
Dialogue: 0,0:19:37.00,0:19:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk merebut kekuatan Fuu?
Dialogue: 0,0:19:39.26,0:19:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:19:40.67,0:19:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kamu juga yang mengirim bandit\Nuntuk menyerangku, kan?
Dialogue: 0,0:19:43.39,0:19:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:19:44.30,0:19:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tuanmu?\NSiapa yang menyuruhmu melakukan ini?
Dialogue: 0,0:19:48.72,0:19:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Nenek Yamaha?
Dialogue: 0,0:19:56.11,0:19:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan…
Dialogue: 0,0:19:58.07,0:20:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku adalah orang yang kupanggil "Ibu".
Dialogue: 0,0:20:07.33,0:20:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kyouka?
Dialogue: 0,0:20:09.58,0:20:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benar, bukan memanggil "Tuan",{\i0}
Dialogue: 0,0:20:12.79,0:20:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi diperintahkan memanggilnya "Ibu",{\i0}
Dialogue: 0,0:20:14.79,0:20:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan disuruh berperilaku seperti\Nibu dan anak manusia.{\i0}
Dialogue: 0,0:20:19.25,0:20:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Perintah untukku adalah menjaga Yuru.{\i0}
Dialogue: 0,0:20:24.09,0:20:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sementara pasanganku, yang dikurung itu,\Ndisuruh berpura-pura jadi Asa.{\i0}
Dialogue: 0,0:20:29.56,0:20:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu kalau ada keadaan darurat,\Nkami disuruh melindungi Nenek Yamaha.{\i0}
Dialogue: 0,0:20:35.44,0:20:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bersikeras minta diajak ke gunung{\i0}
Dialogue: 0,0:20:38.27,0:20:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}supaya Yuru tidak dibunuh bandit.{\i0}
Dialogue: 0,0:20:42.78,0:20:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin kamu tidak akan percaya,\Ntapi itulah kenyataannya.{\i0}
Dialogue: 0,0:20:49.45,0:20:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi Kyouka juga menipuku?{\i0}
Dialogue: 0,0:20:53.50,0:20:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sudah tidak ada lagi…\Norang desa yang bisa kupercaya.
Dialogue: 0,0:21:14.89,0:21:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, Ken, tunggu di sini.
Dialogue: 0,0:21:19.36,0:21:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau sendirian sebentar\Ndi dalam gunung.
Dialogue: 0,0:21:22.82,0:21:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau musuh menyerang bagaimana?
Dialogue: 0,0:21:25.70,0:21:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Migi, biarkan aku sendiri sebentar.
Dialogue: 0,0:21:31.12,0:21:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu permintaan tuanku,\Ntidak ada pilihan lain.
Dialogue: 0,0:21:34.04,0:21:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupatuhi, tapi tolong tetap\Ndi jangkauan pandangan kami.
Dialogue: 0,0:23:28.94,0:23:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena di dalam gunung,\Nmaut selalu mengintai,{\i0}
Dialogue: 0,0:23:32.49,0:23:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}entah bandit, binatang buas,\Natau medan yang terjal,{\i0}
Dialogue: 0,0:23:35.70,0:23:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}semua tindakan bermuara pada satu hal,\Nyaitu bertahan hidup.{\i0}
