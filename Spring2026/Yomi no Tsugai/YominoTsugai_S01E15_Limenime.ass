Dialogue: 0,0:08:41.52,0:08:42.68,sign,,0000,0000,0000,,{\an8}MATANYA DIEDIT
Dialogue: 0,0:11:27.18,0:11:27.89,sign,,0000,0000,0000,,STUDIO HAGURE
Dialogue: 0,0:23:27.57,0:23:28.94,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:41.85,0:01:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danji, kamu itu…
Dialogue: 0,0:01:45.06,0:01:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai, kan?
Dialogue: 0,0:01:47.19,0:01:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan manusia.
Dialogue: 0,0:01:49.48,0:01:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berarti kamu juga\Ntelah menipuku selama ini.{\i0}
Dialogue: 0,0:01:54.23,0:01:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Inilah wujudku sebenarnya.{\i0}
Dialogue: 0,0:02:01.53,0:02:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah sepasang Zashiki Warashi.
Dialogue: 0,0:02:05.75,0:02:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Kyouka juga menipuku?
Dialogue: 0,0:02:10.13,0:02:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sudah tidak ada lagi orang desa
Dialogue: 0,0:02:13.75,0:02:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}yang bisa kupercaya.
Dialogue: 0,0:02:28.23,0:02:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:32.40,0:02:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengganggu!\NAku sedang banyak pikiran, tahu!
Dialogue: 0,0:02:38.61,0:02:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:02:44.66,0:02:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu banyak orang dan hal\Ndi dataran rendah.
Dialogue: 0,0:02:48.04,0:02:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sulit buat menyendiri.
Dialogue: 0,0:02:51.29,0:02:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal di desa, cukup pergi ke gunung\Nkalau mau sendirian.
Dialogue: 0,0:02:55.59,0:02:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa berpikir sendirian\Ntanpa gangguan.
Dialogue: 0,0:03:00.43,0:03:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bandit, hewan buas, dan medan terjal.{\i0}
Dialogue: 0,0:03:03.97,0:03:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gunung selalu dipenuhi hal mematikan.{\i0}
Dialogue: 0,0:03:07.31,0:03:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kondisi itu memaksaku\Nfokus bertahan hidup.{\i0}
Dialogue: 0,0:03:11.94,0:03:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mencari cara apa pun untuk selamat.{\i0}
Dialogue: 0,0:03:15.77,0:03:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan begitu, semua hal rumit di kepala\Nakan berubah jadi jawaban sederhana.{\i0}
Dialogue: 0,0:03:21.95,0:03:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Makanya aku suka ke gunung.{\i0}
Dialogue: 0,0:03:24.28,0:03:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi orang itu…\NDanji selalu merengek minta ikut.
Dialogue: 0,0:03:29.95,0:03:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, "Bagaimana kalau\Nada apa-apa di gunung?"
Dialogue: 0,0:03:36.75,0:03:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan sekali.
Dialogue: 0,0:04:10.20,0:04:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu
Dialogue: 0,0:04:14.21,0:04:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pergi meninggalkan aku dan Asa.
Dialogue: 0,0:04:18.96,0:04:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu
Dialogue: 0,0:04:22.97,0:04:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghilang.
Dialogue: 0,0:04:28.60,0:04:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:04:31.64,0:04:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu bersamamu.
Dialogue: 0,0:04:39.73,0:04:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:04:44.03,0:04:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi teringat hal tidak penting\Ngara-gara kamu.
Dialogue: 0,0:04:51.91,0:04:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya dia bilang ingin sendiri?
Dialogue: 0,0:04:54.58,0:04:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anjing itu hewan, jadi tidak dihitung.
Dialogue: 0,0:05:06.84,0:05:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku tahu alasan kalian\Nmenyayangi tuan yang itu.
Dialogue: 0,0:05:13.68,0:05:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tsugai maupun manusia…{\i0}
Dialogue: 0,0:05:16.31,0:05:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sok akrab banget!
Dialogue: 0,0:05:18.56,0:05:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}…tidak bisa hidup sendirian.
Dialogue: 0,0:05:25.11,0:05:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Mana Danji?
Dialogue: 0,0:05:26.95,0:05:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia baru saja pergi.
Dialogue: 0,0:05:28.87,0:05:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Tuan.
Dialogue: 0,0:05:30.78,0:05:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia ada urusan.
Dialogue: 0,0:05:32.45,0:05:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusan?
Dialogue: 0,0:05:33.95,0:05:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya pasangannya ada\Ndi dataran rendah.
Dialogue: 0,0:05:37.25,0:05:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, Asa palsu?
Dialogue: 0,0:05:39.21,0:05:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia turun gunung juga?
Dialogue: 0,0:05:41.25,0:05:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danji mau mencarinya.
Dialogue: 0,0:05:43.21,0:05:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencarinya sendirian?
Dialogue: 0,0:05:45.97,0:05:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikatan antara sepasang Tsugai itu kuat,\Ntenang saja.
Dialogue: 0,0:05:49.76,0:05:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terpisah jauh,\Nmereka bisa merasakan satu sama lain.
Dialogue: 0,0:05:54.10,0:05:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dih, malah pergi seenaknya.
Dialogue: 0,0:05:56.85,0:05:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal banyak yang ingin kutanyakan.
Dialogue: 0,0:05:59.56,0:06:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak mau banyak alasan,
Dialogue: 0,0:06:01.40,0:06:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia cuma memintaku\Nmenyampaikan maaf padamu.
Dialogue: 0,0:06:09.78,0:06:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mulai gelap, kami izin pamit dulu.
Dialogue: 0,0:06:14.20,0:06:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, sampai jumpa.
Dialogue: 0,0:06:16.16,0:06:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami selalu ada di sekitar sini.
Dialogue: 0,0:06:18.66,0:06:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkunjunglah kapan saja.
Dialogue: 0,0:06:20.88,0:06:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:06:25.42,0:06:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai yang bisa diajak kompromi\Nmemang luar biasa.
Dialogue: 0,0:06:33.47,0:06:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danji.
Dialogue: 0,0:06:37.10,0:06:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan membantu mencari pasanganmu.
Dialogue: 0,0:06:40.14,0:06:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, tidak perlu repot-repot…
Dialogue: 0,0:06:42.94,0:06:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:44.27,0:06:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan kami lebih tahu daerah ini,
Dialogue: 0,0:06:47.19,0:06:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencarinya bersama akan lebih efektif.
Dialogue: 0,0:06:51.11,0:06:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu…
Dialogue: 0,0:06:52.62,0:06:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami senang bisa berteman\Ndengan legenda lainnya.
Dialogue: 0,0:06:55.83,0:06:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zashiki Warashi sangatlah terkenal.
Dialogue: 0,0:07:01.62,0:07:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke mana dulu?
Dialogue: 0,0:07:03.04,0:07:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami antar.
Dialogue: 0,0:07:06.75,0:07:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kok malah menangis?
Dialogue: 0,0:07:09.05,0:07:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa alasannya tapi maafkan kami!
Dialogue: 0,0:07:11.30,0:07:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:07:18.56,0:07:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan, nih?
Dialogue: 0,0:07:20.02,0:07:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa begini?
Dialogue: 0,0:07:22.23,0:07:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, selamat datang.
Dialogue: 0,0:07:24.11,0:07:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, berewokmu dicukur?
Dialogue: 0,0:07:27.15,0:07:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oshirasama, bagaimana kamu bisa kemari?
Dialogue: 0,0:07:30.36,0:07:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat jalan tol.
Dialogue: 0,0:07:31.74,0:07:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudku.
Dialogue: 0,0:07:33.57,0:07:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kuda seharusnya tidak boleh\Nlewat jalan tol.
Dialogue: 0,0:07:38.29,0:07:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, aku melanggar aturan lalu lintas?
Dialogue: 0,0:07:41.83,0:07:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, kalian makan hotpot tanpa aku!
Dialogue: 0,0:07:45.92,0:07:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih makanannya.
Dialogue: 0,0:07:47.09,0:07:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yuru! Katanya mau makan bareng?
Dialogue: 0,0:07:50.63,0:07:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, kata Hana…
Dialogue: 0,0:07:53.09,0:07:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi bisa genting kapan saja,\Nsebaiknya makanlah selagi bisa.
Dialogue: 0,0:07:58.26,0:08:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut keburu basi juga.
Dialogue: 0,0:08:00.02,0:08:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih makanannya.
Dialogue: 0,0:08:01.89,0:08:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu masuk akal.
Dialogue: 0,0:08:04.48,0:08:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju banget.
Dialogue: 0,0:08:06.73,0:08:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah sendiri tidak kumakan selagi bisa.
Dialogue: 0,0:08:09.15,0:08:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak makan di luar?
Dialogue: 0,0:08:11.69,0:08:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku niatnya mau makan di barnya Jin,
Dialogue: 0,0:08:14.41,0:08:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tahunya cuma dikasih kopi kaleng.
Dialogue: 0,0:08:17.03,0:08:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, dari Jin.
Dialogue: 0,0:08:18.99,0:08:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titipan untukmu.
Dialogue: 0,0:08:25.75,0:08:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gambar Ayah dan Ibu!
Dialogue: 0,0:08:28.96,0:08:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa menjanjikannya waktu\Ndi wisma Kagemori.
Dialogue: 0,0:08:32.09,0:08:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia masih ingat.
Dialogue: 0,0:08:37.76,0:08:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam-diam dia menyelundupkan\Ngambarnya sendiri.
Dialogue: 0,0:08:42.68,0:08:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Menjengkelkan.
Dialogue: 0,0:08:44.60,0:08:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bertemu Jin di bar Kagemori?
Dialogue: 0,0:08:46.94,0:08:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tapi Asa tidak ada.
Dialogue: 0,0:08:50.48,0:08:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti,
Dialogue: 0,0:08:52.03,0:08:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada kabar baru soal Ayah dan Ibu?
Dialogue: 0,0:08:58.74,0:09:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku benci anak jeli sepertimu.{\i0}
Dialogue: 0,0:09:03.96,0:09:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:09:05.25,0:09:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Asa palsu itu Zashiki Warashi,
Dialogue: 0,0:09:08.50,0:09:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia disandera bersama anak desa, ya.
Dialogue: 0,0:09:12.00,0:09:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa anak desa yang diculik?
Dialogue: 0,0:09:14.26,0:09:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah.
Dialogue: 0,0:09:15.26,0:09:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berapa orang yang diculik?\N- Entah.
Dialogue: 0,0:09:20.22,0:09:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ditunggu, ya.
Dialogue: 0,0:09:21.89,0:09:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Licik sekali pakai sandera segala.
Dialogue: 0,0:09:25.43,0:09:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak mungkin asal menghampiri, kan?
Dialogue: 0,0:09:28.98,0:09:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:30.11,0:09:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bisa menangkap Asa palsu,\Npasti musuh kita pengguna Tsugai.
Dialogue: 0,0:09:35.61,0:09:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan merepotkan.
Dialogue: 0,0:09:37.70,0:09:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan para bandit maju duluan saja.
Dialogue: 0,0:09:40.20,0:09:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mereka memang tampak ingin bertarung, sih.
Dialogue: 0,0:09:42.87,0:09:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dasar orang-orang emosian.
Dialogue: 0,0:09:46.50,0:09:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi musuh dan para bandit bertarung,\Nkita bisa menolong anak dari desa.
Dialogue: 0,0:09:52.00,0:09:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian, Asa palsu juga.
Dialogue: 0,0:09:57.26,0:09:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada Asa palsu, pasti Danji muncul.
Dialogue: 0,0:10:01.05,0:10:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan kutanyai\Nhabis-habisan soal desa!
Dialogue: 0,0:10:04.89,0:10:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja soal Ayah dan Ibu juga.
Dialogue: 0,0:10:07.60,0:10:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cengar-cengir, Penjaga Ilahi Sayuu!
Dialogue: 0,0:10:14.48,0:10:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan besar,\Nmusuh kita pengguna Tsugai, kan?
Dialogue: 0,0:10:17.45,0:10:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kehadiran Penjaga Ilahi Sayuu\Nbisa dideteksi.
Dialogue: 0,0:10:21.53,0:10:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh akan mengira\Naku bersama mereka, kan?
Dialogue: 0,0:10:25.95,0:10:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Penjaga Ilahi Sayuu\Nharus ada di gudang tempat janjiannya.
Dialogue: 0,0:10:31.38,0:10:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita di mana?
Dialogue: 0,0:10:32.63,0:10:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tempat anak panahku bisa menjangkau.
Dialogue: 0,0:10:34.75,0:10:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti di gedung seberang sini.
Dialogue: 0,0:10:37.59,0:10:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di sini bagaimana?
Dialogue: 0,0:10:39.30,0:10:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tinggi dari yang ini.
Dialogue: 0,0:10:41.72,0:10:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lokasi paling ideal.\N- Hana, mereka…
Dialogue: 0,0:10:44.31,0:10:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tutup telingamu\Nkalau tidak mau kena masalah.
Dialogue: 0,0:10:49.52,0:10:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak khawatir kalau Yuru jauh.
Dialogue: 0,0:10:52.52,0:10:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin?
Dialogue: 0,0:10:54.73,0:10:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan langsung kabur kalau ada bahaya.
Dialogue: 0,0:10:57.99,0:10:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku kalau itu terjadi, ya.
Dialogue: 0,0:10:59.95,0:11:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu.
Dialogue: 0,0:11:05.20,0:11:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kangen Kakak.
Dialogue: 0,0:11:08.79,0:11:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kangen Kakak.
Dialogue: 0,0:11:11.42,0:11:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi Asa bilang begitu terus.
Dialogue: 0,0:11:15.17,0:11:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku kangen Kakak.\N- Konyol banget.
Dialogue: 0,0:11:18.55,0:11:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama dia tetap menggambar,\Nmasih aman, sih.
Dialogue: 0,0:11:22.05,0:11:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak aman! Gambarnya Yuru semua!
Dialogue: 0,0:11:27.89,0:11:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat dulu, yuk.
Dialogue: 0,0:11:29.56,0:11:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:33.81,0:11:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tachikawa, mau teh juga?
Dialogue: 0,0:11:39.19,0:11:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hagure Sensei, kok kamu\Nbisa bikin cerita sebagus ini?
Dialogue: 0,0:11:43.07,0:11:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kamu suka komikku? Yey!
Dialogue: 0,0:11:45.49,0:11:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tinggal di keluarga yang brutal,\Ntidak kusangka kamu bisa
Dialogue: 0,0:11:49.04,0:11:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menulis cerita bahagia.
Dialogue: 0,0:11:51.83,0:11:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itulah alasannya.
Dialogue: 0,0:11:55.50,0:11:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika menggambar dunia yang kuimpikan…
Dialogue: 0,0:11:59.59,0:12:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu-tahu laku.
Dialogue: 0,0:12:00.71,0:12:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hagure Hikaru.{\i0}
Dialogue: 0,0:12:01.92,0:12:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ahli komik yang menghangatkan hati.{\i0}
Dialogue: 0,0:12:05.97,0:12:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci kehidupan yang dipenuhi\Npembunuhan dan pengkhianatan ini.
Dialogue: 0,0:12:11.60,0:12:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku tidak pernah membunuh orang, lo!\N- Aku juga!
Dialogue: 0,0:12:14.69,0:12:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung belum terlambat,\Nkalian cari pekerjaan normal saja.
Dialogue: 0,0:12:19.15,0:12:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh,
Dialogue: 0,0:12:20.15,0:12:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku kepalang nyaman karena atasan di sini\Nsiap pasang badan kalau ada masalah.
Dialogue: 0,0:12:25.20,0:12:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku, sedang butuh uang.
Dialogue: 0,0:12:29.79,0:12:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:12:32.12,0:12:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}cuma tidak mau orang yang seharusnya\Nhidup normal malah mengotori tangannya.{\i0}
Dialogue: 0,0:12:38.96,0:12:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kasihan.{\i0}
Dialogue: 0,0:12:41.55,0:12:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tinggal jadi kepala klan\Ndan memecat kami, kan?
Dialogue: 0,0:12:45.84,0:12:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang,\Naku ogah mewarisi klan gila ini!
Dialogue: 0,0:12:50.31,0:12:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian jadi asisten komikus
Dialogue: 0,0:12:53.73,0:12:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kerja di studioku saja.
Dialogue: 0,0:12:56.19,0:12:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menggambar, lo.
Dialogue: 0,0:12:57.69,0:13:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok anggota kami malah mau kamu bajak?
Dialogue: 0,0:13:00.82,0:13:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain urusan komik,\Naku siap membantumu apa pun, kok.
Dialogue: 0,0:13:05.49,0:13:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kami empat bersaudara\Nberutang budi ke Klan Kagemori.
Dialogue: 0,0:13:08.70,0:13:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu punya saudara?\N- Punya.
Dialogue: 0,0:13:12.24,0:13:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kakak perempuanku, Natsuki.{\i0}
Dialogue: 0,0:13:13.70,0:13:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kakak laki-lakiku, Fuyuki.{\i0}
Dialogue: 0,0:13:15.37,0:13:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu aku, Haruo.{\i0}
Dialogue: 0,0:13:17.12,0:13:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan si bungsu, Akio.{\i0}
Dialogue: 0,0:13:19.13,0:13:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami Kuroya bersaudara.
Dialogue: 0,0:13:21.17,0:13:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat orang? Banyak juga.
Dialogue: 0,0:13:23.88,0:13:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kami dari panti bayi yang sama\Ndan tidak sedarah.
Dialogue: 0,0:13:29.01,0:13:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, maaf topiknya jadi sensitif.
Dialogue: 0,0:13:33.14,0:13:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, kok.
Dialogue: 0,0:13:36.14,0:13:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah dibuang dan diurus\Ndi panti Kagemori sejak bayi.
Dialogue: 0,0:13:41.48,0:13:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tega sekali membuang anak seimut ini.
Dialogue: 0,0:13:44.69,0:13:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan Kagemori juga punya panti bayi?
Dialogue: 0,0:13:49.11,0:13:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga punya panti asuhan,\Nayahku baik kalau sama anak-anak.
Dialogue: 0,0:13:53.12,0:13:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sama anak-anak.
Dialogue: 0,0:13:54.25,0:13:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku jadi gagal paham.\N- Anak baik.
Dialogue: 0,0:13:57.04,0:13:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal rumornya kalian
Dialogue: 0,0:13:58.67,0:14:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- sering berbuat jahat.\N- Haruo anak baik.
Dialogue: 0,0:14:00.46,0:14:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah.
Dialogue: 0,0:14:01.96,0:14:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sekalian buat pencitraan\Ndi muka umum.
Dialogue: 0,0:14:07.17,0:14:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar!
Dialogue: 0,0:14:09.68,0:14:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya kami berempat dilatih\Njadi pasukan Kagemori yang sejahat ini.
Dialogue: 0,0:14:18.69,0:14:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengin berhenti.
Dialogue: 0,0:14:20.48,0:14:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melihat apa, Natsuki?
Dialogue: 0,0:14:22.40,0:14:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situs cari jodoh.
Dialogue: 0,0:14:24.11,0:14:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pengin berhenti kerja di sini.
Dialogue: 0,0:14:27.65,0:14:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kerjaan.
Dialogue: 0,0:14:29.45,0:14:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master dan Jin merencanakan sesuatu.
Dialogue: 0,0:14:41.33,0:14:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Gabuchan mau pergi?
Dialogue: 0,0:14:43.59,0:14:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:44.75,0:14:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama Natsuki, Fuyuki, dan Master.
Dialogue: 0,0:14:49.01,0:14:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben dipisah dari Asa.
Dialogue: 0,0:14:51.55,0:14:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa sedang linglung,
Dialogue: 0,0:14:54.47,0:14:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}jadinya tidak diajak karena takut berulah.
Dialogue: 0,0:14:57.18,0:14:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mau ke mana?
Dialogue: 0,0:15:00.73,0:15:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ke tempat orang yang mengincar Yuru.{\i0}
Dialogue: 0,0:15:04.02,0:15:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di gudang Fujimurayama.{\i0}
Dialogue: 0,0:15:11.66,0:15:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sudah purnama.{\i0}
Dialogue: 0,0:15:14.33,0:15:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berarti jam babi hutan tinggal satu jam.{\i0}
Dialogue: 0,0:15:20.25,0:15:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Dera dan Penjaga Ilahi Sayuu\Nbelum ada perubahan.{\i0}
Dialogue: 0,0:15:30.59,0:15:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Belum ada tanda-tanda musuh.{\i0}
Dialogue: 0,0:15:35.68,0:15:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin para bandit sudah bersiaga\Ndi suatu tempat.{\i0}
Dialogue: 0,0:15:56.58,0:15:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia datang dari mana?{\i0}
Dialogue: 0,0:15:59.91,0:16:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangankan niat membunuh,{\i0}
Dialogue: 0,0:16:02.08,0:16:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bunyinya saja tidak terdengar!{\i0}
Dialogue: 0,0:16:21.89,0:16:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dera tidak menyadarinya.{\i0}
Dialogue: 0,0:16:25.44,0:16:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penjaga Ilahi Sayuu juga tidak.{\i0}
Dialogue: 0,0:16:27.82,0:16:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Hawa keberadaannya tidak terdeteksi.{\i0}
Dialogue: 0,0:16:31.15,0:16:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Meski tidak berniat membunuh,{\i0}
Dialogue: 0,0:16:32.90,0:16:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia bisa menghabisiku sekali pelintir.{\i0}
Dialogue: 0,0:16:39.87,0:16:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang yang bisa langsung menyerang\Nkalau aku bersuara cuma…{\i0}
Dialogue: 0,0:16:45.04,0:16:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku walimu.
Dialogue: 0,0:16:47.38,0:16:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah janji pula\Nsama adikmu yang manis itu.
Dialogue: 0,0:16:51.84,0:16:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Akan kupercayakan pada Dera.{\i0}
Dialogue: 0,0:16:55.18,0:16:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera! Tembak dia!
Dialogue: 0,0:17:00.26,0:17:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa itu?{\i0}
Dialogue: 0,0:17:02.47,0:17:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sejak kapan dia di situ?{\i0}
Dialogue: 0,0:17:30.79,0:17:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru!
Dialogue: 0,0:17:32.30,0:17:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penjaga Ilahi Sayuu.{\i0}
Dialogue: 0,0:17:38.64,0:17:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa kena.
Dialogue: 0,0:18:18.97,0:18:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkurang sedikit.
Dialogue: 0,0:18:20.43,0:18:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sedikit.
Dialogue: 0,0:18:22.18,0:18:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus melahapnya sedikit-sedikit.
Dialogue: 0,0:18:25.02,0:18:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak cocok sama gaya bertarungku.
Dialogue: 0,0:18:37.74,0:18:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghilang?
Dialogue: 0,0:18:52.92,0:18:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Yuru.
Dialogue: 0,0:18:56.26,0:18:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kagemori Asum—
Dialogue: 0,0:18:59.34,0:19:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kamu mabuk kendaraan?
Dialogue: 0,0:19:03.26,0:19:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Tsugai milikmu?
Dialogue: 0,0:19:06.31,0:19:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, ini Tsugai-ku, Matahari dan Bulan.
Dialogue: 0,0:19:09.85,0:19:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Yozakura.
Dialogue: 0,0:19:12.06,0:19:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget hawa keberadaannya tidak terasa.
Dialogue: 0,0:19:16.28,0:19:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana pasangannya?
Dialogue: 0,0:19:17.23,0:19:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Asagiri.
Dialogue: 0,0:19:19.07,0:19:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak ikut karena lemah di malam hari.
Dialogue: 0,0:19:21.99,0:19:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya, Yozakura lemah di siang hari,
Dialogue: 0,0:19:24.66,0:19:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya cuma aktif kalau malam.
Dialogue: 0,0:19:29.04,0:19:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Yozakura bisa kalah kalau siang?
Dialogue: 0,0:19:31.79,0:19:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bocah yang mengerikan.{\i0}
Dialogue: 0,0:19:33.92,0:19:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bisa-bisanya mengobrol\Ndan mengamati sekitar di situasi begini.{\i0}
Dialogue: 0,0:19:38.76,0:19:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebaiknya Tsugai-ku disembunyikan dulu.{\i0}
Dialogue: 0,0:19:42.13,0:19:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Asuma, jangan membocorkan\Nkelemahan Tsugai-mu.
Dialogue: 0,0:19:47.22,0:19:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersikap tulus supaya kita dipercaya.
Dialogue: 0,0:19:51.56,0:19:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mengincar kekuatan Fuu,\NKagemori Asuma?
Dialogue: 0,0:19:55.40,0:19:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai ucapanku di wisma Kagemori.
Dialogue: 0,0:19:58.28,0:20:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, pemilik kekuatan istimewa\Nperlu dikontrol oleh pihak yang tepat.
Dialogue: 0,0:20:05.20,0:20:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kontrol itu apa?{\i0}
Dialogue: 0,0:20:07.66,0:20:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Yuru?
Dialogue: 0,0:20:12.29,0:20:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mencoba mati sekali?
Dialogue: 0,0:20:22.67,0:20:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, mana Yuru?
Dialogue: 0,0:20:24.47,0:20:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diculik kumpulan ngengat\Nbermuka tengkorak.
Dialogue: 0,0:20:27.01,0:20:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu hilang di sini.
Dialogue: 0,0:20:28.26,0:20:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hilang? Aromanya terlacak, tidak?
Dialogue: 0,0:20:32.14,0:20:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah, sih.
Dialogue: 0,0:20:33.69,0:20:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma Yuru tertutup aroma darah\Nyang pekat di sini.
Dialogue: 0,0:20:49.70,0:20:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:20:53.75,0:20:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai katana, ya.
Dialogue: 0,0:20:56.75,0:20:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu yang dimaksud si Dukun.
Dialogue: 0,0:21:00.25,0:21:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si cabul di tengah malam!
Dialogue: 0,0:21:01.80,0:21:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, pihak Desa Higashi\Nsebenarnya menganggapku apa, sih?
Dialogue: 0,0:21:06.39,0:21:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kejam sekali kamu\Nmembantai para bandit.
Dialogue: 0,0:21:11.18,0:21:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibiarkan bersembunyi,\Nnanti negosiasiku diganggu mereka.
Dialogue: 0,0:21:15.35,0:21:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tidak perlu ada yang mati\Nkalau Yuru datang sendirian.
Dialogue: 0,0:21:19.82,0:21:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua Penjaga Ilahi Sayuu, kan?\NTsugai milik Yuru?
Dialogue: 0,0:21:24.15,0:21:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok musuh alami Kai dan Fuu\Nmalah jadi Tsugai-nya si kembar?
Dialogue: 0,0:21:29.32,0:21:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama Hidari.
Dialogue: 0,0:21:30.58,0:21:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dan Fuu sangat tidak cocok.
Dialogue: 0,0:21:34.08,0:21:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ada kamu, mungkin Fuu\Ntidak akan mau kontrak dengan Yuru.
Dialogue: 0,0:21:40.09,0:21:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka dari itu…
Dialogue: 0,0:21:43.92,0:21:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu adalah pengganggu, enyahlah.
Dialogue: 0,0:21:47.80,0:21:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu diajak duel, Hidari.
Dialogue: 0,0:21:54.10,0:21:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku terima.
Dialogue: 0,0:23:28.94,0:23:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kamu adalah pengganggu, enyahlah.{\i0}
Dialogue: 0,0:23:31.91,0:23:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Desa Higashi sudah bukan lagi tempatmu.{\i0}
Dialogue: 0,0:23:34.41,0:23:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aroma darah orang tua Yuru,\NMine dan Nagisa.{\i0}
