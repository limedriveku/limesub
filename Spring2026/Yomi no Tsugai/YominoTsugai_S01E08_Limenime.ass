Dialogue: 0,0:23:27.61,0:23:28.90,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:32.42,0:01:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang buat makan ramai-ramai…
Dialogue: 0,0:01:36.93,0:01:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah?
Dialogue: 0,0:01:38.93,0:01:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aulanya berantakan.
Dialogue: 0,0:01:41.72,0:01:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau diperbaiki?
Dialogue: 0,0:01:43.43,0:01:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:01:48.27,0:01:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rusaknya parah, ya.
Dialogue: 0,0:02:00.82,0:02:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Menghilang.\N- Putih bersih!
Dialogue: 0,0:02:20.01,0:02:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita bisa sarapan.
Dialogue: 0,0:02:23.89,0:02:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi seperti semula?
Dialogue: 0,0:02:26.14,0:02:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kok bisa?
Dialogue: 0,0:02:28.98,0:02:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Tsugai-ku, "Hitam Putih".
Dialogue: 0,0:02:31.23,0:02:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:02:32.44,0:02:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini White.
Dialogue: 0,0:02:34.90,0:02:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ini Beta.
Dialogue: 0,0:02:36.78,0:02:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}White menghapus bagian yang rusak,
Dialogue: 0,0:02:39.78,0:02:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Beta menggambarnya ulang.
Dialogue: 0,0:02:43.32,0:02:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena punya pengamatan dan imajinasi,
Dialogue: 0,0:02:46.12,0:02:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hagure Sensei\Ndan Hitam Putih sangat cocok.
Dialogue: 0,0:02:49.71,0:02:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sensei?
Dialogue: 0,0:02:50.75,0:02:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Hagure Hikaru, seorang komikus.
Dialogue: 0,0:02:55.75,0:02:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Cuih" barusan adalah tanda cinta mereka.
Dialogue: 0,0:03:00.22,0:03:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Komikus itu apa?{\i0}
Dialogue: 0,0:03:05.05,0:03:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setahuku, Hagure nama pengarang film!
Dialogue: 0,0:03:08.06,0:03:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku bisa cari nafkah dari situ.
Dialogue: 0,0:03:12.69,0:03:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hagure cuma nama pena,\Nnama asliku Kagemori Hikaru.
Dialogue: 0,0:03:17.40,0:03:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama pena?
Dialogue: 0,0:03:18.57,0:03:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama samaran.
Dialogue: 0,0:03:19.69,0:03:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bisnis keluarga ini abu-abu,
Dialogue: 0,0:03:23.62,0:03:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pakai nama pena\Nbuat menghindari skandal.
Dialogue: 0,0:03:26.78,0:03:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya kamu dari Klan Kagemori?
Dialogue: 0,0:03:29.54,0:03:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tiga bersaudara.
Dialogue: 0,0:03:32.33,0:03:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku anak sulung, Hikaru.
Dialogue: 0,0:03:33.50,0:03:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku anak kedua, Asuma.
Dialogue: 0,0:03:35.84,0:03:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku anak bungsu, Jin.
Dialogue: 0,0:03:38.17,0:03:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bungsu?
Dialogue: 0,0:03:40.26,0:03:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang paling muda?
Dialogue: 0,0:03:42.84,0:03:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah?
Dialogue: 0,0:03:43.84,0:03:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami cuma saudara tiri.
Dialogue: 0,0:03:49.27,0:03:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mirip, kan?
Dialogue: 0,0:03:50.85,0:03:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hagure akan mewarisi klan\Nsebagai anak sulung.
Dialogue: 0,0:03:54.44,0:03:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat dengannya akan menguntungkan.
Dialogue: 0,0:03:56.73,0:04:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah,\Naku tidak mau mewarisi klan gila ini!
Dialogue: 0,0:04:00.61,0:04:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku cuma mau hidup tenang\Ndan menggambar komik bahagia,
Dialogue: 0,0:04:05.11,0:04:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beda sama kalian yang moralnya rusak!
Dialogue: 0,0:04:09.54,0:04:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya makin gila penciptanya\Nmakin bagus karyanya?
Dialogue: 0,0:04:14.42,0:04:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:04:16.29,0:04:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Sensei,\Nwarnanya cuma hitam dan putih.
Dialogue: 0,0:04:22.59,0:04:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak jadi masalah?
Dialogue: 0,0:04:24.30,0:04:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:04:26.01,0:04:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama-lama warnanya akan kembali
Dialogue: 0,0:04:29.35,0:04:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti sediakala.
Dialogue: 0,0:04:32.52,0:04:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambarku kurang detail,\Ntiangnya terlalu rapi.
Dialogue: 0,0:04:36.73,0:04:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunan setua ini\Nseharusnya dibuat lebih lapuk.
Dialogue: 0,0:04:41.69,0:04:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudutnya terlalu tajam.
Dialogue: 0,0:04:43.32,0:04:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tataminya juga.
Dialogue: 0,0:04:45.03,0:04:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai alas lalu-lalang,\Ntataminya harus lebih lusuh.
Dialogue: 0,0:04:49.74,0:04:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak terasa tua dan bekas.
Dialogue: 0,0:04:54.75,0:04:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambar ulang!
Dialogue: 0,0:04:59.42,0:05:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayo sarapan dulu.{\i0}
Dialogue: 0,0:05:05.01,0:05:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama.
Dialogue: 0,0:05:06.68,0:05:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisinya… Ya sudahlah.
Dialogue: 0,0:05:11.01,0:05:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduklah di mana saja.
Dialogue: 0,0:05:13.22,0:05:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan kami baru naik daun.
Dialogue: 0,0:05:15.31,0:05:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir soal posisi,\Ntradisi, maupun etiket.
Dialogue: 0,0:05:19.90,0:05:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hup!\N- Ha!
Dialogue: 0,0:05:26.49,0:05:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Hup!\N- Ha!
Dialogue: 0,0:05:29.66,0:05:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hup!\N- Ha!
Dialogue: 0,0:05:31.83,0:05:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Hup!\N- Ha!
Dialogue: 0,0:05:35.00,0:05:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:05:36.08,0:05:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, terima kasih.
Dialogue: 0,0:05:41.00,0:05:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hup!\N- Ha!
Dialogue: 0,0:05:42.75,0:05:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup!
Dialogue: 0,0:05:44.17,0:05:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kami juga diberi tempat duduk?
Dialogue: 0,0:05:47.97,0:05:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak makan makanan manusia.
Dialogue: 0,0:05:50.89,0:05:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai tamu, kalian juga harus dijamu.
Dialogue: 0,0:06:03.90,0:06:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,\Nkenapa kamu tahu si Abang ada di sini?
Dialogue: 0,0:06:08.36,0:06:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia.
Dialogue: 0,0:06:12.28,0:06:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wisma kami diserang\Nbeberapa Tsugai tadi malam.
Dialogue: 0,0:06:17.12,0:06:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ulah Desa Higashi, ya?
Dialogue: 0,0:06:20.17,0:06:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Mana kutahu.
Dialogue: 0,0:06:22.21,0:06:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Suasana makan yang riang malah jadi suram.{\i0}
Dialogue: 0,0:06:26.21,0:06:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa aku menyerang markas Kagemori?
Dialogue: 0,0:06:30.34,0:06:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kebetulan waktunya pas\Ndengan datangnya si Abang.
Dialogue: 0,0:06:35.52,0:06:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:06:37.02,0:06:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kakak menikmati makanannya…{\i0}
Dialogue: 0,0:06:40.14,0:06:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, Klan Tadera\Ntahu cara melewati pelindung.
Dialogue: 0,0:06:45.86,0:06:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma khusus pelindung kami saja.
Dialogue: 0,0:06:48.69,0:06:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kakak meminum sup misonya…{\i0}
Dialogue: 0,0:06:52.12,0:06:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:06:53.45,0:06:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Asa, Klan Kagemori baik sama kamu?
Dialogue: 0,0:06:57.45,0:06:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:06:59.12,0:07:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diberi makan\Ndan pendidikan yang layak.
Dialogue: 0,0:07:03.13,0:07:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di wisma ini,\Naku aman dan terhindar dari pembunuh.
Dialogue: 0,0:07:07.96,0:07:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski semalam kecolongan, sih.
Dialogue: 0,0:07:10.63,0:07:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu keluar wisma, musuh di mana-mana.
Dialogue: 0,0:07:13.97,0:07:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sebaiknya tidak keluar,
Dialogue: 0,0:07:17.14,0:07:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kadang Asa perlu\Npenanganan rumah sakit biasa.
Dialogue: 0,0:07:22.81,0:07:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situlah penjagaannya mengendur.
Dialogue: 0,0:07:26.98,0:07:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu diculik pembunuh Desa Higashi pun,
Dialogue: 0,0:07:30.07,0:07:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sedang dirawat di rumah sakit umum.
Dialogue: 0,0:07:33.36,0:07:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa, kamu sakit apa?
Dialogue: 0,0:07:36.87,0:07:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tukak lambung.
Dialogue: 0,0:07:39.33,0:07:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena selalu diteror Desa Higashi,\Nlambungku berlubang akibat stres.
Dialogue: 0,0:07:46.34,0:07:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma protes,
Dialogue: 0,0:07:48.63,0:07:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu bukan ulahku.
Dialogue: 0,0:07:50.76,0:07:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang biasa yang di rumah sakit\Nturut kena imbasnya, tahu!
Dialogue: 0,0:07:57.01,0:07:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hentikan!
Dialogue: 0,0:07:59.18,0:08:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang, bukan aku.
Dialogue: 0,0:08:01.73,0:08:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, deh.\NItu ulah para ekstremis Desa Higashi.
Dialogue: 0,0:08:07.61,0:08:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Asa, identitasmu sudah terdaftar?
Dialogue: 0,0:08:11.24,0:08:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal repot kalau ke rumah sakit\Ntanpa asuransi, kan?
Dialogue: 0,0:08:15.87,0:08:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Yuru belum terdaftar.
Dialogue: 0,0:08:18.49,0:08:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga belum.
Dialogue: 0,0:08:21.58,0:08:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti repot, tuh.
Dialogue: 0,0:08:24.04,0:08:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Ibu orang dataran rendah,
Dialogue: 0,0:08:26.71,0:08:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tadinya aku mau daftar lewat dia.
Dialogue: 0,0:08:31.17,0:08:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya Ibu dan Ayah diculik\Ndan hilang tanpa jejak.
Dialogue: 0,0:08:36.26,0:08:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, orang tuamu hilang?
Dialogue: 0,0:08:39.56,0:08:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya begitu.
Dialogue: 0,0:08:41.72,0:08:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sebagai pihak Desa Higashi,
Dialogue: 0,0:08:45.56,0:08:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku baru tahu orang tuamu hilang.
Dialogue: 0,0:08:48.94,0:08:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling tidak, ini bukan ulah\Nkelompok Desa Higashi yang kukenal.
Dialogue: 0,0:08:54.90,0:08:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kami harus percaya itu?
Dialogue: 0,0:08:59.16,0:09:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tiada ampun\Nkalau wilayah kami diusik,
Dialogue: 0,0:09:03.00,0:09:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak pernah mengusik duluan.
Dialogue: 0,0:09:05.50,0:09:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dengan ekstremis Desa Higashi.
Dialogue: 0,0:09:09.84,0:09:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya, aku menjemput Yuru\Ndengan damai begini.
Dialogue: 0,0:09:15.09,0:09:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja itu ulah ekstremis Kagemori.
Dialogue: 0,0:09:19.51,0:09:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jadi rahasia umum\Nbahwa kalian tidak sejalan.
Dialogue: 0,0:09:25.85,0:09:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Klan Kagemori.
Dialogue: 0,0:09:28.10,0:09:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rencanamu terhadap si kembar?
Dialogue: 0,0:09:35.78,0:09:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap lahirnya kembar yang ditakdirkan,\Ndunia selalu kacau.
Dialogue: 0,0:09:40.91,0:09:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kai dan Fuu sebaiknya tidak ada.
Dialogue: 0,0:09:46.79,0:09:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap Asa dan Yuru jadi yang terakhir.
Dialogue: 0,0:09:50.75,0:09:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Desa Higashi yang jadi sumbernya\Nsepatutnya lenyap.
Dialogue: 0,0:09:56.17,0:09:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Desa malang itu berpemikiran kolot{\i0}
Dialogue: 0,0:09:59.47,0:10:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan masih saja berkhayal menguasai dunia.{\i0}
Dialogue: 0,0:10:03.81,0:10:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zaman sudah berubah.
Dialogue: 0,0:10:05.73,0:10:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai keturunan desa itu,\Nkitalah yang harus mengakhirinya.
Dialogue: 0,0:10:11.81,0:10:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beda pendapat.
Dialogue: 0,0:10:14.44,0:10:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang diberkati kekuatan\Nharus memakainya demi kedamaian dunia.
Dialogue: 0,0:10:20.99,0:10:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah kewajiban mereka
Dialogue: 0,0:10:23.91,0:10:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai pengemban anugerah Tuhan.
Dialogue: 0,0:10:27.33,0:10:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, Kagemori bisa mengontrolnya?
Dialogue: 0,0:10:31.58,0:10:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, Kai dan Fuu\Nmemang dihasilkan Desa Higashi.
Dialogue: 0,0:10:37.42,0:10:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan harus tetap begitu.
Dialogue: 0,0:10:40.13,0:10:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan dikelola organisasi yang tepat.
Dialogue: 0,0:10:43.93,0:10:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah pendapatku.
Dialogue: 0,0:10:48.89,0:10:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu.
Dialogue: 0,0:10:50.31,0:10:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:51.90,0:10:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku mengira kami kembar terkutuk,\Nkalian langsung menyangkal, kan?
Dialogue: 0,0:10:58.78,0:11:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang lain saja yang seenaknya\Nmemperebutkan kami.
Dialogue: 0,0:11:04.33,0:11:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian menegaskan bahwa\Nkami tidak bersalah.
Dialogue: 0,0:11:08.37,0:11:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat lega mendengarnya.
Dialogue: 0,0:11:12.38,0:11:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya kami boleh hidup\Nlayaknya orang lain.
Dialogue: 0,0:11:19.09,0:11:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:11:28.68,0:11:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih makanannya.
Dialogue: 0,0:11:32.69,0:11:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu saja minta maaf.
Dialogue: 0,0:11:36.15,0:11:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerang desa memang salah,
Dialogue: 0,0:11:39.11,0:11:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia minta maaf atas segala hal.
Dialogue: 0,0:11:42.49,0:11:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang membuatnya seminder ini?
Dialogue: 0,0:11:47.16,0:11:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang bilang bahwa ini kesalahannya?
Dialogue: 0,0:11:51.25,0:11:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai kembar yang ditakdirkan,\Nkenapa kami harus hidup diam-diam?
Dialogue: 0,0:11:57.42,0:12:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa hidup kami harus diatur orang lain?
Dialogue: 0,0:12:06.26,0:12:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Klan Kagemori memang tidak sejalan,\Nmungkin omonganku pun
Dialogue: 0,0:12:11.27,0:12:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan terdengar para ekstremis.
Dialogue: 0,0:12:14.65,0:12:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera.
Dialogue: 0,0:12:15.81,0:12:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampaikan ini juga\Npada pihak Desa Higashi.
Dialogue: 0,0:12:22.19,0:12:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan lari atau sembunyi.
Dialogue: 0,0:12:24.66,0:12:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu tidak perlu.
Dialogue: 0,0:12:27.20,0:12:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Higashi maupun Klan Kagemori\Nterlalu ribet.
Dialogue: 0,0:12:30.54,0:12:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau nyawaku? Datang dan ambil saja!
Dialogue: 0,0:12:35.21,0:12:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:12:36.96,0:12:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka cuma akan kalah\Ndan kuperas informasinya.
Dialogue: 0,0:12:42.42,0:12:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, kamu ini…
Dialogue: 0,0:12:45.59,0:12:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kakak bodoh!
Dialogue: 0,0:12:51.93,0:12:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kakak bodoh!
Dialogue: 0,0:13:01.28,0:13:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, siapa yang bodoh?
Dialogue: 0,0:13:03.57,0:13:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau lari atau sembunyi? Jangan sok!
Dialogue: 0,0:13:07.41,0:13:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang begitu karena belum tahu\Nngerinya dikejar-kejar pembunuh!
Dialogue: 0,0:13:14.54,0:13:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau kamu mengalaminya!
Dialogue: 0,0:13:17.29,0:13:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari! Sembunyi!
Dialogue: 0,0:13:19.42,0:13:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangi nyawamu!
Dialogue: 0,0:13:21.84,0:13:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru tipe yang maju terus pantang mundur?
Dialogue: 0,0:13:26.34,0:13:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:13:27.68,0:13:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, nasihati dia…
Dialogue: 0,0:13:30.22,0:13:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai wajib mematuhi tuannya.
Dialogue: 0,0:13:34.98,0:13:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh jual kami beli.
Dialogue: 0,0:13:38.02,0:13:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kalian malah senang?
Dialogue: 0,0:13:40.44,0:13:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:13:42.57,0:13:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kakakmu siap
Dialogue: 0,0:13:45.15,0:13:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membantu mengurangi bebanmu.
Dialogue: 0,0:13:48.57,0:13:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan!
Dialogue: 0,0:13:50.20,0:13:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan kami itu baik hati.\N- Apa?
Dialogue: 0,0:13:55.45,0:14:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku tahu Kakak memang baik.
Dialogue: 0,0:14:03.67,0:14:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, maukah kamu tinggal\Nbersama Klan Kagemori?
Dialogue: 0,0:14:09.26,0:14:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini jauh lebih aman,\Nhidupmu pun akan terjamin.
Dialogue: 0,0:14:15.18,0:14:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau?
Dialogue: 0,0:14:16.18,0:14:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:14:17.31,0:14:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat banget.
Dialogue: 0,0:14:19.06,0:14:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek, semalang apa pun\NDesa Higashi bagimu,
Dialogue: 0,0:14:23.40,0:14:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tumbuh besar dan punya teman di sana.
Dialogue: 0,0:14:28.32,0:14:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski memahami pandanganmu,\Nbukan berarti aku setuju.
Dialogue: 0,0:14:34.45,0:14:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mustahil akur dengan orang\Nyang merusak desaku.{\i0}
Dialogue: 0,0:14:39.16,0:14:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mau\Nmencari orang tuaku.
Dialogue: 0,0:14:42.17,0:14:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku punya cara sendiri.
Dialogue: 0,0:14:45.46,0:14:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencari Ayah\Ndan Ibu bersama Dera.
Dialogue: 0,0:14:51.72,0:14:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku ingin Yuru sembunyi.
Dialogue: 0,0:14:56.93,0:14:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebagai wali,
Dialogue: 0,0:14:59.77,0:15:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku cuma bisa menjaga\Ndan menghormati pilihannya.
Dialogue: 0,0:15:04.65,0:15:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami sudah boleh pulang?
Dialogue: 0,0:15:08.07,0:15:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kagemori, Asa.
Dialogue: 0,0:15:13.16,0:15:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, Dera.
Dialogue: 0,0:15:21.17,0:15:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jaga Kakak.
Dialogue: 0,0:15:25.63,0:15:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap laksanakan.
Dialogue: 0,0:15:28.21,0:15:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuusahakan.
Dialogue: 0,0:15:40.06,0:15:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bisa mengantar sampai sini.
Dialogue: 0,0:15:42.69,0:15:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya itu pelindungnya.
Dialogue: 0,0:15:45.27,0:15:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau keluar,\Ntakutnya aku langsung diserang.
Dialogue: 0,0:15:50.57,0:15:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak juga hati-hati, ya.
Dialogue: 0,0:15:58.70,0:16:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia tidak bebas keluar dari gerbang ini?{\i0}
Dialogue: 0,0:16:03.96,0:16:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujungnya cuma ganti kurungan, dong?{\i0}
Dialogue: 0,0:16:09.96,0:16:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Kakak, lihat ini.
Dialogue: 0,0:16:14.34,0:16:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:16:15.80,0:16:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Hah?
Dialogue: 0,0:16:18.47,0:16:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu?
Dialogue: 0,0:16:20.35,0:16:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sebelum mereka menghilang.
Dialogue: 0,0:16:23.39,0:16:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Ukiyoe?
Dialogue: 0,0:16:25.40,0:16:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, anggap saja model barunya.
Dialogue: 0,0:16:30.78,0:16:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo Kakak. Lihat ke situ.
Dialogue: 0,0:16:36.78,0:16:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknologi ini bisa\Nmengabadikan momen secara langsung.
Dialogue: 0,0:16:41.37,0:16:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Entah kenapa aku sangat terpukau!
Dialogue: 0,0:16:46.38,0:16:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rencanaku mendapat foto Kakak, berhasil.{\i0}
Dialogue: 0,0:16:51.13,0:16:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya!\NKami juga mau diabadikan bareng Yuru!
Dialogue: 0,0:16:55.34,0:16:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya…
Dialogue: 0,0:16:58.60,0:17:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai tidak kelihatan.
Dialogue: 0,0:17:01.64,0:17:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kalian seperti hantu.
Dialogue: 0,0:17:04.06,0:17:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang ada Tsugai yang terpotret, sih.
Dialogue: 0,0:17:08.98,0:17:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di acara TV mistis.
Dialogue: 0,0:17:11.36,0:17:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa.
Dialogue: 0,0:17:13.53,0:17:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau lihat Ayah dan Ibu lagi.
Dialogue: 0,0:17:21.83,0:17:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai baju dataran rendah, ya.
Dialogue: 0,0:17:24.62,0:17:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aneh juga.
Dialogue: 0,0:17:26.92,0:17:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepuluh tahun kami berpisah.
Dialogue: 0,0:17:30.21,0:17:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ada di mana, ya?
Dialogue: 0,0:17:33.13,0:17:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti baik-baik saja.
Dialogue: 0,0:17:37.51,0:17:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku cetak dan kirim padamu.
Dialogue: 0,0:17:40.10,0:17:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran?
Dialogue: 0,0:17:41.85,0:17:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak tinggal di mana?
Dialogue: 0,0:17:44.35,0:17:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan alamatmu.
Dialogue: 0,0:17:45.93,0:17:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat aku tinggal? Eng…
Dialogue: 0,0:17:49.86,0:17:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prefektur Guntama.
Dialogue: 0,0:17:51.07,0:17:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mananya?
Dialogue: 0,0:17:52.07,0:17:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rencanaku mendapat alamat Kakak, gagal.{\i0}
Dialogue: 0,0:17:57.32,0:17:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau rumah Dera?
Dialogue: 0,0:17:58.61,0:18:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan Kagemori tidak boleh tahu markasku.
Dialogue: 0,0:18:02.91,0:18:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada info soal orang tuanya,\Nkami ingin mengabari si Abang.
Dialogue: 0,0:18:07.92,0:18:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah memberi alamat.
Dialogue: 0,0:18:09.88,0:18:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Email atau nomor ponsel juga boleh.
Dialogue: 0,0:18:12.29,0:18:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah, nanti informasi tentangku\Nmalah terbongkar.
Dialogue: 0,0:18:19.13,0:18:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita memang perlu sarana komunikasi.
Dialogue: 0,0:18:24.39,0:18:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai merpati?
Dialogue: 0,0:18:26.02,0:18:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Radio genggam?
Dialogue: 0,0:18:27.85,0:18:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan pesan di Stasiun Shinjuku?
Dialogue: 0,0:18:29.90,0:18:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinyal asap.
Dialogue: 0,0:18:30.90,0:18:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu melanggar aturan.
Dialogue: 0,0:18:34.78,0:18:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah,\Ndatanglah kemari kalau ada perlu.
Dialogue: 0,0:18:38.99,0:18:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bar wanita?
Dialogue: 0,0:18:40.61,0:18:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu salah satu bisnis kami.
Dialogue: 0,0:18:43.49,0:18:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sebut nama Kagemori Jin,\Nmereka pasti paham.
Dialogue: 0,0:18:48.16,0:18:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita komunikasi lewat situ.
Dialogue: 0,0:18:52.42,0:18:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, deh!
Dialogue: 0,0:18:54.25,0:18:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kamu mau utang minuman, ya?{\i0}
Dialogue: 0,0:18:58.17,0:19:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, semoga orang tua si kembar ketemu.
Dialogue: 0,0:19:01.34,0:19:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sarapannya.
Dialogue: 0,0:19:07.56,0:19:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:19:11.06,0:19:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu sangat menyesal\Ntidak membawamu.
Dialogue: 0,0:19:17.61,0:19:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Karena dihalangi Nenek Yamaha,
Dialogue: 0,0:19:20.95,0:19:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}akhirnya cuma aku yang berhasil dibawa.
Dialogue: 0,0:19:25.87,0:19:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ingin kabur sama-sama.
Dialogue: 0,0:19:28.33,0:19:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak ditinggalkan dengan sengaja.
Dialogue: 0,0:19:44.51,0:19:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sia-sia aku kemari\Nkarena bisa mendengar hal itu.
Dialogue: 0,0:19:52.10,0:19:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:20:15.79,0:20:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, jaga kesehatanmu, ya.
Dialogue: 0,0:20:22.26,0:20:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:20:33.60,0:20:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei, Yuru?
Dialogue: 0,0:20:36.02,0:20:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lengah!
Dialogue: 0,0:20:39.07,0:20:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia beruang, aku pasti mati!
Dialogue: 0,0:20:42.03,0:20:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini…
Dialogue: 0,0:20:45.74,0:20:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak salah lagi, dia Asa.
Dialogue: 0,0:20:50.66,0:20:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:20:52.79,0:20:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga kesehatanmu, ya.
Dialogue: 0,0:20:59.21,0:21:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi.
Dialogue: 0,0:21:01.76,0:21:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adikku yang asli.
Dialogue: 0,0:21:08.35,0:21:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa begini… Sial!
Dialogue: 0,0:21:15.56,0:21:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin.
Dialogue: 0,0:21:16.98,0:21:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buntuti mereka,\Nkepercayaan itu penting.
Dialogue: 0,0:21:22.53,0:21:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:21:25.40,0:21:26.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya,
Dialogue: 0,0:21:26.74,0:21:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu dimiliki pihak ketiga\Nuntuk mengontrol Kai dan Fuu.
Dialogue: 0,0:21:33.50,0:21:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka
Dialogue: 0,0:21:36.25,0:21:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah jatuh ke tangan\Nsi kembar pemilik Fuu.
Dialogue: 0,0:21:42.17,0:21:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada apa-apa,\NYuru tidak bisa dihentikan.
Dialogue: 0,0:21:48.39,0:21:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Entah apa yang akan terjadi.{\i0}
Dialogue: 0,0:23:32.49,0:23:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka antek Kagemori.
Dialogue: 0,0:23:34.07,0:23:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kita dibuntuti.
Dialogue: 0,0:23:35.83,0:23:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja keraslah bagai kuda.
