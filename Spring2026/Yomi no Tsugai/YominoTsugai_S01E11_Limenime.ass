Dialogue: 0,0:13:42.44,0:13:43.15,sign,,0000,0000,0000,,PILIHAN KUDA
Dialogue: 0,0:13:44.11,0:13:44.82,sign,,0000,0000,0000,,BAR WANITA CINTA DAN KETULUSAN
Dialogue: 0,0:20:04.66,0:20:05.78,sign,,0000,0000,0000,,ANAK GUNUNG YANG JARANG DAPAT AIR BERSIH
Dialogue: 0,0:23:27.57,0:23:28.90,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:37.63,0:01:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terbunuh.
Dialogue: 0,0:01:39.34,0:01:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jalur menuju markas Tadera\Nsudah ketemu.
Dialogue: 0,0:01:43.18,0:01:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa mengambil jasad-jasad\Norang yang hilang di sana.
Dialogue: 0,0:01:48.10,0:01:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Asagiri.
Dialogue: 0,0:02:03.03,0:02:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu berlarian tadi,
Dialogue: 0,0:02:07.29,0:02:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan Tenaga dan Ashinaga\Nberhenti saat aku lewat sini.
Dialogue: 0,0:02:19.93,0:02:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia di sini.
Dialogue: 0,0:02:21.80,0:02:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuannya Tenaga dan Ashinaga.
Dialogue: 0,0:02:29.23,0:02:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarlah.
Dialogue: 0,0:02:31.31,0:02:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dibunuh?
Dialogue: 0,0:02:32.90,0:02:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok suaranya begitu?
Dialogue: 0,0:02:34.90,0:02:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kecil, ya?
Dialogue: 0,0:02:36.28,0:02:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung jawabanmu.
Dialogue: 0,0:02:39.07,0:02:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kejam sekali, apa dia benaran anak kecil?{\i0}
Dialogue: 0,0:02:48.66,0:02:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukatakan semuanya,\Ntapi jangan bunuh aku!
Dialogue: 0,0:02:53.42,0:02:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, benaran anak kecil.
Dialogue: 0,0:02:57.21,0:02:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tuan Tenaga dan Ashinaga?
Dialogue: 0,0:02:59.09,0:03:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku tuannya.
Dialogue: 0,0:03:01.80,0:03:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu siapa?
Dialogue: 0,0:03:03.76,0:03:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada di sini?
Dialogue: 0,0:03:05.93,0:03:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Tadera Ken.
Dialogue: 0,0:03:09.10,0:03:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, ini rumah ayahku.
Dialogue: 0,0:03:15.82,0:03:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kamu bilang apa?
Dialogue: 0,0:03:17.90,0:03:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:03:20.11,0:03:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, ini anakmu?
Dialogue: 0,0:03:21.15,0:03:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:03:23.03,0:03:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak…
Dialogue: 0,0:03:29.70,0:03:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat!
Dialogue: 0,0:03:31.41,0:03:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok sempat ragu?
Dialogue: 0,0:03:32.71,0:03:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa nama ibumu?
Dialogue: 0,0:03:35.08,0:03:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abeba Tesfaye.
Dialogue: 0,0:03:36.54,0:03:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang asing?
Dialogue: 0,0:03:37.92,0:03:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang Etiopia.
Dialogue: 0,0:03:39.30,0:03:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengenalnya!
Dialogue: 0,0:03:42.55,0:03:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan anakku!
Dialogue: 0,0:03:44.30,0:03:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Tadera Ryuu, kan?
Dialogue: 0,0:03:47.93,0:03:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah memberitahuku soal kamu.
Dialogue: 0,0:03:50.23,0:03:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Tadera Ken, anak Tadera Rouei.
Dialogue: 0,0:03:55.02,0:03:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama Rouei terdengar tidak asing.
Dialogue: 0,0:03:59.07,0:04:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu nama ayahku,\Nkepala Klan Tadera yang dulu.
Dialogue: 0,0:04:03.11,0:04:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kamu kecil,\Ndia masih suka bolak-balik Desa Higashi.
Dialogue: 0,0:04:07.83,0:04:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anaknya Ayah? Umurmu berapa?
Dialogue: 0,0:04:11.08,0:04:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}13 tahun.
Dialogue: 0,0:04:13.00,0:04:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita beda 22 tahun!
Dialogue: 0,0:04:14.62,0:04:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka saudara tiri yang umurnya jauh, ya.
Dialogue: 0,0:04:18.00,0:04:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertemuan mengharukan.
Dialogue: 0,0:04:19.96,0:04:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, Dera, keluargamu bertambah.
Dialogue: 0,0:04:23.09,0:04:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasananya enggak pas, tahu!
Dialogue: 0,0:04:26.14,0:04:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, saat bersembunyi\Naku mendengar obrolan kalian.
Dialogue: 0,0:04:30.72,0:04:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang itu si kembar\Ndari Desa Higashi, kan?
Dialogue: 0,0:04:35.02,0:04:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anaknya Mine dan Nagisa.
Dialogue: 0,0:04:37.73,0:04:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu dari Ayah.
Dialogue: 0,0:04:39.94,0:04:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenal orang tuaku?
Dialogue: 0,0:04:42.49,0:04:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:04:45.57,0:04:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya yang mengajari mereka\Ncara kabur dari desa
Dialogue: 0,0:04:49.08,0:04:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah ayahku.
Dialogue: 0,0:04:50.66,0:04:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, apa-apaan itu?
Dialogue: 0,0:04:53.33,0:04:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku baru tahu!\N- Benarkah?
Dialogue: 0,0:04:55.75,0:04:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat katakan, di mana ayah dan ibuku?
Dialogue: 0,0:04:59.17,0:05:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ampun!
Dialogue: 0,0:05:01.42,0:05:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti…
Dialogue: 0,0:05:03.09,0:05:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau orang tua si kembar\Nada bersama Kagemori,
Dialogue: 0,0:05:06.63,0:05:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah Desa Higashi akan mengira\NKlan Tadera adalah mata-mata?
Dialogue: 0,0:05:12.18,0:05:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eng, cerita dari mana, ya…
Dialogue: 0,0:05:15.85,0:05:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dilanjutkan!
Dialogue: 0,0:05:18.15,0:05:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau tahu lebih banyak lagi.
Dialogue: 0,0:05:21.57,0:05:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tutup mulut\Nkarena sudah ditolong.
Dialogue: 0,0:05:26.07,0:05:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan bilang ke Asuma
Dialogue: 0,0:05:28.41,0:05:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maupun ke kelompok Desa Higashi.
Dialogue: 0,0:05:32.20,0:05:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:33.58,0:05:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah aku pulang sekarang?
Dialogue: 0,0:05:38.54,0:05:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Tsugai-nya Asuma sudah menyusup,
Dialogue: 0,0:05:41.34,0:05:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat ini sudah ketahuan\Ndan tidak berguna lagi.
Dialogue: 0,0:05:45.34,0:05:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma juga membunuh satu mata-mata.
Dialogue: 0,0:05:50.09,0:05:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, bagaimana?
Dialogue: 0,0:05:51.26,0:05:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:05:52.72,0:05:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi nene--
Dialogue: 0,0:05:54.02,0:05:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi ini sempat mengadukanmu\Nke Tenaga dan Ashinaga, lo.
Dialogue: 0,0:05:58.64,0:06:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar sajalah.
Dialogue: 0,0:06:00.40,0:06:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, dia tidak punya niat membunuh.
Dialogue: 0,0:06:03.02,0:06:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tolok ukur pengampunannya dari situ?{\i0}
Dialogue: 0,0:06:06.44,0:06:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Asal banget.{\i0}
Dialogue: 0,0:06:08.61,0:06:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suamimu juga mata-mata?
Dialogue: 0,0:06:10.82,0:06:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, dia pegawai biasa.
Dialogue: 0,0:06:14.20,0:06:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dia\Ntidak tahu soal pekerjaanku ini.
Dialogue: 0,0:06:17.04,0:06:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja dia pulang.
Dialogue: 0,0:06:19.96,0:06:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:23.29,0:06:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:06:30.51,0:06:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begini nasib orang Kagemori
Dialogue: 0,0:06:33.47,0:06:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang hilang karena membuntuti Tadera.
Dialogue: 0,0:06:36.81,0:06:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenaskan sekali.
Dialogue: 0,0:06:40.02,0:06:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum pulang, izinkan aku mengubur\Ndua rekan yang mati tadi.
Dialogue: 0,0:06:45.53,0:06:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak punya kerabat lain.
Dialogue: 0,0:06:49.28,0:06:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kubur saja di mana pun.
Dialogue: 0,0:06:52.87,0:06:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubantu.
Dialogue: 0,0:06:54.78,0:06:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mudah mau membunuh orang,\Ntapi membantu mengubur musuh sendiri.
Dialogue: 0,0:06:59.87,0:07:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompas moralmu aneh juga.
Dialogue: 0,0:07:03.54,0:07:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mayat tidak dikubur,\Nnanti jadi penyakit.
Dialogue: 0,0:07:07.63,0:07:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu akan membahayakan seluruh desa.
Dialogue: 0,0:07:10.88,0:07:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Oh, aku paham sekarang.{\i0}
Dialogue: 0,0:07:13.89,0:07:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Ken bisa cerita lagi\Nkalau kamu cepat pulang.
Dialogue: 0,0:07:18.31,0:07:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, bantu aku.
Dialogue: 0,0:07:26.07,0:07:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup dalam?
Dialogue: 0,0:07:29.11,0:07:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pakai tangan kosong?
Dialogue: 0,0:07:31.20,0:07:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak perlu alat, dong.
Dialogue: 0,0:07:34.87,0:07:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng…
Dialogue: 0,0:07:36.62,0:07:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Abang…\N- Panggil saja Ryuu.
Dialogue: 0,0:07:39.33,0:07:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryuu.
Dialogue: 0,0:07:40.91,0:07:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengalahkan\NTenaga dan Ashinaga.
Dialogue: 0,0:07:49.55,0:07:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.\NMengontrak Tsugai butuh darah, kan?
Dialogue: 0,0:07:53.97,0:07:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain kalau tuannya mati,\Nbagaimana cara memutus kontraknya?
Dialogue: 0,0:07:58.68,0:08:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai kita harus setuju dulu.
Dialogue: 0,0:08:01.56,0:08:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barulah mereka kembali ke wujud asalnya.
Dialogue: 0,0:08:04.06,0:08:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompromi?
Dialogue: 0,0:08:05.27,0:08:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, meski kamu disebut tuan,
Dialogue: 0,0:08:08.19,0:08:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kedudukan kalian setara.
Dialogue: 0,0:08:10.44,0:08:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai juga punya perasaan.
Dialogue: 0,0:08:13.61,0:08:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, masuk akal.
Dialogue: 0,0:08:17.12,0:08:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga sama?
Dialogue: 0,0:08:18.37,0:08:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kalau kamu memintanya,\Nkami akan kembali ke pintu masuk desa.
Dialogue: 0,0:08:24.62,0:08:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Agak disayangkan tapi begitulah aturannya.
Dialogue: 0,0:08:28.17,0:08:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Soalnya jarang-jarang kami boleh\Nbertindak bebas begini.
Dialogue: 0,0:08:32.72,0:08:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sejujurnya, kami ingin lebih menikmati\Ndunia ini setelah 400 tahun.
Dialogue: 0,0:08:37.47,0:08:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah, Bocah!
Dialogue: 0,0:08:39.97,0:08:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak semua Tsugai itu\Npengertian seperti kami.
Dialogue: 0,0:08:44.23,0:08:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membebaskan Tsugai sembarangan.
Dialogue: 0,0:08:47.52,0:08:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti!
Dialogue: 0,0:08:50.65,0:08:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuu bisa menyegel secara paksa\NTsugai sekuat apa pun
Dialogue: 0,0:08:54.74,0:08:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa perlu aturan yang ribet.
Dialogue: 0,0:08:58.49,0:09:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kai menghasilkan Tsugai liar.
Dialogue: 0,0:09:01.49,0:09:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Fuu mengubah Tsugai\Nke wujud asalnya sebelum disegel.
Dialogue: 0,0:09:04.75,0:09:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang penuh belas kasih.
Dialogue: 0,0:09:12.42,0:09:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kota sebelumnya.
Dialogue: 0,0:09:15.01,0:09:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah ada di dunia biasa,\Nbisa pulang sendiri, kan?
Dialogue: 0,0:09:18.97,0:09:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:09:21.31,0:09:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:09:22.93,0:09:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam buat Kagemori Asuma, Bibi.
Dialogue: 0,0:09:33.07,0:09:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pensiun saja, deh.
Dialogue: 0,0:09:43.37,0:09:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu…
Dialogue: 0,0:09:46.16,0:09:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken, ceritakan semua yang kamu tahu.
Dialogue: 0,0:09:49.96,0:09:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, aku tidak tahu\Norang tua Yuru ada di mana.
Dialogue: 0,0:09:55.46,0:10:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ayahku saja entah di mana.
Dialogue: 0,0:10:00.80,0:10:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendahulu masih hidup atau tidak, ya?
Dialogue: 0,0:10:03.76,0:10:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga tidak tahu Ayah ada di mana?
Dialogue: 0,0:10:08.39,0:10:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:10:09.81,0:10:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Dera menyebutnya pendahulu,
Dialogue: 0,0:10:12.44,0:10:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kukira dia sudah mati.
Dialogue: 0,0:10:15.48,0:10:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah bilang dia mati.
Dialogue: 0,0:10:19.07,0:10:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai ini pun milik Klan Tadera,\Nbukan milikku.
Dialogue: 0,0:10:24.58,0:10:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Pendahulu yang punya kontraknya,\Ntapi pergi tanpa mewariskannya padaku.
Dialogue: 0,0:10:30.00,0:10:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, pantas saja tidak ada reaksi\Nmeski nyawamu terancam.
Dialogue: 0,0:10:34.42,0:10:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Tsugai cenderung\Nmelindungi tuannya.
Dialogue: 0,0:10:38.09,0:10:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah memberitahuku banyak hal soal Tsugai.
Dialogue: 0,0:10:42.09,0:10:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya buat jaga-jaga.
Dialogue: 0,0:10:44.81,0:10:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang Ayah mendadak menemui Ibu,
Dialogue: 0,0:10:48.64,0:10:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu mendadak pergi lagi.
Dialogue: 0,0:10:51.56,0:10:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah dia.
Dialogue: 0,0:10:52.86,0:10:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu baru saja meninggal.
Dialogue: 0,0:10:55.78,0:10:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah tidak bisa dihubungi.
Dialogue: 0,0:10:58.99,0:11:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku sendirian.
Dialogue: 0,0:11:01.53,0:11:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena berpikir harus jadi kuat\Nagar bisa hidup sendiri,
Dialogue: 0,0:11:05.08,0:11:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mencoba mencari Tsugai kuat.
Dialogue: 0,0:11:08.20,0:11:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menemukan\Ndan mengontrak Tenaga dan Ashinaga,
Dialogue: 0,0:11:12.58,0:11:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata mereka jahat.
Dialogue: 0,0:11:14.96,0:11:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai tuan, aku memang tidak disakiti.
Dialogue: 0,0:11:20.01,0:11:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi juga tidak dipatuhi.
Dialogue: 0,0:11:23.47,0:11:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bahaya kalau mereka dibiarkan bebas.
Dialogue: 0,0:11:27.47,0:11:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kamu mengurung mereka\Ndi Mayoiga ini?
Dialogue: 0,0:11:31.06,0:11:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku sudah diajarkan\Ncara keluar masuk sini.
Dialogue: 0,0:11:35.19,0:11:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendahulu mewarisiku pekerjaan ini\Nsepuluh tahun lalu.
Dialogue: 0,0:11:39.36,0:11:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat saat orang tua Yuru kabur dari desa.
Dialogue: 0,0:11:42.36,0:11:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba dia melimpahkan\Nsemua tugas Tadera dan pergi.
Dialogue: 0,0:11:48.04,0:11:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya hilang kontak, deh.
Dialogue: 0,0:11:50.58,0:11:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Pendahulu sialan!\NKarena tahu hal ini bakal merepotkan,
Dialogue: 0,0:11:54.92,0:11:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}dia malah mewariskannya padaku.
Dialogue: 0,0:11:58.63,0:12:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti waktu itu kamu sudah lahir, dong?
Dialogue: 0,0:12:03.22,0:12:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski jarang membahas soal pekerjaannya,
Dialogue: 0,0:12:07.30,0:12:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kadang Ayah curhat kalau sedang mabuk.
Dialogue: 0,0:12:11.56,0:12:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagisa orang dataran rendah, kan?
Dialogue: 0,0:12:14.23,0:12:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya dia tahu bahwa ayahku\Nsesama orang dataran rendah.
Dialogue: 0,0:12:18.65,0:12:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Ayah diancam habis-habisan
Dialogue: 0,0:12:22.15,0:12:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar memberi tahu jalur keluar desa.
Dialogue: 0,0:12:25.20,0:12:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Wanita itu terlihat kalem\Ntapi menyeramkan."
Dialogue: 0,0:12:28.58,0:12:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah kata ayahku.
Dialogue: 0,0:12:32.04,0:12:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ibu hebat juga.{\i0}
Dialogue: 0,0:12:33.79,0:12:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah memang kurang setuju\Nsoal tradisi si kembar Desa Higashi.
Dialogue: 0,0:12:39.80,0:12:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tidak ikut campur lagi\Nselain mengajari mereka cara kabur.
Dialogue: 0,0:12:46.09,0:12:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja itu dianggap mengkhianati desa.
Dialogue: 0,0:12:49.43,0:12:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertikaian panjang dengan\NKlan Kagemori pun
Dialogue: 0,0:12:52.93,0:12:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatnya tidak punya tempat bernaung.
Dialogue: 0,0:12:55.19,0:12:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu alasannya pensiun.
Dialogue: 0,0:13:01.03,0:13:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hana, kami pulang.
Dialogue: 0,0:13:02.90,0:13:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru!
Dialogue: 0,0:13:04.07,0:13:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu terluka?
Dialogue: 0,0:13:06.36,0:13:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini cuma luka kecil.
Dialogue: 0,0:13:09.07,0:13:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah pergi diam-diam.
Dialogue: 0,0:13:11.41,0:13:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir, tahu!
Dialogue: 0,0:13:13.79,0:13:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung kamu selamat, syukurlah!
Dialogue: 0,0:13:17.25,0:13:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hana terlihat sangat mengkhawatirkanku.{\i0}
Dialogue: 0,0:13:20.96,0:13:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia memang baik.{\i0}
Dialogue: 0,0:13:22.84,0:13:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untung enggak perlu bayar rumah sakit.{\i0}
Dialogue: 0,0:13:28.64,0:13:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski mendatangi keluarga Kagemori,\Naku kaget kamu masih utuh, Dera.
Dialogue: 0,0:13:34.43,0:13:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang terjadi.
Dialogue: 0,0:13:37.81,0:13:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Penjelasannya nanti saja,\Naku mau istirahat dulu.
Dialogue: 0,0:13:43.15,0:13:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judi?
Dialogue: 0,0:13:44.82,0:13:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main wanita?
Dialogue: 0,0:13:47.24,0:13:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:13:49.95,0:13:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan, namaku Tadera Ken.
Dialogue: 0,0:13:53.95,0:13:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadera?
Dialogue: 0,0:13:56.83,0:13:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak gelap?
Dialogue: 0,0:13:59.46,0:14:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, berapa total asetmu?
Dialogue: 0,0:14:01.92,0:14:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, dia mau minta tunjangan perceraian!
Dialogue: 0,0:14:05.34,0:14:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya uang,\Ntapi punya tanah dan rumah.
Dialogue: 0,0:14:08.26,0:14:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu Tsugai Klan Tadera,\Ntidak bisa jadi tunjangan.
Dialogue: 0,0:14:13.56,0:14:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai yang bisa kena pajak properti?
Dialogue: 0,0:14:22.44,0:14:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang, aku Danno Hana.
Dialogue: 0,0:14:25.15,0:14:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai abdi alias tukang suruh,
Dialogue: 0,0:14:28.24,0:14:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tinggal di dataran rendah\Nsama anjing dan kucing yang lucu.
Dialogue: 0,0:14:31.28,0:14:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi suatu hari,{\i0}
Dialogue: 0,0:14:33.08,0:14:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku tiba-tiba dipaksa menikah\Noleh seniorku yang bernama Dera.{\i0}
Dialogue: 0,0:14:38.50,0:14:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku maunya nikah sama Jason Statham!
Dialogue: 0,0:14:43.17,0:14:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan anak bawaannya juga bermasalah.{\i0}
Dialogue: 0,0:14:46.17,0:14:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selain ketagihan judi, suka main wanita,\Ndan propertinya yang tidak laku,{\i0}
Dialogue: 0,0:14:51.30,0:14:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ternyata…{\i0}
Dialogue: 0,0:14:52.68,0:14:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Suamiku punya anak gelap!{\i0}
Dialogue: 0,0:14:54.68,0:15:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kisah pengantin baru\Nyang penuh kejutan tidak terduga.
Dialogue: 0,0:15:01.02,0:15:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang, dia bukan anakku.
Dialogue: 0,0:15:04.57,0:15:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, jadi…
Dialogue: 0,0:15:06.53,0:15:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dibantu Penjaga Ilahi Sayuu\Nmelacak si adik demi mencari orang tuamu
Dialogue: 0,0:15:11.07,0:15:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tiba di wilayah Klan Kagemori.
Dialogue: 0,0:15:13.78,0:15:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diculik pihak ketiga\Ntapi berhasil melawan.
Dialogue: 0,0:15:17.75,0:15:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara dengan kepala Klan Kagemori.
Dialogue: 0,0:15:20.66,0:15:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu pulangnya judi, main wanita,\Ndan memboyong anak gelap?
Dialogue: 0,0:15:24.67,0:15:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main wanita dan anak gelapnya salah!
Dialogue: 0,0:15:27.30,0:15:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau judi, benar?
Dialogue: 0,0:15:29.84,0:15:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:31.38,0:15:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Pendahulu tidak memberitahuku,\Ndia bukan anak gelap.
Dialogue: 0,0:15:36.51,0:15:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak haram?
Dialogue: 0,0:15:37.43,0:15:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, jaga bahasamu.
Dialogue: 0,0:15:39.18,0:15:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendahulu dan ibuku sudah lama bercerai.
Dialogue: 0,0:15:43.48,0:15:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia menikah lagi sama ibu Ken.
Dialogue: 0,0:15:46.61,0:15:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak berhak komentar soal itu.
Dialogue: 0,0:15:49.65,0:15:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya…
Dialogue: 0,0:15:51.32,0:15:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tampung dia untuk sementara.
Dialogue: 0,0:15:53.78,0:15:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga!
Dialogue: 0,0:15:54.82,0:15:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak punya tempat tinggal,\Nkasihan, kan?
Dialogue: 0,0:15:58.91,0:16:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang, aku benci anak-anak!
Dialogue: 0,0:16:01.79,0:16:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah mau ditambah?
Dialogue: 0,0:16:04.08,0:16:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih banyak pekerja itu bagus, kan?\NBanyak anak banyak rezeki.
Dialogue: 0,0:16:07.84,0:16:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tren zaman sekarang itu hidup tanpa anak!
Dialogue: 0,0:16:10.30,0:16:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan jangan suruh anak-anak bekerja!
Dialogue: 0,0:16:12.51,0:16:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kita tidak tahu\Ndia kawan atau lawan.
Dialogue: 0,0:16:16.93,0:16:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, dia tidak punya niat membunuh.
Dialogue: 0,0:16:22.35,0:16:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru.
Dialogue: 0,0:16:24.06,0:16:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kamu lebih hati-hati menilai.
Dialogue: 0,0:16:28.02,0:16:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya…
Dialogue: 0,0:16:31.69,0:16:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu…
Dialogue: 0,0:16:33.20,0:16:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku tidak punya niat membunuh.
Dialogue: 0,0:16:37.66,0:16:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana kalau aku
Dialogue: 0,0:16:39.79,0:16:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendadak ingin membunuhmu?
Dialogue: 0,0:16:43.04,0:16:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hana, dilarang KDRT.
Dialogue: 0,0:16:49.50,0:16:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah paham, kan, Yuru?
Dialogue: 0,0:16:51.34,0:16:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang paling ngeri kalau dibikin emosi\Ndi rumah ini adalah Hana.
Dialogue: 0,0:16:56.09,0:16:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa kamu suka bikin aku emosi?
Dialogue: 0,0:17:00.68,0:17:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang terkait\NDesa Higashi begini semua?
Dialogue: 0,0:17:05.06,0:17:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak aneh kalau aku yang bilang.
Dialogue: 0,0:17:07.44,0:17:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang berkaitan Desa Higashi\Ntidak ada yang normal.
Dialogue: 0,0:17:11.98,0:17:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun bocah ini punya niat buruk,
Dialogue: 0,0:17:15.74,0:17:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita jelas-jelas menang jumlah.
Dialogue: 0,0:17:19.07,0:17:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tapi…
Dialogue: 0,0:17:21.41,0:17:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, ibuku memberikan ini.
Dialogue: 0,0:17:25.54,0:17:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya untuk biaya hidup.
Dialogue: 0,0:17:28.50,0:17:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku tabungan?
Dialogue: 0,0:17:29.46,0:17:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:17:30.79,0:17:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semacam catatan penyimpanan harta.
Dialogue: 0,0:17:35.88,0:17:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saldonya tidak ketahuan\Nsaking lamanya tidak dipakai.
Dialogue: 0,0:17:39.93,0:17:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, tolong perbarui catatannya.
Dialogue: 0,0:17:42.14,0:17:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:17:44.39,0:17:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian beli makanan juga, ya.
Dialogue: 0,0:17:46.60,0:17:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:17:49.10,0:17:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tiba-tiba posisi\Nsenior juniornya berbalik.{\i0}
Dialogue: 0,0:17:55.28,0:17:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:17:57.61,0:18:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hana, kayaknya Ken memang harus ditampung.
Dialogue: 0,0:18:01.62,0:18:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:07.83,0:18:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken, identitasmu sudah terdaftar?
Dialogue: 0,0:18:10.17,0:18:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sebagai warga Jepang.
Dialogue: 0,0:18:13.00,0:18:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu boleh tinggal di sini selamanya, kok.
Dialogue: 0,0:18:16.59,0:18:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:18:20.72,0:18:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uangnya banyak banget!\NIni kayak bukan tabungan anak-anak.
Dialogue: 0,0:18:25.81,0:18:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain banyak,
Dialogue: 0,0:18:28.73,0:18:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini ditransfer tiap bulan.
Dialogue: 0,0:18:31.19,0:18:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin tunjangan anak.
Dialogue: 0,0:18:33.07,0:18:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahmu bertanggung jawab dan baik sekali!
Dialogue: 0,0:18:36.86,0:18:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada!\NAku tidak pernah diperlakukan begini.
Dialogue: 0,0:18:41.12,0:18:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, bahkan tadi baru ditransfer.
Dialogue: 0,0:18:44.74,0:18:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendahuluku ternyata masih hidup.
Dialogue: 0,0:18:47.75,0:18:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:18:48.87,0:18:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cari dia.
Dialogue: 0,0:18:50.00,0:18:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya…
Dialogue: 0,0:18:52.50,0:18:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken, kamu punya foto Pendahulu?
Dialogue: 0,0:18:55.88,0:18:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak.
Dialogue: 0,0:18:59.01,0:19:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak mau difoto.
Dialogue: 0,0:19:00.76,0:19:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, kan, aku juga tidak punya\Nfotonya sama sekali.
Dialogue: 0,0:19:05.85,0:19:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu bagaimana cara mencarinya?
Dialogue: 0,0:19:09.14,0:19:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula di luar sana,\Npasti dia pakai nama palsu.
Dialogue: 0,0:19:12.65,0:19:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin harus dicari lewat ibunya Ken.
Dialogue: 0,0:19:15.82,0:19:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu Ibu bekerja di bar daerah Katsushika.
Dialogue: 0,0:19:20.32,0:19:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Ibu meninggal,\Nsemua temannya kutanyai
Dialogue: 0,0:19:23.57,0:19:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal keberadaan Ayah, tapi…
Dialogue: 0,0:19:27.08,0:19:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang tahu, ya?
Dialogue: 0,0:19:30.00,0:19:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:32.50,0:19:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dia tidak kunjung\Ntertangkap Klan Kagemori.
Dialogue: 0,0:19:36.21,0:19:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, biar kutanyakan diam-diam\Nke komunitas Desa Higashi.
Dialogue: 0,0:19:41.72,0:19:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ogah terlibat.
Dialogue: 0,0:19:44.14,0:19:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukanlah sendiri.
Dialogue: 0,0:19:46.35,0:19:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, deh.
Dialogue: 0,0:19:48.14,0:19:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan ini pada orang dewasa.
Dialogue: 0,0:19:50.48,0:19:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian para bocah harus mandi\Ndan tidur sehabis makan.
Dialogue: 0,0:19:54.23,0:19:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:19:59.48,0:20:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benaran boleh memakai\Nair hangat sebanyak ini?
Dialogue: 0,0:20:02.95,0:20:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya mubazir banget!
Dialogue: 0,0:20:15.88,0:20:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru,\Nkamu yakin mau pakai futon setipis itu?
Dialogue: 0,0:20:20.21,0:20:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru aku susah tidur kalau keempukan.
Dialogue: 0,0:20:23.72,0:20:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, futon bagusnya malah kupakai.
Dialogue: 0,0:20:29.43,0:20:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu kerabat Dera,\Njadi sudah seperti keluarga sendiri.
Dialogue: 0,0:20:33.23,0:20:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sungkan.
Dialogue: 0,0:20:34.44,0:20:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:36.27,0:20:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga ayahmu cepat ketemu.
Dialogue: 0,0:20:39.98,0:20:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku harus mengabarinya\Nsoal kematian ibu.
Dialogue: 0,0:21:01.34,0:21:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga orang tuamu juga cepat ketemu.
Dialogue: 0,0:21:08.51,0:21:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:21.19,0:21:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:21:22.53,0:21:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunya Ken.
Dialogue: 0,0:21:25.15,0:21:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum tau mau dimakamkan di mana.
Dialogue: 0,0:21:27.57,0:21:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abu jenazahnya, ya.
Dialogue: 0,0:21:33.33,0:21:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Ken berkenan,
Dialogue: 0,0:21:35.79,0:21:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa mencarikan tempat bagus\Ndi gunungku.
Dialogue: 0,0:21:39.00,0:21:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya, Hana si Penggali Kubur.
Dialogue: 0,0:21:42.50,0:21:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga siap menggali\Nkuburanmu kapan saja.
Dialogue: 0,0:21:48.68,0:21:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:21:53.10,0:21:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:23:29.49,0:23:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Senang mendengar suaramu.{\i0}
Dialogue: 0,0:23:31.24,0:23:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada garis tipis di sini.{\i0}
Dialogue: 0,0:23:33.99,0:23:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kayak bekas pisau cukur?{\i0}
Dialogue: 0,0:23:35.99,0:23:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Halo, Paman.{\i0}
