Dialogue: 0,0:03:09.89,0:03:11.69,tanda,,0000,0000,0000,,{\an8}MAJU KENA HARIMAU MUNDUR KENA SERIGALA
Dialogue: 0,0:03:16.77,0:03:18.32,tanda,,0000,0000,0000,,{\an8}DANNO
Dialogue: 0,0:10:43.64,0:10:45.31,tanda,,0000,0000,0000,,KLINIK HEWAN
Dialogue: 0,0:10:45.31,0:10:46.89,tanda,,0000,0000,0000,,YAKINIKU IOGI
Dialogue: 0,0:10:48.43,0:10:49.89,tanda,,0000,0000,0000,,PINTU MASUK
Dialogue: 0,0:10:49.89,0:10:51.27,tanda,,0000,0000,0000,,PINTU KELUAR
Dialogue: 0,0:23:27.61,0:23:28.98,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:36.42,0:01:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk.
Dialogue: 0,0:01:42.51,0:01:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata isi kastel batunya seperti ini?
Dialogue: 0,0:01:46.64,0:01:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Listrik dan air sudah bisa dipakai.
Dialogue: 0,0:01:49.06,0:01:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saluran gasnya akan dibuka nanti.
Dialogue: 0,0:01:52.02,0:01:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, pakailah kamar yang itu.
Dialogue: 0,0:01:55.90,0:01:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru mau kamar dengan tatami, kan?
Dialogue: 0,0:01:58.28,0:01:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatami?
Dialogue: 0,0:02:01.95,0:02:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tatami!
Dialogue: 0,0:02:03.16,0:02:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di desaku, cuma bisa dipakai Asa\Natau saat ada acara khusus saja!
Dialogue: 0,0:02:07.71,0:02:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya yang di desamu itu tikar?
Dialogue: 0,0:02:11.25,0:02:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatami dataran rendah tebal sekali, ya.
Dialogue: 0,0:02:14.80,0:02:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mewah sekali!
Dialogue: 0,0:02:17.09,0:02:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku benaran boleh tidur di sini?
Dialogue: 0,0:02:25.60,0:02:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf, biar kuperkenalkan.
Dialogue: 0,0:02:29.14,0:02:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Kotetsu dan Jirou.
Dialogue: 0,0:02:32.90,0:02:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami masuk, ya.
Dialogue: 0,0:02:36.94,0:02:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami Tsugai miliknya\Ndan akan tinggal bersama kalian.
Dialogue: 0,0:02:39.99,0:02:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dipanggil Penjaga Ilahi Sayuu.
Dialogue: 0,0:02:42.16,0:02:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Migi.
Dialogue: 0,0:02:44.12,0:02:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku Hidari, salam kenal.
Dialogue: 0,0:02:50.25,0:02:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian Tsugai-nya Hana?
Dialogue: 0,0:02:52.75,0:02:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:02:54.67,0:02:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka Tsugai? Anjing dan kucing ini?
Dialogue: 0,0:03:00.51,0:03:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bukan hewan biasa.
Dialogue: 0,0:03:02.93,0:03:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan tinggal bersama,\Nberilah salam yang sopan.
Dialogue: 0,0:03:06.89,0:03:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Tsugai-ku, "Maju Kena Harimau\NMundur Kena Serigala".
Dialogue: 0,0:03:12.27,0:03:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:03:18.32,0:03:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Danno?
Dialogue: 0,0:03:19.28,0:03:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena nama Dera ketahuan,
Dialogue: 0,0:03:21.95,0:03:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih aman pakai margaku, kan?
Dialogue: 0,0:03:24.20,0:03:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkan.
Dialogue: 0,0:03:26.66,0:03:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga pakai marga ini, ya.
Dialogue: 0,0:03:29.45,0:03:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian punya marga?
Dialogue: 0,0:03:32.83,0:03:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian dari keluarga terpandang?
Dialogue: 0,0:03:34.92,0:03:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya marga itu hal biasa di sini.
Dialogue: 0,0:03:37.67,0:03:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hana bahkan punya gunung, lo.
Dialogue: 0,0:03:39.88,0:03:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tuan tanah?
Dialogue: 0,0:03:41.13,0:03:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma warisan keluargaku!
Dialogue: 0,0:03:44.09,0:03:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula gunungnya telantar.
Dialogue: 0,0:03:46.55,0:03:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dijual.
Dialogue: 0,0:03:49.10,0:03:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh berburu di sana?
Dialogue: 0,0:03:50.60,0:03:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enteng banget ucapanmu.
Dialogue: 0,0:03:53.19,0:03:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu butuh lisensi buat berburu di sini.
Dialogue: 0,0:03:55.61,0:03:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lisensi?
Dialogue: 0,0:03:56.56,0:03:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, surat izin.
Dialogue: 0,0:03:58.23,0:04:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengendarai kereta kuda besi juga\Nbutuh surat izin.
Dialogue: 0,0:04:01.65,0:04:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dataran rendah merepotkan.
Dialogue: 0,0:04:30.85,0:04:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup.
Dialogue: 0,0:04:35.81,0:04:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak sesuai ekspektasiku.{\i0}
Dialogue: 0,0:04:38.19,0:04:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sedang latihan, ya.
Dialogue: 0,0:04:41.19,0:04:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master.
Dialogue: 0,0:04:43.53,0:04:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai.
Dialogue: 0,0:04:47.12,0:04:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, halamanmu rusak\Nkarena akurasiku masih jelek.
Dialogue: 0,0:04:51.62,0:04:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:04:53.79,0:04:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama tidak ada korban jiwa,\Nberlatihlah sepuasmu.
Dialogue: 0,0:04:57.58,0:04:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin, segera bereskan.
Dialogue: 0,0:04:59.88,0:05:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik. Ai.
Dialogue: 0,0:05:12.72,0:05:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada keperluan datang kemari?
Dialogue: 0,0:05:14.98,0:05:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, mau menjenguk Gabuchan.
Dialogue: 0,0:05:18.48,0:05:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh,\Npadahal tidak perlu repot-repot datang.
Dialogue: 0,0:05:22.19,0:05:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisimu?
Dialogue: 0,0:05:23.82,0:05:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah membaik, terima kasih.
Dialogue: 0,0:05:26.57,0:05:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabriel, apa kabar?
Dialogue: 0,0:05:30.20,0:05:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu rupanya.
Dialogue: 0,0:05:32.54,0:05:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan, mau makan apel?
Dialogue: 0,0:05:34.58,0:05:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau!
Dialogue: 0,0:05:35.50,0:05:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku lupa bawa pisau.
Dialogue: 0,0:05:39.63,0:05:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makoto.
Dialogue: 0,0:05:44.05,0:05:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:05:45.42,0:05:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:47.34,0:05:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku disuruh makan apel\Nhasil potongan pisau
Dialogue: 0,0:05:50.76,0:05:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang asalnya tidak jelas?
Dialogue: 0,0:05:52.97,0:05:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman,\Nkurasa ini bukan bekas menikam orang.
Dialogue: 0,0:05:56.18,0:05:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Jin…
Dialogue: 0,0:06:03.86,0:06:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan, fokuslah pada penyembuhanmu.
Dialogue: 0,0:06:06.44,0:06:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:06:08.20,0:06:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Asa, tinggallah juga di wisma ini.\N- Eh?
Dialogue: 0,0:06:12.03,0:06:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kabar bahwa kamu dan kakakmu\Nada di dataran rendah meluas,
Dialogue: 0,0:06:16.58,0:06:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti banyak yang mengincar kalian.
Dialogue: 0,0:06:19.71,0:06:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kalian bisa saja diincar\Norang dalam Klan Kagemori.
Dialogue: 0,0:06:24.80,0:06:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di wisma ini kamu akan aman.
Dialogue: 0,0:06:27.88,0:06:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar Jin yang mencari Yuru, oke?
Dialogue: 0,0:06:31.89,0:06:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:06:33.72,0:06:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Naku tidak tahu wajah si Abang.
Dialogue: 0,0:06:37.81,0:06:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, sayang tidak kufoto.
Dialogue: 0,0:06:43.02,0:06:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seperti ini!\N- Subjektif.
Dialogue: 0,0:06:44.86,0:06:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seperti ini!\N- Artistik?
Dialogue: 0,0:06:47.44,0:06:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artistik!
Dialogue: 0,0:06:49.70,0:06:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutelusuri mulai dari Klan Tadera.
Dialogue: 0,0:06:52.12,0:06:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:06:56.66,0:06:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin.
Dialogue: 0,0:07:00.12,0:07:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:02.00,0:07:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai kakak punya penciuman tajam
Dialogue: 0,0:07:04.75,0:07:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai bisa mengenali orang\Ndari bau darahnya.
Dialogue: 0,0:07:11.80,0:07:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artistik…
Dialogue: 0,0:07:17.47,0:07:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segar banget!
Dialogue: 0,0:07:21.60,0:07:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Berewokmu…
Dialogue: 0,0:07:24.23,0:07:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cukur karena keburu dikenali,\Nminimal harus menyamar sedikit.
Dialogue: 0,0:07:28.69,0:07:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aspek mirip Statham-nya hilang, dong.
Dialogue: 0,0:07:31.32,0:07:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak bernilai!
Dialogue: 0,0:07:33.53,0:07:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru juga menikah,\Nistriku langsung bikin kena mental.
Dialogue: 0,0:07:42.08,0:07:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana putra kita?
Dialogue: 0,0:07:44.13,0:07:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru baru saja pergi,\Nkatanya mau jalan-jalan.
Dialogue: 0,0:07:47.75,0:07:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia akan aman?
Dialogue: 0,0:07:49.84,0:07:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Penjaga Ilahi Sayuu, seharusnya aman.
Dialogue: 0,0:07:53.93,0:07:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hana, kamu lihat parangku?
Dialogue: 0,0:07:56.80,0:07:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kupindahkan, kok.
Dialogue: 0,0:07:58.72,0:08:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menaruhnya di pintu masuk.
Dialogue: 0,0:08:01.85,0:08:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Yuru jalan-jalan sejauh mana, ya?
Dialogue: 0,0:08:08.07,0:08:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tertangkap, dia bakal repot\Nkena undang-undang kepemilikan senjata.
Dialogue: 0,0:08:12.82,0:08:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah kubilang jangan berulah!\NBocah tengik!
Dialogue: 0,0:08:20.70,0:08:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dataran rendah menakjubkan.
Dialogue: 0,0:08:23.58,0:08:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanahnya pun punya ribuan bintang.
Dialogue: 0,0:08:26.42,0:08:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luas sekali.
Dialogue: 0,0:08:27.96,0:08:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking luasnya tempat ini,
Dialogue: 0,0:08:30.46,0:08:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu ragu bisa mencari adikmu?
Dialogue: 0,0:08:35.47,0:08:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia juga mencarimu,\Nnanti juga bakal bertemu.
Dialogue: 0,0:08:41.10,0:08:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap, sehati sejiwa.
Dialogue: 0,0:08:47.73,0:08:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bisa merasakan\Nkeberadaan Tsugai lain, kan?
Dialogue: 0,0:08:52.11,0:08:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seperti saat bertemu Oshirasama.\N- Iya.
Dialogue: 0,0:08:55.78,0:08:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga tahu bau darah Asa, kan?
Dialogue: 0,0:08:58.95,0:08:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:01.12,0:09:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera bilang, Klan Kagemori\Npunya banyak pengguna Tsugai.
Dialogue: 0,0:09:06.96,0:09:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti tempat yang Tsugai-nya banyak\Ndan punya bau darah sepertiku.
Dialogue: 0,0:09:13.88,0:09:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa akan berhasil.
Dialogue: 0,0:09:15.76,0:09:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:09:25.52,0:09:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo asah insting kita!
Dialogue: 0,0:10:03.43,0:10:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bau darah seperti milikmu
Dialogue: 0,0:10:06.02,0:10:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan beberapa Tsugai di sini.
Dialogue: 0,0:10:08.64,0:10:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Tsugai di dekat sini?
Dialogue: 0,0:10:11.73,0:10:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau muncul, boleh langsung kuhajar?
Dialogue: 0,0:10:15.78,0:10:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau Tsugai itu\Nbisa kompromi kayak Oshirasama?
Dialogue: 0,0:10:20.41,0:10:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menilai pakai tolok ukur manusia.
Dialogue: 0,0:10:24.58,0:10:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia kita berbeda, jangan pikir\Nsemuanya bisa saling memahami.
Dialogue: 0,0:10:29.87,0:10:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kuanggap mereka\Nseperti beruang atau babi hutan.
Dialogue: 0,0:10:33.92,0:10:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal banget.
Dialogue: 0,0:10:57.03,0:10:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan Tadera.
Dialogue: 0,0:10:58.99,0:11:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, mungkin dia sudah pergi jauh.
Dialogue: 0,0:11:03.53,0:11:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kalau ada info baru,\Ntolong kabari aku.
Dialogue: 0,0:11:08.45,0:11:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, bau Tsugai dan Asa\Ntercium dari mereka.
Dialogue: 0,0:11:14.25,0:11:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}arena kita menyadari mereka,
Dialogue: 0,0:11:16.59,0:11:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai mereka pun\Npasti menyadari keberadaan kita.
Dialogue: 0,0:11:20.17,0:11:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa melihatnya?
Dialogue: 0,0:11:21.38,0:11:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:11:23.55,0:11:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Para pria baju hitam itu manusia?
Dialogue: 0,0:11:26.35,0:11:27.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Manusia.
Dialogue: 0,0:11:44.32,0:11:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa!
Dialogue: 0,0:11:45.57,0:11:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu Yuru! Bau darahnya sudah lama!
Dialogue: 0,0:11:48.04,0:11:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia…
Dialogue: 0,0:12:01.97,0:12:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, penciuman Tsugai-mu tajam.
Dialogue: 0,0:12:06.76,0:12:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, karena bereaksi terhadap Asa ini,
Dialogue: 0,0:12:11.48,0:12:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti kamu si Abang, ya?
Dialogue: 0,0:12:15.23,0:12:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal, aku Kagemori Jin.
Dialogue: 0,0:12:19.19,0:12:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah Tsugai milikku, Pengais.
Dialogue: 0,0:12:23.32,0:12:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu, Yuru.
Dialogue: 0,0:12:31.50,0:12:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, gawat, gawat!
Dialogue: 0,0:12:34.29,0:12:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, ayo cari Yuru!
Dialogue: 0,0:12:36.71,0:12:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:12:38.54,0:12:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena belum tahu aturan dataran rendah,\Nmungkin saja dia melukai orang lain.
Dialogue: 0,0:12:43.34,0:12:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang mungkin.
Dialogue: 0,0:12:45.38,0:12:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bisa gawat kalau dia terluka!
Dialogue: 0,0:12:48.60,0:12:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bilang benci anak-anak,
Dialogue: 0,0:12:51.35,0:12:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata kamu baik hati.
Dialogue: 0,0:12:53.73,0:12:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah? Kamu bicara apa, sih?\N- Eh?
Dialogue: 0,0:12:57.23,0:13:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia belum punya identitas resmi\Ndataran rendah, lo!
Dialogue: 0,0:13:00.73,0:13:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:13:02.65,0:13:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga datang dari gunung.
Dialogue: 0,0:13:05.36,0:13:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, berarti…
Dialogue: 0,0:13:10.20,0:13:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tanpa kartu asuransi, biaya pengobatannya\Nharus kami tanggung sendiri!{\i0}
Dialogue: 0,0:13:14.71,0:13:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh.\N- Jirou.
Dialogue: 0,0:13:17.83,0:13:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baunya Yuru, kejar dia.
Dialogue: 0,0:13:25.34,0:13:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:13:33.35,0:13:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kotetsu, bantu aku.
Dialogue: 0,0:13:40.40,0:13:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Kotetsu dan Jirou\NTsugai yang melek teknologi.
Dialogue: 0,0:13:43.57,0:13:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai Tsugai turun-temurun,
Dialogue: 0,0:13:45.78,0:13:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka sudah lama\Ndan terbiasa hidup di sini.
Dialogue: 0,0:13:49.32,0:13:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Jirou ada di mana, ya?
Dialogue: 0,0:13:53.58,0:13:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa sampai Tokyo?
Dialogue: 0,0:13:57.04,0:13:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali.
Dialogue: 0,0:13:59.12,0:14:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena Penjaga Ilahi Sayuu.
Dialogue: 0,0:14:01.54,0:14:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kesasar? Tidak.{\i0}
Dialogue: 0,0:14:04.76,0:14:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang mereka cari?{\i0}
Dialogue: 0,0:14:10.97,0:14:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Desa Higashi juga ingin\Nsi kembar dalam kontrol mereka.{\i0}
Dialogue: 0,0:14:16.85,0:14:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi… "Dalam kondisi desa\Nyang tercerai-berai akibat diserang,
Dialogue: 0,0:14:22.48,0:14:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mustahil mereka datang mencari Asa".
Dialogue: 0,0:14:25.44,0:14:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka ingin kami berpikir begitu\Nsupaya bisa cari celah.
Dialogue: 0,0:14:32.28,0:14:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami sudah siap untuk ini.
Dialogue: 0,0:14:35.20,0:14:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak perlu repot mencarimu, deh.
Dialogue: 0,0:14:38.66,0:14:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Bang.
Dialogue: 0,0:14:46.26,0:14:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Keras banget.{\i0}
Dialogue: 0,0:14:47.80,0:14:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Tsugai, kalian bersembunyi, kan?
Dialogue: 0,0:14:50.38,0:14:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarlah.
Dialogue: 0,0:14:54.93,0:14:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:14:55.85,0:14:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mencium bau besi,
Dialogue: 0,0:14:58.93,0:15:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya mereka tidak bersenjata.
Dialogue: 0,0:15:01.73,0:15:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku merasakan Tsugai lain, lo.
Dialogue: 0,0:15:04.48,0:15:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada dua pasang lagi.
Dialogue: 0,0:15:06.44,0:15:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Tsugai milik dua orang sisanya.
Dialogue: 0,0:15:08.99,0:15:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya mereka bersembunyi\Nsambil mengintai gerak kita.
Dialogue: 0,0:15:22.63,0:15:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah.
Dialogue: 0,0:15:24.75,0:15:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalani saja dulu.
Dialogue: 0,0:15:26.88,0:15:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka muncul!
Dialogue: 0,0:15:28.80,0:15:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti.
Dialogue: 0,0:15:30.42,0:15:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan kalian sudah tertangkap.
Dialogue: 0,0:15:33.34,0:15:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau dia selamat…
Dialogue: 0,0:15:38.22,0:15:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei!
Dialogue: 0,0:15:41.06,0:15:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti! Sto-Stop!
Dialogue: 0,0:15:43.90,0:15:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan kalian disandera, lo!
Dialogue: 0,0:15:45.77,0:15:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang mau kita sandera?
Dialogue: 0,0:15:48.07,0:15:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu.
Dialogue: 0,0:15:49.28,0:15:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mukanya datar.
Dialogue: 0,0:15:51.32,0:15:53.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kubilang berhenti!
Dialogue: 0,0:15:55.32,0:15:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Penjaga Ilahi Sayuu.\NAku terbawa emosi.
Dialogue: 0,0:15:58.45,0:16:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, apa boleh buat.
Dialogue: 0,0:16:01.71,0:16:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah di situ.
Dialogue: 0,0:16:03.62,0:16:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:04.96,0:16:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tetap diam, kamu menahan\NTsugai yang tampak merepotkan itu.
Dialogue: 0,0:16:10.26,0:16:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga, baiklah.
Dialogue: 0,0:16:14.05,0:16:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah Tsugai-nya yang memerintah?
Dialogue: 0,0:16:17.39,0:16:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya Tsugai\Nmengutamakan keselamatan tuannya!
Dialogue: 0,0:16:21.10,0:16:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak banyak aturan.
Dialogue: 0,0:16:25.10,0:16:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang, ya, orang! Kami, ya, kami!
Dialogue: 0,0:16:29.02,0:16:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak bersenjata,\Njangan berlebihan, Migi.
Dialogue: 0,0:16:32.49,0:16:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasihat itu cocoknya buatmu, Hidari.
Dialogue: 0,0:16:36.03,0:16:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makoto.
Dialogue: 0,0:16:41.50,0:16:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, bahaya!
Dialogue: 0,0:16:50.50,0:16:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:51.84,0:16:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya apanya?
Dialogue: 0,0:16:54.47,0:16:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami itu terbuat dari batu.
Dialogue: 0,0:16:58.10,0:16:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:17:05.27,0:17:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Menyebalkan sekali.
Dialogue: 0,0:17:08.56,0:17:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejenis senapan sumbu, ya?
Dialogue: 0,0:17:17.91,0:17:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mempan!
Dialogue: 0,0:17:23.87,0:17:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lentera batu?
Dialogue: 0,0:17:39.93,0:17:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bersenjata apanya?\NPercuma menahan diri.
Dialogue: 0,0:17:43.47,0:17:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.
Dialogue: 0,0:17:45.43,0:17:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.\NAkan kupanggil mereka, minggir Akio!
Dialogue: 0,0:17:52.36,0:17:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidari!
Dialogue: 0,0:18:09.12,0:18:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:18:10.92,0:18:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku, Hidari!
Dialogue: 0,0:18:13.80,0:18:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Migi…
Dialogue: 0,0:18:18.09,0:18:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:18:20.39,0:18:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat, aku tidak bisa bergerak.
Dialogue: 0,0:18:27.64,0:18:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, Hidari!
Dialogue: 0,0:18:29.69,0:18:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atasilah sendiri.
Dialogue: 0,0:18:44.45,0:18:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia.
Dialogue: 0,0:18:55.21,0:18:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir, Yuru!
Dialogue: 0,0:19:03.26,0:19:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lebih rapuh dari si Gigi.
Dialogue: 0,0:19:09.02,0:19:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Migi! Hah?
Dialogue: 0,0:19:10.35,0:19:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aturan terakhir di jamban?
Dialogue: 0,0:19:14.82,0:19:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matikan lampu!
Dialogue: 0,0:19:27.41,0:19:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Haruo, kamu di mana?\N- Di sini.
Dialogue: 0,0:19:31.08,0:19:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai bocah itu menjauh.
Dialogue: 0,0:19:34.17,0:19:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kabur?
Dialogue: 0,0:19:36.00,0:19:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, Tsugai Akio masih berjaga.{\i0}
Dialogue: 0,0:19:39.42,0:19:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kamu tidak akan bisa lari, Bang.{\i0}
Dialogue: 0,0:19:43.51,0:19:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak memang pemburu sejati.
Dialogue: 0,0:19:54.06,0:19:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makoto!
Dialogue: 0,0:20:11.25,0:20:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah tertangkap?
Dialogue: 0,0:20:13.25,0:20:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi,\Nkok tuan kalian malah ditinggal pergi?
Dialogue: 0,0:20:17.67,0:20:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:19.21,0:20:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin berbeda dengan kalian,\Ntapi beginilah kami.
Dialogue: 0,0:20:24.09,0:20:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama berhasil, cara apa pun boleh.
Dialogue: 0,0:20:26.60,0:20:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kabur selagi bisa itu normal?
Dialogue: 0,0:20:30.85,0:20:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada mati semua.
Dialogue: 0,0:20:32.48,0:20:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:20:35.19,0:20:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mungkin sudah tahu,\NYuru adalah sisi "malam" dari si kembar.
Dialogue: 0,0:20:40.36,0:20:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegelapan adalah tempat berburunya.
Dialogue: 0,0:20:42.74,0:20:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa kami pun dia pasti berhasil.
Dialogue: 0,0:20:46.11,0:20:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka percaya sepenuhnya pada tuannya.
Dialogue: 0,0:20:48.62,0:20:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:20:50.74,0:20:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau tidak ditangkap Yuru,\Nkami yang akan menangkapmu.
Dialogue: 0,0:20:55.04,0:20:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski gelap, baumu tetap tercium.
Dialogue: 0,0:20:57.79,0:21:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti, orang yang tumbuh di gunung
Dialogue: 0,0:21:01.42,0:21:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak bisa disamakan dengan kami\Norang-orang dataran rendah.
Dialogue: 0,0:21:05.43,0:21:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Kagemori, kan?
Dialogue: 0,0:21:07.64,0:21:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian klan yang menyerang\NDesa Higashi, ya?
Dialogue: 0,0:21:15.94,0:21:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang bertanggung jawab.
Dialogue: 0,0:21:19.44,0:21:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jin!
Dialogue: 0,0:21:38.13,0:21:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bawa sinyal asap kecil itu, kan?
Dialogue: 0,0:21:42.34,0:21:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda untuk bicara dari jauh,\Ntadi kamu memakainya.
Dialogue: 0,0:21:47.05,0:21:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maksudmu ponsel?
Dialogue: 0,0:21:49.76,0:21:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh Asa datang kemari.
Dialogue: 0,0:21:53.06,0:21:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bicara dengannya.
