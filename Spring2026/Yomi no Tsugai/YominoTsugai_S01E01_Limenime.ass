Dialogue: 0,0:01:31.23,0:01:36.99,tanda,,0000,0000,0000,,YOMI NO TSUGAI: PASANGAN DARI ALAM BAKA
Dialogue: 0,0:01:38.05,0:01:42.47,tanda,,0000,0000,0000,,16 TAHUN KEMUDIAN
Dialogue: 0,0:02:40.68,0:02:43.18,tanda,,0000,0000,0000,,EPISODE 1: ASA DAN YURU
Dialogue: 0,0:14:37.71,0:14:38.98,tanda,,0000,0000,0000,,YOMI NO TSUGAI: PASANGAN DARI ALAM BAKA
Dialogue: 0,0:23:31.61,0:23:32.97,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:41.98,0:23:46.91,tanda,,0000,0000,0000,,EPISODE 2: MIGI DAN HIDARI
Dialogue: 0,0:00:31.23,0:00:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu bayi lagi di perutnya!
Dialogue: 0,0:00:33.44,0:00:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang kembar!
Dialogue: 0,0:00:37.39,0:00:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi pagi.
Dialogue: 0,0:00:39.56,0:00:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dilahirkan dulu.
Dialogue: 0,0:00:41.95,0:00:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek, melakukan itu mustahil!
Dialogue: 0,0:00:45.17,0:00:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan saja.
Dialogue: 0,0:00:47.38,0:00:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan meski itu mustahil.
Dialogue: 0,0:00:50.57,0:00:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua anak ini
Dialogue: 0,0:00:52.46,0:00:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan jadi penguasa para Tsugai!
Dialogue: 0,0:01:22.98,0:01:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembar yang memisahkan siang dan malam\Ntelah terlahir.
Dialogue: 0,0:02:37.24,0:02:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentut naga yang indah.
Dialogue: 0,0:03:01.80,0:03:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yuru!
Dialogue: 0,0:03:03.81,0:03:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh, kamu berburu sendiri lagi, ya!
Dialogue: 0,0:03:06.93,0:03:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Danji, aku pulang.
Dialogue: 0,0:03:09.50,0:03:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa enggak bilang-bilang padaku?
Dialogue: 0,0:03:12.20,0:03:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:03:13.13,0:03:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau ada apa-apa di gunung?
Dialogue: 0,0:03:16.58,0:03:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah minta tolongnya, tahu!
Dialogue: 0,0:03:18.29,0:03:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:03:20.21,0:03:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu akan melindungiku.
Dialogue: 0,0:03:24.35,0:03:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, luar biasa!
Dialogue: 0,0:03:26.52,0:03:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dapat burung pegar?\NItu susah ditangkap, lo!
Dialogue: 0,0:03:29.53,0:03:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang.
Dialogue: 0,0:03:30.66,0:03:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita panggang!
Dialogue: 0,0:03:32.73,0:03:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direbus, lah.
Dialogue: 0,0:03:33.44,0:03:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih sedap kalau dipanggang!
Dialogue: 0,0:03:35.49,0:03:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih mengenyangkan kalau direbus.
Dialogue: 0,0:03:37.23,0:03:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada!
Dialogue: 0,0:03:40.36,0:03:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Yuru, selamat datang.
Dialogue: 0,0:03:42.51,0:03:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.\NKayaknya cuaca akan memburuk.
Dialogue: 0,0:03:45.77,0:03:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin akan hujan setelah sekian lama.
Dialogue: 0,0:03:48.63,0:03:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti mau aku bantu?
Dialogue: 0,0:03:50.18,0:03:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, tolong, ya.
Dialogue: 0,0:04:08.21,0:04:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek Yamaha, aku pulang.
Dialogue: 0,0:04:10.52,0:04:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Yuru.
Dialogue: 0,0:04:12.51,0:04:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danji, untung kamu datang.
Dialogue: 0,0:04:14.78,0:04:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, Ibu?
Dialogue: 0,0:04:16.66,0:04:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku bekerja!
Dialogue: 0,0:04:18.44,0:04:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah.
Dialogue: 0,0:04:20.07,0:04:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi!
Dialogue: 0,0:04:21.07,0:04:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah sedikit rajin seperti Yuru!
Dialogue: 0,0:04:24.31,0:04:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa baik-baik saja?
Dialogue: 0,0:04:25.64,0:04:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, hari ini pun dia bekerja dengan baik.
Dialogue: 0,0:04:45.61,0:04:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa.
Dialogue: 0,0:04:48.24,0:04:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sehat?
Dialogue: 0,0:04:51.53,0:04:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang,
Dialogue: 0,0:04:53.61,0:04:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:04:58.58,0:05:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku dapat burung pegar.
Dialogue: 0,0:05:00.45,0:05:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak hebat!
Dialogue: 0,0:05:02.59,0:05:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, lah.
Dialogue: 0,0:05:04.78,0:05:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku maunya dapat babi hutan atau rusa.
Dialogue: 0,0:05:07.75,0:05:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panen tahun ini mengkhawatirkan\Nkarena jarang hujan.
Dialogue: 0,0:05:11.56,0:05:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bekal kita di musim dingin\Nakan menipis.
Dialogue: 0,0:05:14.65,0:05:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus berburu lebih banyak\Nuntuk membuat daging kering dan asin.
Dialogue: 0,0:05:19.66,0:05:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa warga desa akan pergi\Nke dataran rendah untuk bekerja?
Dialogue: 0,0:05:25.28,0:05:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja.
Dialogue: 0,0:05:27.80,0:05:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak juga akan pergi?
Dialogue: 0,0:05:29.77,0:05:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, lah!
Dialogue: 0,0:05:31.40,0:05:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir, buat apa aku berlatih berburu?
Dialogue: 0,0:05:35.23,0:05:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa dapat daging\Nyang dibutuhkan desa,
Dialogue: 0,0:05:38.11,0:05:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak perlu kerja di dataran rendah.
Dialogue: 0,0:05:41.18,0:05:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan meninggalkanku\Nseperti Ibu dan Ayah, kan?
Dialogue: 0,0:05:45.99,0:05:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Asa.
Dialogue: 0,0:05:48.31,0:05:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan pernah meninggalkan desa.
Dialogue: 0,0:05:51.07,0:05:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ada kamu, aku tidak akan pergi.
Dialogue: 0,0:05:54.86,0:05:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungimu!
Dialogue: 0,0:05:59.49,0:06:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:06:02.23,0:06:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru.
Dialogue: 0,0:06:04.78,0:06:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:06.97,0:06:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera sudah datang.
Dialogue: 0,0:06:10.12,0:06:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logam yang bagus.
Dialogue: 0,0:06:12.97,0:06:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari mereka yang bekerja di luar.
Dialogue: 0,0:06:15.42,0:06:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf selalu merepotkanmu.
Dialogue: 0,0:06:17.70,0:06:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dataran rendah apa kabar?
Dialogue: 0,0:06:19.19,0:06:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekonominya kurang bagus.
Dialogue: 0,0:06:21.67,0:06:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang musim wabah pula.
Dialogue: 0,0:06:23.93,0:06:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, herba akan kubeli\Ndengan harga tinggi.
Dialogue: 0,0:06:27.48,0:06:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo barter sama garam.
Dialogue: 0,0:06:29.14,0:06:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bibit sayur yang tahan kekeringan?
Dialogue: 0,0:06:32.04,0:06:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:06:33.45,0:06:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usia putriku sudah hampir tujuh tahun.
Dialogue: 0,0:06:36.37,0:06:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau begitu,\Nnanti Mbah Dukun kuajak kemari, deh.
Dialogue: 0,0:06:41.59,0:06:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini kepalaku sakit.
Dialogue: 0,0:06:44.72,0:06:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh pereda nyeri, kan?
Dialogue: 0,0:06:46.35,0:06:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta obat lambung.
Dialogue: 0,0:06:47.99,0:06:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:06:49.85,0:06:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera.
Dialogue: 0,0:06:50.60,0:06:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Yuru, apa kabar?
Dialogue: 0,0:06:53.55,0:06:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu perlu sesuatu?
Dialogue: 0,0:06:56.02,0:06:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak...
Dialogue: 0,0:06:58.47,0:07:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku tidak perlu, apa ada oleh-oleh buat Asa?"\NBegitu, kan?
Dialogue: 0,0:07:05.35,0:07:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:06.98,0:07:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada sayap burung pegar?\NMantap!
Dialogue: 0,0:07:10.46,0:07:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dijual mahal, nih!
Dialogue: 0,0:07:16.12,0:07:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya,
Dialogue: 0,0:07:18.03,0:07:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga ingin keluar desa.
Dialogue: 0,0:07:21.16,0:07:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya dataran rendah, sebagus itu?
Dialogue: 0,0:07:24.05,0:07:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya yang pergi ke sana\Nrata-rata tidak pulang lagi, kan?
Dialogue: 0,0:07:28.65,0:07:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya itu tempat yang bagus.
Dialogue: 0,0:07:31.35,0:07:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:07:33.92,0:07:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, mau tinggal selamanya di sini.
Dialogue: 0,0:07:37.26,0:07:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, iyalah.
Dialogue: 0,0:07:39.31,0:07:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kamu punya adik yang cantik.
Dialogue: 0,0:07:43.34,0:07:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak kabur bareng adikmu saja?
Dialogue: 0,0:07:46.15,0:07:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia takut, bakal kutemani, kok.
Dialogue: 0,0:07:48.69,0:07:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bersamamu, Asa bakal ternodai.
Dialogue: 0,0:07:52.46,0:07:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:07:54.23,0:07:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas Asa itu penting!
Dialogue: 0,0:07:56.91,0:08:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku belum pernah\Nsekali pun melihatnya.
Dialogue: 0,0:08:00.96,0:08:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma boleh bertemu orang tertentu.
Dialogue: 0,0:08:03.04,0:08:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu, dong, Bang.
Dialogue: 0,0:08:06.10,0:08:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang norak sepertimu dilarang menemuinya.
Dialogue: 0,0:08:09.76,0:08:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga mulutmu!
Dialogue: 0,0:08:11.15,0:08:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau, kalahkan aku dulu!
Dialogue: 0,0:08:13.00,0:08:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, ogah, ogah, ogah!
Dialogue: 0,0:08:18.46,0:08:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunyi apa itu?
Dialogue: 0,0:08:20.06,0:08:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya suara naga.
Dialogue: 0,0:08:22.53,0:08:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh.
Dialogue: 0,0:08:24.22,0:08:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentut indah naga itu lagi.
Dialogue: 0,0:08:36.78,0:08:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:39.16,0:08:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya beda dari biasanya.
Dialogue: 0,0:08:41.66,0:08:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang aku mendengarnya\Nwaktu berburu di gunung.
Dialogue: 0,0:08:46.00,0:08:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya kencang banget.
Dialogue: 0,0:08:48.02,0:08:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya makin dekat.
Dialogue: 0,0:08:49.79,0:08:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah melihat wujud naganya?
Dialogue: 0,0:08:52.23,0:08:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pernah.
Dialogue: 0,0:09:16.24,0:09:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat itu!
Dialogue: 0,0:09:46.99,0:09:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tenanglah!
Dialogue: 0,0:09:53.78,0:09:55.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:10:22.06,0:10:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek Yamaha!
Dialogue: 0,0:10:24.61,0:10:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:10:26.06,0:10:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, pelindungnya hancur.
Dialogue: 0,0:10:29.11,0:10:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa?
Dialogue: 0,0:10:30.97,0:10:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah, tapi mungkin Yuru akan diincar.
Dialogue: 0,0:10:35.02,0:10:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, cepat bawa dan sembunyikan Yuru.
Dialogue: 0,0:10:38.21,0:10:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:10:39.87,0:10:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Yuru?
Dialogue: 0,0:10:40.81,0:10:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ladang bawah.
Dialogue: 0,0:10:42.23,0:10:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ke sana!
Dialogue: 0,0:10:46.68,0:10:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini...
Dialogue: 0,0:10:48.54,0:10:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:10:53.31,0:10:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya dibunuh.
Dialogue: 0,0:10:56.18,0:10:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menjauh, Danji.
Dialogue: 0,0:10:58.96,0:11:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, tetaplah hidup!
Dialogue: 0,0:11:09.14,0:11:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Target ditemukan!
Dialogue: 0,0:11:12.07,0:11:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:11:15.50,0:11:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda aneh terbang kemari!
Dialogue: 0,0:11:17.49,0:11:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah benda apa, tapi itu mematikan!
Dialogue: 0,0:11:26.40,0:11:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga barusan ada di lapis ketiga kastel.
Dialogue: 0,0:11:29.73,0:11:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak yakin menang melawannya.
Dialogue: 0,0:11:31.83,0:11:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, memangnya itu naga?
Dialogue: 0,0:11:40.61,0:11:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Ibu sedang bekerja di pusat kastel.
Dialogue: 0,0:11:45.98,0:11:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mau ke tempat Asa, kan?
Dialogue: 0,0:11:49.46,0:11:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku, Danji.
Dialogue: 0,0:11:51.30,0:11:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa?
Dialogue: 0,0:11:52.40,0:11:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bantu saja!
Dialogue: 0,0:12:01.96,0:12:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:12:04.04,0:12:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan pintas ke pusat kastel.
Dialogue: 0,0:12:05.66,0:12:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan pintas ke pusat kastel?
Dialogue: 0,0:12:07.92,0:12:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok aku tidak tahu?
Dialogue: 0,0:12:09.68,0:12:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang,
Dialogue: 0,0:12:11.38,0:12:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu akan melindungi kita.
Dialogue: 0,0:12:17.89,0:12:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa.
Dialogue: 0,0:12:19.37,0:12:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kamu aman.
Dialogue: 0,0:12:21.77,0:12:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yuru!
Dialogue: 0,0:12:33.38,0:12:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:12:40.99,0:12:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krauk.
Dialogue: 0,0:12:48.53,0:12:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krauk.
Dialogue: 0,0:12:50.84,0:12:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krauk, krauk.
Dialogue: 0,0:12:53.26,0:12:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krauk, krauk!
Dialogue: 0,0:12:57.72,0:12:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krauk.
Dialogue: 0,0:13:09.51,0:13:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu...
Dialogue: 0,0:13:11.95,0:13:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak gigit anak-anak, kok.
Dialogue: 0,0:13:17.30,0:13:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krauk.
Dialogue: 0,0:13:21.97,0:13:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Gabuchan di sini.
Dialogue: 0,0:13:24.57,0:13:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapis tiga dan lapis dua hampir kelar.
Dialogue: 0,0:13:29.04,0:13:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Regu darat, silakan kemari.
Dialogue: 0,0:13:38.25,0:13:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Regu darat?
Dialogue: 0,0:13:41.15,0:13:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, kok jadi begini?
Dialogue: 0,0:13:46.88,0:13:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelindungnya malah hancur.
Dialogue: 0,0:13:50.64,0:13:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Hana, ini aku.
Dialogue: 0,0:13:54.59,0:13:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, kan, tersambung.\NIni gawat.
Dialogue: 0,0:13:58.81,0:14:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa lihat asapnya?
Dialogue: 0,0:14:01.14,0:14:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:03.09,0:14:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa ubah titik kumpulnya?
Dialogue: 0,0:14:06.10,0:14:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kemungkinan...
Dialogue: 0,0:14:09.65,0:14:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa telah datang.
Dialogue: 0,0:14:25.09,0:14:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi begitu.
Dialogue: 0,0:14:33.23,0:14:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan!
Dialogue: 0,0:14:41.00,0:14:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:15:02.60,0:15:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa!
Dialogue: 0,0:15:04.24,0:15:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku Asa, Kakak.
Dialogue: 0,0:15:07.86,0:15:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang menjemputmu.
Dialogue: 0,0:15:10.17,0:15:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan akan...
Dialogue: 0,0:15:13.68,0:15:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuh semua orang kecuali Kakak!
Dialogue: 0,0:15:17.17,0:15:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:19.68,0:15:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kamu?
Dialogue: 0,0:15:22.97,0:15:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin orang sepertimu
Dialogue: 0,0:15:26.63,0:15:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah
Dialogue: 0,0:15:28.92,0:15:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adik perempuanku!
Dialogue: 0,0:15:31.74,0:15:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyingkir dari situ!
Dialogue: 0,0:15:39.42,0:15:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pura-pura jadi helikopter tim SAR.
Dialogue: 0,0:15:51.47,0:15:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal repot kalau rute kaburku\Ndibuntuti dari atas.
Dialogue: 0,0:16:00.95,0:16:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:16:02.92,0:16:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah.
Dialogue: 0,0:16:05.09,0:16:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Giginya rapi sekali.
Dialogue: 0,0:16:11.69,0:16:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Om bisa melihatnya?
Dialogue: 0,0:16:20.38,0:16:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enamelnya keras banget.
Dialogue: 0,0:16:22.09,0:16:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Om yang menghabisi regu darat, ya?
Dialogue: 0,0:16:37.64,0:16:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, niatnya cuma mematahkan anak panahmu.
Dialogue: 0,0:16:42.08,0:16:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum terbiasa dengan ini.
Dialogue: 0,0:17:02.71,0:17:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, bawa Yuru pergi!
Dialogue: 0,0:17:10.88,0:17:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembunyi di dataran rendah!
Dialogue: 0,0:17:12.80,0:17:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai ketahuan!
Dialogue: 0,0:17:14.82,0:17:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:17.35,0:17:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu baik-baik saja?
Dialogue: 0,0:17:21.25,0:17:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru?
Dialogue: 0,0:17:22.95,0:17:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru!
Dialogue: 0,0:17:47.92,0:17:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, kita akan turun gunung.
Dialogue: 0,0:17:51.73,0:17:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:17:54.54,0:17:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?\NApa yang sebenarnya terjadi?
Dialogue: 0,0:17:58.10,0:17:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, ikut saja.
Dialogue: 0,0:18:09.15,0:18:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, kita dihalangi.
Dialogue: 0,0:18:15.13,0:18:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gigi palsu barusan datang,\Nkita bakal terkepung.
Dialogue: 0,0:18:19.03,0:18:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa...
Dialogue: 0,0:18:19.74,0:18:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:21.44,0:18:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa mati...
Dialogue: 0,0:18:24.37,0:18:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tapi tadi dia bergerak.
Dialogue: 0,0:18:29.35,0:18:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga meninggalkan Nenek.
Dialogue: 0,0:18:31.72,0:18:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan cewek itu?
Dialogue: 0,0:18:34.37,0:18:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mau membunuh semuanya.
Dialogue: 0,0:18:36.39,0:18:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal warga desa tidak bersalah.
Dialogue: 0,0:18:39.89,0:18:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu untuk menjelaskan.
Dialogue: 0,0:18:45.60,0:18:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakanlah Penjaga Ilahi Sayuu.
Dialogue: 0,0:18:48.11,0:18:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, Penjaga Ilahi Sayuu?\NApa maksudmu?
Dialogue: 0,0:18:51.90,0:18:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa ini.
Dialogue: 0,0:18:53.89,0:18:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lubang di antara patung\NPenjaga Ilahi Sayuu.
Dialogue: 0,0:18:57.01,0:18:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masukkan ke situ.
Dialogue: 0,0:18:59.87,0:19:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu apa, sih?
Dialogue: 0,0:19:01.78,0:19:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah dariku!
Dialogue: 0,0:19:03.88,0:19:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah apa?
Dialogue: 0,0:19:05.67,0:19:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan saja!
Dialogue: 0,0:19:07.43,0:19:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan, Yuru!
Dialogue: 0,0:19:10.29,0:19:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, enggak jelas banget!
Dialogue: 0,0:19:12.96,0:19:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya tidak memberiku penjelasan!
Dialogue: 0,0:19:17.51,0:19:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lubangnya tertutup sampah!
Dialogue: 0,0:19:18.82,0:19:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gali, lah!
Dialogue: 0,0:19:21.85,0:19:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pemudanya.
Dialogue: 0,0:19:23.44,0:19:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkap dia, sisanya bunuh saja!
Dialogue: 0,0:19:26.19,0:19:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, bersihkan tiap hari!
Dialogue: 0,0:19:29.98,0:19:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah masuk, Dera!
Dialogue: 0,0:19:34.65,0:19:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan, sih, kamu?
Dialogue: 0,0:20:04.93,0:20:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:20:41.72,0:20:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:20:46.66,0:20:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendaraannya hancur, deh.
Dialogue: 0,0:20:49.73,0:20:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malas banget harus turun jalan kaki.
Dialogue: 0,0:20:54.74,0:20:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, tenanglah.
Dialogue: 0,0:20:57.84,0:20:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada yang muncul.
Dialogue: 0,0:21:00.92,0:21:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai siapa, ya?
Dialogue: 0,0:21:03.71,0:21:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja mereka lemah.
Dialogue: 0,0:21:14.30,0:21:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh.
Dialogue: 0,0:21:17.43,0:21:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan kita kali ini masih bocah.
Dialogue: 0,0:21:20.87,0:21:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia mudah diatur, Hidari.
Dialogue: 0,0:21:24.55,0:21:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah maupun dewasa,
Dialogue: 0,0:21:27.41,0:21:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perintah tuan kita harus dipatuhi, Migi.
Dialogue: 0,0:21:33.16,0:21:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hantu, youkai, monster,\Nsiluman, makhluk asing,
Dialogue: 0,0:21:39.12,0:21:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}eksistensi mutlak.
Dialogue: 0,0:21:40.68,0:21:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggilan mereka berbeda-beda
Dialogue: 0,0:21:43.76,0:21:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tergantung yang melihat.
Dialogue: 0,0:21:46.32,0:21:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, mereka adalah Tsugai milikmu.
Dialogue: 0,0:21:56.71,0:21:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai?
Dialogue: 0,0:23:32.98,0:23:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas sana adalah pintu keluar desa.
Dialogue: 0,0:23:35.44,0:23:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah, Yuru.
Dialogue: 0,0:23:37.26,0:23:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu\Nakan selalu mengawasi kalian.
