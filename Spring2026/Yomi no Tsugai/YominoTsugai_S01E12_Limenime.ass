Dialogue: 0,0:09:42.79,0:09:43.87,sign,,0000,0000,0000,,KINJOU NAGISA
Dialogue: 0,0:12:33.71,0:12:35.54,sign,,0000,0000,0000,,{\an8}KINJOU
Dialogue: 0,0:14:26.82,0:14:30.24,sign,,0000,0000,0000,,JAMPI-JAMPI, PENGUSIRAN ROH,\NPENGOBATAN GANGGUAN SPIRITUAL
Dialogue: 0,0:14:42.21,0:14:44.54,sign,,0000,0000,0000,,{\an8}JAMPI-JAMPI, PENGUSIRAN ROH,\NPENGOBATAN GANGGUAN SPIRITUAL
Dialogue: 0,0:23:27.57,0:23:28.94,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:43.10,0:01:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, sudah jadi.
Dialogue: 0,0:01:45.14,0:01:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa, semuanya kamu bikin sendiri?
Dialogue: 0,0:01:49.23,0:01:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, biasanya begitu.
Dialogue: 0,0:01:52.90,0:01:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik dasarnya diajari Ayah,\Nsisanya aku ulik sendiri.
Dialogue: 0,0:01:57.70,0:01:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kita sendirian kalau di gunung.
Dialogue: 0,0:02:02.87,0:02:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengujinya.
Dialogue: 0,0:02:06.00,0:02:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, tolong ajarkan aku\Ncara memakai senjata.
Dialogue: 0,0:02:11.17,0:02:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi kuat.
Dialogue: 0,0:02:19.63,0:02:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, baiklah.
Dialogue: 0,0:02:25.60,0:02:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:02:39.40,0:02:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang waktu itu…
Dialogue: 0,0:02:42.57,0:02:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Makoto, Tachikawa Makoto.
Dialogue: 0,0:02:45.20,0:02:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal tempo hari.
Dialogue: 0,0:02:46.49,0:02:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Makoto. Selamat siang.
Dialogue: 0,0:02:50.29,0:02:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si pemilik rubah dan tanuki.
Dialogue: 0,0:02:52.83,0:02:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini ada pekerjaan?
Dialogue: 0,0:02:54.54,0:02:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Jin memanggilku kemari.
Dialogue: 0,0:02:58.21,0:03:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akai dan Midori juga, selamat siang.
Dialogue: 0,0:03:02.43,0:03:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, apa kemampuan mereka?
Dialogue: 0,0:03:06.47,0:03:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ahli penculikan, menangkap orang.
Dialogue: 0,0:03:10.02,0:03:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yin-Yang punya Hamura juga sama, kan?{\i0}
Dialogue: 0,0:03:12.69,0:03:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bisa menyembunyikan dan memunculkan orang.{\i0}
Dialogue: 0,0:03:16.65,0:03:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, pantas saja kamu direkrut\Nuntuk menculik kami.
Dialogue: 0,0:03:22.49,0:03:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mako, bagaimana cara Tsugai-mu\Nmenculik orang?
Dialogue: 0,0:03:25.91,0:03:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok jadi Mako…
Dialogue: 0,0:03:28.41,0:03:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akai bisa berubah jadi manusia.
Dialogue: 0,0:03:30.62,0:03:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa jadi gadis cantik\Ndan menjebak orang.
Dialogue: 0,0:03:34.25,0:03:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Midori sesuai kata pepatah,
Dialogue: 0,0:03:36.00,0:03:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kantung pel** tanuki\Nseluas delapan tatami."
Dialogue: 0,0:03:39.13,0:03:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itunya bisa melebar seperti jaring
Dialogue: 0,0:03:42.84,0:03:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu membungkus target dalam sekejap.
Dialogue: 0,0:03:47.06,0:03:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dibungkus oleh kantung pel**\Nseluas delapan tatami?{\i0}
Dialogue: 0,0:03:52.14,0:03:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu dia pernah ikut perang tanuki\Nyang melegenda di Shikoku.
Dialogue: 0,0:03:57.11,0:04:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Panglima musuh bahkan tertangkap\N- Dibungkus pakai kantung pelyir…
Dialogue: 0,0:04:00.36,0:04:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- oleh bentangan di selangkangannya\N- Ih, takutnya!
Dialogue: 0,0:04:02.49,0:04:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- hingga membuat pasukan lawan kacau.\N- Terima kasih sudah menculikku duluan
Dialogue: 0,0:04:05.03,0:04:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sehebat itulah dia.\N- sebelum Midori, Yin-Yang.
Dialogue: 0,0:04:07.95,0:04:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Midori\NTsugai yang paling mengerikan.
Dialogue: 0,0:04:11.83,0:04:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kamu memanggil Makoto kemari
Dialogue: 0,0:04:17.21,0:04:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan buat\Nmenculik Kakak pakai Midori, kan?
Dialogue: 0,0:04:21.38,0:04:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:04:23.17,0:04:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memintanya mengecek\Ngerbang barat yang sebenarnya tidak ada.
Dialogue: 0,0:04:29.43,0:04:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:04:31.35,0:04:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku di sini ada gerbang.
Dialogue: 0,0:04:34.48,0:04:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas aku masuk langsung ada batu besar,
Dialogue: 0,0:04:37.36,0:04:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pohon biwa, dan pohon pir.
Dialogue: 0,0:04:43.32,0:04:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok hilang?
Dialogue: 0,0:04:45.41,0:04:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bisa saja digambar ulang Sensei?
Dialogue: 0,0:04:48.03,0:04:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau begitu, seharusnya\Ndindingnya masih hitam putih.
Dialogue: 0,0:05:04.88,0:05:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada garis tipis di sini.
Dialogue: 0,0:05:08.80,0:05:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana?
Dialogue: 0,0:05:10.64,0:05:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya. Garisnya rapi.
Dialogue: 0,0:05:17.27,0:05:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lagi.
Dialogue: 0,0:05:20.77,0:05:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya selebar gerbang.
Dialogue: 0,0:05:25.74,0:05:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekas pisau cukur? Tapi bukan.
Dialogue: 0,0:05:29.57,0:05:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendanya pasti lebih tajam.
Dialogue: 0,0:05:34.83,0:05:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tuan Shingo, ada tamu di depan.{\i0}
Dialogue: 0,0:05:37.79,0:05:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, antar dia ke kamarku.
Dialogue: 0,0:05:44.92,0:05:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:05:53.14,0:05:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Paman.
Dialogue: 0,0:05:55.89,0:05:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak sehat, ya, Asuma.
Dialogue: 0,0:05:59.06,0:06:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, syukurlah.
Dialogue: 0,0:06:00.65,0:06:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf selalu membuatmu repot-repot\Ndatang kemari.
Dialogue: 0,0:06:04.57,0:06:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Paman saja\Nyang datang ke wisma Kagemori.
Dialogue: 0,0:06:10.78,0:06:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda.
Dialogue: 0,0:06:12.62,0:06:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti informasiku diambil\Nsama Daftar Hitam-nya Fuyuki.
Dialogue: 0,0:06:15.83,0:06:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku juga ogah masuk wisma itu
Dialogue: 0,0:06:19.08,0:06:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa membawa Tsugai.
Dialogue: 0,0:06:21.79,0:06:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada yang menyerangmu, kok.
Dialogue: 0,0:06:27.63,0:06:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kabar baru?
Dialogue: 0,0:06:29.30,0:06:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum.
Dialogue: 0,0:06:30.55,0:06:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai laporanku, Asa di Kagemori\Ndan Yuru di Tadera.
Dialogue: 0,0:06:36.52,0:06:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bisa-bisanya melepaskan bocah Fuu itu.
Dialogue: 0,0:06:40.48,0:06:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Asuma.
Dialogue: 0,0:06:43.52,0:06:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:06:45.90,0:06:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kesempatan emas\Nmenculik salah satu dari si kembar
Dialogue: 0,0:06:50.24,0:06:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah kamu lewatkan?
Dialogue: 0,0:06:52.37,0:06:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru dan Tsugai miliknya\Ntidak bisa ditangkap semudah itu.
Dialogue: 0,0:06:56.66,0:06:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman pasti paham kalau ada di sana.
Dialogue: 0,0:07:03.04,0:07:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lenyapkan komikus itu.
Dialogue: 0,0:07:05.04,0:07:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia enyah,\Nkamulah yang jadi pewaris klan.
Dialogue: 0,0:07:08.30,0:07:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Hagure mati, kepala klan\Nyang sekarang tidak akan mati semudah itu.
Dialogue: 0,0:07:13.72,0:07:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak sanggup,\Nmakanya bujuk saja Asa!
Dialogue: 0,0:07:17.60,0:07:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung masih lugu,
Dialogue: 0,0:07:19.60,0:07:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}rayu dia biar patuh padamu!
Dialogue: 0,0:07:22.56,0:07:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merayu gadis di bawah umur itu\Nmelanggar hukum.
Dialogue: 0,0:07:26.40,0:07:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sok alim!
Dialogue: 0,0:07:29.28,0:07:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak berguna sama kayak ibumu.
Dialogue: 0,0:07:34.78,0:07:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena laporannya selesai, aku pamit dulu.
Dialogue: 0,0:07:40.75,0:07:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan-kapan, datanglah ke wisma Kagemori.
Dialogue: 0,0:07:44.79,0:07:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bacot.
Dialogue: 0,0:07:54.01,0:07:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Keponakanmu sudah pulang?
Dialogue: 0,0:07:57.89,0:08:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku lupa ada kamu.
Dialogue: 0,0:08:01.52,0:08:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarlah, nanti juga ketemu lagi.
Dialogue: 0,0:08:08.36,0:08:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shingo, keponakanmu enggak sopan, tuh.
Dialogue: 0,0:08:13.86,0:08:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun kerabat, dia bisa saja\Nmenusukmu dari belakang, lo.
Dialogue: 0,0:08:23.37,0:08:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengurus satu anak saja sudah repot,\Napalagi kalau dua.
Dialogue: 0,0:08:28.67,0:08:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin?
Dialogue: 0,0:08:29.96,0:08:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, lagi pula dia cukup bijak.
Dialogue: 0,0:08:35.47,0:08:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia rela mengorbankan nyawa
Dialogue: 0,0:08:38.47,0:08:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi bertanggung jawab karena telah\Nmembebaskan Tenaga Ashinaga.
Dialogue: 0,0:08:43.35,0:08:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, apa ini?\N- Dia cukup kritis
Dialogue: 0,0:08:45.39,0:08:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pasti dewa angin ternama, ya?\N- untuk memahami hal yang kami ketahui.
Dialogue: 0,0:08:48.94,0:08:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken anak baik, tenang saja.
Dialogue: 0,0:08:52.40,0:08:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru anak yang berusaha keras\Nbersikap baik begitu
Dialogue: 0,0:08:56.03,0:08:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biasanya batinnya rapuh.
Dialogue: 0,0:08:59.45,0:09:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ketemu!
Dialogue: 0,0:09:00.79,0:09:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Pasti ini.
Dialogue: 0,0:09:02.12,0:09:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa?
Dialogue: 0,0:09:03.33,0:09:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Laman pemerintah daerah soal orang hilang.
Dialogue: 0,0:09:07.29,0:09:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisi informasi terakhir seseorang\Nsebelum mereka hilang.
Dialogue: 0,0:09:12.13,0:09:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menelusuri daerah Tohoku\Nsebelum Yuru lahir.
Dialogue: 0,0:09:17.13,0:09:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinjou Nagisa.
Dialogue: 0,0:09:19.76,0:09:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada formulir atas nama dia\Ndi pos pendakian Desa Higashi lama.
Dialogue: 0,0:09:23.89,0:09:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Periode dan usianya pun cocok.
Dialogue: 0,0:09:26.31,0:09:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya tidak ada alamatnya.
Dialogue: 0,0:09:29.69,0:09:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian membahas Ibu?
Dialogue: 0,0:09:31.15,0:09:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sepertinya ini dia.
Dialogue: 0,0:09:34.49,0:09:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa bilang, Ibu orang Okinawa.
Dialogue: 0,0:09:39.24,0:09:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marga Kinjou ada banyak di Okinawa.
Dialogue: 0,0:09:43.87,0:09:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Okinawa hurufnya begini.
Dialogue: 0,0:09:46.16,0:09:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagisa ke Okinawa\Nuntuk menemui orang tuanya, kan?
Dialogue: 0,0:09:50.46,0:09:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:51.42,0:09:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, Yuru punya kakek atau nenek?
Dialogue: 0,0:09:58.43,0:10:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hup! Ha!
Dialogue: 0,0:10:00.34,0:10:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuntuti Tadera Ryuu\Nsampai ke markasnya.
Dialogue: 0,0:10:04.47,0:10:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuntuti Tadera?
Dialogue: 0,0:10:06.39,0:10:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita butuh kepercayaan si Abang,\Nkenapa kamu bertindak seenaknya?
Dialogue: 0,0:10:11.90,0:10:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti dia mengira itu kehendak klan kita!
Dialogue: 0,0:10:15.19,0:10:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka punya semacam pelindung,\Nnamanya Mayoiga.
Dialogue: 0,0:10:20.70,0:10:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua mata-mata bawahanku gugur.
Dialogue: 0,0:10:24.12,0:10:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi hilang?
Dialogue: 0,0:10:26.25,0:10:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hilang, tapi mati.
Dialogue: 0,0:10:28.96,0:10:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usia mereka 19 dan 40 tahun,\Ndua-duanya pria sebatang kara.
Dialogue: 0,0:10:37.67,0:10:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar identitasnya bisa dipakai,
Dialogue: 0,0:10:39.13,0:10:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}data mereka akan kubuat\Nseolah masih hidup.
Dialogue: 0,0:10:43.72,0:10:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja anak 19 tahun\Nyang mati itu perempuan,
Dialogue: 0,0:10:47.31,0:10:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}identitasnya bisa dipakai Gabuchan.
Dialogue: 0,0:10:51.85,0:10:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa pun sama, perempuan yang meninggal\Nsekitar usia 16 tahun dan sebatang kara
Dialogue: 0,0:10:58.53,0:11:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat sulit dicari.
Dialogue: 0,0:11:00.36,0:11:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Gabuchan tidak memerlukan itu.
Dialogue: 0,0:11:04.12,0:11:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Asa, kurasa dia tidak akan mau\Nmembajak identitas orang lain.
Dialogue: 0,0:11:11.50,0:11:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:11:12.96,0:11:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jin, kamu ada di wisma?{\i0}
Dialogue: 0,0:11:16.21,0:11:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa sedang ditelepon.
Dialogue: 0,0:11:18.96,0:11:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh neneknya dari Okinawa.
Dialogue: 0,0:11:20.97,0:11:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sehat, kok.
Dialogue: 0,0:11:23.30,0:11:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek juga apa kabar?
Dialogue: 0,0:11:26.81,0:11:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diperlakukan baik\Noleh Klan Kagemori. Iya.
Dialogue: 0,0:11:33.60,0:11:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Ayah dan Ibu masih belum ketemu.
Dialogue: 0,0:11:38.53,0:11:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:40.15,0:11:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa nanti juga Nagisa\Ntiba-tiba pulang dengan sendirinya.
Dialogue: 0,0:11:47.41,0:11:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sudah tambah tua.
Dialogue: 0,0:11:51.87,0:11:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain merindukan Nagisa,
Dialogue: 0,0:11:55.33,0:11:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku juga merindukanmu.{\i0}
Dialogue: 0,0:11:59.59,0:12:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cucu kesayangan Nenek.{\i0}
Dialogue: 0,0:12:02.05,0:12:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku ingin bertemu denganmu\Nselagi masih sehat.{\i0}
Dialogue: 0,0:12:07.10,0:12:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Nenek, aku belum bisa ke sana.
Dialogue: 0,0:12:11.06,0:12:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya Nenek juga kena masalah.
Dialogue: 0,0:12:14.69,0:12:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, senang bisa mendengar suaramu.
Dialogue: 0,0:12:17.48,0:12:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungi lagi kapan-kapan, dadah.
Dialogue: 0,0:12:24.11,0:12:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek masih tidak ada perubahan.
Dialogue: 0,0:12:28.70,0:12:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata-katanya pun tidak ada perubahan.
Dialogue: 0,0:12:35.54,0:12:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku ingin bertemu denganmu\Nselagi masih sehat.
Dialogue: 0,0:12:40.84,0:12:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cucu kesayangan Nenek.
Dialogue: 0,0:12:43.38,0:12:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bertemu denganmu
Dialogue: 0,0:12:46.89,0:12:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selagi masih sehat.
Dialogue: 0,0:12:52.39,0:12:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi masih sehat.
Dialogue: 0,0:12:54.89,0:12:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi masih sehat.
Dialogue: 0,0:13:06.91,0:13:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja. Jangan khawatir.
Dialogue: 0,0:13:13.45,0:13:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sialan!{\i0}
Dialogue: 0,0:13:17.42,0:13:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,\Norang bernama Kinjou tahu soal ibuku?
Dialogue: 0,0:13:21.30,0:13:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir Kinjou\Nyang ada di Okinawa sedikit?
Dialogue: 0,0:13:25.13,0:13:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu marga paling banyak di sana, lo.
Dialogue: 0,0:13:28.05,0:13:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagisa hilang dalam perjalanan\Nmenemui orang tuanya.
Dialogue: 0,0:13:32.43,0:13:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menemui kerabatmu di sana cukup berisiko.
Dialogue: 0,0:13:35.81,0:13:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa membuat mereka dalam bahaya.
Dialogue: 0,0:13:41.07,0:13:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau jangan-jangan di sana\Nsudah ada yang siap menjebakmu.
Dialogue: 0,0:13:46.99,0:13:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Kagemori yang melindungi Nagisa
Dialogue: 0,0:13:49.91,0:13:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya sudah tahu yang mana kerabatmu.
Dialogue: 0,0:13:53.45,0:13:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kagemori tidak melindungi kerabatmu,
Dialogue: 0,0:13:57.58,0:14:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin ucapan Hana benar.
Dialogue: 0,0:14:02.96,0:14:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita coba lacak Tadera Pendahulu, deh.
Dialogue: 0,0:14:06.34,0:14:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau menemui Mbah Dukun dulu.
Dialogue: 0,0:14:31.41,0:14:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:14:33.12,0:14:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang,\Ntumben datang siang bolong begini.
Dialogue: 0,0:14:38.41,0:14:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sepi, sekalian tutup saja.
Dialogue: 0,0:14:41.08,0:14:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:14:44.55,0:14:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa apa kabar? Damai seperti biasa?
Dialogue: 0,0:14:48.92,0:14:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong soal desa…
Dialogue: 0,0:14:51.30,0:14:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azami sudah mau berumur tujuh tahun.
Dialogue: 0,0:14:54.72,0:14:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jampi-jampi dia.
Dialogue: 0,0:14:56.02,0:14:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia sudah harus divaksin.
Dialogue: 0,0:14:59.85,0:15:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Campak dan rubela, biar kusiapkan dulu.
Dialogue: 0,0:15:04.23,0:15:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, desa berantakan\Nkarena diserang Kagemori.
Dialogue: 0,0:15:07.15,0:15:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang dari awal, dong!
Dialogue: 0,0:15:09.32,0:15:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tahu itu lebih penting,\Nmalah bahas vaksin duluan!
Dialogue: 0,0:15:13.99,0:15:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan utama itu datang belakangan, kan?
Dialogue: 0,0:15:18.20,0:15:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kudengar, satu dari si kembar\Nada bersama Klan Kagemori.
Dialogue: 0,0:15:24.08,0:15:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa, ya.
Dialogue: 0,0:15:25.50,0:15:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mendapatkan kekuatan Kai\Ndan menerobos pelindung Desa Higashi.
Dialogue: 0,0:15:30.76,0:15:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil bawa tentara Kagemori.
Dialogue: 0,0:15:33.01,0:15:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yuru juga dibawa pergi?\N- Tidak.
Dialogue: 0,0:15:37.43,0:15:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas perintah Nenek Yamaha,\Naku membawa kabur Yuru.
Dialogue: 0,0:15:41.77,0:15:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dia di sini.
Dialogue: 0,0:15:46.27,0:15:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selepas turun gunung,\Nkami sempat cekcok sama Kagemori.
Dialogue: 0,0:15:50.90,0:15:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung masih lolos.
Dialogue: 0,0:15:52.66,0:15:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku mohon.
Dialogue: 0,0:15:55.28,0:15:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai Yuru direbut pihak lain!
Dialogue: 0,0:15:59.20,0:16:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar-benar Kai?
Dialogue: 0,0:16:01.46,0:16:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya,\Ndia bilang mendapatkannya setelah mati.
Dialogue: 0,0:16:06.92,0:16:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira Kai dan Fuu\Ncuma dongeng para orang tua.
Dialogue: 0,0:16:12.55,0:16:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Makanya, karena tidak yakin\Nbisa menjaganya sendiri,
Dialogue: 0,0:16:17.10,0:16:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}aku butuh ilmu Tadera Pendahulu.
Dialogue: 0,0:16:19.72,0:16:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi entah di mana dia berada.
Dialogue: 0,0:16:22.56,0:16:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendahulu masih tidak ada kabar?
Dialogue: 0,0:16:25.98,0:16:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepuluh tahun\Nkami tidak saling kontak.
Dialogue: 0,0:16:29.15,0:16:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ke kamu?
Dialogue: 0,0:16:30.48,0:16:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku juga tidak pernah dikabari.
Dialogue: 0,0:16:34.61,0:16:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan dia sudah mati.
Dialogue: 0,0:16:37.32,0:16:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti akan kutanyakan ke warga desa,\Nsiapa tahu ada petunjuk.
Dialogue: 0,0:16:42.79,0:16:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:16:45.29,0:16:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, di mana Yuru disembunyikan?
Dialogue: 0,0:16:49.09,0:16:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di markas rahasiaku.
Dialogue: 0,0:16:54.68,0:16:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti aman, ya.
Dialogue: 0,0:16:57.01,0:17:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, anak itu gampang emosi.
Dialogue: 0,0:17:01.85,0:17:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sampai bilang,
Dialogue: 0,0:17:03.39,0:17:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kalau mau nyawaku,\Ndatang dan ambil saja!"
Dialogue: 0,0:17:06.94,0:17:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mereka cuma akan kalah\Ndan kuperas informasinya."
Dialogue: 0,0:17:11.19,0:17:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani banget, ya.
Dialogue: 0,0:17:13.36,0:17:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah, coba saja dia yang jadi aku.
Dialogue: 0,0:17:18.95,0:17:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, karena masih sibuk sekali,\Nsementara ini aku tidak bisa ke desa.
Dialogue: 0,0:17:25.37,0:17:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:17:27.25,0:17:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan mengunjungi desa\Nsekalian menjampi Azami.
Dialogue: 0,0:17:32.38,0:17:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:17:33.59,0:17:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena banyak yang terluka,\Nbawalah banyak obat-obatan.
Dialogue: 0,0:17:37.68,0:17:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:17:42.43,0:17:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semalam aku bertemu orang aneh\Ndi jalan pulang.{\i0}
Dialogue: 0,0:17:47.48,0:17:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia bawa katana.{\i0}
Dialogue: 0,0:17:50.15,0:17:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kemungkinan, sepasang katana itu\Nadalah Tsugai.{\i0}
Dialogue: 0,0:17:56.40,0:18:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia mendekat dalam sekejap dan…{\i0}
Dialogue: 0,0:18:02.91,0:18:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Menebasmu?{\i0}
Dialogue: 0,0:18:07.04,0:18:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tiba-tiba aku terbangun di tengah jalan.{\i0}
Dialogue: 0,0:18:10.25,0:18:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada luka sedikit pun.{\i0}
Dialogue: 0,0:18:13.55,0:18:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apakah dia semacam orang cabul?{\i0}
Dialogue: 0,0:18:17.42,0:18:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau tukang mencari informasi\Nkarena Yuru ada di pihak kita?
Dialogue: 0,0:18:21.60,0:18:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai katana?
Dialogue: 0,0:18:24.47,0:18:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan hati-hati.
Dialogue: 0,0:18:27.48,0:18:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada kabar soal Tadera Pendahulu,\Nkabari aku.
Dialogue: 0,0:18:30.94,0:18:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:18:34.48,0:18:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai dibuntuti\Nsaat menuju desa, Mbah Dukun.
Dialogue: 0,0:18:39.24,0:18:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:18:46.41,0:18:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh, aduh, kacau sekali.
Dialogue: 0,0:18:55.25,0:18:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada makam di sana sini.
Dialogue: 0,0:18:59.88,0:19:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbah Dukun datang!
Dialogue: 0,0:19:01.93,0:19:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mbah Yama!\N- Anak-anak!
Dialogue: 0,0:19:04.68,0:19:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalian selamat!
Dialogue: 0,0:19:06.47,0:19:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mbah Yama, ada orang aneh datang\Ndan membunuh banyak warga.
Dialogue: 0,0:19:11.31,0:19:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar dari Dera.
Dialogue: 0,0:19:13.81,0:19:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada burung besi besar\Ndan mereka melempar bola besi.
Dialogue: 0,0:19:19.53,0:19:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Penjaga Ilahi Sayuu juga menghilang.
Dialogue: 0,0:19:22.32,0:19:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti desa kita didatangi dewa jahat.
Dialogue: 0,0:19:25.58,0:19:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Penjaga Ilahi Sayuu dihancurkan?
Dialogue: 0,0:19:29.04,0:19:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan tak kasatmata mereka\Nmembuat para orang dewasa terbelah dua.
Dialogue: 0,0:19:35.54,0:19:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunya Azami juga dibunuh.
Dialogue: 0,0:19:39.97,0:19:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ini berkah dewanya.
Dialogue: 0,0:19:43.76,0:19:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan sedikit, ya.
Dialogue: 0,0:19:48.22,0:19:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai.
Dialogue: 0,0:19:50.52,0:19:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa penyakit yang jahat\Ntidak akan bisa masuk.
Dialogue: 0,0:19:56.11,0:19:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lepas topengmu, Azami.
Dialogue: 0,0:20:16.71,0:20:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, ibunya dipenggal\Ndi depan matanya.
Dialogue: 0,0:20:20.05,0:20:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, Klan Kagemori memang biadab!
Dialogue: 0,0:20:23.47,0:20:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbah Yama aman, tidak?
Dialogue: 0,0:20:25.80,0:20:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kamu dibuntuti orang Kagemori.
Dialogue: 0,0:20:28.26,0:20:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya memang ada,\Ntapi mereka sudah kukecoh.
Dialogue: 0,0:20:33.48,0:20:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kami berinisiatif\Nmembangkitkan Fuu lebih cepat.
Dialogue: 0,0:20:38.36,0:20:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,\NKagemori tidak akan bisa seenaknya.
Dialogue: 0,0:20:42.15,0:20:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima orang.
Dialogue: 0,0:20:43.61,0:20:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima orang pembunuh elite\Nsudah kukirim untuk membunuh Yuru.
Dialogue: 0,0:20:48.74,0:20:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak ada yang selamat.
Dialogue: 0,0:20:52.12,0:20:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung pegar saja bisa dia panah.
Dialogue: 0,0:20:55.87,0:20:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apalagi manusia biasa.
Dialogue: 0,0:20:58.29,0:21:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bukan tandingannya.
Dialogue: 0,0:21:01.80,0:21:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal, kita harus punya sandera.
Dialogue: 0,0:21:06.22,0:21:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.
Dialogue: 0,0:21:11.39,0:21:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:23.49,0:21:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Desa Higashi.
Dialogue: 0,0:21:27.41,0:21:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini?
Dialogue: 0,0:21:31.87,0:21:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu si cabul di tengah malam!
Dialogue: 0,0:21:34.58,0:21:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja!
Dialogue: 0,0:21:36.37,0:21:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan si cabul di tengah malam,\Nnamaku Yosano Ivan.
Dialogue: 0,0:21:41.25,0:21:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah?
Dialogue: 0,0:21:42.34,0:21:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:21:44.51,0:21:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak bisa melihat Tsugai, ya.
Dialogue: 0,0:21:52.26,0:21:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kerjaanku makin gampang, dong.{\i0}
Dialogue: 0,0:23:28.94,0:23:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Wajah itu…{\i0}
Dialogue: 0,0:23:30.36,0:23:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kamu Asa palsu, ya?{\i0}
Dialogue: 0,0:23:32.20,0:23:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hei, pergilah.{\i0}
Dialogue: 0,0:23:33.45,0:23:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ke rest area, yuk!{\i0}
Dialogue: 0,0:23:35.83,0:23:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bantulah Yuru.{\i0}
