Dialogue: 0,0:03:21.61,0:03:22.53,sign,,0000,0000,0000,,PERKAKAS
Dialogue: 0,0:03:54.27,0:03:55.19,sign,,0000,0000,0000,,KASIR
Dialogue: 0,0:04:14.83,0:04:15.79,sign,,0000,0000,0000,,{\an8}KASIR TUTUP SEMENTARA
Dialogue: 0,0:04:39.48,0:04:41.23,sign,,0000,0000,0000,,BUSANA
Dialogue: 0,0:05:13.22,0:05:14.14,sign,,0000,0000,0000,,CELANA DALAM PRIA
Dialogue: 0,0:15:17.87,0:15:20.71,sign,,0000,0000,0000,,STUDIO HAGURE
Dialogue: 0,0:16:56.76,0:16:57.80,sign,,0000,0000,0000,,TOKO PERLENGKAPAN
Dialogue: 0,0:23:27.57,0:23:28.86,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:44.35,0:01:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Utang minum di sana, ah.{\i0}
Dialogue: 0,0:01:51.31,0:01:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:01:55.15,0:01:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung di pusat kota,\Nayo bersenang-senang.
Dialogue: 0,0:02:00.70,0:02:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pelajaran hidup.
Dialogue: 0,0:02:03.99,0:02:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pelajaran hidup.{\i0}
Dialogue: 0,0:02:38.15,0:02:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kuda-kuda di sini besar dan cepat,\Nkayaknya perlu trik buat menaikinya.
Dialogue: 0,0:02:43.16,0:02:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuda yang juara satu bagus.
Dialogue: 0,0:02:45.99,0:02:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harganya berapa, ya?
Dialogue: 0,0:02:47.91,0:02:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, nanti Hana menceraikanku.
Dialogue: 0,0:02:50.79,0:02:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebutuhanmu akan kubelikan, kok.
Dialogue: 0,0:02:53.84,0:02:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuda dan sapi.
Dialogue: 0,0:02:55.00,0:02:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain hewan ternak.
Dialogue: 0,0:02:57.17,0:03:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku sedang butuh anak panah.
Dialogue: 0,0:03:00.55,0:03:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Busurnya ada di rumah,\Ntapi anak panahnya sedikit.
Dialogue: 0,0:03:03.89,0:03:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko mana yang jual anak panah, ya?
Dialogue: 0,0:03:07.39,0:03:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bikin sendiri kalau ada bahannya.
Dialogue: 0,0:03:18.19,0:03:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini dijual?
Dialogue: 0,0:03:20.45,0:03:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:03:22.53,0:03:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahannya apa saja?
Dialogue: 0,0:03:24.45,0:03:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bambu, benang, dan pisau.
Dialogue: 0,0:03:27.74,0:03:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata panahnya bisa besi atau batu.
Dialogue: 0,0:03:29.79,0:03:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu bulunya?
Dialogue: 0,0:03:31.12,0:03:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa pakai burung pegar\Nyang kujual padamu.
Dialogue: 0,0:03:34.79,0:03:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Di sini jual rusa utuh?\N- Rusa?
Dialogue: 0,0:03:38.00,0:03:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulit dan jeroannya mau kujadikan lem.
Dialogue: 0,0:03:40.55,0:03:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan,\Nnanti tetangga kita protes karena bau.
Dialogue: 0,0:03:45.05,0:03:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai ini.
Dialogue: 0,0:03:47.26,0:03:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Lem kayu!
Dialogue: 0,0:03:49.39,0:03:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa ini?
Dialogue: 0,0:03:50.52,0:03:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini caranya.
Dialogue: 0,0:03:52.52,0:03:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Praktis banget!
Dialogue: 0,0:03:55.19,0:03:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:03:57.61,0:04:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dataran rendah punya segalanya.
Dialogue: 0,0:04:06.82,0:04:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu, dua, tiga.
Dialogue: 0,0:04:11.79,0:04:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:15.79,0:04:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Manajer, aku izin istirahat\Nkarena sudah mulai halusinasi.
Dialogue: 0,0:04:20.26,0:04:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hah? Enak saja minta istirahat.
Dialogue: 0,0:04:23.47,0:04:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar jahat!
Dialogue: 0,0:04:25.97,0:04:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis itu bisa melihat kami.
Dialogue: 0,0:04:30.01,0:04:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tampaknya dia tidak punya Tsugai.
Dialogue: 0,0:04:32.73,0:04:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia orang peka\Nseperti kata Hidari.
Dialogue: 0,0:04:36.52,0:04:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang tidur pun\Nkadang bikin orang bisa melihat, lo.
Dialogue: 0,0:04:41.82,0:04:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian beli baju, deh.
Dialogue: 0,0:04:46.70,0:04:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebegig?
Dialogue: 0,0:04:51.95,0:04:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju dataran rendah enak juga\Nsoalnya sakunya banyak.
Dialogue: 0,0:04:55.37,0:04:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, pilihlah yang kamu suka.
Dialogue: 0,0:04:58.13,0:05:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau hitam,\Nbiar menyamarkan bercak darah.
Dialogue: 0,0:05:01.92,0:05:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Memilih baju dari bercak darah,\Ndingin banget.{\i0}
Dialogue: 0,0:05:05.72,0:05:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mau celana dalam?\N- Apa ini?
Dialogue: 0,0:05:07.47,0:05:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kolor, model barunya fundoshi.
Dialogue: 0,0:05:10.72,0:05:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aneh, aku mau fundoshi saja.
Dialogue: 0,0:05:14.14,0:05:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa di sini jual fundoshi?
Dialogue: 0,0:05:16.69,0:05:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya tidak.
Dialogue: 0,0:05:19.23,0:05:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:05:21.61,0:05:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu berburu sendirian dulu,\Naku pernah beberapa kali diserang bandit.
Dialogue: 0,0:05:28.07,0:05:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sesuai ajaran Ayah,{\i0}
Dialogue: 0,0:05:30.07,0:05:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka langsung kuhabisi\Nkarena berniat membunuh.{\i0}
Dialogue: 0,0:05:33.54,0:05:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau tidak dikubur, aku buang ke sungai.{\i0}
Dialogue: 0,0:05:36.12,0:05:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi selalu terasa janggal.{\i0}
Dialogue: 0,0:05:38.71,0:05:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kejanggalan itu terjawab.
Dialogue: 0,0:05:42.30,0:05:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semua bandit itu berpenampilan rapi.{\i0}
Dialogue: 0,0:05:46.47,0:05:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang dewasa sudah lama hidup di gunung{\i0}
Dialogue: 0,0:05:50.43,0:05:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}biasanya punya noda membandel{\i0}
Dialogue: 0,0:05:53.18,0:05:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}di sela jari dan kuku mereka.{\i0}
Dialogue: 0,0:05:56.73,0:06:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tangan mereka sama bersihnya denganmu\Nyang hidup di dataran rendah.
Dialogue: 0,0:06:01.98,0:06:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan salah satunya pakai benda\Nbernama kolor ini.
Dialogue: 0,0:06:06.36,0:06:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menelanjanginya?
Dialogue: 0,0:06:08.74,0:06:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mereka orang dataran rendah\Nyang naik gunung untuk membunuhku.
Dialogue: 0,0:06:13.58,0:06:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pelakunya warga desa,
Dialogue: 0,0:06:15.12,0:06:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepercayaan Yuru akan\Nhilang meski hidup lagi.
Dialogue: 0,0:06:18.50,0:06:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru mau dibuat seolah mati\Ndan mendapatkan Fuu akibat orang luar
Dialogue: 0,0:06:22.75,0:06:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar dia tetap tinggal di desa.
Dialogue: 0,0:06:25.67,0:06:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Belum tentu ini ulah warga desa.
Dialogue: 0,0:06:29.09,0:06:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi bukan berarti aku memercayai mereka…{\i0}
Dialogue: 0,0:06:32.60,0:06:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau ada apa-apa di gunung?
Dialogue: 0,0:06:35.56,0:06:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}…meskipun aku ingin.
Dialogue: 0,0:06:38.60,0:06:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tahu jalur masuk ke desa
Dialogue: 0,0:06:42.02,0:06:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya aku dan segelintir orang.
Dialogue: 0,0:06:45.11,0:06:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bagus, menguaknya akan lebih mudah.
Dialogue: 0,0:06:48.69,0:06:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menangkapnya?
Dialogue: 0,0:06:50.70,0:06:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kitalah yang punya kendali.
Dialogue: 0,0:06:53.41,0:06:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga akan begini.
Dialogue: 0,0:06:56.58,0:06:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam berburu, siapa cepat dia dapat.
Dialogue: 0,0:07:00.71,0:07:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Omong-omong, Dera.\N- Iya?
Dialogue: 0,0:07:03.67,0:07:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kita dibuntuti.
Dialogue: 0,0:07:04.88,0:07:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sekitar tiga orang.
Dialogue: 0,0:07:07.63,0:07:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu, dua, tiga orang.
Dialogue: 0,0:07:10.34,0:07:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka membuntuti bergantian.
Dialogue: 0,0:07:12.14,0:07:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya suruhan Kagemori,\Nmereka memang licik.
Dialogue: 0,0:07:16.85,0:07:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menoleh.
Dialogue: 0,0:07:18.14,0:07:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:07:20.14,0:07:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, kalau memang tidak mau dilacak,
Dialogue: 0,0:07:24.48,0:07:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kok Asa boleh mengambil gambarmu?
Dialogue: 0,0:07:28.15,0:07:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kamu bisa dicari lewat situ, kan?{\i0}
Dialogue: 0,0:07:30.86,0:07:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak apa-apa.{\i0}
Dialogue: 0,0:07:32.16,0:07:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di wisma semewah itu\Npasti ada kamera pengintai.
Dialogue: 0,0:07:36.87,0:07:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kura-kura pengintai?{\i0}
Dialogue: 0,0:07:39.41,0:07:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak menginjak wisma Kagemori,\Nwajahku pasti akan dikenali.
Dialogue: 0,0:07:50.63,0:07:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kakak…{\i0}
Dialogue: 0,0:07:58.43,0:08:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Edit dulu, ah.
Dialogue: 0,0:08:02.77,0:08:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:08:03.90,0:08:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa, tadi kamu dapat fotonya Tadera, kan?
Dialogue: 0,0:08:08.48,0:08:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera tidak terfoto.
Dialogue: 0,0:08:10.40,0:08:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami perlu informasinya…
Dialogue: 0,0:08:14.11,0:08:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak terfoto?
Dialogue: 0,0:08:15.57,0:08:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:08:17.20,0:08:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya difoto bareng si Abang…
Dialogue: 0,0:08:19.12,0:08:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:08:21.33,0:08:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruo, cari video Tadera\Ndi kamera pengintai di gerbang.
Dialogue: 0,0:08:27.88,0:08:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan aku rekaman Kakak kalau ada.
Dialogue: 0,0:08:33.09,0:08:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria berewokan berjaket kamuflase,\Nnamanya Akishima.
Dialogue: 0,0:08:37.47,0:08:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia makelar pekerjaan ilegal.
Dialogue: 0,0:08:40.64,0:08:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kerjaan ini juga dari dia.
Dialogue: 0,0:08:44.10,0:08:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini riwayat panggilanku.
Dialogue: 0,0:08:46.10,0:08:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghubungiku kemarin, tengah malam.
Dialogue: 0,0:08:50.07,0:08:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ditelepon di waktu serupa.
Dialogue: 0,0:08:53.95,0:08:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia menghubungi\Norang yang bisa langsung datang.
Dialogue: 0,0:08:58.16,0:09:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kubilang,\Nsemua yang dipanggil tidak saling kenal.
Dialogue: 0,0:09:02.87,0:09:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengah malam, berarti setelah kami\Nbertemu Yuru dan menuju kemari.
Dialogue: 0,0:09:08.71,0:09:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat saat Jin dan aku bertukar pesan.
Dialogue: 0,0:09:12.71,0:09:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jam berapa kalian memasuki wisma?
Dialogue: 0,0:09:15.26,0:09:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar jam setengah\Ndua atau lebih sedikit.
Dialogue: 0,0:09:18.55,0:09:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti saat aku mengobati kaki Jin.
Dialogue: 0,0:09:21.47,0:09:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:09:22.47,0:09:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wisma ini dipasangi pelindung.
Dialogue: 0,0:09:25.60,0:09:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya, cuma anggota kami dan tamunya\Nyang bisa masuk di jam tersebut.
Dialogue: 0,0:09:32.07,0:09:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adakah orang dari Kagemori\Nyang membiarkan kalian masuk?
Dialogue: 0,0:09:38.28,0:09:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma berewok… Maksudku cuma ada Akishima.
Dialogue: 0,0:09:41.95,0:09:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kami langsung masuk\Nkarena gerbang baratnya terbuka.
Dialogue: 0,0:09:45.87,0:09:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:09:47.37,0:09:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ada banyak Tsugai saat masuk wisma.
Dialogue: 0,0:09:51.21,0:09:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kupikir bisa sembunyi…
Dialogue: 0,0:09:53.21,0:09:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, tadi gerbang apa katamu?
Dialogue: 0,0:09:56.92,0:09:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, gerbang barat.
Dialogue: 0,0:09:59.51,0:10:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wisma ini tidak punya gerbang barat.
Dialogue: 0,0:10:02.89,0:10:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:04.10,0:10:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, bukannya ada?
Dialogue: 0,0:10:05.64,0:10:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:10:08.06,0:10:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sepanjang halaman kami,\Ntidak ada gerbang barat.
Dialogue: 0,0:10:12.15,0:10:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi baratnya cuma dinding.
Dialogue: 0,0:10:15.74,0:10:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyuki.
Dialogue: 0,0:10:17.15,0:10:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:10:23.08,0:10:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Partnerku mau diapakan?
Dialogue: 0,0:10:25.49,0:10:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, mereka tidak akan dibunuh.
Dialogue: 0,0:10:28.83,0:10:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai ini adalah Siluman Penyamar.
Dialogue: 0,0:10:31.33,0:10:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masing-masing bernama Akai dan Midori.
Dialogue: 0,0:10:35.80,0:10:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan mereka adalah Tachikawa Makoto.
Dialogue: 0,0:10:38.26,0:10:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lahir 4 Mei 1997.
Dialogue: 0,0:10:41.51,0:10:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikeluarkan dari\NUniversitas Wanita Ariake.
Dialogue: 0,0:10:44.35,0:10:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal di Shin-Kiba,
Dialogue: 0,0:10:45.31,0:10:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Distrik Koutou, Tokyo.\N- Tunggu…
Dialogue: 0,0:10:47.81,0:10:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya satu adik lelaki\Ndan satu adik perempuan,
Dialogue: 0,0:10:50.39,0:10:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang tuanya cerai Agustus 2008.
Dialogue: 0,0:10:53.61,0:10:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka diasuh ibunya.
Dialogue: 0,0:10:55.65,0:10:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pengangguran\Ntapi ibunya dirawat di rumah sakit.
Dialogue: 0,0:10:59.61,0:11:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tu-Tunggu…\N- Dia mengambil pekerjaan ini
Dialogue: 0,0:11:01.07,0:11:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oh, maaf.\N- demi membiayai ibunya.
Dialogue: 0,0:11:03.16,0:11:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku tidak membeberkan\Ninformasi pribadi seorang wanita.
Dialogue: 0,0:11:07.75,0:11:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelaki juga enggak boleh!
Dialogue: 0,0:11:09.25,0:11:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bisikan, tolong diam dulu.
Dialogue: 0,0:11:12.54,0:11:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Baik.
Dialogue: 0,0:11:17.25,0:11:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:11:19.05,0:11:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:11:21.13,0:11:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekapan, selanjutnya.
Dialogue: 0,0:11:25.30,0:11:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lembut, ya.
Dialogue: 0,0:11:26.76,0:11:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu lembut, kok.
Dialogue: 0,0:11:29.31,0:11:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai ini Yin Yang,\Nbelum punya nama pribadi.
Dialogue: 0,0:11:32.35,0:11:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuannya adalah Asa.
Dialogue: 0,0:11:34.69,0:11:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan sebelumnya, Hamura Kenichi.
Dialogue: 0,0:11:37.11,0:11:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lahir 16 Juni 1992.
Dialogue: 0,0:11:41.70,0:11:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal di…
Dialogue: 0,0:11:44.24,0:11:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:46.99,0:11:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utang karena judi.
Dialogue: 0,0:11:49.29,0:11:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka jujur,\Nbenaran cuma kerja sampingan.
Dialogue: 0,0:11:53.33,0:11:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan pria pelanggar privasi ini?
Dialogue: 0,0:11:56.71,0:11:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kuroya Fuyuki.
Dialogue: 0,0:11:58.80,0:12:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai ini disebut Daftar Hitam.
Dialogue: 0,0:12:02.01,0:12:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma dengan menyentuh, mereka bisa\Nmengambil informasi tuan Tsugai tersebut.
Dialogue: 0,0:12:07.85,0:12:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terbukti tidak terlibat\Ndengan dalang penyerangan ini.
Dialogue: 0,0:12:14.69,0:12:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau butuh uang, kerjalah di sini.
Dialogue: 0,0:12:17.57,0:12:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:18.82,0:12:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang diberi pekerjaan, tapi…
Dialogue: 0,0:12:22.61,0:12:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak dihukum?
Dialogue: 0,0:12:26.12,0:12:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja keraslah bagai kuda.
Dialogue: 0,0:12:30.24,0:12:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biaya pengobatan ibumu mahal?
Dialogue: 0,0:12:33.16,0:12:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, penyakitnya berat.
Dialogue: 0,0:12:35.67,0:12:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami talangi semuanya,\Nsuruh ibumu fokus ke pemulihan.
Dialogue: 0,0:12:41.96,0:12:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:12:43.47,0:12:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti utangku juga…
Dialogue: 0,0:12:46.47,0:12:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu beda cerita!
Dialogue: 0,0:12:49.76,0:12:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama,\Nmulailah dengan merapikan wisma ini.
Dialogue: 0,0:12:53.14,0:12:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ba-Baik!\N- Baik!
Dialogue: 0,0:12:57.19,0:12:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dibiarkan hidup?
Dialogue: 0,0:12:59.23,0:13:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, identitas mereka\Nada di tangan kita.
Dialogue: 0,0:13:04.95,0:13:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja pion sekali pakai.
Dialogue: 0,0:13:08.20,0:13:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:10.41,0:13:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Tsugai lainnya harus kita apakan?
Dialogue: 0,0:13:13.62,0:13:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Tsugai-nya mati,\Nsuruh bikin kontrak dengan Tsugai baru.
Dialogue: 0,0:13:18.75,0:13:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian periksa\Nmereka pakai Daftar Hitam.
Dialogue: 0,0:13:25.47,0:13:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dalangnya ketemu,\Nbunuh dia dan semua yang ikut terlibat.
Dialogue: 0,0:13:31.97,0:13:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baik.{\i0}
Dialogue: 0,0:13:44.40,0:13:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, maukah kamu mengembalikan Tsugai-ku?
Dialogue: 0,0:13:49.20,0:13:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah punya nama buat mereka?
Dialogue: 0,0:13:54.95,0:13:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ohagi dan Daifuku?
Dialogue: 0,0:13:57.96,0:13:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:01.09,0:14:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, lucu banget.
Dialogue: 0,0:14:03.71,0:14:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Aku ini suka makanan manis!
Dialogue: 0,0:14:06.67,0:14:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya berkebalikan\Nsama wajah dan penampilanmu.
Dialogue: 0,0:14:10.09,0:14:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:14:11.89,0:14:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku Ai dan Makoto juga senasib.
Dialogue: 0,0:14:15.85,0:14:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya siapa nama gigi itu?
Dialogue: 0,0:14:18.64,0:14:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Joe William Frederic Gabriel I
Dialogue: 0,0:14:21.98,0:14:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Kirk Douglas Auldglaive Gabriel II.
Dialogue: 0,0:14:25.90,0:14:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dih, namanya norak banget.
Dialogue: 0,0:14:29.49,0:14:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf, maaf!
Dialogue: 0,0:14:32.28,0:14:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia sudah tobat\Nbahkan memberi kalian nama yang imut.
Dialogue: 0,0:14:37.20,0:14:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kembali padanya?
Dialogue: 0,0:14:41.54,0:14:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak mau.
Dialogue: 0,0:14:44.21,0:14:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil manusia berubah secepat itu.
Dialogue: 0,0:14:47.63,0:14:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang urus dulu, ya.
Dialogue: 0,0:14:50.63,0:14:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bekerja.
Dialogue: 0,0:14:53.80,0:14:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada Yin Yang, Kai tidak protes, kan?
Dialogue: 0,0:14:56.85,0:15:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tidak ada reaksi apa pun.
Dialogue: 0,0:15:00.19,0:15:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka cocok.
Dialogue: 0,0:15:02.40,0:15:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak diadopsi permanen saja?
Dialogue: 0,0:15:05.61,0:15:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Makin banyak pelindungmu makin bagus.
Dialogue: 0,0:15:09.36,0:15:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:15:11.86,0:15:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di wisma pun bisa saja masih ada musuh.{\i0}
Dialogue: 0,0:15:21.29,0:15:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kali ini nyaris sekali.{\i0}
Dialogue: 0,0:15:23.04,0:15:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, rencananya kacau dan bikin panik.
Dialogue: 0,0:15:26.80,0:15:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkanmu, Nakagami.
Dialogue: 0,0:15:29.84,0:15:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikutnya pasti berhasil.
Dialogue: 0,0:15:31.55,0:15:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana? Perlu tambahan anggota?{\i0}
Dialogue: 0,0:15:35.14,0:15:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau butuh pekerja lepas,\Naku bisa panggilkan beberapa orang.{\i0}
Dialogue: 0,0:15:39.56,0:15:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, tidak usah.
Dialogue: 0,0:15:42.90,0:15:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan dan Asa bisa dimanfaatkan.
Dialogue: 0,0:15:47.36,0:15:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak perlu bala bantuan?{\i0}
Dialogue: 0,0:15:49.40,0:15:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, biar aku atasi sendiri.
Dialogue: 0,0:15:53.20,0:15:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Duh, kukira naskahnya bakal telat dikirim.
Dialogue: 0,0:15:58.95,0:16:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang paling parah.
Dialogue: 0,0:16:01.87,0:16:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asistenku tumbang karena flu.
Dialogue: 0,0:16:04.63,0:16:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sempat panik\Nkarena datanya hilang.
Dialogue: 0,0:16:08.96,0:16:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu parah banget!{\i0}
Dialogue: 0,0:16:11.38,0:16:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Negosiasi sama percetakannya jadi susah.{\i0}
Dialogue: 0,0:16:14.34,0:16:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkanmu!
Dialogue: 0,0:16:16.89,0:16:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji akan lebih disiplin waktu.
Dialogue: 0,0:16:19.64,0:16:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu menambah asisten.
Dialogue: 0,0:16:22.02,0:16:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gabuchan dan Asa sedang rajin\Nmembantuku membuat naskah.
Dialogue: 0,0:16:26.23,0:16:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Oh, anak-anak yang suka kamu ceritakan?{\i0}
Dialogue: 0,0:16:30.19,0:16:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka anak baik.
Dialogue: 0,0:16:31.86,0:16:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kamu menggajinya, kan?{\i0}
Dialogue: 0,0:16:34.28,0:16:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:16:36.28,0:16:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi Hagure Sensei,\Nkenapa ruanganmu gelap sekali?{\i0}
Dialogue: 0,0:16:40.49,0:16:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kamu jadi kayak bos organisasi jahat.{\i0}
Dialogue: 0,0:16:43.79,0:16:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahku rusak,\Njadinya mati lampu sebagian.
Dialogue: 0,0:16:51.01,0:16:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ini lebih leluasa dari sandal.
Dialogue: 0,0:16:57.80,0:16:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka masih ada.
Dialogue: 0,0:16:59.51,0:17:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganti baju tidak cukup buat penyamaran, ya.
Dialogue: 0,0:17:02.18,0:17:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku niatnya memburu mereka duluan, sih…
Dialogue: 0,0:17:05.77,0:17:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, parangmu aku bawa\Ndan tertinggal di wisma Kagemori.
Dialogue: 0,0:17:11.48,0:17:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa repot kalau bawa-bawa parang\Ndi tengah kota, jadi tidak apa-apa.
Dialogue: 0,0:17:17.82,0:17:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau senjata,\Nbagaimana kalau kita ke markasku?
Dialogue: 0,0:17:21.29,0:17:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga butuh senjata.
Dialogue: 0,0:17:23.16,0:17:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatmu di dekat sini?
Dialogue: 0,0:17:25.46,0:17:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalan sedikit.
Dialogue: 0,0:17:27.67,0:17:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak perlu menghajar mata-mata itu?
Dialogue: 0,0:17:30.46,0:17:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya markasmu ketahuan.
Dialogue: 0,0:17:32.63,0:17:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja mereka ikut.
Dialogue: 0,0:17:34.97,0:17:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat meninggalkan markas itu,\Ntapi kita manfaatkan dulu.
Dialogue: 0,0:17:47.19,0:17:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti labirin, ya.
Dialogue: 0,0:17:48.98,0:17:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai terpisah.\NNanti kamu tersesat.
Dialogue: 0,0:18:12.71,0:18:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempatnya. Tidak perlu melepas sepatu.
Dialogue: 0,0:18:24.68,0:18:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil senjata yang kamu suka.
Dialogue: 0,0:18:31.73,0:18:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Tsugai lain di sini.
Dialogue: 0,0:18:33.94,0:18:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?\N- Sepertinya begitu.
Dialogue: 0,0:18:40.20,0:18:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu markasnya Tadera.
Dialogue: 0,0:18:42.62,0:18:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup.
Dialogue: 0,0:18:44.41,0:18:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kembali dan melaporkan tempat ini.
Dialogue: 0,0:18:47.75,0:18:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok pulang?
Dialogue: 0,0:18:51.13,0:18:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja dulu.
Dialogue: 0,0:18:59.93,0:19:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:19:12.81,0:19:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang\Ndi Mayoiga milik Klan Tadera.
Dialogue: 0,0:19:16.73,0:19:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batas dunia ini\Ndan dunia asli sangat tipis.
Dialogue: 0,0:19:20.11,0:19:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, cuma aku yang tahu jalan keluarnya.
Dialogue: 0,0:19:23.91,0:19:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendatang seperti kalian tidak bisa kabur.
Dialogue: 0,0:19:28.33,0:19:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu langkah di labirin ini,
Dialogue: 0,0:19:31.17,0:19:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu akan terjebak sampai mati.
Dialogue: 0,0:19:39.55,0:19:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulunya itu Klan Kagemori.
Dialogue: 0,0:19:42.43,0:19:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengikuti Klan Tadera kemari,\Nlalu mati karena terjebak.
Dialogue: 0,0:19:47.81,0:19:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada banyak, lo.
Dialogue: 0,0:19:50.56,0:19:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau bernasib sama,\Nkatakan identitas kalian.
Dialogue: 0,0:19:55.86,0:19:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:19:56.90,0:20:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Dera, keberadaan Tsugai\Nyang lain terus terasa.
Dialogue: 0,0:20:01.20,0:20:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti, soalnya…\NItu Tsugai-nya Klan Tadera.
Dialogue: 0,0:20:05.62,0:20:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah itu?
Dialogue: 0,0:20:07.91,0:20:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai itu bisa membuat Mayoiga.
Dialogue: 0,0:20:10.66,0:20:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip Desa Higashi, sekalinya orang masuk…
Dialogue: 0,0:20:12.79,0:20:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:20:14.29,0:20:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan yang itu.
Dialogue: 0,0:20:16.34,0:20:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sepasang lagi.
Dialogue: 0,0:21:22.03,0:21:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah.
Dialogue: 0,0:21:23.53,0:21:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah, wah, wah.
Dialogue: 0,0:21:26.86,0:21:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Penjaga Ilahi Sayuu.
Dialogue: 0,0:21:30.74,0:21:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, Dera, bawa dia dan pergilah.
Dialogue: 0,0:21:43.71,0:21:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka Tenaga dan Ashinaga.
Dialogue: 0,0:21:46.55,0:21:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bukan tandingannya.
Dialogue: 0,0:23:33.87,0:23:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bedebah!{\i0}
