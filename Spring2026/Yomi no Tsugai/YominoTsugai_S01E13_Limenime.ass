Dialogue: 0,0:00:01.91,0:00:03.42,sign,,0000,0000,0000,,{\an8}RINGKASAN SEJAUH INI
Dialogue: 0,0:01:09.73,0:01:10.65,sign,,0000,0000,0000,,KAI - FUU
Dialogue: 0,0:04:31.02,0:04:32.85,sign,,0000,0000,0000,,PINTU MASUK JALUR PENDAKIAN\NDESA HIGASHI LAMA
Dialogue: 0,0:15:36.47,0:15:38.89,sign,,0000,0000,0000,,PINTU MASUK JALUR PENDAKIAN\NDESA HIGASHI LAMA
Dialogue: 0,0:18:55.55,0:18:58.05,sign,,0000,0000,0000,,JAMPI-JAMPI, PENGUSIRAN ROH,\NPENGOBATAN GANGGUAN SPIRITUAL
Dialogue: 0,0:21:37.33,0:21:38.29,sign,,0000,0000,0000,,UNTUK YURU, KAMI MENYANDERA\NADIK PALSUMU DAN ANAK DARI DESA.
Dialogue: 0,0:23:27.61,0:23:29.03,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:08.25,0:00:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Anak kembar laki-laki dan perempuan\Nyang lahir saat siang dan malam setara,{\i0}
Dialogue: 0,0:00:12.92,0:00:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kelak akan jadi penguasa para Tsugai!{\i0}
Dialogue: 0,0:00:16.76,0:00:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Menurut legenda desa dari Timur,{\i0}
Dialogue: 0,0:00:19.76,0:00:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lahirnya anak kembar yang memisah siang\Ndan malam akan mengguncang dunia.{\i0}
Dialogue: 0,0:00:26.77,0:00:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sekitar 400 tahun lalu, terjadi perang\Nantara dua kubu di dalam negeri.{\i0}
Dialogue: 0,0:00:32.32,0:00:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Para pengguna Tsugai terlibat di baliknya.{\i0}
Dialogue: 0,0:00:36.53,0:00:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Warga Desa Higashi sengaja\Nmenahan si kembar tetap di desa{\i0}
Dialogue: 0,0:00:40.54,0:00:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}demi bisa memanfaatkan mereka.{\i0}
Dialogue: 0,0:00:44.58,0:00:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang tua si kembar sadar\Nakan bahaya yang mengancam{\i0}
Dialogue: 0,0:00:48.92,0:00:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan mencoba membawa keduanya kabur.{\i0}
Dialogue: 0,0:00:52.21,0:00:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sayangnya yang berhasil dibawa\Ncuma Asa, sang adik.{\i0}
Dialogue: 0,0:00:57.34,0:01:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Si kembar berpotensi memiliki\Nkekuatan istimewa.{\i0}
Dialogue: 0,0:01:01.06,0:01:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namanya Kai dan Fuu.{\i0}
Dialogue: 0,0:01:04.31,0:01:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kekuatan untuk membongkar\Nsegala hal secara paksa, Kai.{\i0}
Dialogue: 0,0:01:08.02,0:01:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan kebalikannya.{\i0}
Dialogue: 0,0:01:10.65,0:01:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kekuatan untuk menyegel\Nsegala hal secara paksa, Fuu.{\i0}
Dialogue: 0,0:01:16.82,0:01:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak memilih terlahir\Njadi kembar yang ditakdirkan.{\i0}
Dialogue: 0,0:01:21.62,0:01:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi mulai sekarang ini pilihanku.{\i0}
Dialogue: 0,0:01:25.37,0:01:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Meski harus mengotori tangan.{\i0}
Dialogue: 0,0:01:29.38,0:01:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah mendapatkan kekuatan Kai,{\i0}
Dialogue: 0,0:01:31.54,0:01:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Asa menyerang desa\Nuntuk merebut kembali Yuru.{\i0}
Dialogue: 0,0:01:35.09,0:01:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyingkir dari situ!
Dialogue: 0,0:01:38.97,0:01:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kekacauan itu membuat kami\Ndibangkitkan setelah 400 tahun.{\i0}
Dialogue: 0,0:01:44.77,0:01:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untung tuan yang baru tidak banyak aturan.{\i0}
Dialogue: 0,0:01:48.14,0:01:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, mereka adalah Tsugai milikmu.
Dialogue: 0,0:01:54.40,0:01:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Asa dilindungi oleh Klan Kagemori.{\i0}
Dialogue: 0,0:01:58.28,0:02:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Klan dari Desa Higashi{\i0}
Dialogue: 0,0:02:00.41,0:02:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang memisahkan diri\Nkarena beda pandangan.{\i0}
Dialogue: 0,0:02:03.54,0:02:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yuru tidak bergabung dengan mereka{\i0}
Dialogue: 0,0:02:06.00,0:02:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan memilih mencari orang tuanya sendiri.{\i0}
Dialogue: 0,0:02:09.29,0:02:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak akan lari atau sembunyi.{\i0}
Dialogue: 0,0:02:11.71,0:02:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena itu tidak perlu.{\i0}
Dialogue: 0,0:02:14.25,0:02:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Higashi maupun Klan Kagemori\Nterlalu ribet.
Dialogue: 0,0:02:17.67,0:02:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau nyawaku? Datang dan ambil saja!
Dialogue: 0,0:02:21.30,0:02:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan sepertinya,\NKagemori tidak semuanya sepaham.{\i0}
Dialogue: 0,0:02:26.52,0:02:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:02:28.39,0:02:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pernah mati sekali.
Dialogue: 0,0:02:30.35,0:02:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kai dan Fuu sebaiknya tidak ada.{\i0}
Dialogue: 0,0:02:33.69,0:02:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zaman sudah berubah.
Dialogue: 0,0:02:35.40,0:02:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai keturunan desa itu,\Nkitalah yang harus mengakhirinya.
Dialogue: 0,0:02:41.16,0:02:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kai dan Fuu memang\Ndihasilkan Desa Higashi.
Dialogue: 0,0:02:45.41,0:02:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan harus tetap begitu.{\i0}
Dialogue: 0,0:02:48.16,0:02:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sepertinya ada campur tangan pihak lain.{\i0}
Dialogue: 0,0:02:52.67,0:02:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita harus berhati-hati.{\i0}
Dialogue: 0,0:04:32.85,0:04:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:33.98,0:04:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhenti membuntutinya di tengah jalan
Dialogue: 0,0:04:38.36,0:04:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa dukun itu sudah sampai\Ndi Desa Higashi.
Dialogue: 0,0:04:42.11,0:04:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kerja bagus.
Dialogue: 0,0:04:44.65,0:04:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting dia sudah masuk desa,\Nbersiagalah di situ.
Dialogue: 0,0:04:49.53,0:04:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah, Ivan.
Dialogue: 0,0:04:54.12,0:04:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:04:56.37,0:04:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Shokyo.
Dialogue: 0,0:04:58.04,0:05:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Biasakan panggil aku Tuan Shokyo!
Dialogue: 0,0:05:02.46,0:05:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, majikannya itu aku.
Dialogue: 0,0:05:05.72,0:05:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membantah!\NKamu mau dicincang, Nyet?
Dialogue: 0,0:05:09.10,0:05:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daikyo, tolong nasihati dia.
Dialogue: 0,0:05:14.10,0:05:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malah berpaling.
Dialogue: 0,0:05:16.10,0:05:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergerak tanpa tuan saja tidak bisa,\Nkok kamu sesombong itu?
Dialogue: 0,0:05:21.23,0:05:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bacot!
Dialogue: 0,0:05:22.69,0:05:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cuma ampas tanpa kami, Nyet!
Dialogue: 0,0:05:25.99,0:05:28.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lupa siapa yang menghidupimu?
Dialogue: 0,0:05:28.11,0:05:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku sendiri, lah, dasar tumpul.
Dialogue: 0,0:05:31.03,0:05:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monyet!
Dialogue: 0,0:05:31.95,0:05:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik, cepat pergi!
Dialogue: 0,0:05:34.12,0:05:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekerjalah dengan benar!\NAku sudah bayar mahal!
Dialogue: 0,0:05:37.42,0:05:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, deh.
Dialogue: 0,0:05:47.76,0:05:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup.
Dialogue: 0,0:05:51.64,0:05:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu.
Dialogue: 0,0:06:02.44,0:06:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:06:16.91,0:06:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini?
Dialogue: 0,0:06:18.79,0:06:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:06:19.92,0:06:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa? Bikin senjata lagi?
Dialogue: 0,0:06:23.25,0:06:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung gabut.
Dialogue: 0,0:06:25.00,0:06:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, biar kuberi hiburan.
Dialogue: 0,0:06:28.63,0:06:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan apa itu?
Dialogue: 0,0:06:30.34,0:06:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Televisi.
Dialogue: 0,0:06:31.68,0:06:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terasi?
Dialogue: 0,0:06:34.47,0:06:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Potensi hujan sore ini, nol persen.{\i0}
Dialogue: 0,0:06:36.27,0:06:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sepertinya kemarau akan berlanjut.{\i0}
Dialogue: 0,0:06:40.94,0:06:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Musim panas ini, dikhawatirkan\Nadanya krisis air di Jepang Barat.{\i0}
Dialogue: 0,0:06:45.61,0:06:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berikutnya cuaca nasional.{\i0}
Dialogue: 0,0:06:47.94,0:06:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Okinawa cerah, disusul Kepulauan Tokara…{\i0}
Dialogue: 0,0:06:51.32,0:06:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa pergi\Nke kampung halaman Ibu.
Dialogue: 0,0:06:55.16,0:06:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu?
Dialogue: 0,0:06:56.24,0:06:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:06:57.91,0:07:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampung halaman ibumu di Echigo, kan?
Dialogue: 0,0:07:01.79,0:07:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar Etiopia, ada di luar negeri.
Dialogue: 0,0:07:05.21,0:07:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kamu tidak tertarik ke sana?
Dialogue: 0,0:07:09.17,0:07:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya jauh, sih.
Dialogue: 0,0:07:12.14,0:07:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bahkan tidak bisa pulang\Nke desamu, ya?
Dialogue: 0,0:07:16.43,0:07:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepulanganku akan berbahaya
Dialogue: 0,0:07:19.93,0:07:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagi Desa Higashi.
Dialogue: 0,0:07:25.02,0:07:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi banyak yang tertinggal di sana,{\i0}
Dialogue: 0,0:07:28.44,0:07:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku ingin pulang kalau memang bisa.{\i0}
Dialogue: 0,0:07:32.70,0:07:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa jadi begini?
Dialogue: 0,0:07:37.83,0:07:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbah Dukun.
Dialogue: 0,0:07:40.37,0:07:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan ke mana-mana.
Dialogue: 0,0:07:43.12,0:07:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, Nyet.
Dialogue: 0,0:07:44.33,0:07:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan Tsugai lain di pusat kastel.
Dialogue: 0,0:07:48.96,0:07:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pusat kastel, ya.
Dialogue: 0,0:07:50.80,0:07:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata pepatah, tempat tinggi\Ndisukai orang bodoh dan…
Dialogue: 0,0:07:54.26,0:07:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang bodoh dan monyet, kan?
Dialogue: 0,0:07:56.01,0:07:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang bodoh dan asap, lah, dasar bodoh.
Dialogue: 0,0:07:58.14,0:08:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang bodoh!
Dialogue: 0,0:08:10.32,0:08:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu parah, sih.
Dialogue: 0,0:08:11.78,0:08:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang.
Dialogue: 0,0:08:17.70,0:08:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia terlihat asing.\N- Iya.
Dialogue: 0,0:08:22.91,0:08:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:08:25.00,0:08:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kok bisa ke sini…\N- Hei!
Dialogue: 0,0:08:30.51,0:08:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:08:36.55,0:08:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merepotkan.
Dialogue: 0,0:08:53.69,0:08:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga bukan.
Dialogue: 0,0:09:00.28,0:09:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukan, bukan, bukan.{\i0}
Dialogue: 0,0:09:04.04,0:09:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukan dia.{\i0}
Dialogue: 0,0:09:06.04,0:09:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia juga bukan.{\i0}
Dialogue: 0,0:09:16.72,0:09:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir saja.
Dialogue: 0,0:09:20.68,0:09:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu? Komplotan yang waktu itu?
Dialogue: 0,0:09:25.18,0:09:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warga sudah berjaga ketat\Ndan pelindungnya pun utuh.
Dialogue: 0,0:09:28.94,0:09:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caramu masuk?
Dialogue: 0,0:09:45.00,0:09:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah itu…
Dialogue: 0,0:09:47.21,0:09:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai yang ada dalam kurungan…
Dialogue: 0,0:09:50.00,0:09:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Asa palsu, ya?
Dialogue: 0,0:09:52.71,0:09:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan karena muncul saat nenek ini terancam,
Dialogue: 0,0:09:57.47,0:09:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti dia tuanmu, ya?
Dialogue: 0,0:10:07.64,0:10:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tuanmu disandera,\Nkok berani sekali?
Dialogue: 0,0:10:12.19,0:10:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau dia Tsugai,{\i0}
Dialogue: 0,0:10:13.65,0:10:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}seharusnya mereka sepasang.{\i0}
Dialogue: 0,0:10:17.86,0:10:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di mana pasangannya?{\i0}
Dialogue: 0,0:10:21.37,0:10:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyet, lihat kakimu!
Dialogue: 0,0:10:35.92,0:10:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tega banget, Shokyo.
Dialogue: 0,0:10:38.97,0:10:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Masih mending daripada mati, kan?
Dialogue: 0,0:10:42.09,0:10:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sujud dan berterima kasih!
Dialogue: 0,0:10:45.81,0:10:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa sujud dengan kaki begini.
Dialogue: 0,0:10:49.98,0:10:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mirip Asa.
Dialogue: 0,0:10:52.23,0:10:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dibuat lebih mungil dari aslinya.
Dialogue: 0,0:10:56.61,0:11:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar kalau si Abang mau menetap di desa\Nuntuk melindungi adik semanis ini.
Dialogue: 0,0:11:02.37,0:11:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar licik.
Dialogue: 0,0:11:04.95,0:11:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mentang-mentang\Nwarga tidak bisa melihat Tsugai,{\i0}
Dialogue: 0,0:11:07.91,0:11:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia mau mengambil kekuatan itu\Nagar bisa dipuja-puja seisi desa?{\i0}
Dialogue: 0,0:11:13.96,0:11:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanmu sangat licik dan tidak tahu malu.
Dialogue: 0,0:11:18.01,0:11:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau nenek itu kubunuh,\Nnanti kamu jadi Tsugai liar.
Dialogue: 0,0:11:23.14,0:11:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami butuh wajah ini,\Nsia-sia kalau wujudmu berubah.
Dialogue: 0,0:11:28.35,0:11:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau saja mengontrakmu.
Dialogue: 0,0:11:31.02,0:11:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Sang Petaka milikku…
Dialogue: 0,0:11:34.15,0:11:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama Shokyo,\Nsusah akur sama Tsugai lain.
Dialogue: 0,0:11:38.48,0:11:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kamu malah dibunuh.
Dialogue: 0,0:11:42.41,0:11:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh!
Dialogue: 0,0:11:44.20,0:11:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, kan.
Dialogue: 0,0:11:46.66,0:11:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawa tuanmu aman asal menuruti padaku.
Dialogue: 0,0:11:52.12,0:11:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ikut, Asa palsu.
Dialogue: 0,0:11:55.63,0:11:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke dataran rendah?
Dialogue: 0,0:11:57.29,0:11:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Di sana asyik, lo.
Dialogue: 0,0:12:14.31,0:12:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:16.56,0:12:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut.
Dialogue: 0,0:12:29.83,0:12:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ujungnya pasangan Tsugai ini tidak muncul.{\i0}
Dialogue: 0,0:12:34.67,0:12:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kok aneh? Apa yang dia incar?{\i0}
Dialogue: 0,0:12:37.84,0:12:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cari sandera manusia juga\Nbuat jaga-jaga, ah.{\i0}
Dialogue: 0,0:12:49.56,0:12:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan anak kalem!
Dialogue: 0,0:12:54.31,0:12:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:12:57.44,0:12:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjadi lagi.
Dialogue: 0,0:12:58.90,0:13:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parah sekali.
Dialogue: 0,0:13:00.73,0:13:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa ini sudah tidak punya harapan.
Dialogue: 0,0:13:03.94,0:13:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, ayo kabur, dia berbahaya!
Dialogue: 0,0:13:06.32,0:13:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Danji, kamu pernah bilang mau\Nke dataran rendah bersama Yuru, kan?
Dialogue: 0,0:13:12.20,0:13:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:13.41,0:13:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah turun gunung, sendirian.
Dialogue: 0,0:13:16.58,0:13:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sendirian? Ibu tidak ikut?
Dialogue: 0,0:13:20.09,0:13:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tetap di sini.
Dialogue: 0,0:13:22.25,0:13:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan kalau tidak ada\Nyang menyambut orang yang pulang.
Dialogue: 0,0:13:27.72,0:13:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:13:29.09,0:13:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalur keluar desa tertulis di sini.
Dialogue: 0,0:13:32.97,0:13:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai kesasar.
Dialogue: 0,0:13:37.81,0:13:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah dari sini dan bantulah Yuru.
Dialogue: 0,0:13:41.73,0:13:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertemu Mine dan Nagisa,\Nsampaikan salam dariku.
Dialogue: 0,0:13:51.99,0:13:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini? Siapa sebenarnya
Dialogue: 0,0:13:55.87,0:13:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pria itu?
Dialogue: 0,0:14:04.05,0:14:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang jangan ke mana-mana.
Dialogue: 0,0:14:22.40,0:14:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pergilah duluan.
Dialogue: 0,0:14:37.29,0:14:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di dataran rendah.
Dialogue: 0,0:14:48.05,0:14:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat transportasiku hilang, deh.
Dialogue: 0,0:14:54.47,0:14:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak tahu jalan,
Dialogue: 0,0:14:57.98,0:15:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong antarkan aku pulang, Mbah Dukun.
Dialogue: 0,0:15:39.73,0:15:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di luar desa?
Dialogue: 0,0:15:43.23,0:15:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru.
Dialogue: 0,0:15:44.98,0:15:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus segera
Dialogue: 0,0:15:47.61,0:15:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencari Yuru.
Dialogue: 0,0:15:56.49,0:15:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau naik?
Dialogue: 0,0:16:02.00,0:16:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenalannya Penjaga Ilahi Sayuu?
Dialogue: 0,0:16:04.96,0:16:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya. Kami teman lama.
Dialogue: 0,0:16:08.30,0:16:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari, mereka kabur\Nbersama seorang anak kembar.
Dialogue: 0,0:16:12.34,0:16:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembar? Pasti Yuru!
Dialogue: 0,0:16:14.30,0:16:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka naik mobil dan bilang\Nmau sembunyi di permukiman ramai.
Dialogue: 0,0:16:18.85,0:16:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil?
Dialogue: 0,0:16:23.81,0:16:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendaraannya seperti itu.
Dialogue: 0,0:16:27.19,0:16:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Yuru berhasil\Nke dataran rendah, syukurlah.
Dialogue: 0,0:16:32.28,0:16:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak tahu dia ke mana.
Dialogue: 0,0:16:35.57,0:16:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setahuku, mobilnya pakai pelat nomor kota.
Dialogue: 0,0:16:40.83,0:16:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo kita ke sana.\N- Eh?
Dialogue: 0,0:16:44.29,0:16:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku baru pertama pergi ke kota!
Dialogue: 0,0:16:47.17,0:16:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sebelum pergi,\Ntuanku harus dikabari dulu.
Dialogue: 0,0:16:51.71,0:16:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mampir ke rumahku dulu, ya?
Dialogue: 0,0:16:53.92,0:16:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah.
Dialogue: 0,0:16:59.60,0:17:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, mau menemui temanmu yang pergi jauh?
Dialogue: 0,0:17:04.10,0:17:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bareng teman dari majikan temanku.
Dialogue: 0,0:17:08.90,0:17:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal!
Dialogue: 0,0:17:12.44,0:17:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, anak yang manis.
Dialogue: 0,0:17:15.57,0:17:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia punya siapa, ya?
Dialogue: 0,0:17:20.62,0:17:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati sama mobil.
Dialogue: 0,0:17:23.04,0:17:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengejutkan warga biasa, ya.
Dialogue: 0,0:17:25.37,0:17:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, sampai jumpa.
Dialogue: 0,0:17:27.92,0:17:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersenang-senanglah di sana.
Dialogue: 0,0:17:30.54,0:17:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh? Hore!
Dialogue: 0,0:17:34.42,0:17:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kita lewat jalan tol.
Dialogue: 0,0:17:37.63,0:17:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Jalan tol?
Dialogue: 0,0:17:49.56,0:17:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke rest area, yuk!
Dialogue: 0,0:18:11.09,0:18:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan dari siapa, ya?
Dialogue: 0,0:18:15.76,0:18:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, aku pergi kerja dulu.
Dialogue: 0,0:18:19.34,0:18:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, berjuanglah.
Dialogue: 0,0:18:21.89,0:18:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya, si Dukun dibunuh.
Dialogue: 0,0:18:33.19,0:18:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kami berkunjung,
Dialogue: 0,0:18:37.11,0:18:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia sudah mati.
Dialogue: 0,0:18:38.82,0:18:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, gede banget.
Dialogue: 0,0:18:40.82,0:18:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menguburnya pasti sulit.
Dialogue: 0,0:18:43.74,0:18:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini perlu bayaran ekstra.
Dialogue: 0,0:18:46.12,0:18:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, bukankah Mbah Dukun punya Tsugai?
Dialogue: 0,0:18:50.08,0:18:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka jadi liar, dong?
Dialogue: 0,0:18:52.25,0:18:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, Lady dan Gentleman?
Dialogue: 0,0:18:59.72,0:19:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka juga ditebas bareng si Dukun.{\i0}
Dialogue: 0,0:19:02.89,0:19:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jahat sekali.{\i0}
Dialogue: 0,0:19:04.81,0:19:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Padahal mereka bukan tipe petarung.{\i0}
Dialogue: 0,0:19:08.43,0:19:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana reliknya? Biar sekalian aku kubur.
Dialogue: 0,0:19:12.23,0:19:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayar lagi?
Dialogue: 0,0:19:14.61,0:19:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:19:18.53,0:19:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, coba lihat ini.
Dialogue: 0,0:19:29.79,0:19:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Untuk Yuru, kami menyandera\Nadik palsumu dan anak dari desa.
Dialogue: 0,0:19:34.71,0:19:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datanglah ke gudang\NFujimurayama nomor satu
Dialogue: 0,0:19:37.59,0:19:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di purnama selanjutnya\Npada jam babi hutan.
Dialogue: 0,0:19:40.88,0:19:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari Klan Kagemori?
Dialogue: 0,0:19:42.38,0:19:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:19:43.93,0:19:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum ke Desa Higashi,\NMbah Dukun sempat bilang,
Dialogue: 0,0:19:47.89,0:19:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadera kabur ke dataran rendah\Nmembawa Yuru.
Dialogue: 0,0:19:51.64,0:19:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan mereka sempat cekcok\Ndengan Klan Kagemori.
Dialogue: 0,0:19:55.11,0:19:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu mereka ada di mana?
Dialogue: 0,0:19:58.28,0:20:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang tahu, deh.
Dialogue: 0,0:20:01.07,0:20:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang mengantar mereka\Nke dekat markasnya Dera, sih.
Dialogue: 0,0:20:06.33,0:20:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah ke mana lagi mereka setelah itu.
Dialogue: 0,0:20:09.54,0:20:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior orangnya sangat tertutup.
Dialogue: 0,0:20:12.33,0:20:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga, sifatnya memang begitu.
Dialogue: 0,0:20:16.59,0:20:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertemu Tadera atau Yuru,\Nrahasiakan pesan ini.
Dialogue: 0,0:20:21.26,0:20:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami para bandit yang ke sana.
Dialogue: 0,0:20:24.34,0:20:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai Yuru bertemu pelakunya.
Dialogue: 0,0:20:33.10,0:20:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, kerjaannya makin ribet saja.
Dialogue: 0,0:20:39.52,0:20:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oshirasama!
Dialogue: 0,0:20:42.40,0:20:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong turunkan aku!
Dialogue: 0,0:20:50.33,0:20:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu takut ketinggian, Danji?
Dialogue: 0,0:20:52.62,0:20:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota seram banget!
Dialogue: 0,0:20:55.54,0:20:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabar,\Naku sedang mencari keberadaan Sayuu.
Dialogue: 0,0:21:01.38,0:21:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hawa sekuat mereka
Dialogue: 0,0:21:04.30,0:21:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya cepat ketemu.
Dialogue: 0,0:21:08.18,0:21:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku baru sadar.
Dialogue: 0,0:21:14.10,0:21:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata di kota juga ada banyak Tsugai.
Dialogue: 0,0:21:38.29,0:21:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertemu Tadera atau Yuru,\Nrahasiakan pesan ini.
Dialogue: 0,0:21:42.84,0:21:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kurahasiakan, kok,\Nsupaya bisa hidup damai.
Dialogue: 0,0:21:50.51,0:21:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang bijak akan menjauhi masalah, kan?
Dialogue: 0,0:23:29.03,0:23:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Siapa pembunuhnya?{\i0}
Dialogue: 0,0:23:31.49,0:23:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada Tsugai lain di dekat sini.{\i0}
Dialogue: 0,0:23:33.41,0:23:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayo cegat mereka di sini.{\i0}
Dialogue: 0,0:23:35.53,0:23:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Ada pesan yang ditulis di tubuh si Dukun.{\i0}
