Dialogue: 0,0:23:27.53,0:23:28.90,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:33.21,0:01:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pertama kali aku merasakan\Nniat membunuh orang lain{\i0}
Dialogue: 0,0:01:37.51,0:01:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah sesaat sebelum Ayah\Ndan Ibu pergi dari desa.{\i0}
Dialogue: 0,0:01:42.56,0:01:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pelakunya mungkin bandit.{\i0}
Dialogue: 0,0:01:44.85,0:01:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat pergi berburu bersama Ayah,{\i0}
Dialogue: 0,0:01:47.69,0:01:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku hampir dibunuh.{\i0}
Dialogue: 0,0:01:51.73,0:01:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hawa penolakan yang seolah berkata,{\i0}
Dialogue: 0,0:01:55.82,0:01:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Dunia tidak membutuhkanmu."{\i0}
Dialogue: 0,0:02:00.70,0:02:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terasa menyusup lewat pori-pori,{\i0}
Dialogue: 0,0:02:04.87,0:02:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menembus kulit, lalu menusuk langsung\Nke daging dan organ dalamku.{\i0}
Dialogue: 0,0:02:26.06,0:02:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru!
Dialogue: 0,0:02:28.52,0:02:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru!
Dialogue: 0,0:02:30.40,0:02:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu aman? Ada yang terluka?
Dialogue: 0,0:02:34.19,0:02:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini… Darah orang itu.
Dialogue: 0,0:02:37.44,0:02:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:02:39.74,0:02:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini karena aku lengah!
Dialogue: 0,0:02:43.37,0:02:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu tadi?
Dialogue: 0,0:02:47.45,0:02:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, ingat baik-baik.
Dialogue: 0,0:02:50.50,0:02:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya niat membunuh.
Dialogue: 0,0:02:55.67,0:02:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sesekali… Tidak.
Dialogue: 0,0:02:59.47,0:03:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Selama masih hidup,\Nkamu akan terus mengalaminya.
Dialogue: 0,0:03:04.22,0:03:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jangan beri ampun\Npada siapa pun yang mengincarmu.
Dialogue: 0,0:03:31.12,0:03:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah lebih tenang?
Dialogue: 0,0:03:35.59,0:03:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah bermalam di gunung ini,\Nayo pulang.
Dialogue: 0,0:03:39.71,0:03:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenangkan hatimu.
Dialogue: 0,0:03:41.97,0:03:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik napas dalam-dalam, buang perlahan.
Dialogue: 0,0:03:49.02,0:03:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, buang gejolak batinmu\Nbersama embusan napas.
Dialogue: 0,0:03:54.73,0:03:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati yang goyah bisa berujung maut.
Dialogue: 0,0:03:59.07,0:04:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi bagi pemburu seperti kita
Dialogue: 0,0:04:01.65,0:04:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang bertaruh nyawa dengan para hewan.
Dialogue: 0,0:04:05.66,0:04:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah dan amati situasinya.
Dialogue: 0,0:04:08.49,0:04:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu pikirkan harus apa\Ndan bagaimana cara bertahan hidup
Dialogue: 0,0:04:14.00,0:04:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan apa yang ada.
Dialogue: 0,0:04:17.84,0:04:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematian bisa datang saat hatimu goyah.
Dialogue: 0,0:04:26.84,0:04:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah, Yuru.
Dialogue: 0,0:04:28.68,0:04:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang ke warga desa\Nbahwa kamu diserang.
Dialogue: 0,0:04:32.14,0:04:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:04:33.06,0:04:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau rekan bandit itu\Nmenyerang desa?
Dialogue: 0,0:04:36.77,0:04:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warga harus diberi tahu.
Dialogue: 0,0:04:39.44,0:04:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, desa pasti aman.
Dialogue: 0,0:04:43.78,0:04:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang-bilang,\Nbersikaplah biasa saat kita pulang.
Dialogue: 0,0:04:49.03,0:04:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah tidak terjadi apa pun.
Dialogue: 0,0:04:52.91,0:04:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah tenang.
Dialogue: 0,0:05:03.38,0:05:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mine.
Dialogue: 0,0:05:05.72,0:05:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pulang.
Dialogue: 0,0:05:07.09,0:05:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:05:08.72,0:05:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat khawatir\Nkarena kalian tidak pulang semalam.
Dialogue: 0,0:05:12.77,0:05:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:05:14.10,0:05:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengejar mangsa terlalu jauh.
Dialogue: 0,0:05:17.48,0:05:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bawa Yuru,\Naku memutuskan bermalam di gunung.
Dialogue: 0,0:05:22.03,0:05:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berburu semalaman tanpa hasil?
Dialogue: 0,0:05:24.99,0:05:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben kamu begitu.
Dialogue: 0,0:05:29.03,0:05:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya juga hidup.
Dialogue: 0,0:05:33.49,0:05:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mine!
Dialogue: 0,0:05:36.41,0:05:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka, kami pulang.
Dialogue: 0,0:05:38.92,0:05:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:05:40.33,0:05:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru juga ada.
Dialogue: 0,0:05:42.00,0:05:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami khawatir sebab kalian\Ntidak kunjung pulang.
Dialogue: 0,0:05:47.18,0:05:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang terjadi di gunung?
Dialogue: 0,0:05:50.68,0:05:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada, kami cuma kejauhan\Nmengejar mangsa.
Dialogue: 0,0:05:59.73,0:06:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terluka?
Dialogue: 0,0:06:04.98,0:06:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu darah tikus makan malam kami.
Dialogue: 0,0:06:07.40,0:06:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku lapar.
Dialogue: 0,0:06:09.16,0:06:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tikus tidak bikin kenyang.
Dialogue: 0,0:06:12.20,0:06:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagisa bersama Asa?
Dialogue: 0,0:06:14.33,0:06:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dia di dalam.
Dialogue: 0,0:06:16.41,0:06:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kita sarapan, Yuru.
Dialogue: 0,0:06:20.12,0:06:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:23.34,0:06:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagisa.
Dialogue: 0,0:06:25.96,0:06:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, kami pulang.
Dialogue: 0,0:06:27.88,0:06:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, aku cemas\Nkarena kalian tidak kunjung pulang.
Dialogue: 0,0:06:31.47,0:06:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:06:33.10,0:06:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Asa, kami pulang terlambat\Nkarena berburu terlalu jauh.
Dialogue: 0,0:06:37.98,0:06:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak terluka?
Dialogue: 0,0:06:39.81,0:06:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak baik-baik saja?
Dialogue: 0,0:06:41.31,0:06:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:06:44.52,0:06:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman.
Dialogue: 0,0:06:46.61,0:06:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tidur di luar bikin aku grogi\Nsampai susah tidur.
Dialogue: 0,0:06:51.49,0:06:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi agak lelah.
Dialogue: 0,0:06:54.66,0:06:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:06:56.83,0:06:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga kesehatanmu, ya.
Dialogue: 0,0:07:09.59,0:07:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sedikit lagi dapat.
Dialogue: 0,0:07:13.01,0:07:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ukurannya sangat besar.\N- Nagisa.
Dialogue: 0,0:07:14.60,0:07:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali Kakak pasti berhasil.
Dialogue: 0,0:07:18.35,0:07:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu benar.\N- Iya, aku tidak sabar melihatnya.
Dialogue: 0,0:07:30.86,0:07:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak lama setelah itu,{\i0}
Dialogue: 0,0:07:33.57,0:07:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayah dan Ibu pergi dari desa\Nmeninggalkan kami.{\i0}
Dialogue: 0,0:07:38.16,0:07:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku pikir begitu.{\i0}
Dialogue: 0,0:07:40.33,0:07:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ternyata cuma aku yang ditinggalkan.{\i0}
Dialogue: 0,0:07:43.67,0:07:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayah dan Ibu kabur dari desa\Nsambil membawa Asa.{\i0}
Dialogue: 0,0:07:48.67,0:07:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang yang kuanggap Asa\Nselama sepuluh tahun ini,{\i0}
Dialogue: 0,0:07:53.51,0:07:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ternyata palsu.{\i0}
Dialogue: 0,0:07:56.43,0:08:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Warga Desa Higashi menipuku\Nselama sepuluh tahun.{\i0}
Dialogue: 0,0:08:01.89,0:08:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itulah kesaksian orang\Nyang mengaku Asa asli ini.{\i0}
Dialogue: 0,0:08:06.36,0:08:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang ini juga bilang…{\i0}
Dialogue: 0,0:08:10.03,0:08:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah mati sekali.
Dialogue: 0,0:08:14.49,0:08:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh pembunuh Desa Higashi.
Dialogue: 0,0:08:24.33,0:08:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah lolos dari berbagai pengejaran,
Dialogue: 0,0:08:28.84,0:08:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kukira kami aman\Nsaat dilindungi Klan Kagemori.
Dialogue: 0,0:08:32.72,0:08:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Ayah dan Ibu menghilang.
Dialogue: 0,0:08:37.01,0:08:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahun lalu saat berusia 15 tahun,\Naku diculik oleh pembunuh.
Dialogue: 0,0:08:41.22,0:08:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Di situlah aku dibunuh
Dialogue: 0,0:08:44.14,0:08:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}dan mendapatkan kekuatan Kai.
Dialogue: 0,0:08:55.95,0:09:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini kekuatan Tsugai yang berada\Ndi perbatasan dunia kematian{\i0}
Dialogue: 0,0:09:00.62,0:09:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan dunia manusia.{\i0}
Dialogue: 0,0:09:08.79,0:09:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bertemu Tsugai pemilik Kai.{\i0}
Dialogue: 0,0:09:15.63,0:09:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada daging datang.
Dialogue: 0,0:09:20.60,0:09:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:09:24.14,0:09:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku ditikam pembunuh…
Dialogue: 0,0:09:27.10,0:09:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu mati.
Dialogue: 0,0:09:30.15,0:09:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah mati.
Dialogue: 0,0:09:34.94,0:09:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini neraka?
Dialogue: 0,0:09:37.24,0:09:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tidak terlihat seperti surga, sih.
Dialogue: 0,0:09:41.20,0:09:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa kamu bisa seyakin itu
Dialogue: 0,0:09:45.45,0:09:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan masuk neraka setelah mati?
Dialogue: 0,0:09:49.38,0:09:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa hidupmu di dunia sana?
Dialogue: 0,0:09:55.30,0:10:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini perbatasan\Nantara dunia kematian dan dunia kalian.
Dialogue: 0,0:10:04.14,0:10:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, di mana, ya?
Dialogue: 0,0:10:13.52,0:10:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:10:16.74,0:10:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian menyebut tempat ini\NYomotsu Hirasaka.
Dialogue: 0,0:10:24.16,0:10:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti cerita Ayah.
Dialogue: 0,0:10:27.12,0:10:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut legenda desa,
Dialogue: 0,0:10:29.17,0:10:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat siang dan malam setara\Ndi sebuah desa Timur,
Dialogue: 0,0:10:32.42,0:10:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak kembar laki-laki\Ndan perempuan yang lahir
Dialogue: 0,0:10:35.59,0:10:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan mengunjungi alam baka\Ndan jadi penguasa para Tsugai.
Dialogue: 0,0:10:39.97,0:10:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerita mulut ke mulut\Nmemang suka melenceng.
Dialogue: 0,0:10:43.64,0:10:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepatnya, ini di ambang alam baka.
Dialogue: 0,0:10:48.27,0:10:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang Desa Higashi benar-benar membunuhku.
Dialogue: 0,0:10:53.86,0:10:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya harus mati dulu buat bisa kemari.
Dialogue: 0,0:10:57.78,0:11:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jadi, bagaimana?\N- Eh?
Dialogue: 0,0:11:01.53,0:11:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang ke sini punya dua pilihan.
Dialogue: 0,0:11:05.79,0:11:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mati atau menerimaku?
Dialogue: 0,0:11:09.83,0:11:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau mati, jatuh saja dari jalur itu.
Dialogue: 0,0:11:14.29,0:11:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau hidup, ambil aku…
Dialogue: 0,0:11:16.88,0:11:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil Kai dan kembalilah ke duniamu.
Dialogue: 0,0:11:21.80,0:11:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Praktis, lo.
Dialogue: 0,0:11:23.64,0:11:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa memenggal pemimpin musuh\Nasal dia masuk garis pandangmu.
Dialogue: 0,0:11:30.02,0:11:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perang bisa kamu akhiri sendirian.
Dialogue: 0,0:11:34.15,0:11:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa jadi pahlawan\Nkalau eranya tepat.
Dialogue: 0,0:11:38.03,0:11:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan banyak kegunaan lainnya.
Dialogue: 0,0:11:41.57,0:11:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, banyak yang akan\Nmencoba memanfaatkanmu.
Dialogue: 0,0:11:46.70,0:11:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa saja merasakan neraka\Nselagi hidup.
Dialogue: 0,0:11:49.79,0:11:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga kematian akan serasa lebih enteng.
Dialogue: 0,0:11:54.71,0:11:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin nerakaku sudah dimulai.
Dialogue: 0,0:11:58.71,0:12:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kehilangan arah semenjak\NAyah dan Ibu diculik.
Dialogue: 0,0:12:03.93,0:12:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu begini karena aku terlahir.
Dialogue: 0,0:12:09.93,0:12:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu! Kakakku juga datang kemari?
Dialogue: 0,0:12:13.85,0:12:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Apa dia dibunuh?
Dialogue: 0,0:12:15.69,0:12:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, kalaupun mati\Ndia akan datang ke tempat Fuu.
Dialogue: 0,0:12:21.74,0:12:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ke sini.
Dialogue: 0,0:12:25.07,0:12:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu bagaimana nasib kakakmu.
Dialogue: 0,0:12:35.42,0:12:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum boleh mati.
Dialogue: 0,0:12:38.38,0:12:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak masih tertinggal di desa.
Dialogue: 0,0:12:41.42,0:12:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah dia masih hidup atau tidak.
Dialogue: 0,0:12:44.05,0:12:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan dia dibunuh juga?
Dialogue: 0,0:12:46.80,0:12:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menolongnya.
Dialogue: 0,0:12:49.35,0:12:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum boleh mati!
Dialogue: 0,0:12:52.31,0:12:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih, mau hidup atau mati?
Dialogue: 0,0:13:03.28,0:13:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matamu indah sekali.
Dialogue: 0,0:13:06.41,0:13:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah tatap ke depan\Ndan jangan menoleh.
Dialogue: 0,0:13:21.42,0:13:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, dia tidak hidup lagi!
Dialogue: 0,0:13:24.05,0:13:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:13:25.72,0:13:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kembar yang muncul\Nsetelah 400 tahun lamanya, lo!
Dialogue: 0,0:13:29.14,0:13:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia cuma orang palsu\Ndari Kagemori?
Dialogue: 0,0:13:32.64,0:13:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihatnya waktu di desa!\NMustahil salah!
Dialogue: 0,0:13:36.27,0:13:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu bertahun-tahun lalu\Nsaat dia kecil, kan?
Dialogue: 0,0:13:39.52,0:13:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurungannya gelap pula!
Dialogue: 0,0:13:41.94,0:13:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang wajahnya kelihatan?
Dialogue: 0,0:13:44.36,0:13:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan!
Dialogue: 0,0:13:46.15,0:13:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kebangkitannya gagal,\NKai hangus begitu saja!
Dialogue: 0,0:13:50.49,0:13:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada Fuu!
Dialogue: 0,0:13:52.58,0:13:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuu cukup untuk mengubah dunia!
Dialogue: 0,0:13:56.00,0:13:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakaknya masih ada di desa.
Dialogue: 0,0:13:58.17,0:14:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuu bisa kita kontrol sepenuhnya.
Dialogue: 0,0:14:01.04,0:14:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bunuh dia dan…
Dialogue: 0,0:14:23.44,0:14:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa ketemu?
Dialogue: 0,0:14:25.57,0:14:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana dia?
Dialogue: 0,0:14:28.24,0:14:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa!
Dialogue: 0,0:14:30.66,0:14:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asa!
Dialogue: 0,0:14:41.54,0:14:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:14:44.84,0:14:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya biar aku saja\Nyang melakukan pekerjaan kotor.
Dialogue: 0,0:14:50.43,0:14:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Gabuchan.
Dialogue: 0,0:14:52.60,0:14:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memilih terlahir\Njadi kembar yang ditakdirkan.
Dialogue: 0,0:14:57.27,0:14:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang ini pilihanku.
Dialogue: 0,0:15:01.56,0:15:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski harus mengotori tangan.
Dialogue: 0,0:15:07.28,0:15:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kakak.
Dialogue: 0,0:15:09.95,0:15:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok mungil, imut, dan polos\NAsa yang kamu kenal…
Dialogue: 0,0:15:15.91,0:15:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sudah tidak ada lagi.
Dialogue: 0,0:15:28.88,0:15:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sapi dan kuda, ya.
Dialogue: 0,0:15:31.68,0:15:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka Gozu dan Mezu?
Dialogue: 0,0:15:33.93,0:15:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tua tapi cukup terawat.
Dialogue: 0,0:15:37.31,0:15:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian disayang, ya.
Dialogue: 0,0:15:49.40,0:15:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lapar banget.
Dialogue: 0,0:15:52.20,0:15:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarapannya apa, ya?
Dialogue: 0,0:16:02.16,0:16:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:16:04.92,0:16:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada orang?
Dialogue: 0,0:16:07.38,0:16:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Tuan Kagemori.
Dialogue: 0,0:16:10.71,0:16:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku harus menekan bel?
Dialogue: 0,0:16:14.01,0:16:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya orang kaya punya satpam.
Dialogue: 0,0:16:18.06,0:16:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu siapa?
Dialogue: 0,0:16:18.97,0:16:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ada.
Dialogue: 0,0:16:22.10,0:16:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Tuan Kagemori.\NMaaf bertamu pagi-pagi.
Dialogue: 0,0:16:27.11,0:16:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Tadera Ryu.
Dialogue: 0,0:16:29.57,0:16:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau menjemput Yuru.
Dialogue: 0,0:16:33.28,0:16:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan Tadera?
Dialogue: 0,0:16:35.24,0:16:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dera?{\i0}
Dialogue: 0,0:16:37.03,0:16:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang mau menjemput Abang.
Dialogue: 0,0:16:39.24,0:16:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kelupaan soal Dera.
Dialogue: 0,0:16:42.00,0:16:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:16:45.62,0:16:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah pergi tanpa izin.
Dialogue: 0,0:16:48.67,0:16:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memercayai Klan Kagemori.
Dialogue: 0,0:16:50.50,0:16:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan yang merepotkan.
Dialogue: 0,0:16:52.38,0:16:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur, malas berurusan sama mereka.
Dialogue: 0,0:16:56.84,0:17:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mendengar pendapat kedua pihak\Nakan lebih baik.{\i0}
Dialogue: 0,0:17:03.02,0:17:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh, aku ingin dia ke sini.
Dialogue: 0,0:17:06.48,0:17:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:17:08.27,0:17:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akio, antar dia ke pintu masuk.
Dialogue: 0,0:17:10.86,0:17:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baik.{\i0}
Dialogue: 0,0:17:11.94,0:17:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini jangan dibunuh.
Dialogue: 0,0:17:13.99,0:17:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak akan, maafkan aku.{\i0}
Dialogue: 0,0:17:19.07,0:17:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Jin.
Dialogue: 0,0:17:22.04,0:17:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berantakan sekali, apa yang terjadi?
Dialogue: 0,0:17:25.41,0:17:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asuma, selamat pagi.
Dialogue: 0,0:17:28.54,0:17:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak Tsugai asing masuk ke wisma\Ndan membuat kekacauan.
Dialogue: 0,0:17:33.26,0:17:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ngeri juga.
Dialogue: 0,0:17:35.92,0:17:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ada keributan besar,\Nkenapa kamu tidak membantu?
Dialogue: 0,0:17:40.55,0:17:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidur.
Dialogue: 0,0:17:42.97,0:17:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya pendengaranmu tajam?
Dialogue: 0,0:17:47.06,0:17:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada apa ini, Jin?
Dialogue: 0,0:17:51.48,0:17:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Hagure.
Dialogue: 0,0:17:53.57,0:17:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Asuma.
Dialogue: 0,0:17:55.94,0:17:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Gempa?
Dialogue: 0,0:17:59.45,0:18:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pengguna Tsugai datang\Nmengincar Asa dan kakaknya.
Dialogue: 0,0:18:04.41,0:18:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Asa baik-baik saja?
Dialogue: 0,0:18:06.58,0:18:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf bikin ribut, aku baik-baik saja.
Dialogue: 0,0:18:09.46,0:18:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, syukurlah.
Dialogue: 0,0:18:12.25,0:18:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kakaknya?
Dialogue: 0,0:18:15.88,0:18:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Abang ada di sini.
Dialogue: 0,0:18:18.30,0:18:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakmu sudah ketemu! Selamat, ya, Asa!
Dialogue: 0,0:18:22.76,0:18:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Yuru? Aku tahu namamu dari Asa…
Dialogue: 0,0:18:29.31,0:18:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka Penjaga Ilahi Sayuu,\NTsugai-nya Kakak.
Dialogue: 0,0:18:31.94,0:18:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:18:34.40,0:18:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf tidak bisa membantumu, Jin.
Dialogue: 0,0:18:38.20,0:18:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidur lelap setelah tenggat kelar.
Dialogue: 0,0:18:40.70,0:18:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah, kamu telah bekerja keras.
Dialogue: 0,0:18:43.49,0:18:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, padahal sudah ada pelindung\Nbiar orang luar tidak masuk wisma.
Dialogue: 0,0:18:49.21,0:18:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kapan dan dari mana mereka masuk".
Dialogue: 0,0:18:52.29,0:18:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tawanan yang ada, akan kami siks—
Dialogue: 0,0:18:55.63,0:18:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kami tanya soal itu.
Dialogue: 0,0:18:57.46,0:19:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, wisma ini sudah tidak aman.
Dialogue: 0,0:19:02.09,0:19:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidur pun tidak akan nyenyak.
Dialogue: 0,0:19:05.72,0:19:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mobil Ayah.
Dialogue: 0,0:19:07.93,0:19:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos sudah kembali.
Dialogue: 0,0:19:21.66,0:19:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:19:23.24,0:19:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kayaknya kalian cukup kesulitan.
Dialogue: 0,0:19:26.41,0:19:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, selamat pagi.
Dialogue: 0,0:19:30.66,0:19:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, dia…
Dialogue: 0,0:19:32.62,0:19:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Tadera Ryu.
Dialogue: 0,0:19:34.71,0:19:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi dia ada di depan,\Njadi sekalian kuajak.
Dialogue: 0,0:19:37.46,0:19:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dari Klan Tadera.
Dialogue: 0,0:19:38.96,0:19:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, dia walinya Yuru.
Dialogue: 0,0:19:41.51,0:19:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa, Yuru?
Dialogue: 0,0:19:43.26,0:19:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi kamu Yuru?
Dialogue: 0,0:19:46.51,0:19:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kagemori Gonzou, kepala klan ini.
Dialogue: 0,0:19:50.02,0:19:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian Tsugai yang gagah\Nsesuai yang dirumorkan!
Dialogue: 0,0:19:55.15,0:19:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Klan Tadera, Abdi Desa Higashi.{\i0}
Dialogue: 0,0:19:58.44,0:20:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penghubung Desa Higashi\Ndan dataran rendah.{\i0}
Dialogue: 0,0:20:01.53,0:20:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa klan yang sangat waspada\Ndan tidak pernah menunjukkan diri{\i0}
Dialogue: 0,0:20:08.04,0:20:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}datang sesantai ini ke wilayah musuh?{\i0}
Dialogue: 0,0:20:12.83,0:20:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kagemori dan Dera bersekongkol?
Dialogue: 0,0:20:16.00,0:20:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:20:17.59,0:20:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jin dan kakek itu memancarkan\Nniat membunuh pada Dera.{\i0}
Dialogue: 0,0:20:22.88,0:20:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Klan Tadera punya dosa apa\Nterhadap Klan Kagemori?{\i0}
Dialogue: 0,0:20:27.18,0:20:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera.
Dialogue: 0,0:20:28.31,0:20:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:20:29.51,0:20:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang,
Dialogue: 0,0:20:31.31,0:20:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa dapat kekuatan Fuu kalau mati.
Dialogue: 0,0:20:35.94,0:20:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu itu, kan?
Dialogue: 0,0:20:38.32,0:20:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu juga kenapa diam saja?
Dialogue: 0,0:20:41.94,0:20:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tahu sedikit soal legenda desa.
Dialogue: 0,0:20:46.03,0:20:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu sangat menyayangi adikmu.
Dialogue: 0,0:20:49.91,0:20:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terjadi sesuatu pada Asa,\Nkamu pasti bakal berkorban.
Dialogue: 0,0:20:54.92,0:20:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu punya nyawa cadangan,
Dialogue: 0,0:20:58.84,0:21:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pasti lebih nekat\Ndan pemikiran itu berbahaya.
Dialogue: 0,0:21:02.59,0:21:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum tentu juga bisa hidup kembali.
Dialogue: 0,0:21:06.72,0:21:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bilang, kembar seperti kalian\Nterakhir kali muncul 400 tahun lalu, kan?
Dialogue: 0,0:21:13.35,0:21:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu kembar itu tidak hidup kembali.
Dialogue: 0,0:21:24.07,0:21:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang pas bahas hal berat sambil berdiri.
Dialogue: 0,0:21:28.20,0:21:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, kamu lapar?
Dialogue: 0,0:21:30.49,0:21:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku belum makan sejak semalam.
Dialogue: 0,0:21:34.45,0:21:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo mengobrol sambil sarapan.
Dialogue: 0,0:21:38.54,0:21:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:21:40.71,0:21:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapkan jamuan pagi.
Dialogue: 0,0:21:43.09,0:21:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:21:44.67,0:21:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, tidak akan kuracuni.
Dialogue: 0,0:21:48.89,0:21:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap!
Dialogue: 0,0:21:50.01,0:21:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih jamuannya!
Dialogue: 0,0:21:52.72,0:21:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Makan bareng Kakak!{\i0}
Dialogue: 0,0:23:28.90,0:23:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku Hagure Hikaru, seorang komikus.{\i0}
Dialogue: 0,0:23:32.16,0:23:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Komikus itu apa?{\i0}
Dialogue: 0,0:23:34.41,0:23:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tiap lahirnya kembar yang ditakdirkan,\Ndunia selalu kacau.{\i0}
