Dialogue: 0,0:03:53.81,0:03:56.73,tanda,,0000,0000,0000,,KASIR
Dialogue: 0,0:23:27.57,0:23:28.86,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:35.72,0:01:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini baju dan makanan.
Dialogue: 0,0:01:39.22,0:01:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar tidak mencolok,
Dialogue: 0,0:01:41.22,0:01:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gantilah bajumu.
Dialogue: 0,0:01:48.77,0:01:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kantoui?
Dialogue: 0,0:01:50.11,0:01:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, betul. Lalu, ini semacam hakama.
Dialogue: 0,0:01:53.48,0:01:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai ini juga.
Dialogue: 0,0:01:55.11,0:01:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sandal dataran rendah.
Dialogue: 0,0:01:57.99,0:02:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior, gaya berandal cocok untukmu.
Dialogue: 0,0:02:01.78,0:02:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ini…
Dialogue: 0,0:02:03.33,0:02:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau onigiri, pasti tahu, kan?
Dialogue: 0,0:02:06.00,0:02:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beras murni?
Dialogue: 0,0:02:07.62,0:02:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa campuran?
Dialogue: 0,0:02:09.08,0:02:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ada kombu?
Dialogue: 0,0:02:11.04,0:02:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan pangan kelas atas!
Dialogue: 0,0:02:14.67,0:02:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat di desa itu, sih, iya.
Dialogue: 0,0:02:16.67,0:02:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini diapakan?
Dialogue: 0,0:02:32.61,0:02:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:02:41.61,0:02:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:02:43.83,0:02:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget, ini makanan dewa, ya?
Dialogue: 0,0:02:47.08,0:02:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, baguslah! Makan yang banyak!
Dialogue: 0,0:02:51.00,0:02:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kayak neneknya saja.
Dialogue: 0,0:02:55.92,0:03:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap Asa juga bisa makan ini.
Dialogue: 0,0:03:01.97,0:03:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Dera.
Dialogue: 0,0:03:05.39,0:03:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:03:08.35,0:03:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini namanya rest area,\Nmirip tempat singgah zaman dulu.
Dialogue: 0,0:03:12.85,0:03:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tempat makan, jamban, dan lainnya.
Dialogue: 0,0:03:15.19,0:03:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa beli oleh-oleh juga…
Dialogue: 0,0:03:21.36,0:03:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lihat-lihat?
Dialogue: 0,0:03:23.45,0:03:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah, kami akan menemani Yuru.
Dialogue: 0,0:03:26.87,0:03:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak makan dulu?
Dialogue: 0,0:03:30.29,0:03:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami yang jaga Yuru.
Dialogue: 0,0:03:34.17,0:03:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah kalau begitu.
Dialogue: 0,0:03:36.42,0:03:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hana, ayo makan.\N- Oke.
Dialogue: 0,0:03:39.17,0:03:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh kursi pengemudinya, ya.
Dialogue: 0,0:03:41.80,0:03:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuda di dalam sini tidak diberi makan?
Dialogue: 0,0:03:45.26,0:03:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kuberi minum minyak.
Dialogue: 0,0:03:56.73,0:03:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang apa saja padanya?
Dialogue: 0,0:03:58.57,0:04:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu bahwa selama ini adiknya palsu saja,
Dialogue: 0,0:04:02.36,0:04:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia sudah cukup panik.
Dialogue: 0,0:04:04.86,0:04:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau membebaninya lagi.
Dialogue: 0,0:04:07.58,0:04:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik sekali.
Dialogue: 0,0:04:09.95,0:04:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih anak-anak, lo.
Dialogue: 0,0:04:12.25,0:04:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, soalnya aku benci anak-anak.
Dialogue: 0,0:04:16.46,0:04:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih makanannya.
Dialogue: 0,0:04:18.29,0:04:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku harus apa?
Dialogue: 0,0:04:20.96,0:04:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengantar kalian ke tempatmu?
Dialogue: 0,0:04:23.76,0:04:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, wajah dan namaku sudah ketahuan,
Dialogue: 0,0:04:27.68,0:04:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terpaksa harus ganti tempat.
Dialogue: 0,0:04:30.18,0:04:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi gelandangan bareng bocil, ya.
Dialogue: 0,0:04:33.06,0:04:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan banget.
Dialogue: 0,0:04:35.52,0:04:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cuek begitu, lah.
Dialogue: 0,0:04:38.27,0:04:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sesama Abdi Desa Higashi,\Nkamu harus membantu.
Dialogue: 0,0:04:41.69,0:04:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bakal kuusahakan, kok.
Dialogue: 0,0:04:45.57,0:04:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:04:46.78,0:04:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo menikah, Hana.
Dialogue: 0,0:04:52.54,0:04:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, cincin pernikahannya!
Dialogue: 0,0:04:54.62,0:04:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu membawa benda itu?
Dialogue: 0,0:04:57.04,0:05:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus menikah sama Senior?
Dialogue: 0,0:05:02.17,0:05:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma pura-pura!
Dialogue: 0,0:05:03.67,0:05:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi melindungi Yuru,\Nkita harus berbaur di masyarakat.
Dialogue: 0,0:05:07.93,0:05:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gosip cepat menyebar di pedesaan.
Dialogue: 0,0:05:10.93,0:05:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mendingan di kota besar.
Dialogue: 0,0:05:13.73,0:05:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku ragu kalau cuma sendirian.
Dialogue: 0,0:05:16.77,0:05:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal bareng cukup, kan?\NEnggak usah nikah!
Dialogue: 0,0:05:21.19,0:05:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status keluarga lebih tepercaya,\Nsewa rumah juga bakal mudah.
Dialogue: 0,0:05:25.65,0:05:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau harus keluarga,\Nmending aku jadi kakaknya Yuru saja!
Dialogue: 0,0:05:31.41,0:05:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamu jadi ayah tunggal!
Dialogue: 0,0:05:34.08,0:05:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Papa tunggal yang istrinya minggat?{\i0}
Dialogue: 0,0:05:37.87,0:05:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Istrinya minggat, tuh.
Dialogue: 0,0:05:39.29,0:05:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Wah, apa karena KDRT? Atau selingkuh?
Dialogue: 0,0:05:42.92,0:05:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Papa tabah yang istrinya meninggal,\Nlalu mengasuh anak sendirian?{\i0}
Dialogue: 0,0:05:47.38,0:05:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malang sekali.
Dialogue: 0,0:05:49.18,0:05:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sulit.
Dialogue: 0,0:05:50.55,0:05:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bantu dia.
Dialogue: 0,0:05:52.89,0:05:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya pun bakal jadi buah bibir.
Dialogue: 0,0:05:56.31,0:05:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu mencolok.
Dialogue: 0,0:05:57.98,0:06:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru anak bawaanku,\Ndan aku nikah lagi sama gadis muda.
Dialogue: 0,0:06:02.48,0:06:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma bohongan, kok.\NMohon kerja samanya.
Dialogue: 0,0:06:06.03,0:06:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja saja sendiri.
Dialogue: 0,0:06:08.49,0:06:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pakai marga siapa?
Dialogue: 0,0:06:11.12,0:06:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih.
Dialogue: 0,0:06:13.28,0:06:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah!
Dialogue: 0,0:06:14.99,0:06:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mau menikahi Jason Statham!
Dialogue: 0,0:06:23.59,0:06:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kuda bisa masuk ke kotak kecil ini?
Dialogue: 0,0:06:26.71,0:06:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknologi baru dataran rendah luar biasa.
Dialogue: 0,0:06:30.72,0:06:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, maaf.
Dialogue: 0,0:06:32.80,0:06:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah makan sendirian,\Nkalian tidak lapar?
Dialogue: 0,0:06:37.35,0:06:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan baru kita baik banget.
Dialogue: 0,0:06:40.10,0:06:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, kami tidak makan\Nmakanan manusia.
Dialogue: 0,0:06:45.11,0:06:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, masing-masing dari kalian\Nharus kupanggil apa?
Dialogue: 0,0:06:49.11,0:06:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kamu.
Dialogue: 0,0:06:50.61,0:06:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggilan baru juga boleh.
Dialogue: 0,0:06:54.91,0:06:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Migi dan Nona Hidari?
Dialogue: 0,0:06:58.37,0:07:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaku banget! Kamu itu tuan kami, lo.
Dialogue: 0,0:07:02.71,0:07:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa santai saja.
Dialogue: 0,0:07:05.00,0:07:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu…
Dialogue: 0,0:07:07.84,0:07:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Migi dan Hidari.
Dialogue: 0,0:07:12.09,0:07:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung saja, ceritakan semua\Nyang kalian tahu tentangku dan Asa.
Dialogue: 0,0:07:21.69,0:07:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus tahu dulu.
Dialogue: 0,0:07:23.65,0:07:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama 400 tahun terakhir,
Dialogue: 0,0:07:27.15,0:07:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami terus duduk\Ndi pintu masuk Desa Higashi.
Dialogue: 0,0:07:30.90,0:07:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi cuma bisa lihat orang keluar masuk.{\i0}
Dialogue: 0,0:07:33.82,0:07:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami tidak tahu pasti\Nperistiwa dalam desa.{\i0}
Dialogue: 0,0:07:37.74,0:07:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat warga bilang ada\Nanak kembar terlahir,{\i0}
Dialogue: 0,0:07:41.62,0:07:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tidak lama kemudian kami melihatmu.{\i0}
Dialogue: 0,0:07:47.25,0:07:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil, kamu sering diajak\Nberburu sama ayahmu, kan?
Dialogue: 0,0:07:52.30,0:07:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:53.63,0:07:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah mengajarkanku berburu sejak dini.
Dialogue: 0,0:07:57.39,0:08:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kembaranmu tidak pernah terlihat.
Dialogue: 0,0:08:02.06,0:08:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami sempat mengira dia mati selepas lahir\Nakibat penyakit atau lainnya.{\i0}
Dialogue: 0,0:08:07.90,0:08:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi, sekitar 10 tahun lalu…{\i0}
Dialogue: 0,0:08:24.62,0:08:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami melihat orang tuamu kabur\Ndari desa membawa gadis kecil.{\i0}
Dialogue: 0,0:08:30.21,0:08:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bau darah gadis itu sama denganmu.{\i0}
Dialogue: 0,0:08:38.26,0:08:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia tumbuh besar dan menyerang desa.
Dialogue: 0,0:08:43.35,0:08:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira Ayah\Ndan Ibu meninggalkan kami berdua.
Dialogue: 0,0:08:51.94,0:08:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata cuma aku yang ditinggal.
Dialogue: 0,0:09:03.75,0:09:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, orang yang mengaku Asa asli itu
Dialogue: 0,0:09:06.96,0:09:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin tahu sesuatu soal Ayah dan Ibu.
Dialogue: 0,0:09:11.71,0:09:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:09:13.42,0:09:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:09:15.84,0:09:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf lama.
Dialogue: 0,0:09:19.64,0:09:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hana, kamu kenapa?
Dialogue: 0,0:09:22.01,0:09:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena berbagai alasan,\Naku akan jadi walimu.
Dialogue: 0,0:09:25.60,0:09:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya.
Dialogue: 0,0:09:27.56,0:09:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wali?
Dialogue: 0,0:09:28.48,0:09:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang bertanggung jawab\Nkalau kamu berulah.
Dialogue: 0,0:09:32.07,0:09:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, perjalanan kita masih jauh.
Dialogue: 0,0:09:34.99,0:09:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak buang air dulu?
Dialogue: 0,0:09:36.82,0:09:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, di sekitar situ.
Dialogue: 0,0:09:38.91,0:09:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia langsung berulah!
Dialogue: 0,0:09:40.70,0:09:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, jangan duduk di atap mobil.
Dialogue: 0,0:09:44.00,0:09:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti mencolok.
Dialogue: 0,0:09:45.25,0:09:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh?
Dialogue: 0,0:09:47.33,0:09:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu duduk\Ndi atap terus, lo.
Dialogue: 0,0:09:49.75,0:09:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang biasa tidak bisa melihat Tsugai.
Dialogue: 0,0:09:52.92,0:09:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:09:54.09,0:09:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pengguna Tsugai sepertimu\Nbisa melihat kami.
Dialogue: 0,0:09:57.76,0:10:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsugai juga bisa sengaja\Nmenampakkan diri ke orang tertentu.
Dialogue: 0,0:10:03.14,0:10:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang, makhluk yang peka juga\Nbisa melihat kami.
Dialogue: 0,0:10:08.52,0:10:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:10:10.19,0:10:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menggonggongi apa?
Dialogue: 0,0:10:17.82,0:10:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan Kagemori itu
Dialogue: 0,0:10:20.70,0:10:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengguna Tsugai juga?
Dialogue: 0,0:10:22.95,0:10:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, jumlahnya banyak pula.
Dialogue: 0,0:10:25.95,0:10:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka seperti apa?
Dialogue: 0,0:10:27.41,0:10:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan yang merepotkan.
Dialogue: 0,0:10:29.62,0:10:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pergi dari Desa Higashi\Ndan sukses di dataran rendah.
Dialogue: 0,0:10:33.67,0:10:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semacam klan cabang di desa.
Dialogue: 0,0:10:37.05,0:10:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Karena beda pandangan,\Nmereka berpisah dengan desa.
Dialogue: 0,0:10:40.64,0:10:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur, malas berurusan sama mereka.
Dialogue: 0,0:10:43.89,0:10:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata jaringan keturunan\NDesa Higashi di dataran rendah…
Dialogue: 0,0:10:48.18,0:10:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, kata relasiku…
Dialogue: 0,0:10:51.10,0:10:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa waktu lalu,
Dialogue: 0,0:10:52.40,0:10:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beredar rumor bahwa kembar yang satunya\Nberada di Kagemori.
Dialogue: 0,0:10:57.78,0:10:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti rumornya benar.
Dialogue: 0,0:11:38.28,0:11:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat!
Dialogue: 0,0:11:45.20,0:11:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat! Cepatlah menutup!
Dialogue: 0,0:11:53.87,0:11:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebeb Aoi.
Dialogue: 0,0:11:56.25,0:11:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kabur?
Dialogue: 0,0:11:59.00,0:12:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti! Jangan mendekat!
Dialogue: 0,0:12:00.80,0:12:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya…
Dialogue: 0,0:12:04.55,0:12:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membunuhmu kalau jauh.
Dialogue: 0,0:12:11.77,0:12:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat.
Dialogue: 0,0:12:13.39,0:12:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjauhlah!
Dialogue: 0,0:12:15.44,0:12:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terlalu dekat…
Dialogue: 0,0:12:22.53,0:12:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masuk wilayahku, lo.
Dialogue: 0,0:12:35.00,0:12:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:12:36.46,0:12:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aoi, ini aku Jin.
Dialogue: 0,0:12:39.55,0:12:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah penguntitmu sudah beres.
Dialogue: 0,0:12:47.26,0:12:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku sudah membuatnya berjanji\Ntidak akan mendekatimu lagi.{\i0}
Dialogue: 0,0:12:52.73,0:12:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kamu sudah bisa kembali bekerja.{\i0}
Dialogue: 0,0:12:56.94,0:12:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Biar aku yang mengabari pemilik bar.{\i0}
Dialogue: 0,0:13:02.40,0:13:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selamat malam.{\i0}
Dialogue: 0,0:13:32.39,0:13:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak.
Dialogue: 0,0:13:36.64,0:13:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa melihatnya?
Dialogue: 0,0:13:41.36,0:13:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu…
Dialogue: 0,0:13:48.49,0:13:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rahasia, ya.{\i0}
Dialogue: 0,0:13:52.03,0:13:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Hana tidak diberi tahu detailnya.
Dialogue: 0,0:13:55.83,0:13:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, dari dulu kami hidup\Ndi dataran rendah.
Dialogue: 0,0:13:58.96,0:14:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjaan ini pun cuma warisan.
Dialogue: 0,0:14:01.50,0:14:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek Yamaha cuma bilang,
Dialogue: 0,0:14:03.25,0:14:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan sampai orang luar tahu\Nlokasi desa kita."
Dialogue: 0,0:14:06.01,0:14:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan dia terus mengingatkan,
Dialogue: 0,0:14:07.68,0:14:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan pernah berikan\NAsa dan Yuru ke pihak lain."
Dialogue: 0,0:14:12.51,0:14:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengurus logistik dan komunikasi.
Dialogue: 0,0:14:15.35,0:14:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengurus macam-macam di sini,
Dialogue: 0,0:14:18.19,0:14:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak pernah ke desa.
Dialogue: 0,0:14:20.40,0:14:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa tujuan Nenek dan para tetua.
Dialogue: 0,0:14:23.57,0:14:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebagai Klan Tadera,\Ntugasku wajib dijalankan.
Dialogue: 0,0:14:28.65,0:14:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, nama asliku Tadera Ryu.
Dialogue: 0,0:14:32.32,0:14:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap panggil Dera juga boleh.
Dialogue: 0,0:14:35.12,0:14:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, Nenek tidak mau\Nmereka mengambilku.
Dialogue: 0,0:14:40.46,0:14:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pun sampai diingatkan berkali-kali.
Dialogue: 0,0:14:45.88,0:14:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Asa, sebenarnya apa?
Dialogue: 0,0:14:51.47,0:14:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat siang dan malam setara\Ndi sebuah desa Timur,
Dialogue: 0,0:14:54.51,0:14:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lahirlah anak kembar\Nlaki-laki dan perempuan.
Dialogue: 0,0:14:57.60,0:15:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelahiran mereka mengguncang dunia.
Dialogue: 0,0:15:00.98,0:15:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setahu kami,
Dialogue: 0,0:15:02.98,0:15:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal yang sama pernah terjadi\N400 tahun lalu.
Dialogue: 0,0:15:07.74,0:15:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembar yang memisah siang dan malam,\Nlahir di desa itu.
Dialogue: 0,0:15:12.07,0:15:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di era itu terjadi perang besar\Nantara wilayah Timur dan Barat.{\i0}
Dialogue: 0,0:15:16.33,0:15:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bahkan sebelumnya pernah ada perang\Nantara wilayah Selatan dan Utara.{\i0}
Dialogue: 0,0:15:21.46,0:15:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Keduanya melibatkan pengguna Tsugai\Ndi balik layar.{\i0}
Dialogue: 0,0:15:26.17,0:15:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami kembar terkutuk\Nyang mengacaukan dunia?
Dialogue: 0,0:15:29.88,0:15:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, mereka yang seenaknya berperang\Nmemperebutkan kekuatan kalian.
Dialogue: 0,0:15:35.22,0:15:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan? Aku tidak memilikinya.
Dialogue: 0,0:15:38.47,0:15:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum.
Dialogue: 0,0:15:39.98,0:15:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu layak mendapatkan kekuatan itu.
Dialogue: 0,0:15:44.15,0:15:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya, Asa sudah mendapatkannya.
Dialogue: 0,0:15:49.40,0:15:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, ya.
Dialogue: 0,0:15:51.11,0:15:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga, itu Kai.
Dialogue: 0,0:15:55.45,0:15:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kai.{\i0}
Dialogue: 0,0:15:56.87,0:16:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kekuatan untuk membongkar\Nsegala hal secara paksa.{\i0}
Dialogue: 0,0:16:00.70,0:16:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pelindung sekuat apa pun,\Nbisa dibuka dengan mudah.{\i0}
Dialogue: 0,0:16:05.79,0:16:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan kebalikannya, Fuu.{\i0}
Dialogue: 0,0:16:08.84,0:16:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kekuatan untuk menyegel\Nsegala hal secara paksa.{\i0}
Dialogue: 0,0:16:13.88,0:16:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jadinya kalau Kai dan Fuu beradu?
Dialogue: 0,0:16:17.43,0:16:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontradiktif, ya.
Dialogue: 0,0:16:19.60,0:16:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, pernah ada yang punya dua-duanya?
Dialogue: 0,0:16:22.94,0:16:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setahu kami, tidak ada.
Dialogue: 0,0:16:25.69,0:16:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, belum diketahui apa jadinya.
Dialogue: 0,0:16:29.78,0:16:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan warga desa cuma dipermainkan
Dialogue: 0,0:16:32.82,0:16:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rumor "sesuatu akan terjadi"\Nyang kepalang liar?
Dialogue: 0,0:16:37.20,0:16:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah di desa juga ada pelindung?
Dialogue: 0,0:16:41.12,0:16:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera, bagaimana caramu keluar masuk?
Dialogue: 0,0:16:44.00,0:16:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada jalur khusus untuk melewatinya.
Dialogue: 0,0:16:47.25,0:16:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Putari batunya beberapa kali.{\i0}
Dialogue: 0,0:16:50.96,0:16:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Belok kanan di persimpangan,{\i0}
Dialogue: 0,0:16:52.92,0:16:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lalu kembalilah dan lewati lembah\Ndi simpang selanjutnya.{\i0}
Dialogue: 0,0:16:56.14,0:16:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kemudian belok tegak lurus di pohon besar.{\i0}
Dialogue: 0,0:16:59.89,0:17:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pokoknya ribet.{\i0}
Dialogue: 0,0:17:02.43,0:17:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klanku tahu jalur itu,
Dialogue: 0,0:17:05.27,0:17:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kami bebas keluar masuk desa.
Dialogue: 0,0:17:09.27,0:17:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibumu orang dataran rendah\Nyang kebetulan masuk desa lewat jalur itu.
Dialogue: 0,0:17:17.91,0:17:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kadang memang ada.{\i0}
Dialogue: 0,0:17:19.99,0:17:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang yang tersesat\Ndan tanpa sengaja masuk desa.{\i0}
Dialogue: 0,0:17:41.39,0:17:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yuru.{\i0}
Dialogue: 0,0:17:43.43,0:17:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arti namamu dalam bahasa\Ndi kampung halamanku
Dialogue: 0,0:17:47.31,0:17:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah "malam".
Dialogue: 0,0:17:50.61,0:17:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari nanti,
Dialogue: 0,0:17:52.82,0:17:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin membawa Ayah, Asa,\Ndan kamu ke sana.
Dialogue: 0,0:18:23.72,0:18:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah buang hajat… Siram.{\i0}
Dialogue: 0,0:18:28.60,0:18:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu cuci tangan.{\i0}
Dialogue: 0,0:18:34.02,0:18:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Suaranya kayak raungan naga,\Naku enggak suka.{\i0}
Dialogue: 0,0:18:38.65,0:18:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Matikan lampu ruangan kalau tidak dipakai.{\i0}
Dialogue: 0,0:18:42.91,0:18:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sip!{\i0}
Dialogue: 0,0:18:44.03,0:18:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku sudah ingat aturan\Njamban dataran rendah!{\i0}
Dialogue: 0,0:18:51.71,0:18:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, enak banget\Ntidak perlu menimba air dulu.
Dialogue: 0,0:18:55.75,0:18:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda yang menyala saat ditekan juga aneh.
Dialogue: 0,0:18:59.80,0:19:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain seisi kota yang jadi terang\Ndi malam hari,
Dialogue: 0,0:19:03.68,0:19:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kastel-kastel batu ini juga mengejutkan.
Dialogue: 0,0:19:07.43,0:19:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penguasa di dataran rendah ada banyak, ya?
Dialogue: 0,0:19:10.48,0:19:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya itu rumah, bukan kastel.
Dialogue: 0,0:19:13.36,0:19:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera bilang, banyak yang tinggal\Ndi dalam satu gedungnya.
Dialogue: 0,0:19:17.23,0:19:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu kota memang ramai, ya.
Dialogue: 0,0:19:19.82,0:19:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, ini bukan ibu kota.
Dialogue: 0,0:19:22.28,0:19:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu kota namanya Tokyo,\Nkudengar warganya lebih dari 10 juta.
Dialogue: 0,0:19:26.66,0:19:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}10 juta? Bagaimana menghitungnya?
Dialogue: 0,0:19:30.25,0:19:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, ini bukan ibu kota\Nmeski seramai ini?
Dialogue: 0,0:19:34.96,0:19:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, nama wilayah ini…
Dialogue: 0,0:19:38.05,0:19:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hana menyebutnya…
Dialogue: 0,0:19:40.84,0:19:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prefektur Guntama?
Dialogue: 0,0:19:42.13,0:19:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prefektur Guntama. Ya, sudah kuingat.
Dialogue: 0,0:19:44.43,0:19:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau manusianya sebanyak ini\Nmemang mudah buat sembunyi, sih.
Dialogue: 0,0:19:49.22,0:19:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagai menaruh jarum di tumpukan jerami.
Dialogue: 0,0:19:51.44,0:19:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamu mau mencari adikmu\Ndi keramaian ini?
Dialogue: 0,0:19:59.23,0:20:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:01.07,0:20:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera dan Hana memang baik.
Dialogue: 0,0:20:05.07,0:20:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi, karena mereka berkaitan\Ndengan adik palsuku{\i0}
Dialogue: 0,0:20:08.74,0:20:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan warga desa yang merahasiakannya,{\i0}
Dialogue: 0,0:20:12.04,0:20:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sulit buat percaya sepenuhnya.{\i0}
Dialogue: 0,0:20:14.58,0:20:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi, orang yang mengaku Asa pun\Ntidak bisa langsung dipercaya.{\i0}
Dialogue: 0,0:20:22.13,0:20:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat.
Dialogue: 0,0:20:24.76,0:20:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sampai kabur membawa anaknya,\Npasti perkaranya serius.
Dialogue: 0,0:20:30.14,0:20:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku ingin tahu alasannya.
Dialogue: 0,0:20:32.48,0:20:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menangkap Asa itu\Nagar diantar menemui Ayah dan Ibu.
Dialogue: 0,0:20:37.31,0:20:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kalian membantuku?
Dialogue: 0,0:20:40.28,0:20:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari seseorang di dataran asing ini?
Dialogue: 0,0:20:44.36,0:20:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik!
Dialogue: 0,0:20:45.49,0:20:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 400 tahun enggak ada hiburan!
Dialogue: 0,0:20:48.33,0:20:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru, nih!
Dialogue: 0,0:20:49.79,0:20:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan kita serius,\Njangan bicara begitu, Migi.
Dialogue: 0,0:20:54.12,0:20:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus apa pendapatmu, Hidari?
Dialogue: 0,0:21:00.96,0:21:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada diburu,
Dialogue: 0,0:21:02.97,0:21:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku lebih cocok memburu.
Dialogue: 0,0:21:07.89,0:21:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, siap.
Dialogue: 0,0:21:10.22,0:21:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:12.35,0:21:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, selamat datang.
Dialogue: 0,0:21:14.14,0:21:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali.
Dialogue: 0,0:21:15.27,0:21:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hana mengabari, kita sudah dapat rumah.
Dialogue: 0,0:21:19.90,0:21:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya enggak tidur di mobil lagi!
Dialogue: 0,0:21:24.49,0:21:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nbenda apa yang sering kamu pakai itu?
Dialogue: 0,0:21:28.41,0:21:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini?
Dialogue: 0,0:21:31.33,0:21:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusebut ponsel pun tidak akan paham.
Dialogue: 0,0:21:34.50,0:21:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semacam sinyal asap\Npengirim tulisan dan suara?
Dialogue: 0,0:21:37.87,0:21:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan juga, sih…
Dialogue: 0,0:21:40.17,0:21:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kayak begitulah.
Dialogue: 0,0:21:43.09,0:21:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:21:44.51,0:21:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semacam sinyal asap, ya.
Dialogue: 0,0:21:47.47,0:21:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:21:50.55,0:21:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka benaran asal banget.{\i0}
Dialogue: 0,0:23:29.61,0:23:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan, ini Kotetsu dan Jirou.
Dialogue: 0,0:23:33.70,0:23:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Migi, apa aturan terakhir di jamban?{\i0}
Dialogue: 0,0:23:36.33,0:23:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Matikan lampu!{\i0}
