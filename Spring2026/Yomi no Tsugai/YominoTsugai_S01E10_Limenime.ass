Dialogue: 0,0:23:27.61,0:23:28.98,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:32.09,0:01:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bangun! Cepat Bangun!
Dialogue: 0,0:01:35.76,0:01:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pingsan terus.
Dialogue: 0,0:01:39.59,0:01:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun!
Dialogue: 0,0:01:41.97,0:01:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Lah, Tadera!
Dialogue: 0,0:01:44.39,0:01:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa bergerak?\NBersiaplah untuk kabur.
Dialogue: 0,0:01:46.98,0:01:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:01:48.81,0:01:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di mana?
Dialogue: 0,0:01:52.82,0:01:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa itu?
Dialogue: 0,0:01:54.90,0:01:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan Tsugai milikmu, kan?
Dialogue: 0,0:01:58.03,0:02:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya rekanmu juga dibunuh.
Dialogue: 0,0:02:00.12,0:02:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengenal Tsugai itu!
Dialogue: 0,0:02:03.03,0:02:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh lain lagi? Merepotkan!
Dialogue: 0,0:02:07.16,0:02:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka
Dialogue: 0,0:02:09.46,0:02:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa masuk ke Mayoiga milikku?
Dialogue: 0,0:02:13.38,0:02:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian saling mengenal?
Dialogue: 0,0:02:15.92,0:02:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan.
Dialogue: 0,0:02:18.38,0:02:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena selalu bikin onar di wilayah Utara,{\i0}
Dialogue: 0,0:02:21.51,0:02:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mereka disegel di Gunung Yamou oleh kami,\Npengguna Fuu, dan biksu pengembara.{\i0}
Dialogue: 0,0:02:27.35,0:02:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gunung Yamou?{\i0}
Dialogue: 0,0:02:28.77,0:02:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sekarang namanya Gunung Bandai,\Nbentuknya berubah setelah meletus.{\i0}
Dialogue: 0,0:02:33.36,0:02:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kalian disegel di Gunung Yamou?
Dialogue: 0,0:02:37.53,0:02:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang.
Dialogue: 0,0:02:39.70,0:02:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami dibebaskan\Noleh tuan yang baik hati.
Dialogue: 0,0:02:44.49,0:02:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya bebas\Nsetelah seribu sekian ratus tahun.
Dialogue: 0,0:02:48.45,0:02:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini karena kalian.
Dialogue: 0,0:02:51.79,0:02:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Sayuu anjing!
Dialogue: 0,0:02:53.96,0:02:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kabar biksu itu?
Dialogue: 0,0:02:57.30,0:03:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah, kudengar dia ada di Gunung Kouya.
Dialogue: 0,0:03:01.09,0:03:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut legendanya,
Dialogue: 0,0:03:03.89,0:03:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaga dan Ashinaga suka\Nmenginjak-injak ladang sampai rusak
Dialogue: 0,0:03:08.06,0:03:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menebarkan air danau
Dialogue: 0,0:03:10.48,0:03:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga menyebabkan banjir.
Dialogue: 0,0:03:12.85,0:03:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?
Dialogue: 0,0:03:14.06,0:03:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warga desa sialan!
Dialogue: 0,0:03:15.52,0:03:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mentang-mentang kami disegel,\Nmereka menggosip seenaknya!
Dialogue: 0,0:03:20.36,0:03:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak sejahat itu, enak saja!
Dialogue: 0,0:03:23.36,0:03:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami cuma makan sedikit manusia, kok.
Dialogue: 0,0:03:28.16,0:03:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama daging anak-anak.
Dialogue: 0,0:03:34.00,0:03:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Remaja yang di situ kayaknya enak.
Dialogue: 0,0:03:38.34,0:03:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan sudah mulai alot, sih.\NTapi tidak apa-apa.
Dialogue: 0,0:03:42.88,0:03:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, yang mana tuannya Sayuu?
Dialogue: 0,0:03:48.72,0:03:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kalau ada Sayuu,\Nberarti si kembar sudah lahir, ya.
Dialogue: 0,0:03:54.90,0:03:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin salah satu dari mereka\Nadalah Fuu, Tenaga.
Dialogue: 0,0:03:59.15,0:04:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau disegel lagi, Ashinaga.
Dialogue: 0,0:04:03.91,0:04:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Penjaga Ilahi Sayuu, ini perintah!
Dialogue: 0,0:04:06.37,0:04:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalahkan mereka!
Dialogue: 0,0:04:08.37,0:04:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kenapa kami harus menuruti…
Dialogue: 0,0:04:20.21,0:04:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap laksanakan, Tuanku!
Dialogue: 0,0:04:27.47,0:04:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu tuannya Sayuu,\Nremajanya kita makan nanti saja.
Dialogue: 0,0:04:33.60,0:04:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh dulu yang itu!
Dialogue: 0,0:05:04.38,0:05:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lempar?
Dialogue: 0,0:05:21.07,0:05:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka masih saja meliuk-liuk\Ndan susah diserang.
Dialogue: 0,0:05:25.57,0:05:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pengguna Fuu tidak beraksi,
Dialogue: 0,0:05:28.74,0:05:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti dia tidak ada di sini, ya.
Dialogue: 0,0:05:32.62,0:05:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tanpa bantuan,\Ncuma sebegini kemampuan kalian.
Dialogue: 0,0:05:41.63,0:05:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini tidak ada Fuu dan si Biksu, lo.
Dialogue: 0,0:05:46.63,0:05:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakanlah kutukan yang kami pendam.
Dialogue: 0,0:05:49.89,0:05:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama 1200 tahun ini.
Dialogue: 0,0:05:54.85,0:05:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaga dan Ashinaga ngeri abis!
Dialogue: 0,0:05:56.39,0:05:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dera.
Dialogue: 0,0:05:57.60,0:05:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Yuru.
Dialogue: 0,0:05:58.64,0:06:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah kabur tanpa disuruh.
Dialogue: 0,0:06:01.81,0:06:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terluka?
Dialogue: 0,0:06:03.52,0:06:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu pura-pura\Njadi tuannya Penjaga Ilahi Sayuu?
Dialogue: 0,0:06:07.45,0:06:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya malah diincar, kan?
Dialogue: 0,0:06:09.99,0:06:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku walimu.
Dialogue: 0,0:06:12.62,0:06:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah janji pula sama adikmu\Nyang manis itu.
Dialogue: 0,0:06:16.00,0:06:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu ikut-ikutan segala.
Dialogue: 0,0:06:18.50,0:06:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku juga bisa bertarung.
Dialogue: 0,0:06:20.17,0:06:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau melawan Tenaga dan Ashinaga?
Dialogue: 0,0:06:23.29,0:06:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mimpi!
Dialogue: 0,0:06:26.92,0:06:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pihak Kagemori atau Desa Higashi?
Dialogue: 0,0:06:40.02,0:06:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buang-buang waktu! Jawab!
Dialogue: 0,0:06:44.48,0:06:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pihak Kagemori.
Dialogue: 0,0:06:48.90,0:06:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kagemori tidak semuanya sepaham, kan?
Dialogue: 0,0:06:52.07,0:06:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suruhan siapa?
Dialogue: 0,0:06:53.28,0:06:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kedua, Asuma!
Dialogue: 0,0:06:56.66,0:07:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kai dan Fuu\Nmemang dihasilkan Desa Higashi.
Dialogue: 0,0:07:00.79,0:07:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan harus tetap begitu.
Dialogue: 0,0:07:03.46,0:07:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan dikelola organisasi yang tepat.
Dialogue: 0,0:07:07.42,0:07:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu, ya.
Dialogue: 0,0:07:09.59,0:07:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dilarang melukai kalian,\Nterutama Fuu.
Dialogue: 0,0:07:14.43,0:07:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan dilarang membuntuti terlalu nekat.
Dialogue: 0,0:07:18.02,0:07:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, kenapa aku malah terlibat
Dialogue: 0,0:07:21.39,0:07:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masalah pribadinya\NPenjaga Ilahi Sayuu, sih?
Dialogue: 0,0:07:32.36,0:07:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, setidaknya bibi ini\Ntidak mengincar nyawa kita.
Dialogue: 0,0:07:37.54,0:07:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa melihat mereka\Nkarena sesama pengguna Tsugai, kan?
Dialogue: 0,0:07:41.16,0:07:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:42.29,0:07:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu kami.
Dialogue: 0,0:07:43.83,0:07:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh Tsugai-mu ikut bertarung.
Dialogue: 0,0:07:45.88,0:07:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, kami tidak membawa Tsugai
Dialogue: 0,0:07:49.21,0:07:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar tidak ketahuan Penjaga Ilahi Sayuu.
Dialogue: 0,0:07:52.18,0:07:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi kami cuma membuntuti.
Dialogue: 0,0:07:55.89,0:07:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak berguna!
Dialogue: 0,0:07:59.31,0:08:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini bilang,
Dialogue: 0,0:08:00.85,0:08:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat ini Mayoiga, kan?
Dialogue: 0,0:08:03.23,0:08:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tinggalkan saja\NTenaga dan Ashinaga di sini!
Dialogue: 0,0:08:08.32,0:08:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:08:10.15,0:08:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa gawat kalau Tenaga, Ashinaga,
Dialogue: 0,0:08:12.78,0:08:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tuannya\Ntahu jalur keluar masuk tempat ini.
Dialogue: 0,0:08:16.49,0:08:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, biar aku yang menangkap tuan mereka.
Dialogue: 0,0:08:20.66,0:08:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti di sekitar sini.
Dialogue: 0,0:08:23.12,0:08:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Tsugai cenderung\Nmelindungi tuannya.
Dialogue: 0,0:08:27.17,0:08:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:08:28.75,0:08:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan mereka lengah\Nkarena mengira Yuru anak biasa.
Dialogue: 0,0:08:33.17,0:08:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kayaknya aku bisa bebas bergerak.
Dialogue: 0,0:08:37.51,0:08:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah, mereka mengira\Nkamulah tuan Penjaga Ilahi Sayuu.
Dialogue: 0,0:08:42.06,0:08:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tidak diwaspadai.
Dialogue: 0,0:08:44.94,0:08:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku dan Penjaga Ilahi Sayuu\Nakan meladeni Tenaga dan Ashinaga.
Dialogue: 0,0:08:49.98,0:08:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong cari tuan mereka.
Dialogue: 0,0:08:52.07,0:08:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Bibi.
Dialogue: 0,0:08:56.49,0:08:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah. Apa boleh buat!
Dialogue: 0,0:09:01.66,0:09:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisau tersembunyi?
Dialogue: 0,0:09:03.96,0:09:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo selesaikan biar aku cepat pulang.
Dialogue: 0,0:09:06.92,0:09:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suamiku harus dibuatkan makan malam.
Dialogue: 0,0:09:10.17,0:09:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Ibu-ibu memang ngeri.{\i0}
Dialogue: 0,0:09:25.98,0:09:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus ke gudang senjata diam-diam.
Dialogue: 0,0:09:54.42,0:09:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangannya panjang banget.
Dialogue: 0,0:09:58.59,0:10:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, markasku rusak parah.
Dialogue: 0,0:10:01.93,0:10:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat itu, aku bisa masuk gudangnya.
Dialogue: 0,0:10:09.69,0:10:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tuannya Tenaga dan Ashinaga.{\i0}
Dialogue: 0,0:10:11.44,0:10:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di mana? Di mana dia?{\i0}
Dialogue: 0,0:10:19.91,0:10:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketem—
Dialogue: 0,0:10:21.82,0:10:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dera memang bilang ada beberapa mayat.{\i0}
Dialogue: 0,0:10:26.41,0:10:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ternyata banyak banget!{\i0}
Dialogue: 0,0:10:31.04,0:10:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seharusnya lebih mudah dicari\Nkalau niat membunuhnya terasa.{\i0}
Dialogue: 0,0:10:35.05,0:10:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di mana kamu, tuannya Tenaga dan Ashinaga?{\i0}
Dialogue: 0,0:10:40.01,0:10:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, mereka masih saja keras.
Dialogue: 0,0:10:43.43,0:10:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita memang harus membunuh\Ntuan mereka duluan.
Dialogue: 0,0:10:47.56,0:10:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:10:49.31,0:10:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat mereka jadi Tsugai liar
Dialogue: 0,0:10:52.65,0:10:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berakhir menyedihkan\Ndi Mayoiga ini merupakan ide bagus.
Dialogue: 0,0:11:00.20,0:11:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashinaga!
Dialogue: 0,0:11:01.41,0:11:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa?
Dialogue: 0,0:11:03.87,0:11:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa yang terjadi?\N- A-Apa ini?
Dialogue: 0,0:11:06.54,0:11:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashinaga!
Dialogue: 0,0:11:09.16,0:11:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata mempan.
Dialogue: 0,0:11:12.08,0:11:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian yang baru bebas\Nsetelah disegel sangat lama
Dialogue: 0,0:11:17.80,0:11:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti tidak tahu senjata ini.
Dialogue: 0,0:11:20.72,0:11:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persetan soal kutukan seribu tahun kalian.
Dialogue: 0,0:11:24.26,0:11:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami punya teknologi modern\Nuntuk melawannya.
Dialogue: 0,0:11:28.52,0:11:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kira bisa berbuat seenaknya\Ndi wilayahku.
Dialogue: 0,0:11:35.69,0:11:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaga!
Dialogue: 0,0:11:47.28,0:11:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:11:48.62,0:11:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dilempari sesuatu!
Dialogue: 0,0:11:50.66,0:11:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana?
Dialogue: 0,0:11:56.38,0:11:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Migi!
Dialogue: 0,0:11:59.30,0:12:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidari!
Dialogue: 0,0:12:11.27,0:12:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bedebah!
Dialogue: 0,0:12:15.02,0:12:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bedebah!
Dialogue: 0,0:12:20.11,0:12:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Gawat, aku bisa ketahuan\Nkalau mereka setinggi itu.
Dialogue: 0,0:12:25.78,0:12:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:12:31.87,0:12:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:12:34.79,0:12:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tua, tapi okelah.
Dialogue: 0,0:12:37.71,0:12:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih lebih empuk dan enak\Ndaripada daging laki-laki.
Dialogue: 0,0:12:42.21,0:12:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan buat penyembuhan.
Dialogue: 0,0:12:44.38,0:12:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah duluan, Ashinaga.
Dialogue: 0,0:12:48.39,0:12:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik sekali, Tenaga.
Dialogue: 0,0:12:52.31,0:12:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:12:54.06,0:12:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah yang tadi lebih enak, lo!
Dialogue: 0,0:12:56.98,0:13:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi,\Ndia si kembar calon pemilik Fuu!
Dialogue: 0,0:13:02.94,0:13:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dasar tua bangka! Dia malah mengadu!{\i0}
Dialogue: 0,0:13:05.95,0:13:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:07.36,0:13:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lebih menggiurkan dariku!
Dialogue: 0,0:13:10.66,0:13:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah yang bersamamu tadi?
Dialogue: 0,0:13:16.62,0:13:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah calon pemilik Fuu ada di sini?
Dialogue: 0,0:13:22.46,0:13:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah itu belum mendapatkan Fuu?
Dialogue: 0,0:13:28.97,0:13:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagus, cepat cari bocah itu.{\i0}
Dialogue: 0,0:13:32.60,0:13:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Akan kupotong\Ntangannya saat mulai longgar!{\i0}
Dialogue: 0,0:13:38.81,0:13:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja kami butuh nutrisi\Nbuat menyembuhkan diri.
Dialogue: 0,0:13:56.21,0:14:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan bibi itu,\Ndia punya keluarga yang menunggu.
Dialogue: 0,0:14:01.46,0:14:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah si kembar pemisah siang dan malam.
Dialogue: 0,0:14:05.34,0:14:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekaligus tuan asli\Ndari Penjaga Ilahi Sayuu.
Dialogue: 0,0:14:08.84,0:14:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalau ada perlu,
Dialogue: 0,0:14:10.89,0:14:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}maju sini!{\i0}
Dialogue: 0,0:14:15.81,0:14:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah ini si kembar\Nsekaligus tuan aslinya Sayuu?
Dialogue: 0,0:14:23.61,0:14:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau disebutnya calon pemilik Fuu.
Dialogue: 0,0:14:27.07,0:14:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti dia belum dapat kekuatannya.
Dialogue: 0,0:14:30.87,0:14:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:14:34.37,0:14:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibunuh, nanti dia mendapatkan Fuu.
Dialogue: 0,0:14:39.12,0:14:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kita malah disegel lagi.
Dialogue: 0,0:14:42.75,0:14:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia hidup lagi,\Nlangsung bunuh lagi saja.
Dialogue: 0,0:14:46.38,0:14:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin Sayuu membiarkannya, Tenaga.
Dialogue: 0,0:14:52.85,0:14:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar, Ashinaga.
Dialogue: 0,0:14:55.81,0:14:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga Ilahi Sayuu, jangan ikut campur.
Dialogue: 0,0:14:58.27,0:14:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:59.23,0:15:01.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur sebelum kuizinkan.
Dialogue: 0,0:15:03.02,0:15:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tugasku.
Dialogue: 0,0:15:11.36,0:15:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap laksanakan!
Dialogue: 0,0:15:24.92,0:15:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua anjing itu benaran diam saja,\NAshinaga.
Dialogue: 0,0:15:30.22,0:15:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka anjing\Nyang sungguh patuh, ya, Tenaga.
Dialogue: 0,0:15:34.09,0:15:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal matanya hancur,\Nkok kakinya masih lincah?
Dialogue: 0,0:15:37.68,0:15:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski buta, aku bisa melihat lewat Tenaga.
Dialogue: 0,0:15:44.40,0:15:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Meski pincang,
Dialogue: 0,0:15:46.19,0:15:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ashinaga akan berjalan sesuai kemauanku.
Dialogue: 0,0:15:53.91,0:15:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah satu kesatuan.
Dialogue: 0,0:15:57.62,0:16:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah bentuk sempurna
Dialogue: 0,0:16:00.41,0:16:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari Tenaga dan Ashinaga!
Dialogue: 0,0:16:11.55,0:16:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, mereka besar tapi meliuk-liuk.
Dialogue: 0,0:16:14.47,0:16:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakannya cepat, sulit dibidik!
Dialogue: 0,0:16:27.23,0:16:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelihatan, lo.
Dialogue: 0,0:16:30.15,0:16:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan melumatmu setelah bocah itu.
Dialogue: 0,0:16:57.47,0:16:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:17:16.07,0:17:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru!
Dialogue: 0,0:17:38.59,0:17:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh pakai cara apa, ya?
Dialogue: 0,0:17:41.93,0:17:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita copot dulu lengan kirinya?
Dialogue: 0,0:17:45.31,0:17:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tarik dulu lidahnya\Nbiar tidak bisa minta tolong si Sayuu.
Dialogue: 0,0:17:58.70,0:18:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan-jangan\Nbocah ini sudah punya kekuatan Fuu?{\i0}
Dialogue: 0,0:18:03.70,0:18:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Diingat-ingat,{\i0}
Dialogue: 0,0:18:05.45,0:18:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}pria itu juga bohong soal tuannya Sayuu.{\i0}
Dialogue: 0,0:18:12.46,0:18:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa dia pura-pura tidak bisa memakai Fuu{\i0}
Dialogue: 0,0:18:14.92,0:18:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sampai benar-benar yakin\Nbisa menghabisi kami?{\i0}
Dialogue: 0,0:18:20.34,0:18:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terkecoh.
Dialogue: 0,0:18:24.06,0:18:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Lengah sekilas pun sudah cukup
Dialogue: 0,0:18:28.27,0:18:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}untuk dimanfaatkan Penjaga Ilahi Sayuu.
Dialogue: 0,0:18:30.90,0:18:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sudah boleh!
Dialogue: 0,0:18:34.15,0:18:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan sesuka kalian!
Dialogue: 0,0:18:39.11,0:18:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kalian melukai tuan kami!
Dialogue: 0,0:18:58.59,0:19:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaga! Di mana kamu?
Dialogue: 0,0:19:02.09,0:19:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab aku, Tenaga!
Dialogue: 0,0:19:04.76,0:19:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melihat apa-apa!
Dialogue: 0,0:19:07.77,0:19:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi, Tenaga?
Dialogue: 0,0:19:11.81,0:19:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku di sini.
Dialogue: 0,0:19:14.52,0:19:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong…
Dialogue: 0,0:19:28.91,0:19:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaga?
Dialogue: 0,0:19:31.46,0:19:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaga?
Dialogue: 0,0:20:12.75,0:20:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bentuk asli mereka, ya.
Dialogue: 0,0:20:15.67,0:20:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal makhluk sekuat mereka\Nbisa jadi dewa ternama kalau berbuat baik.
Dialogue: 0,0:20:21.76,0:20:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuru, kamu baik-baik saja?
Dialogue: 0,0:20:24.51,0:20:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan.
Dialogue: 0,0:20:26.26,0:20:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipuanmu berhasil.
Dialogue: 0,0:20:34.56,0:20:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Asa mengepal lalu membuka tangannya\Nsaat menggunakan Kai.{\i0}
Dialogue: 0,0:20:39.02,0:20:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir Fuu kebalikannya\Ndan ternyata benar.
Dialogue: 0,0:20:42.61,0:20:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar kaget.
Dialogue: 0,0:20:45.20,0:20:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau monster kayak mereka saja\Nbisa langsung disegel,
Dialogue: 0,0:20:48.78,0:20:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berarti memang ngeri.
Dialogue: 0,0:20:51.41,0:20:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya,\Nkekuatan Fuu memang sehebat itu.
Dialogue: 0,0:20:56.96,0:21:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya manusia tanpa Fuu sepertimu\Nmenghadapi Tenaga Ashinaga.
Dialogue: 0,0:21:02.67,0:21:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak bisa menang,\Naku bisa kabur dari serangannya.
Dialogue: 0,0:21:07.18,0:21:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi rencanamu bukan cuma kabur, kan?
Dialogue: 0,0:21:10.72,0:21:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, itu tugasku, sisanya kalian.
Dialogue: 0,0:21:16.31,0:21:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah Tsugai yang mengikuti kita\Nsejak meninggalkan wisma Kagemori.
Dialogue: 0,0:21:22.61,0:21:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit kudeteksi karena hawanya tipis.
Dialogue: 0,0:21:25.65,0:21:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia yang mereka kirim cuma pengalihan.
Dialogue: 0,0:21:30.95,0:21:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mata-mata aslinya kupu-kupu ini?
Dialogue: 0,0:21:33.95,0:21:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Tsugai milik Asuma.
Dialogue: 0,0:21:36.46,0:21:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya,\Nbagian kecil dari Tsugai-nya.
Dialogue: 0,0:21:40.59,0:21:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuh satu ekor ini saja\Ntidak akan berpengaruh.
Dialogue: 0,0:23:28.99,0:23:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benarkah?{\i0}
Dialogue: 0,0:23:30.82,0:23:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Maafkan aku!{\i0}
Dialogue: 0,0:23:32.07,0:23:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia anakmu, Dera?{\i0}
Dialogue: 0,0:23:33.57,0:23:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak mengenalnya!{\i0}
Dialogue: 0,0:23:36.08,0:23:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia bukan anakku!{\i0}
