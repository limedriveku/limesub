Dialogue: 0,0:00:43.56,0:00:46.28,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:09:00.69,0:09:01.48,sign,,0000,0000,0000,,LABIRIN LEDAKAN
Dialogue: 0,0:10:12.30,0:10:13.93,sign,,0000,0000,0000,,TINJU LEDAK LIMA ANGGOTA TUBUH
Dialogue: 0,0:12:25.02,0:12:27.06,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:12:27.06,0:12:29.02,sign,,0000,0000,0000,,PESTA PERNIKAHAN PENGGUNA SERANGGA
Dialogue: 0,0:12:59.38,0:13:03.64,sign,,0000,0000,0000,,TINJU LEDAK TUBUH PALSU
Dialogue: 0,0:22:02.26,0:22:02.88,sign,,0000,0000,0000,,PENGGUNA TOMBAK: KUSHIMA NAGIHIKO
Dialogue: 0,0:22:11.31,0:22:12.73,sign,,0000,0000,0000,,PENGGUNA RACUN: GERO HIKARU
Dialogue: 0,0:23:53.20,0:23:55.96,sign,,0000,0000,0000,,PERBURUAN PEMBUNUH BAYARAN
Dialogue: 0,0:00:12.53,0:00:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.95,0:00:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:00:17.54,0:00:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.71,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:25.63,0:00:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.51,0:00:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:02:06.56,0:02:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Serangga, Hanamaki Toshiki.
Dialogue: 0,0:02:09.22,0:02:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia rekan sejawatku sejak lama
Dialogue: 0,0:02:11.69,0:02:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekaligus sahabatku.
Dialogue: 0,0:02:13.36,0:02:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pesta pernikahan orang ini?
Dialogue: 0,0:02:16.87,0:02:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran seperti seorang pengguna.
Dialogue: 0,0:02:19.20,0:02:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat bersenang-senang, ya.
Dialogue: 0,0:02:20.41,0:02:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kinosaki.
Dialogue: 0,0:02:21.87,0:02:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:22.41,0:02:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh.
Dialogue: 0,0:02:24.17,0:02:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kupu-kupu\Nyang ditujukan padamu juga.
Dialogue: 0,0:02:27.84,0:02:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruntuk yang terhormat Kinosaki.
Dialogue: 0,0:02:30.17,0:02:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kabar Anda saat semilir\Npermulaan musim panas menyentuh kulit ini?
Dialogue: 0,0:02:34.88,0:02:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya sudah dengar situasinya dari Gero.
Dialogue: 0,0:02:37.30,0:02:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak sudah membantu\Npencarian jodoh Gero di tengah kesibukan Anda.
Dialogue: 0,0:02:42.06,0:02:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka dari itu,
Dialogue: 0,0:02:43.18,0:02:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya akan sangat senang bila Anda bersedia hadir\Ndi pesta pernikahan saya bersama Gero.
Dialogue: 0,0:02:48.23,0:02:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon izinkan saya\Nberterima kasih secara langsung.
Dialogue: 0,0:02:51.78,0:02:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan penuh hormat,\NPengguna Serangga, Hanamaki Toshiki.
Dialogue: 0,0:02:55.53,0:02:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ternyata orangnya sangat baik?
Dialogue: 0,0:02:58.45,0:03:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya buatku,\Njadi enggak punya baju yang cocok...
Dialogue: 0,0:03:01.91,0:03:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya aku ingin hadir dengan rapi\Ndi pesta pernikahannya.
Dialogue: 0,0:03:05.87,0:03:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatmu bagus, tuh.
Dialogue: 0,0:03:07.71,0:03:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya pesta pernikahan juga\Nbisa jadi pertemuan baru.
Dialogue: 0,0:03:10.67,0:03:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian minta dibelikan juga, ah.
Dialogue: 0,0:03:13.55,0:03:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang traktir, ya.
Dialogue: 0,0:03:30.77,0:03:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pesta pernikahan Pengguna Serangga?
Dialogue: 0,0:03:33.90,0:03:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh kali lipat lebih fantasi\Ndari bayanganku.
Dialogue: 0,0:03:46.12,0:03:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero?
Dialogue: 0,0:03:51.47,0:03:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero!
Dialogue: 0,0:03:53.21,0:03:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hidup lagi!
Dialogue: 0,0:03:55.30,0:03:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, staminamu parah sekali turunnya.
Dialogue: 0,0:03:58.34,0:04:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu bergantung\Npada Mutasi Keturunan.
Dialogue: 0,0:04:01.26,0:04:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kusegarkan lagi dirimu sampai 80%.
Dialogue: 0,0:04:04.97,0:04:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, biar aku kenalkan padamu.
Dialogue: 0,0:04:07.02,0:04:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga sahabatku\Nsama seperti Pengguna Racun.
Dialogue: 0,0:04:10.31,0:04:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsunagi si Pengguna Racun.
Dialogue: 0,0:04:12.02,0:04:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang berbisnis denganmu.
Dialogue: 0,0:04:13.90,0:04:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian.\NAku sudah dapat uang.
Dialogue: 0,0:04:16.77,0:04:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir pekan kita akan pergi\Nke Taman Hiburan Fushi Land.
Dialogue: 0,0:04:20.16,0:04:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, nanti bisa ketemu Fusshi?
Dialogue: 0,0:04:22.62,0:04:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:04:23.62,0:04:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rute terbaik untuk naik wahananya?
Dialogue: 0,0:04:25.70,0:04:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan padamu.
Dialogue: 0,0:04:26.79,0:04:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ayah yang baik.
Dialogue: 0,0:04:28.50,0:04:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ayah dari tiga anak.
Dialogue: 0,0:04:30.08,0:04:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi kamu penasihat\Ncari jodohnya Bos, ya?
Dialogue: 0,0:04:34.67,0:04:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti berat, aku bisa mengerti.
Dialogue: 0,0:04:36.84,0:04:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda paham kesulitanku?
Dialogue: 0,0:04:39.93,0:04:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadirin yang terhormat.
Dialogue: 0,0:04:41.89,0:04:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak telah meluangkan waktu\Nuntuk datang dari jauh pada hari ini.
Dialogue: 0,0:04:49.44,0:04:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesaat lagi, pesta pernikahan Hanamaki Toshiki\Ndan Kawakita Anna akan segera dimulai.
Dialogue: 0,0:05:02.49,0:05:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar fajar bisa bersinar di dunia gelap...
Dialogue: 0,0:05:07.04,0:05:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaringan perdagangan organ\Ndan kartel narkoba...
Dialogue: 0,0:05:11.50,0:05:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang harus saling bekerja sama...
Dialogue: 0,0:05:13.83,0:05:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambisiku untuk membuka luas\Ndunia gelap masih—
Dialogue: 0,0:05:19.22,0:05:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:05:27.97,0:05:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kamu datang.
Dialogue: 0,0:05:29.93,0:05:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya datang untuk memperingati\Nsecara langsung.
Dialogue: 0,0:05:32.98,0:05:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar!
Dialogue: 0,0:05:34.15,0:05:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski menjilatku karena aku cucunya,
Dialogue: 0,0:05:36.11,0:05:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan membuat Nenek\Nmemberi kalian perlakuan istimewa!
Dialogue: 0,0:05:40.36,0:05:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:41.53,0:05:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, maaf sudah membuatmu salah paham.
Dialogue: 0,0:05:44.66,0:05:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin minum bersama.
Dialogue: 0,0:05:47.99,0:05:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersamamu, Gero Hikaru.
Dialogue: 0,0:05:55.67,0:05:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tidak menemaniku?
Dialogue: 0,0:05:58.05,0:06:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih di bawah umur,\Njadi minuman biasa saja, ya.
Dialogue: 0,0:06:03.59,0:06:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, kamu mendengarkan tidak?
Dialogue: 0,0:06:06.64,0:06:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:06:07.81,0:06:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awal pertemuan mereka.
Dialogue: 0,0:06:09.77,0:06:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya itu saat Anna yang jadi mempelai wanita\Nkena masalah saat mendaki gunung.
Dialogue: 0,0:06:14.60,0:06:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang begitu sifatnya.
Dialogue: 0,0:06:53.31,0:06:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, apa aku juga bisa\Ndapat pernikahan seindah itu?
Dialogue: 0,0:06:59.98,0:07:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bisa.
Dialogue: 0,0:07:01.15,0:07:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ada aku yang membantumu.
Dialogue: 0,0:07:06.07,0:07:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, Toshiki.
Dialogue: 0,0:07:20.34,0:07:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuh kebahagiaan.
Dialogue: 0,0:07:22.46,0:07:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuh cinta sekali dirimu,\NPengguna Serangga.
Dialogue: 0,0:07:25.55,0:07:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang sekali.
Dialogue: 0,0:07:33.22,0:07:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hobi keduanya yang bertemu di gunung\Nadalah pergi kemah saat libur.
Dialogue: 0,0:07:37.14,0:07:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga hiking, serta mengelilingi kayu bakar
Dialogue: 0,0:07:40.31,0:07:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghabiskan
Dialogue: 0,0:07:41.52,0:07:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- waktu bersama dengan syahdu.\N- Tambah chateaubriand lagi!
Dialogue: 0,0:07:43.03,0:07:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lalu, di malam hari,\N- Tambah chateaubriand lagi!
Dialogue: 0,0:07:44.36,0:07:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di bawah langit berbintang...
Dialogue: 0,0:07:46.20,0:07:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero?
Dialogue: 0,0:07:47.28,0:07:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya habis ini ada pidato\Nperwakilan sahabat?
Dialogue: 0,0:07:49.66,0:07:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan padamu, Kinosaki!
Dialogue: 0,0:07:51.45,0:07:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:07:52.49,0:07:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laba-laba apa itu?
Dialogue: 0,0:07:55.16,0:07:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, Julia Junior.
Dialogue: 0,0:07:57.16,0:08:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sobatnya, tentu kalian\Ntidak ingin pesta ini ternoda.
Dialogue: 0,0:08:04.05,0:08:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini hari terbaik Toshiki, kan?
Dialogue: 0,0:08:09.68,0:08:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat lima menit lagi.
Dialogue: 0,0:08:12.30,0:08:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teroboslah aula dari semua pintu masuk\Nyang sudah ditentukan
Dialogue: 0,0:08:15.69,0:08:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengamuklah sesuka kalian.
Dialogue: 0,0:08:17.14,0:08:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin banyak yang kalian bunuh,\Nmakin banyak bonusnya.
Dialogue: 0,0:08:19.56,0:08:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Pengguna Serangga\Ndan para pengguna yang ada di sana
Dialogue: 0,0:08:23.27,0:08:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai melawan balik, kalian boleh pergi.
Dialogue: 0,0:08:26.03,0:08:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat itu, aku akan menyalakan\Nkembang api pada mempelai wanita.
Dialogue: 0,0:08:30.32,0:08:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin warnanya akan\Nberubah jadi indah.
Dialogue: 0,0:08:33.08,0:08:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga membekas di pelupuk mata
Dialogue: 0,0:08:35.83,0:08:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan jadi kenangan indah untuk selamanya...
Dialogue: 0,0:08:43.00,0:08:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bayaran yang kusewa dari\NKerjaan Gelap cuma selevel ini, ya.
Dialogue: 0,0:08:46.88,0:08:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:08:49.53,0:08:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya mengubah rencana!
Dialogue: 0,0:09:01.48,0:09:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Labirin Ledakan!
Dialogue: 0,0:09:04.44,0:09:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sayang sekali!
Dialogue: 0,0:09:07.19,0:09:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini kusiapkan untuk tamu yang panik\Nagar bisa lari dari dunia nyata.
Dialogue: 0,0:09:11.99,0:09:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mau bagaimana lagi,\Nkamu sudah menghalangi.
Dialogue: 0,0:09:15.91,0:09:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terpenting saat ini adalah\Nberterima kasih pada Pengguna Serangga.
Dialogue: 0,0:09:20.12,0:09:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia pria yang telah merebut\Nsatu-satunya gairahku!
Dialogue: 0,0:09:24.96,0:09:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, saat itu aku...
Dialogue: 0,0:09:27.71,0:09:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah tidak peduli pada apa pun lagi.
Dialogue: 0,0:09:30.84,0:09:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjut sekolah, cari kerja, menikah.
Dialogue: 0,0:09:33.93,0:09:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepele rasanya.
Dialogue: 0,0:09:35.76,0:09:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan saat tahu-tahu sudah\Nmenanggung utang yang besar pun
Dialogue: 0,0:09:38.64,0:09:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tetap masa bodoh.
Dialogue: 0,0:09:43.02,0:09:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membayarnya, meski orang\Nyang mengaku sebagai pengguna boneka
Dialogue: 0,0:09:46.73,0:09:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memodifikasiku jadi pion\Nbagi organisasi kriminal,
Dialogue: 0,0:09:50.65,0:09:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tetap tidak peduli.
Dialogue: 0,0:09:56.08,0:09:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada.
Dialogue: 0,0:09:57.70,0:10:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di pergelangan tangan dan kaki kananmu,
Dialogue: 0,0:10:00.29,0:10:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pergelangan kiri tangan dan kaki,\Nserta kepalamu sudah kupasangi bom kecil.
Dialogue: 0,0:10:06.46,0:10:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika sakelar di gigi gerahammu ditekan\Nsaat terjadi benturan.
Dialogue: 0,0:10:10.38,0:10:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh akan meledak bersama
Dialogue: 0,0:10:12.30,0:10:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daging dan tulangmu sendiri.
Dialogue: 0,0:10:13.93,0:10:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinju Ledak Lima Anggota Tubuh.
Dialogue: 0,0:10:17.31,0:10:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan keberadaan sampah sepertimu\Nadalah untuk meledak dengan indah.
Dialogue: 0,0:10:27.90,0:10:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah terdesak, aku tinggal mati\Nbersama musuhku saja.
Dialogue: 0,0:10:31.82,0:10:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinju Ledak Lima Anggota Tubuh
Dialogue: 0,0:10:34.70,0:10:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah menyulut api gairah di hatiku\Nuntuk pertama kalinya!
Dialogue: 0,0:10:43.16,0:10:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai aku bertemu dengannya.
Dialogue: 0,0:11:04.27,0:11:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terjebak!
Dialogue: 0,0:11:05.98,0:11:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau senjata pemungkas yang tertanam\Ndi kepalaku kuaktifkan sekarang!
Dialogue: 0,0:11:10.40,0:11:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan nyawaku sebagai bayarannya...
Dialogue: 0,0:11:15.32,0:11:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kulepas.
Dialogue: 0,0:11:17.16,0:11:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah tidak perlu dibayangi\Nrasa takut akan mati lagi.
Dialogue: 0,0:11:24.29,0:11:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah caranya dia...
Dialogue: 0,0:11:26.08,0:11:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}merenggut gairahku hanya demi\Nkepuasan dirinya sendiri!
Dialogue: 0,0:11:30.34,0:11:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga berhak\Nuntuk menghancurkan hal berharganya, kan?
Dialogue: 0,0:11:35.34,0:11:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meminjam tangan dan kaki baru\Ndari Pengguna Boneka,
Dialogue: 0,0:11:38.93,0:11:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu ambil kerjaan kotor\Nmati-matian mengumpulkan uang,
Dialogue: 0,0:11:42.43,0:11:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sembari menunggu hari ini tiba!
Dialogue: 0,0:11:44.68,0:11:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun yang menghalangi—
Dialogue: 0,0:11:47.03,0:11:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, dia sudah mati, ya?
Dialogue: 0,0:11:50.65,0:11:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, Kinosaki, begitu saja.
Dialogue: 0,0:11:53.40,0:11:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong gantikan aku.
Dialogue: 0,0:11:55.32,0:11:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:56.11,0:11:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susyi?
Dialogue: 0,0:11:57.20,0:11:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, deh.
Dialogue: 0,0:12:00.57,0:12:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang sesuatu?
Dialogue: 0,0:12:03.45,0:12:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:12:05.34,0:12:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu kondisimu,
Dialogue: 0,0:12:06.71,0:12:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi orang baik-baik tidak akan dendam\Npada Pengguna Serangga.
Dialogue: 0,0:12:10.04,0:12:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutolak pertunjukan membosankanmu.
Dialogue: 0,0:12:15.00,0:12:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, pidato dari perwakilan sahabat.
Dialogue: 0,0:12:19.80,0:12:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat Gero mentraktirku susyi\Nseharga ratusan ribu yen.
Dialogue: 0,0:12:29.81,0:12:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya turun hujan.
Dialogue: 0,0:12:32.27,0:12:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal pemandangan senja dari sini\Nindah sekali.
Dialogue: 0,0:12:35.73,0:12:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, sahabat dari mempelai pria,\NTuan Gero Hikaru—
Dialogue: 0,0:12:40.99,0:12:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:42.03,0:12:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero sakit perut karena gugup.
Dialogue: 0,0:12:45.24,0:12:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, izinkan saya membacakan surat\Nyang dia titipkan.
Dialogue: 0,0:12:48.25,0:12:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama saya Kinosaki Mei.
Dialogue: 0,0:12:57.34,0:12:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu itu!
Dialogue: 0,0:12:59.38,0:13:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang Pengguna, kan?
Dialogue: 0,0:13:01.05,0:13:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya lebih baik jangan disimpan saja?
Dialogue: 0,0:13:03.64,0:13:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mutasi Keturunanmu itu!
Dialogue: 0,0:13:08.98,0:13:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mubazir kalau ditunjukkan padamu!
Dialogue: 0,0:13:12.69,0:13:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toshiki, Anna.
Dialogue: 0,0:13:15.11,0:13:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas pernikahan kalian.
Dialogue: 0,0:13:17.32,0:13:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih tidak percaya akan tiba hari\Naku mengucapkan selamat begini.
Dialogue: 0,0:13:22.53,0:13:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toshiki.
Dialogue: 0,0:13:24.74,0:13:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku juga sedang cari calon.
Dialogue: 0,0:13:28.25,0:13:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar berat ternyata.
Dialogue: 0,0:13:33.25,0:13:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diriku yang dulu sampai tahu,
Dialogue: 0,0:13:35.46,0:13:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pasti marah dan bilang,\N"Mustahil, itu cuma buang-buang waktu."
Dialogue: 0,0:13:40.92,0:13:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, alasanku sekarang jadi ingin
Dialogue: 0,0:13:44.09,0:13:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertemu pasangan hidup yang terbaik itu.
Dialogue: 0,0:13:47.93,0:13:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toshiki, itu pengaruh darimu.
Dialogue: 0,0:13:53.48,0:13:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Toshiki.
Dialogue: 0,0:13:54.77,0:14:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa kamu sangat peduli padaku\Nyang terhuyung lesu seperti hantu?
Dialogue: 0,0:14:02.57,0:14:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuucapkan terima kasih\Nmewakili diriku saat itu.
Dialogue: 0,0:14:06.37,0:14:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada dirimu,
Dialogue: 0,0:14:09.16,0:14:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang aku pasti masih...
Dialogue: 0,0:14:20.09,0:14:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membidik ke mana—
Dialogue: 0,0:14:24.59,0:14:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak memedulikan ikatan yang rumit
Dialogue: 0,0:14:27.01,0:14:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan selalu mengulurkan tangan\Npada orang yang kesulitan.
Dialogue: 0,0:14:31.56,0:14:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang seperti itulah sahabat terbaik\Ndan terkeren yang kumiliki.
Dialogue: 0,0:14:39.07,0:14:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin mengotori\Nhari bahagia ini dengan darah.
Dialogue: 0,0:14:42.53,0:14:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang sana.
Dialogue: 0,0:14:45.32,0:14:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada, tampaknya kamu kesulitan.
Dialogue: 0,0:14:48.12,0:14:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini layanan purnajual.
Dialogue: 0,0:14:50.24,0:14:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kulepas pembatasmu.
Dialogue: 0,0:14:52.79,0:14:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa mengempaskan semuanya\Ndengan ledakan sekelas angin topan.
Dialogue: 0,0:15:03.51,0:15:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu saja kamu, Pengguna Serangga!
Dialogue: 0,0:15:19.90,0:15:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan...
Dialogue: 0,0:15:21.98,0:15:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu curang!
Dialogue: 0,0:15:24.70,0:15:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dibanding sekadar pion sepertiku,\Nkamu jauh lebih kelam dan dalam
Dialogue: 0,0:15:29.16,0:15:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadikan dunia gelap wilayah kekuasaanmu.
Dialogue: 0,0:15:33.00,0:15:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagaimana bisa memeluk\Nmusuhmu dengan selembut itu?
Dialogue: 0,0:15:38.67,0:15:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada, arahmu itu terbalik.
Dialogue: 0,0:15:42.21,0:15:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu...
Dialogue: 0,0:15:43.84,0:15:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Sial! Sialan!
Dialogue: 0,0:15:48.03,0:15:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah perpisahanku!
Dialogue: 0,0:15:51.78,0:15:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir, untuk Anna.
Dialogue: 0,0:15:53.97,0:15:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah diperjelas,\Ntapi saat kamu bertemu dengannya
Dialogue: 0,0:16:01.19,0:16:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhir bahagiamu sudah terjamin.
Dialogue: 0,0:16:05.36,0:16:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian.
Dialogue: 0,0:16:06.70,0:16:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:16:13.58,0:16:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadirin, silakan lihat ke luar jendela.
Dialogue: 0,0:16:24.76,0:16:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toshiki.
Dialogue: 0,0:16:28.22,0:16:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat.
Dialogue: 0,0:16:44.69,0:16:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, terima kasih.
Dialogue: 0,0:16:47.61,0:16:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pidato,\Nserta pencarian jodoh Gero.
Dialogue: 0,0:16:50.95,0:16:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak seberapa.
Dialogue: 0,0:16:52.91,0:16:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyangka\Nternyata kamu orang yang baik.
Dialogue: 0,0:16:56.50,0:17:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu perhatian pada Gero\Nsejak dia masih memberontak.
Dialogue: 0,0:17:01.54,0:17:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru aku yang harus berterima kasih.
Dialogue: 0,0:17:05.71,0:17:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:06.99,0:17:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mengakuiku sebagai sahabat.
Dialogue: 0,0:17:09.47,0:17:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta datang ke pernikahanku,\Nkalau melihat strata kekuatan keluarga,
Dialogue: 0,0:17:14.39,0:17:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya tidak mungkin.
Dialogue: 0,0:17:16.22,0:17:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strata kekuatan?
Dialogue: 0,0:17:18.18,0:17:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu juga pengguna\Nsama seperti Gero?
Dialogue: 0,0:17:25.89,0:17:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Pengguna Serangga Hanamaki\Nberasal dari racun serangga.
Dialogue: 0,0:17:29.03,0:17:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan Keluarga Pengguna Jarum Tsunagi\Ndari jarum racun.
Dialogue: 0,0:17:32.03,0:17:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, masih banyak pengguna lain\Nyang menggunakan "penyakit" misalnya.
Dialogue: 0,0:17:37.04,0:17:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi keluarga ranting seperti kami
Dialogue: 0,0:17:38.95,0:17:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berasal dari Keluarga Pengguna racun.
Dialogue: 0,0:17:41.46,0:17:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, ada hierarki absolut\Ndi antara kami.
Dialogue: 0,0:17:45.00,0:17:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di puncak hierarki tersebut,\Nada Lima Keluarga Besar.
Dialogue: 0,0:17:48.51,0:17:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Gero.
Dialogue: 0,0:17:50.09,0:17:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Arima.
Dialogue: 0,0:17:51.76,0:17:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Dogo.
Dialogue: 0,0:17:53.76,0:17:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Kirishima.
Dialogue: 0,0:17:55.33,0:17:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Nasu.
Dialogue: 0,0:17:57.97,0:18:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkumpulan yang disebut Pengguna
Dialogue: 0,0:18:00.31,0:18:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya adalah keluarga cabang\Ndan keluarga ranting mereka.
Dialogue: 0,0:18:04.02,0:18:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terkadang ada keluarga\Nyang tidak terhubung ke mana pun.
Dialogue: 0,0:18:07.44,0:18:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika orang dari keluarga cabang diperintah\Nuntuk mati oleh keluarga inti,
Dialogue: 0,0:18:11.65,0:18:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka akan menurut dan mengakhiri hidup.
Dialogue: 0,0:18:13.85,0:18:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebesar itulah kesenjangan yang ada.
Dialogue: 0,0:18:18.24,0:18:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Toshiki.
Dialogue: 0,0:18:20.12,0:18:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita itu dibiarkan hidup oleh Keluarga Gero.
Dialogue: 0,0:18:26.13,0:18:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala keluarga dari Lima Keluarga Besar
Dialogue: 0,0:18:28.42,0:18:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak berperikemanusiaan dan sudah\Nratusan tahun mempermainkan hidup manusia.
Dialogue: 0,0:18:32.38,0:18:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikir kita setara dengan mereka.
Dialogue: 0,0:18:34.76,0:18:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawa musuh dan sekutu tidak lebih\Ndari pion bagi bisnis keluarga mereka.
Dialogue: 0,0:18:40.18,0:18:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ingin binasa,\Npilihannya cuma diam dan patuh.
Dialogue: 0,0:18:59.70,0:19:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian boleh mengangkat kepala.
Dialogue: 0,0:19:06.17,0:19:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau Tuan Hikaru yang baru dipilih\Njadi kepala keluarga selanjutnya.
Dialogue: 0,0:19:11.49,0:19:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesan pertama saat bertemu Gero,\Ndibanding merasa takut,
Dialogue: 0,0:19:17.61,0:19:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kurasa malah...
Dialogue: 0,0:19:22.65,0:19:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangga seperti kami bisa bertahan hidup\Nberkat Keluarga Gero.
Dialogue: 0,0:19:28.61,0:19:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, cukup sampai di sini.
Dialogue: 0,0:19:30.32,0:19:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:19:32.91,0:19:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hikaru!
Dialogue: 0,0:19:34.69,0:19:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawanya tidak lebih dari serangga!
Dialogue: 0,0:19:37.49,0:19:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan pakai dan buang sesuka Anda!
Dialogue: 0,0:19:41.33,0:19:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mohon dengan sangat!
Dialogue: 0,0:19:54.13,0:19:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin dia serangga.
Dialogue: 0,0:20:01.66,0:20:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya ditakuti sepihak\Noleh orang-orang di sekitarnya.
Dialogue: 0,0:20:06.31,0:20:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, dia hanya orang biasa.
Dialogue: 0,0:20:09.58,0:20:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang normal yang baik.
Dialogue: 0,0:20:13.03,0:20:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski mulut ayahku sampai berbusa dan pingsan\Nsaat kuberi tahu aku jadi teman minumnya.
Dialogue: 0,0:20:19.87,0:20:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki.
Dialogue: 0,0:20:28.71,0:20:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kurasa akan lebih merepotkan dibanding\Nkeluargaku atau keluarga Pengguna Jarum.
Dialogue: 0,0:20:34.22,0:20:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tolong buat dia sebahagia mungkin.
Dialogue: 0,0:20:39.89,0:20:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aku benaran kerepotan, lo.
Dialogue: 0,0:20:42.68,0:20:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia langsung gugup\Nkalau di hadapan perempuan.
Dialogue: 0,0:20:45.52,0:20:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa dimengerti.
Dialogue: 0,0:20:47.39,0:20:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tahu dia orang yang baik.
Dialogue: 0,0:20:52.15,0:20:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan kutemukan.
Dialogue: 0,0:20:54.65,0:20:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang akan menjalani hidup\Nbersama Gero.
Dialogue: 0,0:21:02.78,0:21:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sepengetahuanku dia sudah\Nmenjalin ikatan dengan rekan kerjaku.
Dialogue: 0,0:21:07.33,0:21:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sudah Kinosaki lakukan?
Dialogue: 0,0:21:13.08,0:21:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ajak-ajak kalau bertarung.
Dialogue: 0,0:21:15.42,0:21:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus mengurus anak, kan?
Dialogue: 0,0:21:22.61,0:21:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toshiki.
Dialogue: 0,0:21:24.65,0:21:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kamu menemukan\N100 juta kebahagiaan.
Dialogue: 0,0:21:33.98,0:21:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga bahagia selamanya!
Dialogue: 0,0:21:48.41,0:21:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat mahir mengayunkan
Dialogue: 0,0:21:51.79,0:21:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tongkat panjang yang ada bilahnya.
Dialogue: 0,0:21:54.42,0:21:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi...
Dialogue: 0,0:21:57.21,0:22:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, sepertinya biasa saja.
Dialogue: 0,0:22:00.55,0:22:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:22:02.88,0:22:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku kirimkan\Ndaftar Pengguna berikutnya.
Dialogue: 0,0:22:07.12,0:22:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat membasmi pembunuh bayarannya, ya.
Dialogue: 0,0:23:46.39,0:23:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Akan kubiarkan kamu melindungi diriku!\N- Sehari sepuluh ribu yen.
Dialogue: 0,0:23:50.08,0:23:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang, yuk, pulang.
Dialogue: 0,0:23:50.95,0:23:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia maju duluan?\N- Sangat menyenangkan, bukan?
Dialogue: 0,0:23:51.95,0:23:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tolong mati.\N- Sangat menyenangkan, bukan?
Dialogue: 0,0:23:53.20,0:23:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Perburuan Pembunuh Bayaran.
