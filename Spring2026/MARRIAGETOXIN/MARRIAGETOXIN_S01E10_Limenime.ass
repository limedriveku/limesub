Dialogue: 0,0:00:43.56,0:00:46.23,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:02:39.76,0:02:42.77,sign,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN - STAR MAP
Dialogue: 0,0:03:21.43,0:03:25.18,sign,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN - BLACK HOLE
Dialogue: 0,0:04:46.60,0:04:49.85,sign,,0000,0000,0000,,DAUR ULANG ARASHIYAMA
Dialogue: 0,0:09:49.86,0:09:51.11,sign,,0000,0000,0000,,TOXIN DOBEL: TARIAN KAKI X CIPTA LEMBING
Dialogue: 0,0:10:11.92,0:10:13.68,sign,,0000,0000,0000,,LABORATORIUM BIOTEKNOLOGI DOGO
Dialogue: 0,0:10:55.59,0:10:58.68,sign,,0000,0000,0000,,TOXIN: TRIPEL
Dialogue: 0,0:12:12.74,0:12:14.29,sign,,0000,0000,0000,,DARI SALURAN AIR SAMPAI PEMBUNUHAN
Dialogue: 0,0:12:14.29,0:12:15.71,sign,,0000,0000,0000,,PENGGUNA AIR: USHIO SHIZUKU
Dialogue: 0,0:12:20.97,0:12:23.01,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:12:23.01,0:12:25.02,sign,,0000,0000,0000,,TIDAK BERGUNA
Dialogue: 0,0:19:59.34,0:20:03.93,sign,,0000,0000,0000,,GERO
Dialogue: 0,0:21:44.03,0:21:46.20,sign,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN\NJARINGAN HAMSTER DAN TIKUS
Dialogue: 0,0:23:53.20,0:23:55.96,sign,,0000,0000,0000,,PERSEMBAHAN
Dialogue: 0,0:00:12.53,0:00:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.91,0:00:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:00:17.50,0:00:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.71,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:25.63,0:00:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.51,0:00:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:02:07.36,0:02:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Hamster.
Dialogue: 0,0:02:09.53,0:02:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo hajar Pengguna Binatang\Nbersama-sama!
Dialogue: 0,0:02:15.07,0:02:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersama?
Dialogue: 0,0:02:16.45,0:02:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:02:17.66,0:02:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama, tolong pinjamkan kekuatanmu.
Dialogue: 0,0:02:22.21,0:02:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, harus kutunjukkan kemampuanku.
Dialogue: 0,0:02:27.46,0:02:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para hamster!
Dialogue: 0,0:02:31.09,0:02:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan.
Dialogue: 0,0:02:34.01,0:02:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Star Map!
Dialogue: 0,0:02:42.77,0:02:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peta dari pulau ini.
Dialogue: 0,0:02:44.73,0:02:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubuat dengan meminta para hamster\Nberpencar memeriksanya.
Dialogue: 0,0:02:48.31,0:02:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jujur ini sangat membantu.
Dialogue: 0,0:02:51.40,0:02:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bisa ke tempat Pengguna Binatang\Ntanpa tersesat.
Dialogue: 0,0:02:56.28,0:02:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuanku saat serius\Nbukan cuma begini, lo!
Dialogue: 0,0:02:59.24,0:03:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahagialah, Gero Hikaru!
Dialogue: 0,0:03:00.95,0:03:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, secara khusus...
Dialogue: 0,0:03:02.75,0:03:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kujamu dirimu dengan\Nmasakan spesial buatanku!
Dialogue: 0,0:03:06.92,0:03:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak perlu.
Dialogue: 0,0:03:08.50,0:03:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa makan masakan ora—
Dialogue: 0,0:03:10.25,0:03:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para hamster, persembahkan\Nbuah-buah yang bisa dimakan!
Dialogue: 0,0:03:15.59,0:03:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, hei!
Dialogue: 0,0:03:17.26,0:03:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan,
Dialogue: 0,0:03:21.43,0:03:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Black Hole!
Dialogue: 0,0:03:23.31,0:03:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa?
Dialogue: 0,0:03:32.69,0:03:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jadi!
Dialogue: 0,0:03:34.11,0:03:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Resep rahasia keluarga Arashiyama,\NApa Saja Dibubur!
Dialogue: 0,0:03:39.07,0:03:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei, tunggu dulu—
Dialogue: 0,0:03:41.91,0:03:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, makan saja!
Dialogue: 0,0:03:43.54,0:03:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak makan, nanti mati, lo.
Dialogue: 0,0:03:57.47,0:03:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hikaru.
Dialogue: 0,0:03:59.97,0:04:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segala sesuatu yang disuguhkan orang lain\Nadalah racun.
Dialogue: 0,0:04:03.56,0:04:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan turunkan kewaspadaan Anda.
Dialogue: 0,0:04:06.35,0:04:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelengahan sekecil apa pun,\Nbisa berakibat kematian.
Dialogue: 0,0:04:11.27,0:04:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ge-Gero Hikaru, kamu tidak apa-apa?
Dialogue: 0,0:04:26.66,0:04:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama.
Dialogue: 0,0:04:29.00,0:04:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak.
Dialogue: 0,0:04:32.54,0:04:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:04:33.63,0:04:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah pikirkan kebersihannya.
Dialogue: 0,0:04:35.51,0:04:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah sakit perut gara-gara ini!
Dialogue: 0,0:04:41.93,0:04:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku yang menghilang.
Dialogue: 0,0:04:49.85,0:04:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sering membuatkan ini saat tidak ada uang.
Dialogue: 0,0:04:55.44,0:04:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu cara masak yang khusus?
Dialogue: 0,0:04:58.03,0:05:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Biasa saja, kok.
Dialogue: 0,0:05:00.36,0:05:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau harus bilang.
Dialogue: 0,0:05:03.20,0:05:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubuat dengan memikirkanmu sepenuh hati.
Dialogue: 0,0:05:07.95,0:05:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buah penuh nutrisi kuberi bumbu\Nyang ramah untuk tubuh terluka.
Dialogue: 0,0:05:13.08,0:05:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu direbus hingga mudah disantap.
Dialogue: 0,0:05:16.00,0:05:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja!
Dialogue: 0,0:05:19.63,0:05:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Arashiyama.
Dialogue: 0,0:05:21.97,0:05:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kalinya aku makan\Nmasakan selezat ini.
Dialogue: 0,0:05:26.72,0:05:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, kacamatamu itu\Nmirip dengan punyaku, ya.
Dialogue: 0,0:05:29.85,0:05:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:30.69,0:05:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cu-Cu-Cuma kebetulan!
Dialogue: 0,0:05:50.16,0:05:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria yang baik hati rupanya.
Dialogue: 0,0:05:52.87,0:05:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau melawan seorang diri segala.
Dialogue: 0,0:05:56.00,0:06:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami Aliansi Brutal para Pengguna Koala.
Dialogue: 0,0:06:02.17,0:06:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berisik.
Dialogue: 0,0:06:04.59,0:06:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang kelelahan karena harus\Nbersikap berbeda dari biasanya.
Dialogue: 0,0:06:07.85,0:06:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membiarkannya istirahat.
Dialogue: 0,0:06:11.35,0:06:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai sekali kelihatannya.
Dialogue: 0,0:06:13.94,0:06:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kamu\Nmencemaskan diri sendiri saja?
Dialogue: 0,0:06:16.86,0:06:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hadapan kekuatan yang diberikan\NTuan Pengguna Binatang,
Dialogue: 0,0:06:20.99,0:06:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang berlututlah—
Dialogue: 0,0:06:31.29,0:06:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya diam juga.
Dialogue: 0,0:06:33.87,0:06:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara bisa tenang.
Dialogue: 0,0:06:38.13,0:06:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama!
Dialogue: 0,0:06:47.18,0:06:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoek, jijik.
Dialogue: 0,0:06:51.60,0:06:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berharap karena\Nmelihatmu makan dengan lahap.
Dialogue: 0,0:06:55.69,0:06:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata sampah.
Dialogue: 0,0:06:57.23,0:07:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang nanti harus kumur-kumur\Nsampai bersih.
Dialogue: 0,0:07:00.11,0:07:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu apakan Arashiyama?
Dialogue: 0,0:07:02.23,0:07:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sadar jadi kutonton terus.
Dialogue: 0,0:07:04.32,0:07:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Drama percintaan nyata.
Dialogue: 0,0:07:06.53,0:07:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Plot campur tangan yang tidak-tidak\Nsetelah hubungan mulai menghangat.
Dialogue: 0,0:07:12.08,0:07:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situ bagusnya.
Dialogue: 0,0:07:15.33,0:07:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kubunuh.
Dialogue: 0,0:07:17.71,0:07:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:07:20.34,0:07:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, kacamata si wanita hamster.
Dialogue: 0,0:07:23.21,0:07:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata sama dengan punya Gero.
Dialogue: 0,0:07:25.30,0:07:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jijik banget!
Dialogue: 0,0:07:26.63,0:07:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peliharaanku sudah serendah ini rupanya.
Dialogue: 0,0:07:31.14,0:07:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bohong!
Dialogue: 0,0:07:34.14,0:07:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf.\NAku bercanda.
Dialogue: 0,0:07:36.48,0:07:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum kubunuh, kok.\NUntuk sekarang.
Dialogue: 0,0:07:40.11,0:07:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini...
Dialogue: 0,0:07:41.19,0:07:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin dapat lebih, lebih,\Nlebih banyak lagi, Gero Hikaru!
Dialogue: 0,0:07:46.28,0:07:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darahmu yang mendidih oleh amarah!
Dialogue: 0,0:07:49.62,0:07:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pecahan terakhir untuk menyelesaikan\NDarah Campuran yang sempurna!
Dialogue: 0,0:07:54.37,0:07:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin Mutasi Keturunan keluarga Gero\Nmendekati kematian,
Dialogue: 0,0:07:57.54,0:08:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan bisa menetralkan reaksi penolakan\Nyang gawat sekalipun.
Dialogue: 0,0:08:00.88,0:08:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menggabungkan darah-darah\Nyang harusnya tidak bisa bercampur tanpa risiko!
Dialogue: 0,0:08:06.26,0:08:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah yang diambil si Burung Sialan\Nitu masih kurang.
Dialogue: 0,0:08:09.26,0:08:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya...
Dialogue: 0,0:08:11.14,0:08:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pertaruhkan nyawamu, Gero!
Dialogue: 0,0:08:14.60,0:08:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang serius, dong!
Dialogue: 0,0:08:16.52,0:08:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kandidat istrimu diculik!
Dialogue: 0,0:08:19.31,0:08:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hampir dibunuh!\NPaham tidak?
Dialogue: 0,0:08:27.82,0:08:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NSudah serius sekarang?
Dialogue: 0,0:08:31.74,0:08:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero?
Dialogue: 0,0:08:32.83,0:08:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, dengar tidak?
Dialogue: 0,0:08:35.33,0:08:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero.
Dialogue: 0,0:08:37.69,0:08:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga, nafsu membunuh\Nyang seratus persen murni membakar dada.
Dialogue: 0,0:08:43.25,0:08:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah bisa dipancing seperti itu.
Dialogue: 0,0:08:47.30,0:08:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tidak sia-sia\Nmendatangimu, Gero.
Dialogue: 0,0:08:51.30,0:08:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bergegas,\Nwanita hamster itu akan kubunuh.
Dialogue: 0,0:08:54.81,0:08:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius.
Dialogue: 0,0:09:12.87,0:09:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua, sama sepertiku.
Dialogue: 0,0:09:16.37,0:09:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerabat dari Pengguna Binatang.
Dialogue: 0,0:09:19.79,0:09:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasus orang hilang misterius\Nyang sering dibicarakan perkumpulan.
Dialogue: 0,0:09:23.79,0:09:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini penyebabnya.
Dialogue: 0,0:09:40.64,0:09:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sirius, aku mengandalkanmu.
Dialogue: 0,0:09:45.86,0:09:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin: Dobel.
Dialogue: 0,0:09:52.61,0:09:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, itu! Itu dia!
Dialogue: 0,0:09:54.66,0:09:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang kuinginkan!
Dialogue: 0,0:09:56.99,0:09:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,
Dialogue: 0,0:09:58.79,0:10:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu adalah genius papan atas di antara\Npengguna dari generasi yang sama.
Dialogue: 0,0:10:04.04,0:10:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Darah Campuran yang kuracik\Nsepenuh hati pun,
Dialogue: 0,0:10:07.29,0:10:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak lebih dari sampah di hadapanmu.
Dialogue: 0,0:10:11.92,0:10:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ya.
Dialogue: 0,0:10:15.39,0:10:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau ada seratus?
Dialogue: 0,0:10:20.14,0:10:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang genius melawan seratus orang sampah.
Dialogue: 0,0:10:24.40,0:10:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah bukan soal kemampuan lagi.
Dialogue: 0,0:10:28.48,0:10:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:10:37.07,0:10:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:10:42.12,0:10:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal sedikit lagi!
Dialogue: 0,0:10:44.12,0:10:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gugur di tempat seperti ini!
Dialogue: 0,0:10:53.92,0:10:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus pakai Tripel...
Dialogue: 0,0:10:55.59,0:10:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi kemungkinan aku bakal langsung mati!
Dialogue: 0,0:11:00.89,0:11:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hikaru.
Dialogue: 0,0:11:02.81,0:11:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ceroboh melakukan sesuatu\Ndi luar kemampuan Anda.
Dialogue: 0,0:11:06.77,0:11:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Anda berkapasitas sebagai\Nkepala selanjutnya Pengguna Racun,
Dialogue: 0,0:11:09.98,0:11:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetap akan mati kalau overdosis.
Dialogue: 0,0:11:12.28,0:11:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beradaptasi dengan racun itu\Nharus secara perlahan.
Dialogue: 0,0:11:16.78,0:11:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai calon kepala keluarga berikutnya.
Dialogue: 0,0:11:18.99,0:11:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda tidak boleh mati sebelum mencapai\Nesensi dari Pengguna Racun.
Dialogue: 0,0:11:24.04,0:11:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang harus Anda tuju adalah puncak.
Dialogue: 0,0:11:27.46,0:11:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan pembunuh mutlak,\Nyang tidak dapat dinetralkan.
Dialogue: 0,0:11:32.05,0:11:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero dari Lima Keluarga Besar\Nternyata cuma begini.
Dialogue: 0,0:11:35.93,0:11:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski diperkuat darah campuran,
Dialogue: 0,0:11:38.34,0:11:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tetap keroco\Nyang tidak layak disebut pengguna.
Dialogue: 0,0:11:41.72,0:11:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia sudah tidak berkutik.
Dialogue: 0,0:12:00.82,0:12:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda masih saja melakukan\Npekerjaan murahan, ya.
Dialogue: 0,0:12:06.54,0:12:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Pengguna Binatang,\Napa Anda lihat?
Dialogue: 0,0:12:09.58,0:12:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada mempekerjakan\Nseratus orang seperti mereka.
Dialogue: 0,0:12:12.74,0:12:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memakai layanan saya.
Dialogue: 0,0:12:14.29,0:12:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memakai layanan saya,
Dialogue: 0,0:12:15.71,0:12:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biayanya akan jauh lebih efektif, lo.
Dialogue: 0,0:12:18.72,0:12:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah begitu, Tuan Gero?
Dialogue: 0,0:12:26.48,0:12:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak bermaksud\Nmengakrabkan diri dengan Anda.
Dialogue: 0,0:12:29.85,0:12:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya hanya menerima permintaan\Ndari si Penipu Pernikahan itu.
Dialogue: 0,0:12:33.40,0:12:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang menyewa jasanya!
Dialogue: 0,0:12:35.53,0:12:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya berprinsip\Nuntuk tidak membuat utang bisnis.
Dialogue: 0,0:12:39.91,0:12:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Air, kamu...
Dialogue: 0,0:12:42.32,0:12:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling Anda menerima\Npekerjaan murahan lagi, kan?
Dialogue: 0,0:12:45.87,0:12:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Per hari 10 ribu yen.
Dialogue: 0,0:12:47.08,0:12:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh ribu?
Dialogue: 0,0:12:48.21,0:12:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham tidak kalau Anda itu\Nsalah satu pemimpin bisnis?
Dialogue: 0,0:12:50.87,0:12:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap Anda itu bisa merusak harga pasar!
Dialogue: 0,0:12:57.42,0:12:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:12:59.43,0:13:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efektivitas biaya kali ini\Nbenar-benar parah.
Dialogue: 0,0:13:05.89,0:13:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat melenyapkan Pengguna Binatang\Ndemi pelanggan kafe di masa depan,
Dialogue: 0,0:13:11.69,0:13:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kenapa kalian berjuang mati-matian\Ndemi gadis itu?
Dialogue: 0,0:13:17.53,0:13:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada disebut untuk aku...
Dialogue: 0,0:13:20.03,0:13:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi demi pencarian jodoh Gero.
Dialogue: 0,0:13:22.36,0:13:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan menolong permintaan\Norang yang sedang kesusahan,
Dialogue: 0,0:13:25.58,0:13:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin akan ada pertemuan\Nyang terbaik untuk dirinya.
Dialogue: 0,0:13:30.12,0:13:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tujuannya cari jodoh,\Nbukankah ada cara yang lebih pas?
Dialogue: 0,0:13:35.38,0:13:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat acara cari jodoh atau aplikasi.
Dialogue: 0,0:13:38.63,0:13:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu sampai bertaruh nyawa?
Dialogue: 0,0:13:41.13,0:13:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar banget.
Dialogue: 0,0:13:43.22,0:13:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memikirkan soal efisiensi,\Nini jelas memutar jauh.
Dialogue: 0,0:13:47.26,0:13:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagi Gero ini adalah cara terbaik.
Dialogue: 0,0:13:51.52,0:13:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menolong gadis dari situasi genting\Nuntuk membuatnya jatuh cinta!
Dialogue: 0,0:13:54.94,0:13:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuberi nama, "Operasi Pangeran"!
Dialogue: 0,0:13:58.57,0:14:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ekspresinya ragu seakan,\N"Orang sepertiku menolong orang lain?"
Dialogue: 0,0:14:02.45,0:14:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dicoba,\Nternyata jauh melampaui ekspektasiku.
Dialogue: 0,0:14:08.35,0:14:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma dugaanku, tapi mungkin\Ndia sudah lama mendambakan itu.
Dialogue: 0,0:14:14.17,0:14:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin membuat pemandangan seperti ini\Ndengan kekuatannya sendiri.
Dialogue: 0,0:14:18.96,0:14:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, itu sekadar dugaanku, sih.
Dialogue: 0,0:14:22.93,0:14:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku yakin Operasi Pangeran\Nadalah yang terbaik untuk Gero.
Dialogue: 0,0:14:28.31,0:14:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi pernikahan yang terbaik,\Nproses cari jodohnya juga harus terbaik.
Dialogue: 0,0:14:34.35,0:14:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penipu pernikahan yang sudah paham\Npria dan wanita luar dalam memang hebat.
Dialogue: 0,0:14:40.48,0:14:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami para pengguna kungkang,\NKumpulan Enam Kungkang Jari Tiga.
Dialogue: 0,0:14:44.20,0:14:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa Gero akan baik-baik saja?
Dialogue: 0,0:14:47.41,0:14:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:48.45,0:14:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemburu Pembunuh Bayaran,\Njadilah mangsa cakar kami!
Dialogue: 0,0:14:52.96,0:14:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa sekarang pasti sedang\Ndiserang oleh para pengguna.
Dialogue: 0,0:14:57.08,0:15:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya juga tidak ahli\Npertarungan jarak dekat.
Dialogue: 0,0:15:00.05,0:15:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mati sebelum berhasil cari jodoh,\Nbukankah akan sia-sia saja?
Dialogue: 0,0:15:04.59,0:15:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, aku sudah memanggil bantuan\Nmengira akan ada hal seperti ini.
Dialogue: 0,0:15:15.81,0:15:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, sepertinya terlalu meremehkan mereka.
Dialogue: 0,0:15:18.86,0:15:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal mereka semua cuma keroco!
Dialogue: 0,0:15:23.69,0:15:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naluri pertarungan jarak dekatnya\Ndi luar nalar!
Dialogue: 0,0:15:27.66,0:15:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasokan air tanahnya bisa habis duluan!
Dialogue: 0,0:15:30.66,0:15:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertarung sambil menghemat air\Nitu ada batasnya.
Dialogue: 0,0:15:34.04,0:15:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Air.
Dialogue: 0,0:15:35.54,0:15:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pinjamkan kekuatanmu.
Dialogue: 0,0:15:37.12,0:15:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak punya keharusan\Nmenuruti perintah Anda.
Dialogue: 0,0:15:39.79,0:15:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membutuhkan kekuatanmu!
Dialogue: 0,0:15:48.76,0:15:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:15:49.39,0:15:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gas beracun!
Dialogue: 0,0:15:50.64,0:15:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya mundur!
Dialogue: 0,0:15:52.85,0:15:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai kehilangan target!
Dialogue: 0,0:15:55.10,0:15:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal jaga jarak, tidak perlu takut!
Dialogue: 0,0:15:57.35,0:16:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gasnya pasti akan hilang\Nsetelah beberapa waktu!
Dialogue: 0,0:16:01.48,0:16:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah diprediksi Pengguna Racun\Nakan menyerang balik seperti ini.
Dialogue: 0,0:16:11.33,0:16:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gas beracun langsung masuk\Nke hidung dan mulut?
Dialogue: 0,0:16:38.10,0:16:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Gero.
Dialogue: 0,0:16:40.10,0:16:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya memang pengguna air.
Dialogue: 0,0:16:42.81,0:16:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabut juga salah satu alat saya.
Dialogue: 0,0:16:44.94,0:16:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi harus mencampur dengan gas beracun\Ndan mengontrolnya itu sudah gila.
Dialogue: 0,0:16:48.61,0:16:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan diulangi lagi.
Dialogue: 0,0:16:50.99,0:16:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rapat persiapan adalah\Naturan wajib dalam bisnis.
Dialogue: 0,0:16:55.04,0:16:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:16:56.58,0:16:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu adalah uang.
Dialogue: 0,0:16:58.29,0:17:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo segera beranjak.
Dialogue: 0,0:17:02.42,0:17:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Pengguna Air.
Dialogue: 0,0:17:04.38,0:17:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:17:06.33,0:17:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertolong karena kedatanganmu.
Dialogue: 0,0:17:10.33,0:17:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta bantuan gadis yang sangat kuat\Ndan bisa diandalkan dalam bekerja.
Dialogue: 0,0:17:15.31,0:17:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa sekarang sudah gabung sama dia.
Dialogue: 0,0:17:18.02,0:17:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ada Arashiyama juga,\Napa tidak akan ribut?
Dialogue: 0,0:17:22.90,0:17:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jernihkan hati.
Dialogue: 0,0:17:25.44,0:17:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa keluar hidup-hidup dari sini.
Dialogue: 0,0:17:27.65,0:17:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang harapan seperti itu.
Dialogue: 0,0:17:29.78,0:17:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah satu-satunya cara\Nuntuk mati tenang di sini.
Dialogue: 0,0:17:33.62,0:17:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Subjek percobaan yang baru saja\Ndimasukkan kurungan di depan mataku,
Dialogue: 0,0:17:39.83,0:17:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nyala kehidupannya sudah hampir padam.
Dialogue: 0,0:17:42.75,0:17:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal tetap diam tidak melawan,\Npenderitaan yang lebih parah bisa dihindari.
Dialogue: 0,0:17:47.88,0:17:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jenirkanlah hatimu.
Dialogue: 0,0:17:50.34,0:17:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahankan akal sehat\Ndan mati sebagai manusia
Dialogue: 0,0:17:53.55,0:17:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kehilangan akal dan mati\Nsebagai binatang.
Dialogue: 0,0:17:57.39,0:18:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu jatuh kemari,\Nhanya itu kebebasan yang tersisa.
Dialogue: 0,0:18:02.39,0:18:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawa wanita ini paling lama\Ntinggal tiga hari lagi.
Dialogue: 0,0:18:06.27,0:18:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal beberapa jam lagi, aku akan...
Dialogue: 0,0:18:11.11,0:18:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah mengirim wanita\Ndan anak-anak untuk menyusup...
Dialogue: 0,0:18:14.03,0:18:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada saja orang dewasa yang kejam\Ndi dunia ini.
Dialogue: 0,0:18:23.25,0:18:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis tikus yang suka berkeliaran\Ndan mengganggu pemandangan.
Dialogue: 0,0:18:29.00,0:18:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek candu obat ini sangat kuat.
Dialogue: 0,0:18:31.17,0:18:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan bisa sekalian membersihkan\Norgan dalam dari kotoran!
Dialogue: 0,0:18:35.14,0:18:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat Cuci dan Gosok Organ!
Dialogue: 0,0:18:38.35,0:18:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuambil organ dalammu.
Dialogue: 0,0:18:43.81,0:18:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kakakku menghilang,
Dialogue: 0,0:18:46.56,0:18:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa menolak pekerjaan ini.
Dialogue: 0,0:18:49.82,0:18:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ternyata memang mustahil buatku!
Dialogue: 0,0:18:52.82,0:18:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau mati seperti ini!
Dialogue: 0,0:18:55.66,0:18:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kutolak saja\Nmeski orang-orang perkumpulan memaksa.
Dialogue: 0,0:18:59.79,0:19:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, sejak awal...
Dialogue: 0,0:19:01.16,0:19:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah berharap lahir\Ndi keluarga pengguna...
Dialogue: 0,0:19:11.05,0:19:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa tahu tempat ini?
Dialogue: 0,0:19:18.10,0:19:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat kalau sudah ketahuan!
Dialogue: 0,0:19:23.85,0:19:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh dia!
Dialogue: 0,0:19:36.99,0:19:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih!
Dialogue: 0,0:19:37.95,0:19:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pihak berwenang...
Dialogue: 0,0:19:39.70,0:19:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai mempekerjakan Lima Keluarga Besar?
Dialogue: 0,0:19:42.33,0:19:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekanak-kanakan sekali!
Dialogue: 0,0:19:45.08,0:19:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aduh...
Dialogue: 0,0:19:51.59,0:19:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu, terima ka—
Dialogue: 0,0:19:54.05,0:19:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mengerjakan tugas.
Dialogue: 0,0:19:59.34,0:20:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke, ke, ke-keren!
Dialogue: 0,0:20:04.47,0:20:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada saat itu aku bersumpah.
Dialogue: 0,0:20:06.73,0:20:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk selamanya mengidolakan pangeran\Nyang menyelamatkanku di saat genting.
Dialogue: 0,0:20:11.48,0:20:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:20:13.57,0:20:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sebenarnya aku sudah sadar.
Dialogue: 0,0:20:17.03,0:20:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati Gero Hikaru kala itu begitu kacau
Dialogue: 0,0:20:20.74,0:20:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku hanya orang berengsek\Nyang mengartikan dirinya seenak hati.
Dialogue: 0,0:20:25.41,0:20:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang ingin melakukannya.
Dialogue: 0,0:20:27.71,0:20:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia mengulurkan tangan lagi.
Dialogue: 0,0:20:31.04,0:20:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan karena disuruh seperti dulu.
Dialogue: 0,0:20:34.96,0:20:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dengan keinginannya sendiri.
Dialogue: 0,0:20:37.59,0:20:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kini jadi lebih menawan.
Dialogue: 0,0:20:41.30,0:20:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tetap tidak berguna!
Dialogue: 0,0:20:44.97,0:20:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Hamster,
Dialogue: 0,0:20:46.81,0:20:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo hajar Pengguna Binatang\Nbersama-sama!
Dialogue: 0,0:20:50.06,0:20:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku harus menjawab dengan benar!
Dialogue: 0,0:20:56.86,0:21:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mempertaruhkan segalanya\Ntermasuk keberadaanku!
Dialogue: 0,0:21:23.05,0:21:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para hamster dan tikus yang sudah\Nkusebar di tiap kurungan.
Dialogue: 0,0:21:27.14,0:21:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita mulai.
Dialogue: 0,0:21:39.15,0:21:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan!
Dialogue: 0,0:21:41.70,0:21:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaringan Hamster dan Tikus!
Dialogue: 0,0:21:46.20,0:21:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal!
Dialogue: 0,0:21:49.08,0:21:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya pengguna hamster,\NArashiyama Kimie!
Dialogue: 0,0:21:53.67,0:21:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, mau tidak kalau kita\Nhancurkan tempat ini?
Dialogue: 0,0:23:30.68,0:23:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Campur, campur, campur darahnya.
Dialogue: 0,0:23:37.73,0:23:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya pesta kita akan dimulai.
Dialogue: 0,0:23:43.19,0:23:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakko.
Dialogue: 0,0:23:46.03,0:23:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maaf membuatmu menunggu, Kinosaki!\N- Kenapa?
Dialogue: 0,0:23:47.96,0:23:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Penipu pernikahan biasa yang ada di mana-mana.\N- Kenapa tidak kamu habisi?
Dialogue: 0,0:23:50.20,0:23:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kayaknya bisa jual menu buruan di kafe.\N- Aku pengin menikah.
Dialogue: 0,0:23:51.16,0:23:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kayaknya bisa jual menu buruan di kafe.\N- Memang tidak seberapa.
Dialogue: 0,0:23:53.20,0:23:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Persembahan.
