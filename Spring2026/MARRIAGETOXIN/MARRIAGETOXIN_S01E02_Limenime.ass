Dialogue: 0,0:23:53.20,0:23:55.96,5-normal,,0,0,0,,{\pos(960,785)\fs80\b1\bord0\c&H000000&}Pasangan Pertama
Dialogue: 0,0:00:12.87,0:00:15.91,Default,,0,0,0,,Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.91,0:00:17.70,Default,,0,0,0,,para "Pengguna".
Dialogue: 0,0:00:17.70,0:00:20.79,Default,,0,0,0,,Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.79,0:00:25.53,Default,,0,0,0,,mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:26.09,0:00:31.55,Default,,0,0,0,,Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.55,0:00:34.60,Default,,0,0,0,,untuk mencari jodoh.
Dialogue: 0,0:02:07.41,0:02:09.11,Default,,0,0,0,,Gero, Gero.
Dialogue: 0,0:02:09.11,0:02:13.03,Default,,0,0,0,,Besok siang kita ketemuan\Ndi Kapal Galeri Seni Avocado, ya.
Dialogue: 0,0:02:13.03,0:02:14.33,Default,,0,0,0,,Kapal Galeri Seni?
Dialogue: 0,0:02:14.33,0:02:16.53,Default,,0,0,0,,Bukannya mau mencari daya tarikku?
Dialogue: 0,0:02:16.53,0:02:18.15,Default,,0,0,0,,Sudahlah, datang saja!
Dialogue: 0,0:02:21.29,0:02:22.83,Default,,0,0,0,,Kinosaki telat.
Dialogue: 0,0:02:22.83,0:02:24.83,Default,,0,0,0,,Gero!
Dialogue: 0,0:02:24.83,0:02:26.58,Default,,0,0,0,,Maaf sudah menunggu!
Dialogue: 0,0:02:30.09,0:02:32.47,Default,,0,0,0,,Pas pilih baju malah terlambat.
Dialogue: 0,0:02:32.47,0:02:33.34,Default,,0,0,0,,Oke, ayo pergi.
Dialogue: 0,0:02:35.43,0:02:38.18,Default,,0,0,0,,La-Langsung main pegang itu tidak sopan!
Dialogue: 0,0:02:38.18,0:02:39.97,Default,,0,0,0,,Hah? Jahat!
Dialogue: 0,0:02:39.97,0:02:44.19,Default,,0,0,0,,Menggandeng tanganku itu biasanya\Nharus bayar ratusan ribu, lo!
Dialogue: 0,0:02:51.61,0:02:55.82,Default,,0,0,0,,Bagaimana, ya.\NIni yang disebut tempat kencan, kan?
Dialogue: 0,0:02:55.82,0:02:57.20,Default,,0,0,0,,Kenapa malah ke sini?
Dialogue: 0,0:02:57.20,0:03:01.29,Default,,0,0,0,,Hari ini adalah kencan pertamamu.\NAnggap saja latihan praktik.
Dialogue: 0,0:03:01.29,0:03:02.04,Default,,0,0,0,,Ha?
Dialogue: 0,0:03:02.04,0:03:06.08,Default,,0,0,0,,Gero, meski sudah dapat kontak\Ndan berhasil mengajak kencan.
Dialogue: 0,0:03:06.08,0:03:08.54,Default,,0,0,0,,Dirimu yang sekarang\Npasti panik terus bubar, kan?
Dialogue: 0,0:03:08.54,0:03:10.76,Default,,0,0,0,,Kalau bikin antisipasi dulu,\Nnanti bisa tenang.
Dialogue: 0,0:03:12.02,0:03:14.05,Default Above,,0,0,0,,Anjing ini imut banget!
Dialogue: 0,0:03:15.86,0:03:17.92,Default,,0,0,0,,Kasih reaksi apa, kek.
Dialogue: 0,0:03:18.93,0:03:20.81,Default,,0,0,0,,Warna biru ini juga indah.
Dialogue: 0,0:03:20.81,0:03:22.60,Default,,0,0,0,,Hm... Ah...
Dialogue: 0,0:03:22.60,0:03:23.47,Default,,0,0,0,,Apa, ya...
Dialogue: 0,0:03:23.47,0:03:26.23,Default,,0,0,0,,Biru, biru berarti langit.
Dialogue: 0,0:03:26.23,0:03:28.15,Default,,0,0,0,,Kamu ini terlalu tegang.
Dialogue: 0,0:03:28.15,0:03:29.94,Default,,0,0,0,,Minus sepuluh poin.
Dialogue: 0,0:03:29.94,0:03:32.61,Default,,0,0,0,,Wanita ini cantik banget enggak, sih?
Dialogue: 0,0:03:32.61,0:03:34.24,Default,,0,0,0,,Be-Benarkah?
Dialogue: 0,0:03:34.24,0:03:35.15,Default,,0,0,0,,Eh?
Dialogue: 0,0:03:35.15,0:03:37.74,Default,,0,0,0,,Ju-Justru kamu yang lebih cantik.
Dialogue: 0,0:03:37.74,0:03:39.57,Default,,0,0,0,,Itu jelas banget bohongnya.
Dialogue: 0,0:03:39.57,0:03:41.07,Default,,0,0,0,,Minus seratus poin.
Dialogue: 0,0:03:41.83,0:03:43.58,Default,,0,0,0,,Aku harus bagaimana?
Dialogue: 0,0:03:44.53,0:03:45.58,Default,,0,0,0,,Gero.
Dialogue: 0,0:03:45.98,0:03:48.21,Default,,0,0,0,,Tidak usah memaksakan diri terlihat keren.
Dialogue: 0,0:03:48.21,0:03:49.04,Default,,0,0,0,,Tapi...
Dialogue: 0,0:03:49.38,0:03:51.84,Default,,0,0,0,,Kencan itu sukses\Nkalau kedua pihak menikmatinya!
Dialogue: 0,0:03:54.30,0:03:56.72,Default,,0,0,0,,Andaikan bisa begitu,\Naku tidak akan kesulitan.
Dialogue: 0,0:03:56.72,0:03:59.01,Default,,0,0,0,,Makanya sekarang kita latih.
Dialogue: 0,0:03:59.63,0:04:02.56,Default,,0,0,0,,Seribu kali lebih berat\Ndibanding masa latihanku.
Dialogue: 0,0:04:05.81,0:04:07.52,Default,,0,0,0,,Bu-Bukankah ini?
Dialogue: 0,0:04:07.52,0:04:08.77,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:04:08.77,0:04:12.27,Default,,0,0,0,,Camilan mainan pertama\Nyang dijual di dunia 40 tahun lalu!
Dialogue: 0,0:04:12.27,0:04:13.73,Default,,0,0,0,,Campur Aduk Zero!
Dialogue: 0,0:04:13.73,0:04:15.23,Default,,0,0,0,,Estimasi harganya 30 juta!
Dialogue: 0,0:04:15.23,0:04:16.36,Default,,0,0,0,,Mahal amat!
Dialogue: 0,0:04:16.36,0:04:17.24,Default,,0,0,0,,Terlalu murah.
Dialogue: 0,0:04:17.24,0:04:19.07,Default,,0,0,0,,Aku saja berani bayar lima kalinya.
Dialogue: 0,0:04:19.07,0:04:20.91,Default,,0,0,0,,Cuma wadah sama bubuk, kan?
Dialogue: 0,0:04:20.91,0:04:21.53,Default,,0,0,0,,Tidak!
Dialogue: 0,0:04:21.53,0:04:23.37,Default,,0,0,0,,Bukan harganya secara materi.
Dialogue: 0,0:04:23.37,0:04:24.41,Default,,0,0,0,,Ini seperti monolit
Dialogue: 0,0:04:24.41,0:04:25.87,Default,,0,0,0,,- yang membawa kemajuan umat manusia—\N- Sudah, ayo lanjut.
Dialogue: 0,0:04:27.54,0:04:30.80,Default,,0,0,0,,Kamu betulan suka camilan mainan, ya.
Dialogue: 0,0:04:33.84,0:04:35.67,Default,,0,0,0,,Kali ini, ada apa lagi?
Dialogue: 0,0:04:35.67,0:04:36.44,Default,,0,0,0,,Hm?
Dialogue: 0,0:04:36.44,0:04:38.67,Default,,0,0,0,,Kalau dilihat seperti ini menarik, lo.
Dialogue: 0,0:04:38.67,0:04:40.01,Default,,0,0,0,,Eh?
Dialogue: 0,0:04:41.84,0:04:44.01,Default,,0,0,0,,Wah, benar!
Dialogue: 0,0:04:44.01,0:04:45.00,Default,,0,0,0,,Iya, kan?
Dialogue: 0,0:04:46.31,0:04:49.48,Default,,0,0,0,,Yah, mungkin bakal kukasih bonus 30 poin.
Dialogue: 0,0:04:49.48,0:04:50.52,Default,,0,0,0,,Pelitnya.
Dialogue: 0,0:04:50.98,0:04:53.53,Default,,0,0,0,,Mungkin perkembangannya\Nbaru dimulai sekarang.
Dialogue: 0,0:04:54.41,0:04:56.31,Default,,0,0,0,,Begini, Kinosaki.
Dialogue: 0,0:04:56.31,0:04:58.40,Default,,0,0,0,,Terima kasih latihan praktik kencannya.
Dialogue: 0,0:04:58.40,0:05:02.03,Default,,0,0,0,,Tapi buruan beri tahu, dong,\Napa sebenarnya daya tarikku.
Dialogue: 0,0:05:02.66,0:05:04.20,Default,,0,0,0,,Gero, Gero.
Dialogue: 0,0:05:06.10,0:05:08.58,Default,,0,0,0,,Menurutmu, paman di sana bagaimana?
Dialogue: 0,0:05:08.58,0:05:10.87,Default,,0,0,0,,Yah, kalau ditanya bagaimana...
Dialogue: 0,0:05:10.87,0:05:12.63,Default,,0,0,0,,- Hamster Djungarian.\N- Maaf!
Dialogue: 0,0:05:13.26,0:05:15.09,Default,,0,0,0,,Toiletnya antre panjang.
Dialogue: 0,0:05:15.09,0:05:16.55,Default,,0,0,0,,Mirkat.
Dialogue: 0,0:05:16.55,0:05:18.17,Default,,0,0,0,,Yang di sebelah itu istrinya.
Dialogue: 0,0:05:18.17,0:05:19.72,Default,,0,0,0,,Lalu, dia itu...
Dialogue: 0,0:05:19.72,0:05:21.93,Default,,0,0,0,,Suhu?
Dialogue: 0,0:05:21.93,0:05:24.05,Default,,0,0,0,,Suhu!
Dialogue: 0,0:05:24.51,0:05:28.06,Default,,0,0,0,,Seniman paling populer\Ndi kalangan anak muda sekarang.
Dialogue: 0,0:05:28.06,0:05:29.64,Default,,0,0,0,,Shiratori Takeru.
Dialogue: 0,0:05:29.64,0:05:32.14,Default,,0,0,0,,Meski penampilan dan sikapnya maniak,
Dialogue: 0,0:05:32.14,0:05:34.32,Default,,0,0,0,,nilainya sempurna di mata penggemar.
Dialogue: 0,0:05:34.32,0:05:37.11,Default,,0,0,0,,Karena dia punya bakat sebagai seniman.
Dialogue: 0,0:05:37.11,0:05:38.28,Default,,0,0,0,,Eh?
Dialogue: 0,0:05:38.61,0:05:40.32,Default,,0,0,0,,Kalau contoh lainnya...
Dialogue: 0,0:05:41.17,0:05:43.78,Default,,0,0,0,,Atlet yang mencetak prestasi di saat genting.
Dialogue: 0,0:05:43.78,0:05:45.16,Default,,0,0,0,,Kakak!
Dialogue: 0,0:05:45.16,0:05:47.74,Default,,0,0,0,,Dokter yang menyelamatkan keluarga tercinta.
Dialogue: 0,0:05:48.97,0:05:52.16,Default,,0,0,0,,Musisi yang menghancurkan keseharian\Nyang membosankan.
Dialogue: 0,0:05:52.59,0:05:55.63,Default,,0,0,0,,Merasakan daya tarik dari bakat mereka\Nlalu jadi suka.
Dialogue: 0,0:05:55.63,0:06:00.34,Default,,0,0,0,,Sama seperti suka dan jatuh cinta\Npada tampilan dan sifat orang terdekat.
Dialogue: 0,0:06:00.34,0:06:02.40,Default,,0,0,0,,Perasaan itu asli.
Dialogue: 0,0:06:02.90,0:06:06.33,Default,,0,0,0,,Oh, daya tarik yang seperti itu, ya.
Dialogue: 0,0:06:06.33,0:06:07.22,Default,,0,0,0,,Aku tidak ada hu—
Dialogue: 0,0:06:07.22,0:06:08.68,Default,,0,0,0,,Kamu sendiri.
Dialogue: 0,0:06:10.60,0:06:13.02,Default,,0,0,0,,Kinosaki, kamu tidak usah apa-apa.
Dialogue: 0,0:06:13.02,0:06:15.52,Default,,0,0,0,,Pejamkan matamu selama 30 detik.
Dialogue: 0,0:06:15.52,0:06:19.15,Default,,0,0,0,,Seorang diri mengalahkan banyak penjahat
Dialogue: 0,0:06:19.15,0:06:21.65,Default,,0,0,0,,dan menyelamatkan diriku yang diculik.
Dialogue: 0,0:06:23.22,0:06:26.17,Default,,0,0,0,,Tidak salah lagi, itulah daya tarikmu!
Dialogue: 0,0:06:26.57,0:06:29.08,Default,,0,0,0,,Jadi cara terbaik\Nagar kamu bersinar maksimal
Dialogue: 0,0:06:29.08,0:06:33.25,Default,,0,0,0,,melebihi acara cari jodoh\Natau aplikasi kencan adalah
Dialogue: 0,0:06:33.61,0:06:34.96,Default,,0,0,0,,menolong orang.
Dialogue: 0,0:06:36.37,0:06:41.05,Default,,0,0,0,,Dengan kata lain menyelamatkan sandera\Natau mengawal orang penting
Dialogue: 0,0:06:41.45,0:06:44.80,Default,,0,0,0,,untuk membuat pasanganmu merasa suka.
Dialogue: 0,0:06:44.80,0:06:46.76,Default,,0,0,0,,Kamu pasti bisa mengatasi kasus apa pun—
Dialogue: 0,0:06:46.76,0:06:48.14,Default,,0,0,0,,Tu-Tunggu sebentar.
Dialogue: 0,0:06:48.14,0:06:50.43,Default,,0,0,0,,Aku ini Pengguna Racun,\Npembunuh bayaran.
Dialogue: 0,0:06:50.43,0:06:52.83,Default,,0,0,0,,Menolong orang itu bukan hal tabu, kan?
Dialogue: 0,0:06:52.83,0:06:55.81,Default,,0,0,0,,Tapi, kalau seolah memanfaatkan\Nkelemahan seseorang begitu...
Dialogue: 0,0:06:57.05,0:07:01.28,Default,,0,0,0,,Sejujurnya, awal pertemuan itu\Nbagaimanapun bentuknya bukan masalah.
Dialogue: 0,0:07:01.28,0:07:03.65,Default,,0,0,0,,Suhu, ayo makan siang bersama kami!
Dialogue: 0,0:07:03.65,0:07:05.03,Default,,0,0,0,,- Mau ikut!\N- Mau ikut!
Dialogue: 0,0:07:05.03,0:07:09.33,Default,,0,0,0,,Mau ada niat tersembunyi atau tidak,\Nitu sekadar titik awal.
Dialogue: 0,0:07:09.33,0:07:12.03,Default,,0,0,0,,Yang sebenarnya akan diuji\Nadalah setelahnya.
Dialogue: 0,0:07:12.83,0:07:16.25,Default,,0,0,0,,Bisa menjalin hubungan bahagia\Nbersama pasangan atau tidak.
Dialogue: 0,0:07:16.25,0:07:17.00,Default,,0,0,0,,Suhu?
Dialogue: 0,0:07:17.00,0:07:17.63,Default,,0,0,0,,Eh?
Dialogue: 0,0:07:23.34,0:07:27.09,Default,,0,0,0,,Ah, Suhu!\NSaya juga mau tanda tangannya!
Dialogue: 0,0:07:27.09,0:07:27.97,Default,,0,0,0,,Hei!
Dialogue: 0,0:07:27.97,0:07:30.18,Default Above,,0,0,0,,Jangan-jangan, tujuanmu demi ini?
Dialogue: 0,0:07:35.48,0:07:37.81,Default,,0,0,0,,Pak Kepala, kemungkinan ini ulah Himekawa!
Dialogue: 0,0:07:38.60,0:07:40.23,Default,,0,0,0,,Wanita itu tidak bisa dimaafkan!
Dialogue: 0,0:07:40.23,0:07:44.28,Default,,0,0,0,,Dia pikir berapa kepala kolektor yang sudah\NKapten tundukkan sepenuh hati
Dialogue: 0,0:07:44.28,0:07:47.70,Default,,0,0,0,,untuk mengumpulkan karya-karya ini\Ndemi senyum pengunjung?
Dialogue: 0,0:07:47.70,0:07:49.41,Default,,0,0,0,,Jangan biarkan dia kabur!
Dialogue: 0,0:07:49.41,0:07:52.75,Default,,0,0,0,,Tembak semua bayangan mencurigakan\Nyang mendekat!
Dialogue: 0,0:07:52.75,0:07:54.45,Default,,0,0,0,,Tidak ada reaksi di radar!
Dialogue: 0,0:07:54.45,0:07:57.04,Default,,0,0,0,,Pasti masih sembunyi di dalam kapal!
Dialogue: 0,0:07:57.04,0:08:01.25,Default,,0,0,0,,"Bukankah Putriku Seperti Mentari?"\Nharus kita rebut kembali!
Dialogue: 0,0:08:02.34,0:08:06.47,Default,,0,0,0,,Kapten, "Bukankah Putriku Seperti Mentari?"\Ntelah dicuri.
Dialogue: 0,0:08:06.47,0:08:08.80,Default,,0,0,0,,Kecil itu.
Dialogue: 0,0:08:13.22,0:08:15.06,Default,,0,0,0,,Terima kasih, Sameshige.
Dialogue: 0,0:08:16.48,0:08:19.06,Default,,0,0,0,,Lain kali, ayo kencan di luar kerjaan.
Dialogue: 0,0:08:19.94,0:08:21.69,Default,,0,0,0,,- Hei!\N- Hei!
Dialogue: 0,0:08:21.69,0:08:23.77,Default,,0,0,0,,Maaf membuat kalian menunggu.
Dialogue: 0,0:08:40.70,0:08:43.79,Default,,0,0,0,,Menolong gadis di situasi genting\Nuntuk membuatnya jatuh cinta!
Dialogue: 0,0:08:43.79,0:08:46.42,Default,,0,0,0,,Kuberi nama, "Operasi Pangeran"!
Dialogue: 0,0:08:47.70,0:08:49.30,Default,,0,0,0,,Apa-apaan mukamu itu?
Dialogue: 0,0:08:49.30,0:08:52.21,Default,,0,0,0,,Tapi, aku jelas bukan tipe pangeran.
Dialogue: 0,0:08:52.99,0:08:55.01,Default,,0,0,0,,Kalau begitu anggap saja pangeran magang.
Dialogue: 0,0:08:55.77,0:08:58.68,Default,,0,0,0,,Kesampingkan soal penamaan\NOperasi Pangeran.
Dialogue: 0,0:08:58.68,0:09:02.56,Default,,0,0,0,,Yang jadi masalah, bagaimana caranya\Ndapat pekerjaan menolong orang?
Dialogue: 0,0:09:02.56,0:09:06.19,Default,,0,0,0,,Hap, nyam, nyam, nyam!
Dialogue: 0,0:09:06.19,0:09:07.40,Default,,0,0,0,,Ah, ya.
Dialogue: 0,0:09:07.40,0:09:11.20,Default,,0,0,0,,Aku yang salah mengajakmu bicara\Nsaat sedang makan.
Dialogue: 0,0:09:11.20,0:09:12.70,Default,,0,0,0,,Kerjaan Gelap?
Dialogue: 0,0:09:12.70,0:09:13.45,Default,,0,0,0,,Benar.
Dialogue: 0,0:09:13.90,0:09:16.70,Default,,0,0,0,,Membunuh, kurir barang, lain sebagainya.
Dialogue: 0,0:09:16.70,0:09:20.12,Default,,0,0,0,,Situs yang jadi perantara\Nmencari pekerjaan di dunia bawah.
Dialogue: 0,0:09:20.12,0:09:22.88,Default,,0,0,0,,Menolong sandera atau jadi pengawal.
Dialogue: 0,0:09:22.88,0:09:25.63,Default,,0,0,0,,Bakal ada banyak kalau dicari\Ndi Kerjaan Gelap.
Dialogue: 0,0:09:25.94,0:09:27.59,Default,,0,0,0,,Kamu belum pernah pakai?
Dialogue: 0,0:09:27.59,0:09:28.92,Default,,0,0,0,,Baru dengar sekarang.
Dialogue: 0,0:09:28.92,0:09:31.01,Default,,0,0,0,,Kami biasanya lewat agen.
Dialogue: 0,0:09:31.88,0:09:35.81,Default,,0,0,0,,Keluarga Gero yang punya sejarah\Ndan tradisi panjang memang beda.
Dialogue: 0,0:09:35.81,0:09:37.60,Default,,0,0,0,,Permisi, mau pesan apa?
Dialogue: 0,0:09:37.60,0:09:39.18,Default,,0,0,0,,Dia akan makan jatah dua orang.
Dialogue: 0,0:09:39.18,0:09:41.64,Default,,0,0,0,,Perut sapi bumbu tsubozuke lima porsi!
Dialogue: 0,0:09:46.65,0:09:49.32,Default,,0,0,0,,Sari dagingnya banjir sekali!
Dialogue: 0,0:09:49.32,0:09:52.07,Default,,0,0,0,,Isinya cuma jadi penerima uang\Nsama kurir barang.
Dialogue: 0,0:09:52.07,0:09:55.66,Default,,0,0,0,,Kalau kamu punya akun di sana,\Npasti bebas mau pilih apa.
Dialogue: 0,0:09:55.66,0:09:58.08,Default,,0,0,0,,Maaf kalau aku ini kuno.
Dialogue: 0,0:09:59.50,0:10:00.62,Default,,0,0,0,,Hei, Kinosaki.
Dialogue: 0,0:10:00.94,0:10:01.96,Default,,0,0,0,,Bagaimana dengan ini?
Dialogue: 0,0:10:01.96,0:10:02.76,Default,,0,0,0,,Hm?
Dialogue: 0,0:10:04.67,0:10:09.13,Default,,0,0,0,,Permintaan kami adalah karya seni\Nyang sedang kalian simpan.
Dialogue: 0,0:10:09.13,0:10:10.63,Default,,0,0,0,,Semuanya.
Dialogue: 0,0:10:10.63,0:10:14.34,Default,,0,0,0,,Lokasi pertukaran dengan Himekawa\Nakan dikabari lagi nanti.
Dialogue: 0,0:10:14.34,0:10:16.64,Default,,0,0,0,,Dia, Himekawa Kyoko.
Dialogue: 0,0:10:16.64,0:10:20.35,Default,,0,0,0,,Pencuri yang namanya diakui di dunia gelap.
Dialogue: 0,0:10:20.35,0:10:22.89,Default,,0,0,0,,Tetapi, sebenarnya dia merebut kembali
Dialogue: 0,0:10:22.89,0:10:25.81,Default,,0,0,0,,karya seni yang dirampas\Nkarena keadaan atau kolektor jahat
Dialogue: 0,0:10:25.81,0:10:28.44,Default,,0,0,0,,dan dikembalikan kepada pemilik aslinya!
Dialogue: 0,0:10:29.03,0:10:31.40,Default,,0,0,0,,Karya seni yang telah dipercayakan Himekawa,
Dialogue: 0,0:10:31.40,0:10:34.28,Default,,0,0,0,,tidak mungkin kami serahkan\Nsesuai permintaan mereka!
Dialogue: 0,0:10:34.76,0:10:39.37,Default,,0,0,0,,Kami ingin kalian menyusup\Nke markas mereka sebelum serah terima
Dialogue: 0,0:10:39.37,0:10:42.80,Default,,0,0,0,,dan menyelamatkan Himekawa!
Dialogue: 0,0:10:46.42,0:10:49.13,Default,,0,0,0,,Sudah kuduga bayarannya sangat kurang!
Dialogue: 0,0:10:49.13,0:10:51.67,Default,,0,0,0,,Bagi kita yang cuma hidup\Ndari kerja sambilan ini...
Dialogue: 0,0:10:51.67,0:10:53.63,Default,,0,0,0,,Biar kujual saja semua organ dalamku!
Dialogue: 0,0:10:53.63,0:10:55.68,Default,,0,0,0,,Kitami, tenang dulu!
Dialogue: 0,0:10:55.68,0:10:59.68,Default,,0,0,0,,Yah, tidak akan ada yang menerima misi\Ndengan bayaran sejelek ini.
Dialogue: 0,0:10:59.68,0:11:04.69,Default,,0,0,0,,Tapi ini kesempatan untuk Gero,\Nkarena tidak ada kandidat pangeran lain.
Dialogue: 0,0:11:04.69,0:11:06.06,Default,,0,0,0,,Tamat sudah kita!
Dialogue: 0,0:11:06.06,0:11:09.61,Default,,0,0,0,,Permisi, dia pengguna dari keluarga Gero.
Dialogue: 0,0:11:09.61,0:11:11.11,Default,,0,0,0,,Aku Gero Hikaru.
Dialogue: 0,0:11:11.11,0:11:14.57,Default,,0,0,0,,Aku datang untuk menyelamatkan bos kalian,\NHimekawa Kyoko.
Dialogue: 0,0:11:15.55,0:11:16.41,Default,,0,0,0,,Gero katanya?
Dialogue: 0,0:11:16.77,0:11:18.91,Default,,0,0,0,,Jangan bilang Pengguna Racun yang itu?
Dialogue: 0,0:11:18.91,0:11:21.49,Default,,0,0,0,,Ke-Kenapa seorang pengguna ada di sini?
Dialogue: 0,0:11:21.49,0:11:25.37,Default,,0,0,0,,Kalau lewat jalur resmi, organ dalamku\Nbisa habis cuma buat bayar perantara!
Dialogue: 0,0:11:25.82,0:11:28.08,Default,,0,0,0,,Tapi, kalau ada seorang pengguna!
Dialogue: 0,0:11:28.08,0:11:30.92,Default,,0,0,0,,Himekawa pasti bisa diselamatkan!
Dialogue: 0,0:11:31.88,0:11:35.03,Default,,0,0,0,,Menjatuhkan benteng utama,\Ndimulai dari parit luar dulu.
Dialogue: 0,0:11:38.21,0:11:42.22,Default,,0,0,0,,Hei, kalian semua, aku belum\Ntanya sesuatu yang penting.
Dialogue: 0,0:11:42.68,0:11:43.68,Default,,0,0,0,,A-Apa, ya?
Dialogue: 0,0:11:43.68,0:11:45.27,Default,,0,0,0,,Memang perlu organ dalam?
Dialogue: 0,0:11:46.69,0:11:48.48,Default,,0,0,0,,Himekawa sendiri
Dialogue: 0,0:11:48.82,0:11:50.84,Default,,0,0,0,,mau sama cowok berkacamata, kan?
Dialogue: 0,0:11:51.85,0:11:52.64,Default,,0,0,0,,Eh?
Dialogue: 0,0:12:01.89,0:12:06.83,Default,,0,0,0,,Tidak ada orang yang kuanggap\Nsecantik ini selain dirimu.
Dialogue: 0,0:12:07.16,0:12:10.08,Default,,0,0,0,,Akan kujamin hidup enak\Ndengan standar tinggi.
Dialogue: 0,0:12:10.08,0:12:13.00,Default,,0,0,0,,Angkatlah kaki dari hidup miskin\Nsebagai pencuri.
Dialogue: 0,0:12:14.87,0:12:17.55,Default,,0,0,0,,Mau, kan, buat jadi koleksiku?
Dialogue: 0,0:12:17.55,0:12:19.26,Default,,0,0,0,,Jelas tidak!
Dialogue: 0,0:12:20.55,0:12:24.31,Default,,0,0,0,,Aku mencuri atas prinsipku sendiri.
Dialogue: 0,0:12:24.67,0:12:25.98,Default,,0,0,0,,Mereka sedang menangis!
Dialogue: 0,0:12:26.57,0:12:29.76,Default,,0,0,0,,Para karya seni yang dirampas\Nsecara paksa dari pemiliknya.
Dialogue: 0,0:12:30.38,0:12:34.15,Default,,0,0,0,,Maestro gadis gaul berkulit gelap,\Nmendiang Egg Saturnia.
Dialogue: 0,0:12:34.15,0:12:39.49,Default,,0,0,0,,Yang dicuri adalah lukisan putrinya berjudul\N"Bukankah Putriku Seperti Mentari?"
Dialogue: 0,0:12:40.03,0:12:43.28,Default,,0,0,0,,Estimasi harganya mungkin sekitar 2 miliar.
Dialogue: 0,0:12:43.79,0:12:48.21,Default,,0,0,0,,Aku diberi tahu soal dirimu saat minta saran\Ndari penjual lukisan kenalan lama Pak Egg.
Dialogue: 0,0:12:48.62,0:12:50.08,Default,,0,0,0,,Kumohon!
Dialogue: 0,0:12:50.08,0:12:53.21,Default,,0,0,0,,Itu satu-satunya\Nlukisan istriku yang kumiliki!
Dialogue: 0,0:12:53.21,0:12:55.21,Default,,0,0,0,,Dan bagi anak ini...
Dialogue: 0,0:12:55.84,0:12:56.96,Default,,0,0,0,,Maaf saja.
Dialogue: 0,0:12:57.46,0:12:59.72,Default,,0,0,0,,Aku sudah berjanji ke anak itu.
Dialogue: 0,0:13:00.17,0:13:03.47,Default,,0,0,0,,Tenang saja, akan segera\Nkupertemukan dengan ibumu.
Dialogue: 0,0:13:05.26,0:13:08.23,Default,,0,0,0,,Kalau pasti akan kurebut kembali.
Dialogue: 0,0:13:08.23,0:13:11.98,Default,,0,0,0,,Makanya, kamu juga jangan menangis.
Dialogue: 0,0:13:16.77,0:13:18.40,Default,,0,0,0,,Ushio.
Dialogue: 0,0:13:18.40,0:13:22.11,Default,,0,0,0,,Bisa patahkan hatinya dengan baik?
Dialogue: 0,0:13:23.06,0:13:27.20,Default,,0,0,0,,Kamu ini, pertanyaanmu tadi\Nsebenarnya bahaya, lo.
Dialogue: 0,0:13:27.20,0:13:29.44,Default,,0,0,0,,Mereka semua jadi bingung, tuh.
Dialogue: 0,0:13:29.44,0:13:30.66,Default,,0,0,0,,Cowok berkacamata?
Dialogue: 0,0:13:30.66,0:13:32.21,Default,,0,0,0,,Mungkin itu kode rahasia?
Dialogue: 0,0:13:32.21,0:13:35.54,Default,,0,0,0,,Blakblakan punya niat tersembunyi\Nitu hal paling jauh dari pangeran.
Dialogue: 0,0:13:36.92,0:13:41.05,Default,,0,0,0,,Bagaimanapun juga, aku akan serius\Nkarena sudah terima pekerjaannya.
Dialogue: 0,0:13:43.15,0:13:47.19,Default,,0,0,0,,Tapi, tidak kusangka\Nakan kembali ke sini sama kamu.
Dialogue: 0,0:13:47.19,0:13:50.68,Default,,0,0,0,,Menurut GPS yang akurat bukan main\Npunya bawahan bernama Kitami,
Dialogue: 0,0:13:50.68,0:13:52.80,Default,,0,0,0,,seharusnya tinggal sedikit lagi.
Dialogue: 0,0:13:54.69,0:13:57.19,Default,,0,0,0,,- Tikus harus dibasmi, itu aturannya!\N- Tikus harus dibasmi, itu aturannya!
Dialogue: 0,0:14:10.81,0:14:13.92,Default,,0,0,0,,Kinosaki, selanjutnya harus ke mana?
Dialogue: 0,0:14:14.43,0:14:18.75,Default,,0,0,0,,Gero, sepertinya aku memang\Nlebih baik jaga rumah saja.
Dialogue: 0,0:14:19.30,0:14:21.30,Default,,0,0,0,,Aku membutuhkanmu.
Dialogue: 0,0:14:25.39,0:14:30.14,Default,,0,0,0,,Aku tidak tahu harus bagaimana\Nbicara sama perempuan yang baru kutemui.
Dialogue: 0,0:14:30.78,0:14:32.27,Default,,0,0,0,,Apa boleh buat.
Dialogue: 0,0:14:32.63,0:14:34.31,Default,,0,0,0,,Ayo rapat dulu sebentar.
Dialogue: 0,0:14:42.15,0:14:44.24,Default,,0,0,0,,Stop, Ushio.
Dialogue: 0,0:14:45.20,0:14:47.74,Default,,0,0,0,,Ada tikus menyusup.
Dialogue: 0,0:14:48.10,0:14:49.89,Default,,0,0,0,,Sana hancurkan mereka.
Dialogue: 0,0:14:52.32,0:14:55.29,Default,,0,0,0,,Apa ini? Sudah selesai?
Dialogue: 0,0:14:55.81,0:14:57.29,Default,,0,0,0,,Sekarang.
Dialogue: 0,0:14:57.73,0:15:00.16,Default,,0,0,0,,Ayo kita ganti haluan.
Dialogue: 0,0:15:01.00,0:15:04.09,Default,,0,0,0,,Aku Gero Hikaru, Pengguna Racun.
Dialogue: 0,0:15:04.09,0:15:08.64,Default,,0,0,0,,Dengan harapan menikah,\Nmaukah berpacaran denganku?
Dialogue: 0,0:15:08.91,0:15:09.81,Default,,0,0,0,,Mana bisa!
Dialogue: 0,0:15:09.81,0:15:12.68,Default,,0,0,0,,Kalau ini sungguhan,\Npasti mati kamu.
Dialogue: 0,0:15:12.68,0:15:14.52,Default,,0,0,0,,Terus aku harus bilang apa?
Dialogue: 0,0:15:14.52,0:15:15.60,Default,,0,0,0,,Jangan bergerak!
Dialogue: 0,0:15:15.60,0:15:16.19,Default,,0,0,0,,Bunuh!
Dialogue: 0,0:15:16.19,0:15:18.11,Default,,0,0,0,,Nanti dicatat, ya!
Dialogue: 0,0:15:18.11,0:15:19.90,Default,,0,0,0,,Dasar mencari jodoh adalah
Dialogue: 0,0:15:19.90,0:15:23.15,Default,,0,0,0,,memikirkan perasaan pasanganmu\Ndengan mendalam!
Dialogue: 0,0:15:23.15,0:15:25.53,Default,,0,0,0,,Jadi lupakan dulu soal cari jodohnya!
Dialogue: 0,0:15:25.53,0:15:27.07,Default,,0,0,0,,Hah?\NKok malah kontra—
Dialogue: 0,0:15:27.07,0:15:29.20,Default,,0,0,0,,Itu bukan urusan dia!
Dialogue: 0,0:15:30.08,0:15:31.41,Default,,0,0,0,,Berhenti!
Dialogue: 0,0:15:31.41,0:15:35.83,Default,,0,0,0,,Kamu adalah Pengguna yang datang\Nmenyelamatkan Himekawa Kyoko!
Dialogue: 0,0:15:37.04,0:15:41.25,Default,,0,0,0,,Dia sudah disekap di sini\Ndan merasakan segala penderitaan.
Dialogue: 0,0:15:41.92,0:15:43.55,Default,,0,0,0,,Apa yang akan kamu katakan padanya?
Dialogue: 0,0:15:45.97,0:15:48.16,Default,,0,0,0,,Oke, kita latihan sekali lagi.
Dialogue: 0,0:15:52.60,0:15:56.69,Default,,0,0,0,,Sudah sok berwibawa, payah banget\Nsekarang malah main todong pistol.
Dialogue: 0,0:15:56.69,0:16:00.15,Default,,0,0,0,,Menurutmu pasti payah.
Dialogue: 0,0:16:00.79,0:16:01.90,Default,,0,0,0,,Hei, itu...
Dialogue: 0,0:16:02.44,0:16:05.07,Default,,0,0,0,,Harusnya begini saja dari awal.
Dialogue: 0,0:16:05.07,0:16:07.91,Default,,0,0,0,,Kalau kamu juga kolektor,\Nharusnya tahu betapa berharganya—
Dialogue: 0,0:16:07.91,0:16:09.74,Default,,0,0,0,,Murah ini, kecil.
Dialogue: 0,0:16:09.74,0:16:12.87,Default,,0,0,0,,Kalau demi menambahkanmu ke koleksiku!
Dialogue: 0,0:16:13.29,0:16:16.12,Default,,0,0,0,,Sekarang mau jadi milikku, kan?
Dialogue: 0,0:16:17.96,0:16:20.93,Default,,0,0,0,,Bukannya mengembalikan ibu anak itu.
Dialogue: 0,0:16:21.55,0:16:23.53,Default,,0,0,0,,Aku malah membuatnya dalam bahaya.
Dialogue: 0,0:16:24.77,0:16:28.15,Default,,0,0,0,,Baiklah, aku akan turuti keinginanmu.
Dialogue: 0,0:16:34.47,0:16:38.77,Default,,0,0,0,,Tanganku!
Dialogue: 0,0:16:42.94,0:16:43.90,Default,,0,0,0,,Apa?
Dialogue: 0,0:16:43.90,0:16:44.82,Default,,0,0,0,,Siapa?
Dialogue: 0,0:16:44.82,0:16:47.03,Default,,0,0,0,,Harusnya ini ruangan tertutup!
Dialogue: 0,0:16:51.57,0:16:54.58,Default,,0,0,0,,Terima kasih sudah membersihkanku.
Dialogue: 0,0:17:01.58,0:17:03.46,Default,,0,0,0,,Mimpi saja yang indah.
Dialogue: 0,0:17:04.17,0:17:07.24,Default,,0,0,0,,Aku Gero Hikaru, Pengguna Racun.
Dialogue: 0,0:17:07.61,0:17:09.42,Default,,0,0,0,,Datang untuk menyelamatkanmu.
Dialogue: 0,0:17:10.05,0:17:11.59,Default,,0,0,0,,Sudah aman sekarang.
Dialogue: 0,0:17:12.55,0:17:16.60,Default,,0,0,0,,Memang kalimat yang simpel,\Ntapi harusnya bisa agak tenang sekarang.
Dialogue: 0,0:17:16.60,0:17:18.93,Default,,0,0,0,,Malah Pengguna yang muncul.
Dialogue: 0,0:17:19.45,0:17:21.85,Default,,0,0,0,,Kami tidak punya uang buat membayarmu, lo.
Dialogue: 0,0:17:23.50,0:17:25.86,Default,,0,0,0,,Mereka sampai jual organ dalam, ya.
Dialogue: 0,0:17:25.86,0:17:28.94,Default,,0,0,0,,Kalimat kedua memang belum\Ndirencanakan sayangnya.
Dialogue: 0,0:17:28.94,0:17:32.11,Default,,0,0,0,,Habisnya main maju saja\Nsaat sedang rapat.
Dialogue: 0,0:17:32.91,0:17:34.78,Default,,0,0,0,,Ah, biar kulepas.
Dialogue: 0,0:17:35.35,0:17:38.69,Default,,0,0,0,,Tapi, syukurlah,\Nsituasi terburuknya belum terjadi.
Dialogue: 0,0:17:47.25,0:17:51.38,Default,,0,0,0,,Bunuh tikus-tikus itu, Ushio sang Pengguna Air!
Dialogue: 0,0:18:00.23,0:18:01.89,Default,,0,0,0,,Kamu juga tidur saja sana!
Dialogue: 0,0:18:03.40,0:18:04.27,Default,,0,0,0,,Air?
Dialogue: 0,0:18:07.44,0:18:08.28,Default,,0,0,0,,Cepat sekali!
Dialogue: 0,0:18:08.28,0:18:10.40,Default,,0,0,0,,Kinosaki, urus Himekawa!
Dialogue: 0,0:18:11.70,0:18:14.82,Default,,0,0,0,,Hei, Gero!\NPerlakukan wanita dengan lembut!
Dialogue: 0,0:18:14.82,0:18:17.33,Default,,0,0,0,,Maaf!\NNanti akan kudengar ocehanmu!
Dialogue: 0,0:18:33.06,0:18:34.47,Default,,0,0,0,,Gero!
Dialogue: 0,0:18:41.13,0:18:43.94,Default,,0,0,0,,Maaf, terlambat memperkenalkan diri, halo.
Dialogue: 0,0:18:43.94,0:18:46.44,Default,,0,0,0,,Ini kartu nama saya.
Dialogue: 0,0:18:46.44,0:18:48.86,Default,,0,0,0,,Anda Tuan Gero sang Pengguna Racun, ya.
Dialogue: 0,0:18:48.86,0:18:50.94,Default,,0,0,0,,Pebisnis sopan ternyata?
Dialogue: 0,0:18:50.94,0:18:53.10,Default,,0,0,0,,Langsung saja usulan dari saya.
Dialogue: 0,0:18:53.10,0:18:55.95,Default,,0,0,0,,Bagaimana kalau ini\Nkita selesaikan dengan damai?
Dialogue: 0,0:18:55.95,0:19:00.74,Default,,0,0,0,,Kalau sesama pengguna saling bertarung,\Nkerugian melambung, melebihi bayaran.
Dialogue: 0,0:19:00.74,0:19:06.08,Default,,0,0,0,,Jadi, biar saya beri bayaran\Nsepuluh kali dari klien Anda.
Dialogue: 0,0:19:06.08,0:19:09.17,Default,,0,0,0,,Secara bisnis, tentu akan dilepas, bukan?
Dialogue: 0,0:19:09.17,0:19:11.73,Default,,0,0,0,,Tugas, kemanusiaan, ikatan.
Dialogue: 0,0:19:12.07,0:19:16.24,Default,,0,0,0,,Bayangkan seluruh keluarga tiap hari\Nberkumpul di meja makan di jam 6 sore.
Dialogue: 0,0:19:16.65,0:19:20.56,Default,,0,0,0,,Bagi pebisnis seperti itu, tidak akan\Nmendapat pertumbuhan pesat.
Dialogue: 0,0:19:20.56,0:19:21.89,Default,,0,0,0,,Bicara apa dia?
Dialogue: 0,0:19:21.89,0:19:24.56,Default,,0,0,0,,Seorang profesional tidak peduli\Npada ikatan yang tidak perlu.
Dialogue: 0,0:19:24.56,0:19:26.31,Default,,0,0,0,,- Harus bertindak maksimal dalam 24 jam.\N- Doping punya Gero?
Dialogue: 0,0:19:26.31,0:19:28.56,Default,,0,0,0,,- Harus bertindak maksimal dalam 24 jam.\N- Masih ada sisanya, biar kupungut.
Dialogue: 0,0:19:28.56,0:19:29.72,Default,,0,0,0,,Jangan sentuh!
Dialogue: 0,0:19:31.78,0:19:34.69,Default,,0,0,0,,Begitu rupanya,\Njadi itu racun mematikan.
Dialogue: 0,0:19:34.69,0:19:35.91,Default,,0,0,0,,Eh?
Dialogue: 0,0:19:36.45,0:19:38.74,Default,,0,0,0,,"Mutasi Keturunan" yang diwarisi turun-temurun
Dialogue: 0,0:19:38.74,0:19:40.70,Default,,0,0,0,,oleh pengguna sebagai mata pencaharian.
Dialogue: 0,0:19:40.70,0:19:43.04,Default,,0,0,0,,Mutasi Keturunan Pengguna Racun adalah
Dialogue: 0,0:19:43.04,0:19:46.87,Default,,0,0,0,,penguatan fungsi tubuh atas reaksi\Nterhadap racun dalam dosis fatal.
Dialogue: 0,0:19:46.87,0:19:51.35,Default,,0,0,0,,Dengan kata lain, strategi bertahan hidup\Ndi dunia para pengguna.
Dialogue: 0,0:19:51.35,0:19:53.34,Default,,0,0,0,,Bukan sesuatu yang mengenakkan.
Dialogue: 0,0:19:53.34,0:19:58.34,Default,,0,0,0,,Ini kutukan demi memastikan\Nbisa menghabisi target sebelum mati.
Dialogue: 0,0:19:58.34,0:20:03.13,Default,,0,0,0,,Kalau kamu Pengguna Air,\Ntrik anehmu juga Mutasi Keturunan, kan?
Dialogue: 0,0:20:03.13,0:20:05.77,Default,,0,0,0,,Walau sekilas terlihat seperti sihir.
Dialogue: 0,0:20:07.39,0:20:08.65,Default,,0,0,0,,Tepat sekali.
Dialogue: 0,0:20:08.65,0:20:10.98,Default,,0,0,0,,Lalu, kalau boleh menambahkan,
Dialogue: 0,0:20:10.98,0:20:12.65,Default,,0,0,0,,begitu juga dengan baju kerja kami.
Dialogue: 0,0:20:12.65,0:20:15.40,Default,,0,0,0,,Jarum atau gas beracun tidak akan bisa tembus.
Dialogue: 0,0:20:15.40,0:20:18.70,Default,,0,0,0,,Dirancang kedap udara\Nuntuk menahan tekanan air ekstrem.
Dialogue: 0,0:20:18.70,0:20:21.45,Default,,0,0,0,,Lalu langsung saja soal uang damainya.
Dialogue: 0,0:20:22.91,0:20:24.16,Default,,0,0,0,,Begitu rupanya.
Dialogue: 0,0:20:24.16,0:20:26.37,Default,,0,0,0,,Sangat disayangkan.
Dialogue: 0,0:20:33.92,0:20:35.01,Default,,0,0,0,,Jadi begitu.
Dialogue: 0,0:20:35.52,0:20:40.14,Default,,0,0,0,,Mutasi Keturunan Pengguna Racun\Nakan meningkat saat mendekati kematian.
Dialogue: 0,0:20:40.14,0:20:41.82,Default,,0,0,0,,Menyusahkan sekali.
Dialogue: 0,0:20:41.82,0:20:44.31,Default,,0,0,0,,Asal bisa kena sekali saja\Ndia akan habis.
Dialogue: 0,0:20:44.31,0:20:46.35,Default,,0,0,0,,Bukankah Keluarga Pengguna Racun Gero
Dialogue: 0,0:20:46.35,0:20:50.06,Default,,0,0,0,,adalah satu dari lima keluarga\Nyang memimpin bisnis ini?
Dialogue: 0,0:20:50.06,0:20:54.15,Default,,0,0,0,,Bagaimana kalau melakukan hal\Nyang lebih bermakna dan bernilai saja?
Dialogue: 0,0:20:55.11,0:20:56.32,Default,,0,0,0,,Atau mungkin.
Dialogue: 0,0:20:56.32,0:20:59.03,Default,,0,0,0,,Himekawa adalah pelanggan berharga\Nbagi Tuan Gero?
Dialogue: 0,0:20:59.03,0:21:01.24,Default,,0,0,0,,Bukan, lebih dari itu.
Dialogue: 0,0:21:01.24,0:21:04.12,Default,,0,0,0,,Atau jangan-jangan, dia kekasihmu?
Dialogue: 0,0:21:09.50,0:21:11.46,Default,,0,0,0,,Serangan balik yang payah sekali.
Dialogue: 0,0:21:11.46,0:21:13.54,Default,,0,0,0,,Cuma kena satu lapisan kulit saja.
Dialogue: 0,0:21:16.25,0:21:17.96,Default,,0,0,0,,Sudah dilumuri apa—
Dialogue: 0,0:21:20.81,0:21:24.39,Default,,0,0,0,,Himekawa hanyalah orang asing.
Dialogue: 0,0:21:31.61,0:21:32.60,Default,,0,0,0,,Tapi!
Dialogue: 0,0:21:38.86,0:21:42.41,Default,,0,0,0,,Bisa saja ke depannya\Nakan menjadi sosok berharga bagiku.
Dialogue: 0,0:21:44.77,0:21:46.95,Default,,0,0,0,,Dengan akurasi hingga milimeter.
Dialogue: 0,0:21:46.95,0:21:49.20,Default,,0,0,0,,Tiga kali menyerang di titik yang sama?
Dialogue: 0,0:21:49.20,0:21:53.75,Default,,0,0,0,,Saya benar-benar tidak mengerti\Napa yang Anda bicarakan.
Dialogue: 0,0:21:54.21,0:21:55.63,Default,,0,0,0,,Tentu saja.
Dialogue: 0,0:21:55.63,0:21:59.41,Default,,0,0,0,,Dari sudut pandangmu,\Naku sangat bodoh dan tidak masuk akal.
Dialogue: 0,0:21:59.41,0:22:00.53,Default,,0,0,0,,Hanya saja.
Dialogue: 0,0:22:01.00,0:22:05.21,Default,,0,0,0,,Tiap hari jam 6 sore seluruh keluarga\Nberkumpul untuk makan bersama.
Dialogue: 0,0:22:05.75,0:22:09.14,Default,,0,0,0,,Sesuatu yang sudah kamu sebut\Ntidak berguna dan kamu buang.
Dialogue: 0,0:22:10.93,0:22:15.19,Default,,0,0,0,,Ingin kudapatkan walau nyawa taruhannya!
Dialogue: 0,0:23:46.46,0:23:47.78,Default,,0,0,0,,- Syukurlah pasangan pertamaku Himekawa.\N- Tentu akan ganti rugi.
Dialogue: 0,0:23:47.78,0:23:49.03,Default,,0,0,0,,- Syukurlah pasangan pertamaku Himekawa.\N- Aku suka ini.
Dialogue: 0,0:23:49.03,0:23:50.78,Default,,0,0,0,,- Misi kencan dimulai!\N- Mencuri hatiku itu tidak mudah, lo.
Dialogue: 0,0:23:50.78,0:23:51.95,Default,,0,0,0,,- Ini langkah pertama\N- Aku ingin kamu dapat pernikahan terbaik.
Dialogue: 0,0:23:51.95,0:23:53.20,Default,,0,0,0,,- pernikahan bahagia yang kudambakan!\N- Aku ingin kamu dapat pernikahan terbaik.
Dialogue: 0,0:23:53.20,0:23:55.96,Default Above,,0,0,0,,Selanjutnya, Pasangan Pertama.
