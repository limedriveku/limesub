Dialogue: 0,0:00:43.56,0:00:46.23,tanda,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:07:46.32,0:07:51.83,tanda,,0000,0000,0000,,SAKIT, SAKIT, SAKIT
Dialogue: 0,0:10:28.40,0:10:30.90,tanda,,0000,0000,0000,,AKU YANG MEMBUATNYA TERBIASA - KINOSAKI MEI
Dialogue: 0,0:10:50.59,0:10:52.85,tanda,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN
Dialogue: 0,0:10:52.85,0:10:55.18,tanda,,0000,0000,0000,,MIND WHISPER
Dialogue: 0,0:11:02.60,0:11:04.60,tanda,,0000,0000,0000,,BAGIAN ATAS - PUNGGUNG - BAGIAN BAWAH
Dialogue: 0,0:11:44.10,0:11:45.02,tanda,,0000,0000,0000,,MEONG 2.980 YEN
Dialogue: 0,0:11:47.39,0:11:48.48,tanda,,0000,0000,0000,,MEONG
Dialogue: 0,0:14:03.91,0:14:06.70,tanda,,0000,0000,0000,,NAMA PENGGUNA: KITAMI ALIAS HIME LOVE
Dialogue: 0,0:15:13.98,0:15:16.02,tanda,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:15:16.02,0:15:18.02,tanda,,0000,0000,0000,,TUAN CHLADNI
Dialogue: 0,0:15:34.29,0:15:36.37,tanda,,0000,0000,0000,,TELINGA APA ITU? KENAPA DIGENDONG?
Dialogue: 0,0:15:41.63,0:15:44.05,tanda,,0000,0000,0000,,AKU YANG MEMBERIKAN - KITAMI
Dialogue: 0,0:15:48.01,0:15:49.55,tanda,,0000,0000,0000,,GPS?
Dialogue: 0,0:18:17.74,0:18:20.87,tanda,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN
Dialogue: 0,0:18:20.87,0:18:23.25,tanda,,0000,0000,0000,,GRAND ACTOR
Dialogue: 0,0:19:24.98,0:19:28.19,tanda,,0000,0000,0000,,PENYUBUR SUPER TANAMAN HIAS
Dialogue: 0,0:23:53.24,0:23:56.00,tanda,,0000,0000,0000,,BERSAMAKU
Dialogue: 0,0:00:12.53,0:00:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.91,0:00:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:00:17.54,0:00:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.71,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:26.05,0:00:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.34,0:00:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:02:07.45,0:02:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama!
Dialogue: 0,0:02:08.61,0:02:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya uji nyali dimulai!
Dialogue: 0,0:02:11.03,0:02:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kita adalah kuil itu!
Dialogue: 0,0:02:13.53,0:02:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maunya begitu, sih.
Dialogue: 0,0:02:14.74,0:02:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena memang bahaya, di tengah jalan\Nsudah ditaruh papan foto wajah.
Dialogue: 0,0:02:19.97,0:02:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan diberi tongsis dan harus\Nfoto berdua bersama pasangan.
Dialogue: 0,0:02:24.84,0:02:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa pakai lampu kilat.
Dialogue: 0,0:02:27.04,0:02:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu semuanya,\Nayo buat kenangan yang tak terlupakan!
Dialogue: 0,0:02:31.34,0:02:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yay!\N- Wow!
Dialogue: 0,0:02:45.10,0:02:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, ini kesempatanmu.
Dialogue: 0,0:02:47.73,0:02:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu efek jembatan gantung?
Dialogue: 0,0:02:49.61,0:02:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat lewat jembatan gantung,
Dialogue: 0,0:02:50.94,0:02:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasa takut malah disalahartikan jadi\Ndebaran cinta dari pasangan itu, lo!
Dialogue: 0,0:02:54.90,0:02:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hantu juga sama.
Dialogue: 0,0:02:56.36,0:02:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh?
Dialogue: 0,0:02:57.91,0:03:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasananya itu penting, paham?
Dialogue: 0,0:03:00.41,0:03:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan begini harus dimanfaatkan\Natau nanti tidak bisa dapat pacar, lo.
Dialogue: 0,0:03:05.50,0:03:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah dia\Nyang kelihatan senang begini?
Dialogue: 0,0:03:08.21,0:03:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku yang minta dibantu cari jodoh.
Dialogue: 0,0:03:10.96,0:03:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka-sih!
Dialogue: 0,0:03:15.01,0:03:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:15.93,0:03:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:03:16.93,0:03:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak,\Nsampai mau menemaniku melakukan ini.
Dialogue: 0,0:03:21.93,0:03:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya ini memberatkanmu, kan?
Dialogue: 0,0:03:26.02,0:03:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja aku berdiam diri di rumah,
Dialogue: 0,0:03:28.69,0:03:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pekerjaanmu pasti lebih mudah.
Dialogue: 0,0:03:32.11,0:03:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada kaitannya.
Dialogue: 0,0:03:34.69,0:03:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru metode serangannya\Nakan terbatas di tempat seperti ini.
Dialogue: 0,0:03:39.31,0:03:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada satu yang harus\Nkupesan pada Ureshino.
Dialogue: 0,0:03:43.20,0:03:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan semua risaumu\Ndan nikmati saja kamp ini.
Dialogue: 0,0:03:51.35,0:03:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan seperti ini dalam hidup\Nitu bisa dihitung jari, kan?
Dialogue: 0,0:03:55.35,0:03:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu kamu sia-siakan segalanya\Nhanya karena nyawamu diincar.
Dialogue: 0,0:04:00.39,0:04:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk itulah ada aku.
Dialogue: 0,0:04:03.45,0:04:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero.
Dialogue: 0,0:04:08.31,0:04:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma papan foto wajah.
Dialogue: 0,0:04:11.31,0:04:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongsis ini bagaimana pakainya?
Dialogue: 0,0:04:15.03,0:04:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, biar aku yang foto.
Dialogue: 0,0:04:18.08,0:04:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupotret, ya.
Dialogue: 0,0:04:19.20,0:04:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak, jero-an~
Dialogue: 0,0:04:35.96,0:04:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero?
Dialogue: 0,0:04:41.85,0:04:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero!
Dialogue: 0,0:04:43.85,0:04:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menyusul Gero!
Dialogue: 0,0:04:47.48,0:04:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus ketemu dia lagi!
Dialogue: 0,0:04:53.19,0:04:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero!
Dialogue: 0,0:04:56.53,0:04:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukur—
Dialogue: 0,0:06:01.22,0:06:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:29.66,0:06:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiori.
Dialogue: 0,0:06:35.46,0:06:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayah?
Dialogue: 0,0:06:38.54,0:06:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:40.42,0:06:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang di antara hidup dan mati\Nsebagai persembahan untuk Tuan Chladni.
Dialogue: 0,0:06:47.35,0:06:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka kesempatan minum\Nbersamamu akan datang seperti ini.
Dialogue: 0,0:06:52.68,0:06:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayah kenapa?\NKenapa menunjukku jadi pewaris?
Dialogue: 0,0:07:02.69,0:07:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah ambil keputusan!
Dialogue: 0,0:07:05.11,0:07:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:06.58,0:07:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi pilih kasih karena kamu putriku!
Dialogue: 0,0:07:10.33,0:07:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, itu sebuah kesalahan!
Dialogue: 0,0:07:13.29,0:07:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu aslinya tahu, kan?
Dialogue: 0,0:07:15.71,0:07:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia tidak berguna hanya akan\Nmenderita jika berjuang terlalu keras, Shiori!
Dialogue: 0,0:07:28.43,0:07:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan bisa jadi kuat.
Dialogue: 0,0:07:32.81,0:07:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, menyerah saja.
Dialogue: 0,0:07:37.81,0:07:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memenuhi harapan Ayah atau orang sekitar
Dialogue: 0,0:07:42.20,0:07:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu menyakitkan, bukan?
Dialogue: 0,0:07:52.33,0:07:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyerah.
Dialogue: 0,0:08:02.75,0:08:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang benar.
Dialogue: 0,0:08:07.34,0:08:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:08.84,0:08:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari itu!
Dialogue: 0,0:08:11.13,0:08:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat senang melihat\Nmereka semua bahagia!
Dialogue: 0,0:08:16.81,0:08:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku tidak bisa jadi kuat\Nmeski dilatih sekeras apa pun.
Dialogue: 0,0:08:20.56,0:08:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku tetap ingin\Nmelatih diriku!
Dialogue: 0,0:08:24.90,0:08:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan lari!
Dialogue: 0,0:08:30.66,0:08:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketinggian ini... pasti mati...
Dialogue: 0,0:08:35.03,0:08:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bagaimana ini?\N- Harus apa biar selamat?
Dialogue: 0,0:08:36.12,0:08:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tasku?\N- Sungainya terlalu dangkal.
Dialogue: 0,0:08:36.87,0:08:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Papan foto wajah? - Jajanan?\N- Permen pelega tenggorokan?
Dialogue: 0,0:08:38.21,0:08:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Payung!
Dialogue: 0,0:08:40.96,0:08:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Payung lipat!
Dialogue: 0,0:08:43.34,0:08:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa!
Dialogue: 0,0:08:44.55,0:08:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mati di sini, aku tidak enak\Npada orang yang sudah melindungiku.
Dialogue: 0,0:08:49.51,0:08:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus berbuat sesuatu!
Dialogue: 0,0:08:51.59,0:08:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu!
Dialogue: 0,0:09:02.98,0:09:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini yang waktu pesta minum...
Dialogue: 0,0:09:06.15,0:09:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polimer superabsorben!
Dialogue: 0,0:09:11.36,0:09:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghabisi diri sendiri
Dialogue: 0,0:09:12.70,0:09:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau dibuat seperti kecelakaan,\Nkalau tidak kerabatmu yang dicurigai.
Dialogue: 0,0:09:17.20,0:09:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti sudah bukan soal warisan lagi.
Dialogue: 0,0:09:20.62,0:09:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya membuat rencana sematang ini.
Dialogue: 0,0:09:25.63,0:09:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Legenda Tuan Chladni juga\Nhasil rekayasamu, kan?
Dialogue: 0,0:09:31.80,0:09:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Suara, Naruko!
Dialogue: 0,0:09:39.43,0:09:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cekatan sekali dirimu, Pengguna Suara.
Dialogue: 0,0:09:41.60,0:09:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menekan tombol rana\Ndi lokasi papan foto wajah.
Dialogue: 0,0:09:44.86,0:09:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero! Gero!
Dialogue: 0,0:09:47.13,0:09:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung menyerangku\Ndengan gelombang kejut.
Dialogue: 0,0:09:50.57,0:09:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatku kehilangan arah\Nagar terpisah dari Ureshino.
Dialogue: 0,0:09:54.70,0:09:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata lebih ceria dari dugaanku.
Dialogue: 0,0:09:58.33,0:10:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya bakal super seru.
Dialogue: 0,0:10:02.00,0:10:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:10:03.50,0:10:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah menghabisi diri sendiri\Natau kecelakaan.
Dialogue: 0,0:10:06.29,0:10:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melodi yang disebut aturan itu\Nakan super kupatuhi.
Dialogue: 0,0:10:12.01,0:10:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ureshino, bahaya kalau kita\Nterus di sini!
Dialogue: 0,0:10:14.59,0:10:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita terobos!
Dialogue: 0,0:10:16.51,0:10:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak bisa berdiri.
Dialogue: 0,0:10:19.01,0:10:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pinggulku lemas.
Dialogue: 0,0:10:21.75,0:10:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:10:24.44,0:10:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik ke pundakku.
Dialogue: 0,0:10:25.77,0:10:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:26.15,0:10:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku sudah terbiasa\Nberkat Kinosaki.
Dialogue: 0,0:10:28.40,0:10:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang membuatnya terbiasa!
Dialogue: 0,0:10:37.37,0:10:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, benar begini?
Dialogue: 0,0:10:39.33,0:10:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:40.34,0:10:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:10:42.39,0:10:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai jatuh, ya!
Dialogue: 0,0:10:44.12,0:10:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:10:49.67,0:10:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan,
Dialogue: 0,0:10:52.85,0:10:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mind Whisper.
Dialogue: 0,0:10:55.84,0:10:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:10:56.59,0:10:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:10:58.30,0:11:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma perkiraanku.
Dialogue: 0,0:11:00.10,0:11:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mungkin sejenis serangan psikis!
Dialogue: 0,0:11:09.90,0:11:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan fisiknya sangat fortissimo.
Dialogue: 0,0:11:12.69,0:11:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini Mutasi Keturunan\Nyang dirahasiakan pengguna racun.
Dialogue: 0,0:11:18.07,0:11:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa merasakannya.
Dialogue: 0,0:11:19.50,0:11:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Getaran peningkatan racun.
Dialogue: 0,0:11:22.45,0:11:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Super terhormat.
Dialogue: 0,0:11:24.55,0:11:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, gunung ini ada dalam\Njangkauan Mind Whisper.
Dialogue: 0,0:11:29.42,0:11:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Super mustahil untuk lari.
Dialogue: 0,0:11:31.92,0:11:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ureshino, pakai sumbat telinga ini!
Dialogue: 0,0:11:35.55,0:11:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ge-Gero, aku punya sesuatu yang bagus.
Dialogue: 0,0:11:39.64,0:11:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Headset yang dilengkapi peredam suara!
Dialogue: 0,0:11:42.26,0:11:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengobrol kalau disambungkan.
Dialogue: 0,0:11:45.43,0:11:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok sekali dengan Gero.
Dialogue: 0,0:11:48.48,0:11:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menutup telinga adalah langkah naif.
Dialogue: 0,0:11:51.36,0:11:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Mind Whisper bertumpuk,
Dialogue: 0,0:11:54.07,0:11:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bilah suara akan mengorek dagingmu.
Dialogue: 0,0:11:58.16,0:12:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telinga kucing sama sekali\Ntidak cocok buatmu.
Dialogue: 0,0:12:05.87,0:12:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan didengar.
Dialogue: 0,0:12:07.62,0:12:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hindari dengan kulit!
Dialogue: 0,0:12:11.00,0:12:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain penguatan fisik,\Njuga memaksimalkan indra perasa kulit!
Dialogue: 0,0:12:16.47,0:12:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin: Puncak Candra!
Dialogue: 0,0:12:22.26,0:12:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:12:23.76,0:12:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Targetnya bukan kamu.
Dialogue: 0,0:12:32.48,0:12:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ureshino?
Dialogue: 0,0:12:34.05,0:12:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan aku bukan\Ntarget serangan aslinya?
Dialogue: 0,0:12:37.49,0:12:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi menggetarkan headphone?
Dialogue: 0,0:12:44.03,0:12:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaanku.
Dialogue: 0,0:12:46.25,0:12:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya ayahnya.
Dialogue: 0,0:12:48.33,0:12:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini punya segudang trauma.
Dialogue: 0,0:12:51.88,0:12:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatimu akan terus-menerus hancur.
Dialogue: 0,0:13:00.13,0:13:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ureshino!
Dialogue: 0,0:13:06.54,0:13:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman?
Dialogue: 0,0:13:08.06,0:13:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sadar, kan?
Dialogue: 0,0:13:09.98,0:13:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sebenarnya aku\Nmenganggapmu sebagai beban.
Dialogue: 0,0:13:16.69,0:13:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyiapkan berbagai hal,\Njuga melobi pemegang saham.
Dialogue: 0,0:13:21.67,0:13:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelah.
Dialogue: 0,0:13:24.28,0:13:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya pamanmu\Nmengizinkan ikut kamp.
Dialogue: 0,0:13:27.79,0:13:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena setuju pada rencana pembunuhanmu.
Dialogue: 0,0:13:32.54,0:13:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada satu pun yang berpihak—
Dialogue: 0,0:13:37.21,0:13:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin begitu!
Dialogue: 0,0:13:44.93,0:13:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamanmu itu
Dialogue: 0,0:13:46.81,0:13:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah mewawancarai banyak pengawal\Nsebelum akhirnya mempekerjakanku!
Dialogue: 0,0:13:51.35,0:13:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak tahu apa-apa,\Ndia selalu dapat orang berengsek.
Dialogue: 0,0:13:55.77,0:14:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu berakhir kacau dan harus bayar mahal\Nuntuk biaya pembatalan.
Dialogue: 0,0:14:01.61,0:14:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan pamanmu menawariku adalah
Dialogue: 0,0:14:03.91,0:14:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membaca ulasan super panjang
Dialogue: 0,0:14:05.32,0:14:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepuluh ribu karakter.
Dialogue: 0,0:14:06.70,0:14:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia bisa tenang\Nmemercayakanmu padaku.
Dialogue: 0,0:14:10.75,0:14:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin sampai sejauh itu\Nuntuk orang yang dianggap beban?
Dialogue: 0,0:14:17.46,0:14:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ya.
Dialogue: 0,0:14:21.01,0:14:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Ureshino.
Dialogue: 0,0:14:22.97,0:14:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat tidur sebentar.
Dialogue: 0,0:14:26.51,0:14:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Racun memang hebat.
Dialogue: 0,0:14:28.72,0:14:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antisipasinya pada ilusi\Nsetingkat lebih unggul, ya.
Dialogue: 0,0:14:33.02,0:14:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dengar, kan, Naruko?
Dialogue: 0,0:14:36.15,0:14:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilusi dan cuci otakmu itu menggunakan\Nkenangan dan perasaan di lubuk hati
Dialogue: 0,0:14:41.32,0:14:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menarik keluar trauma\Nlalu memperkuatnya.
Dialogue: 0,0:14:44.53,0:14:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ureshino yang punya segunung luka di hatinya.
Dialogue: 0,0:14:47.41,0:14:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga pamannya mengizinkan ikut kamp\Nmemanglah sebuah fakta.
Dialogue: 0,0:14:50.91,0:14:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi!
Dialogue: 0,0:14:52.00,0:14:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya satu pecahan kecil!
Dialogue: 0,0:14:55.71,0:14:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamannya sempat terpengaruh\Nkarena kamu yang memperkuatnya.
Dialogue: 0,0:14:59.75,0:15:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ureshino tahu kalau dirinya lemah\Ndan mati-matian mengatasinya.
Dialogue: 0,0:15:06.97,0:15:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:15:09.97,0:15:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu dia lebih dari ini!
Dialogue: 0,0:15:22.24,0:15:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, aneh sekali.
Dialogue: 0,0:15:25.24,0:15:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rombongan Gero harusnya ada di sekitar sini.
Dialogue: 0,0:15:30.37,0:15:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero!\NDan Ureshino?
Dialogue: 0,0:15:33.16,0:15:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang—
Dialogue: 0,0:15:36.37,0:15:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas lama sekali, ternyata seperti itu.
Dialogue: 0,0:15:39.17,0:15:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung saja kupasangi GPS.
Dialogue: 0,0:15:41.63,0:15:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang memberikan.
Dialogue: 0,0:15:44.05,0:15:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, kamu tidak apa-apa?
Dialogue: 0,0:15:46.23,0:15:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sedikit memaksakan diri.
Dialogue: 0,0:15:49.55,0:15:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, Kinosaki.
Dialogue: 0,0:15:51.60,0:15:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bawa Ureshino menjauh dari desa ini.
Dialogue: 0,0:15:54.14,0:15:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:15:55.10,0:15:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa?
Dialogue: 0,0:15:56.48,0:16:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut sifat bawaan misinya,\Ndia seharusnya menghabisiku lebih dulu.
Dialogue: 0,0:16:02.03,0:16:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sudah dua kali\Nmerusak rencananya.
Dialogue: 0,0:16:04.69,0:16:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pergi menghajar Naruko.
Dialogue: 0,0:16:07.83,0:16:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi itu, aku ingin menyerahkan\Nkeselamatan Ureshino padamu.
Dialogue: 0,0:16:11.95,0:16:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:16:12.91,0:16:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini penasihat cari jodoh, lo.
Dialogue: 0,0:16:18.12,0:16:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sekali ini saja, ya.
Dialogue: 0,0:16:19.92,0:16:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nanti minta traktir susyi mahal!\N- Yakiniku mewah yang kedua!
Dialogue: 0,0:16:21.07,0:16:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuna Oma! - Bulu babi! - Harga di konter!\N- Makan tuna dua malam berturut-turut!
Dialogue: 0,0:16:22.59,0:16:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terbantu.
Dialogue: 0,0:16:23.88,0:16:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo!
Dialogue: 0,0:16:27.67,0:16:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Ureshino.
Dialogue: 0,0:16:30.68,0:16:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar.
Dialogue: 0,0:16:32.60,0:16:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sengaja membahayakan diri\Ndengan mendekat adalah
Dialogue: 0,0:16:35.89,0:16:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyelipkan ini agar ilusi\Ndan cuci otaknya jadi lebih kuat.
Dialogue: 0,0:16:40.44,0:16:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat dari jurus Naruko.
Dialogue: 0,0:16:42.77,0:16:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau belum kupahami sepenuhnya.
Dialogue: 0,0:16:45.69,0:16:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini menarik.
Dialogue: 0,0:16:47.37,0:16:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia berniat bertarung\Nsambil bersembunyi.
Dialogue: 0,0:16:49.86,0:16:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal kuseret dia keluar!
Dialogue: 0,0:16:52.62,0:16:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Super merepotkan.
Dialogue: 0,0:16:54.71,0:16:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekarang mengejar target,
Dialogue: 0,0:16:57.00,0:17:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada risiko justru diriku\Nyang ditikam dari belakang.
Dialogue: 0,0:17:01.54,0:17:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Super merepotkan.
Dialogue: 0,0:17:03.57,0:17:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalahkan Pengguna Racun lebih dulu,
Dialogue: 0,0:17:06.00,0:17:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghabisi Ureshino.\Nsetelah itu baru perlahan
Dialogue: 0,0:17:09.08,0:17:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu opsi paling masuk akal.
Dialogue: 0,0:17:10.93,0:17:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisiku sedang super prima.
Dialogue: 0,0:17:15.03,0:17:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya klimaks dimulai.
Dialogue: 0,0:17:23.31,0:17:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niat membunuhnya ada di level berbeda.
Dialogue: 0,0:17:25.81,0:17:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar ruangan, gas akan menyebar\Ndan dayanya jadi berkurang.
Dialogue: 0,0:17:30.27,0:17:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarum beracun juga tidak berguna\Nkalau bukan dari jarak dekat.
Dialogue: 0,0:17:34.24,0:17:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana?
Dialogue: 0,0:17:35.95,0:17:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kawatnya kupotong,\Nteknikmu tidak akan berfungsi!
Dialogue: 0,0:17:41.33,0:17:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terpental?
Dialogue: 0,0:17:43.67,0:17:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senar ini bergetar dengan\Nkecepatan super tinggi.
Dialogue: 0,0:17:46.96,0:17:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada ruang bagi cairan\Nuntuk meresap.
Dialogue: 0,0:17:53.05,0:17:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya tercipta.
Dialogue: 0,0:18:17.74,0:18:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan,
Dialogue: 0,0:18:20.87,0:18:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grand Actor!
Dialogue: 0,0:19:00.29,0:19:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bergerak?
Dialogue: 0,0:19:01.83,0:19:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakinya juga?
Dialogue: 0,0:19:03.12,0:19:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:19:04.50,0:19:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan, Pengguna Racun?
Dialogue: 0,0:19:06.46,0:19:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan memotong kawatnya,\Ntapi pohonnya?
Dialogue: 0,0:19:09.00,0:19:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:09.75,0:19:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa ada anomali seperti itu.
Dialogue: 0,0:19:11.84,0:19:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga bukan dibuat layu dengan racun.
Dialogue: 0,0:19:14.38,0:19:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru sangat prima.
Dialogue: 0,0:19:17.11,0:19:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:19:18.59,0:19:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:19:23.51,0:19:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temanmu itu.
Dialogue: 0,0:19:24.98,0:19:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya menyukai obatku.
Dialogue: 0,0:19:28.19,0:19:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelemahan teknikmu adalah\Nkerumitan penyetelannya.
Dialogue: 0,0:19:32.44,0:19:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pepohonan terus bertumbuh.
Dialogue: 0,0:19:35.20,0:19:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik suaramu yang presisi itu jadi mustahil.
Dialogue: 0,0:19:38.82,0:19:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamat sudah.
Dialogue: 0,0:19:44.79,0:19:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekhawatiran yang bersemayam\Ndi lubuk hari orang-orang.
Dialogue: 0,0:19:50.71,0:19:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benihnya sudah ditabur.
Dialogue: 0,0:19:54.63,0:19:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal
Dialogue: 0,0:19:57.51,0:20:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diperkuat saja.
Dialogue: 0,0:20:01.97,0:20:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua yang di sana,\Nada masalah besar!
Dialogue: 0,0:20:06.06,0:20:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin...
Dialogue: 0,0:20:07.44,0:20:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu satu-satunya jalan keluar dari sini.
Dialogue: 0,0:20:09.60,0:20:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat uji nyali.\NAda yang tidak enak badan
Dialogue: 0,0:20:12.69,0:20:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu mau dibawa ke rumah sakit\Npakai mobil, sudah seperti itu.
Dialogue: 0,0:20:15.99,0:20:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyusuri hutan itu bahaya untuk pemula.
Dialogue: 0,0:20:18.28,0:20:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunggu pertolongan saja?
Dialogue: 0,0:20:19.53,0:20:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, itu!
Dialogue: 0,0:20:30.79,0:20:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:20:33.67,0:20:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini amarah Tuan Chladni!
Dialogue: 0,0:20:35.76,0:20:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutukannya ternyata benar!
Dialogue: 0,0:20:38.18,0:20:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan kena bencana!
Dialogue: 0,0:20:41.97,0:20:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak mau mati!
Dialogue: 0,0:20:45.10,0:20:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persembahan.
Dialogue: 0,0:20:48.31,0:20:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menuruti legenda.
Dialogue: 0,0:20:50.77,0:20:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus mempersembahkan anak-anak\Npada Tuan Chladni.
Dialogue: 0,0:20:55.65,0:20:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang paling muda di sini adalah anak-anak.
Dialogue: 0,0:20:59.11,0:21:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ulang tahunnya paling akhir\Nadalah tumbal untuk Tuan Chladni!
Dialogue: 0,0:21:03.74,0:21:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua anak baru keluarkan\Nkartu mahasiswa kalian.
Dialogue: 0,0:21:07.79,0:21:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}27 September.
Dialogue: 0,0:21:09.87,0:21:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}4 Februari.
Dialogue: 0,0:21:11.25,0:21:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}10 Oktober.
Dialogue: 0,0:21:12.63,0:21:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}5 Mei.
Dialogue: 0,0:21:14.09,0:21:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}20 Maret.
Dialogue: 0,0:21:17.01,0:21:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maret...
Dialogue: 0,0:21:18.58,0:21:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}31 Maret.
Dialogue: 0,0:21:21.89,0:21:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah super mustahil\Nuntuk menghentikan bibit kepanikan.
Dialogue: 0,0:21:27.97,0:21:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkap anak itu!
Dialogue: 0,0:21:29.89,0:21:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lari!
Dialogue: 0,0:21:31.90,0:21:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:21:33.69,0:21:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu harus dipersembahkan pada Tuan Chladni!\N- Tinggal masalah waktu sampai
Dialogue: 0,0:21:36.78,0:21:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak ada jalan lain agar kami selamat!\N- target kehilangan nyawanya.
Dialogue: 0,0:21:39.15,0:21:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama tidak menghentikanku,\Nmereka akan terus lepas kendali.
Dialogue: 0,0:21:47.87,0:21:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fiuuuuwit...
Dialogue: 0,0:22:01.88,0:22:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Super sempurna.
Dialogue: 0,0:22:06.30,0:22:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Violin?
Dialogue: 0,0:22:09.14,0:22:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia?
Dialogue: 0,0:22:11.69,0:22:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan\NPengguna Suara!
Dialogue: 0,0:23:46.47,0:23:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dunia ini ternyata tidak sekotor yang dikira.\N- Kemenangan superku!
Dialogue: 0,0:23:49.21,0:23:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Meledaklah, Roh Api!\N- Boleh juga, Gero!
Dialogue: 0,0:23:51.03,0:23:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tolong sekali lagi!\N- Super nikmat!
Dialogue: 0,0:23:53.24,0:23:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Bersamaku.
