Dialogue: 0,0:00:43.56,0:00:46.28,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:02:08.52,0:02:10.65,sign,,0000,0000,0000,,BINATANG BEROTOT SHIRATORI TAKERU
Dialogue: 0,0:02:22.41,0:02:23.46,sign,,0000,0000,0000,,PELATIHAN KENCAN KINOSAKI!
Dialogue: 0,0:02:23.46,0:02:24.71,sign,,0000,0000,0000,,EDISI PUSAT PERMAINAN!
Dialogue: 0,0:02:24.71,0:02:26.08,sign,,0000,0000,0000,,AYO JADI DEKAT DENGAN GADIS~
Dialogue: 0,0:02:26.08,0:02:28.84,sign,,0000,0000,0000,,SURGA CAMPUR ADUK
Dialogue: 0,0:02:42.85,0:02:47.06,sign,,0000,0000,0000,,SURGA CAMPUR ADUK
Dialogue: 0,0:03:34.82,0:03:36.28,sign,,0000,0000,0000,,TATSU SI BERUANG COKELAT BESAR
Dialogue: 0,0:03:36.28,0:03:37.36,sign,,0000,0000,0000,,YASU SI RAJA KAMBING HUTAN
Dialogue: 0,0:03:37.36,0:03:38.20,sign,,0000,0000,0000,,SHINICHI SI MACAN PEMAKAN MANUSIA
Dialogue: 0,0:03:38.20,0:03:38.87,sign,,0000,0000,0000,,JOE SI SERIGALA SENYAP
Dialogue: 0,0:03:41.03,0:03:42.08,sign,,0000,0000,0000,,KUSHIMA SI PENGGUNA TOMBAK
Dialogue: 0,0:03:42.08,0:03:42.99,sign,,0000,0000,0000,,DAN SI TUKANG MUTILASI
Dialogue: 0,0:03:47.67,0:03:50.08,sign,,0000,0000,0000,,TAMBAHI SENJATA
Dialogue: 0,0:04:25.37,0:04:27.71,sign,,0000,0000,0000,,SIDAT LAUT PANIK, ASYIK, LO!
Dialogue: 0,0:04:31.38,0:04:34.38,sign,,0000,0000,0000,,KUNCI SASARAN TEPAT DI HATI!
Dialogue: 0,0:11:09.77,0:11:11.65,sign,,0000,0000,0000,,TAMAN HEWAN GUYUB RUKUN
Dialogue: 0,0:12:18.97,0:12:21.01,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:12:21.01,0:12:23.01,sign,,0000,0000,0000,,PEMBURU PEMBUNUH BAYARAN
Dialogue: 0,0:13:33.38,0:13:37.71,sign,,0000,0000,0000,,TOXIN: NETRA
Dialogue: 0,0:13:37.71,0:13:42.22,sign,,0000,0000,0000,,TOXIN: CIPTA LEMBING
Dialogue: 0,0:15:29.62,0:15:31.99,sign,,0000,0000,0000,,AMAN
Dialogue: 0,0:16:18.37,0:16:20.54,sign,,0000,0000,0000,,TOXIN: TRIPEL
Dialogue: 0,0:17:56.76,0:17:59.47,sign,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN: KANIS MAYOR
Dialogue: 0,0:19:18.26,0:19:22.02,sign,,0000,0000,0000,,PENATU ITABASHI
Dialogue: 0,0:23:53.20,0:23:55.96,sign,,0000,0000,0000,,KERAJAAN HEWAN
Dialogue: 0,0:00:12.53,0:00:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.93,0:00:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:00:17.73,0:00:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.71,0:00:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:26.05,0:00:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.51,0:00:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:02:06.90,0:02:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, dengar baik-baik.
Dialogue: 0,0:02:08.52,0:02:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuncinya menilai dengan cermat.
Dialogue: 0,0:02:10.65,0:02:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe mesinnya, posisi hadiah.
Dialogue: 0,0:02:13.24,0:02:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan lengan capitnya dan sebagainya\Nharus diamati dengan cermat.
Dialogue: 0,0:02:18.79,0:02:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu diburu!
Dialogue: 0,0:02:20.91,0:02:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumit, ya.
Dialogue: 0,0:02:23.46,0:02:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang ayo kita praktikkan langsung!
Dialogue: 0,0:02:26.08,0:02:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin capit adalah pilihan klasik buat kencan.
Dialogue: 0,0:02:28.84,0:02:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilainya tinggi karena bisa sambil santai!
Dialogue: 0,0:02:31.13,0:02:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memupuk citra positif sangatlah penting!
Dialogue: 0,0:02:33.34,0:02:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus diburu!
Dialogue: 0,0:02:41.18,0:02:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh ribu yen melayang...
Dialogue: 0,0:02:42.85,0:02:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sebaiknya dihindari
Dialogue: 0,0:02:44.10,0:02:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum kamu terbiasa.
Dialogue: 0,0:02:45.73,0:02:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uangmu terisap, tuh.
Dialogue: 0,0:02:49.44,0:02:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo masukkan koinnya.\N- Ini sepertinya aku bisa.
Dialogue: 0,0:02:53.90,0:02:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini...
Dialogue: 0,0:02:55.32,0:02:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh! Aduh! Aduh! Aduh!
Dialogue: 0,0:02:59.87,0:03:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sidat laut...
Dialogue: 0,0:03:02.27,0:03:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamat!
Dialogue: 0,0:03:03.12,0:03:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempurna!
Dialogue: 0,0:03:04.41,0:03:06.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu nomor satu!
Dialogue: 0,0:03:06.04,0:03:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat!
Dialogue: 0,0:03:07.88,0:03:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang hebat, sih...
Dialogue: 0,0:03:10.29,0:03:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kayaknya kurang buat memukau wanita.
Dialogue: 0,0:03:13.97,0:03:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikutnya!
Dialogue: 0,0:03:17.14,0:03:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikutnya.
Dialogue: 0,0:03:18.43,0:03:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Matagi!\N- Ini terlalu spesifik.
Dialogue: 0,0:03:21.72,0:03:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo buat kenangan berburu\Nyang terkenang selamanya!
Dialogue: 0,0:03:28.31,0:03:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, kamu sudah dengar?
Dialogue: 0,0:03:30.77,0:03:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo hias sepenuh hatimu!\N- Pemburu Pembunuh Bayaran.
Dialogue: 0,0:03:34.82,0:03:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasus pembunuh bayaran yang punya nama
Dialogue: 0,0:03:37.36,0:03:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dihabisi satu per satu itu, ya.
Dialogue: 0,0:03:38.87,0:03:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan dan identitasnya tidak diketahui,
Dialogue: 0,0:03:41.03,0:03:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi lumayan ahli.
Dialogue: 0,0:03:43.55,0:03:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah membunuh Dan si Tukang Mutilasi\Ndan Kushima si Pengguna Tombak.
Dialogue: 0,0:03:47.67,0:03:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna itu puncak pembunuh bayaran.
Dialogue: 0,0:03:50.08,0:03:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi tidak banyak yang bisa adu fisik\Nmenghabisi Pengguna Tombak.
Dialogue: 0,0:03:54.52,0:03:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga harus hati-hati, ya.
Dialogue: 0,0:03:56.38,0:03:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:03:57.55,0:03:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, sudah jadi!
Dialogue: 0,0:03:59.68,0:04:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:04:01.31,0:04:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini itu asyik, ya?
Dialogue: 0,0:04:03.39,0:04:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cowok yang tidak antusias\Nitu tidak tenar, lo.
Dialogue: 0,0:04:07.10,0:04:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutarik ucapanku barusan.
Dialogue: 0,0:04:08.90,0:04:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenangannya, Gero.
Dialogue: 0,0:04:11.90,0:04:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenang-kenangan kalau pernah\Nseru-seruan bareng.
Dialogue: 0,0:04:14.90,0:04:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:04:17.27,0:04:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa kenangan ini boleh kucetak?\N- Kamu sendiri,
Dialogue: 0,0:04:19.66,0:04:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti senang kalau lawan bicaramu paham\Nbahasan camilan mainan, kan?
Dialogue: 0,0:04:23.53,0:04:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:04:25.37,0:04:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan memaksamu.
Dialogue: 0,0:04:27.71,0:04:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama yang disenangi pasangan,\NTapi kalau bisa sama-sama antusias
Dialogue: 0,0:04:31.38,0:04:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti menyenangkan sekali, kan?
Dialogue: 0,0:04:38.67,0:04:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya pu—
Dialogue: 0,0:04:48.83,0:04:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero Hikaru, aku ingin bicara denganmu.
Dialogue: 0,0:04:52.65,0:04:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sebelum itu...
Dialogue: 0,0:04:55.40,0:04:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo foto sama aku juga.
Dialogue: 0,0:04:59.11,0:05:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:05:03.49,0:05:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Arashiyama Kimie?
Dialogue: 0,0:05:06.29,0:05:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi menunggu kesempatan\Nkarena ada permintaan ke Gero, ya?
Dialogue: 0,0:05:11.92,0:05:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya permintaan bisa lewat Kerjaan Gelap?
Dialogue: 0,0:05:15.50,0:05:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis cantik yang lahir sekali dalam\N10 juta tahun datang menemuimu.
Dialogue: 0,0:05:19.55,0:05:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti senang banget, kan?
Dialogue: 0,0:05:24.22,0:05:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang, Gero.
Dialogue: 0,0:05:25.64,0:05:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tunggu!
Dialogue: 0,0:05:27.18,0:05:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, setidaknya tolong dengar dulu!
Dialogue: 0,0:05:29.89,0:05:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuntuti orang yang mau dimintai tolong itu\Ntidak baik buat membangun kepercayaan.
Dialogue: 0,0:05:34.40,0:05:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, maaf.
Dialogue: 0,0:05:36.98,0:05:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kupikir, jangan-jangan ini\NPemburu Pembunuh Bayaran mendatangi Gero.
Dialogue: 0,0:05:41.49,0:05:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, itu dia topiknya.
Dialogue: 0,0:05:43.49,0:05:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:05:44.95,0:05:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku juga seorang pengguna.
Dialogue: 0,0:05:48.04,0:05:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero Hikaru.
Dialogue: 0,0:05:49.50,0:05:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai Pemburu Pembunuh Bayaran itu\Nberhasil ditumpas, akan kuizinkan dirimu...
Dialogue: 0,0:05:54.75,0:05:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melindungi diriku!
Dialogue: 0,0:05:56.59,0:05:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang, yuk, pulang.
Dialogue: 0,0:05:57.75,0:05:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tu-tunggu dulu!
Dialogue: 0,0:05:59.80,0:06:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah seorang pengguna harusnya\Nbisa melindungi diri sendiri?
Dialogue: 0,0:06:03.59,0:06:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Habisnya aku bukan tipe petarung!
Dialogue: 0,0:06:07.43,0:06:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita dengar ceritanya sedikit lagi.
Dialogue: 0,0:06:11.43,0:06:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tapi...
Dialogue: 0,0:06:14.23,0:06:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pengguna sampai minta tolong\Nke keluarga yang tidak ada hubungannya...
Dialogue: 0,0:06:18.61,0:06:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti benaran sedang terpojok.
Dialogue: 0,0:06:22.32,0:06:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan, Arashiyama?
Dialogue: 0,0:06:24.82,0:06:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama...
Dialogue: 0,0:06:30.41,0:06:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei!
Dialogue: 0,0:06:35.88,0:06:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hikaru apa tidak terlalu baik?
Dialogue: 0,0:06:38.92,0:06:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, Arashiyama, kamu tidak apa-apa?\N- Sebentar, aku sekarang...
Dialogue: 0,0:06:41.09,0:06:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Arashiyama!\N- Sedang dipeluk Tuan Hikaru
Dialogue: 0,0:06:43.55,0:06:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Arashiyama!\N- dan memanggil-manggil namaku?
Dialogue: 0,0:06:45.43,0:06:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Arashiyama!\N- Dia mengingat namaku?
Dialogue: 0,0:06:46.80,0:06:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawaku diincar Pemburu Pembunuh Bayaran\Nsampai kepalaku kosong melompong.
Dialogue: 0,0:06:51.18,0:06:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukur bisa ketemu Tuan Hikaru\Ndari Keluarga Gero itu.
Dialogue: 0,0:06:53.64,0:06:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tanpa janji dan pasti mengganggu.
Dialogue: 0,0:06:56.56,0:07:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi menangkapku dengan selembut ini...
Dialogue: 0,0:07:00.19,0:07:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama...
Dialogue: 0,0:07:03.65,0:07:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama?
Dialogue: 0,0:07:08.12,0:07:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiknya kebangetan...
Dialogue: 0,0:07:11.62,0:07:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:12.75,0:07:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cekcok?
Dialogue: 0,0:07:13.50,0:07:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selingkuh?
Dialogue: 0,0:07:14.04,0:07:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta segitiga?
Dialogue: 0,0:07:15.04,0:07:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, keselamatanku sudah terjamin!
Dialogue: 0,0:07:18.29,0:07:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maju sini, Pemburu Pembunuh Bayaran!\N- Wah, jangan sampai kena
Dialogue: 0,0:07:20.96,0:07:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- orang bahaya kayak dia...\N- Tunggu...
Dialogue: 0,0:07:22.05,0:07:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku belum menerima permintaanmu...\N- Jangan dilihat.
Dialogue: 0,0:07:25.33,0:07:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara tertawanya lepas sekali.
Dialogue: 0,0:07:28.76,0:07:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini spesial, akan kutunjukkan padamu.
Dialogue: 0,0:07:31.26,0:07:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini pengguna apa.
Dialogue: 0,0:07:36.64,0:07:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cit, cit, cit, cit, cit.
Dialogue: 0,0:07:39.61,0:07:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dari meja itu lagi.\N- Jangan dilihat.
Dialogue: 0,0:07:40.98,0:07:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abaikan, abaikan.
Dialogue: 0,0:07:49.20,0:07:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamu!
Dialogue: 0,0:07:50.99,0:07:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan lagi.
Dialogue: 0,0:07:52.28,0:07:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Arashiyama Kimie si Pengguna Hamster.
Dialogue: 0,0:07:55.62,0:07:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu ini partnerku, Sirius.
Dialogue: 0,0:07:58.25,0:08:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero Hikaru, dia juga\Nyang menemukanmu di tengah kota.
Dialogue: 0,0:08:03.59,0:08:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengumpulkan informasi\Ndan trik rumit adalah keahlianku.
Dialogue: 0,0:08:07.13,0:08:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentunya, dengan meminjam\Nkekuatan mereka.
Dialogue: 0,0:08:10.26,0:08:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut sekali!
Dialogue: 0,0:08:12.22,0:08:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamu!
Dialogue: 0,0:08:13.26,0:08:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamu.
Dialogue: 0,0:08:14.60,0:08:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabang keluarga Pengguna Binatang, ya.
Dialogue: 0,0:08:16.81,0:08:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna adalah seorang ahli\Ndalam pembunuhan.
Dialogue: 0,0:08:20.02,0:08:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak selalu ahli pertarungan langsung.
Dialogue: 0,0:08:22.65,0:08:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri lebih spesifik\Nfokus ke asasinasi dan perangkap.
Dialogue: 0,0:08:26.11,0:08:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu hitungannya belum ahli?
Dialogue: 0,0:08:29.11,0:08:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau berurusan dengan\NPemburu Pembunuh Bayaran.
Dialogue: 0,0:08:33.03,0:08:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi perkumpulan tempat keluargaku bergabung,
Dialogue: 0,0:08:35.58,0:08:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}begitu semangat ingin menumpas\NPemburu Pembunuh Bayaran.
Dialogue: 0,0:08:39.21,0:08:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merasa bahaya makanya ingin dikawal.
Dialogue: 0,0:08:41.46,0:08:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, begitu.
Dialogue: 0,0:08:42.84,0:08:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau ada perkumpulan keluarga,\Nkenapa tidak minta dilindungi mere—
Dialogue: 0,0:08:47.09,0:08:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil.
Dialogue: 0,0:08:49.80,0:08:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kakek buyutku adalah\Ngenerasi Pengguna Tikus
Dialogue: 0,0:08:53.35,0:08:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang katanya diakui dan punya pengaruh\Ndi keluarga utama Pengguna Binatang.
Dialogue: 0,0:08:58.28,0:09:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang darah itu sudah memudar
Dialogue: 0,0:09:00.35,0:09:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merosot sampai status pengguna kami\Nbisa dicabut kapan saja.
Dialogue: 0,0:09:06.95,0:09:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri belum pernah membunuh.
Dialogue: 0,0:09:10.20,0:09:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghubungnya hanya kalung ini.
Dialogue: 0,0:09:12.66,0:09:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajib dipakai oleh\Nkeluarga cabang Pengguna Binatang.
Dialogue: 0,0:09:15.91,0:09:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena seperti itulah keadaannya.
Dialogue: 0,0:09:18.91,0:09:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat datang di waktu perkumpulan saja,
Dialogue: 0,0:09:21.67,0:09:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahasan pentingnya sudah selesai\Ntanpa kehadiranku.
Dialogue: 0,0:09:24.71,0:09:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pembasmian kali ini juga sama.
Dialogue: 0,0:09:27.59,0:09:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang di depan mukaku.
Dialogue: 0,0:09:29.97,0:09:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna tanpa kemampuan\Ndan prestasi membunuh
Dialogue: 0,0:09:32.26,0:09:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hidup normal dan kerja kantoran biasa
Dialogue: 0,0:09:35.64,0:09:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik jadi tameng hidup saja.
Dialogue: 0,0:09:42.02,0:09:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih untuk hari ini.
Dialogue: 0,0:09:44.03,0:09:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tenang.
Dialogue: 0,0:09:45.68,0:09:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:46.65,0:09:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kuucapkan karena terbawa suasana.
Dialogue: 0,0:09:48.73,0:09:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penerus Lima Keluarga Besar
Dialogue: 0,0:09:50.28,0:09:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mana mungkin mengawal\Nkeroco keluarga cabang, kan?
Dialogue: 0,0:09:53.53,0:09:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku mana bisa bayar\Nbiaya permintaan yang besar.
Dialogue: 0,0:09:57.79,0:10:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah bisa bertemu idolaku\Nsebelum aku mati.
Dialogue: 0,0:10:01.37,0:10:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Per hari sepuluh ribu yen.
Dialogue: 0,0:10:04.12,0:10:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai kapan aku harus mengawalmu?
Dialogue: 0,0:10:06.13,0:10:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin, Gero?
Dialogue: 0,0:10:08.92,0:10:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya...
Dialogue: 0,0:10:11.22,0:10:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benaran dalam masalah, kan, Arashiyama?
Dialogue: 0,0:10:17.64,0:10:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kayaknya bukan masalah.
Dialogue: 0,0:10:20.16,0:10:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang melenceng\Ndari rencana pencarian jodohku.
Dialogue: 0,0:10:22.81,0:10:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi daya tarik Gero mulai terpoles.
Dialogue: 0,0:10:25.65,0:10:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, bagus.
Dialogue: 0,0:10:30.99,0:10:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat fan servis ekstra!
Dialogue: 0,0:10:32.99,0:10:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, aku harus bagaimana?
Dialogue: 0,0:10:35.32,0:10:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluk balik saja, sana.
Dialogue: 0,0:10:37.37,0:10:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Mana bisa!
Dialogue: 0,0:10:43.58,0:10:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu dia.
Dialogue: 0,0:10:45.50,0:10:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yo!\N- Hamu!
Dialogue: 0,0:10:46.54,0:10:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero Hikaru dan asistennya!
Dialogue: 0,0:10:48.71,0:10:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuajak kalian setor muka\Nke perkumpulan keluargaku.
Dialogue: 0,0:10:51.42,0:10:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamu!
Dialogue: 0,0:10:52.55,0:10:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu bakal terlibat nantinya.\NSoalnya, mau tidak mau
Dialogue: 0,0:10:55.76,0:10:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau aku bawa Gero Hikaru,\N- Ternyata ini sifat aslinya Arashiyama?
Dialogue: 0,0:10:57.55,0:10:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- mereka pasti bakal kaget!\N- Ternyata ini sifat aslinya Arashiyama?
Dialogue: 0,0:10:59.26,0:11:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang paling nyentrik dari selama ini.
Dialogue: 0,0:11:02.02,0:11:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia juga seorang pengguna.
Dialogue: 0,0:11:03.98,0:11:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu orang seperti ini\Nmalah cocok sama Gero.
Dialogue: 0,0:11:09.77,0:11:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempatnya.
Dialogue: 0,0:11:11.65,0:11:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung saja kuperkenalkan.
Dialogue: 0,0:11:13.61,0:11:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Ular Besar, Ryumon.
Dialogue: 0,0:11:15.61,0:11:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Burung Hantu, Chojabaru.
Dialogue: 0,0:11:17.87,0:11:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Kuda Nil, Shibaseki.
Dialogue: 0,0:11:19.87,0:11:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Paus Pembunuh, Kankaiji.
Dialogue: 0,0:11:21.87,0:11:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Kerbau, Horita.
Dialogue: 0,0:11:23.87,0:11:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Buaya, Hamawaki.
Dialogue: 0,0:11:29.71,0:11:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi tidur siang?
Dialogue: 0,0:11:31.38,0:11:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, para manusianya...
Dialogue: 0,0:11:34.30,0:11:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah mati.
Dialogue: 0,0:11:44.77,0:11:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda juga dari perkumpulan?
Dialogue: 0,0:11:46.27,0:11:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:11:48.29,0:11:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:11:49.02,0:11:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:50.94,0:11:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, Arashiyama, lari!
Dialogue: 0,0:12:01.03,0:12:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kamu Pengguna Racun, kan?
Dialogue: 0,0:12:05.79,0:12:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu kenapa\Nkamu bisa ada di sini.
Dialogue: 0,0:12:09.54,0:12:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pas sekali,\Njadi tidak repot kucari lagi.
Dialogue: 0,0:12:14.63,0:12:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bisa menyingkirkan buruan besar.
Dialogue: 0,0:12:26.18,0:12:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia barusan menusuk?
Dialogue: 0,0:12:28.94,0:12:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:12:30.19,0:12:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari! Cepat!
Dialogue: 0,0:12:37.15,0:12:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang nyaris, tapi luka fatal\Nberhasil kuhindari.
Dialogue: 0,0:12:39.82,0:12:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendarahan juga sudah berhenti\Nwalau cuma sementara.
Dialogue: 0,0:12:43.24,0:12:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Pemburu Pembunuh Bayaran, ya?
Dialogue: 0,0:12:45.54,0:12:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuanmu?
Dialogue: 0,0:13:01.97,0:13:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma dengan sebilah pisau?
Dialogue: 0,0:13:05.72,0:13:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan teknik manusia biasa!
Dialogue: 0,0:13:22.20,0:13:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bagus bertarung lama-lama.
Dialogue: 0,0:13:24.16,0:13:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan menyiapkan jebakan?\NNihil.
Dialogue: 0,0:13:27.49,0:13:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tidak mau harus kuhadapi langsung.
Dialogue: 0,0:13:30.31,0:13:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung kupakai maksimal dari awal!
Dialogue: 0,0:13:33.38,0:13:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan laju reaksi penglihatan,
Dialogue: 0,0:13:35.96,0:13:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin: Netra!
Dialogue: 0,0:13:37.71,0:13:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan daya hantam otot,
Dialogue: 0,0:13:40.17,0:13:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin: Cipta Lembing!
Dialogue: 0,0:13:44.55,0:13:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung kuhabisi dengan dosis dobel!
Dialogue: 0,0:14:13.00,0:14:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:14:14.50,0:14:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, salah?
Dialogue: 0,0:14:19.51,0:14:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Pengguna Racun itu juga\Npembunuh bayaran, kan?
Dialogue: 0,0:14:23.76,0:14:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi pengawal?\NKerja paruh waktu di Kerjaan Gelap
Dialogue: 0,0:14:26.55,0:14:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin ada yang salah?
Dialogue: 0,0:14:29.18,0:14:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin Lima Keluarga Besar\Nkerja paruh waktu.
Dialogue: 0,0:14:32.68,0:14:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lumayan bahaya sampai memakai\Ndua suntikan ke dirinya sendiri, lo.
Dialogue: 0,0:14:37.65,0:14:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, begitu.
Dialogue: 0,0:14:39.57,0:14:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dua suntikan sekaligus itu\Nberbahaya, kan?
Dialogue: 0,0:14:43.32,0:14:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya memang lebih baik\Nkubereskan di sini saja.
Dialogue: 0,0:14:46.89,0:14:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:50.49,0:14:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyerang pertama yang menang!
Dialogue: 0,0:15:18.77,0:15:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja?
Dialogue: 0,0:15:19.86,0:15:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa kulihat meski dengan Toxin: Netra?
Dialogue: 0,0:15:23.36,0:15:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir saja.
Dialogue: 0,0:15:27.87,0:15:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua aman?
Dialogue: 0,0:15:34.41,0:15:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik pada hewan, ya.
Dialogue: 0,0:15:37.96,0:15:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang mereka berbuat jahat?
Dialogue: 0,0:15:40.67,0:15:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu ini sebenarnya?
Dialogue: 0,0:15:42.88,0:15:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabang dari Pengguna Besi, ya?
Dialogue: 0,0:15:45.13,0:15:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku cuma warga sipil.
Dialogue: 0,0:15:48.72,0:15:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil?
Dialogue: 0,0:15:49.76,0:15:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan dari keluarga mana pun?
Dialogue: 0,0:15:51.10,0:15:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu bohong pada orang\Nyang sebentar lagi mati.
Dialogue: 0,0:15:55.39,0:15:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kerabatku adalah guru.
Dialogue: 0,0:16:01.19,0:16:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini... mutasi, ya?
Dialogue: 0,0:16:05.53,0:16:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Monster yang dalam satu generasi\N- Maaf, bisa segera kita selesaikan?
Dialogue: 0,0:16:07.78,0:16:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maaf, bisa segera kita selesaikan?\N- bisa mengungguli kekuatan
Dialogue: 0,0:16:09.03,0:16:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- keturunan pengguna yang sudah\N- Aku ada janji makan siang
Dialogue: 0,0:16:11.16,0:16:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dibangun turun-temurun.\N- dengan pacarku soalnya.
Dialogue: 0,0:16:12.45,0:16:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski belum kucoba sebelumnya.\NSialan, kalau begini,
Dialogue: 0,0:16:15.95,0:16:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pilihan lain.
Dialogue: 0,0:16:18.37,0:16:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin: Tripel!
Dialogue: 0,0:16:21.63,0:16:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, kenapa malah berusaha\Nmenghabisi diri sendiri begitu?
Dialogue: 0,0:16:29.89,0:16:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin: Tripel di kondisi terluka...
Dialogue: 0,0:16:34.64,0:16:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya memang akan overdosis.
Dialogue: 0,0:16:37.68,0:16:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya sudah kubilang.
Dialogue: 0,0:16:40.15,0:16:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membunuh orang dan menebar kebencian.\NIni balasan karena sudah banyak
Dialogue: 0,0:16:48.53,0:16:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah.
Dialogue: 0,0:16:53.28,0:16:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjanjilah!
Dialogue: 0,0:16:56.45,0:16:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh... mereka berdua!
Dialogue: 0,0:17:00.61,0:17:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:17:08.92,0:17:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemburu Pembunuh Bayaran!
Dialogue: 0,0:17:12.26,0:17:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan Gero Hikaru\Nkamu bunuh!
Dialogue: 0,0:17:14.55,0:17:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Arashiyama?
Dialogue: 0,0:17:16.27,0:17:19.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau mengganggu,\Nkalian juga harus kusingkirkan.
Dialogue: 0,0:17:19.94,0:17:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel, bodoh! Bego!
Dialogue: 0,0:17:22.94,0:17:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebar kebencian katamu?\NMana mungkin itu!
Dialogue: 0,0:17:27.07,0:17:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau sudah dengan senang hati\Nmau mengawal orang sepertiku, tahu!
Dialogue: 0,0:17:31.95,0:17:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan mau jadi tameng hidup\Norang-orang berengsek!
Dialogue: 0,0:17:35.12,0:17:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau untuk idolaku,\Nmati pun aku rela!
Dialogue: 0,0:17:40.08,0:17:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan Sirius.
Dialogue: 0,0:17:51.47,0:17:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo maju.
Dialogue: 0,0:17:54.01,0:17:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan:
Dialogue: 0,0:17:56.76,0:17:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanis Mayor!
Dialogue: 0,0:17:59.47,0:18:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kilau terang di langit musim dingin...
Dialogue: 0,0:18:03.19,0:18:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasi Bintang Anjing Besar!
Dialogue: 0,0:18:05.23,0:18:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:18:14.36,0:18:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tu-Tunggu, mau apa kamu?\N- Hei, turunkan aku!
Dialogue: 0,0:18:16.58,0:18:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa?\NMau kubawa ke rumah sakit.
Dialogue: 0,0:18:19.91,0:18:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia sekarat.
Dialogue: 0,0:18:21.41,0:18:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:22.04,0:18:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatinya berubah karena Kanis Mayor?
Dialogue: 0,0:18:24.83,0:18:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kamu datang untuk membunuhku?
Dialogue: 0,0:18:27.13,0:18:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah membiarkanku hidup?
Dialogue: 0,0:18:31.13,0:18:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku melihat\Nsesama pengguna saling melindungi.
Dialogue: 0,0:18:35.64,0:18:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tidak ingin membunuhmu lagi.
Dialogue: 0,0:18:37.89,0:18:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa alasan itu tidak cukup?
Dialogue: 0,0:18:43.14,0:18:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:45.27,0:18:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunkan aku.
Dialogue: 0,0:18:46.77,0:18:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ke rumah sakit?
Dialogue: 0,0:18:47.94,0:18:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma begini bisa kusembuhkan sendiri.
Dialogue: 0,0:18:51.28,0:18:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Nakagawa Piichi.
Dialogue: 0,0:18:54.03,0:18:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin jadi bantal paha\Nuntuk Tuan Hikaru.
Dialogue: 0,0:18:56.95,0:18:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuanku adalah
Dialogue: 0,0:18:59.04,0:19:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melenyapkan Pengguna Binatang,\Nsalah satu dari Lima Keluarga Besar.
Dialogue: 0,0:19:03.40,0:19:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Pengguna Binatang merencanakan
Dialogue: 0,0:19:05.75,0:19:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sesuatu yang berbahaya dan akan\Nmembunuh banyak orang.
Dialogue: 0,0:19:08.50,0:19:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku berpikir untuk menghabisinya\Nsebelum terjadi kerugian besar.
Dialogue: 0,0:19:12.97,0:19:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, kenapa selain Pengguna Binatang\Njuga diburu?
Dialogue: 0,0:19:16.00,0:19:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian saja.
Dialogue: 0,0:19:17.18,0:19:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian?
Dialogue: 0,0:19:18.26,0:19:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar tidak tahu
Dialogue: 0,0:19:20.35,0:19:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lokasi Pengguna Binatang,
Dialogue: 0,0:19:22.02,0:19:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku keliling menanyai orang\Nyang mungkin ada hubungannya.
Dialogue: 0,0:19:25.81,0:19:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti pembunuh yang dulu pernah\Nbertransaksi dengan Pengguna Binatang.
Dialogue: 0,0:19:29.69,0:19:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek dengan tongkat berbilah,\Nanggota keluarga cabang dan semacamnya.
Dialogue: 0,0:19:34.28,0:19:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang berbahaya\Nsekalian saja kusingkirkan.
Dialogue: 0,0:19:38.87,0:19:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa maksudnya?
Dialogue: 0,0:19:41.16,0:19:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan si Tukang Mutilasi tidak minta uang\Nsebagai upah membunuh,
Dialogue: 0,0:19:44.96,0:19:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi selalu meminta pria di atas 80 tahun.
Dialogue: 0,0:19:48.33,0:19:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan Kushima si Pengguna Tombak,
Dialogue: 0,0:19:50.21,0:19:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak segan melibatkan warga sipil\Nbila itu demi pekerjaan.
Dialogue: 0,0:19:55.22,0:19:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendirikan kafe\Nbersama pacarku.
Dialogue: 0,0:20:00.55,0:20:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku tidak melenyapkan\Nsemua orang berbahaya seperti mereka,
Dialogue: 0,0:20:06.52,0:20:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nanti para pelanggan tidak bisa bersantai.
Dialogue: 0,0:20:11.90,0:20:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bantal pahanya apa enggak kelamaan?\N- Hamu!
Dialogue: 0,0:20:14.15,0:20:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengajak ribut Lima Keluarga Besar,\Nkamu sudah gila, ya?
Dialogue: 0,0:20:17.90,0:20:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, orang jahat bukankah lebih baik\Nkalau lenyap saja?
Dialogue: 0,0:20:23.08,0:20:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir seperti biasa,\Nitu cuma khayalan belaka.
Dialogue: 0,0:20:27.00,0:20:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dengan kekuatannya itu,\Nmungkin saja...
Dialogue: 0,0:20:30.42,0:20:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir keluarga Gero\Nsang Pengguna Racun juga berbahaya,
Dialogue: 0,0:20:35.35,0:20:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi nyatanya tidak.
Dialogue: 0,0:20:38.41,0:20:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukanlah sosok yang akan\Nmenghancurkan dunia impianku.
Dialogue: 0,0:20:43.26,0:20:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, untuk sekarang.
Dialogue: 0,0:20:47.60,0:20:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu akan melepaskan kami, ya?
Dialogue: 0,0:20:50.91,0:20:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamu!
Dialogue: 0,0:20:51.77,0:20:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, satu masalah beres!
Dialogue: 0,0:20:56.39,0:20:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero.
Dialogue: 0,0:20:57.42,0:21:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari koneksi Lima Keluarga Besar,\Napa tahu sesuatu soal Pengguna Binatang?
Dialogue: 0,0:21:02.03,0:21:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku tahu.
Dialogue: 0,0:21:04.08,0:21:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima Keluarga Besar dipanggil begitu\Nhanya biar praktis,
Dialogue: 0,0:21:07.16,0:21:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan berarti punya koneksi khusus.
Dialogue: 0,0:21:09.62,0:21:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:21:12.63,0:21:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai keluarga cabang Pengguna Binatang,\Napa kamu tahu sesuatu?
Dialogue: 0,0:21:17.20,0:21:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah ke keluarga utama\Natau ketemu mereka!
Dialogue: 0,0:21:20.01,0:21:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:21:21.13,0:21:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kutahu cuma kalung yang dibagi—
Dialogue: 0,0:21:27.18,0:21:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama!
Dialogue: 0,0:21:31.35,0:21:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelelawar?
Dialogue: 0,0:21:33.52,0:21:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisi Arashiyama bagaimana?
Dialogue: 0,0:21:35.27,0:21:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu!
Dialogue: 0,0:21:36.61,0:21:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyebabnya kalung ini, ya?
Dialogue: 0,0:21:38.49,0:21:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau kamu mau menghancurkannya,\Ndia akan mengisap habis darah inangnya.
Dialogue: 0,0:21:43.91,0:21:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk hias yang sudah dimodifikasi\Ndengan organ pengisap darah, Tali Pengikat.
Dialogue: 0,0:21:48.45,0:21:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuaktifkan paksa.
Dialogue: 0,0:21:50.37,0:21:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawa wanita ini paling lama\Ntinggal tiga hari lagi.
Dialogue: 0,0:21:53.75,0:21:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa diberi benda seperti ini?
Dialogue: 0,0:21:55.29,0:21:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka lari bisa repot, kan?
Dialogue: 0,0:21:57.25,0:21:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para hewan ternaknya.
Dialogue: 0,0:22:00.84,0:22:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pasang muka seram seperti itu,\NGero Hikaru, Nakagawa Piichi.
Dialogue: 0,0:22:05.60,0:22:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian mencariku,\Nbiar aku undang kalian.
Dialogue: 0,0:22:09.72,0:22:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke marka beras Pengguna Binatang,\NKerajaan Hewan Dogo!
Dialogue: 0,0:23:46.03,0:23:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Telingaku muak mendengar ceritamu!\N- Cara mudah memotong cumi-cumi.
Dialogue: 0,0:23:47.74,0:23:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Telingaku muak mendengar ceritamu!\N- Hanezawa Gota!
Dialogue: 0,0:23:48.66,0:23:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini 100% jelas-jelas jebakan!\N- Kemampuan tipe ahli bertempur langsung?
Dialogue: 0,0:23:50.70,0:23:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pasti lezat...\N- Kemampuan tipe ahli bertempur langsung?
Dialogue: 0,0:23:53.20,0:23:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Kerajaan Hewan.
