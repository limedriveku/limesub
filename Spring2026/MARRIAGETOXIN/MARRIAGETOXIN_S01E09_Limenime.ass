Dialogue: 0,0:00:43.56,0:00:46.28,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:04:42.64,0:04:44.85,sign,,0000,0000,0000,,TOXIN: TARIAN KAKI
Dialogue: 0,0:05:00.15,0:05:01.61,sign,,0000,0000,0000,,SUPER MUDAH! CARA MEMOTONG CUMI-CUMI
Dialogue: 0,0:05:01.61,0:05:03.49,sign,,0000,0000,0000,,YANG MALU ANDA DITANYAKAN!
Dialogue: 0,0:05:03.49,0:05:04.91,sign,,0000,0000,0000,,BISA UNTUK CUMI-CUMI RAKSASA
Dialogue: 0,0:05:21.43,0:05:24.05,sign,,0000,0000,0000,,KELUARKAN ISI PERUT DARI BADAN CUMI-CUMI!
Dialogue: 0,0:05:38.15,0:05:40.15,sign,,0000,0000,0000,,KELUARKAN TINTA CUMI-CUMINYA!
Dialogue: 0,0:08:26.28,0:08:29.28,sign,,0000,0000,0000,,BISBOL BURUNG: BIRDSBALL
Dialogue: 0,0:08:33.15,0:08:37.90,sign,,0000,0000,0000,,MONITOR TELUR IKAN
Dialogue: 0,0:09:36.06,0:09:38.85,sign,,0000,0000,0000,,MUTASI KETURUNAN - BIRDSBALL
Dialogue: 0,0:09:38.85,0:09:41.39,sign,,0000,0000,0000,,STADION PEMAKAMAN LANGIT
Dialogue: 0,0:10:07.21,0:10:10.63,sign,,0000,0000,0000,,BIRDSBALL: SAYAP BESI PARUH AKHIR
Dialogue: 0,0:10:33.82,0:10:35.70,sign,,0000,0000,0000,,GRANAT ASAP - EKSTRA TEBAL!
Dialogue: 0,0:11:52.65,0:11:56.53,sign,,0000,0000,0000,,GERO HIKARU
Dialogue: 0,0:13:19.99,0:13:22.03,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:13:22.03,0:13:24.03,sign,,0000,0000,0000,,KERAJAAN HEWAN
Dialogue: 0,0:13:24.49,0:13:26.91,sign,,0000,0000,0000,,PENGGUNA TOMBAK, KUSHIMA NAGIHIKO
Dialogue: 0,0:13:26.91,0:13:29.12,sign,,0000,0000,0000,,USIA WAFAT, 72 TAHUN
Dialogue: 0,0:13:29.12,0:13:30.54,sign,,0000,0000,0000,,SKOR KORBAN YANG DIBUNUH: 887 ORANG
Dialogue: 0,0:13:30.54,0:13:32.29,sign,,0000,0000,0000,,TANPA MEMANDANG USIA DAN JENIS KELAMIN
Dialogue: 0,0:13:32.29,0:13:34.29,sign,,0000,0000,0000,,KEAHLIANNYA ADALAH
Dialogue: 0,0:13:34.29,0:13:35.88,sign,,0000,0000,0000,,TEKNIK YANG HANYA ADA DI DARAH KELUARGA
Dialogue: 0,0:13:35.88,0:13:37.30,sign,,0000,0000,0000,,YANG MENDEDIKASIKAN SEGALANYA
Dialogue: 0,0:13:37.30,0:13:38.05,sign,,0000,0000,0000,,PADA TOMBAK
Dialogue: 0,0:13:38.80,0:13:42.55,sign,,0000,0000,0000,,88 KALI/DETIK
Dialogue: 0,0:13:42.55,0:13:43.76,sign,,0000,0000,0000,,TUSUKAN
Dialogue: 0,0:13:59.49,0:14:01.49,sign,,0000,0000,0000,,PENGGUNA TOMBAK BURUNG
Dialogue: 0,0:14:30.93,0:14:34.14,sign,,0000,0000,0000,,TONGKAT BURUNG
Dialogue: 0,0:15:14.77,0:15:16.69,sign,,0000,0000,0000,,KERAJAAN HEWAN DOGO
Dialogue: 0,0:15:16.69,0:15:19.27,sign,,0000,0000,0000,,MUNGKIN DI SEKITAR SINI
Dialogue: 0,0:17:06.05,0:17:08.51,sign,,0000,0000,0000,,MATI
Dialogue: 0,0:20:11.61,0:20:16.15,sign,,0000,0000,0000,,PIICHI - GERO
Dialogue: 0,0:20:31.08,0:20:33.21,sign,,0000,0000,0000,,PIICHI - GERO
Dialogue: 0,0:23:53.24,0:23:56.00,sign,,0000,0000,0000,,TIDAK BERGUNA
Dialogue: 0,0:00:12.53,0:00:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.91,0:00:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:00:17.50,0:00:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.75,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:25.63,0:00:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.51,0:00:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:02:13.86,0:02:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, kenapa kamu punya lisensi\Nmengemudi kapal kecil kelas satu?
Dialogue: 0,0:02:17.70,0:02:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya om-om tajir banyak yang suka.
Dialogue: 0,0:02:20.62,0:02:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya banyak lisensi lain, lo.
Dialogue: 0,0:02:22.91,0:02:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasi terapan, sekretaris,\Npencicip sake, pencocok warna, pilot drone.
Dialogue: 0,0:02:28.04,0:02:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ahli kosmetik, somelier kaldu,\N- Penipu Pernikahan memang ajaib.
Dialogue: 0,0:02:30.17,0:02:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- pemandu tur pemandangan malam.\N- Penipu Pernikahan memang ajaib.
Dialogue: 0,0:02:31.21,0:02:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akuntansi, agen properti...
Dialogue: 0,0:02:32.34,0:02:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kelihatannya lumayan tenang,
Dialogue: 0,0:02:35.18,0:02:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi cara melepas kalung itu\Nmasih belum diketahui.
Dialogue: 0,0:02:37.85,0:02:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun caranya entah itu dengan\Nserum kebenaran dan sebagainya,
Dialogue: 0,0:02:40.97,0:02:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kubuat Pengguna Binatang mengatakannya.
Dialogue: 0,0:02:42.89,0:02:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oke!\N- Hamu!
Dialogue: 0,0:02:44.56,0:02:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berpisah di sini.
Dialogue: 0,0:02:46.06,0:02:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengantarku.
Dialogue: 0,0:02:48.36,0:02:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permintaanku untuk melindungi dari\NPemburu Pembunuh Bayaran sudah selesai, kan?
Dialogue: 0,0:02:53.03,0:02:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai dari sini, biar aku sendiri\Nyang mengajak mereka bicara.
Dialogue: 0,0:02:56.82,0:02:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar mau melepaskanku.
Dialogue: 0,0:02:59.20,0:03:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, kalian sudah tidak dibutuhkan lagi!
Dialogue: 0,0:03:04.12,0:03:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama, itu pasti caramu\Nmenunjukkan sungkan...
Dialogue: 0,0:03:07.33,0:03:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar! Maksudku itu...
Dialogue: 0,0:03:09.67,0:03:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini 100% jelas-jelas jebakan!
Dialogue: 0,0:03:13.13,0:03:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti mengincar nyawa Gero Hikaru\Ndari Lima Keluarga Besar.
Dialogue: 0,0:03:17.34,0:03:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak mau.
Dialogue: 0,0:03:19.18,0:03:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membahayakan nyawamu gara-gara aku.
Dialogue: 0,0:03:22.52,0:03:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang ingin melakukannya.
Dialogue: 0,0:03:24.02,0:03:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:25.06,0:03:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di sini aku mengabaikan\Norang yang kesulitan.
Dialogue: 0,0:03:28.48,0:03:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku tidak akan bisa\Nmembuat siapa pun bahagia.
Dialogue: 0,0:03:42.08,0:03:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun tidak keberatan asal bisa\Nmenghabisi Pengguna Binatang.
Dialogue: 0,0:03:50.00,0:03:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, terima kasih bantuannya.
Dialogue: 0,0:03:52.00,0:03:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggulah di pelabuhan kita berangkat\Nsampai kukabari.
Dialogue: 0,0:03:55.30,0:03:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mulai dari sini,\Naku tidak bisa memintamu untuk ikut.
Dialogue: 0,0:03:58.72,0:04:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunggu sambil menyiapkan\Npencarian jodoh selanjutnya.
Dialogue: 0,0:04:01.64,0:04:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kamu kembali, ya.
Dialogue: 0,0:04:03.31,0:04:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:04.60,0:04:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Binatang pasti memanfaatkan\NArashiyama sebagai umpan
Dialogue: 0,0:04:07.44,0:04:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menghabisiku dan Piichi sekaligus.
Dialogue: 0,0:04:10.61,0:04:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda denganmu yang sudah mengejar ke mana-mana,
Dialogue: 0,0:04:13.15,0:04:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak ingat\Nmereka punya dendam padaku.
Dialogue: 0,0:04:15.49,0:04:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka menganggapku\Nsaingan bisnis dari Lima Keluarga Besar...
Dialogue: 0,0:04:30.50,0:04:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cumi-cumi dan elang?
Dialogue: 0,0:04:31.96,0:04:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Binatang menyergap?
Dialogue: 0,0:04:33.50,0:04:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting rebut Arashiyama!
Dialogue: 0,0:04:42.64,0:04:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin: Tarian Kaki!
Dialogue: 0,0:04:44.85,0:04:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:04:59.03,0:05:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Super mudah!
Dialogue: 0,0:05:00.15,0:05:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara memotong cumi-cumi
Dialogue: 0,0:05:01.61,0:05:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang malu Anda tanyakan!
Dialogue: 0,0:05:03.49,0:05:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:05:04.91,0:05:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kamu mengganggu,\Njadi akan kupotong.
Dialogue: 0,0:05:12.42,0:05:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mengejutkan!\NTernyata Pengguna Racun
Dialogue: 0,0:05:16.63,0:05:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa berlari di atas laut?
Dialogue: 0,0:05:20.47,0:05:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langkah pertama,
Dialogue: 0,0:05:21.43,0:05:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keluarkan isi perut dari tubuh cumi-cumi.
Dialogue: 0,0:05:24.05,0:05:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, taruh cumi-cumi\Nyang sudah disiapkan di talenan.
Dialogue: 0,0:05:27.56,0:05:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik tentakel\Nuntuk mengeluarkan isi perutnya.
Dialogue: 0,0:05:31.89,0:05:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua tentakelnya mengganggu.
Dialogue: 0,0:05:34.65,0:05:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, pertama keluarkan isi perutnya dulu...
Dialogue: 0,0:05:37.32,0:05:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langkah kedua.
Dialogue: 0,0:05:38.15,0:05:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita keluarkan tinta cumi-cuminya.
Dialogue: 0,0:05:40.15,0:05:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belah memanjang tubuh cumi-cumi\Nyang sudah diambil tentakelnya,
Dialogue: 0,0:05:43.20,0:05:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu ambil dan buang kantong tintanya.
Dialogue: 0,0:05:49.04,0:05:52.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir, potong-potong jadi ukuran\Nyang mudah disantap.
Dialogue: 0,0:05:53.79,0:05:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini...
Dialogue: 0,0:05:56.46,0:06:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemampuan asli ahli pertarungan langsung\Nyang dibilang Gero?
Dialogue: 0,0:06:04.93,0:06:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bisa kutambahkan menu\Npasta tinta cumi di kafe.
Dialogue: 0,0:06:08.01,0:06:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:09.06,0:06:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku yang duluan, ya!
Dialogue: 0,0:06:11.39,0:06:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang hebat!
Dialogue: 0,0:06:12.89,0:06:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria tercepat di dunia, Hanezawa...
Dialogue: 0,0:06:15.40,0:06:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gota!\N- Dia bukan Pengguna Binatang.
Dialogue: 0,0:06:19.15,0:06:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari penampilannya, kemungkinan\NPengguna Burung dari keluarga cabang.
Dialogue: 0,0:06:23.28,0:06:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaki tangan keluarga utama.
Dialogue: 0,0:06:25.82,0:06:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ingin kalian lakukan?
Dialogue: 0,0:06:28.12,0:06:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai menyandera dan memancing kemari.
Dialogue: 0,0:06:29.95,0:06:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mengincar nyawa kami?
Dialogue: 0,0:06:33.41,0:06:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku tahu.
Dialogue: 0,0:06:35.00,0:06:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:06:36.04,0:06:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalaupun tahu, mana mungkin mau bilang.\N- Yang jelas.
Dialogue: 0,0:06:38.50,0:06:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa memburu kalian,\Naku bisa hidup mewah selamanya.
Dialogue: 0,0:06:42.51,0:06:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai pastinya tidak bisa kusebut\Nkarena kontrak rahasia,
Dialogue: 0,0:06:45.51,0:06:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sebut saja jumlahnya puluhan miliar.
Dialogue: 0,0:06:49.76,0:06:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa menculik Arashiyama?
Dialogue: 0,0:06:51.52,0:06:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diperintah untuk menjadikannya sandera\Nagar mudah mengalahkanmu.
Dialogue: 0,0:06:55.52,0:06:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau sebenarnya ogah,\Naku juga pengguna.
Dialogue: 0,0:06:58.52,0:07:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan bawa\Nurusan pribadi ke pekerjaan.
Dialogue: 0,0:07:00.78,0:07:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tampangku begini,\Naslinya aku mudah tersentuh.
Dialogue: 0,0:07:04.24,0:07:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, aku pernah melanggar\Nprinsipku sendiri sekali.
Dialogue: 0,0:07:07.53,0:07:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, itu malam bersalju\Nyang tidak biasa di bulan Maret.
Dialogue: 0,0:07:11.20,0:07:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat sedang ke minimarket\Nsambil latihan lari ke base.
Dialogue: 0,0:07:14.00,0:07:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba teman bangauku...
Dialogue: 0,0:07:15.37,0:07:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini tipe yang cerewet!
Dialogue: 0,0:07:18.54,0:07:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah kisah pertemuanku dengan dia.
Dialogue: 0,0:07:22.30,0:07:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara melepas Tali Ikatan?
Dialogue: 0,0:07:25.42,0:07:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja kamu...
Dialogue: 0,0:07:26.68,0:07:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencoba cari tahu itu adalah kesalahan.
Dialogue: 0,0:07:29.80,0:07:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainan dimulai!
Dialogue: 0,0:07:32.52,0:07:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan-rekan timku,\Nayo semangat habisi dia!
Dialogue: 0,0:07:44.74,0:07:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik Pukulan Burung!
Dialogue: 0,0:07:49.12,0:07:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecepatannya gila sekali!
Dialogue: 0,0:07:51.33,0:07:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabang yang nyaris\Nmendekati keluarga utama, ya!
Dialogue: 0,0:07:57.21,0:08:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelemparnya takut, hei, hei, hei!
Dialogue: 0,0:08:00.50,0:08:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal terjebak di trik kemenanganku begini,\Naku bisa membunuhnya.
Dialogue: 0,0:08:04.84,0:08:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau bermusuhan\Ndengan Pengguna Racun,
Dialogue: 0,0:08:07.34,0:08:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi imbalan tetap imbalan.
Dialogue: 0,0:08:08.63,0:08:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima Keluarga Besar itu cuma\Nberdasarkan kemampuan membunuh,
Dialogue: 0,0:08:12.56,0:08:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan peringkat lima besar daya tempur.
Dialogue: 0,0:08:15.56,0:08:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengincar kesempatan\Nhome run pengubah hidup ini, kan?
Dialogue: 0,0:08:19.15,0:08:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuselesaikan pekerjaan ini,
Dialogue: 0,0:08:21.25,0:08:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu pergi ke tanah kelahiran bisbol di Amerika\Ndan menyebarkan Birdsball
Dialogue: 0,0:08:26.28,0:08:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tidak terikat buku aturan!
Dialogue: 0,0:08:39.58,0:08:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya pasti lezat...
Dialogue: 0,0:08:43.78,0:08:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah keluarga Gero.
Dialogue: 0,0:08:46.67,0:08:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Pengguna Racun akan kalah dari\NPengguna Burung yang jadi kelemahannya?
Dialogue: 0,0:08:51.18,0:08:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak paham, Byakko.
Dialogue: 0,0:08:53.55,0:08:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dalam masalah\Njustru si Burung Sialan itu.
Dialogue: 0,0:08:57.18,0:09:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, debaran jantungku tak mau berhenti.
Dialogue: 0,0:09:00.81,0:09:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikirkan dengan tenang,\Nmemang wajar, bukan?
Dialogue: 0,0:09:03.56,0:09:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Racun sudah hidup begitu panjang\Ndengan jebakan dan tipu daya.
Dialogue: 0,0:09:08.49,0:09:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan melancarkan sesuatu!
Dialogue: 0,0:09:10.86,0:09:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taring racun akan menggerogoti tubuhnya\Nsecara perlahan-lahan.
Dialogue: 0,0:09:14.45,0:09:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat sadar, semua sudah terlambat.
Dialogue: 0,0:09:16.91,0:09:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, rasanya aku tidak tahan\Nseakan mau hancur!
Dialogue: 0,0:09:23.54,0:09:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Racun, Gero Hikaru.
Dialogue: 0,0:09:25.80,0:09:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan sesungguhnya dari\Njebakan dan tipu dayamu.
Dialogue: 0,0:09:28.59,0:09:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan itu padaku.
Dialogue: 0,0:09:29.72,0:09:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei!\NHei, hei, hei!
Dialogue: 0,0:09:33.30,0:09:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainan tamat, Pengguna Racun!
Dialogue: 0,0:09:36.06,0:09:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Birdsball!
Dialogue: 0,0:09:37.35,0:09:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pukulan Kemenangan,
Dialogue: 0,0:09:38.85,0:09:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stadion Pemakaman Langit!
Dialogue: 0,0:09:43.19,0:09:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di area berbatu seperti ini,\Nkamu tidak bisa lari atau sembunyi!
Dialogue: 0,0:09:51.20,0:09:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bom asap?
Dialogue: 0,0:09:52.45,0:09:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma ini...
Dialogue: 0,0:09:53.91,0:09:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah menyiapkannya!
Dialogue: 0,0:09:55.24,0:09:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gas beracun!
Dialogue: 0,0:09:56.70,0:09:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti mau mengulur waktu\Nuntuk memasang jebakan!
Dialogue: 0,0:09:59.20,0:10:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya ini di tepi laut.
Dialogue: 0,0:10:01.62,0:10:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditunggu sebentar,\Nangin akan menerbangkan gas ini.
Dialogue: 0,0:10:04.04,0:10:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman!
Dialogue: 0,0:10:04.96,0:10:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, lebih baik jaga-jaga.
Dialogue: 0,0:10:07.21,0:10:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Birdsball!
Dialogue: 0,0:10:08.67,0:10:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayap Besi Paruh Akhir—
Dialogue: 0,0:10:11.97,0:10:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung pukul?\NMana jebakannya?
Dialogue: 0,0:10:16.55,0:10:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh sekali.
Dialogue: 0,0:10:18.68,0:10:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Burung, kecepatanmu itu\Nmemang tiada duanya.
Dialogue: 0,0:10:22.98,0:10:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu tidak akan cukup\Nuntuk menang dari orang licik.
Dialogue: 0,0:10:26.19,0:10:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jebakan pada dasarnya akan mempan\Nsebagai serangan kejutan.
Dialogue: 0,0:10:29.57,0:10:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau sengaja terang-terangan begitu.
Dialogue: 0,0:10:32.78,0:10:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti justru itulah jebakannya.
Dialogue: 0,0:10:35.70,0:10:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditakut-takuti dengan bom asap beraroma\Nuntuk membuatnya panik.
Dialogue: 0,0:10:39.33,0:10:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal pandangannya teralihkan sebentar saja,
Dialogue: 0,0:10:42.25,0:10:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akselerasi dan lompatan Toxin: Tarian Kaki\Nsudah cukup untuk menghabisinya.
Dialogue: 0,0:10:48.21,0:10:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanezawa, masih ada yang perlu\Nkutanyakan padamu.
Dialogue: 0,0:10:50.92,0:10:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat keluarga utama Pengguna Binatang\Nada di puncak gunung itu.
Dialogue: 0,0:10:55.26,0:11:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesti tahu sekalipun,\Nmustahil untuk sampai ke sana.
Dialogue: 0,0:11:06.10,0:11:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah musuh ada berapa?
Dialogue: 0,0:11:07.44,0:11:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku membocorkan soal itu!
Dialogue: 0,0:11:09.69,0:11:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga utama sampai mengerahkan
Dialogue: 0,0:11:11.82,0:11:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keluarga cabang dan ranting\Nuntuk memburu kalian!
Dialogue: 0,0:11:13.94,0:11:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yah, kalau ada yang bahaya di antara mereka.\N- Jangan-jangan dia...
Dialogue: 0,0:11:16.20,0:11:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- mungkin Pengguna Koala dan Pengguna Badak.\N- Jangan-jangan dia...
Dialogue: 0,0:11:17.07,0:11:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- mungkin Pengguna Koala dan Pengguna Badak.\N- membocorkan rahasia karena sudah putus asa?
Dialogue: 0,0:11:19.62,0:11:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau melepas Tali Ikatan?
Dialogue: 0,0:11:21.91,0:11:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum ada yang bisa melakukan hal gila itu,\Ntapi aku pernah dengar rumor.
Dialogue: 0,0:11:25.83,0:11:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Binatang—
Dialogue: 0,0:11:31.42,0:11:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ah, ah, tes mik, tes mik, sip.
Dialogue: 0,0:11:35.93,0:11:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero Hikaru!
Dialogue: 0,0:11:38.09,0:11:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Kerajaan Hewan Dogo!
Dialogue: 0,0:11:41.51,0:11:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku raja di sini, Dogo Toshiro\Nsang Pengguna Binatang.
Dialogue: 0,0:11:46.48,0:11:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian berkenalan, beri tahu aku.
Dialogue: 0,0:11:49.02,0:11:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal yang mulai diperbincangkan itu.
Dialogue: 0,0:11:51.32,0:11:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kepala Selanjutnya
Dialogue: 0,0:11:52.65,0:11:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Gero menerima kerja recehan.
Dialogue: 0,0:11:56.53,0:11:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini strategi bisnis baru?
Dialogue: 0,0:11:58.57,0:11:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa jadi pengawal—
Dialogue: 0,0:11:59.74,0:12:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat cari jodoh.
Dialogue: 0,0:12:01.83,0:12:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:02.70,0:12:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya cari jodoh untuk menikah.
Dialogue: 0,0:12:04.75,0:12:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan Operasi Pangeran—
Dialogue: 0,0:12:06.12,0:12:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencari pertemuan\Ndengan menolong orang.
Dialogue: 0,0:12:15.01,0:12:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang menjadikannya umpan,
Dialogue: 0,0:12:17.13,0:12:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sangat tidak masuk akal.
Dialogue: 0,0:12:18.84,0:12:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kenapa kepala keluarga selanjutnya\Nmau sama wanita tidak berguna ini?
Dialogue: 0,0:12:23.64,0:12:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misterinya sudah pecah sekarang.
Dialogue: 0,0:12:25.35,0:12:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia kandidat istrimu, ya.
Dialogue: 0,0:12:27.56,0:12:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, akan kuberi nasihat bagus.
Dialogue: 0,0:12:29.14,0:12:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan saja.
Dialogue: 0,0:12:30.90,0:12:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah Pengguna Racun sudah\Ndiasah berabad-abad.
Dialogue: 0,0:12:34.86,0:12:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah karya seni tingkat SSR.
Dialogue: 0,0:12:38.11,0:12:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan jadi kerugian besar di bisnis, lo.
Dialogue: 0,0:12:40.57,0:12:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini punya uang dan kekuasaan,\Nwanita dengan keturunan dan muka bagus itu—
Dialogue: 0,0:12:44.70,0:12:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah dia terlelap.
Dialogue: 0,0:12:46.87,0:12:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapanmu itu membuatku muak.
Dialogue: 0,0:12:57.09,0:12:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:13:05.93,0:13:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tombak?
Dialogue: 0,0:13:08.02,0:13:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perpaduan antara Pengguna Burung\Ndan Pengguna Tombak.
Dialogue: 0,0:13:12.06,0:13:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mengumpulkan darah\Nakan mendapat kekuatannya.
Dialogue: 0,0:13:15.73,0:13:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat tirai era baru dibuka.
Dialogue: 0,0:13:18.11,0:13:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya berdebar-debar, kan?
Dialogue: 0,0:13:24.49,0:13:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Tombak, Kushima Nagihiko.
Dialogue: 0,0:13:26.91,0:13:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wafat di usia 72.
Dialogue: 0,0:13:29.12,0:13:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skornya, 887 orang.
Dialogue: 0,0:13:32.29,0:13:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahliannya adalah teknik
Dialogue: 0,0:13:34.29,0:13:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang hanya ada di darah keluarga
Dialogue: 0,0:13:35.88,0:13:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mendedikasikan segalanya pada tombak.
Dialogue: 0,0:13:38.80,0:13:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tusukan tanpa suara yang dilancarkan
Dialogue: 0,0:13:40.51,0:13:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan akurat sebanyak 88 kali per detik.
Dialogue: 0,0:13:45.01,0:13:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini! Ini! Ini dia!
Dialogue: 0,0:13:48.47,0:13:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaga yang luar biasa!\NNikmat sekali!
Dialogue: 0,0:13:52.69,0:13:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat asyik!
Dialogue: 0,0:13:54.35,0:13:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersumpah setia ke Pengguna Binatang\Nternyata memang tepat!
Dialogue: 0,0:13:57.23,0:13:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Birdsball berevolusi lebih jauh
Dialogue: 0,0:13:59.49,0:14:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi Pengguna Tombak Burung!
Dialogue: 0,0:14:02.57,0:14:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jelas teknik Pengguna Tombak!
Dialogue: 0,0:14:04.62,0:14:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Pengguna Burung\Nmendadak menguasainya?
Dialogue: 0,0:14:06.83,0:14:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada hubungannya\Nsama kasus yang Piichi bilang?
Dialogue: 0,0:14:09.62,0:14:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Pengguna Binatang merencanakan
Dialogue: 0,0:14:12.33,0:14:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sesuatu yang berbahaya\Ndan akan membunuh banyak orang.
Dialogue: 0,0:14:17.59,0:14:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah terpojok!
Dialogue: 0,0:14:19.25,0:14:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan bola mati Tombak Burung super cepat!
Dialogue: 0,0:14:21.76,0:14:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubabat habis semua base milikmu!
Dialogue: 0,0:14:25.22,0:14:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tongkat burung tentunya!
Dialogue: 0,0:14:30.93,0:14:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencampurkan darah para pengguna
Dialogue: 0,0:14:34.14,0:14:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menciptakan pengguna baru,\Nteknik Darah Campuran.
Dialogue: 0,0:14:38.32,0:14:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Era yang akan dipenuhi oleh potensi.
Dialogue: 0,0:14:40.82,0:14:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya menguasai satu keturunan\Njelas membosankan, bukan?
Dialogue: 0,0:14:44.49,0:14:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mau bagaimana sekarang, Gero?
Dialogue: 0,0:14:47.24,0:14:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trik licikmu seperti tadi\Ntidak akan berguna lagi!
Dialogue: 0,0:14:50.66,0:14:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byakko, ayo ikut nonton sini!
Dialogue: 0,0:14:53.62,0:14:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha, apa coba?
Dialogue: 0,0:14:55.04,0:14:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi "mengambil" yang di sana rupanya.
Dialogue: 0,0:14:57.92,0:15:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelek banget waktunya.
Dialogue: 0,0:15:02.55,0:15:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi jadi babak belur karena melindungiku.
Dialogue: 0,0:15:05.80,0:15:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka teknik penyelamatan di laut
Dialogue: 0,0:15:08.10,0:15:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kupelajari untuk seleb penyuka\Nselancar akan berguna.
Dialogue: 0,0:15:10.89,0:15:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berhasil selamat dari bom gurita\Nyang tiba-tiba muncul,
Dialogue: 0,0:15:14.77,0:15:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi malah terseret arus laut
Dialogue: 0,0:15:16.69,0:15:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke sisi pulau yang berlawanan dari Gero.
Dialogue: 0,0:15:20.23,0:15:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku cuma penipu pernikahan biasa.
Dialogue: 0,0:15:23.28,0:15:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus begini?
Dialogue: 0,0:15:28.12,0:15:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruang putih?
Dialogue: 0,0:15:48.09,0:15:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertunjukan bela diri?
Dialogue: 0,0:15:49.26,0:15:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali!
Dialogue: 0,0:15:55.48,0:15:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dilihat baik-baik,\Ndia juga sabuk hitam?
Dialogue: 0,0:15:57.81,0:15:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:15:59.31,0:16:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, itu sangat membantu.
Dialogue: 0,0:16:01.40,0:16:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kami pergi dulu.
Dialogue: 0,0:16:06.15,0:16:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan darahmu!
Dialogue: 0,0:16:07.99,0:16:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, dia tidak bisa dikelabui!
Dialogue: 0,0:16:13.24,0:16:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babak tambahan sudah usai, Gero!
Dialogue: 0,0:16:15.70,0:16:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kukirim kamu terbang tinggi!
Dialogue: 0,0:16:17.87,0:16:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan perpisahan home run penuh\Npembalik keadaan!
Dialogue: 0,0:16:25.92,0:16:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati para rekan timku\Npecah berkeping-keping?
Dialogue: 0,0:16:29.64,0:16:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan?
Dialogue: 0,0:16:30.55,0:16:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia lakukan?
Dialogue: 0,0:16:32.01,0:16:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu meremehkan Pengguna Racun.
Dialogue: 0,0:16:33.93,0:16:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan trik licik tanpa kamu sadari\Nitu sangatlah mudah.
Dialogue: 0,0:16:38.35,0:16:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia... jangan-jangan!
Dialogue: 0,0:16:39.98,0:16:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sengaja membiarkan dirinya dipatuk?
Dialogue: 0,0:16:42.02,0:16:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mencampurkan sesuatu\Nke dalam darahnya!
Dialogue: 0,0:16:44.61,0:16:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini racun untuk melumpuhkan otot.
Dialogue: 0,0:16:46.86,0:16:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri punya kekebalannya,\Ntapi kalian bagaimana?
Dialogue: 0,0:16:54.20,0:16:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Beraninya dengan cara\Nyang tidak sportif begini!
Dialogue: 0,0:16:58.04,0:16:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan-rekan timku!
Dialogue: 0,0:16:59.71,0:17:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalahkan dia dengan jumlah!
Dialogue: 0,0:17:06.05,0:17:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati!
Dialogue: 0,0:17:12.26,0:17:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero Hikaru, akan kudapatkan dirimu,\Npokoknya pasti.
Dialogue: 0,0:17:18.56,0:17:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama! Arashiyama!
Dialogue: 0,0:17:21.73,0:17:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama, kamu tidak apa-apa?
Dialogue: 0,0:17:24.31,0:17:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:17:30.28,0:17:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa menolongku?
Dialogue: 0,0:17:32.20,0:17:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan berbaring tenang,\Npendarahanmu akan berhenti.
Dialogue: 0,0:17:34.91,0:17:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya maniak bisbol cerewet\Nyang kebebasannya
Dialogue: 0,0:17:37.58,0:17:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- direnggut Pengguna Binatang.\N- Namanya Birdsball.
Dialogue: 0,0:17:40.54,0:17:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainan bisbol burung kami\Nyang melampaui bisbol asli.
Dialogue: 0,0:17:45.92,0:17:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan, para rekan timku?
Dialogue: 0,0:17:49.55,0:17:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah telak, Gero.
Dialogue: 0,0:17:51.97,0:17:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, selanjutnya aku tidak akan kalah.
Dialogue: 0,0:17:54.51,0:17:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengalahkanmu dalam\Npermainan Birdsball yang adil!
Dialogue: 0,0:17:57.81,0:18:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang, tidak akan ada yang selanjutnya.
Dialogue: 0,0:18:04.98,0:18:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah Campuran menghubungkan\Ndarah yang berbeda secara paksa.
Dialogue: 0,0:18:09.32,0:18:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalinya diaktifkan, akan saling menolak\Ndi dalam tubuh
Dialogue: 0,0:18:12.74,0:18:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berakhir dengan kematian.
Dialogue: 0,0:18:16.07,0:18:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek.
Dialogue: 0,0:18:17.41,0:18:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga cabang dan ranting\Nhanyalah mainan keluarga utama.
Dialogue: 0,0:18:21.54,0:18:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung Sialan adalah tikus percobaanku,\NWanita Hamster itu rantai yang mengikatmu!
Dialogue: 0,0:18:26.67,0:18:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang mau melepas Tali Pengikat, ya?
Dialogue: 0,0:18:29.55,0:18:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuberi tahu sesuatu.
Dialogue: 0,0:18:31.30,0:18:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darahku adalah kunci induknya.
Dialogue: 0,0:18:36.22,0:18:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, datanglah ke tempatku!
Dialogue: 0,0:18:39.18,0:18:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh keluargaku akan menyambutmu!
Dialogue: 0,0:18:42.10,0:18:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, darah yang dipatuk\Nsi Burung Sialan itu sudah cukup.
Dialogue: 0,0:18:46.77,0:18:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu pasti akan kuperas\Nsampai tak bersisa.
Dialogue: 0,0:18:50.78,0:18:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Racun.
Dialogue: 0,0:18:54.11,0:18:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benaran ingin membuat...
Dialogue: 0,0:18:56.28,0:19:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisbol Burung... Birdsball...\Njadi tren besar.
Dialogue: 0,0:19:20.97,0:19:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, aku sudah tidak apa-apa.
Dialogue: 0,0:19:33.90,0:19:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi, bahaya!
Dialogue: 0,0:19:44.37,0:19:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Toshiro.
Dialogue: 0,0:19:47.79,0:19:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Byakko.
Dialogue: 0,0:19:50.09,0:19:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berhasil saya dapatkan\Ntanpa masalah.
Dialogue: 0,0:19:55.92,0:19:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka semua akan\Nberjalan selancar ini.
Dialogue: 0,0:19:59.22,0:20:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sensasinya sangat luar biasa.
Dialogue: 0,0:20:01.10,0:20:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jatahmu, Byakko.
Dialogue: 0,0:20:03.97,0:20:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masih jam kerja.
Dialogue: 0,0:20:05.56,0:20:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:06.52,0:20:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau bermain dengan mainanku, ya?
Dialogue: 0,0:20:08.90,0:20:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan.
Dialogue: 0,0:20:10.15,0:20:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudahlah.
Dialogue: 0,0:20:11.61,0:20:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini darahnya sudah komplet.
Dialogue: 0,0:20:14.19,0:20:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya dinikahkan.
Dialogue: 0,0:20:16.15,0:20:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekurangan Darah Campuran adalah
Dialogue: 0,0:20:18.32,0:20:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}reaksi penolakannya begitu kuat\Ndan menghancurkan tubuh.
Dialogue: 0,0:20:22.20,0:20:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, darah Keluarga Gero.
Dialogue: 0,0:20:24.62,0:20:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena telah diberi racun\Nyang tak terhingga jumlahnya,
Dialogue: 0,0:20:27.91,0:20:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa menetralkan segala reaksi penolakan.
Dialogue: 0,0:20:31.08,0:20:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan darah orang bernama Piichi
Dialogue: 0,0:20:33.21,0:20:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa meningkatkan kecepatan berpikir\Ndan kemampuan fisik dengan pesat.
Dialogue: 0,0:20:37.30,0:20:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua darah yang kudambakan
Dialogue: 0,0:20:38.76,0:20:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siapa sangka berhasil kudapat\Nberkat keluarga cabang.
Dialogue: 0,0:20:41.68,0:20:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapan sudah selesai.
Dialogue: 0,0:20:44.35,0:20:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byakko, cepat bereskan mereka
Dialogue: 0,0:20:48.23,0:20:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu ayo gapai tujuan kita.
Dialogue: 0,0:20:57.99,0:21:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya makin memburuk.
Dialogue: 0,0:21:00.07,0:21:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kapan Pengguna Binatang akan\Nberubah pikiran dan membuang Arashiyama.
Dialogue: 0,0:21:06.12,0:21:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo pergi.
Dialogue: 0,0:21:07.25,0:21:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar!
Dialogue: 0,0:21:08.12,0:21:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisimu belum prima, kan, Gero Hikaru.
Dialogue: 0,0:21:11.00,0:21:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kita harus segera—
Dialogue: 0,0:21:13.88,0:21:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, hei!
Dialogue: 0,0:21:19.30,0:21:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang terluka mending diam\Ndan menikmati saja pahaku!
Dialogue: 0,0:21:22.64,0:21:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini—
Dialogue: 0,0:21:23.55,0:21:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!
Dialogue: 0,0:21:25.01,0:21:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku ikut melakukan sesuatu.
Dialogue: 0,0:21:29.23,0:21:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski diledek perkumpulan
Dialogue: 0,0:21:31.27,0:21:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena tidak pernah dapat permintaan membunuh\Npadahal seorang pengguna.
Dialogue: 0,0:21:35.44,0:21:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah berharap\Nuntuk mendapat kekuatan.
Dialogue: 0,0:21:39.32,0:21:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, saat cuma bisa sembunyi melihat\Norang-orang yang terluka.
Dialogue: 0,0:21:44.53,0:21:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja aku punya kekuatan lebih...
Dialogue: 0,0:21:47.79,0:21:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa hasil akhirnya akan berbeda?
Dialogue: 0,0:21:51.75,0:21:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku ini,\Nsangat tidak berguna begini?
Dialogue: 0,0:21:59.26,0:22:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama, sebagai seorang pengguna.
Dialogue: 0,0:22:02.59,0:22:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin menolongmu\Ntanpa bertanya apa yang kamu bisa.
Dialogue: 0,0:22:08.14,0:22:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuralat, Pengguna Hamster.\NAyo kita...
Dialogue: 0,0:22:12.27,0:22:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hajar Pengguna Binatang\Nbersama-sama!
Dialogue: 0,0:23:46.07,0:23:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku, Pengguna Air.
Dialogue: 0,0:23:47.03,0:23:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jijik!\N- Sudah makan saja!
Dialogue: 0,0:23:48.37,0:23:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pekerjaanmu lembek sekali, ya.\N- Buat Gero...
Dialogue: 0,0:23:50.78,0:23:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu yang paling cocok.
Dialogue: 0,0:23:53.24,0:23:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Tidak Berguna.
