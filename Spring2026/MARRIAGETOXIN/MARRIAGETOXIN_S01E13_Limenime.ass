Dialogue: 0,0:00:43.61,0:00:46.28,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:03:42.29,0:03:44.50,sign,,0000,0000,0000,,BAWA PENUMPANG
Dialogue: 0,0:04:03.39,0:04:08.06,sign,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN
Dialogue: 0,0:04:29.42,0:04:32.25,sign,,0000,0000,0000,,PESTA SYUKUR AKBAR HEWAN
Dialogue: 0,0:05:07.54,0:05:11.04,sign,,0000,0000,0000,,MAKASIH, YA
Dialogue: 0,0:08:18.06,0:08:20.23,sign,,0000,0000,0000,,JURUS CARI JODOH ALIRAN KINOSAKI
Dialogue: 0,0:08:20.23,0:08:21.69,sign,,0000,0000,0000,,JEMBATAN IKATAN
Dialogue: 0,0:11:50.69,0:11:51.27,sign,,0000,0000,0000,,TEMAN - 4
Dialogue: 0,0:13:20.20,0:13:21.49,sign,,0000,0000,0000,,KANTOR DETEKTIF ARASHIYAMA
Dialogue: 0,0:15:02.84,0:15:04.88,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:15:04.88,0:15:06.97,sign,,0000,0000,0000,,MAKASIH, YA
Dialogue: 0,0:15:38.04,0:15:40.17,sign,,0000,0000,0000,,PENCERAMAH CINTA MEI
Dialogue: 0,0:15:40.17,0:15:42.09,sign,,0000,0000,0000,,MEMECAHKAN MASALAH KHUSUS PENGIKUT
Dialogue: 0,0:15:42.09,0:15:44.59,sign,,0000,0000,0000,,TAMU SPESIAL COWOK MENAWAN BERKACAMATA - HIKARU
Dialogue: 0,0:18:33.13,0:18:34.76,sign,,0000,0000,0000,,TOXIN: WICARA
Dialogue: 0,0:22:07.76,0:22:09.98,sign,,0000,0000,0000,,ENAK, LO!\NPOJOK MAKANAN SIAP SAJI
Dialogue: 0,0:00:12.53,0:00:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.92,0:00:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:00:17.66,0:00:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.79,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:25.63,0:00:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.34,0:00:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:02:08.22,0:02:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala keluarga Pengguna Binatang?
Dialogue: 0,0:02:10.57,0:02:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti Toshiro...
Dialogue: 0,0:02:12.82,0:02:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang urus mereka.
Dialogue: 0,0:02:15.87,0:02:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jadi masalah, kan?
Dialogue: 0,0:02:24.42,0:02:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua anak baik.
Dialogue: 0,0:02:27.13,0:02:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampah yang tidak tahu diri
Dialogue: 0,0:02:30.38,0:02:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memang seharusnya disingkirkan.
Dialogue: 0,0:02:34.47,0:02:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Hikaru.
Dialogue: 0,0:02:37.26,0:02:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang mencari pasangan, kan?
Dialogue: 0,0:02:43.31,0:02:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu aku yang memanjakanmu?
Dialogue: 0,0:02:48.44,0:02:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sesama kepala keluarga,\Nkita pasti akan kembali bersua.
Dialogue: 0,0:02:52.03,0:02:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menuju penyatuan Lima Keluarga Besar\Nyang telah berlangsung berabad-abad.
Dialogue: 0,0:03:06.42,0:03:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, mari pulang.
Dialogue: 0,0:03:08.00,0:03:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, cepat sekali hatimu berubah?
Dialogue: 0,0:03:10.38,0:03:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Arashiyama sudah diselamatkan.
Dialogue: 0,0:03:14.22,0:03:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana Pengguna Binatang juga\Nberhasil dicegah.
Dialogue: 0,0:03:17.22,0:03:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, itu benar.
Dialogue: 0,0:03:19.80,0:03:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah justru kamu yang sekarang\Nbaru harus berusaha?
Dialogue: 0,0:03:24.02,0:03:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:03:25.94,0:03:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mendukung pencarian jodohmu.
Dialogue: 0,0:03:32.23,0:03:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero Hikaru!
Dialogue: 0,0:03:39.45,0:03:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:03:40.83,0:03:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak apa-apa.\N- Untungnya iya.
Dialogue: 0,0:03:54.09,0:03:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua, terima kasih, ya.
Dialogue: 0,0:03:57.30,0:04:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertunjukan yang dipersembahkan dengan
Dialogue: 0,0:04:00.72,0:04:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasa terima kasih terbesar dari kami!
Dialogue: 0,0:04:03.39,0:04:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan,
Dialogue: 0,0:04:17.89,0:04:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:04:25.58,0:04:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta Syukur Akbar Hewan!
Dialogue: 0,0:04:54.73,0:04:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini namanya pengguna keimutan...
Dialogue: 0,0:04:58.19,0:05:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, waktunya klimaks!
Dialogue: 0,0:05:06.70,0:05:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:05:07.54,0:05:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bentuk terima kasih kami!
Dialogue: 0,0:05:17.00,0:05:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kejadian ini kami betul-betul tersadar.
Dialogue: 0,0:05:20.26,0:05:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna keroco seperti kami\Nhanya bisa melakukan hal seperti ini.
Dialogue: 0,0:05:26.39,0:05:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu bukan masalah!
Dialogue: 0,0:05:29.27,0:05:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan terus hidup dengan bangga!
Dialogue: 0,0:05:33.44,0:05:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren.
Dialogue: 0,0:05:36.27,0:05:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren sekali kalian.
Dialogue: 0,0:05:42.53,0:05:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:05:48.74,0:05:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat hati Gero dan Arashiyama terhubung,
Dialogue: 0,0:05:51.71,0:05:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentu penipu pernikahan super elite\Nseperti Kinosaki Mei tidak melewatkannya.
Dialogue: 0,0:05:56.00,0:05:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan sempurna\Nuntuk mendekatkan mereka.
Dialogue: 0,0:05:59.92,0:06:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah nonton episode\NBagai Tali Takdir Kusut pekan lalu?
Dialogue: 0,0:06:03.51,0:06:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku lihat.
Dialogue: 0,0:06:04.80,0:06:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Gero Hikaru juga nonton Tali Takdir?
Dialogue: 0,0:06:07.35,0:06:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengatur arah pembicaraan\Nlayaknya teknik dewa.
Dialogue: 0,0:06:10.02,0:06:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan yang bikin hati berdebar\Nsudah pasti di jet pribadi!
Dialogue: 0,0:06:14.10,0:06:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?\NMemangnya raja minyak?
Dialogue: 0,0:06:17.02,0:06:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal pun setelah beberapa menit\Nakan sangat semangat membahas cerita cinta!
Dialogue: 0,0:06:24.24,0:06:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak logis.
Dialogue: 0,0:06:26.16,0:06:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, pacarnya Piichi\Nitu orangnya seperti apa?
Dialogue: 0,0:06:30.29,0:06:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok yang tiada tara.
Dialogue: 0,0:06:34.21,0:06:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat senyumannya sebelum bekerja,\Nmembuatku bisa maju sekuat tenaga.
Dialogue: 0,0:06:38.00,0:06:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan bersama saja sudah cukup\Nuntuk mengempaskan rasa lelahku.
Dialogue: 0,0:06:41.59,0:06:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pergi main di hari libur,\Nbesoknya aku jadi bisa berusaha lebih keras.
Dialogue: 0,0:06:48.22,0:06:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku manusia yang tidak normal.
Dialogue: 0,0:06:51.72,0:06:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebahagiaan sebagai manusia\Nyang ingin kuraih,
Dialogue: 0,0:06:54.52,0:06:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya diajari oleh pacarku.
Dialogue: 0,0:06:57.36,0:07:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bisa saling berbagi\Nkesenangan dan kesedihan.
Dialogue: 0,0:07:00.90,0:07:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila demi melindungi
Dialogue: 0,0:07:03.44,0:07:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keseharian dengan pacarku.
Dialogue: 0,0:07:06.53,0:07:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rela melakukan apa pun.
Dialogue: 0,0:07:12.33,0:07:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nakagawa Piichi!
Dialogue: 0,0:07:14.16,0:07:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dengan tenang mengatakannya\Ntanpa merasa malu?
Dialogue: 0,0:07:18.33,0:07:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jadi inilah
Dialogue: 0,0:07:20.84,0:07:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sikap dari cowok populer?
Dialogue: 0,0:07:24.01,0:07:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesra banget kalian berdua!
Dialogue: 0,0:07:26.22,0:07:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lihat fotonya?
Dialogue: 0,0:07:27.59,0:07:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mau, mau!\N- Sip, situasinya sudah mulai mendukung.
Dialogue: 0,0:07:34.56,0:07:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang Arashiyama itu punya\Nperasaan cinta padamu.
Dialogue: 0,0:07:41.27,0:07:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Punya rasa cinta,"\Ntapi itu pedang bermata dua.
Dialogue: 0,0:07:45.44,0:07:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena punya harapan itu,\Nkalau kecewa bakal langsung selesai.
Dialogue: 0,0:07:49.70,0:07:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus lebih serius dibanding\Nsama Himekawa dan Ureshino.
Dialogue: 0,0:07:54.45,0:07:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero juga sudah berkembang,\Npasti termotivasi kalau diberi dorongan.
Dialogue: 0,0:07:59.25,0:08:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengerti?
Dialogue: 0,0:08:03.21,0:08:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersikaplah tenang seperti Piichi\Ndan mintalah kontaknya dengan keren.
Dialogue: 0,0:08:08.05,0:08:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan sikap keren itu, mulai hari ini\Nkamu bisa jadi Gero yang baru!
Dialogue: 0,0:08:13.10,0:08:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sudah mau sampai.
Dialogue: 0,0:08:15.77,0:08:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti harus berpisah.
Dialogue: 0,0:08:18.06,0:08:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurus Cari Jodoh Aliran Kinosaki,
Dialogue: 0,0:08:20.23,0:08:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jembatan Ikatan!
Dialogue: 0,0:08:21.69,0:08:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sedih kalau enggak bisa\Nketemu para hamster lagi.
Dialogue: 0,0:08:25.57,0:08:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:08:26.57,0:08:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:08:28.53,0:08:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, Gero!\NManfaatkan alur ini!
Dialogue: 0,0:08:33.70,0:08:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama.
Dialogue: 0,0:08:43.53,0:08:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia punya rasa cinta padaku.
Dialogue: 0,0:08:45.30,0:08:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?\NTidak bohong, kan?
Dialogue: 0,0:08:47.80,0:08:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka padaku?
Dialogue: 0,0:08:49.30,0:08:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran suka orang sepertiku?
Dialogue: 0,0:08:53.05,0:08:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero! Gero!
Dialogue: 0,0:08:55.39,0:08:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masih terlalu cepat\Nbuat diberi tahu punya rasa cinta?
Dialogue: 0,0:08:59.14,0:09:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:09:00.56,0:09:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, dia bakal jadi kaku\Ndan mungkin enggak bisa bertukar kontak!
Dialogue: 0,0:09:06.44,0:09:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero Hikaru?
Dialogue: 0,0:09:08.32,0:09:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, sih?
Dialogue: 0,0:09:09.78,0:09:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bilang sesuatu?
Dialogue: 0,0:09:15.87,0:09:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat ini, mah.
Dialogue: 0,0:09:17.58,0:09:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutenangkan dia dulu\Nterus ditata lagi dari awal.
Dialogue: 0,0:09:23.29,0:09:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, boleh aku duluan?
Dialogue: 0,0:09:32.13,0:09:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu!
Dialogue: 0,0:09:39.98,0:09:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa tadi?
Dialogue: 0,0:09:44.56,0:09:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:09:49.53,0:09:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak bisa mengajukan diri\Nsebagai calon pengantinmu.
Dialogue: 0,0:09:55.28,0:09:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:09:57.08,0:10:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kamu sedang mencari jodoh.
Dialogue: 0,0:10:00.29,0:10:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku juga mau," pikirku.
Dialogue: 0,0:10:03.75,0:10:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak boleh.
Dialogue: 0,0:10:05.29,0:10:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku masih
Dialogue: 0,0:10:07.17,0:10:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum mengakui diriku sendiri.
Dialogue: 0,0:10:13.34,0:10:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak percaya diri dalam pekerjaanku\Ndan mentalku sangat payah.
Dialogue: 0,0:10:17.72,0:10:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau diterima\Ndengan keadaan seperti itu?
Dialogue: 0,0:10:20.98,0:10:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan akan jadi bergantung\Ndan malah merepotkanmu.
Dialogue: 0,0:10:25.02,0:10:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pokoknya tidak mau begitu.
Dialogue: 0,0:10:27.90,0:10:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski setengah-setengah\Ndan terasa egois,
Dialogue: 0,0:10:31.53,0:10:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan jadi betul-betul mandiri\Ndan mati-matian mengasah diri.
Dialogue: 0,0:10:37.07,0:10:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu mengungkapkan perasaanku lagi.
Dialogue: 0,0:10:39.91,0:10:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu...
Dialogue: 0,0:10:41.62,0:10:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima ka—
Dialogue: 0,0:10:42.33,0:10:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mengerjakan tugas yang disuruh.
Dialogue: 0,0:10:45.42,0:10:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan sebagai pengagum.
Dialogue: 0,0:10:47.42,0:10:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi orang hebat yang bisa\Nmembantu dan mendukungmu
Dialogue: 0,0:10:52.84,0:10:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuatmu benar-benar jatuh hati,\Njadi bersiaplah!
Dialogue: 0,0:11:02.22,0:11:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, bilang apa aku ini?
Dialogue: 0,0:11:07.19,0:11:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:11:10.52,0:11:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sejauh itu demi orang sepertiku.
Dialogue: 0,0:11:16.95,0:11:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya\Nada yang bilang begitu padaku.
Dialogue: 0,0:11:20.70,0:11:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:11:27.21,0:11:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunggu.
Dialogue: 0,0:11:36.01,0:11:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya!
Dialogue: 0,0:11:41.47,0:11:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau begitu, boleh minta kontak...
Dialogue: 0,0:11:45.43,0:11:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-Boleh.
Dialogue: 0,0:11:46.48,0:11:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, mereka ini bikin geregetan!
Dialogue: 0,0:11:51.27,0:11:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:11:52.32,0:11:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kusimpan.
Dialogue: 0,0:11:53.86,0:11:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:11:55.86,0:11:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kelihatannya bagus.
Dialogue: 0,0:11:59.87,0:12:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan akhirnya adalah\Npernikahan terbaik.
Dialogue: 0,0:12:03.87,0:12:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentunya, bagi mereka berdua.
Dialogue: 0,0:12:07.92,0:12:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk biaya tambahan,\Ntolong ditransfer ke rekening yang ditunjuk.
Dialogue: 0,0:12:11.42,0:12:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau telat bayar, akan kubunuh!
Dialogue: 0,0:12:14.05,0:12:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah!
Dialogue: 0,0:12:16.34,0:12:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia marah?
Dialogue: 0,0:12:18.05,0:12:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, Piichi kapan pulangnya?
Dialogue: 0,0:12:23.60,0:12:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Piichi.
Dialogue: 0,0:12:25.72,0:12:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang, Marin.
Dialogue: 0,0:12:28.10,0:12:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:12:29.52,0:12:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:30.52,0:12:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu tidak biasa berkelompok, kan?
Dialogue: 0,0:12:34.11,0:12:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi menginap satu malam di pulau\Ndengan orang baru dikenal.
Dialogue: 0,0:12:37.24,0:12:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak terasa berat?
Dialogue: 0,0:12:40.78,0:12:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tapi waktu berangkatnya\Nmemang terasa agak berat.
Dialogue: 0,0:12:44.95,0:12:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa aku bisa biasa saja\Ndengan mereka.
Dialogue: 0,0:12:47.75,0:12:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:12:49.12,0:12:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:12:50.08,0:12:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kamu sudah punya teman.
Dialogue: 0,0:12:52.42,0:12:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman...
Dialogue: 0,0:12:54.46,0:12:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman?
Dialogue: 0,0:12:58.47,0:12:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:12:59.59,0:13:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah belajar cara\Nmemotong cumi-cumi raksasa.
Dialogue: 0,0:13:02.80,0:13:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa untuk pasta tinta cumi.
Dialogue: 0,0:13:04.51,0:13:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:13:06.06,0:13:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo masukkan ke menu kafe kita!
Dialogue: 0,0:13:09.14,0:13:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:11.69,0:13:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke depannya mau bagaimana, Arashiyama?
Dialogue: 0,0:13:14.40,0:13:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sudah menanyakannya!
Dialogue: 0,0:13:16.48,0:13:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau membuka kantor detektif!
Dialogue: 0,0:13:21.49,0:13:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tidak mau melakukan\Npertunjukan seperti tadi?
Dialogue: 0,0:13:25.03,0:13:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sehebat itu.
Dialogue: 0,0:13:27.87,0:13:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih keren jadi detektif, kan?
Dialogue: 0,0:13:31.21,0:13:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:13:33.33,0:13:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mencari\Nkakakku yang menghilang.
Dialogue: 0,0:13:39.13,0:13:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai ketemu lagi!
Dialogue: 0,0:13:43.84,0:13:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arashiyama itu...
Dialogue: 0,0:13:45.68,0:13:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan cuma Arashiyama.
Dialogue: 0,0:13:49.02,0:13:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga Himekawa dan Ureshino.
Dialogue: 0,0:13:52.14,0:13:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka benar-benar sangat menawan\Ndan telah bekerja keras.
Dialogue: 0,0:13:56.65,0:14:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa layak untuk mereka,
Dialogue: 0,0:14:01.15,0:14:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin jadi lebih memesona lagi!
Dialogue: 0,0:14:09.24,0:14:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku bakal lebih keras lagi, ya,\Ndengan seribu kesakitan.
Dialogue: 0,0:14:13.83,0:14:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bimbingannya.
Dialogue: 0,0:14:34.19,0:14:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruaki.
Dialogue: 0,0:14:41.28,0:14:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guci racunmu yang baru.
Dialogue: 0,0:14:44.40,0:14:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya?
Dialogue: 0,0:14:47.99,0:14:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir mati dengan penuh semangat!
Dialogue: 0,0:14:52.00,0:14:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Guru ada perlu apa?
Dialogue: 0,0:14:55.79,0:14:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pernikahan Tuan Hikaru.
Dialogue: 0,0:15:00.67,0:15:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lebih rinci.
Dialogue: 0,0:15:07.64,0:15:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan dengan ketiganya\Nberjalan lancar bersamaan.
Dialogue: 0,0:15:10.18,0:15:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior di tempat kerja paruh waktu,\Nanak seangkatan dari SMA sebelah,
Dialogue: 0,0:15:13.89,0:15:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan adik kelas yang dulunya\Nsatu ekskul waktu SMP.
Dialogue: 0,0:15:17.23,0:15:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cinta mati sama ketiganya,\Njadi mustahil buat pilih satu.
Dialogue: 0,0:15:22.73,0:15:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mas Penasihat,\Nsebaiknya aku bagaimana?
Dialogue: 0,0:15:27.49,0:15:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:15:29.45,0:15:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bertiga bilang pokoknya\Nmau kencan pas ulang tahunku.
Dialogue: 0,0:15:33.12,0:15:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:15:34.54,0:15:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi, ya...\N- Konsultasi cinta?
Dialogue: 0,0:15:36.83,0:15:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:38.04,0:15:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penceramah Cinta, Mei.
Dialogue: 0,0:15:40.17,0:15:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memecahkan masalah khusus pengikut.
Dialogue: 0,0:15:44.59,0:15:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus ikut menemani\Nproyek yang kujalankan ini.
Dialogue: 0,0:15:49.05,0:15:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku—
Dialogue: 0,0:15:51.56,0:15:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jadi ini...
Dialogue: 0,0:15:53.43,0:15:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar jadi orang memesona yang layak\Nuntuk Himekawa, Ureshino, dan Arashiyama.
Dialogue: 0,0:15:59.19,0:16:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini latihan seribu rasa sakit untuk itu?
Dialogue: 0,0:16:01.69,0:16:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah seratus rasa sakit,\Nkalau bisa melalui ini semua...
Dialogue: 0,0:16:06.90,0:16:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang itu yang kuharap!
Dialogue: 0,0:16:10.91,0:16:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya bagaimana, ya?
Dialogue: 0,0:16:12.95,0:16:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bagaimana kalau begini?
Dialogue: 0,0:16:15.45,0:16:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumpulkan mereka\Nlalu kencan bareng bertiga!
Dialogue: 0,0:16:19.08,0:16:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada cara seperti itu.
Dialogue: 0,0:16:22.46,0:16:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:16:23.92,0:16:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah!
Dialogue: 0,0:16:25.51,0:16:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Yu, soal ulang tahunku...
Dialogue: 0,0:16:29.26,0:16:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru permulaan.
Dialogue: 0,0:16:31.35,0:16:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo! Aku ingin mengungkapkan perasaan\Nke manajer sebelum kelulusan!
Dialogue: 0,0:16:36.10,0:16:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia populer di antara seluruh rekan timku!
Dialogue: 0,0:16:38.94,0:16:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, perasaanku tidak akan kalah\Ndari siapa pun!
Dialogue: 0,0:16:41.94,0:16:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara agar aku\Nbisa menangkap hatinya?
Dialogue: 0,0:16:45.57,0:16:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu bagaimana, Gero?
Dialogue: 0,0:16:54.66,0:16:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-Yang terpenting tulus dengan hati...
Dialogue: 0,0:16:58.83,0:16:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:16:59.67,0:17:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan perlahan.
Dialogue: 0,0:17:00.75,0:17:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:01.88,0:17:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih banyak!
Dialogue: 0,0:17:03.59,0:17:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah!
Dialogue: 0,0:17:07.92,0:17:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke toilet dulu.
Dialogue: 0,0:17:13.93,0:17:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toiletnya jadi mengilap!
Dialogue: 0,0:17:15.39,0:17:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:17:16.09,0:17:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilusi?
Dialogue: 0,0:17:19.31,0:17:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa saranku tadi sudah benar?
Dialogue: 0,0:17:23.44,0:17:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, ayo terus lanjut.
Dialogue: 0,0:17:26.81,0:17:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya cuma mau main-main.
Dialogue: 0,0:17:29.90,0:17:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi belakangan ini jadi serius.
Dialogue: 0,0:17:34.70,0:17:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah lulus kuliah,\Naku selalu sibuk bekerja
Dialogue: 0,0:17:38.58,0:17:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sama sekali tidak ada pertemuan asmara.
Dialogue: 0,0:17:42.92,0:17:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengajar kelas masakan Spanyol\Nuntuk waktu yang lama.
Dialogue: 0,0:17:47.67,0:17:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu jatuh hati pada murid yang ada di sana.
Dialogue: 0,0:17:54.64,0:17:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong nilai lagu yang kubuat\Nuntuk pacarku!
Dialogue: 0,0:18:00.18,0:18:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bimbang harus bilang suka\Nke teman seangkatanku atau tidak.
Dialogue: 0,0:18:04.60,0:18:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melupakan wanita lebih tua\Nyang kutemui di perjalanan.
Dialogue: 0,0:18:09.78,0:18:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah lima tahu tinggal bersama,
Dialogue: 0,0:18:12.07,0:18:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sama sekali tidak ada\Nobrolan soal menikah.
Dialogue: 0,0:18:15.91,0:18:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan gelora dari guru\Ndi kelas masakan Spanyol.
Dialogue: 0,0:18:23.37,0:18:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini sepertinya masih 20 orang lagi.
Dialogue: 0,0:18:26.96,0:18:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pilihan lagi,\Naku harus memakai itu.
Dialogue: 0,0:18:30.76,0:18:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Kemampuan Bahasa Intelektual,
Dialogue: 0,0:18:33.13,0:18:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin Wicara.
Dialogue: 0,0:18:34.76,0:18:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero! Jangan gerus nyawamu\Ncuma buat konsultasi asmara!
Dialogue: 0,0:18:40.56,0:18:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini benar-benar payah.
Dialogue: 0,0:18:43.85,0:18:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka benar-benar sedang kebingungan.
Dialogue: 0,0:18:46.94,0:18:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin orang sepertiku,\Nbisa tahu jawabannya.
Dialogue: 0,0:18:50.40,0:18:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:18:54.11,0:18:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu merasakan\Nkalau mereka semua memang serius.
Dialogue: 0,0:19:00.54,0:19:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, tidak ada jawaban yang benar.
Dialogue: 0,0:19:03.91,0:19:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu adalah bukti bahwa tiap orang\Nsudah berpikir setengah mati
Dialogue: 0,0:19:07.67,0:19:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berjuang dengan keras.
Dialogue: 0,0:19:11.46,0:19:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri belum lama ini
Dialogue: 0,0:19:14.30,0:19:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditembak seorang wanita lalu jadi panik\Ndan terlihat seolah hilang percaya diri.
Dialogue: 0,0:19:20.72,0:19:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu merasa tidak bisa menjawab\Nperasaan Arashiyama sepenuh hati.
Dialogue: 0,0:19:26.31,0:19:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu adalah bukti
Dialogue: 0,0:19:28.77,0:19:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kamu juga berjuang sungguh-sungguh\Nsama seperti semuanya.
Dialogue: 0,0:19:34.90,0:19:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:19:36.36,0:19:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang menapaki jalan\Nmenuju pernikahan terbaik.
Dialogue: 0,0:19:43.58,0:19:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, buat menikah bakal masih jauh.
Dialogue: 0,0:19:49.58,0:19:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:19:52.42,0:19:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu...
Dialogue: 0,0:19:58.89,0:20:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat berjuang.
Dialogue: 0,0:20:02.76,0:20:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:20:06.64,0:20:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah camilan mainan?
Dialogue: 0,0:20:08.52,0:20:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah untuk diriku.
Dialogue: 0,0:20:10.87,0:20:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kita bikin perayaan!
Dialogue: 0,0:20:12.98,0:20:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sukiyaki!
Dialogue: 0,0:20:14.48,0:20:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:20:15.32,0:20:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:20:16.15,0:20:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habis ini aku ada janji\Nyang tidak bisa ditinggal.
Dialogue: 0,0:20:19.70,0:20:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain waktu, ya.
Dialogue: 0,0:20:21.20,0:20:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, pokoknya nanti makan sukiyaki mahal\Nterus lanjut sama susyi, ya!
Dialogue: 0,0:20:26.16,0:20:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki.
Dialogue: 0,0:20:27.41,0:20:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:20:29.12,0:20:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:20:30.75,0:20:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak aku bertemu denganmu waktu itu.
Dialogue: 0,0:20:33.92,0:20:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kamu jadi penasihat cari jodohku.
Dialogue: 0,0:20:39.43,0:20:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali yang terjadi.
Dialogue: 0,0:20:43.35,0:20:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya.
Dialogue: 0,0:20:45.89,0:20:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sangat menyenangkan.
Dialogue: 0,0:20:50.27,0:20:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caraku bersenang-senang menikmati hidup\Nsebelum bertemu Kinosaki itu
Dialogue: 0,0:20:54.36,0:20:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma ada lewat camilan mainan saja.
Dialogue: 0,0:20:57.44,0:20:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya...
Dialogue: 0,0:20:59.49,0:21:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bimbing aku mencari jodoh\Nuntuk ke depannya.
Dialogue: 0,0:21:07.00,0:21:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero.
Dialogue: 0,0:21:10.46,0:21:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan saja padaku!
Dialogue: 0,0:21:12.17,0:21:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan membuatmu bisa\Nmendapatkan pernikahan yang bahagia!
Dialogue: 0,0:21:33.36,0:21:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, lama tidak ketemu.
Dialogue: 0,0:21:36.78,0:21:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah meluangkan\Nwaktu untuk hari ini.
Dialogue: 0,0:21:40.45,0:21:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari jodohmu bagaimana?
Dialogue: 0,0:21:41.86,0:21:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lumayan.
Dialogue: 0,0:21:43.57,0:21:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Lumayan ada kemajuannya?
Dialogue: 0,0:21:45.95,0:21:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penasihat cari jodohnya jago...
Dialogue: 0,0:21:47.87,0:21:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspektasimu rendah sekali, Akari.
Dialogue: 0,0:21:51.33,0:21:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mungkin harus bergegas.
Dialogue: 0,0:21:57.00,0:22:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruaki dari...
Dialogue: 0,0:22:00.92,0:22:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...keluarga cabang Gero...
Dialogue: 0,0:22:04.30,0:22:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...mulai bergerak?
