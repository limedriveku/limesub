Dialogue: 0,0:00:43.56,0:00:46.28,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:03:11.46,0:03:15.43,sign,,0000,0000,0000,,JALAN PINTAS - RUTE NORMAL
Dialogue: 0,0:04:00.80,0:04:02.39,sign,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN
Dialogue: 0,0:04:02.97,0:04:05.18,sign,,0000,0000,0000,,BUMP UP
Dialogue: 0,0:07:55.58,0:07:56.29,sign,,0000,0000,0000,,BINATANG SINTESIS - HYAKKO
Dialogue: 0,0:11:24.46,0:11:27.08,sign,,0000,0000,0000,,MARIN
Dialogue: 0,0:12:38.95,0:12:40.99,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:12:40.99,0:12:43.03,sign,,0000,0000,0000,,PERSEMBAHAN
Dialogue: 0,0:20:26.33,0:20:28.62,sign,,0000,0000,0000,,TOXIN: TRIPEL
Dialogue: 0,0:23:53.20,0:23:55.96,sign,,0000,0000,0000,,ESENSI
Dialogue: 0,0:00:12.53,0:00:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.93,0:00:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:00:17.50,0:00:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.79,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:25.63,0:00:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.34,0:00:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:02:07.93,0:02:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kinosaki Mei!
Dialogue: 0,0:02:10.07,0:02:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penipu Pernikahan biasa\Nyang ada di mana saja!
Dialogue: 0,0:02:14.45,0:02:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, aku sedang membantu\Npencarian jodoh Gero!
Dialogue: 0,0:02:18.70,0:02:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya begitu...
Dialogue: 0,0:02:23.87,0:02:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa jadi seperti ini?
Dialogue: 0,0:02:26.25,0:02:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya penasihat cari jodoh\Ntidak diperlukan di sini?
Dialogue: 0,0:02:29.85,0:02:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Piichi.
Dialogue: 0,0:02:32.13,0:02:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya kami memang bermusuhan.
Dialogue: 0,0:02:33.84,0:02:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setelah sama-sama ingin\Nmengalahkan Pengguna Binatang,
Dialogue: 0,0:02:37.05,0:02:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia jadi ikut membantu.
Dialogue: 0,0:02:40.77,0:02:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara singkatnya, dia monster.
Dialogue: 0,0:02:45.14,0:02:47.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain kemampuan tempurnya yang luar biasa.
Dialogue: 0,0:02:47.48,0:02:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal terluka parah\Nkarena terkena ledakan,
Dialogue: 0,0:02:50.07,0:02:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bisa pulih sepenuhnya\Nsetelah tidur sepuluh jam.
Dialogue: 0,0:02:54.45,0:02:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya mimpi membuka kafe bersama pacarnya.
Dialogue: 0,0:02:57.12,0:03:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena takut pelanggannya tidak bisa tenang\Nkalau ada orang jahat,
Dialogue: 0,0:03:00.62,0:03:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia mau menghabisi Pengguna Binatang.
Dialogue: 0,0:03:02.91,0:03:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang benar-benar seram.
Dialogue: 0,0:03:07.75,0:03:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya seperti pintu belakang.
Dialogue: 0,0:03:10.00,0:03:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan pengguna,
Dialogue: 0,0:03:11.46,0:03:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bisa menemukan rute tersingkat
Dialogue: 0,0:03:13.84,0:03:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menuju markas Pengguna Binatang.
Dialogue: 0,0:03:15.43,0:03:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan jagoan yang menyebut\Nsebagai Lima Bintang Binatang pun
Dialogue: 0,0:03:18.43,0:03:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia habisi hitungan detik.
Dialogue: 0,0:03:20.43,0:03:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mereka bisa kukalahkan begitu saja.
Dialogue: 0,0:03:23.81,0:03:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah sekarang.
Dialogue: 0,0:03:42.20,0:03:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruang Karate yang waktu itu?
Dialogue: 0,0:03:44.79,0:03:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti yang ada di depannya...
Dialogue: 0,0:03:50.29,0:03:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Binatang?
Dialogue: 0,0:03:52.30,0:03:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byakko, ulur waktu sepuluh detik.
Dialogue: 0,0:03:58.13,0:04:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan!
Dialogue: 0,0:04:02.97,0:04:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bump Up!
Dialogue: 0,0:04:11.36,0:04:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Toshiro, serahkan pada saya.
Dialogue: 0,0:04:15.57,0:04:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia gelap yang dipenuhi\Nkejahatan dan kekejaman,
Dialogue: 0,0:04:18.77,0:04:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami adalah sosok yang diasingkan\Ndari keluarga Pengguna Binatang.
Dialogue: 0,0:04:22.74,0:04:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyusup Tercela.
Dialogue: 0,0:04:26.70,0:04:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal mereka tidak memperdalam\Nikatan dengan partnernya,
Dialogue: 0,0:04:30.96,0:04:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukannya aneh disebut Pengguna Binatang?
Dialogue: 0,0:04:33.17,0:04:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dulu cukup kuat, lo.
Dialogue: 0,0:04:35.46,0:04:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau sekarang cuma jadi kostum boneka.
Dialogue: 0,0:04:39.18,0:04:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:04:41.55,0:04:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi, Ibu agak ceroboh waktu kerja.
Dialogue: 0,0:04:47.39,0:04:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat sekali...
Dialogue: 0,0:04:49.73,0:04:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan tidak dapat pengobatan...
Dialogue: 0,0:04:52.69,0:04:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:04:54.77,0:04:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu yang salah karena terluka.
Dialogue: 0,0:04:59.24,0:05:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana adalah rumah sakit khusus bagi\NPengguna Binatang yang punya partner.
Dialogue: 0,0:05:04.78,0:05:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh dipakai oleh\NPenyusup Tercela seperti kita.
Dialogue: 0,0:05:08.16,0:05:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:05:09.87,0:05:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byakko.
Dialogue: 0,0:05:12.88,0:05:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:05:15.21,0:05:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obatnya saja tidak apa-apa!\NPasti akan saya bayar!
Dialogue: 0,0:05:19.01,0:05:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mohon!
Dialogue: 0,0:05:28.81,0:05:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?
Dialogue: 0,0:05:36.48,0:05:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Kenapa?
Dialogue: 0,0:05:39.28,0:05:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejam sekali.
Dialogue: 0,0:05:53.17,0:05:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:05:55.29,0:05:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua, semua, semua,\Naku benci semuanya.
Dialogue: 0,0:05:59.67,0:06:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia yang dikekang oleh aturan busuk ini!
Dialogue: 0,0:06:07.51,0:06:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para sampah itu hanyalah pakan,\Nhanya untuk kita berdua.
Dialogue: 0,0:06:12.52,0:06:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita hancurkan\Ndunia busuk ini sama-sama.
Dialogue: 0,0:06:18.27,0:06:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Toshiro sudah memberi isi\Npada diriku yang kosong.
Dialogue: 0,0:06:23.99,0:06:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila itu impian Tuan Toshiro!
Dialogue: 0,0:06:27.41,0:06:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menu set hasil buruan\Nmungkin cocok buat di kafe?
Dialogue: 0,0:06:31.45,0:06:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali serang?
Dialogue: 0,0:06:33.87,0:06:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukannya berniat\Nbertarung demi keadilan.
Dialogue: 0,0:06:38.04,0:06:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, jika Pengguna Binatang\Ningin mengorbankan seseorang,
Dialogue: 0,0:06:43.76,0:06:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu harus mati.
Dialogue: 0,0:06:48.30,0:06:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:06:51.10,0:06:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tidur sampai kapan?
Dialogue: 0,0:06:56.85,0:07:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mohon maaf, Tuan Toshiro.
Dialogue: 0,0:07:01.28,0:07:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu yang kumaksud.
Dialogue: 0,0:07:03.74,0:07:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, sekarang sudah jadi.
Dialogue: 0,0:07:07.45,0:07:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibuat dengan mengumpulkan 93 darah\Nkeluarga cabang dan kerabat Pengguna Binatang.
Dialogue: 0,0:07:13.33,0:07:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta enam darah pengguna\Ntermasuk milik Gero.
Dialogue: 0,0:07:19.09,0:07:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dibuat khusus hanya untukmu.
Dialogue: 0,0:07:50.83,0:07:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Binatang Sintesis,
Dialogue: 0,0:07:53.83,0:07:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakko!
Dialogue: 0,0:07:58.67,0:08:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan itu rasanya memang nikmat, bukan?
Dialogue: 0,0:08:09.01,0:08:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya benar-benar mohon maaf...
Dialogue: 0,0:08:11.39,0:08:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menantang saya bertarung di tempat ini,
Dialogue: 0,0:08:14.68,0:08:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka kalian sudah kehilangan\Npeluang untuk menang!
Dialogue: 0,0:08:22.65,0:08:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Gero, mari lanjut.
Dialogue: 0,0:08:33.74,0:08:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisau ini tidak akan bisa memotongnya...
Dialogue: 0,0:08:39.41,0:08:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari sesuatu di sekitar\Nyang bisa dijadikan senjata.
Dialogue: 0,0:08:42.08,0:08:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu...
Dialogue: 0,0:08:43.38,0:08:46.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang besar dan berat...
Dialogue: 0,0:08:46.34,0:08:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bisa langsung menusuk...
Dialogue: 0,0:08:57.68,0:08:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang bagus!
Dialogue: 0,0:08:59.23,0:09:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulang hewan raksasa?
Dialogue: 0,0:09:37.64,0:09:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:09:39.06,0:09:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih cepat dan berat dari perkiraanku.
Dialogue: 0,0:09:43.56,0:09:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otot dan tulang yang sudah dibuat\Nsangat ringan dan tangguh luar biasa.
Dialogue: 0,0:09:49.44,0:09:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah,
Dialogue: 0,0:09:50.57,0:09:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sistem saraf yang memungkinkan
Dialogue: 0,0:09:52.45,0:09:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manipulasi jaringan permukaan tubuh\Nuntuk berubah sesuka hati.
Dialogue: 0,0:09:55.74,0:09:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sudah berjuang sangat keras\Nuntuk membuat ini.
Dialogue: 0,0:09:59.54,0:10:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kalau dengan ini
Dialogue: 0,0:10:02.75,0:10:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana?
Dialogue: 0,0:10:07.00,0:10:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan membutakan pandangan\Nlalu sekuat tenaga ke belakangnya,
Dialogue: 0,0:10:10.42,0:10:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti bisa memberimu luka fa—
Dialogue: 0,0:10:14.51,0:10:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakanku terbaca?
Dialogue: 0,0:10:16.22,0:10:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya mustahil—
Dialogue: 0,0:10:17.72,0:10:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penukar tubuh?
Dialogue: 0,0:10:18.60,0:10:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditahan, apakah sempat?
Dialogue: 0,0:10:19.89,0:10:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya harus mengorbankan satu lengan...
Dialogue: 0,0:10:22.58,0:10:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau kalau sakit.
Dialogue: 0,0:10:26.06,0:10:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kenapa? Kenapa tidak bisa kuhabisi?"
Dialogue: 0,0:10:28.90,0:10:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sejak aku memegang pisau,"
Dialogue: 0,0:10:31.28,0:10:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"tidak ada yang mustahil kuhabisi\Nmeski itu seorang pengguna."
Dialogue: 0,0:10:35.49,0:10:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:10:37.66,0:10:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi?
Dialogue: 0,0:10:41.91,0:10:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak ada yang aneh.
Dialogue: 0,0:10:44.33,0:10:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakko memiliki darah pengguna\Nyang sudah kupilih sendiri
Dialogue: 0,0:10:48.75,0:10:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta dicampur dengan darah milikmu.
Dialogue: 0,0:10:54.13,0:10:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu sedang melawan\Nversi lebih kuat dari dirimu sendiri!
Dialogue: 0,0:11:00.76,0:11:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi!
Dialogue: 0,0:11:14.78,0:11:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tolong angkat teleponnya?
Dialogue: 0,0:11:16.91,0:11:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang?
Dialogue: 0,0:11:18.53,0:11:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu telepon dari kekasihku\Nyang berharga.
Dialogue: 0,0:11:20.91,0:11:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke...
Dialogue: 0,0:11:24.46,0:11:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi, sedang gawat sekali di sini!
Dialogue: 0,0:11:29.45,0:11:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang,\Nasasin dari Pengguna Binatang...
Dialogue: 0,0:11:31.84,0:11:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begini...
Dialogue: 0,0:11:33.09,0:11:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk merayakan sepuluh tahun\Ndibentuknya King Goose,
Dialogue: 0,0:11:36.43,0:11:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mengumumkan tur nasional!
Dialogue: 0,0:11:39.22,0:11:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:11:40.85,0:11:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aomori, Aichi, Fukuoka, lalu Budokan.
Dialogue: 0,0:11:44.81,0:11:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perang tiketnya pasti seperti neraka.
Dialogue: 0,0:11:47.10,0:11:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:50.25,0:11:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, Piichi.
Dialogue: 0,0:11:52.48,0:11:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:53.36,0:11:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan agendamu kosong, ya.
Dialogue: 0,0:11:55.53,0:11:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi jauh sendirian itu melelahkan.
Dialogue: 0,0:11:57.53,0:11:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, ya.
Dialogue: 0,0:12:03.24,0:12:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, coba?
Dialogue: 0,0:12:04.16,0:12:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah repot-repot kutunggu.
Dialogue: 0,0:12:06.71,0:12:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita santai yang tidak bisa baca suasana.
Dialogue: 0,0:12:09.83,0:12:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti biar kumasukkan ke liang kubur\Nyang sama dengan pacarnya yang gila.
Dialogue: 0,0:12:14.76,0:12:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh.
Dialogue: 0,0:12:21.47,0:12:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marin mengatakan itu karena tahu.
Dialogue: 0,0:12:27.85,0:12:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginan untuk melindungi\Nkeseharian dengannya yang biasa saja
Dialogue: 0,0:12:36.07,0:12:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan memantik semangat dalam diriku!
Dialogue: 0,0:12:44.03,0:12:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, coba?
Dialogue: 0,0:12:45.37,0:12:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau serius di saat seperti ini\Nitu sudah terlambat!
Dialogue: 0,0:12:55.75,0:12:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhancurkan!
Dialogue: 0,0:12:58.95,0:13:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi!
Dialogue: 0,0:13:04.43,0:13:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mengalahkannya?
Dialogue: 0,0:13:05.97,0:13:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kelemahannya?
Dialogue: 0,0:13:07.22,0:13:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengubah tubuh.
Dialogue: 0,0:13:08.39,0:13:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarafnya dimodifikasi.
Dialogue: 0,0:13:09.85,0:13:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya khimaira.
Dialogue: 0,0:13:10.85,0:13:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mengalahkannya?\NBisa mengubah tubuh, ya.
Dialogue: 0,0:13:12.65,0:13:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hewan apa ini? Mungkin sendinya lemah?\NBanyak hewan yang bercampur?
Dialogue: 0,0:13:14.65,0:13:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah penggunanya untuk mengendalikan tubuh.\NKalau masuk dalam tubuhnya?
Dialogue: 0,0:13:16.65,0:13:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja ada senjata yang kuat.\NBuat menu di kafe?
Dialogue: 0,0:13:18.65,0:13:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ada senjata yang lebih bagus.
Dialogue: 0,0:13:20.65,0:13:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Set menu khimaira, ya...
Dialogue: 0,0:13:24.28,0:13:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi kepalaku.
Dialogue: 0,0:13:29.29,0:13:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama itu selalu kacau berisikan ini dan itu.
Dialogue: 0,0:13:36.25,0:13:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang.
Dialogue: 0,0:13:38.42,0:13:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa jauh lebih luas,\Ndalam dan bebas...
Dialogue: 0,0:13:44.26,0:13:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memikirkan bermacam hal ini dan itu.
Dialogue: 0,0:13:50.02,0:13:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria ini...
Dialogue: 0,0:13:52.31,0:13:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma karena telepon satu menit,\Nbisa berubah mengerikan?
Dialogue: 0,0:13:58.32,0:14:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pinjam tangan kananmu, ya.
Dialogue: 0,0:14:00.44,0:14:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa memprediksi lagi langkah\Nyang sudah kuprediksi?
Dialogue: 0,0:14:04.99,0:14:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:06.41,0:14:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begini caranya\Ntangan kanan ini digerakkan?
Dialogue: 0,0:14:09.50,0:14:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, rasanya aku tetap butuh\Ndaya serang yang lebih besar.
Dialogue: 0,0:14:13.87,0:14:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini...
Dialogue: 0,0:14:17.17,0:14:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:14:20.26,0:14:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendali sistem sarafnya...
Dialogue: 0,0:14:23.68,0:14:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tidak jelas seperti dia...
Dialogue: 0,0:14:26.85,0:14:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak boleh kalah darinya!
Dialogue: 0,0:14:30.97,0:14:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita hancurkan\Ndunia busuk ini sama-sama.
Dialogue: 0,0:14:38.44,0:14:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:14:39.86,0:14:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:14:44.28,0:14:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menghentikan majikanmu.
Dialogue: 0,0:14:48.74,0:14:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi.
Dialogue: 0,0:14:50.95,0:14:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu tidak apa-apa?
Dialogue: 0,0:14:53.04,0:14:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku berbaring lima menit.
Dialogue: 0,0:14:57.63,0:14:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:07.26,0:15:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Toshiro.
Dialogue: 0,0:15:10.01,0:15:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong serap habis darah saya.
Dialogue: 0,0:15:14.27,0:15:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi satu dengan darah dan daging Anda\Nadalah kebanggaan bagi saya.
Dialogue: 0,0:15:19.86,0:15:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah kebanggaan.
Dialogue: 0,0:15:27.03,0:15:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus kabur dulu dari sini.
Dialogue: 0,0:15:31.41,0:15:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabut darah?
Dialogue: 0,0:15:35.37,0:15:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Byakko.
Dialogue: 0,0:15:39.04,0:15:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo hancurkan dunia busuk\Npenuh sampah ini bersama-sama!
Dialogue: 0,0:15:45.39,0:15:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi belum bisa bergerak.
Dialogue: 0,0:15:49.47,0:15:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jaraknya sebegini,
Dialogue: 0,0:15:51.35,0:15:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku masih bisa kabur!
Dialogue: 0,0:15:55.18,0:15:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bermain.
Dialogue: 0,0:16:05.86,0:16:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu, Kinosaki!
Dialogue: 0,0:16:09.11,0:16:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero!
Dialogue: 0,0:16:14.04,0:16:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama, Pengguna Air juga!
Dialogue: 0,0:16:16.16,0:16:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mau datang!
Dialogue: 0,0:16:17.75,0:16:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ushio Boost barusan masuk\Ntagihan ekstra, ya.
Dialogue: 0,0:16:27.22,0:16:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri belum pulih maksimal.
Dialogue: 0,0:16:31.39,0:16:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi masih bisa bergerak.
Dialogue: 0,0:16:33.06,0:16:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki.
Dialogue: 0,0:16:35.43,0:16:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu ini penasihat cari jodoh.
Dialogue: 0,0:16:37.81,0:16:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:16:39.56,0:16:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera membereskan ini,
Dialogue: 0,0:16:42.86,0:16:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi tolong siapkan latihan kencannya!
Dialogue: 0,0:16:51.07,0:16:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Binatang\Ndari Lima Keluarga Besar.
Dialogue: 0,0:16:54.79,0:16:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mutasi keturunan keluarga cabang dan kerabat
Dialogue: 0,0:16:57.58,0:17:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memungkinkan komunikasi dengan partnernya,
Dialogue: 0,0:17:00.67,0:17:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka akan menyelaraskan\Nbagian tubuh tertentu.
Dialogue: 0,0:17:04.67,0:17:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi,
Dialogue: 0,0:17:06.21,0:17:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}garis keturunan utama keluarga Dogo\Ntidak punya batasan itu.
Dialogue: 0,0:17:10.26,0:17:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari anggota tubuh, organ dalam, sampai indra.
Dialogue: 0,0:17:14.18,0:17:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh kekuatan binatang\Nakan diinstal dan dikerahkan.
Dialogue: 0,0:17:19.31,0:17:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah Mutasi Abnormal.
Dialogue: 0,0:17:22.06,0:17:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah sumber dari mutasi keturunan,
Dialogue: 0,0:17:26.06,0:17:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah Binatang!
Dialogue: 0,0:17:27.78,0:17:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Domba, kambing, rusa, unta, keledai, kuda nil,
Dialogue: 0,0:17:32.57,0:17:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lama, kerbau, gnu, okapi, bison, kerbau air,\Njakal, hiena, impala, antelop, badak,
Dialogue: 0,0:17:34.57,0:17:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jerapah, rusa kutub, oriks, kanguru, yurumi,\Ntapir, rubah, rakun, babi hutan, kelinci,
Dialogue: 0,0:17:36.66,0:17:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cerpelai, amunin, musang bulan, cerpelai ekor\Npendek, berang-berang, kuskus, tupai terbang,
Dialogue: 0,0:17:38.58,0:17:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tupai, koala, armadilo, landak, kungkang,\Nsinga laut, anjing laut, anjing laut berbulu,
Dialogue: 0,0:17:40.58,0:17:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}walrus, berang-berang laut, kapibara, biwara,\Ntikus sungai, panda merah, tikus tanah,
Dialogue: 0,0:17:42.58,0:17:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}garangan, paus pembunuh, beruang kutub,\Nplatipus, paus tanduk, ular raksasa, ular habu,
Dialogue: 0,0:17:44.58,0:17:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}buaya, penyu, labi-labi, kadal, bunglon, iguana,\Nkatak, salamander, lamprey, rajawali,
Dialogue: 0,0:17:46.59,0:17:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}elang, elang paria, alap-alap, burung hantu,\Ngagak, bebek, merpati, bulbul,
Dialogue: 0,0:17:48.59,0:17:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pipit, burung layang-layang, pentet,\Nbangau, burung unta, pelikan, beo,
Dialogue: 0,0:17:50.55,0:17:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gurita, dan darah nautilus
Dialogue: 0,0:17:51.84,0:17:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari ke-93 spesies ini!
Dialogue: 0,0:17:53.51,0:17:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dicampur dengan enam pengguna,\Ntotalnya menjadi 99.
Dialogue: 0,0:17:57.81,0:17:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disatukan ke wujud binatang,
Dialogue: 0,0:17:59.52,0:18:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hyakko!
Dialogue: 0,0:18:01.44,0:18:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kemudian dikenakan Byakko\Nuntuk mengeluarkan kekuatannya.
Dialogue: 0,0:18:06.86,0:18:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sebenarnya...\Nhanyalah pakan!
Dialogue: 0,0:18:33.01,0:18:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persembahan agar diriku,\NDogo Toshiro bisa menjadi monster.
Dialogue: 0,0:18:40.27,0:18:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piichi!
Dialogue: 0,0:18:41.81,0:18:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ushio...
Dialogue: 0,0:18:45.19,0:18:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero!
Dialogue: 0,0:18:47.94,0:18:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Plot mendebarkan ketika kalian\Nsaling menggabungkan kekuatan.
Dialogue: 0,0:18:54.61,0:18:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sebenarnya, tidak seberapa?
Dialogue: 0,0:19:02.25,0:19:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kamu ini?
Dialogue: 0,0:19:06.25,0:19:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau mati dengan tenang,\Nhentikan ekspresimu itu.
Dialogue: 0,0:19:13.42,0:19:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita semua menggabungkan kekuatan,
Dialogue: 0,0:19:16.05,0:19:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat seperti ini pasti bisa\Ndihancurkan dengan mudah.
Dialogue: 0,0:19:29.52,0:19:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma.
Dialogue: 0,0:19:30.94,0:19:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua bisa merasakannya\Nlewat darah.
Dialogue: 0,0:19:33.99,0:19:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teriakan para partner\Nyang diserap Pengguna Binatang.
Dialogue: 0,0:19:38.99,0:19:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun bisa menghancurkan kurungan ini,
Dialogue: 0,0:19:41.99,0:19:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan bisa lari dari monster itu.
Dialogue: 0,0:19:44.87,0:19:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lagi kerabat terlemah sepertimu.
Dialogue: 0,0:19:52.71,0:19:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penderitaanmu hanya sementara.
Dialogue: 0,0:19:54.92,0:19:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi akan tenang.
Dialogue: 0,0:19:57.09,0:20:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihannya cuma jernihkanlah hatimu.
Dialogue: 0,0:20:23.58,0:20:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero pakai tiga dosis?
Dialogue: 0,0:20:26.33,0:20:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toxin: Tripel.
Dialogue: 0,0:20:33.13,0:20:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesadarannya sudah hilang!
Dialogue: 0,0:20:35.80,0:20:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai Tripel di saat seperti ini?
Dialogue: 0,0:20:38.55,0:20:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau melawan dengan sia-sia, ya?
Dialogue: 0,0:20:40.55,0:20:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Overdosis itu menyiksa, kan?
Dialogue: 0,0:20:43.76,0:20:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat kamu mati dengan tenang.
Dialogue: 0,0:20:51.19,0:20:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini darah ternak yang sudah kukumpulkan
Dialogue: 0,0:20:56.57,0:20:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai hasil dari seluruh hidupku!
Dialogue: 0,0:20:59.28,0:21:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero!
Dialogue: 0,0:21:04.49,0:21:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat makan...
Dialogue: 0,0:21:07.54,0:21:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa sambil mengobrol santai,\Nternyata asyik juga.
Dialogue: 0,0:21:27.06,0:21:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Overdosis sama dengan kematian.
Dialogue: 0,0:21:38.03,0:21:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah yang didapat setelah melewati\Nberbagai upaya pencarian jodoh.
Dialogue: 0,0:21:53.29,0:21:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketajaman penglihatan dinamis rajawali,\Ndaya lompat kanguru.
Dialogue: 0,0:21:57.92,0:22:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan mematikan burung kasuari.
Dialogue: 0,0:22:00.97,0:22:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhancurkan dia sebelum\Nkembali sadar!
Dialogue: 0,0:22:10.73,0:22:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin sekali rasanya...
Dialogue: 0,0:22:12.98,0:22:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa menikah.
Dialogue: 0,0:23:46.03,0:23:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Duel? Salah besar.\N- Overdosis itu menyakitkan, bukan?
Dialogue: 0,0:23:48.49,0:23:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Niat membunuh sudah lama hilang.\N- Akan kuisap sampai tidak bersisa!
Dialogue: 0,0:23:49.74,0:23:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Memakan atau dimakan orang lain...\N- Dasar keroco sialan!
Dialogue: 0,0:23:52.16,0:23:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah bukanlah kutukan.
Dialogue: 0,0:23:53.20,0:23:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Esensi.
