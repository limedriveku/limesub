Dialogue: 0,0:03:19.51,0:03:22.22,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:07:18.75,0:07:21.39,sign,,0000,0000,0000,,PELEPASAN DARAH BINATANG
Dialogue: 0,0:07:21.39,0:07:23.34,sign,,0000,0000,0000,,PARADE SERATUS BINATANG
Dialogue: 0,0:09:17.50,0:09:19.41,sign,,0000,0000,0000,,PELEPASAN DARAH RACUN\NSETETES KIRANA
Dialogue: 0,0:12:14.92,0:12:16.97,sign,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:12:16.97,0:12:18.97,sign,,0000,0000,0000,,ESENSI
Dialogue: 0,0:17:13.68,0:17:14.47,sign,,0000,0000,0000,,UPACARA DARAH BINATANG
Dialogue: 0,0:23:53.16,0:23:56.00,sign,,0000,0000,0000,,MAKASIH, YA
Dialogue: 0,0:00:17.00,0:00:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hikaru.
Dialogue: 0,0:00:20.08,0:00:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumber mutasi keturunan yang diwarisi\Nkeluarga Gero adalah Darah Racun.
Dialogue: 0,0:00:27.01,0:00:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan makin kuat saat makin\Ndekat dengan kematian.
Dialogue: 0,0:00:33.93,0:00:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, potensinya akan\Nmeningkat sebanding dengan pengalaman.
Dialogue: 0,0:00:39.19,0:00:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk Tuan Hikaru mencapai tahap berikutnya
Dialogue: 0,0:00:42.36,0:00:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}paling cepat 20 tahun lagi.
Dialogue: 0,0:00:50.53,0:00:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang harus Tuan Hikaru tuju adalah puncak.
Dialogue: 0,0:00:54.16,0:00:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan pembunuh mutlak,\Nyang tidak dapat dinetralkan.
Dialogue: 0,0:00:58.75,0:01:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum bisa menguasainya,
Dialogue: 0,0:01:01.21,0:01:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong jangan ceroboh melakukan\Nsesuatu di luar kemampuan Anda.
Dialogue: 0,0:01:05.09,0:01:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski berkapasitas sebagai\Nkepala keluarga selanjutnya sekalipun.
Dialogue: 0,0:01:17.81,0:01:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesadarannya sudah...
Dialogue: 0,0:01:20.56,0:01:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai Tripel di saat seperti ini?
Dialogue: 0,0:01:23.31,0:01:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau melawan dengan sia-sia, ya?
Dialogue: 0,0:01:24.86,0:01:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Overdosis itu menyiksa, kan?
Dialogue: 0,0:01:30.24,0:01:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Overdosis sama dengan kematian.
Dialogue: 0,0:01:43.83,0:01:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beradaptasi dengan racun itu\Nharus secara perlahan.
Dialogue: 0,0:01:52.01,0:01:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah yang didapat setelah melewati\Nberbagai upaya pencarian jodoh.
Dialogue: 0,0:01:58.26,0:02:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah Racun milik Gero Hikaru
Dialogue: 0,0:02:14.41,0:02:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah mendapat pengalaman\Nselama puluhan tahun yang dipadatkan
Dialogue: 0,0:02:18.33,0:02:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemudian bermutasi\Ndan mencapai ranah tersebut.
Dialogue: 0,0:02:25.67,0:02:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin sekali rasanya...
Dialogue: 0,0:02:27.96,0:02:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa menikah.
Dialogue: 0,0:02:31.92,0:02:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengembangkan dirinya
Dialogue: 0,0:02:35.64,0:02:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke tahap berikutnya.
Dialogue: 0,0:02:48.48,0:02:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:02:51.84,0:02:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:02:53.49,0:02:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:02:56.74,0:03:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:03:01.54,0:03:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:03:07.29,0:03:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:04:48.02,0:04:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil?
Dialogue: 0,0:04:50.94,0:04:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero Hikaru.
Dialogue: 0,0:04:53.23,0:04:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seranganmu itu... membosankan!
Dialogue: 0,0:04:59.45,0:05:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di belakang diriku\Nada tumpukan mayat yang menjulang.
Dialogue: 0,0:05:05.83,0:05:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kebanggaan Lima Keluarga Besar.
Dialogue: 0,0:05:26.35,0:05:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Racun tidak akan ada artinya!
Dialogue: 0,0:05:29.06,0:05:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena darahmu juga sudah\Nbercampur di dalamnya!
Dialogue: 0,0:05:39.11,0:05:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero Hikaru.
Dialogue: 0,0:05:41.99,0:05:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batas dosis mematikannya
Dialogue: 0,0:05:51.08,0:05:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi jauh lebih cepat dibanding waktu itu!
Dialogue: 0,0:05:54.88,0:05:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, masih belum cukup!
Dialogue: 0,0:06:01.09,0:06:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak diragukan lagi,\Nbakatmu paling luar biasa di generasi kita.
Dialogue: 0,0:06:05.34,0:06:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang setara dengan yang sudah\Nkusiapkan selama bertahun-tahun
Dialogue: 0,0:06:09.85,0:06:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa kamu dapatkan begitu mudahnya!
Dialogue: 0,0:06:14.31,0:06:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memuakkan.
Dialogue: 0,0:06:16.81,0:06:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh sia-sia!
Dialogue: 0,0:06:19.86,0:06:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero!
Dialogue: 0,0:06:21.86,0:06:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mas Gero!
Dialogue: 0,0:06:23.28,0:06:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bakatmu tidak kamu niatkan\Nuntuk membunuh!
Dialogue: 0,0:06:26.70,0:06:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya ingin\Nmelindungi teman-temanmu?
Dialogue: 0,0:06:31.62,0:06:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh bayaran mau melindungi orang?\NBercandamu tidak lucu!
Dialogue: 0,0:06:37.08,0:06:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti itu, tidak akan\Nbisa membunuhku, lo.
Dialogue: 0,0:06:41.92,0:06:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah pasang muka santai,\Npadahal berdiri saja setengah mati, kan?
Dialogue: 0,0:06:45.76,0:06:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai dari sini, mau kemampuan atau bakat\Ntidak ada hubungannya.
Dialogue: 0,0:06:50.10,0:06:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sama-sama pembunuh bayaran.
Dialogue: 0,0:06:52.64,0:06:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang akan menang adalah
Dialogue: 0,0:06:54.52,0:06:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang niat membunuhnya lebih pekat!
Dialogue: 0,0:07:12.16,0:07:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurus Pemungkas Dogo Toshiro,
Dialogue: 0,0:07:18.75,0:07:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelepasan Darah Binatang,
Dialogue: 0,0:07:21.39,0:07:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parade Seratus Binatang!
Dialogue: 0,0:07:24.05,0:07:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}93 binatang yang sudah disatukan\Ndi dalam Hyakko
Dialogue: 0,0:07:28.43,0:07:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berbaris muncul dalam bentuk hayat!
Dialogue: 0,0:07:33.18,0:07:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar...
Dialogue: 0,0:07:38.40,0:07:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembus begitu saja?
Dialogue: 0,0:07:40.61,0:07:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...niat membunuhku telah lama hilang.
Dialogue: 0,0:07:45.11,0:07:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku hanya ingin menggapai
Dialogue: 0,0:07:48.32,0:07:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kebahagiaan layaknya orang normal.
Dialogue: 0,0:07:52.12,0:07:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipancing sampai detik terakhir\Nlalu dihindari?
Dialogue: 0,0:07:55.16,0:07:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana asal kekuatannya itu?
Dialogue: 0,0:07:57.71,0:08:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku jadi sadar setelah melakukan\Npencarian jodoh bersama Kinosaki.
Dialogue: 0,0:08:03.88,0:08:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggapainya seorang diri adalah\Nhal yang mustahil.
Dialogue: 0,0:08:08.88,0:08:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini
Dialogue: 0,0:08:10.80,0:08:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya bisa meraih kebahagiaan
Dialogue: 0,0:08:14.68,0:08:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan mengulurkan bantuan\Npada orang lain.
Dialogue: 0,0:08:26.90,0:08:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya mengakhiri ini semua,\NPengguna Binatang.
Dialogue: 0,0:08:32.12,0:08:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Racun Raga.
Dialogue: 0,0:08:34.33,0:08:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbagai macam racun yang tersimpan\Ndi dalam tubuh Anda
Dialogue: 0,0:08:38.62,0:08:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam waktu panjang akan saling memangsa\Ndan makin terasah.
Dialogue: 0,0:08:44.34,0:08:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan adalah
Dialogue: 0,0:08:46.92,0:08:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}esensi yang memunculkan kekuatan\Ntersembunyi dari darah.
Dialogue: 0,0:08:49.93,0:08:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan yang terukir pada darah\NLima Keluarga Besar ada di tingkatan berbeda.
Dialogue: 0,0:08:56.31,0:08:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keampuhan dari racun mematikan
Dialogue: 0,0:08:58.64,0:09:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan bergantung pada sifat Racun Raga\Nyang Tuan Hikaru kembangkan sendiri.
Dialogue: 0,0:09:04.15,0:09:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang harus Anda kuasai adalah\Nyang mustahil dinetralkan.
Dialogue: 0,0:09:07.74,0:09:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan pembunuh mutlak\Nyang sekali kena akan mati.
Dialogue: 0,0:09:12.41,0:09:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah...
Dialogue: 0,0:09:19.41,0:09:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelepasan Darah Racun:\NSetetes Kirana!
Dialogue: 0,0:09:42.19,0:09:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas usaha sia-siamu itu!
Dialogue: 0,0:09:44.69,0:09:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini punya kekebalan milikmu—
Dialogue: 0,0:09:53.07,0:09:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan racun ini?
Dialogue: 0,0:09:55.74,0:09:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sempat dinetralkan?
Dialogue: 0,0:09:58.91,0:10:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:10:01.62,0:10:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kamu
Dialogue: 0,0:10:03.54,0:10:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi darah super ultra SSR, ya?
Dialogue: 0,0:10:10.30,0:10:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memotong tangannya sendiri?
Dialogue: 0,0:10:15.18,0:10:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahagia, Gero!
Dialogue: 0,0:10:17.93,0:10:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa terbang lebih tinggi lagi!
Dialogue: 0,0:10:21.23,0:10:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganggu! Ganggu!\NGanggu semua!
Dialogue: 0,0:10:26.52,0:10:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah wujud binatang\Nyang dikhususkan murni hanya
Dialogue: 0,0:10:32.61,0:10:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk saling membunuh!
Dialogue: 0,0:10:45.92,0:10:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datanglah padaku\Ndengan segala yang kamu punya!
Dialogue: 0,0:10:48.71,0:10:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuisap habis seluruh darahmu!
Dialogue: 0,0:10:51.92,0:10:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meluap-luap dengan nafsu membunuh!
Dialogue: 0,0:10:54.55,0:10:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru jalan hidup pembunuh bayaran!
Dialogue: 0,0:11:07.23,0:11:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin Pengguna Racun\Nmaju terang-terangan
Dialogue: 0,0:11:14.15,0:11:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari depan.
Dialogue: 0,0:11:32.80,0:11:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:11:35.30,0:11:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak kelihatan apa-apa!\N- Hei, Gero!
Dialogue: 0,0:11:38.43,0:11:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di mana?
Dialogue: 0,0:11:40.97,0:11:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa dengar apa-apa!
Dialogue: 0,0:11:48.15,0:11:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa!
Dialogue: 0,0:11:56.20,0:11:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dinetralkan.
Dialogue: 0,0:11:57.99,0:12:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan pembunuh mutlak\Nyang sekali kena akan mati.
Dialogue: 0,0:12:01.91,0:12:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah
Dialogue: 0,0:12:04.41,0:12:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}esensi dari seorang Pengguna Racun.
Dialogue: 0,0:12:22.76,0:12:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benaran mati?
Dialogue: 0,0:12:24.97,0:12:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku ini?
Dialogue: 0,0:12:27.89,0:12:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah habis banyak tenaga\Ndan memakan banyak pakan?
Dialogue: 0,0:12:36.61,0:12:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi taringku tetap tidak bisa\Nmenggapai mereka, ya?
Dialogue: 0,0:12:43.08,0:12:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, setidaknya
Dialogue: 0,0:12:48.33,0:12:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kuperas habis daya hidupku\Nyang seperti sampah ini
Dialogue: 0,0:12:58.97,0:13:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyeret kalian semua ke neraka!
Dialogue: 0,0:13:06.47,0:13:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero.
Dialogue: 0,0:13:08.85,0:13:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka lebih penting\Ndari nyawamu sendiri, kan?
Dialogue: 0,0:13:13.61,0:13:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang kalah di duel ini!
Dialogue: 0,0:13:19.36,0:13:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel?
Dialogue: 0,0:13:20.86,0:13:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah.
Dialogue: 0,0:13:43.51,0:13:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, maaf sudah membuat\Nkalian menunggu!
Dialogue: 0,0:13:45.97,0:13:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Hamster?
Dialogue: 0,0:13:48.47,0:13:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku tidak mau bergerak!
Dialogue: 0,0:13:50.52,0:13:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:13:57.69,0:13:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:13:59.65,0:14:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa berdiri?
Dialogue: 0,0:14:02.32,0:14:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu yang terlemah.
Dialogue: 0,0:14:05.41,0:14:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong dengarkan!
Dialogue: 0,0:14:07.16,0:14:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu betul rasa takut kalian!
Dialogue: 0,0:14:12.25,0:14:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan kita adalah para binatang\Nyang telah dikuasai oleh amarah berapi-api
Dialogue: 0,0:14:16.63,0:14:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari raja yang menguasai seratus binatang.
Dialogue: 0,0:14:22.97,0:14:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:14:24.72,0:14:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ingat lagi!
Dialogue: 0,0:14:27.85,0:14:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita adalah
Dialogue: 0,0:14:29.72,0:14:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengguna yang menguasai satu binatang.
Dialogue: 0,0:14:32.68,0:14:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita paling jago\Nsoal bersahabat dengan binatang liar?
Dialogue: 0,0:14:39.36,0:14:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:14:42.99,0:14:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua
Dialogue: 0,0:14:45.53,0:14:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah musuh.
Dialogue: 0,0:14:48.03,0:14:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka adalah partner kita\Nyang tidak ada gantinya!
Dialogue: 0,0:15:06.43,0:15:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Da-Dasar ternak-ternak sialan!
Dialogue: 0,0:15:26.86,0:15:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memanggil hewan yang ada\Ndi dalam tubuhku dan menjinakkannya!
Dialogue: 0,0:15:31.83,0:15:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Binatang.
Dialogue: 0,0:15:34.25,0:15:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan duel antara aku dan dirimu.
Dialogue: 0,0:15:39.33,0:15:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertarungan semua orang\Nuntuk memutus rantai mereka.
Dialogue: 0,0:15:49.05,0:15:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial... sial!
Dialogue: 0,0:15:52.26,0:15:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian keroco sialan!
Dialogue: 0,0:16:25.84,0:16:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang hebat, Pengguna Hamster.
Dialogue: 0,0:17:11.58,0:17:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Upacara Darah Binatang.
Dialogue: 0,0:17:14.47,0:17:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari ulang tahun ke-13 anggota\Nkeluarga utama Pengguna Binatang,
Dialogue: 0,0:17:19.52,0:17:23.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepala keluarga akan memberi partner\Nyang nantinya menemani mereka seumur hidup.
Dialogue: 0,0:17:23.94,0:17:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur dan disiplin.
Dialogue: 0,0:17:26.02,0:17:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Binatang untuk Toshiro yang pantas\Nmenjadi kepala keluarga selanjutnya
Dialogue: 0,0:17:29.53,0:17:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti harimau atau mungkin serigala.
Dialogue: 0,0:17:33.12,0:17:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kepala keluarga Pengguna Binatang
Dialogue: 0,0:17:36.83,0:17:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan memberikan binatang\Nuntuk menjadi rekan bagi Dogo Toshiro.
Dialogue: 0,0:17:56.64,0:17:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:59.02,0:18:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:08.48,0:18:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan penuh hormat akan saya terima.
Dialogue: 0,0:18:14.32,0:18:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matanya yang bicara.
Dialogue: 0,0:18:17.24,0:18:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kamu tidak layak sebagai kepala keluarga."
Dialogue: 0,0:18:20.20,0:18:24.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kelelawar adalah yang paling cocok untukmu."
Dialogue: 0,0:18:28.75,0:18:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan besar khawatir\Npada kemampuanku
Dialogue: 0,0:18:32.55,0:18:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan takut posisi kepala keluarga\Nakan kurebut.
Dialogue: 0,0:18:35.80,0:18:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:18:37.05,0:18:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:18:39.06,0:18:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubunuh sesuai harapan kalian
Dialogue: 0,0:18:43.60,0:18:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku yang jadi kepala keluarga!
Dialogue: 0,0:18:46.69,0:18:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku!
Dialogue: 0,0:19:03.79,0:19:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, kenapa aku masih hidup?
Dialogue: 0,0:19:08.50,0:19:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkena serangan racun mematikan\Nyang sudah dikuasai
Dialogue: 0,0:19:11.88,0:19:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepala Pengguna Racun\Nyang berikutnya, Gero Hikaru.
Dialogue: 0,0:19:16.26,0:19:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa aku belum mati?
Dialogue: 0,0:19:19.30,0:19:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:19:24.14,0:19:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keampuhan dari racun mematikan
Dialogue: 0,0:19:26.73,0:19:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan bergantung pada sifat Racun Raga\Nyang Tuan Hikaru kembangkan sendiri.
Dialogue: 0,0:19:33.61,0:19:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Racun ini adalah kehendakku.
Dialogue: 0,0:19:39.66,0:19:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin membunuhmu\Natau pun menang darimu.
Dialogue: 0,0:19:44.00,0:19:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya
Dialogue: 0,0:19:45.66,0:19:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin membantu Arashiyama\Ndan mereka semua.
Dialogue: 0,0:19:51.75,0:19:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah Lima Keluarga Besar adalah kutukan!
Dialogue: 0,0:19:56.43,0:19:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terlahir di Lima Keluarga Besar
Dialogue: 0,0:19:59.39,0:20:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya akan memakan atau dimakan\Norang lain, kamu tahu itu, kan?
Dialogue: 0,0:20:10.73,0:20:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah bukanlah kutukan.
Dialogue: 0,0:20:17.07,0:20:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupertaruhkan hidupku\Nuntuk membuktikannya.
Dialogue: 0,0:20:24.29,0:20:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka camilan mainan.
Dialogue: 0,0:20:29.50,0:20:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang butuh usaha ekstra\Nitu lebih cocok untukku.
Dialogue: 0,0:20:37.72,0:20:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh sekali.
Dialogue: 0,0:20:40.93,0:20:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Binatang.
Dialogue: 0,0:20:43.14,0:20:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu masih menyembunyikan\Nrencana yang berbahaya?
Dialogue: 0,0:20:46.98,0:20:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau mengatakan semuanya—
Dialogue: 0,0:20:55.11,0:20:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Byakko, apa yang kamu lakukan?
Dialogue: 0,0:21:07.62,0:21:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Toshiro.
Dialogue: 0,0:21:10.67,0:21:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya akan menemani Anda\Nmulai dari nol lagi.
Dialogue: 0,0:21:20.30,0:21:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan kabur!
Dialogue: 0,0:21:49.83,0:21:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:21:58.63,0:22:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena kakakku sudah membuat ribut.
Dialogue: 0,0:22:03.89,0:22:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari, aku baru saja ditunjuk\Nsebagai kepala keluarga.
Dialogue: 0,0:22:08.18,0:22:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Pengguna Binatang, Dogo Tonako.
Dialogue: 0,0:23:45.99,0:23:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sejujurnya, Arashiyama suka sama Gero.\N- Serahkan saja, aku pasti akan membuat Gero...
Dialogue: 0,0:23:47.82,0:23:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh, mereka bikin emosi saja!\N- Latihan seribu siksa?
Dialogue: 0,0:23:49.28,0:23:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku hampir mati dengan penuh semangat!\N- Betulan suka padaku? Tidak bohong, kan?
Dialogue: 0,0:23:50.53,0:23:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku hampir mati dengan penuh semangat!\N- ...pasti bisa menikah dengan bahagia.
Dialogue: 0,0:23:52.12,0:23:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukainya!
Dialogue: 0,0:23:53.16,0:23:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Makasih, Ya.
