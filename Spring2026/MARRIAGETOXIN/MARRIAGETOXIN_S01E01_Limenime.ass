Dialogue: 0,0:01:15.81,0:01:21.64,tanda,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:03:00.58,0:03:03.33,tanda,,0000,0000,0000,,ADA SATU PESAN BARU - PENGGUNA SERANGGA
Dialogue: 0,0:15:51.98,0:15:54.02,tanda,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:15:54.02,0:15:56.02,tanda,,0000,0000,0000,,PENGGUNA RACUN CARI JODOH
Dialogue: 0,0:18:13.36,0:18:17.03,tanda,,0000,0000,0000,,COCOK! KIRIM PESAN/KEMBALI
Dialogue: 0,0:18:17.03,0:18:22.04,tanda,,0000,0000,0000,,KEDAI KOPI IOGI
Dialogue: 0,0:20:38.51,0:20:41.43,tanda,,0000,0000,0000,,TAMBAHKAN TEMAN
Dialogue: 0,0:23:19.51,0:23:22.13,tanda,,0000,0000,0000,,TEMAN 1
Dialogue: 0,0:23:53.20,0:23:55.91,tanda,,0000,0000,0000,,DAYA TARIK ITU APA?
Dialogue: 0,0:00:18.10,0:00:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Motonya, kehangatan manusia.
Dialogue: 0,0:00:22.50,0:00:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 15 tahun Furnitur Manusia berdiri.
Dialogue: 0,0:00:25.96,0:00:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski berkali-kali nyaris bangkrut,
Dialogue: 0,0:00:28.63,0:00:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita selalu bangkit kembali\Nmenggunakan cara kejam.
Dialogue: 0,0:00:33.39,0:00:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua upaya tersebut,\Nberbuah manis pada hari ini.
Dialogue: 0,0:00:39.95,0:00:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lezat.
Dialogue: 0,0:00:41.23,0:00:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak beracun.
Dialogue: 0,0:00:42.75,0:00:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, Pak Presiden.
Dialogue: 0,0:00:45.45,0:00:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamotsu, lalu Natsumi.
Dialogue: 0,0:00:48.35,0:00:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas pernikahannya.
Dialogue: 0,0:00:49.83,0:00:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lahirkanlah banyak putra tangguh\Nuntuk jadi penerus.
Dialogue: 0,0:00:54.41,0:00:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:00:55.74,0:00:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!
Dialogue: 0,0:01:04.48,0:01:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Presiden!
Dialogue: 0,0:01:06.21,0:01:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tidak becus!
Dialogue: 0,0:01:07.96,0:01:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:01:08.92,0:01:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada racunnya!
Dialogue: 0,0:01:10.30,0:01:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aku yang meracuni!
Dialogue: 0,0:01:35.43,0:01:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa triknya?
Dialogue: 0,0:01:37.41,0:01:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengelabui pencicip racun ulung\Ndan berhasil memasukkan racun.
Dialogue: 0,0:01:41.04,0:01:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:01:42.35,0:01:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menciptakan antibodi\Ndi tubuh si pencicip racun.
Dialogue: 0,0:01:45.69,0:01:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antibodi? Kok bisa?
Dialogue: 0,0:01:48.00,0:01:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan si pencicip kucampurkan\Nracun berdosis kecil selama tiga bulan.
Dialogue: 0,0:01:52.87,0:01:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar dia kebal saat kena dosis mematikan.
Dialogue: 0,0:01:57.06,0:01:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu sangat merepotkan?
Dialogue: 0,0:01:59.97,0:02:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:02:01.06,0:02:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak seorang pun kepikiran\Nmelakukan hal konyol itu.
Dialogue: 0,0:02:04.48,0:02:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah kita bisa\Nmenjalankan pekerjaan.
Dialogue: 0,0:02:08.30,0:02:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\NKakak sudah memikirkan soal itu?
Dialogue: 0,0:02:11.78,0:02:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal apa?
Dialogue: 0,0:02:13.15,0:02:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernikahan.
Dialogue: 0,0:02:17.95,0:02:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akari, kamu pikir aku bisa menikah?
Dialogue: 0,0:02:21.58,0:02:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil dapat jodoh di pekerjaan ini.
Dialogue: 0,0:02:24.08,0:02:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:02:24.79,0:02:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:02:26.58,0:02:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek ingin salah satu dari kita\Nmeneruskan keluarga Pengguna Racun.
Dialogue: 0,0:02:31.29,0:02:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena menolak dan bilang\Ntidak punya calon,
Dialogue: 0,0:02:34.18,0:02:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dipertemukan anak keluarga cabang\Nyang wajahnya pun asing
Dialogue: 0,0:02:37.22,0:02:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hampir dijodohkan paksa.
Dialogue: 0,0:02:40.53,0:02:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu berlebihan.
Dialogue: 0,0:02:43.35,0:02:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Pengguna Racun\Nakan berakhir di generasiku.
Dialogue: 0,0:02:46.02,0:02:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal lajang selamanya.
Dialogue: 0,0:02:48.29,0:02:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga tinggal saja sama pacarmu.
Dialogue: 0,0:02:54.25,0:02:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, Kakak memang enggak akan laku, sih.
Dialogue: 0,0:02:58.12,0:02:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel.
Dialogue: 0,0:03:04.19,0:03:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak jumpa, Pengguna Serangga.
Dialogue: 0,0:03:07.45,0:03:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga tidak berubah—
Dialogue: 0,0:03:10.19,0:03:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Julia.
Dialogue: 0,0:03:12.63,0:03:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yey.
Dialogue: 0,0:03:18.09,0:03:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna Jarum katanya\Nsudah punya tiga anak.
Dialogue: 0,0:03:21.22,0:03:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya laki-laki.
Dialogue: 0,0:03:22.77,0:03:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang biaya makannya gila sekali.
Dialogue: 0,0:03:25.02,0:03:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lagi pula aku mau terus melajang.
Dialogue: 0,0:03:28.57,0:03:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bakal lebih santai, kan?
Dialogue: 0,0:03:31.11,0:03:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu...
Dialogue: 0,0:03:33.31,0:03:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam waktu dekat,\Naku berencana menikah.
Dialogue: 0,0:03:39.16,0:03:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jujur, baik,
Dialogue: 0,0:03:41.57,0:03:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menerima jati diriku apa adanya.
Dialogue: 0,0:03:44.29,0:03:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya.
Dialogue: 0,0:03:46.86,0:03:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak mengira, kan?
Dialogue: 0,0:03:48.59,0:03:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, kukira kamu\Nbakal lebih enggak laku.
Dialogue: 0,0:03:52.71,0:03:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begini,\Naku berjuang habis-habisan, lo.
Dialogue: 0,0:03:57.06,0:03:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tukang gocek.
Dialogue: 0,0:04:00.01,0:04:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero.
Dialogue: 0,0:04:01.85,0:04:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah menikah,\Nkita akan tetap bersahabat.
Dialogue: 0,0:04:06.88,0:04:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:04:08.10,0:04:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, selamat.
Dialogue: 0,0:04:14.13,0:04:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti, Gero.
Dialogue: 0,0:04:16.24,0:04:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo minum lagi kalau senggang.
Dialogue: 0,0:04:19.32,0:04:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Pengguna Serangga.
Dialogue: 0,0:04:21.89,0:04:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hebat.
Dialogue: 0,0:04:24.79,0:04:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa menemukan sosok yang berharga.
Dialogue: 0,0:04:28.46,0:04:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya itu mustahil bagiku.
Dialogue: 0,0:04:31.81,0:04:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya kesan baik soal pernikahan.
Dialogue: 0,0:04:34.99,0:04:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mendengar ceritamu,
Dialogue: 0,0:04:37.47,0:04:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa menikah tidak seburuk itu.
Dialogue: 0,0:04:41.59,0:04:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku tidak akan mengalaminya, sih.
Dialogue: 0,0:04:49.26,0:04:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah kehormatan kamu mau datang ke sini!
Dialogue: 0,0:04:52.23,0:04:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisnisnya kelihatan lancar, ya.
Dialogue: 0,0:04:54.82,0:04:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga berkatmu.
Dialogue: 0,0:04:56.65,0:05:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Layanan pembersihan kami\Npunya harga terjangkau
Dialogue: 0,0:05:00.15,0:05:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar bisa diakses khalayak.
Dialogue: 0,0:05:03.82,0:05:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mereka berdua
Dialogue: 0,0:05:05.79,0:05:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pembunuh sekaligus sekretaris\Nyang kerja di sini.
Dialogue: 0,0:05:08.45,0:05:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan gunakan untuk membantu\Npekerjaan atau menghiburmu.
Dialogue: 0,0:05:14.63,0:05:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:05:16.38,0:05:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, kurang suka begituan, ya?
Dialogue: 0,0:05:19.22,0:05:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak, tunggu seben—
Dialogue: 0,0:05:21.56,0:05:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dinding sekat antipeluru.\NKeren, kan?
Dialogue: 0,0:05:26.97,0:05:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sampah masyarakat\Nyang harus Pak Gero urus.
Dialogue: 0,0:05:30.43,0:05:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penipu pernikahan yang super jahat,\NKinosaki Mei!
Dialogue: 0,0:05:34.65,0:05:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah banyak mengacau di daerah kami.
Dialogue: 0,0:05:38.61,0:05:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong dibereskan.
Dialogue: 0,0:05:43.49,0:05:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kamu siapa?
Dialogue: 0,0:05:47.37,0:05:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarafmu akan
Dialogue: 0,0:05:49.33,0:05:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai kebas dari ujung kaki ke ujung kepala
Dialogue: 0,0:05:52.50,0:05:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu merasa sakit luar biasa\Nseakan sedang dimutilasi.
Dialogue: 0,0:05:57.38,0:06:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kamu tidak akan hilang kesadaran.
Dialogue: 0,0:06:01.91,0:06:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir akan dihabisi\Nracun mematikan racikanku.
Dialogue: 0,0:06:06.13,0:06:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyesallah karena terlahir ke dunia.
Dialogue: 0,0:06:08.39,0:06:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, namaku Kinosaki Mei.
Dialogue: 0,0:06:12.48,0:06:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pernah—
Dialogue: 0,0:06:13.14,0:06:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:06:15.77,0:06:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, anu...
Dialogue: 0,0:06:18.81,0:06:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mirip cinta pertamaku,\Njadinya kelepasan.
Dialogue: 0,0:06:22.45,0:06:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penipu pernikahan\Nmau merayu biar selamat, ya.
Dialogue: 0,0:06:28.23,0:06:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang melakukan\Npenipuan pernikahan.
Dialogue: 0,0:06:31.62,0:06:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang butuh uang dalam jumlah besar.
Dialogue: 0,0:06:35.33,0:06:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menolong adikku yang sakit.
Dialogue: 0,0:06:38.34,0:06:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berutang ke sana-sini\Ndan ambil kerjaan yang tidak pantas diumbar.
Dialogue: 0,0:06:42.84,0:06:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya uangku tetap belum cukup.
Dialogue: 0,0:06:49.60,0:06:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau bisa mati\Nditemani kembaran orang terkasihku...
Dialogue: 0,0:06:55.64,0:06:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata hidup tidak seburuk itu, ya.
Dialogue: 0,0:06:59.50,0:07:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, setidaknya beri tahu namamu.
Dialogue: 0,0:07:06.40,0:07:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero.
Dialogue: 0,0:07:08.25,0:07:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direktur, apa si Gero baik-baik saja?
Dialogue: 0,0:07:11.49,0:07:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat targetnya cuma kriminal\Ndan sampah masyarakat.
Dialogue: 0,0:07:15.41,0:07:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pikir siapa dirinya?
Dialogue: 0,0:07:17.84,0:07:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang ahli Pengguna Racun.
Dialogue: 0,0:07:19.84,0:07:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Gero salah satu\Nyang paling tua dari yang tertua.
Dialogue: 0,0:07:23.96,0:07:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski memegang prinsip konyol,
Dialogue: 0,0:07:26.34,0:07:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemampuannya asli\Ndan banyak pelanggannya.
Dialogue: 0,0:07:29.26,0:07:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yah, kita saksikan saja.\N- Gero.
Dialogue: 0,0:07:33.14,0:07:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:36.35,0:07:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bukan apa-apa.
Dialogue: 0,0:07:40.45,0:07:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan wanita ini...
Dialogue: 0,0:07:43.60,0:07:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedang...
Dialogue: 0,0:07:46.83,0:07:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jatuh cinta padaku?
Dialogue: 0,0:07:51.37,0:07:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, maaf pakai telepon darurat.
Dialogue: 0,0:07:54.16,0:07:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:55.45,0:07:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pulang ke rumah keluarga kita.
Dialogue: 0,0:07:58.08,0:08:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ada yang ingin kusampaikan.
Dialogue: 0,0:08:00.54,0:08:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:02.15,0:08:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melahirkan penerus\Nkeluarga Pengguna Racun Gero.
Dialogue: 0,0:08:06.50,0:08:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan keluarga cabang sedang cari calon.
Dialogue: 0,0:08:09.01,0:08:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!\NBuat apa?
Dialogue: 0,0:08:11.35,0:08:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Kakak tidak mengerti,\Ntapi nenek serius.
Dialogue: 0,0:08:15.52,0:08:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diberi tahu langsung.
Dialogue: 0,0:08:17.44,0:08:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kakak tidak memberi penerus\Ndan aku juga menolak.
Dialogue: 0,0:08:21.23,0:08:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dipaksa mengandung secara paksa.
Dialogue: 0,0:08:25.32,0:08:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada begitu,\Nlebih baik aku maju sendiri, kan?
Dialogue: 0,0:08:29.92,0:08:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akari, terus bagaimana pacarmu?
Dialogue: 0,0:08:33.21,0:08:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami cuma bisa putus.
Dialogue: 0,0:08:35.87,0:08:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:08:37.19,0:08:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus apa?
Dialogue: 0,0:08:38.15,0:08:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak mau menggantikanku?
Dialogue: 0,0:08:41.05,0:08:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu yang tidak boleh.
Dialogue: 0,0:08:42.91,0:08:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma di saat begini aku bisa berguna.
Dialogue: 0,0:08:46.86,0:08:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggulah sebentar.
Dialogue: 0,0:08:48.34,0:08:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:50.07,0:08:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak mau mati,\Nmenikahlah denganku.
Dialogue: 0,0:08:54.26,0:08:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menikah untuk meneruskan\Nkeluarga pengguna racun.
Dialogue: 0,0:08:58.65,0:09:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau harus memilih,\Naku mau orang yang mencintaiku.
Dialogue: 0,0:09:02.52,0:09:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membantu pengobatan adikmu.
Dialogue: 0,0:09:07.78,0:09:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku pantas sebahagia ini?
Dialogue: 0,0:09:15.66,0:09:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas...
Dialogue: 0,0:09:19.46,0:09:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah banget.
Dialogue: 0,0:09:24.38,0:09:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah wajah yang kutunggu.
Dialogue: 0,0:09:27.17,0:09:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya kalau mati,\Naku enggak kalah secara sepihak.
Dialogue: 0,0:09:33.18,0:09:35.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, lega rasanya!
Dialogue: 0,0:09:35.39,0:09:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasangan di dunia ini.
Dialogue: 0,0:09:38.18,0:09:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau itu sifat, keuangan, atau penampilan.
Dialogue: 0,0:09:41.51,0:09:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berpasangan dari kecocokan itu.
Dialogue: 0,0:09:44.61,0:09:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan berengseknya kamu melamar\Norang sambil memegang nyawanya,
Dialogue: 0,0:09:48.53,0:09:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mana mungkin diterima.
Dialogue: 0,0:09:51.15,0:09:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:09:52.45,0:09:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau memang ingin\Nketemu orang seperti itu.
Dialogue: 0,0:09:56.37,0:09:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ungkapkan dulu isi hatimu.
Dialogue: 0,0:09:59.58,0:10:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang saling memahami,\Nberselisih, bahkan hancur lebur
Dialogue: 0,0:10:03.75,0:10:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi dapat pasangan terbaik.
Dialogue: 0,0:10:06.46,0:10:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin ingin menikah\Nuntuk meneruskan keluarga?
Dialogue: 0,0:10:15.42,0:10:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Pak Gero?\NTolong cepat lakukan.
Dialogue: 0,0:10:19.22,0:10:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah bayar mahal buat nonton, nih.
Dialogue: 0,0:10:23.74,0:10:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya akan menghabisi sampah\Nyang jadi racun di masyarakat.
Dialogue: 0,0:10:29.01,0:10:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan atas rasa keadilan.
Dialogue: 0,0:10:31.35,0:10:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tidak ingin susah tidur\Nsetelah membunuh.
Dialogue: 0,0:10:33.90,0:10:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, pembunuh tetaplah pembunuh.
Dialogue: 0,0:10:37.17,0:10:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ada kalanya aku ingin hidup damai\Nbersama sosok yang kucintai.
Dialogue: 0,0:10:43.30,0:10:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku muak sama sisi itu.
Dialogue: 0,0:10:47.42,0:10:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga...
Dialogue: 0,0:10:49.42,0:10:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin bertemu orang yang betulan kucintai\Ndan hidup bahagia bersama!
Dialogue: 0,0:10:55.30,0:10:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum makan malam atau tidur,
Dialogue: 0,0:10:56.97,0:11:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pengin ada obrolan remeh\Nkayak, "Bagaimana harimu?"
Dialogue: 0,0:11:00.06,0:11:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau ditanyai, "Kamu kenapa?",\Nsaat aku batuk!
Dialogue: 0,0:11:04.06,0:11:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi!
Dialogue: 0,0:11:06.13,0:11:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku dapat jodoh.
Dialogue: 0,0:11:09.32,0:11:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah sekolah bahkan dari TK.
Dialogue: 0,0:11:12.03,0:11:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kecil aku hidup sebagai pengguna racun.
Dialogue: 0,0:11:15.32,0:11:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunjukkan sisi lemah\Npada lawan bisa jadi fatal.
Dialogue: 0,0:11:18.91,0:11:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuka diri dan curhat ke orang asing
Dialogue: 0,0:11:22.20,0:11:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jelas mustahil bagiku!
Dialogue: 0,0:11:25.71,0:11:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya!
Dialogue: 0,0:11:28.46,0:11:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa, sih?
Dialogue: 0,0:11:31.21,0:11:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru saja cerita isi hatimu\Nke orang baru sepertiku, lo.
Dialogue: 0,0:11:36.38,0:11:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status pembunuh memang\Nminus yang besar.
Dialogue: 0,0:11:40.51,0:11:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu cuma perlu bertemu banyak orang.
Dialogue: 0,0:11:45.56,0:11:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menunjukkan isi hatimu\Ndan berusaha mati-matian,
Dialogue: 0,0:11:49.73,0:11:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti ada yang tertarik padamu.
Dialogue: 0,0:11:53.82,0:11:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, pasti susah, sih.
Dialogue: 0,0:11:58.16,0:12:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, bunuh saja aku.
Dialogue: 0,0:12:00.70,0:12:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampah masyarakat.
Dialogue: 0,0:12:02.79,0:12:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengobatan adikku akan terhenti.\NKarena kelalaianku,
Dialogue: 0,0:12:07.54,0:12:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena merenggut\Nmasa depan orang yang kusayang,
Dialogue: 0,0:12:12.31,0:12:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku memang sampah sejati.
Dialogue: 0,0:12:15.84,0:12:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Gero, sudah cukup.
Dialogue: 0,0:12:19.01,0:12:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah konsultasi asmara\Nsama penipu pernikahan.
Dialogue: 0,0:12:22.51,0:12:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah habisi sampah itu!
Dialogue: 0,0:12:26.49,0:12:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:12:28.35,0:12:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membutuhkanmu!
Dialogue: 0,0:12:30.81,0:12:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu populer sampai bisa bertunangan\Nsama banyak orang, kan?
Dialogue: 0,0:12:34.17,0:12:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta bantuanmu\Nsebagai ahli pernikahan.
Dialogue: 0,0:12:36.83,0:12:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupmu dan adikmu,\Nakan kujamin sebisa mungkin!
Dialogue: 0,0:12:40.91,0:12:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bantu aku supaya bisa menikah!
Dialogue: 0,0:12:47.82,0:12:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari sekian banyak pengalaman asmara ini,
Dialogue: 0,0:12:51.63,0:12:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baru kali ini aku dilamar seperti itu.
Dialogue: 0,0:12:54.55,0:12:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:12:55.88,0:12:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa keluar dari sini, kan?
Dialogue: 0,0:12:58.76,0:13:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kecewa, Pak Gero.
Dialogue: 0,0:13:02.22,0:13:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:13:03.85,0:13:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sepakat.
Dialogue: 0,0:13:06.68,0:13:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membunuh calon penerus\Nkeluarga pengguna racun,
Dialogue: 0,0:13:09.73,0:13:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nama bisnis kami bakal meroket, nih!
Dialogue: 0,0:13:13.98,0:13:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian memberi layanan tarif rendah\Nke warga biasa,
Dialogue: 0,0:13:19.09,0:13:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu memeras mereka seumur hidup.
Dialogue: 0,0:13:23.21,0:13:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak hidup yang sudah kalian rusak?
Dialogue: 0,0:13:26.01,0:13:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana kutahu!
Dialogue: 0,0:13:27.16,0:13:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salahnya memanfaatkan orang bodoh?
Dialogue: 0,0:13:29.58,0:13:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sok pahlawan?
Dialogue: 0,0:13:31.97,0:13:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma memastikan syaratnya.
Dialogue: 0,0:13:35.42,0:13:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian adalah...
Dialogue: 0,0:13:45.10,0:13:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampah masyarakat.
Dialogue: 0,0:13:47.56,0:13:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!\NBunuh mereka!
Dialogue: 0,0:14:05.41,0:14:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kok hilang?
Dialogue: 0,0:14:07.87,0:14:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutunjukkan secara khusus
Dialogue: 0,0:14:13.05,0:14:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cara pengguna racun bekerja.
Dialogue: 0,0:14:18.51,0:14:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:14:21.13,0:14:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukan sok jago,\Ntapi benaran jagoan?
Dialogue: 0,0:14:27.01,0:14:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebanyak apa pun,\Nkeroco tetaplah keroco.
Dialogue: 0,0:14:29.68,0:14:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, ini sekadar pedasnya 300 neraka.
Dialogue: 0,0:14:33.61,0:14:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kubuat trauma\Nbiar kapok bisnis begini lagi.
Dialogue: 0,0:14:39.19,0:14:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, soal bahasan yang tadi,\Naku pergi dulu, ya.
Dialogue: 0,0:14:43.03,0:14:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akari.
Dialogue: 0,0:14:46.87,0:14:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu meneruskan keluarga.
Dialogue: 0,0:14:49.41,0:14:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, perasaanku—
Dialogue: 0,0:14:53.63,0:14:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.
Dialogue: 0,0:14:56.55,0:14:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bertemu dan hidup bersama\Norang yang berharga bagimu,
Dialogue: 0,0:14:59.88,0:15:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaikan keajaiban.
Dialogue: 0,0:15:03.15,0:15:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiduplah bersama pacarmu!
Dialogue: 0,0:15:06.76,0:15:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan ke Nenek.
Dialogue: 0,0:15:09.62,0:15:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menikah dan menjadi\Npenerus pengguna racun.
Dialogue: 0,0:15:12.47,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, biar kucari sendiri calonnya.
Dialogue: 0,0:15:18.27,0:15:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu?
Dialogue: 0,0:15:20.73,0:15:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak memang seenaknya.
Dialogue: 0,0:15:24.86,0:15:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, terserahlah.\NAkan kusampaikan.
Dialogue: 0,0:15:31.37,0:15:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:32.66,0:15:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum bisa bergerak.
Dialogue: 0,0:15:34.58,0:15:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana caraku menggendongmu?
Dialogue: 0,0:15:36.92,0:15:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah menyentuh wanita\Nselain saat bekerja,
Dialogue: 0,0:15:39.75,0:15:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagian mana yang boleh kusentuh?
Dialogue: 0,0:15:43.21,0:15:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman saja kalau soal itu.
Dialogue: 0,0:15:45.55,0:15:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku cowok.
Dialogue: 0,0:15:47.26,0:15:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oalah, kalau begitu...
Dialogue: 0,0:15:50.68,0:15:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:57.48,0:16:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mandi sehabis medan perang\Nmemang beda rasanya.
Dialogue: 0,0:16:00.81,0:16:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, enggak mau mandi bareng?
Dialogue: 0,0:16:02.94,0:16:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:16:04.44,0:16:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada masalah, kan?
Dialogue: 0,0:16:06.61,0:16:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:16:08.70,0:16:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, energi hidupku penuh lagi.
Dialogue: 0,0:16:11.58,0:16:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini...
Dialogue: 0,0:16:12.58,0:16:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dilihat dari mana pun,\Ntidak terlihat seperti cowok?"
Dialogue: 0,0:16:15.41,0:16:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba periksa?
Dialogue: 0,0:16:20.25,0:16:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu dandan jadi cewek?
Dialogue: 0,0:16:22.75,0:16:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:23.63,0:16:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena korbanku yang terakhir cowok.
Dialogue: 0,0:16:26.13,0:16:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu menggoda cewek,\Naku dandan cowok, kok.
Dialogue: 0,0:16:28.51,0:16:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi keduanya itu seru, kan?
Dialogue: 0,0:16:31.01,0:16:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, melamarku adalah pilihan tepat.
Dialogue: 0,0:16:34.61,0:16:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melam—
Dialogue: 0,0:16:35.43,0:16:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengajari cara merayu\Ncewek maupun cowok.
Dialogue: 0,0:16:39.69,0:16:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, cepat ajari aku—
Dialogue: 0,0:16:41.33,0:16:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ini.
Dialogue: 0,0:16:43.02,0:16:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kudaftarkan ikut pesta cari jodoh.
Dialogue: 0,0:16:45.82,0:16:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi profilmu.
Dialogue: 0,0:16:47.24,0:16:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:16:47.82,0:16:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sekarang sudah ganti hari,\Nberarti hari ini, dong?
Dialogue: 0,0:16:51.62,0:16:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan...
Dialogue: 0,0:16:53.62,0:16:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kalau diisi jujur bisa bahaya.
Dialogue: 0,0:16:57.02,0:16:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerja mandiri.
Dialogue: 0,0:17:00.06,0:17:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peserta laki-laki jumlahnya\Njauh lebih banyak.
Dialogue: 0,0:17:03.42,0:17:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi akan kurayu semua pria\Ndan mengurangi sainganmu.
Dialogue: 0,0:17:07.92,0:17:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham, Gero?
Dialogue: 0,0:17:09.42,0:17:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesan bersih dan fesyen itu\Nhanya teknik agar tidak dibenci.
Dialogue: 0,0:17:13.93,0:17:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meningkatkannya cuma bakal\Nmentok dianggap "orang baik".
Dialogue: 0,0:17:16.56,0:17:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mencari\Ndan mengembangkan daya tarikmu,
Dialogue: 0,0:17:19.31,0:17:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lawan jenis tidak akan terpesona.
Dialogue: 0,0:17:21.34,0:17:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja praktik langsung.
Dialogue: 0,0:17:25.35,0:17:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, salam kenal.
Dialogue: 0,0:17:27.60,0:17:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyelidiki\Nkalau kesan pertama itu segalanya.
Dialogue: 0,0:17:31.29,0:17:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya kalimat paling ampuh.
Dialogue: 0,0:17:34.70,0:17:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Gero.
Dialogue: 0,0:17:36.24,0:17:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendapatanku per tahun **** yen.
Dialogue: 0,0:17:38.29,0:17:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa begitu!
Dialogue: 0,0:17:39.87,0:17:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang malah jijik, tuh!
Dialogue: 0,0:17:41.29,0:17:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, daya tarikku\Ncuma pendapatan tahunan!
Dialogue: 0,0:17:43.46,0:17:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan tenar nomor satu!
Dialogue: 0,0:17:45.04,0:17:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja, kalau langsung begitu,\Nbakal dicap bedebah tukang pamer!
Dialogue: 0,0:17:49.80,0:17:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, tatap dulu matanya\Nlalu senyum dan ajak bicara.
Dialogue: 0,0:18:07.48,0:18:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang nanti, cari tutorial senyum, ah.
Dialogue: 0,0:18:10.74,0:18:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, selanjutnya ini, ya.
Dialogue: 0,0:18:12.57,0:18:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:18:13.36,0:18:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lewat aplikasi kencan,
Dialogue: 0,0:18:14.87,0:18:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu bisa ngobrol santai sama cewek.
Dialogue: 0,0:18:17.03,0:18:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kucarikan dalam sekejap.
Dialogue: 0,0:18:19.70,0:18:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita keluarkan pesonamu.
Dialogue: 0,0:18:23.79,0:18:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu...
Dialogue: 0,0:18:25.58,0:18:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna racun umumnya tidak akan\Nmemakan pemberian orang lain.
Dialogue: 0,0:18:29.05,0:18:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini insting yang terukir\Nuntuk melindungi diri!
Dialogue: 0,0:18:32.03,0:18:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kayaknya tidak ada\Nyang mengincarku di sini!
Dialogue: 0,0:18:36.39,0:18:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pasti aman!\NPasti aman!
Dialogue: 0,0:18:39.22,0:18:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan ini?
Dialogue: 0,0:18:43.39,0:18:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke, selanjutnya gadis ini.
Dialogue: 0,0:18:46.65,0:18:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Selanjutnya.
Dialogue: 0,0:18:50.61,0:18:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya.
Dialogue: 0,0:19:02.54,0:19:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini saja aku hampir\Nketemu 30 wanita.
Dialogue: 0,0:19:06.86,0:19:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak ada yang bisa\Ndiminta bertukar kontak.
Dialogue: 0,0:19:09.63,0:19:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu sudah berjuang, kok.
Dialogue: 0,0:19:14.30,0:19:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, memang benar.
Dialogue: 0,0:19:16.18,0:19:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tujuan kita mencari daya tarikmu,
Dialogue: 0,0:19:19.06,0:19:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuharap ada momen bagus sekali saja.
Dialogue: 0,0:19:22.64,0:19:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, jangan-jangan\Naku memang tidak punya daya tarik?
Dialogue: 0,0:19:28.06,0:19:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya!
Dialogue: 0,0:19:29.15,0:19:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti punya!
Dialogue: 0,0:19:30.36,0:19:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma belum ketahuan saja!
Dialogue: 0,0:19:33.55,0:19:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada orang yang tertarik padamu!
Dialogue: 0,0:19:36.32,0:19:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar mereka kelepek-kelepek,
Dialogue: 0,0:19:38.99,0:19:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar aku yang memoles\Ndan mengeluarkan daya tarikmu!
Dialogue: 0,0:19:43.58,0:19:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, sudah ada satu\Nyang bisa diasah, sih.
Dialogue: 0,0:19:46.67,0:19:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:48.67,0:19:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka camilan mainan.
Dialogue: 0,0:19:50.54,0:19:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:19:51.29,0:19:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sama-sama punya hobi unik,\Nobrolannya bisa seru, kan?
Dialogue: 0,0:19:54.55,0:19:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, cairan pembersih itu manjur banget.
Dialogue: 0,0:19:57.38,0:19:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Joker yang kuracik sendiri.
Dialogue: 0,0:19:59.97,0:20:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membersihkan kerak membandel pakai\Nracun mematikan itu pelepas stres nomor satu.
Dialogue: 0,0:20:04.61,0:20:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau serius, aku juga bisa membuat\Ncairan pembersih yang menguapkan besi.
Dialogue: 0,0:20:08.65,0:20:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, apa ini juga hobi unik?
Dialogue: 0,0:20:11.27,0:20:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasiakan hobimu yang ini selamanya, ya.
Dialogue: 0,0:20:16.95,0:20:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu juga.
Dialogue: 0,0:20:19.79,0:20:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, aku pulang lewat sini!
Dialogue: 0,0:20:22.10,0:20:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai besok!
Dialogue: 0,0:20:23.29,0:20:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:24.95,0:20:28.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, memang besok ada apa?\NKetemuan di mana?
Dialogue: 0,0:20:43.38,0:20:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki Mei, apa yang sudah\Nkamu lakukan pada abangku?
Dialogue: 0,0:20:47.60,0:20:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:48.39,0:20:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pura-pura bodoh.
Dialogue: 0,0:20:50.23,0:20:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bisnis payah ketinggalan zaman ini,\Nakan kuguncang bak gajah purba mengaum!"
Dialogue: 0,0:20:55.51,0:20:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abangku yang menyombongkan itu
Dialogue: 0,0:20:57.93,0:21:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang bilang mau meneruskan\Nusaha penatu di rumah keluarga.
Dialogue: 0,0:21:01.37,0:21:04.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia lelah hidup di kota?
Dialogue: 0,0:21:10.03,0:21:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bola timah.
Dialogue: 0,0:21:12.96,0:21:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu menggoda juga.
Dialogue: 0,0:21:15.05,0:21:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat kamu mengakui semuanya.
Dialogue: 0,0:21:18.27,0:21:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau serius mau minta ampun.
Dialogue: 0,0:21:20.88,0:21:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar ku—
Dialogue: 0,0:21:21.68,0:21:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada jadi rekan bajingan\Nyang memeras orang biasa,
Dialogue: 0,0:21:25.10,0:21:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik aku mati!
Dialogue: 0,0:21:28.39,0:21:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani juga cakapmu.
Dialogue: 0,0:21:30.39,0:21:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari makan di dunia gelap,\Ntapi enggan melibatkan warga sipil?
Dialogue: 0,0:21:35.82,0:21:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang prinsipnya lemah\Ntidak akan bertahan hidup.
Dialogue: 0,0:21:40.72,0:21:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat wajah imut yang jadi\Nsenjatamu itu tidak berguna lagi.
Dialogue: 0,0:21:45.86,0:21:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, senapan gotri.
Dialogue: 0,0:21:49.62,0:21:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos!
Dialogue: 0,0:21:51.72,0:21:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Depan!
Dialogue: 0,0:21:55.21,0:21:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero?
Dialogue: 0,0:21:56.46,0:21:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah!
Dialogue: 0,0:21:57.46,0:21:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tabrak saja sampai mati!
Dialogue: 0,0:22:43.27,0:22:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuteruskan bisnis penatunya.
Dialogue: 0,0:22:52.01,0:22:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melupakan ini.
Dialogue: 0,0:22:54.05,0:22:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:22:55.85,0:22:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, terima kasih.
Dialogue: 0,0:22:58.27,0:23:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil untukku bertemu\Nsebanyak itu dalam satu hari.
Dialogue: 0,0:23:02.44,0:23:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang menolak satu saja,\Naku pasti sedih selamanya.
Dialogue: 0,0:23:07.70,0:23:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berpengalaman,\Njadi mohon bimbingannya.
Dialogue: 0,0:23:10.74,0:23:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku tidak bertukar kontak\Ndengan siapa pun.
Dialogue: 0,0:23:14.21,0:23:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, dengar, dong!
Dialogue: 0,0:23:15.29,0:23:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, kalau mau,\Nayo bertukar kontak denganku.
Dialogue: 0,0:23:22.13,0:23:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya tidak akan bertambah lagi.
Dialogue: 0,0:23:25.05,0:23:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:23:27.05,0:23:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu menyilaukan sekali.
Dialogue: 0,0:23:30.87,0:23:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:23:31.81,0:23:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:23:32.72,0:23:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!\NDaya tarik terbesarnya Gero!
Dialogue: 0,0:23:36.02,0:23:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah pembunuh bayaran kelas satu,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:23:40.97,0:23:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sedang mencari jodoh.
Dialogue: 0,0:23:43.57,0:23:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:23:46.59,0:23:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini yang disebut tempat kencan, kan?\N- Kencan pertama Gero, gladi bersih.
Dialogue: 0,0:23:50.41,0:23:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu bilangnya bagaimana?\N- Pokoknya enggak mau!
Dialogue: 0,0:23:52.12,0:23:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa itu!
Dialogue: 0,0:23:53.20,0:23:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Daya Tarik Itu Apa?
