Dialogue: 0,0:01:59.56,0:02:02.27,tanda,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:03:47.92,0:03:52.21,tanda,,0000,0000,0000,,PENINGKATAN MUTASI KETURUNAN: HELL LASHES
Dialogue: 0,0:09:22.63,0:09:26.13,tanda,,0000,0000,0000,,SHIRATORI TAKERU: HEWAN MUNGIL VS TUBUH FISIK
Dialogue: 0,0:12:59.97,0:13:01.30,tanda,,0000,0000,0000,,MAAF~ TABRAKAN SAMA KENCAN LAIN~
Dialogue: 0,0:13:01.30,0:13:02.47,tanda,,0000,0000,0000,,GERO PASTI AMAN
Dialogue: 0,0:13:02.47,0:13:04.30,tanda,,0000,0000,0000,,SEMANGAT!
Dialogue: 0,0:13:04.30,0:13:05.93,tanda,,0000,0000,0000,,KAMU PASTI BISA!
Dialogue: 0,0:13:13.19,0:13:15.23,tanda,,0000,0000,0000,,MARRIAGETOXIN
Dialogue: 0,0:13:15.23,0:13:16.98,tanda,,0000,0000,0000,,PASANGAN PERTAMA
Dialogue: 0,0:13:36.09,0:13:37.92,tanda,,0000,0000,0000,,DIMANGSA
Dialogue: 0,0:13:44.22,0:13:45.30,tanda,,0000,0000,0000,,MISI KENCAN DIMULAI!
Dialogue: 0,0:14:26.97,0:14:29.72,tanda,,0000,0000,0000,,ANTING INDAH, KALUNG CANTIK
Dialogue: 0,0:14:29.72,0:14:32.39,tanda,,0000,0000,0000,,KUKU IMUT, JAKET MODIS
Dialogue: 0,0:18:33.63,0:18:35.59,tanda,,0000,0000,0000,,AYO PEPET!!
Dialogue: 0,0:20:54.77,0:20:57.24,tanda,,0000,0000,0000,,TEMAN 2
Dialogue: 0,0:23:53.20,0:23:55.96,tanda,,0000,0000,0000,,PENGGUNA SUARA
Dialogue: 0,0:00:12.85,0:00:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang terus mengasah\Nseni pembunuhan,
Dialogue: 0,0:00:15.96,0:00:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para "Pengguna".
Dialogue: 0,0:00:17.69,0:00:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah melalui garis keturunan\Nyang sangat panjang,
Dialogue: 0,0:00:20.79,0:00:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka mendapat teknik mematikan\Nyang disebut "Mutasi Keturunan".
Dialogue: 0,0:00:26.05,0:00:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kisah salah satu dari mereka,\NGero Hikaru sang Pengguna Racun
Dialogue: 0,0:00:31.77,0:00:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari jodoh.
Dialogue: 0,0:00:38.62,0:00:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hng...
Dialogue: 0,0:00:42.41,0:00:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sudah jam sebegini?
Dialogue: 0,0:00:47.65,0:00:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, Ibu, aku kan sudah minta\Nbuat harus dibangunkan!
Dialogue: 0,0:00:51.86,0:00:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal telat ke sekolah, dong, ini.
Dialogue: 0,0:00:55.33,0:00:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat!
Dialogue: 0,0:00:56.95,0:00:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa kamu ini?
Dialogue: 0,0:00:58.45,0:01:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya sekarang hari libur?
Dialogue: 0,0:01:01.08,0:01:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga!
Dialogue: 0,0:01:09.35,0:01:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah ruang makan keluarga,\Nsatu dari perilaku hidup manusia.
Dialogue: 0,0:01:15.35,0:01:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya adalah pojok dari\N"Persahabatan Lawan Jenis".
Dialogue: 0,0:01:21.70,0:01:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di keluarga Gero juga diajari hal lain\Ndi samping teknik membunuh.
Dialogue: 0,0:01:26.27,0:01:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Realitas dari manusia yang akan kami bunuh.
Dialogue: 0,0:01:30.66,0:01:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibuat menjalani keseharian normal\Ntanpa tahu situasi sebenarnya.
Dialogue: 0,0:01:35.91,0:01:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kebun Binatang Manusia.\N-Kebun Binatang Manusia.
Dialogue: 0,0:01:38.24,0:01:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa tahu apa-apa.
Dialogue: 0,0:01:39.87,0:01:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka makhluk lemah yang hanya\Ndipermainkan oleh takdir.
Dialogue: 0,0:01:44.29,0:01:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi penerus Pengguna Racun adalah
Dialogue: 0,0:01:47.59,0:01:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengendalikan nasib manusia.
Dialogue: 0,0:03:22.89,0:03:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap hari jam 6 sore seluruh keluarga\Nberkumpul untuk makan bersama.
Dialogue: 0,0:03:27.51,0:03:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang sudah kamu sebut\Ntidak berguna dan kamu buang.
Dialogue: 0,0:03:31.33,0:03:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin kudapatkan walau nyawa taruhannya!
Dialogue: 0,0:03:36.05,0:03:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tekad Anda masih kurang?
Dialogue: 0,0:03:38.61,0:03:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika penerusnya punya sikap seperti itu.
Dialogue: 0,0:03:41.33,0:03:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan keluarga Gero yang ternama sekalipun
Dialogue: 0,0:03:44.16,0:03:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa dilahap oleh perusahaan perintis!
Dialogue: 0,0:03:47.92,0:03:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peningkatan Mutasi Keturunan, Hell Lashes!
Dialogue: 0,0:03:58.09,0:04:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulit saya bisa menyimulasikan\Ngerak cairan dengan akurat.
Dialogue: 0,0:04:03.01,0:04:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini!
Dialogue: 0,0:04:08.81,0:04:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki!
Dialogue: 0,0:04:10.27,0:04:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa serangan saya mengenai\Norang yang tidak terlibat?
Dialogue: 0,0:04:13.65,0:04:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu akan saya ganti rugi,\Nasal ada asuransi yang bisa diambil sekarang.
Dialogue: 0,0:04:18.99,0:04:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu tidak apa-apa?
Dialogue: 0,0:04:21.70,0:04:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian sampai sejauh ini?
Dialogue: 0,0:04:24.20,0:04:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini pekerjaan.
Dialogue: 0,0:04:27.13,0:04:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada yang lebih dari itu\Nbagi Gero untukmu...
Dialogue: 0,0:04:36.98,0:04:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:04:38.13,0:04:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larilah lebih dulu.
Dialogue: 0,0:04:41.76,0:04:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prioritas kami adalah\Nmemulangkanmu dengan selamat.
Dialogue: 0,0:04:46.06,0:04:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Gero akan menyusul.
Dialogue: 0,0:04:50.09,0:04:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, tidak apa-apa.
Dialogue: 0,0:04:52.90,0:04:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang bisa kubantu?
Dialogue: 0,0:05:05.20,0:05:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua jarum dan racunku hilang\Nkarena satu pukulan tadi!
Dialogue: 0,0:05:09.16,0:05:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:05:11.49,0:05:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecepatanku tidak cukup untuk mendekati\Nserangannya yang sinting itu!
Dialogue: 0,0:05:15.29,0:05:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hikaru.
Dialogue: 0,0:05:16.99,0:05:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat melawan Pengguna lain adalah\Nbayaran sebesar 5 miliar atau lebih.
Dialogue: 0,0:05:21.88,0:05:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu hanya berlaku jika Anda\Nsudah pasti akan menang.
Dialogue: 0,0:05:25.81,0:05:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang Pengguna tidak boleh
Dialogue: 0,0:05:27.08,0:05:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengambil risiko membocorkan\NPeningkatan Mutasi Keturunan miliknya.
Dialogue: 0,0:05:32.31,0:05:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau misalkan sampai ada yang tahu,\Nharus dipastikan untuk dibunuh.
Dialogue: 0,0:05:38.33,0:05:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua demi melestarikan\Ndan mengembangkan sejarah Pengguna Racun.
Dialogue: 0,0:05:43.36,0:05:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:05:51.71,0:05:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kuberikan padamu!
Dialogue: 0,0:05:53.33,0:05:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padaku?
Dialogue: 0,0:05:54.17,0:05:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kenapa?
Dialogue: 0,0:05:56.71,0:06:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melemparkan sesuatu,\Nbakal ditepis sama si Pengguna Air itu, kan?
Dialogue: 0,0:06:01.22,0:06:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua biar pasti sampai padamu.
Dialogue: 0,0:06:04.09,0:06:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!
Dialogue: 0,0:06:05.72,0:06:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang ke sini untuk menolongmu,\Nkenapa tidak lari—
Dialogue: 0,0:06:09.42,0:06:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namamu Gero, kan?
Dialogue: 0,0:06:11.02,0:06:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata semangatmu panas juga.
Dialogue: 0,0:06:12.60,0:06:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mungkin ingin menjadi pangeran.
Dialogue: 0,0:06:16.06,0:06:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, bukan gayaku jadi tuan putri\Nyang nurut-nurut saja menunggu diselamatkan.
Dialogue: 0,0:06:21.82,0:06:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, aku juga ingin membantumu.
Dialogue: 0,0:06:34.18,0:06:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konyol!
Dialogue: 0,0:06:35.96,0:06:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah datang sendiri untuk ditangkap.
Dialogue: 0,0:06:38.48,0:06:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Tuan Gero\Nsudah melindungimu mati-matian!
Dialogue: 0,0:06:41.01,0:06:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pantas dapat penghargaan\N"Tidak Layak Diselamatkan Tahun Ini"!
Dialogue: 0,0:06:45.41,0:06:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaan Anda saat ini?
Dialogue: 0,0:06:47.51,0:06:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mempertaruhkan nyawa\Nmalah akan mati bodoh begini.
Dialogue: 0,0:06:51.91,0:06:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki.
Dialogue: 0,0:06:52.89,0:06:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:54.31,0:06:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mempertemukan kami.
Dialogue: 0,0:06:58.05,0:07:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung saja bukan orang lain.
Dialogue: 0,0:07:00.27,0:07:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur kalau Himekawa\Nadalah pasangan pertamaku.
Dialogue: 0,0:07:05.74,0:07:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang alat suntik itu sekarang juga!
Dialogue: 0,0:07:18.92,0:07:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kosong?
Dialogue: 0,0:07:24.87,0:07:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:07:26.53,0:07:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terlihat—
Dialogue: 0,0:07:27.68,0:07:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari belakang?
Dialogue: 0,0:07:28.71,0:07:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:07:29.74,0:07:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya tidak bisa kukendalikan!\NSetelanku—
Dialogue: 0,0:07:46.95,0:07:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlianmu hebat juga.
Dialogue: 0,0:07:50.09,0:07:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupanggil kalau misalkan\Ndapurku pampat.
Dialogue: 0,0:07:55.62,0:07:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, aku ini sedang...
Dialogue: 0,0:07:57.79,0:08:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyentuh bagian yang sensitif, ya?
Dialogue: 0,0:08:00.54,0:08:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukannya ada niat tersembunyi.
Dialogue: 0,0:08:02.92,0:08:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di luar kendali,
Dialogue: 0,0:08:04.73,0:08:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lagi pula pakai punggung tangan,\Nbukannya sengaja...
Dialogue: 0,0:08:07.46,0:08:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki, aku harus bagaimana?
Dialogue: 0,0:08:32.11,0:08:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini, kulitmu itu punya\Nalergi udara bersih, kan?
Dialogue: 0,0:08:36.36,0:08:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasukkan air ke setelanmu agar kulit\Ntidak bersentuhan langsung dengan udara.
Dialogue: 0,0:08:41.30,0:08:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu karena tercantum\Ndi Perpustakaan Pengguna Racun.
Dialogue: 0,0:08:45.21,0:08:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuresepkan obat\Nuntuk meredam gejala kambuhnya.
Dialogue: 0,0:08:48.01,0:08:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara ini oleskan saja itu.
Dialogue: 0,0:08:49.55,0:08:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, apa itu?
Dialogue: 0,0:08:52.22,0:08:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini bentuk iba?
Dialogue: 0,0:08:53.39,0:08:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin begitu.
Dialogue: 0,0:08:54.93,0:08:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengalahkanmu sepenuhnya.
Dialogue: 0,0:08:57.10,0:08:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalah di adu fisik,\Npenyakitmu juga disembuhkan.
Dialogue: 0,0:08:59.62,0:09:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah masuk kategori\Ntidak bisa menang dariku seumur hidup.
Dialogue: 0,0:09:03.36,0:09:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melawan lagi di lain waktu\Nsudah tidak menguntungkan, bukan?
Dialogue: 0,0:09:14.28,0:09:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Aku minta maaf!
Dialogue: 0,0:09:17.75,0:09:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji tidak akan pernah\Nmengulangi ini lagi...
Dialogue: 0,0:09:20.79,0:09:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya.
Dialogue: 0,0:09:22.63,0:09:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pameran resmimu itu sudah bagus,
Dialogue: 0,0:09:24.54,0:09:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mending diusahakan dengan benar, dong.
Dialogue: 0,0:09:26.84,0:09:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuawasi pokoknya.
Dialogue: 0,0:09:29.34,0:09:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naif!
Dialogue: 0,0:09:30.63,0:09:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terlalu naif!
Dialogue: 0,0:09:32.22,0:09:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menerima penyesalannya\Ndan semua selesai begitu saja?
Dialogue: 0,0:09:34.97,0:09:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna harus memastikan\Ntargetnya terbunuh dan—
Dialogue: 0,0:09:37.81,0:09:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita berhadapan lagi,\Nakan kuberi Racun Seribu Siksaan.
Dialogue: 0,0:09:42.73,0:09:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bagimu terlihat pengecut.
Dialogue: 0,0:09:44.98,0:09:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi diminta sekalipun tidak akan kubunuh.
Dialogue: 0,0:09:47.77,0:09:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himekawa tidak keberatan dengan itu?
Dialogue: 0,0:09:50.06,0:09:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:51.15,0:09:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan lengah\Nsampai tertangkap lagi.
Dialogue: 0,0:09:54.71,0:09:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, biar kuantar!
Dialogue: 0,0:09:59.54,0:10:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ini apa?"
Dialogue: 0,0:10:00.79,0:10:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini teman hiuku, Sameshige!
Dialogue: 0,0:10:05.25,0:10:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Teman hiu itu apa?"
Dialogue: 0,0:10:07.25,0:10:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman hiu, ya, teman hiu!
Dialogue: 0,0:10:09.22,0:10:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan, Sameshige?
Dialogue: 0,0:10:29.10,0:10:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali, Ibu!
Dialogue: 0,0:10:35.29,0:10:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Egg tidak begitu dihargai\Nsemasa hidupnya,
Dialogue: 0,0:10:38.24,0:10:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melepaskan sebagian besar karyanya.
Dialogue: 0,0:10:42.29,0:10:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa kamu mojok begitu?\N- Selain satu-satunya lukisan
Dialogue: 0,0:10:44.12,0:10:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak ada salahnya, kan?\N- yang menggambarkan putrinya!
Dialogue: 0,0:10:46.00,0:10:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istriku meninggal dalam laka lantas\Ntak lama setelah melahirkan Ageha.
Dialogue: 0,0:10:51.01,0:10:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini dijual,
Dialogue: 0,0:10:52.38,0:10:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami bisa tinggal di rumah bagus\Ndan tidak pusing soal hidup sehari-hari.
Dialogue: 0,0:10:56.25,0:10:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami ingin hidup bersama\Nsebagai sebuah keluarga.
Dialogue: 0,0:10:59.18,0:11:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero, ayo sini!
Dialogue: 0,0:11:01.31,0:11:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ageha mau bilang terima kasih katanya.
Dialogue: 0,0:11:03.52,0:11:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku kan cuma—
Dialogue: 0,0:11:05.60,0:11:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan diambil pusing, ah.
Dialogue: 0,0:11:07.52,0:11:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja dirimu\Ndihujani terima kasih begitu.
Dialogue: 0,0:11:09.82,0:11:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu rendah hati\Njustru jadinya tidak sopan.
Dialogue: 0,0:11:14.80,0:11:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:11:16.20,0:11:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyelamatkan ibuku!
Dialogue: 0,0:11:19.45,0:11:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Gero seorang Pengguna,\Nkupikir kamu orang yang sangat jahat.
Dialogue: 0,0:11:25.46,0:11:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu berbeda!
Dialogue: 0,0:11:29.79,0:11:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, aku juga belum berterima kasih\Nkarena tidak ada kesempatan.
Dialogue: 0,0:11:36.47,0:11:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Okuto, adik laki-lakiku.
Dialogue: 0,0:11:39.67,0:11:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah dioperasi memakai uang\Nyang kamu berikan padaku
Dialogue: 0,0:11:42.56,0:11:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sedang tahap pemulihan.
Dialogue: 0,0:11:44.81,0:11:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap hari dia mengirimi swafoto dengan ceria.
Dialogue: 0,0:11:48.02,0:11:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, dia ini nakal sekali\Npadahal sudah disuruh istirahat.
Dialogue: 0,0:11:53.23,0:11:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kamu yang bertarung\Ndengan taruhan nyawa.
Dialogue: 0,0:11:56.20,0:11:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak itu juga,\NHimekawa dan teman-temannya.
Dialogue: 0,0:11:59.53,0:12:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga adikku akhirnya bisa tersenyum semua.
Dialogue: 0,0:12:03.26,0:12:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah melakukan hal sehebat itu.
Dialogue: 0,0:12:09.09,0:12:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, mau ke mana?
Dialogue: 0,0:12:10.75,0:12:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bersih-bersih toilet dulu.
Dialogue: 0,0:12:13.00,0:12:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:13.96,0:12:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tunggu sebentar, kami ingin\Nmembahas soal uang imbalannya.
Dialogue: 0,0:12:17.38,0:12:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya pekerjaan Gero kali ini\Ntidak akan cukup dibayar
Dialogue: 0,0:12:21.14,0:12:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}walau punya organ dalam sebanyak apa pun.
Dialogue: 0,0:12:23.64,0:12:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku tidak punya uang.
Dialogue: 0,0:12:26.06,0:12:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan melakukan apa saja.\NKalau selain itu,
Dialogue: 0,0:12:36.61,0:12:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinosaki telat.
Dialogue: 0,0:12:38.57,0:12:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sibuk pilih baju lagi, ya?
Dialogue: 0,0:12:40.70,0:12:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, dia yang...
Dialogue: 0,0:12:42.82,0:12:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Himekawa!
Dialogue: 0,0:12:44.28,0:12:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kembali ke sini,\Nayo kita rayakan pesta bertiga!
Dialogue: 0,0:13:06.34,0:13:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:09.94,0:13:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua saja, nih?
Dialogue: 0,0:13:25.74,0:13:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiu, hiu...
Dialogue: 0,0:13:27.41,0:13:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo Hiu!\N- Te-Ternyata tempat kayak begini?
Dialogue: 0,0:13:30.75,0:13:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shark!
Dialogue: 0,0:13:34.33,0:13:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sha-Sha—
Dialogue: 0,0:13:35.54,0:13:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uwah!
Dialogue: 0,0:13:37.92,0:13:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Same's Stomach!
Dialogue: 0,0:13:45.30,0:13:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi kencan dimulai!
Dialogue: 0,0:13:48.43,0:13:50.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lewat Operasi Pangeran, Gero akan
Dialogue: 0,0:13:50.73,0:13:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- menyelamatkan Himekawa yang diculik.\N- Saus tomat.
Dialogue: 0,0:13:52.64,0:13:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu digiring untuk kencan berdua\Ndengan tingkat perhatian maksimal.
Dialogue: 0,0:13:57.38,0:13:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal ungkapkan perasaan saja!
Dialogue: 0,0:14:01.99,0:14:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung ketahuan.
Dialogue: 0,0:14:03.53,0:14:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengguna memang hebat.
Dialogue: 0,0:14:05.20,0:14:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah bersembunyi.
Dialogue: 0,0:14:09.75,0:14:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi coba ingat lagi, Gero,\NTeknik Kencan Kinosaki Nomor 1-3.
Dialogue: 0,0:14:15.25,0:14:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kalau obrolan buntu karena tidak ada topik,\Npujilah sesuatu yang dia kenakan."
Dialogue: 0,0:14:20.26,0:14:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cara untuk menunjukkan\Nkamu tertarik padanya.
Dialogue: 0,0:14:23.51,0:14:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero, ada segunung yang bisa\Ndipuji dari Himekawa, lo!
Dialogue: 0,0:14:26.97,0:14:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anting-anting yang indah, kalung yang cantik,
Dialogue: 0,0:14:29.72,0:14:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuku yang imut, atau jaket yang modis!
Dialogue: 0,0:14:33.97,0:14:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalungmu itu...
Dialogue: 0,0:14:36.02,0:14:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaskan!
Dialogue: 0,0:14:36.90,0:14:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat cukup berumur.
Dialogue: 0,0:14:39.36,0:14:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peninggalan, ya?
Dialogue: 0,0:14:41.97,0:14:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:42.69,0:14:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himekawa kebingungan, tuh.
Dialogue: 0,0:14:44.45,0:14:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ini?
Dialogue: 0,0:14:46.28,0:14:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bonus dari pengering udara\Nyang kubeli di pasar loak.
Dialogue: 0,0:14:48.58,0:14:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balasan yang di luar dugaan!
Dialogue: 0,0:14:51.50,0:14:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, lanjutkan obrolannya!
Dialogue: 0,0:14:52.91,0:14:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengering udara dari pasar loak?
Dialogue: 0,0:14:54.50,0:14:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bonus dari beli itu?
Dialogue: 0,0:14:55.71,0:14:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang bisa dipertanyakan, bukan?
Dialogue: 0,0:14:57.89,0:15:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu potong poni?
Dialogue: 0,0:15:00.90,0:15:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak.
Dialogue: 0,0:15:02.46,0:15:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyerah!
Dialogue: 0,0:15:04.68,0:15:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat sini!\NLihat Himekawa sana!
Dialogue: 0,0:15:06.39,0:15:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero.
Dialogue: 0,0:15:07.85,0:15:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, kesan positif yang sudah\Nsusah-susah didapat...
Dialogue: 0,0:15:11.43,0:15:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak kamu makan, boleh kuminta?
Dialogue: 0,0:15:13.35,0:15:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:15:14.60,0:15:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih!
Dialogue: 0,0:15:15.85,0:15:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman!
Dialogue: 0,0:15:17.06,0:15:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah Himekawa orangnya santai.
Dialogue: 0,0:15:18.98,0:15:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka ini.
Dialogue: 0,0:15:20.11,0:15:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Suka?
Dialogue: 0,0:15:21.69,0:15:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak, bablas!
Dialogue: 0,0:15:23.86,0:15:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, sih, percuma.
Dialogue: 0,0:15:25.45,0:15:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:15:26.61,0:15:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah begini, biar aku...
Dialogue: 0,0:15:28.49,0:15:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membantumu!
Dialogue: 0,0:15:29.70,0:15:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Hiu Greenland!
Dialogue: 0,0:15:31.16,0:15:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu banyak tahu!
Dialogue: 0,0:15:33.29,0:15:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, oh, ini Hiu Bantuan Penolong\Nyang menghilang
Dialogue: 0,0:15:37.42,0:15:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kurang disukai pengguna!
Dialogue: 0,0:15:39.25,0:15:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}BAHAS CERITA MASA KECIL, ORCAY♪\NWah, banyak tahu sekali!
Dialogue: 0,0:15:40.54,0:15:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhiran kalimatnya pakai "Orcay" segala.
Dialogue: 0,0:15:42.63,0:15:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf...
Dialogue: 0,0:15:44.67,0:15:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelanggan tidak boleh pegang monitor semba—
Dialogue: 0,0:15:48.05,0:15:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar saja, kumohon.
Dialogue: 0,0:15:53.49,0:15:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}BAHAS CERITA MASA KECIL, ORCAY♪\NSedikit sekali makanmu dari tadi.
Dialogue: 0,0:15:55.68,0:15:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:56.64,0:15:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, anu...
Dialogue: 0,0:15:59.18,0:16:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanku tidak bisa memakan\Nmasakan buatan orang lain
Dialogue: 0,0:16:03.42,0:16:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena itu sudah tertanam dalam diriku.
Dialogue: 0,0:16:06.32,0:16:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak belum bisa mengingat apa-apa,
Dialogue: 0,0:16:08.28,0:16:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setiap hari aku sudah mengasah\Nteknik Pengguna Racun.
Dialogue: 0,0:16:12.71,0:16:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terpenting bagiku saat makan\Nadalah tidak ada racun di dalamnya
Dialogue: 0,0:16:17.05,0:16:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kulakukan seorang diri di antara latihan.
Dialogue: 0,0:16:20.97,0:16:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelanggan? Manajer?
Dialogue: 0,0:16:23.21,0:16:24.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka.
Dialogue: 0,0:16:24.77,0:16:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin mengerti.
Dialogue: 0,0:16:28.26,0:16:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kecil aku juga selalu sendiri.
Dialogue: 0,0:16:32.10,0:16:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}DENGARKAN CERITA LAWAN BICARAMU, ORCAY♪
Dialogue: 0,0:16:35.22,0:16:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal, aku tidak punya keluarga,\Ndi panti pun juga dikucilkan.
Dialogue: 0,0:16:41.98,0:16:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari.
Dialogue: 0,0:16:43.32,0:16:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diadopsi oleh pria tua kaya sebatang kara\Nyang hidupnya tidak panjang lagi.
Dialogue: 0,0:16:47.87,0:16:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak jadi masalah.\NMungkin baginya siapa saja
Dialogue: 0,0:16:51.49,0:16:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa dia hanya takut pada kenyataan\Nbahwa menjelang kematiannya
Dialogue: 0,0:16:55.16,0:16:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia belum meninggalkan jejak apa pun.
Dialogue: 0,0:16:57.70,0:17:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lalu mewarisi nama Himekawa\Nbeserta kekayaan yang melimpah.
Dialogue: 0,0:17:03.35,0:17:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kuturuti saja jalannya,\Npasti bisa hidup enak selamanya.
Dialogue: 0,0:17:07.47,0:17:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:11.31,0:17:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada begitu banyak karya seni\Nyang menangis dikurung di sana.
Dialogue: 0,0:17:18.73,0:17:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kuselidiki, karya-karya itu terpisah\Nkarena didapat dari jalur ilegal.
Dialogue: 0,0:17:24.44,0:17:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu betul sulitnya hidup sendirian.
Dialogue: 0,0:17:28.71,0:17:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, kuputuskan\Nuntuk mengembalikan mereka semua.
Dialogue: 0,0:17:32.73,0:17:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ruang koleksi jadi kosong,
Dialogue: 0,0:17:35.24,0:17:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harta warisan Himekawa sudah habis\Nkarena berbagai biaya yang ada.
Dialogue: 0,0:17:39.96,0:17:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku kerja sambilan lima kali seminggu\Ndan meneruskan kegiatanku.
Dialogue: 0,0:17:44.92,0:17:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kamu bingung\Napa yang sebenarnya kulakukan, ya?
Dialogue: 0,0:17:48.78,0:17:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:17:52.47,0:17:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lama ini, untuk pertama kalinya
Dialogue: 0,0:17:55.41,0:17:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dapat ucapan terima kasih\Ndari seseorang atas apa yang kuperbuat.
Dialogue: 0,0:17:59.57,0:18:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga berkat bantuan kalian.
Dialogue: 0,0:18:02.48,0:18:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamu selalu melakukan itu...
Dialogue: 0,0:18:05.86,0:18:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sehebat itu—
Dialogue: 0,0:18:21.96,0:18:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa aku ada salah?
Dialogue: 0,0:18:25.31,0:18:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan begitu.
Dialogue: 0,0:18:28.22,0:18:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah dipuji begitu soalnya.
Dialogue: 0,0:18:30.76,0:18:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi malu, deh.
Dialogue: 0,0:18:45.87,0:18:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glek...
Dialogue: 0,0:18:49.36,0:18:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiu! Hiu!
Dialogue: 0,0:18:52.90,0:18:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shark!
Dialogue: 0,0:19:02.16,0:19:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A... Yo...
Dialogue: 0,0:19:04.65,0:19:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himekawa, aku punya permintaan.
Dialogue: 0,0:19:09.96,0:19:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon...
Dialogue: 0,0:19:12.31,0:19:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadilah temanku!
Dialogue: 0,0:19:22.18,0:19:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gero! Barusan itu harusnya\Nbisa berhasil, tahu!
Dialogue: 0,0:19:29.23,0:19:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget, tahu.
Dialogue: 0,0:19:31.07,0:19:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman? Oke.
Dialogue: 0,0:19:32.94,0:19:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kamu mau menembakku.
Dialogue: 0,0:19:34.61,0:19:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, memang ingin begitu.
Dialogue: 0,0:19:36.24,0:19:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:37.74,0:19:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak tahu apa-apa tentangmu.
Dialogue: 0,0:19:42.16,0:19:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih lagi.
Dialogue: 0,0:19:44.01,0:19:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga tidak tahu apa-apa tentang diriku.
Dialogue: 0,0:19:48.09,0:19:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejadian tempo hari mungkin\Nsedikit banyak memberi kesan yang baik.
Dialogue: 0,0:19:52.10,0:19:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu hanya permukaan yang baik\Ndari diriku saja.
Dialogue: 0,0:19:55.49,0:20:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ada juga bagian kotor\Nyang mungkin membuatmu ingin berpaling.
Dialogue: 0,0:20:01.93,0:20:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang aku ingin\Nmerasakan banyak hal bersama
Dialogue: 0,0:20:04.93,0:20:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan saling mengenal semuanya\Nmeski perlahan-lahan!
Dialogue: 0,0:20:08.10,0:20:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:20:09.36,0:20:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau setelahnya kamu juga merasa mau,\Naku ingin mengajukan langkah itu.
Dialogue: 0,0:20:15.40,0:20:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah...
Dialogue: 0,0:20:17.02,0:20:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langkah pertama menuju\Npernikahan bahagia yang kudambakan!
Dialogue: 0,0:20:26.53,0:20:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:20:28.24,0:20:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, kamu ingin mulai\Ndari jadi teman dulu?
Dialogue: 0,0:20:32.09,0:20:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya, niat tersembunyimu\Nterbuka lebar sekali.
Dialogue: 0,0:20:35.72,0:20:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan...
Dialogue: 0,0:20:36.76,0:20:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja!
Dialogue: 0,0:20:37.88,0:20:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mencuri hatiku itu tidak mudah, lo!
Dialogue: 0,0:20:44.14,0:20:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru kukira kamu pacaran sama Kinosaki.
Dialogue: 0,0:20:47.77,0:20:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia penasihat cari jodohku.
Dialogue: 0,0:20:49.94,0:20:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oalah, jadi begitu!
Dialogue: 0,0:21:01.93,0:21:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himekawa!
Dialogue: 0,0:21:04.89,0:21:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bisa makan\Nmasakan orang lain.
Dialogue: 0,0:21:07.12,0:21:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bertemu lagi nanti,\Nkamu saja yang bikinkan bekal.
Dialogue: 0,0:21:10.04,0:21:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke.
Dialogue: 0,0:21:12.04,0:21:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menu kesukaanku dashimaki.
Dialogue: 0,0:21:25.97,0:21:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gero!
Dialogue: 0,0:21:28.31,0:21:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, tugas jadi pengawal, ya!
Dialogue: 0,0:21:30.87,0:21:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri tunggal dari orang top perusahaan besar.
Dialogue: 0,0:21:33.19,0:21:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, bukannya itu selingkuh?
Dialogue: 0,0:21:35.40,0:21:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bejat banget, dong!
Dialogue: 0,0:21:36.90,0:21:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kok.
Dialogue: 0,0:21:37.98,0:21:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kalian baru jadi teman.
Dialogue: 0,0:21:40.48,0:21:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, kamu cuma kenal\Nsama Himekawa, kan?
Dialogue: 0,0:21:46.46,0:21:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, di dunia ini ada pasangan tak terduga\Nyang jumlahnya sebanyak bintang di langit!
Dialogue: 0,0:21:52.91,0:21:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi baik bisa terlihat jelas\Nkalau berinteraksi dengan banyak orang
Dialogue: 0,0:21:56.42,0:21:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan juga bisa jadi lebih cinta.
Dialogue: 0,0:22:00.78,0:22:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin jodohmu memang Himekawa.
Dialogue: 0,0:22:03.43,0:22:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin juga orang yang akan\Nkamu temui nantinya.
Dialogue: 0,0:22:08.70,0:22:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu dan pasanganmu itu\Ndapat pernikahan yang terbaik.
Dialogue: 0,0:23:46.45,0:23:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku ingin melatih diriku.\N- Jadi ini...
Dialogue: 0,0:23:47.95,0:23:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cowok yang bisa masak itu 3x lebih tenar.\N- penyambutan maba yang legendaris itu?
Dialogue: 0,0:23:48.95,0:23:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cowok yang bisa masak itu 3x lebih tenar.\N- Melodi Hutan ini.
Dialogue: 0,0:23:49.62,0:23:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- PumPop.\N- Oshima Daigo dari Fakultas Ekonomi.
Dialogue: 0,0:23:51.74,0:23:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terima kasih sekali pada takdir.\N- Oshima Daigo dari Fakultas Ekonomi.
Dialogue: 0,0:23:53.20,0:23:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Pengguna Suara.
