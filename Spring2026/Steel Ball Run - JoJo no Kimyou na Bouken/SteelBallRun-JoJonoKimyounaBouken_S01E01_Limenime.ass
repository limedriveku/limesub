Dialogue: 0,0:02:06.91,0:02:11.42,tanda,,0000,0000,0000,,{\an8}STEEL BALL RUN
Dialogue: 0,0:02:59.84,0:03:01.97,tanda,,0000,0000,0000,,PENDAFTARAN PACUAN
Dialogue: 0,0:05:28.16,0:05:29.66,tanda,,0000,0000,0000,,{\an8}TANDA TANGAN\NGYRO ZEPPELI
Dialogue: 0,0:05:36.96,0:05:38.58,tanda,,0000,0000,0000,,{\an8}MAJU! MAJU! ZEPPELI
Dialogue: 0,0:05:46.30,0:05:48.01,tanda,,0000,0000,0000,,{\an8}SIUUUUNG
Dialogue: 0,0:09:04.54,0:09:06.46,tanda,,0000,0000,0000,,{\an8}DUAK
Dialogue: 0,0:09:58.09,0:09:59.01,tanda,,0000,0000,0000,,{\an8}DUAK
Dialogue: 0,0:12:45.51,0:12:47.93,tanda,,0000,0000,0000,,{\an8}PACUAN STEEL BALL RUN DIMULAI BESOK LUSA
Dialogue: 0,0:15:33.64,0:15:34.68,tanda,,0000,0000,0000,,DOR
Dialogue: 0,0:17:08.27,0:17:11.65,tanda,,0000,0000,0000,,24 SEPTEMBER 1890\NSEHARI SEBELUM PACUAN
Dialogue: 0,0:17:42.85,0:17:44.64,tanda,,0000,0000,0000,,{\an8}GEDUBRAK
Dialogue: 0,0:19:30.87,0:19:33.79,tanda,,0000,0000,0000,,25 SEPTEMBER 1890\NHARI PACUAN
Dialogue: 0,0:25:36.03,0:25:37.41,tanda,,0000,0000,0000,,{\an8}DUAR
Dialogue: 0,0:29:32.06,0:29:33.93,tanda,,0000,0000,0000,,DESING
Dialogue: 0,0:34:01.12,0:34:02.49,tanda,,0000,0000,0000,,SYUUT
Dialogue: 0,0:36:25.51,0:36:27.43,tanda,,0000,0000,0000,,{\an8}KRAK
Dialogue: 0,0:38:25.46,0:38:26.46,tanda,,0000,0000,0000,,BAM
Dialogue: 0,0:39:00.21,0:39:02.25,tanda,,0000,0000,0000,,{\an8}TERHUYUNG
Dialogue: 0,0:39:04.13,0:39:05.05,tanda,,0000,0000,0000,,DUAK
Dialogue: 0,0:39:59.02,0:40:00.27,tanda,,0000,0000,0000,,BRUK
Dialogue: 0,0:43:16.88,0:43:17.80,tanda,,0000,0000,0000,,WUS
Dialogue: 0,0:45:33.77,0:45:35.89,tanda,,0000,0000,0000,,BERSAMBUNG
Dialogue: 0,0:00:37.95,0:00:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pada abad ke-19,\NAmerika terus memperluas wilayahnya.{\i0}
Dialogue: 0,0:00:43.25,0:00:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan{\i0} Frontier {\i1}adalah\Npenaklukan wilayah Barat.{\i0}
Dialogue: 0,0:00:52.01,0:00:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Menuju Barat…{\i0}
Dialogue: 0,0:00:57.09,0:00:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hasrat bernama Amerika itu\Nmelintasi benua…{\i0}
Dialogue: 0,0:01:02.93,0:01:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}merenggut tanah penduduk asli,{\i0}
Dialogue: 0,0:01:06.23,0:01:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}hingga mencapai Samudra Pasifik.{\i0}
Dialogue: 0,0:01:18.20,0:01:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukum dia! Dia harus dihukum!
Dialogue: 0,0:01:20.24,0:01:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyembunyikan\Nbuku orang kulit putih di tendanya!
Dialogue: 0,0:01:32.46,0:01:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaya lari macam apa itu?
Dialogue: 0,0:01:35.01,0:01:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu gaya lari orang kulit putih!
Dialogue: 0,0:01:39.43,0:01:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghilang?!
Dialogue: 0,0:01:45.10,0:01:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu, di musim panas tahun 1890,\Norang-orang mulai berkumpul di belantara,{\i0}
Dialogue: 0,0:01:51.61,0:01:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tempat angin sakal Santa Ana berembus\Ndari Meksiko, untuk mencari sesuatu.{\i0}
Dialogue: 0,0:02:14.96,0:02:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Tinjanya meluber, tuh!
Dialogue: 0,0:02:17.63,0:02:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini tendaku!\N- Diam. Aku di sini lebih dahulu!
Dialogue: 0,0:02:21.26,0:02:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di pacuan Steel Ball Run!
Dialogue: 0,0:02:28.06,0:02:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacuan ini dimulai dari San Diego\Ndengan garis finis di New York.
Dialogue: 0,0:02:33.15,0:02:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pacuan kuda pertama\Nyang melintasi benua Amerika Utara!
Dialogue: 0,0:02:41.95,0:02:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarak totalnya sekitar 6.500 kilometer.
Dialogue: 0,0:02:44.74,0:02:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rute dibagi menjadi sembilan tahap
Dialogue: 0,0:02:47.87,0:02:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sang juara berhak\Natas hadiah 50 juta dolar.
Dialogue: 0,0:02:53.00,0:02:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya satu orang di pantai ini\Nyang akan menyabet hadiahnya.
Dialogue: 0,0:03:01.97,0:03:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tn. Steven Steel!
Dialogue: 0,0:03:03.76,0:03:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baron Roocatugo dari Jerman mengumumkan\Nakan memakai mesin bernama automobil.
Dialogue: 0,0:03:08.93,0:03:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saya izinkan.
Dialogue: 0,0:03:11.48,0:03:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat perintis\Ntermasuk identitas dari pacuan ini.
Dialogue: 0,0:03:15.61,0:03:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin apa pun itu, kami siap menerimanya.
Dialogue: 0,0:03:19.82,0:03:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biaya pendaftaran 150 dolarnya dikritik\Nsebagai taktik mencari untung.
Dialogue: 0,0:03:24.70,0:03:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak benar.
Dialogue: 0,0:03:27.33,0:03:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kami menanggung biaya medis\Nserta biaya lain peserta yang gagal finis.
Dialogue: 0,0:03:32.54,0:03:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, keselamatan di lintasan\Nmenjadi tanggung jawab pribadi.
Dialogue: 0,0:03:36.46,0:03:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menolak melanggar Amandemen Kedua,\Nhak membela diri dengan senjata.
Dialogue: 0,0:03:42.26,0:03:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak ada yang berhasil finis,\Npacuan ini gagal total.
Dialogue: 0,0:03:46.26,0:03:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bentuk tanggung jawab Anda\Nkepada investor nanti?
Dialogue: 0,0:03:50.77,0:03:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa dibunuh.
Dialogue: 0,0:03:52.81,0:03:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda.
Dialogue: 0,0:03:55.15,0:03:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf?
Dialogue: 0,0:03:57.11,0:03:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegagalan itu…
Dialogue: 0,0:03:59.28,0:04:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik!
Dialogue: 0,0:04:00.90,0:04:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegagalan sesungguhnya itu\Njika kita melupakan semangat perintis
Dialogue: 0,0:04:04.82,0:04:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan enggan menghadapi tantangan!
Dialogue: 0,0:04:10.50,0:04:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam pacuan ini,\Ntak ada yang namanya kegagalan!
Dialogue: 0,0:04:13.96,0:04:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua peserta adalah petualang!
Dialogue: 0,0:04:16.21,0:04:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacuan Steel Ball Run ini
Dialogue: 0,0:04:18.96,0:04:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menjadi pengalaman kompetisi\Nyang baru bagi dunia!
Dialogue: 0,0:04:29.18,0:04:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, bagaimana ini? Cemas aku. Huwa…
Dialogue: 0,0:04:34.52,0:04:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kalau gagal, bagaimana…
Dialogue: 0,0:04:38.69,0:04:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Steven.
Dialogue: 0,0:04:40.86,0:04:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 40 tahun kau menjadi promotor, 'kan?
Dialogue: 0,0:04:45.11,0:04:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percaya diri saja, Sayangku.
Dialogue: 0,0:04:51.08,0:04:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya. Aku akan berusaha.
Dialogue: 0,0:04:53.62,0:04:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cup, cup.
Dialogue: 0,0:05:07.09,0:05:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda ingin mendaftar pacuan?
Dialogue: 0,0:05:11.51,0:05:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan tanda tangani.
Dialogue: 0,0:05:13.56,0:05:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari perlombaan akan diminta\Nsidik hidung kuda dan sidik jari joki.
Dialogue: 0,0:05:17.52,0:05:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang berganti joki dan kuda\Nselama balapan berlangsung.
Dialogue: 0,0:05:21.57,0:05:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini tanda peserta dan nomor pelana Anda.
Dialogue: 0,0:05:31.03,0:05:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro Zeppeli.
Dialogue: 0,0:05:34.70,0:05:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyohoho!
Dialogue: 0,0:05:38.58,0:05:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membawa benda aneh.
Dialogue: 0,0:05:42.34,0:05:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa ini?
Dialogue: 0,0:05:48.84,0:05:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa…
Dialogue: 0,0:05:54.31,0:05:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa? Kakiku…{\i0}
Dialogue: 0,0:05:56.52,0:05:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan! Apa-apaan ini?
Dialogue: 0,0:05:59.48,0:06:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma sedikit penasaran\Ndengan benda aneh itu!
Dialogue: 0,0:06:03.15,0:06:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah?
Dialogue: 0,0:06:04.48,0:06:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petugas, coba hitung uang pendaftaranku.
Dialogue: 0,0:06:08.45,0:06:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau nominalnya benar,\Nbaru aku memercayaimu.
Dialogue: 0,0:06:15.08,0:06:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, uangnya kurang 20 dolar.
Dialogue: 0,0:06:17.75,0:06:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku sudah bayar, 'kan?
Dialogue: 0,0:06:20.50,0:06:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuitansinya belum keluar.\NBerarti tetap dianggap kurang.
Dialogue: 0,0:06:24.59,0:06:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti benar kau pelakunya.
Dialogue: 0,0:06:27.55,0:06:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarkan uang yang kau copet.
Dialogue: 0,0:06:30.47,0:06:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bisa ikut pacuan,\Naku tidak bisa menang, 'kan?
Dialogue: 0,0:06:38.43,0:06:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, pencopet?
Dialogue: 0,0:06:40.48,0:06:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekuriti!
Dialogue: 0,0:06:42.02,0:06:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan dulu kuitansiku.
Dialogue: 0,0:06:51.86,0:06:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada apa?\N- Katanya dia pencopet.
Dialogue: 0,0:06:56.29,0:06:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Valkyrie, maaf membuatmu menunggu.
Dialogue: 0,0:06:59.54,0:07:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jadi, yang mana tendaku…\N- Hei!
Dialogue: 0,0:07:02.29,0:07:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti kau, Sialan!\NUrusan kita belum selesai!
Dialogue: 0,0:07:06.30,0:07:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok jago\Nkarena trik murahan begitu.
Dialogue: 0,0:07:10.05,0:07:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melawan!
Dialogue: 0,0:07:11.93,0:07:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mampus kau!
Dialogue: 0,0:07:15.39,0:07:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, pistolku direbut.
Dialogue: 0,0:07:17.27,0:07:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar!
Dialogue: 0,0:07:21.85,0:07:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Gigi Emas Tengik.\NKalau aku serius, kau pasti sudah mati.
Dialogue: 0,0:07:26.65,0:07:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan tak melihatku mencuri.
Dialogue: 0,0:07:30.65,0:07:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cuma asal tebak untuk mempermalukanku!
Dialogue: 0,0:07:33.91,0:07:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kira aku akan diam saja!
Dialogue: 0,0:07:35.99,0:07:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuputuskan! Aku akan ikut pacuan\Ndan terus membuntutimu!
Dialogue: 0,0:07:40.87,0:07:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam! Kami seret kau ke Sheriff.
Dialogue: 0,0:07:43.71,0:07:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan dia.
Dialogue: 0,0:07:47.67,0:07:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku batal menuntut.
Dialogue: 0,0:07:49.42,0:07:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laporan kucabut. Lepaskan dia.
Dialogue: 0,0:07:53.51,0:07:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan juga pistol itu kepadanya.
Dialogue: 0,0:08:11.03,0:08:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil.
Dialogue: 0,0:08:12.95,0:08:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, begitu kau ambil,\Nitu tanda duel dimulai.
Dialogue: 0,0:08:21.45,0:08:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mustahil kita tangani sendiri!\N- Panggil Sheriff!
Dialogue: 0,0:08:24.08,0:08:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisa mereka saling bunuh!
Dialogue: 0,0:08:27.59,0:08:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ribut-ribut apa?
Dialogue: 0,0:08:29.17,0:08:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Minggir semua.
Dialogue: 0,0:08:32.17,0:08:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kelihatan.
Dialogue: 0,0:08:42.60,0:08:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:08:44.56,0:08:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ditanggapi serius?
Dialogue: 0,0:08:46.98,0:08:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bercanda. Bercanda!
Dialogue: 0,0:08:50.02,0:08:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pasang wajah seram begitu.
Dialogue: 0,0:08:54.65,0:08:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke? Tadi cuma lucu-lucuan.
Dialogue: 0,0:08:57.95,0:09:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah. Semangat pacuannya.
Dialogue: 0,0:09:00.45,0:09:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sedang apa di sini?
Dialogue: 0,0:09:17.59,0:09:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan orang baik.
Dialogue: 0,0:09:19.97,0:09:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan pelatuknya.
Dialogue: 0,0:09:22.68,0:09:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu pergilah ke rumah sakit\Nsebelum tengah hari.
Dialogue: 0,0:09:28.27,0:09:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keparat kau!
Dialogue: 0,0:09:39.45,0:09:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sheriff, kita harus bagaimana?
Dialogue: 0,0:09:41.37,0:09:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu dibesar-besarkan.\NIni hanya duel biasa.
Dialogue: 0,0:09:44.95,0:09:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel yang disepakati keduanya.\NTak masalah.
Dialogue: 0,0:09:49.92,0:09:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel?
Dialogue: 0,0:09:51.67,0:09:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia lakukan tadi?
Dialogue: 0,0:09:55.13,0:09:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bola baja itu berputar.{\i0}
Dialogue: 0,0:09:59.01,0:10:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Sangat cepat.{\i0}
Dialogue: 0,0:10:00.18,0:10:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Lalu menancap di lengannya\Ndan rotasinya makin intens.{\i0}
Dialogue: 0,0:10:06.10,0:10:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu! Bola baja tadi apa?
Dialogue: 0,0:10:09.48,0:10:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba tunjukkan sekali lagi!
Dialogue: 0,0:10:11.19,0:10:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan disentuh! Bolanya masih berputar!
Dialogue: 0,0:10:25.29,0:10:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang baru saja terjadi?{\i0}
Dialogue: 0,0:10:28.16,0:10:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Barusan, aku jelas bisa berdiri.{\i0}
Dialogue: 0,0:10:36.92,0:10:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:10:39.84,0:10:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:10:41.76,0:10:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghalangi saja! Minggir, dasar lelet!
Dialogue: 0,0:10:44.76,0:10:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa kau bilang?\N- Berisik!
Dialogue: 0,0:10:46.93,0:10:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:10:50.23,0:10:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu aku! Kau apakan aku tadi?
Dialogue: 0,0:10:53.06,0:10:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang tadi terjadi?
Dialogue: 0,0:10:54.73,0:10:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu apa penyebab kematian tertinggi?
Dialogue: 0,0:10:58.28,0:11:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang pertama adalah penyakit\Nyang ditularkan nyamuk,
Dialogue: 0,0:11:01.57,0:11:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selanjutnya adalah disepak kuda.
Dialogue: 0,0:11:04.95,0:11:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau ingin menukar urutannya?
Dialogue: 0,0:11:08.75,0:11:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berkhayal.
Dialogue: 0,0:11:11.58,0:11:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan saja tadi kau bisa berdiri.
Dialogue: 0,0:11:15.04,0:11:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu refleks fisik.
Dialogue: 0,0:11:17.21,0:11:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Refleks?
Dialogue: 0,0:11:19.13,0:11:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga bola baja itu penyebabnya!
Dialogue: 0,0:11:22.05,0:11:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan lagi! Akan kuberi imbalan.
Dialogue: 0,0:11:24.39,0:11:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau bicara lagi.
Dialogue: 0,0:11:34.02,0:11:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Bocah. Berani-beraninya\Nkau menyerangku tadi.
Dialogue: 0,0:11:37.78,0:11:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ha?\N- Kalau begitu…
Dialogue: 0,0:11:42.66,0:11:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupegang langsung!
Dialogue: 0,0:11:56.09,0:11:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jariku…{\i0}
Dialogue: 0,0:11:57.42,0:12:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum membuatmu kecewa,\Nbiarkan aku memuji.
Dialogue: 0,0:12:00.76,0:12:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otot-otot bagian atas tubuhmu\Ncukup terlatih juga.
Dialogue: 0,0:12:05.14,0:12:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang biar kutegaskan.
Dialogue: 0,0:12:07.64,0:12:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spin dari Steel Ball ini tak bisa\Nmemulihkan orang lumpuh sepertimu.
Dialogue: 0,0:12:13.23,0:12:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa percaya itu\Nsetelah kejadian tadi!
Dialogue: 0,0:12:15.86,0:12:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah akan membongkar\Nrahasia rotasinya!
Dialogue: 0,0:12:19.32,0:12:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau tak bisa berkuda?
Dialogue: 0,0:12:21.65,0:12:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok lusa, aku sudah tak di sini.
Dialogue: 0,0:12:24.57,0:12:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menjuarai pacuan.
Dialogue: 0,0:12:26.78,0:12:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu! Sial…
Dialogue: 0,0:12:36.00,0:12:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir! Menghalangi saja!
Dialogue: 0,0:12:38.63,0:12:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan datang ke sini, dasar sampah.
Dialogue: 0,0:12:41.55,0:12:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Cepat pulang sana.
Dialogue: 0,0:13:02.94,0:13:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa aku datang ke pantai ini?{\i0}
Dialogue: 0,0:13:07.41,0:13:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Sekadar ingin melihat awal pacuan?{\i0}
Dialogue: 0,0:13:11.70,0:13:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Atau ada hal lain?{\i0}
Dialogue: 0,0:13:16.96,0:13:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namaku Johnny Joestar.{\i0}
Dialogue: 0,0:13:19.88,0:13:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayahku seorang peternak kuda\Nsekaligus pelatih kuda tersohor.{\i0}
Dialogue: 0,0:13:24.09,0:13:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sejak aku lahir,\Nhidupku tak pernah lepas dari kuda.{\i0}
Dialogue: 0,0:13:29.51,0:13:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gerak otot kuda\Nyang terlihat dari atas pelana{\i0}
Dialogue: 0,0:13:32.22,0:13:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan bunyi kuku kuda menghantam tanah\Nterasa indah bagiku.{\i0}
Dialogue: 0,0:13:36.44,0:13:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat kuda berlari, aku seolah bisa\Nmemahami pikiran dan perasaannya.{\i0}
Dialogue: 0,0:13:44.40,0:13:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Manusia mencintai keindahan.{\i0}
Dialogue: 0,0:13:47.28,0:13:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan keindahan yang bergerak\Nialah hal terindah yang pernah ada.{\i0}
Dialogue: 0,0:13:53.16,0:13:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Tuan Muda Johnny punya bakat,"{\i0}
Dialogue: 0,0:13:55.83,0:13:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ujar seorang pakatik tua\Nyang memantik semangatku.{\i0}
Dialogue: 0,0:13:58.67,0:14:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayah tak pernah peduli kepadaku.{\i0}
Dialogue: 0,0:14:02.04,0:14:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena kakakku, Nicholas,\Nsudah mencuri perhatian.{\i0}
Dialogue: 0,0:14:07.05,0:14:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, suatu hari,\NKakak meninggal karena kecelakaan.{\i0}
Dialogue: 0,0:14:11.39,0:14:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Segalanya berubah.{\i0}
Dialogue: 0,0:14:15.14,0:14:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sepeninggal kakakku, aku serius menekuni\Nbalap kuda dan terus meraih kemenangan.{\i0}
Dialogue: 0,0:14:20.15,0:14:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku pun dijuluki joki genius.{\i0}
Dialogue: 0,0:14:23.77,0:14:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setiap kali aku menang,\Nmakin banyak yang mengerumuniku,{\i0}
Dialogue: 0,0:14:27.15,0:14:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menyanjungku dari bawah kuda,\Nsambil membawa uang serta hadiah.{\i0}
Dialogue: 0,0:14:31.82,0:14:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Menang pacuan kuda{\i0}
Dialogue: 0,0:14:34.03,0:14:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah simbol kemenangan manusia\Ndan lambang kekuasaan.{\i0}
Dialogue: 0,0:14:40.58,0:14:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sayangnya, itu tak berlangsung lama.{\i0}
Dialogue: 0,0:14:43.59,0:14:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Dorothy Parker itu imut banget!
Dialogue: 0,0:14:47.97,0:14:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini penggemar beratnya, ya?
Dialogue: 0,0:14:49.88,0:14:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari nanti, akan datang\Nera aktris keren dianggap seni!
Dialogue: 0,0:14:54.64,0:14:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Permisi, aku juga mengantre.\N- Tapi memang ramai sekali, ya.
Dialogue: 0,0:14:58.43,0:14:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu?
Dialogue: 0,0:15:01.44,0:15:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah antre sejak kemarin.
Dialogue: 0,0:15:03.61,0:15:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat.
Dialogue: 0,0:15:05.36,0:15:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antrenya dari belakang sana.\NAku sudah di sini semalaman.
Dialogue: 0,0:15:10.03,0:15:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel! Baru bergadang saja sudah ribut!
Dialogue: 0,0:15:13.32,0:15:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ada masalah apa?
Dialogue: 0,0:15:15.49,0:15:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, aku sudah ikut antre,\Ntapi dia malah cari ribut.
Dialogue: 0,0:15:20.50,0:15:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Johnny Joestar, lo.
Dialogue: 0,0:15:27.76,0:15:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang yang paling keren!
Dialogue: 0,0:15:29.63,0:15:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu sampai mengantre segala?
Dialogue: 0,0:15:31.93,0:15:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya…
Dialogue: 0,0:15:35.51,0:15:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa lagi?
Dialogue: 0,0:15:36.64,0:15:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kepala batu.
Dialogue: 0,0:15:44.86,0:15:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, apa-apaan…
Dialogue: 0,0:15:52.45,0:15:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lagi-lagi, segalanya berubah.{\i0}
Dialogue: 0,0:16:00.87,0:16:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Perawat.
Dialogue: 0,0:16:02.92,0:16:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab aku! Hei!
Dialogue: 0,0:16:06.21,0:16:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek… Sialan…
Dialogue: 0,0:16:09.21,0:16:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotoranku…\NAku sampai berak… Mengompol juga…
Dialogue: 0,0:16:15.55,0:16:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, cepat bersihkan kotoranku!\NSudah tugasmu, 'kan?
Dialogue: 0,0:16:21.31,0:16:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pula tabung di kakiku ini?
Dialogue: 0,0:16:24.31,0:16:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darahku mengalir!
Dialogue: 0,0:16:28.65,0:16:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan teriak-teriak.
Dialogue: 0,0:16:32.49,0:16:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mengambil darahmu sedikit.
Dialogue: 0,0:16:35.11,0:16:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau mati rasa.\NTak masalah, 'kan?
Dialogue: 0,0:16:38.49,0:16:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar…
Dialogue: 0,0:16:42.71,0:16:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang datang menjengukmu.
Dialogue: 0,0:16:46.08,0:16:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk ayahmu sendiri.
Dialogue: 0,0:16:48.84,0:16:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang sudi melihatmu!
Dialogue: 0,0:16:51.92,0:16:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cebok sendiri saja tidak bisa.\NBegini nasib mantan joki genius?
Dialogue: 0,0:17:00.01,0:17:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan.
Dialogue: 0,0:17:02.81,0:17:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, akan kuungkap.\NAku akan berkuda lagi!
Dialogue: 0,0:17:13.28,0:17:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Valkyrie?\NAda kuda yang sekiranya bisa menandingimu?
Dialogue: 0,0:17:17.99,0:17:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dilihat sepintas…
Dialogue: 0,0:17:27.58,0:17:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum menyerah?\NSudah sejak tengah malam, lo.
Dialogue: 0,0:17:31.34,0:17:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar-dengar, dia akan ikut pacuan.
Dialogue: 0,0:17:33.71,0:17:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi meski dia mantan joki ternama,\Nrasanya kasihan, ya.
Dialogue: 0,0:17:38.76,0:17:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudanya.
Dialogue: 0,0:17:44.64,0:17:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ini berbahaya.
Dialogue: 0,0:17:47.06,0:17:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia masih terjebak kejayaan lampaunya?
Dialogue: 0,0:17:49.56,0:17:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisa dia terluka parah.
Dialogue: 0,0:17:55.19,0:17:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Serius dia tak apa?
Dialogue: 0,0:17:58.36,0:18:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya tubuh bagian bawahnya\Nsudah mati rasa.
Dialogue: 0,0:18:01.99,0:18:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi, kuda yang dibelinya\Nsudah tua, galak, beringas pula.
Dialogue: 0,0:18:08.33,0:18:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja.
Dialogue: 0,0:18:12.29,0:18:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak sanggup melihatnya! Suruh berhenti!
Dialogue: 0,0:18:14.80,0:18:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sependapat, 'kan?
Dialogue: 0,0:18:17.01,0:18:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma menonton.
Dialogue: 0,0:18:19.72,0:18:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kalau boleh jujur,\Ntak mungkin dia menungganginya.
Dialogue: 0,0:18:24.26,0:18:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil dengan kondisi itu.
Dialogue: 0,0:18:27.85,0:18:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun bisa,\Nberarti dia manusia luar biasa.
Dialogue: 0,0:18:36.57,0:18:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin ikut pacuan.
Dialogue: 0,0:18:39.40,0:18:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya. Ini ada uang masuknya.
Dialogue: 0,0:18:41.87,0:18:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai uang orang kulit putih.
Dialogue: 0,0:18:44.74,0:18:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kau sanggup bayar?
Dialogue: 0,0:18:48.08,0:18:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini…
Dialogue: 0,0:18:50.21,0:18:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zamrud?
Dialogue: 0,0:18:53.38,0:18:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanda peserta dan nomor pelana.
Dialogue: 0,0:18:55.42,0:18:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum perlombaan,\Nsidik hidung kuda akan direkam…
Dialogue: 0,0:18:58.51,0:19:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak perlu.\N- Hah?
Dialogue: 0,0:19:01.72,0:19:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melintasi benua\Ndan menang hanya dengan kaki ini.
Dialogue: 0,0:19:07.14,0:19:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kuincar adalah\Nuang orang kulit putih.
Dialogue: 0,0:19:15.98,0:19:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya besok tiba.
Dialogue: 0,0:19:45.14,0:19:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyo…
Dialogue: 0,0:19:52.39,0:19:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadirin, akhirnya dimulai juga.
Dialogue: 0,0:19:55.31,0:19:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacuan akbar lintas Amerika Utara.
Dialogue: 0,0:19:58.15,0:20:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Steel Ball Run!
Dialogue: 0,0:20:00.74,0:20:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantai luar biasa padat
Dialogue: 0,0:20:03.24,0:20:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh peserta, penonton, dan kotoran kuda.
Dialogue: 0,0:20:07.66,0:20:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, inilah para kandidat juara kita.
Dialogue: 0,0:20:13.50,0:20:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koboi dari Wyoming, Mountain Tim,
Dialogue: 0,0:20:17.54,0:20:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan kuda kesayangannya, Shadow Rider!
Dialogue: 0,0:20:21.97,0:20:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penunggang kuda ulung\Ndari Mongolia, Dott Han!
Dialogue: 0,0:20:26.35,0:20:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuda kesayangannya adalah #1!
Dialogue: 0,0:20:29.31,0:20:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengembara dari Sahara, Urmd Avdul!
Dialogue: 0,0:20:32.77,0:20:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka? Dia datang naik unta!
Dialogue: 0,0:20:36.23,0:20:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dia datang\Nbersama kuda kesayangannya, Silver Bullet,
Dialogue: 0,0:20:40.98,0:20:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan nomor pelana #001,
Dialogue: 0,0:20:43.70,0:20:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pangeran pacuan kuda Inggris,\NDiego Brando!
Dialogue: 0,0:20:51.37,0:20:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahap pertama adalah balapan 16 km\Ndengan finis di gereja Katolik.
Dialogue: 0,0:20:56.83,0:20:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenang tahap ini
Dialogue: 0,0:20:58.71,0:21:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menerima bonus waktu satu jam\Nbeserta hadiah 10.000 dolar.
Dialogue: 0,0:21:03.30,0:21:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, Steel Ball Run dimulai!
Dialogue: 0,0:21:14.39,0:21:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para tamu terhormat,\Nsetelah pacuan dimulai, silakan ke sana.
Dialogue: 0,0:21:18.65,0:21:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacuan dapat disaksikan\Ndari kereta khusus itu.
Dialogue: 0,0:21:23.78,0:21:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, lihat, orang itu datang.
Dialogue: 0,0:21:30.08,0:21:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia memang tak waras.
Dialogue: 0,0:21:39.58,0:21:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan…
Dialogue: 0,0:21:43.46,0:21:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan menyerah.
Dialogue: 0,0:21:45.63,0:21:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rotasi bolanya…
Dialogue: 0,0:21:47.34,0:21:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku akan menguak\Nrahasia Steel Ball itu…
Dialogue: 0,0:21:52.14,0:21:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihan kudamu sudah tepat.
Dialogue: 0,0:21:55.35,0:21:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuda tua sudah berpengalaman.
Dialogue: 0,0:21:57.69,0:22:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia takkan terburu-buru\Nsampai kakinya terkilir seperti kuda muda.
Dialogue: 0,0:22:02.65,0:22:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tertarik, biar kuberi petunjuk.
Dialogue: 0,0:22:06.07,0:22:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah punya jawabannya.
Dialogue: 0,0:22:08.99,0:22:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau bertekad berkuda,\Nkenapa tak memakainya saja?
Dialogue: 0,0:22:15.08,0:22:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyo-ho!
Dialogue: 0,0:22:18.25,0:22:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua menit sebelum balapan dimulai.
Dialogue: 0,0:22:26.80,0:22:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi…
Dialogue: 0,0:22:28.88,0:22:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jilat aku sekali lagi.
Dialogue: 0,0:22:36.27,0:22:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sekali lagi…{\i0}
Dialogue: 0,0:22:39.23,0:22:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berputar!{\i0}
Dialogue: 0,0:22:44.44,0:22:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Steel Ball Run akan dimulai!
Dialogue: 0,0:23:02.58,0:23:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggal 25 September 1890,\Npukul 10.00 tepat,
Dialogue: 0,0:23:06.63,0:23:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}balapan lintas daratan Amerika Utara,\NSteel Ball Run,
Dialogue: 0,0:23:10.38,0:23:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya dimulai!
Dialogue: 0,0:23:16.06,0:23:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Bagaimana bisa dia\Nmengendalikan kuda tanpa memakai kaki?
Dialogue: 0,0:23:21.98,0:23:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bersamamu, aku pasti bisa.{\i0}
Dialogue: 0,0:23:27.40,0:23:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Spin…{\i0}
Dialogue: 0,0:23:29.40,0:23:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku ingin tahu lebih banyak\Nsoal Steel Ball itu.{\i0}
Dialogue: 0,0:23:45.79,0:23:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kuda bersaing ketat sejak start.
Dialogue: 0,0:23:48.63,0:23:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja. Meski tahap pertama\Nrelatif pendek, jaraknya tetaplah 16 km.
Dialogue: 0,0:23:53.09,0:23:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika salah atur tempo,\Nbisa-bisa kuda roboh di hari pertama.
Dialogue: 0,0:23:59.02,0:24:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada yang langsung memelesat!
Dialogue: 0,0:24:01.10,0:24:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor pelana #636.
Dialogue: 0,0:24:03.56,0:24:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cepat! Sangat cepat!\NKecepatan yang menakjubkan!
Dialogue: 0,0:24:07.02,0:24:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:24:08.11,0:24:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor 636. Gyro Zeppeli.
Dialogue: 0,0:24:11.57,0:24:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa dia sudah gila?\NMasa, memacu secepat itu di hari pertama…{\i0}
Dialogue: 0,0:24:16.41,0:24:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa dia benar-benar berniat\Nmengarungi benua?{\i0}
Dialogue: 0,0:24:19.37,0:24:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, dia berniat menang.\NUntuk itulah dia kemari.{\i0}
Dialogue: 0,0:24:29.71,0:24:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mulai oleng!{\i0}
Dialogue: 0,0:24:30.84,0:24:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gawat. Kuda-kuda lain terpancing\Ndan mulai gelisah.{\i0}
Dialogue: 0,0:24:36.05,0:24:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang tumbang!\NBeberapa kuda mungkin sudah tersisih.
Dialogue: 0,0:24:43.39,0:24:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, menyeruduk tidak melanggar aturan.
Dialogue: 0,0:24:47.90,0:24:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada satu kuda lagi yang memelesat.
Dialogue: 0,0:24:50.98,0:24:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diego Brando rupanya!
Dialogue: 0,0:24:52.99,0:24:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran nomor satu pacuan Inggris ini\Nmulai menunjukkan taringnya.
Dialogue: 0,0:24:56.99,0:25:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu! Ada lagi\Nyang mau menyusul dari sisi kiri.
Dialogue: 0,0:25:02.75,0:25:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya unta Urmd Avdul!
Dialogue: 0,0:25:07.42,0:25:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Unta lebih berat 1,5 lipat dari kuda.
Dialogue: 0,0:25:10.09,0:25:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada kuda yang bisa\Nmenahan serangan ini!
Dialogue: 0,0:25:14.01,0:25:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro tersandung.
Dialogue: 0,0:25:16.89,0:25:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diego Brando memanfaatkan peluang.
Dialogue: 0,0:25:29.11,0:25:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang akan mendapatkan bonus waktu
Dialogue: 0,0:25:32.94,0:25:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah aku, Urmd Avdul!
Dialogue: 0,0:25:40.28,0:25:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:25:49.42,0:25:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Avdul jatuh!
Dialogue: 0,0:25:51.50,0:25:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia tak sadar ada semak kaktus?
Dialogue: 0,0:25:55.09,0:25:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Avdul tak berkutik!
Dialogue: 0,0:25:57.34,0:26:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urmd Avdul, kandidat unggulan,\Ntak disangka tersingkir di tahap pertama!
Dialogue: 0,0:26:10.40,0:26:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu Steel Ball Gyro.{\i0}
Dialogue: 0,0:26:16.53,0:26:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak tahu cara kerjanya,{\i0}
Dialogue: 0,0:26:19.03,0:26:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi dia memakainya\Nuntuk mencari semak kaktus{\i0}
Dialogue: 0,0:26:21.91,0:26:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan memancing si penunggang unta\Nagar terjerumus ke sana.{\i0}
Dialogue: 0,0:26:25.08,0:26:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku ingin tahu\Nsoal Steel Ball dan pria itu.{\i0}
Dialogue: 0,0:26:30.08,0:26:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal bukan penyakit,\Nkalau bisa diambil, akan kuambil.
Dialogue: 0,0:26:33.63,0:26:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi bonus waktu.
Dialogue: 0,0:26:35.96,0:26:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyo-ho!
Dialogue: 0,0:26:43.85,0:26:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lho?
Dialogue: 0,0:26:45.93,0:26:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang pukul berapa?
Dialogue: 0,0:26:51.77,0:26:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Aduh! Aku ketiduran!
Dialogue: 0,0:26:55.94,0:26:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang pendaftaran tak bisa kembali.
Dialogue: 0,0:26:57.65,0:27:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tetap ikut!\NKalau tidak, mana bisa dapat hadiahnya!
Dialogue: 0,0:27:01.16,0:27:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:27:02.45,0:27:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menang, yo!
Dialogue: 0,0:27:04.70,0:27:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini pria yang sedang berada\Ndi puncak kejayaanku!
Dialogue: 0,0:27:09.79,0:27:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang aneh yang baru bergabung.\NCatat saja untuk jaga-jaga.
Dialogue: 0,0:27:14.09,0:27:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor pelana #777.
Dialogue: 0,0:27:16.05,0:27:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Pocoloco.
Dialogue: 0,0:27:19.76,0:27:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa mulus tanahnya!
Dialogue: 0,0:27:22.72,0:27:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara diinjak kuda lain,
Dialogue: 0,0:27:24.72,0:27:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}larinya jadi seenak ini!
Dialogue: 0,0:27:28.31,0:27:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pocoloco lagi mujur! Yo, yo, yo, yo!
Dialogue: 0,0:27:33.77,0:27:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru sadar sesuatu.
Dialogue: 0,0:27:35.57,0:27:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika seliter menempuh 365 meter,\Nbukannya mustahil melintasi benua?
Dialogue: 0,0:27:39.61,0:27:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.\NMari kita pulang ke tanah air, Tuan.
Dialogue: 0,0:27:46.95,0:27:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, Gyro Zeppeli masih memimpin.
Dialogue: 0,0:27:50.08,0:27:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diego Brando, alias Dio,\Nmenempati urutan kedua.
Dialogue: 0,0:27:54.33,0:27:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang itu… Gerak-geriknya aneh sejak tadi.{\i0}
Dialogue: 0,0:27:58.00,0:28:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mengejar dari kanan,\Nlalu merapat dari kiri.{\i0}
Dialogue: 0,0:28:01.51,0:28:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jaraknya dengan Gyro makin menyempit.{\i0}
Dialogue: 0,0:28:11.89,0:28:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lagi-lagi! Jangan-jangan dia\Nbisa membaca gerakan kuda Gyro?{\i0}
Dialogue: 0,0:28:19.03,0:28:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia menghilang?{\i0}
Dialogue: 0,0:28:20.49,0:28:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang terjadi? Dio menghilang!{\i0}
Dialogue: 0,0:28:24.95,0:28:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba dia menyusul!
Dialogue: 0,0:28:29.54,0:28:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana bisa?\NTadi dia tak terlihat menambah kecepatan.{\i0}
Dialogue: 0,0:28:33.87,0:28:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Insiden unta tadi agak mengejutkanku,\Ntapi kini aku sadar kau cuma amatir.
Dialogue: 0,0:28:40.46,0:28:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerak-gerikmu terbaca.
Dialogue: 0,0:28:42.92,0:28:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ternyata benar dia tahu!\NKebiasaan kuda Gyro!{\i0}
Dialogue: 0,0:28:47.26,0:28:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setiap hal atau makhluk\Npasti punya kebiasaan.{\i0}
Dialogue: 0,0:28:52.31,0:28:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kuda pun demikian.{\i0}
Dialogue: 0,0:28:54.06,0:28:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mengibas ekor sebelum memelesat,\Nmelebar ke luar saat terdesak,{\i0}
Dialogue: 0,0:28:59.15,0:29:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menggeleng, merendahkan badan.{\i0}
Dialogue: 0,0:29:01.74,0:29:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terkadang itu bisa menjadi\Nkelemahan besar dalam pacuan.{\i0}
Dialogue: 0,0:29:05.61,0:29:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kebiasaan kuda ini sungguh fatal.{\i0}
Dialogue: 0,0:29:08.45,0:29:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lima, enam, tujuh…{\i0}
Dialogue: 0,0:29:10.29,0:29:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergeser ke kiri.
Dialogue: 0,0:29:16.12,0:29:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ya, kudanya sedikit meliuk ke kiri\Nsetiap napas kedelapan.{\i0}
Dialogue: 0,0:29:20.17,0:29:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan tentu saja,\Nkecepatannya turun saat meliuk.{\i0}
Dialogue: 0,0:29:23.13,0:29:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, jika aku menambah laju di momen itu,{\i0}
Dialogue: 0,0:29:25.84,0:29:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku bisa menandingi kecepatannya\Ntanpa membuat kuda kesayanganku kelelahan!{\i0}
Dialogue: 0,0:29:33.93,0:29:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dio berhasil memimpin tipis!
Dialogue: 0,0:29:36.14,0:29:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trik macam apa ini?
Dialogue: 0,0:29:39.36,0:29:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini teknik profesional.
Dialogue: 0,0:29:41.23,0:29:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tetaplah di belakang sana.
Dialogue: 0,0:29:44.07,0:29:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu kudaku punya kebiasaan?
Dialogue: 0,0:29:48.03,0:29:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gunanya memberitahumu?\NKebiasaan tak bisa diperbaiki.
Dialogue: 0,0:29:51.62,0:29:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama halnya dengan takdir!
Dialogue: 0,0:29:56.16,0:29:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dio makin memimpin!
Dialogue: 0,0:29:58.63,0:30:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:30:00.42,0:30:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil memimpin,\Ntapi kecepatannya tampak tak berubah!
Dialogue: 0,0:30:04.51,0:30:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya bakat alami.
Dialogue: 0,0:30:08.05,0:30:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gawat. Dia takkan bisa menyalipnya lagi.{\i0}
Dialogue: 0,0:30:11.51,0:30:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Selisih jaraknya justru makin besar.{\i0}
Dialogue: 0,0:30:13.81,0:30:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut penanda, 13 km tersisa.\NDi depan terbentang sungai kering.
Dialogue: 0,0:30:20.44,0:30:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jadi kau punya kebiasaan?\NAku baru tahu.
Dialogue: 0,0:30:25.03,0:30:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia ini banyak juga\Nrival yang benar-benar tangguh.
Dialogue: 0,0:30:29.91,0:30:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kebiasaanmu tak perlu diperbaiki.
Dialogue: 0,0:30:33.12,0:30:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larilah dan tonjolkan saja.
Dialogue: 0,0:30:42.84,0:30:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kudamu terhuyung.\NApa itu kebiasaannya?
Dialogue: 0,0:30:46.80,0:30:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus. Teruskan.
Dialogue: 0,0:30:50.59,0:30:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonjolkan kebiasaanmu dan berlarilah.
Dialogue: 0,0:30:56.60,0:30:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papan jembatan rompal dan berhamburan!
Dialogue: 0,0:30:59.19,0:31:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro Zeppeli nekat menerobos!
Dialogue: 0,0:31:04.11,0:31:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dio bimbang!
Dialogue: 0,0:31:06.32,0:31:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia…
Dialogue: 0,0:31:07.82,0:31:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Joki lain di belakang\Nmemilih lewat sungai.
Dialogue: 0,0:31:10.74,0:31:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dio masih terhenti di jembatan.
Dialogue: 0,0:31:13.07,0:31:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sama halnya dengan kakiku.{\i0}
Dialogue: 0,0:31:15.79,0:31:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rotasi Steel Ball misterius itu\Nmenguatkan kebiasaan kudanya!{\i0}
Dialogue: 0,0:31:21.21,0:31:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyo-ho!
Dialogue: 0,0:31:23.54,0:31:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, yo, yo, yo!
Dialogue: 0,0:31:25.84,0:31:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia! Sudah terlihat.\NAku berhasil menyusul barisan belakang.
Dialogue: 0,0:31:30.63,0:31:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, yo, yo!
Dialogue: 0,0:31:31.80,0:31:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan… Ini jurang!
Dialogue: 0,0:31:33.85,0:31:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ini rute pacuannya!
Dialogue: 0,0:31:35.89,0:31:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, gara-gara pria itu!
Dialogue: 0,0:31:46.27,0:31:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larinya sekencang itu,\Ntanpa sadar kita mengekorinya!
Dialogue: 0,0:31:50.49,0:31:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba lihat petanya!
Dialogue: 0,0:31:52.36,0:31:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bisa lewati jurangnya,\Nini jalan pintas!
Dialogue: 0,0:31:55.07,0:31:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan kalau kau mau kudamu celaka.
Dialogue: 0,0:31:58.04,0:32:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku balik arah saja. Persetan.
Dialogue: 0,0:32:04.75,0:32:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:32:09.84,0:32:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa, Pocoloco?
Dialogue: 0,0:32:12.84,0:32:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang menghitung awan.
Dialogue: 0,0:32:16.30,0:32:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku,
Dialogue: 0,0:32:17.85,0:32:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kau malah rebahan seharian,\Nbukannya bekerja?
Dialogue: 0,0:32:22.23,0:32:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga hari lalu,
Dialogue: 0,0:32:23.81,0:32:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku minta peramal tua membaca nasibku.
Dialogue: 0,0:32:26.44,0:32:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantas?
Dialogue: 0,0:32:27.40,0:32:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya titik terendah hidup\Ndisebut "siksa langit".
Dialogue: 0,0:32:32.53,0:32:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba dengar.
Dialogue: 0,0:32:33.61,0:32:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang aku justru kebalikannya.\NKebalikan dari yang terburuk.
Dialogue: 0,0:32:38.41,0:32:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dua bulan ke depan\Nadalah puncak kebahagiaan hidupmu.{\i0}
Dialogue: 0,0:32:43.83,0:32:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apalagi, kau satu dari lima miliar orang.{\i0}
Dialogue: 0,0:32:46.71,0:32:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tak ada yang perlu diragukan.\NTak ada musuh yang perlu ditakuti.{\i0}
Dialogue: 0,0:32:53.97,0:32:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti keberuntunganmu langsung datang.
Dialogue: 0,0:32:57.18,0:33:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan tanah memberimu pekerjaan\Nuntuk menggarap lahan baru.
Dialogue: 0,0:33:01.06,0:33:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku memutuskan untuk bersantai saja.
Dialogue: 0,0:33:05.56,0:33:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang seperti kita mana bisa hidup santai.
Dialogue: 0,0:33:09.77,0:33:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa sudah hitung awan sampai mana.
Dialogue: 0,0:33:13.28,0:33:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal susah payah aku melobi tuan tanah
Dialogue: 0,0:33:15.57,0:33:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya gajimu naik dari 100 ke 150.
Dialogue: 0,0:33:24.16,0:33:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Tua, proyek menggarap lahan baru tadi…
Dialogue: 0,0:33:27.63,0:33:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa upahnya kau bilang?
Dialogue: 0,0:33:30.88,0:33:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku satu dari lima miliar orang.\NKeyakinan itu mengantarku ke San Diego.
Dialogue: 0,0:33:36.84,0:33:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menang. Menang, kemudian…
Dialogue: 0,0:33:40.76,0:33:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang ke kampung halaman\Ndan hidup lebih bahagia!
Dialogue: 0,0:33:55.90,0:33:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan tali bawaanmu\Njika tahu cara pakainya.
Dialogue: 0,0:34:14.21,0:34:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kuat sekali kaki orang itu.{\i0}
Dialogue: 0,0:34:17.09,0:34:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi jangan kira aku akan berterima kasih.{\i0}
Dialogue: 0,0:34:19.84,0:34:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku berhasil melewati tebing itu\Nberkat keberuntunganku.{\i0}
Dialogue: 0,0:34:24.60,0:34:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hey ya!
Dialogue: 0,0:34:33.36,0:34:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahap pertama tersisa 7 km lagi.
Dialogue: 0,0:34:36.78,0:34:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro Zeppeli masih memimpin!
Dialogue: 0,0:34:38.95,0:34:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah dia pertahankan sampai akhir?
Dialogue: 0,0:34:43.87,0:34:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Gyro tiba-tiba mengubah haluan.\NApa rencananya?
Dialogue: 0,0:34:49.87,0:34:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jalan pintas.
Dialogue: 0,0:34:51.42,0:34:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika menerobos hutan,\Ndia bisa memotong sekitar 0,7 km.
Dialogue: 0,0:34:55.84,0:34:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukankah pohon-pohonnya\Nmenghalangi jalan?
Dialogue: 0,0:34:59.13,0:35:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertaruhan. Yang sangat riskan.
Dialogue: 0,0:35:02.85,0:35:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana dengan regu pengejarnya?
Dialogue: 0,0:35:05.68,0:35:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan dia memimpin lebih jauh.
Dialogue: 0,0:35:09.14,0:35:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu joki mengikuti!\NEnam joki lagi. Total tujuh joki.
Dialogue: 0,0:35:12.94,0:35:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yiha! Aku berhasil menyusul!
Dialogue: 0,0:35:16.32,0:35:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, yo, yo!
Dialogue: 0,0:35:17.94,0:35:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu di mana joki terdepan?
Dialogue: 0,0:35:20.74,0:35:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak tahu? Kita akan menerobos hutan.
Dialogue: 0,0:35:28.58,0:35:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya, tapi sudah terbukti\Njalan pintas itu jalur keberuntunganku.
Dialogue: 0,0:35:35.92,0:35:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa? Dia malah memejamkan mata.{\i0}
Dialogue: 0,0:35:47.93,0:35:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku ini pria beruntung.{\i0}
Dialogue: 0,0:35:49.39,0:35:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Meski mataku terpejam,\Ntak bakal menabrak dahan!{\i0}
Dialogue: 0,0:35:53.65,0:35:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana bisa?\NWajar kalau kuda terus berlari.{\i0}
Dialogue: 0,0:35:57.69,0:36:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Padahal matanya terpejam\Ndan gaya berkudanya begitu.{\i0}
Dialogue: 0,0:36:00.28,0:36:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa dia aman-aman saja?{\i0}
Dialogue: 0,0:36:04.24,0:36:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa-apaan dia? Kenapa malah tutup mata?{\i0}
Dialogue: 0,0:36:08.41,0:36:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada yang janggal.\NOrang seperti itu harus segera…{\i0}
Dialogue: 0,0:36:13.62,0:36:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan!
Dialogue: 0,0:36:28.93,0:36:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua menit sejak masuk hutan.\NApa sebentar lagi mereka akan keluar?
Dialogue: 0,0:36:33.81,0:36:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro muncul!
Dialogue: 0,0:36:36.11,0:36:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaan, Gyro Zeppeli\Nmasih unggul jauh di depan!
Dialogue: 0,0:36:39.73,0:36:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, ada satu kuda lagi!\NJokinya terseret!
Dialogue: 0,0:36:44.16,0:36:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor pelana #777.\NNama terdaftar Pocoloco.
Dialogue: 0,0:36:47.78,0:36:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:36:48.78,0:36:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tak terduga.
Dialogue: 0,0:36:50.12,0:36:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena diseret kuda,
Dialogue: 0,0:36:51.62,0:36:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bisa menghindari dahan\Nsehingga kudanya bebas melaju!
Dialogue: 0,0:36:56.38,0:36:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa jatuhku tadi keberuntungan?
Dialogue: 0,0:37:01.96,0:37:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga! Aku memang pria beruntung!
Dialogue: 0,0:37:05.05,0:37:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Memang boleh begitu?
Dialogue: 0,0:37:08.14,0:37:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pocoloco menempati urutan kedua.
Dialogue: 0,0:37:10.14,0:37:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peserta lain terlihat melewati rute resmi,
Dialogue: 0,0:37:12.85,0:37:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jaraknya terpaut ratusan meter!
Dialogue: 0,0:37:15.06,0:37:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Posisi ini tidak buruk.{\i0}
Dialogue: 0,0:37:17.15,0:37:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jalan pintasnya berguna.{\i0}
Dialogue: 0,0:37:19.52,0:37:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa! Tahap pertama saja\Nsudah sangat mendebarkan.
Dialogue: 0,0:37:23.11,0:37:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikutnya adalah\Nbagian tersulit dari rute ini,
Dialogue: 0,0:37:26.36,0:37:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}turunan sepanjang 1,8 km
Dialogue: 0,0:37:28.62,0:37:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan selisih elevasi 46 meter\Ndan kemiringan sampai 30 derajat.
Dialogue: 0,0:37:32.95,0:37:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunan 1,8 km?
Dialogue: 0,0:37:34.08,0:37:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sulit memasang rel,\Nkereta terpaksa menempuh jalur memutar.
Dialogue: 0,0:37:43.88,0:37:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini mereka memasuki turunan sulit.
Dialogue: 0,0:37:46.97,0:37:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentunya, jika terlalu cepat,\Nkaki kuda bisa cedera parah.
Dialogue: 0,0:37:51.47,0:37:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditahan. Laju kuda ditahan!
Dialogue: 0,0:37:53.93,0:37:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini, keahlian joki sangat menentukan!
Dialogue: 0,0:37:57.65,0:38:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlahan saja. Hati-hati.
Dialogue: 0,0:38:01.07,0:38:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa kau takut, Tuan Satu dari Lima Miliar?{\i0}
Dialogue: 0,0:38:06.78,0:38:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara siapa itu? Siapa bilang aku takut?
Dialogue: 0,0:38:09.37,0:38:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tak ada yang perlu diragukan.\NTak ada musuh yang perlu ditakuti.{\i0}
Dialogue: 0,0:38:15.45,0:38:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:38:16.83,0:38:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak ada musuh yang perlu ditakuti,
Dialogue: 0,0:38:20.04,0:38:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada pula\Njalan yang perlu ditakuti, 'kan?
Dialogue: 0,0:38:26.47,0:38:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyingkir, Pak Tua!
Dialogue: 0,0:38:28.72,0:38:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pocoloco menyusul! Dia tak melambat!
Dialogue: 0,0:38:31.76,0:38:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:38:33.35,0:38:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, yo, yo!
Dialogue: 0,0:38:34.72,0:38:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alah, cuma orang bodoh rupanya.
Dialogue: 0,0:38:39.48,0:38:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah. Jangan terpengaruh!
Dialogue: 0,0:38:42.06,0:38:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lain mengikuti!\NBeberapa kuda lain terpengaruh memacu!
Dialogue: 0,0:38:51.62,0:38:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Tabrakan hebat!
Dialogue: 0,0:38:54.37,0:38:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lereng terkutuk!
Dialogue: 0,0:38:56.58,0:38:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa. Teruslah melaju!
Dialogue: 0,0:38:58.87,0:39:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita beruntung…
Dialogue: 0,0:39:05.05,0:39:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pocoloco tersungkur! Gyro memimpin!
Dialogue: 0,0:39:08.05,0:39:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus!
Dialogue: 0,0:39:09.80,0:39:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Pocoloco sembrono!
Dialogue: 0,0:39:14.81,0:39:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?!
Dialogue: 0,0:39:17.39,0:39:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:39:18.31,0:39:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pocoloco tak terluka! Ia bahkan tak jatuh!
Dialogue: 0,0:39:21.77,0:39:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia menunggangi sesuatu.\NKecepatannya luar biasa!
Dialogue: 0,0:39:26.61,0:39:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini…
Dialogue: 0,0:39:28.07,0:39:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangkai!
Dialogue: 0,0:39:30.20,0:39:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia meluncur di atas bangkai sapi!
Dialogue: 0,0:39:32.57,0:39:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yiha! Siapa sangka\Nada bangkai di rerumputan!
Dialogue: 0,0:39:37.04,0:39:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila benar!
Dialogue: 0,0:39:38.62,0:39:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pocoloco memimpin!
Dialogue: 0,0:39:40.25,0:39:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Situasi konyol macam apa ini?{\i0}
Dialogue: 0,0:39:43.46,0:39:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan-jangan itu semacam teknik?{\i0}
Dialogue: 0,0:39:46.92,0:39:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, masa bodoh soal itu.{\i0}
Dialogue: 0,0:39:50.84,0:39:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini balapan naik kuda.{\i0}
Dialogue: 0,0:39:53.39,0:39:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan malah naik bangkai sapi!{\i0}
Dialogue: 0,0:39:56.81,0:39:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan!
Dialogue: 0,0:40:00.27,0:40:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuruntuhkan bebatuan itu\Ndan hentikan luncuran sapinya.
Dialogue: 0,0:40:08.32,0:40:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa? Kenapa tiba-tiba ada orang?{\i0}
Dialogue: 0,0:40:13.32,0:40:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, luput.
Dialogue: 0,0:40:15.16,0:40:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya!
Dialogue: 0,0:40:16.91,0:40:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor pelana #990,\NSand Man, tiba-tiba merangsek!
Dialogue: 0,0:40:20.41,0:40:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mengejutkan, dia berlari dengan kaki!
Dialogue: 0,0:40:22.62,0:40:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunannya akan segera berakhir!
Dialogue: 0,0:40:24.71,0:40:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yiha!
Dialogue: 0,0:40:26.88,0:40:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacuan sudah berjalan 17 menit!
Dialogue: 0,0:40:30.30,0:40:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sialan…{\i0}
Dialogue: 0,0:40:34.22,0:40:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tikungan terakhir sudah di depan mata.
Dialogue: 0,0:40:36.68,0:40:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah deretan tebing,\Ntinggal lintasan lurus!
Dialogue: 0,0:40:40.27,0:40:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Sand Man memotong jalur\Ndan lewat tebing!
Dialogue: 0,0:40:46.44,0:40:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini? Kenapa bisa jadi begini?
Dialogue: 0,0:40:50.15,0:40:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah dia manusia?
Dialogue: 0,0:40:52.49,0:40:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah kekuatan misterius penduduk asli.
Dialogue: 0,0:40:55.74,0:40:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang sangat cocok\Nuntuk balapan lintas daratan Amerika.
Dialogue: 0,0:40:59.66,0:41:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Regu belakang melewati turunan\Ndan menuju tikungan terakhir.
Dialogue: 0,0:41:03.83,0:41:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pocoloco di depan 3.800 joki lain!
Dialogue: 0,0:41:09.17,0:41:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Valkyrie, mustahil menang\Njika menghadap bokong mereka terus.
Dialogue: 0,0:41:15.89,0:41:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo susul.
Dialogue: 0,0:41:20.31,0:41:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia! Gyro berusaha menyalip!
Dialogue: 0,0:41:24.02,0:41:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidakkah ini terlalu dini?
Dialogue: 0,0:41:25.73,0:41:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada 1,8 km lintasan lurus\Nsetelah tikungan ini!
Dialogue: 0,0:41:42.33,0:41:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa? Ramai sekali…\N- Steel Ball Run!
Dialogue: 0,0:41:45.29,0:41:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Luar biasa! Penonton membeludak!\N- Steel Ball Run!
Dialogue: 0,0:41:48.38,0:41:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angin Santa Ana dari Meksiko
Dialogue: 0,0:41:50.59,0:41:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menerpa gereja di ujung padang tandus!
Dialogue: 0,0:41:53.71,0:41:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puluhan ribu orang berbondong-bondong\Nmenyaksikan akhir tahap pertama!
Dialogue: 0,0:41:58.93,0:42:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenang pacuan ini\Nakan menjadi pahlawan dunia.
Dialogue: 0,0:42:06.35,0:42:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah berlari sejauh ini,\Nkau masih menghemat stamina.{\i0}
Dialogue: 0,0:42:10.69,0:42:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pasti bisa. 1,8 km terakhir.{\i0}
Dialogue: 0,0:42:15.53,0:42:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tak mungkin. Joki itu…
Dialogue: 0,0:42:19.49,0:42:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya Dio!
Dialogue: 0,0:42:20.82,0:42:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sempat tertinggal jauh,\Nkini memimpin regu pengejar!
Dialogue: 0,0:42:29.83,0:42:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik perisai hambatan angin!
Dialogue: 0,0:42:33.71,0:42:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dia berhasil menyusul.
Dialogue: 0,0:42:36.30,0:42:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kemenangan atau hadiah uang\Ntak penting bagiku.{\i0}
Dialogue: 0,0:42:40.84,0:42:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi untuk mengungkap misteri bola baja,\Naku harus diakui dulu olehnya.{\i0}
Dialogue: 0,0:42:47.43,0:42:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang akan menyalip Gyro Zeppeli…{\i0}
Dialogue: 0,0:42:52.98,0:42:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah aku, Johnny Joestar!
Dialogue: 0,0:42:57.90,0:43:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di fase ini, tampaknya\Ntak bisa mengandalkan teknik saja.{\i0}
Dialogue: 0,0:43:01.28,0:43:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penentu pemenangnya\Nadalah sisa tenaga di kaki kuda!{\i0}
Dialogue: 0,0:43:05.45,0:43:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menghemat energi kudaku di bukit.
Dialogue: 0,0:43:08.16,0:43:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balapan sebenarnya dimulai di sini!
Dialogue: 0,0:43:10.04,0:43:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasuki 1 km terakhir,\NPocoloco mulai tancap gas.
Dialogue: 0,0:43:14.13,0:43:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Sand Man ikut menyalip!
Dialogue: 0,0:43:17.80,0:43:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu lagi.
Dialogue: 0,0:43:19.26,0:43:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersisa 450 meter lagi.\NRegu pengejar berpacu maksimal!
Dialogue: 0,0:43:23.01,0:43:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dio dan satu joki lain,\Nnomor pelana #939, Johnny Joestar!
Dialogue: 0,0:43:26.64,0:43:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tujuh kuda di belakang Gyro.\NGyro tiga kuda di belakang Sand Man.
Dialogue: 0,0:43:30.31,0:43:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat joki mengejar Sand Man!
Dialogue: 0,0:43:33.15,0:43:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarak ke Gyro tiga kuda, dua kuda, satu…
Dialogue: 0,0:43:39.19,0:43:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejajar!
Dialogue: 0,0:43:41.74,0:43:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat kuda kini sejajar!
Dialogue: 0,0:43:44.16,0:43:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Johnny Joestar, aku kagum.\NKau berhasil sampai sejauh ini.
Dialogue: 0,0:43:49.71,0:43:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kau pernah berlayar?
Dialogue: 0,0:43:53.38,0:43:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal justru makin cepat\Nsaat diterpa angin sakal.
Dialogue: 0,0:43:57.42,0:44:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angin dari Meksiko itu ditakdirkan\Nuntuk membantu kudaku berlari.
Dialogue: 0,0:44:02.64,0:44:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal pacuan.
Dialogue: 0,0:44:05.60,0:44:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan sengit menjelang finis!
Dialogue: 0,0:44:08.22,0:44:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal 90 meter lagi. Siapakah juaranya?
Dialogue: 0,0:44:14.69,0:44:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro Zeppeli!
Dialogue: 0,0:44:18.28,0:44:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro memimpin!
Dialogue: 0,0:44:20.69,0:44:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro memelesat ke depan!
Dialogue: 0,0:44:22.57,0:44:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Steel Ball-nya!{\i0}
Dialogue: 0,0:44:24.57,0:44:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rotasinya mengibarkan mantelnya.\NDia terangkat berkat prinsip Bernoulli.{\i0}
Dialogue: 0,0:44:30.04,0:44:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ibarat kapal yang melawan\Nangin sakal dari Meksiko.{\i0}
Dialogue: 0,0:44:34.75,0:44:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro memimpin!
Dialogue: 0,0:44:37.21,0:44:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal 45 meter lagi! 27 meter!
Dialogue: 0,0:44:39.63,0:44:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tak terkejar!\NGyro Zeppeli memimpin dan…
Dialogue: 0,0:44:45.43,0:44:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}finis!
Dialogue: 0,0:44:48.93,0:44:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gyro Zeppeli menjuarai tahap pertama!
Dialogue: 0,0:44:52.77,0:44:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah lahir pemimpin Steel Ball Run!
Dialogue: 0,0:44:59.65,0:45:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Musim panas tahun 1890.{\i0}
Dialogue: 0,0:45:02.65,0:45:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku merasa terpanggil ke sini.{\i0}
Dialogue: 0,0:45:06.20,0:45:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Oleh keindahan yang menyala\Ndalam kegelapan ini.{\i0}
Dialogue: 0,0:45:10.45,0:45:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin itu cahaya bernama "harapan".{\i0}
Dialogue: 0,0:45:14.67,0:45:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini kisah tentang bagaimana aku\Nkembali melangkah.{\i0}
Dialogue: 0,0:45:19.42,0:45:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukan secara fisik,{\i0}
Dialogue: 0,0:45:21.09,0:45:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}melainkan tentang bertumbuh\Ndari remaja menjadi dewasa.{\i0}
Dialogue: 0,0:45:26.76,0:45:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semua bermula saat aku, Johnny Joestar,\Nbertemu pria misterius{\i0}
Dialogue: 0,0:45:31.22,0:45:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bernama Gyro Zeppeli.{\i0}
Dialogue: 0,0:47:03.61,0:47:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Terjemahan subtitle oleh Rizky Soraya
