Dialogue: 0,0:03:13.71,0:03:16.93,sign,,0000,0000,0000,,EPISODE SEBELAS: MANA CUKUP SATU SAYAP
Dialogue: 0,0:06:07.47,0:06:12.08,sign,,0000,0000,0000,,15, 16, 17...
Dialogue: 0,0:06:12.08,0:06:15.35,sign,,0000,0000,0000,,21, 22...
Dialogue: 0,0:18:43.17,0:18:47.11,sign,,0000,0000,0000,,GELOMBANG PENGHANCUR SUPER
Dialogue: 0,0:23:48.95,0:23:54.87,sign,,0000,0000,0000,,EPISODE DUA BELAS: AYAM SEMESTA
Dialogue: 0,0:23:54.87,0:24:06.05,sign,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:04.32,0:00:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:05.40,0:00:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia...
Dialogue: 0,0:00:06.74,0:00:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang kejutnya kusalurkan ke tanah.
Dialogue: 0,0:00:10.37,0:00:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur aku terkejut.
Dialogue: 0,0:00:13.12,0:00:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak disangka\Nkekuatan telur mulia sebesar ini.
Dialogue: 0,0:00:20.12,0:00:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Auranya lebih besar dan kuat\Ndari demon yang satunya.
Dialogue: 0,0:00:25.94,0:00:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodohnya aku
Dialogue: 0,0:00:27.26,0:00:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena mengira bisa menang.
Dialogue: 0,0:00:30.82,0:00:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Ayah.
Dialogue: 0,0:00:33.79,0:00:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku tidak bisa.
Dialogue: 0,0:00:39.10,0:00:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanduk demon biasanya dua,\Nmau tahu kenapa punyaku tiga?
Dialogue: 0,0:00:45.36,0:00:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanduk demon adalah simbol kekuatan.
Dialogue: 0,0:00:48.28,0:00:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin kuat makin ada banyak.
Dialogue: 0,0:00:52.78,0:00:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis Putih...
Dialogue: 0,0:00:54.24,0:00:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah paham, kan?
Dialogue: 0,0:00:55.74,0:00:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah memilih lawan.
Dialogue: 0,0:00:58.75,0:01:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:01:00.62,0:01:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabar.
Dialogue: 0,0:01:01.78,0:01:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga kamu aku bunuh.
Dialogue: 0,0:01:04.00,0:01:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth...
Dialogue: 0,0:01:06.67,0:01:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya?
Dialogue: 0,0:01:08.26,0:01:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati tanpa berhasil menolong ayahmu.
Dialogue: 0,0:01:11.38,0:01:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, ikatan kalian palsu.
Dialogue: 0,0:01:14.24,0:01:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kamu biasa saja.
Dialogue: 0,0:01:16.14,0:01:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati sana.
Dialogue: 0,0:01:18.39,0:01:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamatlah sudah.
Dialogue: 0,0:01:23.77,0:01:24.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Keiji?
Dialogue: 0,0:01:24.94,0:01:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:01:26.57,0:01:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih mau melawan?
Dialogue: 0,0:01:29.78,0:01:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini belum berakhir!
Dialogue: 0,0:03:13.71,0:03:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mana Cukup Satu Sayap".
Dialogue: 0,0:03:22.56,0:03:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesepian.
Dialogue: 0,0:03:24.54,0:03:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan Ayah pulang, ya?
Dialogue: 0,0:03:27.52,0:03:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, Keisuke.
Dialogue: 0,0:03:29.44,0:03:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, ayahmu selingkuh lagi.
Dialogue: 0,0:03:33.19,0:03:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bo-Bohong!\N- Idih, dia hidung belang.
Dialogue: 0,0:03:34.82,0:03:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jijik banget.\N- Idih, dia hidung belang.
Dialogue: 0,0:03:37.41,0:03:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Jangan hina ayahku!
Dialogue: 0,0:03:39.91,0:03:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak tingkah!
Dialogue: 0,0:03:41.16,0:03:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pecundang!\N- Dasar cebol!
Dialogue: 0,0:03:43.33,0:03:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, tolong aku.
Dialogue: 0,0:03:46.29,0:03:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:03:48.29,0:03:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasumi?
Dialogue: 0,0:03:49.55,0:03:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu Keisuke!
Dialogue: 0,0:03:52.80,0:03:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis yang aku cintai melindungiku!
Dialogue: 0,0:03:57.34,0:03:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet!
Dialogue: 0,0:03:59.18,0:04:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikat dia juga!
Dialogue: 0,0:04:00.72,0:04:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cewek jangan sok keras!\N- Hentikan!
Dialogue: 0,0:04:04.35,0:04:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar betina!\N- Ke-Keisuke...
Dialogue: 0,0:04:05.85,0:04:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku, Keisuke!
Dialogue: 0,0:04:12.15,0:04:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kasumi.
Dialogue: 0,0:04:16.77,0:04:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mamaku bilang begitu.
Dialogue: 0,0:04:18.99,0:04:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu banget.
Dialogue: 0,0:04:20.07,0:04:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:04:20.91,0:04:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:04:22.93,0:04:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih buat kemarin.
Dialogue: 0,0:04:29.50,0:04:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi.
Dialogue: 0,0:04:30.32,0:04:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya, ayo.\N- Oke.
Dialogue: 0,0:04:34.50,0:04:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi.
Dialogue: 0,0:04:36.64,0:04:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun pasti kabur dalam situasi itu.
Dialogue: 0,0:04:39.38,0:04:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bersalah!
Dialogue: 0,0:04:41.30,0:04:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke.
Dialogue: 0,0:04:43.26,0:04:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak nakal, kan?
Dialogue: 0,0:04:44.64,0:04:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayah!
Dialogue: 0,0:04:46.11,0:04:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang dari kapan?
Dialogue: 0,0:04:47.43,0:04:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru saja.
Dialogue: 0,0:04:49.14,0:04:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke, kita harus bicara.
Dialogue: 0,0:04:54.02,0:04:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh?
Dialogue: 0,0:04:55.44,0:04:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Membasmi iblis?
Dialogue: 0,0:04:58.15,0:05:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku...\NAyah bercanda, kan?
Dialogue: 0,0:05:01.49,0:05:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:05:03.01,0:05:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini saatnya menunaikan\Ntugas sebagai Goshikidori.
Dialogue: 0,0:05:06.79,0:05:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan kuajarkan ilmu\NAliran Lima Dewa.
Dialogue: 0,0:05:11.20,0:05:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba banget.
Dialogue: 0,0:05:13.18,0:05:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mungkin bisa!
Dialogue: 0,0:05:16.30,0:05:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan apa itu Goshikidori?\NAku tidak mengerti!
Dialogue: 0,0:05:22.72,0:05:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu iblis, Keisuke, ikuti aku!
Dialogue: 0,0:05:25.89,0:05:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh?
Dialogue: 0,0:05:27.52,0:05:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkanlah
Dialogue: 0,0:05:30.77,0:05:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}senandung dari hidungku!
Dialogue: 0,0:05:41.58,0:05:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lu-Luar biasa.
Dialogue: 0,0:05:43.58,0:05:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster sebesar itu langsung kalah.
Dialogue: 0,0:05:49.45,0:05:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayah, bisakah aku jadi sekuat dirimu?
Dialogue: 0,0:05:54.54,0:05:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kamu mewarisi kekuatanku.
Dialogue: 0,0:06:01.33,0:06:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus berusaha
Dialogue: 0,0:06:03.34,0:06:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya jadi petarung sekeren Ayah!
Dialogue: 0,0:06:18.36,0:06:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak celah!
Dialogue: 0,0:06:24.49,0:06:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, apa aku tidak berbakat?
Dialogue: 0,0:06:28.87,0:06:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke, tahukah kamu kekuatan sejati?
Dialogue: 0,0:06:33.62,0:06:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:06:36.13,0:06:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Carilah jawabannya sendiri.
Dialogue: 0,0:06:39.75,0:06:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang tugasmu hanya berlatih.
Dialogue: 0,0:06:45.09,0:06:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski berlatih mati-matian,
Dialogue: 0,0:06:47.64,0:06:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku belum tahu jawabannya.
Dialogue: 0,0:06:50.50,0:06:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\Nkekuatanku cuma pajangan.
Dialogue: 0,0:06:55.23,0:06:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, masa bodoh soal nasib dunia.
Dialogue: 0,0:06:59.36,0:07:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin jadi seperti Ayah.
Dialogue: 0,0:07:03.24,0:07:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang berubah sejak itu.
Dialogue: 0,0:07:06.57,0:07:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa sampai sejauh ini pun sudah bagus.
Dialogue: 0,0:07:10.61,0:07:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usahaku sudah maksimal.
Dialogue: 0,0:07:18.93,0:07:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak apa-apaan, sih?
Dialogue: 0,0:07:21.71,0:07:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lebih lemah dariku,\Nmana bisa menang?
Dialogue: 0,0:07:25.26,0:07:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja.
Dialogue: 0,0:07:28.09,0:07:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan luka itu,
Dialogue: 0,0:07:29.76,0:07:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memangnya kamu bisa apa?
Dialogue: 0,0:07:32.22,0:07:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas.
Dialogue: 0,0:07:34.62,0:07:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghajarmu.
Dialogue: 0,0:07:37.25,0:07:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup, Keiji!
Dialogue: 0,0:07:38.56,0:07:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa mati!
Dialogue: 0,0:07:41.57,0:07:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat, Hikari.
Dialogue: 0,0:07:42.98,0:07:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bunuh kenalanku.
Dialogue: 0,0:07:45.36,0:07:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu boleh menyiksanya.
Dialogue: 0,0:07:48.74,0:07:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menguji sesuatu.
Dialogue: 0,0:07:51.78,0:07:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang spesial darinya?
Dialogue: 0,0:07:58.79,0:08:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:08:05.26,0:08:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mo...
Dialogue: 0,0:08:06.75,0:08:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio?
Dialogue: 0,0:08:09.14,0:08:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, aku merindukanmu!
Dialogue: 0,0:08:12.26,0:08:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kabar?
Dialogue: 0,0:08:14.06,0:08:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mo-Morio, aku bisa mati...
Dialogue: 0,0:08:16.89,0:08:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, maaf!
Dialogue: 0,0:08:20.27,0:08:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:08:21.48,0:08:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:08:23.36,0:08:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana Piyoko?
Dialogue: 0,0:08:24.57,0:08:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana.
Dialogue: 0,0:08:26.24,0:08:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bertaruh nyawa demi membasmi\Nmakhluk jahat di kepalaku.
Dialogue: 0,0:08:31.49,0:08:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia penyelamatku.
Dialogue: 0,0:08:34.62,0:08:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga kamu, Piyoko.
Dialogue: 0,0:08:37.28,0:08:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, aku sudah dengar semuanya.
Dialogue: 0,0:08:40.21,0:08:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu datang menolongku, kan?
Dialogue: 0,0:08:42.71,0:08:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang baik!
Dialogue: 0,0:08:46.13,0:08:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma kebetulan lewat.
Dialogue: 0,0:08:48.34,0:08:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi begitu?
Dialogue: 0,0:08:50.72,0:08:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tetap senang, sih.
Dialogue: 0,0:08:52.30,0:08:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obrolan macam apa ini?
Dialogue: 0,0:08:54.64,0:08:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:08:55.89,0:08:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka membuatku murka.
Dialogue: 0,0:08:59.69,0:09:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dikendalikan
Dialogue: 0,0:09:01.27,0:09:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk merusak kota
Dialogue: 0,0:09:03.52,0:09:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyerang kelompok Keiji.
Dialogue: 0,0:09:05.90,0:09:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku sangat terluka.
Dialogue: 0,0:09:09.57,0:09:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan
Dialogue: 0,0:09:11.91,0:09:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kumaafkan!
Dialogue: 0,0:09:19.83,0:09:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio!
Dialogue: 0,0:09:30.84,0:09:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio!
Dialogue: 0,0:09:35.47,0:09:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok jago, Ampas.
Dialogue: 0,0:09:38.97,0:09:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:09:44.48,0:09:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh.
Dialogue: 0,0:09:46.02,0:09:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kami tidak dibunuh?
Dialogue: 0,0:09:48.36,0:09:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia main-main?
Dialogue: 0,0:10:03.44,0:10:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, tolong hentikan.
Dialogue: 0,0:10:07.58,0:10:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, Kakak.
Dialogue: 0,0:10:10.01,0:10:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berjuang.
Dialogue: 0,0:10:12.34,0:10:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi percuma saja.
Dialogue: 0,0:10:15.31,0:10:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kalah telak.
Dialogue: 0,0:10:25.19,0:10:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji...
Dialogue: 0,0:10:27.82,0:10:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, aku keras kepala!
Dialogue: 0,0:10:32.82,0:10:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan.
Dialogue: 0,0:10:34.95,0:10:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok dia masih kuat?
Dialogue: 0,0:10:38.70,0:10:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa...
Dialogue: 0,0:10:40.95,0:10:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu maju\Nmeski lebih lemah dariku?
Dialogue: 0,0:10:43.96,0:10:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu melawan\Nmeski bukan tandingannya?
Dialogue: 0,0:10:48.50,0:10:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke!
Dialogue: 0,0:10:49.71,0:10:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahukah kamu kekuatan sejati?
Dialogue: 0,0:10:56.22,0:10:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, akhirnya aku tahu.
Dialogue: 0,0:10:59.63,0:11:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil aku selalu menyalahkan\Norang lain dan keadaan.
Dialogue: 0,0:11:04.89,0:11:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu bikin alasan untuk lari dari masalah.
Dialogue: 0,0:11:09.11,0:11:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku sangat lemah.
Dialogue: 0,0:11:12.15,0:11:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski menyadarinya,\Naku tidak mau
Dialogue: 0,0:11:15.49,0:11:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengakui kelemahan itu.
Dialogue: 0,0:11:18.46,0:11:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:11:20.20,0:11:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kuat.
Dialogue: 0,0:11:22.58,0:11:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terpaku masa lalu,
Dialogue: 0,0:11:24.45,0:11:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maju tanpa rasa takut,
Dialogue: 0,0:11:26.26,0:11:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tetap teguh pada keyakinanmu!
Dialogue: 0,0:11:31.21,0:11:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya,
Dialogue: 0,0:11:32.59,0:11:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku selalu
Dialogue: 0,0:11:36.84,0:11:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin jadi jantan sepertimu!
Dialogue: 0,0:11:42.26,0:11:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:11:43.90,0:11:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanku meluap!
Dialogue: 0,0:11:48.90,0:11:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apakah ini...
Dialogue: 0,0:11:51.73,0:11:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur muliamu sudah terlatih
Dialogue: 0,0:11:55.18,0:11:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk masuk kebangkitan kedua.
Dialogue: 0,0:11:58.36,0:12:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil,\Nkekuatan barumu akan terbuka.
Dialogue: 0,0:12:02.41,0:12:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tergantung hatimu.
Dialogue: 0,0:12:05.16,0:12:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku?
Dialogue: 0,0:12:07.21,0:12:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Carilah makna kekuatan sejati, Keisuke.
Dialogue: 0,0:12:17.42,0:12:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup main-mainnya.
Dialogue: 0,0:12:19.47,0:12:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tidak ada yang spesial.
Dialogue: 0,0:12:22.03,0:12:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan kubiarkan hidup.
Dialogue: 0,0:12:34.10,0:12:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak memicu kebangkitan keduaku.
Dialogue: 0,0:12:37.05,0:12:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:37.99,0:12:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan sisanya padaku.
Dialogue: 0,0:12:42.24,0:12:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan sejati adalah
Dialogue: 0,0:12:45.83,0:12:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}percaya pada diri sendiri!
Dialogue: 0,0:12:49.08,0:12:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berjanji
Dialogue: 0,0:12:50.67,0:12:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan menyerah!
Dialogue: 0,0:12:55.59,0:12:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu barusan?
Dialogue: 0,0:12:57.30,0:13:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya serangnya tiba-tiba meningkat.
Dialogue: 0,0:13:02.98,0:13:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama, ini makin menarik.
Dialogue: 0,0:13:07.49,0:13:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang terjadi?
Dialogue: 0,0:13:10.35,0:13:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berubah dalam sekejap.
Dialogue: 0,0:13:14.69,0:13:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke, kamu...
Dialogue: 0,0:13:17.23,0:13:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth, bantu aku.
Dialogue: 0,0:13:19.70,0:13:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong cari ayahku selagi sempat.
Dialogue: 0,0:13:22.07,0:13:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya dia ada di dalam pabrik.
Dialogue: 0,0:13:24.53,0:13:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi...
Dialogue: 0,0:13:25.99,0:13:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percayakan saja padaku,\Ndia pasti kalah!
Dialogue: 0,0:13:32.21,0:13:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:13:33.71,0:13:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memercayaimu.
Dialogue: 0,0:13:35.09,0:13:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:36.50,0:13:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji.
Dialogue: 0,0:13:38.06,0:13:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai mati.
Dialogue: 0,0:13:41.18,0:13:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus menang!
Dialogue: 0,0:13:42.86,0:13:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:45.68,0:13:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini,
Dialogue: 0,0:13:47.01,0:13:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti aku lindungi!
Dialogue: 0,0:13:51.69,0:13:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang!
Dialogue: 0,0:13:55.10,0:13:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat!
Dialogue: 0,0:14:01.24,0:14:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:14:02.74,0:14:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah kekuatan\Nkebangkitan kedua telur mulia?
Dialogue: 0,0:14:07.95,0:14:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:14:12.50,0:14:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lari!
Dialogue: 0,0:14:28.66,0:14:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:14:31.48,0:14:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sembunyi terus,
Dialogue: 0,0:14:33.60,0:14:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goshikidori!
Dialogue: 0,0:14:36.11,0:14:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:39.98,0:14:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurus Pemungkas Aliran Lima Dewa!
Dialogue: 0,0:14:43.90,0:14:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Penghancur Super!
Dialogue: 0,0:15:01.57,0:15:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku menang?
Dialogue: 0,0:15:11.39,0:15:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu jadi kuat?
Dialogue: 0,0:15:15.39,0:15:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkat Kakak.
Dialogue: 0,0:15:18.18,0:15:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:15:19.73,0:15:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bersaudara.
Dialogue: 0,0:15:21.86,0:15:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:15:23.38,0:15:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin menolong Ayah.
Dialogue: 0,0:15:26.41,0:15:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah inspirasiku.
Dialogue: 0,0:15:30.70,0:15:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:15:32.77,0:15:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dikalahkan ikatan keluarga.
Dialogue: 0,0:15:38.58,0:15:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikatan yang asli.
Dialogue: 0,0:15:42.55,0:15:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikatan?
Dialogue: 0,0:15:44.35,0:15:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari.
Dialogue: 0,0:15:46.09,0:15:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari-ku yang tersayang.
Dialogue: 0,0:15:50.35,0:15:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siapa dia?
Dialogue: 0,0:15:57.95,0:15:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:12.78,0:16:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Mama.
Dialogue: 0,0:16:15.29,0:16:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah lengah.
Dialogue: 0,0:16:26.80,0:16:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada di sini.
Dialogue: 0,0:16:28.54,0:16:31.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ayahnya Keisuke?
Dialogue: 0,0:16:32.05,0:16:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:16:33.12,0:16:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh.
Dialogue: 0,0:16:34.35,0:16:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:16:36.74,0:16:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbang sini kalau bisa, Ayam Bodoh.
Dialogue: 0,0:16:39.94,0:16:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh katamu?
Dialogue: 0,0:16:41.76,0:16:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, Sophia.
Dialogue: 0,0:16:43.20,0:16:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktifkan jetnya.
Dialogue: 0,0:16:44.65,0:16:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:16:48.57,0:16:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:16:49.70,0:16:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NSial!
Dialogue: 0,0:16:52.70,0:16:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan ayam itu!
Dialogue: 0,0:16:54.96,0:16:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah, dasar bodoh!
Dialogue: 0,0:16:57.20,0:16:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti bilang bodoh!
Dialogue: 0,0:17:00.67,0:17:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:17:03.67,0:17:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan!
Dialogue: 0,0:17:05.96,0:17:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:17:07.21,0:17:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga dia iblis kappa.
Dialogue: 0,0:17:10.43,0:17:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahaya kalau bertarung dalam air.
Dialogue: 0,0:17:15.70,0:17:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak mengejar, ya.
Dialogue: 0,0:17:17.64,0:17:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tetap di sini.
Dialogue: 0,0:17:19.73,0:17:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persetan soal perintah,\Ndia mati pun bukan urusanku.
Dialogue: 0,0:17:28.54,0:17:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:17:30.99,0:17:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku pingsan.
Dialogue: 0,0:17:35.71,0:17:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:17:36.87,0:17:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lari sampai kapan, Goshikidori?
Dialogue: 0,0:17:42.87,0:17:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya serang dan kecepatannya\Nmelonjak drastis.
Dialogue: 0,0:17:46.77,0:17:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhnya bisa regenerasi.
Dialogue: 0,0:17:48.85,0:17:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya kalau asal serang.
Dialogue: 0,0:17:50.99,0:17:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengincar titik lemahnya!
Dialogue: 0,0:17:53.34,0:17:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup main-mainnya!
Dialogue: 0,0:17:55.46,0:17:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima ini!
Dialogue: 0,0:17:59.52,0:18:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena!
Dialogue: 0,0:18:00.81,0:18:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayamnya masuk kurungan!
Dialogue: 0,0:18:03.02,0:18:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, gelap sekali!
Dialogue: 0,0:18:07.73,0:18:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nerakanya baru dimulai.
Dialogue: 0,0:18:09.82,0:18:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:18:15.79,0:18:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dilihat!
Dialogue: 0,0:18:17.54,0:18:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan suara
Dialogue: 0,0:18:19.83,0:18:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aliran udaranya!
Dialogue: 0,0:18:26.79,0:18:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa merasakannya.
Dialogue: 0,0:18:29.00,0:18:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata pancaindraku juga meningkat!
Dialogue: 0,0:18:33.86,0:18:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak kena?
Dialogue: 0,0:18:35.09,0:18:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa!
Dialogue: 0,0:18:39.72,0:18:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:40.72,0:18:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:18:43.17,0:18:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Penghancur Super!
Dialogue: 0,0:18:53.10,0:18:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:55.42,0:18:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titik lemahnya bukan kepala?
Dialogue: 0,0:18:59.66,0:19:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:19:01.20,0:19:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia beregenerasi dari bola itu!
Dialogue: 0,0:19:07.54,0:19:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup.
Dialogue: 0,0:19:09.34,0:19:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin bertarung.
Dialogue: 0,0:19:11.55,0:19:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, ini menyesakkan.
Dialogue: 0,0:19:13.97,0:19:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama.
Dialogue: 0,0:19:15.34,0:19:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari.
Dialogue: 0,0:19:17.68,0:19:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertarunglah.
Dialogue: 0,0:19:20.43,0:19:23.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Mama.
Dialogue: 0,0:19:23.14,0:19:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan kuberi kematian yang brutal!
Dialogue: 0,0:19:30.65,0:19:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati, mati, matilah!
Dialogue: 0,0:19:34.75,0:19:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengamuk.
Dialogue: 0,0:19:36.76,0:19:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking membabibutanya, tidak ada celah!
Dialogue: 0,0:19:43.78,0:19:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke...
Dialogue: 0,0:19:45.41,0:19:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati, mati, matilah!
Dialogue: 0,0:19:49.04,0:19:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio?
Dialogue: 0,0:19:50.04,0:19:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum memaafkanmu!
Dialogue: 0,0:19:53.26,0:19:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih hidup, Produk Gagal?
Dialogue: 0,0:19:56.63,0:20:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjahat sepertimu tidak boleh hidup!
Dialogue: 0,0:20:00.55,0:20:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan, Morio!
Dialogue: 0,0:20:07.77,0:20:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah remuk!
Dialogue: 0,0:20:11.22,0:20:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengganggu!
Dialogue: 0,0:20:15.94,0:20:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio!
Dialogue: 0,0:20:16.82,0:20:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati pun tidak akan kulepaskan!
Dialogue: 0,0:20:25.79,0:20:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji.
Dialogue: 0,0:20:27.42,0:20:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf tidak bisa membantumu.
Dialogue: 0,0:20:33.04,0:20:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah.
Dialogue: 0,0:20:34.17,0:20:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:20:48.80,0:20:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mo-Morio...
Dialogue: 0,0:20:56.24,0:21:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal temanmu baru saja sadar,\Nsayang sekali, ya.
Dialogue: 0,0:21:00.86,0:21:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi biarkan saja, tidak penting juga.
Dialogue: 0,0:21:05.49,0:21:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma ampas.
Dialogue: 0,0:21:08.58,0:21:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lahir dari kekeliruan.
Dialogue: 0,0:21:12.83,0:21:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya hidupku berarti!
Dialogue: 0,0:21:25.97,0:21:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek, beraninya kamu
Dialogue: 0,0:21:29.77,0:21:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membunuh Morio!
Dialogue: 0,0:21:33.10,0:21:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Kakak...
Dialogue: 0,0:21:36.61,0:21:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang apa?
Dialogue: 0,0:21:46.66,0:21:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, akhirnya telur mulianya...
Dialogue: 0,0:21:50.29,0:21:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti...
Dialogue: 0,0:21:54.54,0:21:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan membunuhmu!
Dialogue: 0,0:23:40.65,0:23:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah berakhir?
Dialogue: 0,0:23:41.98,0:23:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum selesai, Kakak.
Dialogue: 0,0:23:44.19,0:23:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, Keiji, jangan lengah.
Dialogue: 0,0:23:46.40,0:23:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam, ingatlah bakti!
Dialogue: 0,0:23:48.95,0:23:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Ayam Semesta".
Dialogue: 0,0:23:51.20,0:23:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bikin jenggerku panas!
