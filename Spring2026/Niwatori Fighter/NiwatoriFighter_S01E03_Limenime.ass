Dialogue: 0,0:01:40.48,0:01:44.00,tanda,,0000,0000,0000,,EPISODE TIGA: PERUMPAMAAN TIGA BURUNG
Dialogue: 0,0:03:05.83,0:03:07.58,tanda,,0000,0000,0000,,MOMOTARO
Dialogue: 0,0:03:07.58,0:03:08.06,tanda,,0000,0000,0000,,TERIMA KASIH
Dialogue: 0,0:16:36.14,0:16:38.27,tanda,,0000,0000,0000,,BAKTI
Dialogue: 0,0:16:41.90,0:16:44.65,tanda,,0000,0000,0000,,BAKTI
Dialogue: 0,0:17:48.46,0:17:54.18,tanda,,0000,0000,0000,,ONSEN EKOUWA
Dialogue: 0,0:18:23.15,0:18:24.21,tanda,,0000,0000,0000,,KOLAM LUMPUR
Dialogue: 0,0:23:49.74,0:23:51.29,tanda,,0000,0000,0000,,EPISODE EMPAT:
Dialogue: 0,0:23:51.29,0:23:54.99,tanda,,0000,0000,0000,,BERNAPAS DAN MELIHAT LAYAKNYA BURUNG
Dialogue: 0,0:23:55.00,0:24:01.14,tanda,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:01:41.63,0:01:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Perumpamaan Tiga Burung".
Dialogue: 0,0:01:48.05,0:01:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah, Keiji.
Dialogue: 0,0:01:51.97,0:01:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:01:53.72,0:01:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam?
Dialogue: 0,0:01:56.30,0:01:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak merasa berbuat salah\Nsampai pantas kamu bunuh.
Dialogue: 0,0:02:00.02,0:02:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bagimu, tidak.
Dialogue: 0,0:02:01.64,0:02:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, pantas!
Dialogue: 0,0:02:16.74,0:02:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu barusan?
Dialogue: 0,0:02:17.99,0:02:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbakar, tuh.
Dialogue: 0,0:02:19.70,0:02:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda yang kamu pegang cukup ngeri, ya.
Dialogue: 0,0:02:22.37,0:02:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat petir ini bertegangan 10 juta volt.
Dialogue: 0,0:02:29.80,0:02:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatnya dengan niat memanggangmu.
Dialogue: 0,0:02:35.47,0:02:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cukup terampil, ya.\NTapi kenapa sebegitunya membenciku?
Dialogue: 0,0:02:42.81,0:02:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benaran lupa, ya?
Dialogue: 0,0:02:45.14,0:02:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, tidak akan melupakan hari itu.
Dialogue: 0,0:02:49.69,0:02:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamanya.
Dialogue: 0,0:02:52.69,0:02:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak lahir, aku dibesarkan keluarga kaya.
Dialogue: 0,0:02:59.95,0:03:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan ibu sangat baik.
Dialogue: 0,0:03:03.31,0:03:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka merawatku dengan kasih sayang.
Dialogue: 0,0:03:08.06,0:03:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi membuat mereka bahagia,
Dialogue: 0,0:03:10.98,0:03:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mempelajari banyak hal.
Dialogue: 0,0:03:18.72,0:03:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Oh, rasakan ini.\N- Berjuanglah.
Dialogue: 0,0:03:24.27,0:03:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup bahagia serba berkecukupan.
Dialogue: 0,0:03:29.56,0:03:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, hatiku merasa ada yang kurang.
Dialogue: 0,0:03:34.47,0:03:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan suatu hari...
Dialogue: 0,0:03:39.57,0:03:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku menari!
Dialogue: 0,0:03:47.87,0:03:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:03:55.05,0:03:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terluka?
Dialogue: 0,0:03:57.17,0:04:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam sekejap, aku jatuh cinta.
Dialogue: 0,0:04:02.22,0:04:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,
Dialogue: 0,0:04:03.51,0:04:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sambil menyusuri pasir pantai,\Naku mendengar kisah hidupmu.
Dialogue: 0,0:04:08.77,0:04:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Elizabeth.
Dialogue: 0,0:04:10.94,0:04:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama yang bagus.
Dialogue: 0,0:04:12.72,0:04:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisahmu begitu menarik dan terasa baru.
Dialogue: 0,0:04:19.02,0:04:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan di malam itu...
Dialogue: 0,0:04:21.70,0:04:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil mendengar desir ombak,\Nkamu mencumbuku.
Dialogue: 0,0:04:26.91,0:04:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Keiji.
Dialogue: 0,0:04:29.20,0:04:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ini yang kucari selama ini.
Dialogue: 0,0:04:32.71,0:04:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa cinta pada seseayam.
Dialogue: 0,0:04:45.18,0:04:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi kamu...
Dialogue: 0,0:04:51.60,0:04:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kamu mau ke mana?
Dialogue: 0,0:04:55.65,0:04:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota selanjutnya menungguku.
Dialogue: 0,0:04:58.82,0:05:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita saling mencintai?
Dialogue: 0,0:05:02.33,0:05:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa...
Dialogue: 0,0:05:04.70,0:05:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta? Kamu salah.
Dialogue: 0,0:05:07.79,0:05:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini disebut berahi.
Dialogue: 0,0:05:11.33,0:05:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal.
Dialogue: 0,0:05:24.06,0:05:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah setengah tahun berlalu
Dialogue: 0,0:05:26.10,0:05:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak kamu menghancurkan hatiku.
Dialogue: 0,0:05:30.67,0:05:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kumaafkan!
Dialogue: 0,0:05:32.60,0:05:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wa-Wanita ini
Dialogue: 0,0:05:34.96,0:05:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantan pacarnya Tuan Ayam?
Dialogue: 0,0:05:39.93,0:05:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu marah karena aku\Nlangsung pergi setelah begituan?
Dialogue: 0,0:05:51.67,0:05:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubunuh kamu!
Dialogue: 0,0:05:54.63,0:05:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan gegabah,\Nnanti bisa terluka.
Dialogue: 0,0:05:57.38,0:05:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:05:59.26,0:06:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mempermainkan hati seorang gadis,
Dialogue: 0,0:06:02.01,0:06:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu harus mati!
Dialogue: 0,0:06:13.81,0:06:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan juga.
Dialogue: 0,0:06:15.31,0:06:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur, cowok bejat!
Dialogue: 0,0:06:18.24,0:06:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:06:20.00,0:06:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:06:21.69,0:06:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam, jangan kabur!
Dialogue: 0,0:06:24.45,0:06:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hajar cewek itu sampai babak belur!
Dialogue: 0,0:06:34.03,0:06:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buset!
Dialogue: 0,0:06:37.71,0:06:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan!
Dialogue: 0,0:06:39.46,0:06:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thunder Machine Gun!
Dialogue: 0,0:07:13.38,0:07:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Keiji...
Dialogue: 0,0:07:24.01,0:07:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:07:25.88,0:07:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kamu?\NDasar gila!
Dialogue: 0,0:07:29.10,0:07:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal, kamu tidak berniat membunuh.
Dialogue: 0,0:07:37.10,0:07:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Polisi, itu mereka!
Dialogue: 0,0:07:40.11,0:07:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kabur dulu.
Dialogue: 0,0:07:43.52,0:07:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kabur!
Dialogue: 0,0:07:46.48,0:07:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku berniat membunuhnya\Nkalau kami bertemu.
Dialogue: 0,0:07:50.53,0:07:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku belum rela!
Dialogue: 0,0:07:59.58,0:08:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu!
Dialogue: 0,0:08:01.75,0:08:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya ciuman sama Tuan Ayam-ku!
Dialogue: 0,0:08:05.02,0:08:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pelakor!
Dialogue: 0,0:08:06.63,0:08:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tuan Ayam-ku"?
Dialogue: 0,0:08:08.43,0:08:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah sekecil ini pun kamu sikat?
Dialogue: 0,0:08:11.51,0:08:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja, itu penyimpangan.
Dialogue: 0,0:08:14.70,0:08:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong!\NMata keranjang sepertimu...
Dialogue: 0,0:08:18.27,0:08:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kalau sengotot ini\Nnanti aku dikira mencintainya.
Dialogue: 0,0:08:23.87,0:08:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum memaafkanmu.
Dialogue: 0,0:08:32.49,0:08:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salah paham.
Dialogue: 0,0:08:34.27,0:08:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertualang bukan untuk mengejarmu.
Dialogue: 0,0:08:37.33,0:08:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya tujuan utama.
Dialogue: 0,0:08:40.15,0:08:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan utama?
Dialogue: 0,0:08:41.33,0:08:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memusnahkan semua iblis.
Dialogue: 0,0:08:47.10,0:08:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kepergianmu,\Naku menyaksikan kotanya.
Dialogue: 0,0:08:52.22,0:08:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya kacau balau.
Dialogue: 0,0:08:54.78,0:08:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sahabatku Yuki si anjing, Lola si kucing,
Dialogue: 0,0:08:58.98,0:09:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan yang lainnya menjadi korban.
Dialogue: 0,0:09:04.07,0:09:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akibat iblis yang muncul\Nhampir setiap hari di penjuru negeri,
Dialogue: 0,0:09:09.36,0:09:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak orang kehilangan keluarga\Ndan sahabat sama sepertiku.
Dialogue: 0,0:09:15.62,0:09:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas ada yang salah dari dunia\Nkalau yang sengsara sebanyak ini!
Dialogue: 0,0:09:22.69,0:09:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah,\Naku ingin memusnahkan semua iblis.
Dialogue: 0,0:09:27.98,0:09:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah saja.
Dialogue: 0,0:09:29.67,0:09:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuanku cuma membalas dendam adikku.
Dialogue: 0,0:09:32.78,0:09:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:09:33.99,0:09:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya,
Dialogue: 0,0:09:35.20,0:09:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tahu di mana pembunuh adikmu?
Dialogue: 0,0:09:39.19,0:09:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mencari iblis dengan tanda di leher, kan?
Dialogue: 0,0:09:42.31,0:09:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu sesuatu?
Dialogue: 0,0:09:44.18,0:09:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu, aku mempelajari soal iblis.
Dialogue: 0,0:09:49.65,0:09:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, mesin apa ini?
Dialogue: 0,0:09:52.51,0:09:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat praktis yang dipakai manusia.
Dialogue: 0,0:09:55.59,0:09:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak iblis pertama muncul\Nsekitar tiga tahun lalu,
Dialogue: 0,0:09:59.19,0:10:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah ada 800 lebih iblis tercatat.
Dialogue: 0,0:10:02.95,0:10:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka umumnya menyerang\Nmembabi buta ke kota dan manusia.
Dialogue: 0,0:10:07.52,0:10:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perilakunya menunjukkan inteligensi rendah.
Dialogue: 0,0:10:10.97,0:10:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna tubuhnya kebanyakan merah atau biru.
Dialogue: 0,0:10:14.26,0:10:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi belakangan ini, terjadi fenomena aneh.
Dialogue: 0,0:10:18.76,0:10:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Munculnya iblis mutan.
Dialogue: 0,0:10:20.88,0:10:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mutan?
Dialogue: 0,0:10:22.46,0:10:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecerdasan dan ekspresi mereka mirip manusia.
Dialogue: 0,0:10:25.98,0:10:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifat dan bentuknya pun beragam.
Dialogue: 0,0:10:28.44,0:10:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mampus!\N- Ada yang mengganggu manusia.
Dialogue: 0,0:10:33.95,0:10:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ada yang tidak.
Dialogue: 0,0:10:36.24,0:10:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semprot!
Dialogue: 0,0:10:37.68,0:10:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada yang membantu manusia.
Dialogue: 0,0:10:40.91,0:10:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warnanya bisa kuning, hijau,\Nungu, dan lain-lain.
Dialogue: 0,0:10:45.29,0:10:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia juga mutan.
Dialogue: 0,0:10:51.05,0:10:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan inilah topik utamanya.
Dialogue: 0,0:10:53.27,0:10:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini video yang viral di internet.
Dialogue: 0,0:11:01.97,0:11:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia...
Dialogue: 0,0:11:03.43,0:11:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini, belum pernah ada iblis\Nyang punya empat tanduk dan tubuh putih.
Dialogue: 0,0:11:09.45,0:11:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di internet, dia disebut "Iblis Putih".
Dialogue: 0,0:11:19.45,0:11:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayam ini...
Dialogue: 0,0:11:22.78,0:11:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:11:25.83,0:11:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sara...
Dialogue: 0,0:11:43.31,0:11:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah lehernya.
Dialogue: 0,0:12:15.01,0:12:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Ayam, tenanglah!
Dialogue: 0,0:12:34.11,0:12:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau ke mana?
Dialogue: 0,0:12:37.25,0:12:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau menyendiri sebentar.
Dialogue: 0,0:12:55.71,0:12:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sara, apakah itu kamu?
Dialogue: 0,0:13:01.55,0:13:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:13:02.86,0:13:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segalanya membingungkan.
Dialogue: 0,0:13:05.75,0:13:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:13:07.32,0:13:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuncinya ada di bedebah itu.
Dialogue: 0,0:13:10.63,0:13:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti akan kubalas.
Dialogue: 0,0:13:24.16,0:13:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran ada di sini?
Dialogue: 0,0:13:25.78,0:13:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah capek.
Dialogue: 0,0:13:28.35,0:13:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, biar kuperiksa lagi.
Dialogue: 0,0:13:35.42,0:13:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada!
Dialogue: 0,0:13:36.58,0:13:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsen alami.
Dialogue: 0,0:13:39.72,0:13:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Onsen!
Dialogue: 0,0:13:41.48,0:13:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah tidak ada manusia.
Dialogue: 0,0:13:44.57,0:13:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!\NJadi ini yang namanya onsen?
Dialogue: 0,0:13:48.07,0:13:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:13:50.98,0:13:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air di sini juga bagus untuk luka.
Dialogue: 0,0:13:53.92,0:13:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus menyembuhkan luka
Dialogue: 0,0:13:56.30,0:13:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}supaya siap melawan iblis selanjutnya, kan?
Dialogue: 0,0:14:02.73,0:14:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal...
Dialogue: 0,0:14:04.53,0:14:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku cuma mau berendam, sih.
Dialogue: 0,0:14:13.67,0:14:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:14:18.22,0:14:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran.
Dialogue: 0,0:14:22.88,0:14:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya sedalam apa...
Dialogue: 0,0:14:26.14,0:14:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu takut air?
Dialogue: 0,0:14:28.91,0:14:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Culun banget,\Nkamu enggak bisa berenang?
Dialogue: 0,0:14:31.68,0:14:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berisik, ah.
Dialogue: 0,0:14:34.10,0:14:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bahas apaan, sih?
Dialogue: 0,0:14:37.36,0:14:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ada stroberi liar, tuh.
Dialogue: 0,0:14:40.00,0:14:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengelak!
Dialogue: 0,0:14:41.71,0:14:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kayak mimpi.
Dialogue: 0,0:14:43.82,0:14:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku tanya balik.
Dialogue: 0,0:14:45.70,0:14:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa makhluk darat seperti kita\Nbisa berenang?
Dialogue: 0,0:14:50.26,0:14:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, ayam adalah...
Dialogue: 0,0:14:54.21,0:14:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kakiku kepeleset.
Dialogue: 0,0:14:57.02,0:14:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:14:59.74,0:15:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal mati!
Dialogue: 0,0:15:09.97,0:15:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya boleh juga.
Dialogue: 0,0:15:11.61,0:15:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benamkan sampai leher.
Dialogue: 0,0:15:17.65,0:15:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:15:18.71,0:15:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Handuk basah.
Dialogue: 0,0:15:20.52,0:15:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mengeluarkan panas lewat jengger\Nuntuk menstabilkan suhu tubuh.
Dialogue: 0,0:15:26.27,0:15:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi jengger harus didinginkan\Nsupaya tidak pusing.
Dialogue: 0,0:15:30.03,0:15:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia juga begini, kok.
Dialogue: 0,0:15:35.62,0:15:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaman sekali.
Dialogue: 0,0:15:40.38,0:15:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, sudah lama tidak berendam.
Dialogue: 0,0:15:45.34,0:15:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum bertualang,
Dialogue: 0,0:15:47.45,0:15:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biasanya aku minum Romanée-Conti\Nsambil memandangi laut.
Dialogue: 0,0:15:51.56,0:15:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah membasmi semua iblis,
Dialogue: 0,0:15:53.50,0:15:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin mandi Romanée-Conti\Nuntuk merayakannya.
Dialogue: 0,0:16:01.86,0:16:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Menjauhlah!
Dialogue: 0,0:16:04.63,0:16:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi sana!
Dialogue: 0,0:16:07.11,0:16:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam.
Dialogue: 0,0:16:08.45,0:16:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:16:10.62,0:16:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam.
Dialogue: 0,0:16:12.20,0:16:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum punya nama.
Dialogue: 0,0:16:15.74,0:16:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri aku nama.
Dialogue: 0,0:16:20.82,0:16:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:16:22.87,0:16:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko.
Dialogue: 0,0:16:23.54,0:16:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal banget!
Dialogue: 0,0:16:24.30,0:16:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukainya!
Dialogue: 0,0:16:25.86,0:16:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:16:26.80,0:16:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau dipanggil Piyoko sampai dewasa?
Dialogue: 0,0:16:28.90,0:16:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menghargai nama yang Tuan Ayam berikan.
Dialogue: 0,0:16:38.27,0:16:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, apa maksud\Ntulisan "bakti" di punggungmu?
Dialogue: 0,0:16:46.05,0:16:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:16:47.77,0:16:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena telah diberi handuk,\Naku akan memberitahumu.
Dialogue: 0,0:16:51.53,0:16:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah menulisnya supaya aku\Nmenolong orang yang kesusahan.
Dialogue: 0,0:16:57.16,0:17:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah dan tumbuh besar dan kuat.
Dialogue: 0,0:17:02.08,0:17:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:17:07.01,0:17:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:17:21.44,0:17:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku maunya hidup\Nbersama Tuan Ayam saja, deh!
Dialogue: 0,0:17:24.81,0:17:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang banget berubah pikiran.
Dialogue: 0,0:17:28.56,0:17:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Hidup bersama?
Dialogue: 0,0:17:32.99,0:17:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh amat.
Dialogue: 0,0:17:35.02,0:17:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, ogah memaafkan ayam ini!
Dialogue: 0,0:17:46.09,0:17:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Tuan Ayam.
Dialogue: 0,0:17:48.46,0:17:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu begini akibat berendam kelamaan, sih.
Dialogue: 0,0:17:55.65,0:17:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:18:02.34,0:18:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada setan!
Dialogue: 0,0:18:05.81,0:18:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kamu keluar, iblis!
Dialogue: 0,0:18:07.57,0:18:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut setan.
Dialogue: 0,0:18:13.20,0:18:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku, Elizabeth.
Dialogue: 0,0:18:17.04,0:18:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa?\NKamu jatuh ke kolam ikan?
Dialogue: 0,0:18:19.52,0:18:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:18:20.45,0:18:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja, ini masker lumpur.
Dialogue: 0,0:18:24.21,0:18:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut internet,\Nkandungan lumpur ini bagus untuk kulit.
Dialogue: 0,0:18:28.45,0:18:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam juga pengin terlihat cantik, tahu.
Dialogue: 0,0:18:31.47,0:18:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, kamu memang\Nenggak paham perasaan cewek.
Dialogue: 0,0:18:56.95,0:18:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji.
Dialogue: 0,0:19:00.11,0:19:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang memikirkan apa?
Dialogue: 0,0:19:05.08,0:19:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis Putih yang kemarin kamu perlihatkan.
Dialogue: 0,0:19:08.17,0:19:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat diingat-ingat lagi dengan kepala dingin,
Dialogue: 0,0:19:11.51,0:19:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wujudnya agak berbeda\Ndengan yang ada di masa laluku.
Dialogue: 0,0:19:16.76,0:19:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam itu juga...
Dialogue: 0,0:19:18.93,0:19:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung mengira itu Sara,
Dialogue: 0,0:19:21.15,0:19:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi belum ada buktinya.
Dialogue: 0,0:19:22.93,0:19:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Adikmu?
Dialogue: 0,0:19:24.88,0:19:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin?\NHabisnya dia...
Dialogue: 0,0:19:29.21,0:19:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbakar habis.
Dialogue: 0,0:19:35.20,0:19:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sudah belum?
Dialogue: 0,0:19:38.15,0:19:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:19:49.70,0:19:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini, Kak.
Dialogue: 0,0:19:58.14,0:19:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sara!
Dialogue: 0,0:20:08.31,0:20:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:20:09.28,0:20:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:20:10.19,0:20:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, fokus ke depan!
Dialogue: 0,0:20:23.33,0:20:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:20:43.53,0:20:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu...
Dialogue: 0,0:20:46.06,0:20:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi seperti yang kubilang,\Nbelum ada buktinya.
Dialogue: 0,0:20:50.18,0:20:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah dia iblis yang kucari?
Dialogue: 0,0:20:54.51,0:20:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mutasi para iblis membuktikan
Dialogue: 0,0:20:58.26,0:21:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa bisa saja mereka berevolusi.
Dialogue: 0,0:21:02.72,0:21:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja bentuknya berubah
Dialogue: 0,0:21:05.59,0:21:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena Iblis Putih itu telah berevolusi.
Dialogue: 0,0:21:09.00,0:21:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:21:10.89,0:21:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanda di lehernya adalah bukti kuat, kan?
Dialogue: 0,0:21:14.25,0:21:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting, kita kejar dulu si Iblis Putih.
Dialogue: 0,0:21:16.80,0:21:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ketemu, faktanya akan terkuak.
Dialogue: 0,0:21:19.05,0:21:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begini rencana ke depannya.
Dialogue: 0,0:21:21.64,0:21:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:21:24.05,0:21:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Iblis Putih muncul di Tokyo.
Dialogue: 0,0:21:27.27,0:21:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- 300 kilometer ke timur laut dari sini.\N- Elizabeth.
Dialogue: 0,0:21:29.91,0:21:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup jauh.
Dialogue: 0,0:21:32.90,0:21:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana Piyoko?
Dialogue: 0,0:21:36.13,0:21:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali, padahal tadi tidur di sini.
Dialogue: 0,0:21:40.70,0:21:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana dia pergi?
Dialogue: 0,0:21:51.46,0:21:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Ayam, tolong!
Dialogue: 0,0:21:54.98,0:22:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal dimakan!
Dialogue: 0,0:23:40.64,0:23:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa itu berada di dasar lembah\Nyang menyeramkan.
Dialogue: 0,0:23:43.86,0:23:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang dikendalikan bagaikan mayat.
Dialogue: 0,0:23:46.71,0:23:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situlah kami...
Dialogue: 0,0:23:49.16,0:23:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya,
Dialogue: 0,0:23:49.74,0:23:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bernapas dan Melihat Layaknya Burung".
Dialogue: 0,0:23:51.29,0:23:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Keiji, kamu sedang apa? Dasar mesum!
