Dialogue: 0,0:23:48.70,0:23:54.75,tanda,,0000,0000,0000,,EPISODE SEMBILAN: DUNIA CEKER AYAM
Dialogue: 0,0:23:54.75,0:24:00.08,tanda,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:04.73,0:00:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, di kota ini juga\Nterasa keberadaan iblis.
Dialogue: 0,0:00:09.36,0:00:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, baunya tercium.
Dialogue: 0,0:00:14.12,0:00:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke, ikuti aku!
Dialogue: 0,0:00:15.24,0:00:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada iblis?
Dialogue: 0,0:00:17.12,0:00:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan cewek!
Dialogue: 0,0:00:20.08,0:00:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:00:21.17,0:00:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke, pergi dulu sana.
Dialogue: 0,0:00:23.50,0:00:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, kita harus mencari iblisnya!
Dialogue: 0,0:00:26.38,0:00:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Keisuke!
Dialogue: 0,0:00:28.42,0:00:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, seram!
Dialogue: 0,0:00:29.51,0:00:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:00:36.06,0:00:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak, mari kita enak-enak!
Dialogue: 0,0:00:41.27,0:00:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tolong dia!
Dialogue: 0,0:00:42.23,0:00:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pasti asyik, deh.\N- Tunggu.
Dialogue: 0,0:00:45.65,0:00:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, enak, enak.
Dialogue: 0,0:00:47.59,0:00:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia?
Dialogue: 0,0:00:49.65,0:00:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:00:50.57,0:00:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:01:01.71,0:01:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembunyi!
Dialogue: 0,0:01:06.88,0:01:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejar dia, Keisuke.
Dialogue: 0,0:01:08.06,0:01:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:01:13.30,0:01:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia.
Dialogue: 0,0:01:25.98,0:01:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo periksa ruangan itu.
Dialogue: 0,0:01:28.13,0:01:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:01:31.40,0:01:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Keisuke!
Dialogue: 0,0:01:32.45,0:01:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Hah?
Dialogue: 0,0:01:37.16,0:01:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iblis?
Dialogue: 0,0:01:39.03,0:01:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak terasa niat membunuh.
Dialogue: 0,0:01:40.66,0:01:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma itu.
Dialogue: 0,0:01:43.04,0:01:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka seperti boneka.
Dialogue: 0,0:01:45.29,0:01:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa hidup.
Dialogue: 0,0:01:47.55,0:01:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ju-Jumlahnya banyak pula.
Dialogue: 0,0:01:51.17,0:01:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ulah pemuda itu?
Dialogue: 0,0:01:53.01,0:01:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa tujuannya?
Dialogue: 0,0:01:57.06,0:01:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:01:59.39,0:02:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:02:00.81,0:02:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:02:06.31,0:02:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sadar sedang dibuntuti.
Dialogue: 0,0:02:08.44,0:02:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:02:09.41,0:02:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sadar ada mereka!
Dialogue: 0,0:02:11.57,0:02:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari, jangan-jangan...
Dialogue: 0,0:02:15.11,0:02:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya iya.
Dialogue: 0,0:02:17.24,0:02:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka keturunan Klan Goshikidori.
Dialogue: 0,0:02:19.66,0:02:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita beruntung.
Dialogue: 0,0:02:21.66,0:02:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tahu?
Dialogue: 0,0:02:22.83,0:02:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dapat info dari atasan.
Dialogue: 0,0:02:25.25,0:02:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak pertanyaan\Nyang menunggu kalian.
Dialogue: 0,0:02:28.46,0:02:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka paham omonganku?
Dialogue: 0,0:02:30.64,0:02:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian iblis?
Dialogue: 0,0:02:32.47,0:02:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis?
Dialogue: 0,0:02:34.88,0:02:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah.
Dialogue: 0,0:02:36.56,0:02:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah demon.
Dialogue: 0,0:02:38.47,0:02:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk-makhluk terpilih.
Dialogue: 0,0:02:40.60,0:02:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}De-Demon?
Dialogue: 0,0:02:42.48,0:02:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor 31, Nomor 56, tangkap dia.
Dialogue: 0,0:03:03.20,0:03:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga.
Dialogue: 0,0:03:04.96,0:03:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:03:09.00,0:03:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikutan, deh.
Dialogue: 0,0:03:24.35,0:03:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan membunuhnya.
Dialogue: 0,0:03:26.81,0:03:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, maaf.
Dialogue: 0,0:03:32.11,0:03:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski iblisnya bisa kuatasi,
Dialogue: 0,0:03:34.49,0:03:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makhluk bernama demon ini\Nmustahil dilawan.
Dialogue: 0,0:03:37.86,0:03:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mau bagaimana?
Dialogue: 0,0:03:40.07,0:03:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}La-Lari, Keisuke!
Dialogue: 0,0:03:46.96,0:03:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejar dia!
Dialogue: 0,0:03:48.33,0:03:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji akan kembali untuk menolongmu!
Dialogue: 0,0:03:51.84,0:03:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, Ayah!
Dialogue: 0,0:03:57.59,0:04:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, bagaimana ini?
Dialogue: 0,0:04:00.88,0:04:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil bertarung sendirian,\Naku butuh bantuan.
Dialogue: 0,0:04:05.47,0:04:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke.
Dialogue: 0,0:04:06.77,0:04:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kamu punya kakak tiri.
Dialogue: 0,0:04:10.40,0:04:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Keiji.
Dialogue: 0,0:04:12.11,0:04:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada saatnya kalian akan bertarung bersama.
Dialogue: 0,0:04:15.86,0:04:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, ada Kakak!
Dialogue: 0,0:04:18.45,0:04:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, harus kucari ke mana?
Dialogue: 0,0:04:23.20,0:04:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ayam ini.
Dialogue: 0,0:04:26.12,0:04:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gokil!
Dialogue: 0,0:04:27.12,0:04:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia meledakkan kepala iblisnya.
Dialogue: 0,0:04:29.00,0:04:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jago banget!
Dialogue: 0,0:04:31.17,0:04:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kemarin dia ada di Kota Midorino.
Dialogue: 0,0:04:33.46,0:04:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:04:38.34,0:04:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota Midorino\Nharus lewat tiga gunung dari sini.
Dialogue: 0,0:04:44.51,0:04:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihatnya di stasiun sana.
Dialogue: 0,0:04:47.02,0:04:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, hidung belang itu?
Dialogue: 0,0:04:49.02,0:04:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari dia kencan buta sama kami.
Dialogue: 0,0:04:51.27,0:04:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya sia-sia, sih.
Dialogue: 0,0:05:00.40,0:05:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya...\NAkhirnya aku menemukanmu.
Dialogue: 0,0:05:04.53,0:05:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:06:49.68,0:06:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ayam Tidak Berdaya".
Dialogue: 0,0:07:06.34,0:07:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Meski berlatih pun,
Dialogue: 0,0:07:09.33,0:07:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- aku tidak akan berubah.
Dialogue: 0,0:07:12.58,0:07:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah supaya cepat besar.
Dialogue: 0,0:07:16.42,0:07:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku rindu Ayah.
Dialogue: 0,0:07:27.47,0:07:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah bangun?
Dialogue: 0,0:07:29.80,0:07:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:07:31.41,0:07:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah membaik.
Dialogue: 0,0:07:36.48,0:07:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beristirahatlah, kamu belum sembuh total.
Dialogue: 0,0:07:41.11,0:07:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku pingsan.
Dialogue: 0,0:07:44.74,0:07:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apakah kamu yang merawatku?
Dialogue: 0,0:07:49.37,0:07:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku cuma berada di sisimu saja.
Dialogue: 0,0:07:52.58,0:07:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sisiku?
Dialogue: 0,0:07:54.83,0:07:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih!
Dialogue: 0,0:07:57.83,0:07:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertolong.
Dialogue: 0,0:07:59.71,0:08:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Te-Terima kasih banyak!\N- Jangan-jangan...
Dialogue: 0,0:08:02.30,0:08:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak terbiasa sama cewek?
Dialogue: 0,0:08:05.63,0:08:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:08:06.97,0:08:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:08:08.88,0:08:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, harus istirahat.
Dialogue: 0,0:08:12.10,0:08:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak usah.
Dialogue: 0,0:08:13.89,0:08:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku sudah sehat.
Dialogue: 0,0:08:15.77,0:08:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sebaiknya kamu
Dialogue: 0,0:08:19.27,0:08:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}istirahat lagi.
Dialogue: 0,0:08:21.48,0:08:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini lucu juga.
Dialogue: 0,0:08:25.48,0:08:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:08:27.53,0:08:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, hentikan itu!
Dialogue: 0,0:08:30.87,0:08:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memanggilku kakak lalu pingsan dua hari.
Dialogue: 0,0:08:33.90,0:08:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah sadar malah berahi!
Dialogue: 0,0:08:37.62,0:08:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu, Keiji.
Dialogue: 0,0:08:39.25,0:08:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang...
Dialogue: 0,0:08:40.25,0:08:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah orang, ya?
Dialogue: 0,0:08:42.71,0:08:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya adik cowok!
Dialogue: 0,0:08:44.59,0:08:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:08:48.84,0:08:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku Keisuke, adik tirimu.
Dialogue: 0,0:08:55.51,0:08:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Adik tiriku?
Dialogue: 0,0:08:59.34,0:09:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, jangan bohong!\NMana buktinya?
Dialogue: 0,0:09:03.06,0:09:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kecil, kita pernah bertemu.
Dialogue: 0,0:09:10.40,0:09:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia...
Dialogue: 0,0:09:17.50,0:09:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:09:18.70,0:09:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sari, ini.
Dialogue: 0,0:09:20.00,0:09:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu membuatnya untukku?
Dialogue: 0,0:09:23.92,0:09:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Cocok?
Dialogue: 0,0:09:25.80,0:09:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, begitulah.
Dialogue: 0,0:09:30.09,0:09:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Sayang.
Dialogue: 0,0:09:31.88,0:09:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa coba?
Dialogue: 0,0:09:33.80,0:09:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa, ya?
Dialogue: 0,0:09:35.26,0:09:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.
Dialogue: 0,0:09:37.35,0:09:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung tidak ketahuan, ya, Keiji.
Dialogue: 0,0:09:39.68,0:09:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, jangan diberi tahu, Ayah!
Dialogue: 0,0:09:44.48,0:09:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat!
Dialogue: 0,0:09:47.02,0:09:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sayang Ayah.
Dialogue: 0,0:09:50.19,0:09:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, aku jalan-jalan dulu.
Dialogue: 0,0:09:52.49,0:09:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati sama kucing liar, ya.
Dialogue: 0,0:09:55.89,0:09:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naiklah ke punggungku.
Dialogue: 0,0:09:58.70,0:10:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada suara Ayah!
Dialogue: 0,0:10:00.57,0:10:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:10:02.08,0:10:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, tinggi banget!
Dialogue: 0,0:10:05.08,0:10:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayah?
Dialogue: 0,0:10:11.16,0:10:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siapa mereka?
Dialogue: 0,0:10:13.38,0:10:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bersama Ayah?
Dialogue: 0,0:10:15.17,0:10:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:10:16.76,0:10:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu orang sini?
Dialogue: 0,0:10:19.06,0:10:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main sama-sama, yuk!
Dialogue: 0,0:10:28.27,0:10:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu bocil yang waktu itu!
Dialogue: 0,0:10:31.53,0:10:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelahnya aku baru tahu\Nbahwa kamu adalah kakakku.
Dialogue: 0,0:10:37.07,0:10:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, aku mau minta tolong.
Dialogue: 0,0:10:41.12,0:10:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah ditangkap oleh iblis.
Dialogue: 0,0:10:43.85,0:10:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku menyelamatkannya!
Dialogue: 0,0:10:46.67,0:10:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sedang berkelana\Nmelawan iblis, kan?
Dialogue: 0,0:10:50.63,0:10:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu dari Ayah.
Dialogue: 0,0:10:52.05,0:10:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok dia tahu?
Dialogue: 0,0:10:54.93,0:10:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh kita sangat kuat,\Naku butuh bantuanmu!
Dialogue: 0,0:10:59.56,0:11:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini keterlaluan.
Dialogue: 0,0:11:02.48,0:11:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku ingin menyelamatkannya.
Dialogue: 0,0:11:05.69,0:11:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Kakak!
Dialogue: 0,0:11:09.52,0:11:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:11:12.28,0:11:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa?
Dialogue: 0,0:11:13.74,0:11:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ayahmu, kan?
Dialogue: 0,0:11:15.45,0:11:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan lagi ayahku.
Dialogue: 0,0:11:18.87,0:11:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:11:21.33,0:11:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:11:23.70,0:11:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, jangan pergi!
Dialogue: 0,0:11:26.79,0:11:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang...
Dialogue: 0,0:11:28.79,0:11:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:11:35.05,0:11:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lama setelah itu,\Nibuku sakit keras akibat tekanan batin.
Dialogue: 0,0:11:40.88,0:11:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu baik-baik saja?
Dialogue: 0,0:11:42.68,0:11:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sudah hampir sembuh.
Dialogue: 0,0:11:46.53,0:11:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, di suatu pagi...
Dialogue: 0,0:11:52.15,0:11:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku meninggal.
Dialogue: 0,0:11:55.44,0:11:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meninggalkan Sara yang baru menetas.
Dialogue: 0,0:11:59.01,0:12:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu menyembunyikan telur terakhir\Nhasil kawin dengan Ayah dariku,
Dialogue: 0,0:12:04.66,0:12:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berkorban demi mengeraminya!
Dialogue: 0,0:12:10.42,0:12:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi anak si bedebah itu,
Dialogue: 0,0:12:12.49,0:12:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa Ibu harus...
Dialogue: 0,0:12:15.59,0:12:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:12:19.64,0:12:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kalau dia mau\Nbikin keluarga baru.
Dialogue: 0,0:12:24.85,0:12:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ibuku dibuat sakit hati
Dialogue: 0,0:12:28.98,0:12:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai meninggal!
Dialogue: 0,0:12:31.45,0:12:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dosanya tidak bisa diampuni!
Dialogue: 0,0:12:35.73,0:12:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku turut berduka.
Dialogue: 0,0:12:39.88,0:12:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Ayah tidak sepenuhnya salah...
Dialogue: 0,0:12:41.59,0:12:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:12:42.87,0:12:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok tahu!
Dialogue: 0,0:12:45.08,0:12:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah sepertimu yang dibesarkan\Nsampah itu, jangan sok tahu!
Dialogue: 0,0:12:51.02,0:12:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampah?
Dialogue: 0,0:12:53.25,0:12:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak suka sampah?\NBerengsek saja, deh!
Dialogue: 0,0:12:55.84,0:12:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak bebas berpendapat.
Dialogue: 0,0:12:58.26,0:13:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia sosok ayah\Nsekaligus guru bela diriku.
Dialogue: 0,0:13:02.35,0:13:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menghinanya lagi,
Dialogue: 0,0:13:04.72,0:13:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak akan sungkan padamu!
Dialogue: 0,0:13:07.02,0:13:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Sudahlah.
Dialogue: 0,0:13:09.64,0:13:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Keiji!
Dialogue: 0,0:13:14.02,0:13:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sampah paling busuk sedunia.
Dialogue: 0,0:13:17.53,0:13:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas untuk mati!
Dialogue: 0,0:13:22.53,0:13:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!\NJangan bertengkar!
Dialogue: 0,0:13:33.38,0:13:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:13:37.67,0:13:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:13:39.05,0:13:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji kewalahan?
Dialogue: 0,0:13:41.80,0:13:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sebegini kemampuanmu?
Dialogue: 0,0:13:46.06,0:13:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:13:59.15,0:14:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak gerakan sia-sia\Ndan dia juga lamban.
Dialogue: 0,0:14:08.04,0:14:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, sudah cukup!
Dialogue: 0,0:14:09.83,0:14:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma melanjutkan ini!
Dialogue: 0,0:14:12.92,0:14:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:14:14.68,0:14:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal kamu babak belur dulu!
Dialogue: 0,0:14:17.50,0:14:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, biar kuakhiri.
Dialogue: 0,0:14:22.03,0:14:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas.
Dialogue: 0,0:14:24.89,0:14:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbesar.
Dialogue: 0,0:14:27.39,0:14:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alihkan!
Dialogue: 0,0:14:29.77,0:14:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah.
Dialogue: 0,0:14:34.90,0:14:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hantaman Gelombang!
Dialogue: 0,0:14:52.12,0:14:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anak ini...
Dialogue: 0,0:14:55.12,0:14:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuat sekali!
Dialogue: 0,0:15:06.16,0:15:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kei...
Dialogue: 0,0:15:13.77,0:15:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka Kakak selemah itu.
Dialogue: 0,0:15:18.56,0:15:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin meski bekerja sama,
Dialogue: 0,0:15:21.03,0:15:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mustahil kami menang.
Dialogue: 0,0:15:23.37,0:15:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Plus, Kakak kepalang marah padaku.
Dialogue: 0,0:15:27.41,0:15:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:15:28.45,0:15:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah mungkin saja sudah dibunuh.
Dialogue: 0,0:15:33.05,0:15:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak boleh menyerah!
Dialogue: 0,0:15:41.59,0:15:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti syok.
Dialogue: 0,0:15:43.59,0:15:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya baru pertama kali kalah.
Dialogue: 0,0:15:50.80,0:15:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko?
Dialogue: 0,0:15:53.39,0:15:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuan Aam!
Dialogue: 0,0:15:55.14,0:15:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan ini biar semangat!
Dialogue: 0,0:15:57.93,0:15:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:16:01.15,0:16:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja dulu.
Dialogue: 0,0:16:05.94,0:16:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:16:07.28,0:16:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakannya terlalu cepat.
Dialogue: 0,0:16:10.95,0:16:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek serangannya pun di luar nalar.
Dialogue: 0,0:16:15.95,0:16:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bedebah!
Dialogue: 0,0:16:17.96,0:16:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti membalasmu!
Dialogue: 0,0:16:22.40,0:16:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:16:24.38,0:16:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju sini!
Dialogue: 0,0:16:26.23,0:16:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada ampun kali ini!
Dialogue: 0,0:16:27.91,0:16:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak salah paham!
Dialogue: 0,0:16:31.35,0:16:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal tadi, aku yang salah.
Dialogue: 0,0:16:35.00,0:16:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa pun yang terjadi\Naku ingin menyelamatkan Ayah!
Dialogue: 0,0:16:40.15,0:16:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Ayah mati,
Dialogue: 0,0:16:42.33,0:16:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dunia ini akan dikuasai iblis.
Dialogue: 0,0:16:45.46,0:16:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah belum boleh mati.
Dialogue: 0,0:16:48.36,0:16:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:16:49.40,0:16:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu aku menyelamatkannya!
Dialogue: 0,0:16:51.66,0:16:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Kakak!
Dialogue: 0,0:16:55.29,0:16:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku boleh tanya?
Dialogue: 0,0:16:57.54,0:16:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Elizabeth?
Dialogue: 0,0:16:59.67,0:17:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu barusan?
Dialogue: 0,0:17:02.81,0:17:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku dan Ayah juga\Nberjuang membasmi iblis.
Dialogue: 0,0:17:08.80,0:17:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:10.43,0:17:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena,
Dialogue: 0,0:17:12.26,0:17:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itulah tugas Klan Goshikidori.
Dialogue: 0,0:17:16.93,0:17:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan kami dan para iblis\Npunya sejarah panjang.
Dialogue: 0,0:17:21.23,0:17:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kami yang bisa mengalahkan mereka.
Dialogue: 0,0:17:23.81,0:17:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klan yang bertugas membasmi iblis?
Dialogue: 0,0:17:27.31,0:17:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa dia?
Dialogue: 0,0:17:29.32,0:17:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak juga punya darah itu.
Dialogue: 0,0:17:32.27,0:17:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, tolong bantu aku!
Dialogue: 0,0:17:37.95,0:17:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah, bukan urusanku.
Dialogue: 0,0:17:40.33,0:17:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:17:43.71,0:17:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:17:44.96,0:17:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa ceritakan kronologinya?
Dialogue: 0,0:17:48.48,0:17:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Bisa.
Dialogue: 0,0:17:52.09,0:17:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kamu kalah?
Dialogue: 0,0:17:54.59,0:17:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka\Nmengendalikan para iblis itu
Dialogue: 0,0:17:58.05,0:18:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk tujuan yang jahat.
Dialogue: 0,0:18:00.74,0:18:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja,
Dialogue: 0,0:18:02.12,0:18:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka sulit dikalahkan.
Dialogue: 0,0:18:04.98,0:18:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:18:06.27,0:18:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak mungkin membiarkan Ayah!
Dialogue: 0,0:18:09.05,0:18:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau kehilangan dia!
Dialogue: 0,0:18:15.37,0:18:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:18:17.12,0:18:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di mana ayahmu tertangkap?
Dialogue: 0,0:18:19.95,0:18:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Seingatku, di pabrik tua\Ndi pinggiran kota Akamori.
Dialogue: 0,0:18:24.62,0:18:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar 50 km ke barat dari sini.
Dialogue: 0,0:18:27.72,0:18:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu ponsel, kan?
Dialogue: 0,0:18:30.42,0:18:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu benda praktis ini?
Dialogue: 0,0:18:33.61,0:18:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Elizabeth memesona, ya.
Dialogue: 0,0:18:37.64,0:18:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Kota Akamori\Nsedang muncul beberapa iblis.
Dialogue: 0,0:18:41.81,0:18:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Iblis ini...
Dialogue: 0,0:18:43.73,0:18:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji.
Dialogue: 0,0:18:44.90,0:18:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita harus datang ke sana.
Dialogue: 0,0:18:51.29,0:18:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mo-Morio?
Dialogue: 0,0:18:54.70,0:18:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si iblis baik hati...
Dialogue: 0,0:18:57.71,0:19:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Morio begitu?
Dialogue: 0,0:19:04.92,0:19:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan Morio?
Dialogue: 0,0:19:10.75,0:19:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ulah Morio?
Dialogue: 0,0:19:12.34,0:19:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio, tidak mungkin.
Dialogue: 0,0:19:14.72,0:19:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut info internet,
Dialogue: 0,0:19:16.68,0:19:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lima iblis termasuk Morio mendadak muncul
Dialogue: 0,0:19:20.35,0:19:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghilang satu jam kemudian.
Dialogue: 0,0:19:23.06,0:19:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung tidak ada korban jiwa.
Dialogue: 0,0:19:26.05,0:19:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kota ini sering diserang iblis.
Dialogue: 0,0:19:29.52,0:19:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pabrik markas para demon ada di sana.
Dialogue: 0,0:19:32.49,0:19:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka ada hubungannya!
Dialogue: 0,0:19:37.20,0:19:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada iblis!
Dialogue: 0,0:19:38.70,0:19:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:19:41.45,0:19:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio, apa itu kamu?
Dialogue: 0,0:19:47.00,0:19:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bukan.
Dialogue: 0,0:19:48.56,0:19:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang aku lawan di pabrik!
Dialogue: 0,0:19:51.48,0:19:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:52.36,0:19:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi iblis ini tidak asing.
Dialogue: 0,0:20:02.35,0:20:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi.
Dialogue: 0,0:20:04.35,0:20:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir!\NDia mangsaku!
Dialogue: 0,0:20:07.07,0:20:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengaturku!
Dialogue: 0,0:20:08.48,0:20:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhak bertarung!
Dialogue: 0,0:20:11.75,0:20:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati saja sana!
Dialogue: 0,0:20:15.24,0:20:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:20:16.40,0:20:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbesar!
Dialogue: 0,0:20:17.61,0:20:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membunuhnya!
Dialogue: 0,0:20:19.36,0:20:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulunya, dia iblis baik!
Dialogue: 0,0:20:21.87,0:20:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi dia
Dialogue: 0,0:20:24.24,0:20:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak bisa dibiarkan.
Dialogue: 0,0:20:26.21,0:20:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku!
Dialogue: 0,0:20:43.93,0:20:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Talinya berbahan khusus,\Ntidak akan melukai.
Dialogue: 0,0:20:48.23,0:20:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia serbabisa.
Dialogue: 0,0:20:59.57,0:21:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat katakan!
Dialogue: 0,0:21:02.95,0:21:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, dia keras kepala.
Dialogue: 0,0:21:06.70,0:21:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu Klan Goshikidori\Nberniat memusnahkan kami.
Dialogue: 0,0:21:11.89,0:21:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain ayam sutra itu,\Nsiapa rekanmu?
Dialogue: 0,0:21:15.09,0:21:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu-menahu.
Dialogue: 0,0:21:17.96,0:21:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar...
Dialogue: 0,0:21:19.52,0:21:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Izin lapor.
Dialogue: 0,0:21:21.39,0:21:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:21:22.32,0:21:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Funakichi?
Dialogue: 0,0:21:23.85,0:21:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah melepas para iblis, kan?
Dialogue: 0,0:21:27.10,0:21:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, tapi...
Dialogue: 0,0:21:29.60,0:21:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nomor 56 telah dikalahkan.
Dialogue: 0,0:21:32.06,0:21:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh siapa?
Dialogue: 0,0:21:33.77,0:21:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam yang kabur kemarin bawa teman,\Nmereka pelakunya.
Dialogue: 0,0:21:38.86,0:21:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada yang lain.
Dialogue: 0,0:21:41.36,0:21:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti mereka kemari.
Dialogue: 0,0:21:45.12,0:21:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama.
Dialogue: 0,0:21:47.12,0:21:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menangkap mereka,\Naku akan dipuji lagi, kan?
Dialogue: 0,0:21:53.83,0:21:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, Hikari.
Dialogue: 0,0:21:56.71,0:21:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupuji sebanyak-banyaknya.
Dialogue: 0,0:23:40.32,0:23:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, aku akan menyelamatkanmu!
Dialogue: 0,0:23:43.23,0:23:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak iblis.
Dialogue: 0,0:23:44.73,0:23:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak tidak bisa diandalkan!
Dialogue: 0,0:23:46.09,0:23:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus berusaha!
Dialogue: 0,0:23:47.82,0:23:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya,
Dialogue: 0,0:23:48.70,0:23:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dunia Ceker Ayam".
Dialogue: 0,0:23:50.84,0:23:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth?
Dialogue: 0,0:23:51.95,0:23:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu sangat memesona!
