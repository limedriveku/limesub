Dialogue: 0,0:00:00.52,0:00:02.23,tanda,,0000,0000,0000,,LIMA HARI LALU
Dialogue: 0,0:06:49.68,0:06:52.93,tanda,,0000,0000,0000,,EPISODE DELAPAN: AYAM TIDAK BERDAYA
Dialogue: 0,0:06:53.73,0:06:58.69,tanda,,0000,0000,0000,,309, 310, 311.
Dialogue: 0,0:06:58.69,0:07:02.99,tanda,,0000,0000,0000,,312, 313, 314.
Dialogue: 0,0:07:02.99,0:07:06.34,tanda,,0000,0000,0000,,315, 316.
Dialogue: 0,0:07:06.34,0:07:09.33,tanda,,0000,0000,0000,,- 317, 318.
