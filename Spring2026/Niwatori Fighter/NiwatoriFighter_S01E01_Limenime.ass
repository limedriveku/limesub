Dialogue: 0,0:00:08.11,0:00:10.87,Default,,0,0,0,,Eh, Mama, apa makan malam hari ini?
Dialogue: 0,0:00:10.87,0:00:12.59,Default,,0,0,0,,Apa, ya?
Dialogue: 0,0:00:14.26,0:00:15.87,Default,,0,0,0,,Karena Papa tidak akan pulang,
Dialogue: 0,0:00:15.87,0:00:17.92,Default,,0,0,0,,beli yakitori dari Torishige, yuk!
Dialogue: 0,0:00:17.92,0:00:20.03,Default,,0,0,0,,Wah, asyik!
Dialogue: 0,0:00:20.03,0:00:21.60,Default,,0,0,0,,Aku mau...
Dialogue: 0,0:00:21.60,0:00:24.80,Default,,0,0,0,,Ampela, pipi, leher, kerongkongan, dan brutu!
Dialogue: 0,0:00:26.30,0:00:28.73,Default,,0,0,0,,Seleramu kolot banget, ya.
Dialogue: 0,0:00:28.73,0:00:30.25,Default,,0,0,0,,Mirip sama papamu.
Dialogue: 0,0:00:30.25,0:00:32.61,Default,,0,0,0,,Oh, tambah sup jeroan ayam!
Dialogue: 0,0:00:32.61,0:00:34.72,Default,,0,0,0,,Kayak om-om, ih.
Dialogue: 0,0:00:55.66,0:00:56.68,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:00:56.68,0:00:57.97,Default,,0,0,0,,Itu Iblis!
Dialogue: 0,0:00:57.97,0:00:59.39,Default,,0,0,0,,Iblis?
Dialogue: 0,0:01:08.87,0:01:10.44,Default,,0,0,0,,Nak...
Dialogue: 0,0:01:10.44,0:01:12.21,Default,,0,0,0,,Putraku...
Dialogue: 0,0:01:12.21,0:01:13.92,Default,,0,0,0,,Nak...
Dialogue: 0,0:01:14.85,0:01:19.44,Default,,0,0,0,,- Di mana kamu?\N- Tolong!
Dialogue: 0,0:01:30.07,0:01:32.39,Default,,0,0,0,,Putraku.
Dialogue: 0,0:01:39.87,0:01:40.83,Default,,0,0,0,,Mama!
Dialogue: 0,0:01:40.83,0:01:42.09,Default,,0,0,0,,Yuki!
Dialogue: 0,0:01:44.29,0:01:46.05,Default,,0,0,0,,Ketemu.
Dialogue: 0,0:01:49.63,0:01:50.47,Default,,0,0,0,,Mama!
Dialogue: 0,0:01:50.47,0:01:52.55,Default,,0,0,0,,Yuki!
Dialogue: 0,0:01:53.41,0:01:55.43,Default,,0,0,0,,Mama!
Dialogue: 0,0:01:55.43,0:01:59.18,Default,,0,0,0,,Putraku.
Dialogue: 0,0:02:00.35,0:02:04.29,Default,,0,0,0,,Milikku, hanya milikku!
Dialogue: 0,0:02:05.94,0:02:08.07,Default,,0,0,0,,Yuki!
Dialogue: 0,0:02:21.66,0:02:24.01,Default,,0,0,0,,Yuki!
Dialogue: 0,0:02:38.14,0:02:40.81,Default,,0,0,0,,Kembalikan putraku...
Dialogue: 0,0:02:40.81,0:02:45.23,Default,,0,0,0,,Sudah cukup kalian berbuat seenaknya.
Dialogue: 0,0:02:45.23,0:02:47.98,Default,,0,0,0,,Di mana anak itu?
Dialogue: 0,0:02:48.40,0:02:51.71,Default,,0,0,0,,Di mana anak itu?
Dialogue: 0,0:02:52.23,0:02:55.07,Default,,0,0,0,,Di mana kamu, Nak?
Dialogue: 0,0:02:55.07,0:02:57.37,Default,,0,0,0,,- Kalian semua...\N- Nak?
Dialogue: 0,0:02:57.99,0:02:59.74,Default,,0,0,0,,akan kuhajar!
Dialogue: 0,0:03:12.79,0:03:14.17,Default,,0,0,0,,Ini adalah
Dialogue: 0,0:03:15.36,0:03:17.55,Default,,0,0,0,,kisah seekor ayam jantan
Dialogue: 0,0:03:19.22,0:03:22.59,Default,,0,0,0,,yang menyelamatkan umat manusia.
Dialogue: 0,0:05:55.61,0:05:56.76,Default,,0,0,0,,Tunggu!
Dialogue: 0,0:05:58.55,0:06:00.01,Default,,0,0,0,,Kamu mau pergi?
Dialogue: 0,0:06:01.15,0:06:05.34,Default,,0,0,0,,Aku ayam pengembara,\Ntidak terikat di satu tempat.
Dialogue: 0,0:06:06.22,0:06:07.72,Default,,0,0,0,,Kamu mempermainkanku?
Dialogue: 0,0:06:08.89,0:06:09.87,Default,,0,0,0,,Tidak...
Dialogue: 0,0:06:11.52,0:06:13.32,Default,,0,0,0,,Aku cuma berahi!
Dialogue: 0,0:06:17.28,0:06:19.98,Default,,0,0,0,,"Seekor Bangau di Kerumunan Ayam".
Dialogue: 0,0:06:41.42,0:06:42.52,Default,,0,0,0,,Lezat!
Dialogue: 0,0:06:43.01,0:06:45.82,Default,,0,0,0,,Aroma gurih dan rasa pahit yang pas.
Dialogue: 0,0:06:45.82,0:06:49.03,Default,,0,0,0,,Kepik daun memang sarapan ideal.
Dialogue: 0,0:06:49.03,0:06:50.26,Default,,0,0,0,,Selain itu,
Dialogue: 0,0:06:50.26,0:06:54.84,Default,,0,0,0,,ini bagus untuk melancarkan pencernaan.
Dialogue: 0,0:06:57.52,0:06:59.65,Default,,0,0,0,,Lezat dan sehat.
Dialogue: 0,0:06:59.65,0:07:02.65,Default,,0,0,0,,Sambil menyelam minum air!
Dialogue: 0,0:07:15.29,0:07:17.96,Default,,0,0,0,,- Wah, ada ayam!\N- Wah, ada ayam!
Dialogue: 0,0:07:18.79,0:07:20.34,Default,,0,0,0,,Jenggernya manis sekali!
Dialogue: 0,0:07:20.34,0:07:21.80,Default,,0,0,0,,Kayaknya dia ayam liar.
Dialogue: 0,0:07:21.80,0:07:22.88,Default,,0,0,0,,Dari mana asalmu?
Dialogue: 0,0:07:22.88,0:07:24.09,Default,,0,0,0,,Mungkin kebun binatang?
Dialogue: 0,0:07:24.09,0:07:26.70,Default,,0,0,0,,- Lucu banget!\N- Aku benci anak-anak.
Dialogue: 0,0:07:26.70,0:07:29.91,Default,,0,0,0,,Mereka kasar, keras kepala, dan berisik.
Dialogue: 0,0:07:29.91,0:07:32.43,Default,,0,0,0,,Hei, kamu mau ini?
Dialogue: 0,0:07:33.56,0:07:36.94,Default,,0,0,0,,Ayam goreng ini enak, lo!
Dialogue: 0,0:07:37.48,0:07:40.03,Default,,0,0,0,,Dia sudah gila, ya?
Dialogue: 0,0:07:43.53,0:07:45.24,Default,,0,0,0,,Ada hewan menarik, nih.
Dialogue: 0,0:07:45.24,0:07:47.71,Default,,0,0,0,,Ayamnya kasihan, tahu!
Dialogue: 0,0:07:48.11,0:07:50.00,Default,,0,0,0,,Bawel, dasar bocah!
Dialogue: 0,0:07:50.70,0:07:51.61,Default,,0,0,0,,Yuk!
Dialogue: 0,0:07:51.61,0:07:52.40,Default,,0,0,0,,Ayo.
Dialogue: 0,0:07:52.40,0:07:54.37,Default,,0,0,0,,Jenggernya keren banget.
Dialogue: 0,0:07:54.37,0:07:56.25,Default,,0,0,0,,Kalian juga bocah, tahu!
Dialogue: 0,0:07:56.25,0:07:57.75,Default,,0,0,0,,Benar!
Dialogue: 0,0:07:59.50,0:08:00.89,Default,,0,0,0,,Kita apakan, nih?
Dialogue: 0,0:08:00.89,0:08:02.31,Default,,0,0,0,,Aku ingin memakannya.
Dialogue: 0,0:08:02.31,0:08:04.99,Default,,0,0,0,,Bodoh, bisa bahaya kalau dia penyakitan.
Dialogue: 0,0:08:04.99,0:08:05.76,Default,,0,0,0,,Betul juga.
Dialogue: 0,0:08:05.76,0:08:08.72,Default,,0,0,0,,Bagaimana kalau\Nkita jadikan makanan kucingku?
Dialogue: 0,0:08:08.72,0:08:10.26,Default,,0,0,0,,Ide bagus!
Dialogue: 0,0:08:12.76,0:08:14.01,Default,,0,0,0,,Tunggu!
Dialogue: 0,0:08:14.01,0:08:16.14,Default,,0,0,0,,Hei, tunggu!
Dialogue: 0,0:08:17.31,0:08:20.27,Default,,0,0,0,,Siapa juga yang sudi, dasar anak nakal.
Dialogue: 0,0:08:23.15,0:08:25.65,Default,,0,0,0,,Berhenti, ayam sialan!
Dialogue: 0,0:08:25.95,0:08:28.28,Default,,0,0,0,,Cih, keras kepala!
Dialogue: 0,0:08:35.31,0:08:37.52,Default,,0,0,0,,Tunggu!
Dialogue: 0,0:08:50.97,0:08:52.26,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:08:52.26,0:08:54.56,Default,,0,0,0,,Ayam jago itu milik kami.
Dialogue: 0,0:08:55.22,0:08:56.35,Default,,0,0,0,,Oh?
Dialogue: 0,0:09:00.48,0:09:02.19,Default,,0,0,0,,Tidak mungkin.
Dialogue: 0,0:09:02.19,0:09:04.85,Default,,0,0,0,,Soalnya ini peliharaanku.
Dialogue: 0,0:09:04.85,0:09:05.57,Default,,0,0,0,,Eh?
Dialogue: 0,0:09:05.57,0:09:07.57,Default,,0,0,0,,Hei, Kokesuke!
Dialogue: 0,0:09:07.57,0:09:10.49,Default,,0,0,0,,Sudah kubilang, jangan keluar dari halaman!
Dialogue: 0,0:09:10.49,0:09:12.07,Default,,0,0,0,,Ko-Kokesuke?
Dialogue: 0,0:09:12.07,0:09:15.20,Default,,0,0,0,,Maaf, aku akan lebih hati-hati.
Dialogue: 0,0:09:19.08,0:09:20.46,Default,,0,0,0,,Ayo pergi.
Dialogue: 0,0:09:24.96,0:09:27.40,Default,,0,0,0,,Aku selamat, Pak Tua.
Dialogue: 0,0:09:31.34,0:09:34.79,Default,,0,0,0,,Apa ayam itu benaran punya kakek tadi?
Dialogue: 0,0:09:34.79,0:09:36.81,Default,,0,0,0,,Jelas bukan, lah!
Dialogue: 0,0:09:36.81,0:09:38.22,Default,,0,0,0,,- Kuotanya...\N- Dasar tua bangka!
Dialogue: 0,0:09:38.22,0:09:39.39,Default,,0,0,0,,- Kuotanya...\N- Kurasa dia
Dialogue: 0,0:09:39.39,0:09:40.82,Default,,0,0,0,,berniat memakannya sendirian.
Dialogue: 0,0:09:40.82,0:09:42.67,Default,,0,0,0,,Bulan ini...
Dialogue: 0,0:09:42.67,0:09:44.02,Default,,0,0,0,,Pasti...
Dialogue: 0,0:09:44.02,0:09:45.84,Default,,0,0,0,,Pasti kupenuhi...
Dialogue: 0,0:09:45.84,0:09:46.98,Default,,0,0,0,,Kuotanya...
Dialogue: 0,0:09:48.31,0:09:50.37,Default,,0,0,0,,Terima kasih, Pak Tua.
Dialogue: 0,0:09:50.37,0:09:53.53,Default,,0,0,0,,Tapi aku ada urusan penting.
Dialogue: 0,0:09:55.85,0:09:59.16,Default,,0,0,0,,Maaf, cuma ini yang aku punya.
Dialogue: 0,0:10:00.29,0:10:03.29,Default,,0,0,0,,Beras cokelat, jagung, dan daun shiso?
Dialogue: 0,0:10:03.29,0:10:04.61,Default,,0,0,0,,Pak Tua...
Dialogue: 0,0:10:05.63,0:10:09.09,Default,,0,0,0,,Ini jamuan yang sangat istimewa!
Dialogue: 0,0:10:10.51,0:10:13.96,Default,,0,0,0,,Enak, ya? Syukurlah.
Dialogue: 0,0:10:21.10,0:10:25.73,Default,,0,0,0,,Istriku juga selalu memberi makan\Nburung pipit yang berkunjung.
Dialogue: 0,0:10:28.40,0:10:29.99,Default,,0,0,0,,Dipikir-pikir,
Dialogue: 0,0:10:30.73,0:10:33.28,Default,,0,0,0,,seharusnya aku pensiun lebih awal
Dialogue: 0,0:10:33.28,0:10:37.01,Default,,0,0,0,,dan lebih sering menemaninya.
Dialogue: 0,0:10:43.71,0:10:46.63,Default,,0,0,0,,Ini, jangan berebut.
Dialogue: 0,0:10:46.63,0:10:49.03,Default,,0,0,0,,Makanlah pelan-pelan.
Dialogue: 0,0:11:01.14,0:11:03.98,Default,,0,0,0,,Maaf malah mengoceh.
Dialogue: 0,0:11:03.98,0:11:08.02,Default,,0,0,0,,Entah kenapa aku merasa\Nbisa cerita apa pun padamu.
Dialogue: 0,0:11:09.07,0:11:11.04,Default,,0,0,0,,Aku mengerti, Pak Tua.
Dialogue: 0,0:11:11.74,0:11:15.13,Default,,0,0,0,,Seharusnya aku juga lebih sering menemani dia.
Dialogue: 0,0:11:15.61,0:11:16.91,Default,,0,0,0,,Kakak.
Dialogue: 0,0:11:21.20,0:11:22.79,Default,,0,0,0,,Kakak.
Dialogue: 0,0:11:24.44,0:11:25.88,Default,,0,0,0,,Kakak!
Dialogue: 0,0:11:26.54,0:11:29.67,Default,,0,0,0,,Kakak!
Dialogue: 0,0:11:29.67,0:11:31.92,Default,,0,0,0,,Sa-Sara!
Dialogue: 0,0:11:31.92,0:11:34.05,Default,,0,0,0,,Kakak!
Dialogue: 0,0:11:37.93,0:11:39.80,Default,,0,0,0,,Sara!
Dialogue: 0,0:11:45.68,0:11:48.77,Default,,0,0,0,,Kakak!
Dialogue: 0,0:11:49.94,0:11:53.41,Default,,0,0,0,,Sara!
Dialogue: 0,0:12:07.58,0:12:09.52,Default,,0,0,0,,A-Apa itu?
Dialogue: 0,0:12:16.97,0:12:19.22,Default,,0,0,0,,Peningkatan model!
Dialogue: 0,0:12:19.22,0:12:22.01,Default,,0,0,0,,Pertukaran bernilai tinggi!
Dialogue: 0,0:12:22.49,0:12:27.69,Default,,0,0,0,,Peringatan darurat, iblis telah muncul.
Dialogue: 0,0:12:28.27,0:12:34.17,Default,,0,0,0,,Segeralah mengungsi ke tempat aman.
Dialogue: 0,0:12:38.32,0:12:39.82,Default,,0,0,0,,Iblis!
Dialogue: 0,0:12:40.16,0:12:46.83,Default,,0,0,0,,Bulan ini, kuotanya pasti kupenuhi!
Dialogue: 0,0:12:52.21,0:12:54.71,Default,,0,0,0,,- Tolong!\N- Tolong!
Dialogue: 0,0:12:54.71,0:12:56.21,Default,,0,0,0,,Anak-anak nakal barusan!
Dialogue: 0,0:13:00.34,0:13:01.52,Default,,0,0,0,,Hiroshi!
Dialogue: 0,0:13:02.03,0:13:03.22,Default,,0,0,0,,Aduh!
Dialogue: 0,0:13:06.77,0:13:10.39,Default,,0,0,0,,Kuota...
Dialogue: 0,0:13:11.15,0:13:12.97,Default,,0,0,0,,Cepat, lari!
Dialogue: 0,0:13:13.52,0:13:16.90,Default,,0,0,0,,...terpenuhi!
Dialogue: 0,0:13:20.24,0:13:21.24,Default,,0,0,0,,Pak Tua!
Dialogue: 0,0:13:38.17,0:13:39.63,Default,,0,0,0,,Penarikan?
Dialogue: 0,0:13:51.45,0:13:54.02,Default,,0,0,0,,Ini kesempatan kita! Ayo!
Dialogue: 0,0:13:54.44,0:13:55.71,Default,,0,0,0,,Bedebah.
Dialogue: 0,0:13:56.32,0:13:59.39,Default,,0,0,0,,Beraninya kamu mengincar\Nanak-anak dan lansia.
Dialogue: 0,0:14:00.07,0:14:03.45,Default,,0,0,0,,Bikin jenggerku panas saja!
Dialogue: 0,0:14:28.43,0:14:33.19,Default,,0,0,0,,Memenuhi kuota!
Dialogue: 0,0:14:38.69,0:14:42.15,Default,,0,0,0,,Kamu akan kuhajar!
Dialogue: 0,0:14:44.07,0:14:47.37,Default,,0,0,0,,Model edisi khusus!
Dialogue: 0,0:14:57.08,0:14:58.21,Default,,0,0,0,,Kendaraan hibrida!
Dialogue: 0,0:14:58.21,0:14:59.25,Default,,0,0,0,,Mesin hidrogen!
Dialogue: 0,0:15:09.76,0:15:11.10,Default,,0,0,0,,Harus jadi
Dialogue: 0,0:15:11.10,0:15:14.52,Default,,0,0,0,,peringkat pertama nasional!
Dialogue: 0,0:15:38.88,0:15:39.96,Default,,0,0,0,,Domestik!
Dialogue: 0,0:15:39.96,0:15:41.67,Default,,0,0,0,,Impor!
Dialogue: 0,0:15:41.67,0:15:43.40,Default,,0,0,0,,Domestik!
Dialogue: 0,0:15:43.40,0:15:44.84,Default,,0,0,0,,Luar biasa.
Dialogue: 0,0:16:06.53,0:16:07.80,Default,,0,0,0,,Jurus pemungkas!
Dialogue: 0,0:16:13.54,0:16:14.75,Default,,0,0,0,,Rasakan ini!
Dialogue: 0,0:16:16.33,0:16:17.41,Default,,0,0,0,,Ku...
Dialogue: 0,0:16:18.08,0:16:19.21,Default,,0,0,0,,Ku...
Dialogue: 0,0:16:19.75,0:16:20.67,Default,,0,0,0,,Ru...
Dialogue: 0,0:16:22.42,0:16:25.13,Default,,0,0,0,,Yuk!
Dialogue: 0,0:16:25.13,0:16:27.64,Default,,0,0,0,,Yuk!
Dialogue: 0,0:16:49.03,0:16:55.23,Default,,0,0,0,,Laporan penjualan!
Dialogue: 0,0:17:13.47,0:17:15.34,Default,,0,0,0,,Apa itu barusan?
Dialogue: 0,0:17:15.34,0:17:16.89,Default,,0,0,0,,Jangan-jangan ini...
Dialogue: 0,0:17:17.60,0:17:20.41,Default,,0,0,0,,fenomena yang disebut "resonansi".
Dialogue: 0,0:17:20.41,0:17:21.77,Default,,0,0,0,,Re-Resonansi?
Dialogue: 0,0:17:21.77,0:17:25.23,Default,,0,0,0,,Kalian pernah melihatnya di TV dan film, kan?
Dialogue: 0,0:17:26.17,0:17:28.49,Default,,0,0,0,,Orang yang memecahkan kaca cuma pakai suara.
Dialogue: 0,0:17:28.49,0:17:29.74,Default,,0,0,0,,Wow!
Dialogue: 0,0:17:32.95,0:17:34.62,Default,,0,0,0,,Kalau tidak salah,
Dialogue: 0,0:17:34.62,0:17:41.37,Default,,0,0,0,,resonansi terjadi saat frekuensi suara\Ncocok dengan frekuensi objek.
Dialogue: 0,0:17:42.46,0:17:45.42,Default,,0,0,0,,Tapi suara macam apa\Nyang mampu menghancurkan
Dialogue: 0,0:17:45.42,0:17:47.75,Default,,0,0,0,,monster sebesar ini?
Dialogue: 0,0:17:53.18,0:17:54.96,Default,,0,0,0,,Kenapa ayam jago itu...
Dialogue: 0,0:17:56.31,0:17:57.81,Default,,0,0,0,,bisa...
Dialogue: 0,0:19:02.04,0:19:03.63,Default,,0,0,0,,Tidak ada tandanya.
Dialogue: 0,0:19:03.63,0:19:05.83,Default,,0,0,0,,Ternyata bukan dia.
Dialogue: 0,0:19:05.83,0:19:07.79,Default,,0,0,0,,Waduh.
Dialogue: 0,0:19:07.79,0:19:10.15,Default,,0,0,0,,Kacau banget.
Dialogue: 0,0:19:10.65,0:19:13.30,Default,,0,0,0,,Halamanmu berantakan, Pak Tua.
Dialogue: 0,0:19:18.18,0:19:21.19,Default,,0,0,0,,Kamu ingin membantu bersih-bersih?
Dialogue: 0,0:19:25.44,0:19:27.15,Default,,0,0,0,,Ada yang terluka?
Dialogue: 0,0:19:27.15,0:19:29.65,Default,,0,0,0,,Tolong hati-hati!
Dialogue: 0,0:19:32.15,0:19:34.03,Default,,0,0,0,,Korban luka mau lewat.
Dialogue: 0,0:19:35.36,0:19:37.28,Default,,0,0,0,,Ada kantong sampah lagi?
Dialogue: 0,0:19:37.28,0:19:40.16,Default,,0,0,0,,Iya, masih ada.
Dialogue: 0,0:19:43.29,0:19:45.16,Default,,0,0,0,,Hup!
Dialogue: 0,0:19:45.73,0:19:48.79,Default,,0,0,0,,Akhirnya selesai.
Dialogue: 0,0:19:48.79,0:19:52.59,Default,,0,0,0,,Mengalahkan Iblis dan membantu bersih-bersih,
Dialogue: 0,0:19:52.59,0:19:55.15,Default,,0,0,0,,kamu ayam jago yang hebat!
Dialogue: 0,0:19:56.20,0:19:58.01,Default,,0,0,0,,Lo? Mana dia?
Dialogue: 0,0:19:58.01,0:19:59.30,Default,,0,0,0,,Lo?
Dialogue: 0,0:20:02.43,0:20:03.56,Default,,0,0,0,,Kokesuke...
Dialogue: 0,0:20:08.52,0:20:10.84,Default,,0,0,0,,Kokesuke adalah...
Dialogue: 0,0:20:10.84,0:20:12.36,Default,,0,0,0,,bukan namaku.
Dialogue: 0,0:20:12.36,0:20:13.60,Default,,0,0,0,,Namaku Keiji.
Dialogue: 0,0:20:13.97,0:20:15.84,Default,,0,0,0,,Aku pengembara sejati.
Dialogue: 0,0:20:16.36,0:20:18.57,Default,,0,0,0,,Sudah saatnya meninggalkan kota ini.
Dialogue: 0,0:20:19.05,0:20:22.83,Default,,0,0,0,,Pak Tua, utang budi\Njamuan darimu sudah kubalas.
Dialogue: 0,0:20:23.20,0:20:25.08,Default,,0,0,0,,Aku sudah mengalahkan Iblis.
Dialogue: 0,0:20:25.75,0:20:26.83,Default,,0,0,0,,Dan juga
Dialogue: 0,0:20:27.79,0:20:30.21,Default,,0,0,0,,membersihkan halamanmu.
Dialogue: 0,0:20:31.46,0:20:33.99,Default,,0,0,0,,Pergi tanpa meninggalkan masalah.
Dialogue: 0,0:20:34.48,0:20:37.76,Default,,0,0,0,,Begitulah cara hidupku.
Dialogue: 0,0:20:40.92,0:20:42.68,Default,,0,0,0,,Baiklah...
Dialogue: 0,0:20:43.47,0:20:45.31,Default,,0,0,0,,Kamu mau pergi?
Dialogue: 0,0:20:45.71,0:20:49.91,Default,,0,0,0,,Meninggalkan wanita menangis\Nbukanlah gayaku.
Dialogue: 0,0:20:49.91,0:20:52.81,Default,,0,0,0,,Maaf menunggu lama, aku kembali.
Dialogue: 0,0:21:07.25,0:21:10.56,Default,,0,0,0,,Kota berikutnya menungguku.
Dialogue: 0,0:22:51.02,0:22:52.77,Default,,0,0,0,,Lihatlah!
Dialogue: 0,0:22:53.23,0:22:56.60,Default,,0,0,0,,Lihat ini!
Dialogue: 0,0:22:57.94,0:22:59.49,Default,,0,0,0,,Menjijikkan!
Dialogue: 0,0:22:59.49,0:23:00.61,Default,,0,0,0,,Mesum banget!
Dialogue: 0,0:23:00.61,0:23:04.70,Default,,0,0,0,,Aku jadi bahan tontonan!
Dialogue: 0,0:23:07.16,0:23:08.58,Default,,0,0,0,,Tidak ada yang mau
Dialogue: 0,0:23:08.58,0:23:10.33,Default,,0,0,0,,melihat tubuh kotormu!
Dialogue: 0,0:23:15.83,0:23:18.71,Default,,0,0,0,,Thunderbird!
Dialogue: 0,0:23:27.09,0:23:29.03,Default,,0,0,0,,Menjijikkan.
