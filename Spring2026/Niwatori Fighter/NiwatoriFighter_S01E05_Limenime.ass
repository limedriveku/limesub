Dialogue: 0,0:00:33.93,0:00:39.31,tanda,,0000,0000,0000,,PRAJURIT AYAM, MENGALAHKAN IBLIS!!!
Dialogue: 0,0:00:57.91,0:00:58.34,tanda,,0000,0000,0000,,UKURANNYA 9,5 CM!
Dialogue: 0,0:00:58.34,0:01:00.33,tanda,,0000,0000,0000,,[BIKIN KAGET] AKU DAPAT KUMBANG RAKSASA
Dialogue: 0,0:01:00.33,0:01:01.33,tanda,,0000,0000,0000,,[KUMBANG TANDUK]
Dialogue: 0,0:03:32.82,0:03:34.19,tanda,,0000,0000,0000,,EPISODE LIMA
Dialogue: 0,0:03:34.19,0:03:35.82,tanda,,0000,0000,0000,,KUMPUL BAGAI HEWAN BUAS, BUBAR BAGAI BURUNG
Dialogue: 0,0:03:37.32,0:03:40.20,tanda,,0000,0000,0000,,PRAJURIT AYAM, MENGALAHKAN IBLIS!!!
Dialogue: 0,0:05:10.21,0:05:12.21,tanda,,0000,0000,0000,,ADA MESIN BARU
Dialogue: 0,0:07:28.76,0:07:30.76,tanda,,0000,0000,0000,,BULU BABI MENTAH
Dialogue: 0,0:10:43.87,0:10:46.38,tanda,,0000,0000,0000,,KLINIK YAOI\NPANGGILAN BERAKHIR
Dialogue: 0,0:11:59.03,0:12:03.79,tanda,,0000,0000,0000,,SAKE DAIGINJOU
Dialogue: 0,0:15:01.17,0:15:02.46,tanda,,0000,0000,0000,,BISA, KOK
Dialogue: 0,0:19:53.67,0:19:55.55,tanda,,0000,0000,0000,,BAKTI
Dialogue: 0,0:23:48.66,0:23:50.91,tanda,,0000,0000,0000,,EPISODE ENAM: ISTANA SAYAP BURUNG
Dialogue: 0,0:23:54.83,0:23:59.79,tanda,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:01.44,0:00:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini!
Dialogue: 0,0:00:02.36,0:00:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:03.27,0:00:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren, kan?
Dialogue: 0,0:00:04.36,0:00:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling, ini editan.
Dialogue: 0,0:00:06.49,0:00:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pakai listrik.
Dialogue: 0,0:00:08.10,0:00:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kepala iblisnya sampai hancur.
Dialogue: 0,0:00:11.16,0:00:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu banget!
Dialogue: 0,0:00:13.53,0:00:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti mereka!
Dialogue: 0,0:00:15.66,0:00:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius, mereka ada di sini!
Dialogue: 0,0:00:18.36,0:00:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok rasanya aneh, ya.
Dialogue: 0,0:00:20.42,0:00:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka lihat kemari karena keimutanku.
Dialogue: 0,0:00:23.75,0:00:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:00:24.77,0:00:25.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:00:25.67,0:00:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, jangan bergerak!
Dialogue: 0,0:00:28.42,0:00:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, ayo lari!
Dialogue: 0,0:00:31.95,0:00:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Mama.
Dialogue: 0,0:00:34.47,0:00:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penontonnya sudah satu juta lebih.
Dialogue: 0,0:00:36.89,0:00:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang, aku bisa.
Dialogue: 0,0:00:39.98,0:00:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, nanti kutelepon lagi.\NAku sayang Mama.
Dialogue: 0,0:00:48.32,0:00:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku jadi Byutuber top.
Dialogue: 0,0:00:52.32,0:00:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, aku mengunggah\Nvideo berburu serangga langka.
Dialogue: 0,0:00:58.34,0:01:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukurannya 9,5 cm, gede banget!
Dialogue: 0,0:01:01.73,0:01:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, semuanya berubah
Dialogue: 0,0:01:04.09,0:01:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah aku bertemu ayam-ayam itu
Dialogue: 0,0:01:08.13,0:01:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat menjelajahi gunung.
Dialogue: 0,0:01:11.76,0:01:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu, aku mengejar mereka\Nsampai ke kota ini.
Dialogue: 0,0:01:15.40,0:01:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya tidak terkejar.
Dialogue: 0,0:01:18.98,0:01:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya mereka masih di sini.
Dialogue: 0,0:01:24.11,0:01:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam-ayam itu milikku.
Dialogue: 0,0:01:27.19,0:01:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti menemukan\Ndan menjadikan mereka konten viral!
Dialogue: 0,0:01:31.05,0:01:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, woi!
Dialogue: 0,0:01:31.83,0:01:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi!
Dialogue: 0,0:03:15.80,0:03:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:03:18.39,0:03:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:03:20.88,0:03:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lagi?
Dialogue: 0,0:03:21.93,0:03:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, terkepung!
Dialogue: 0,0:03:23.56,0:03:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena kamu!
Dialogue: 0,0:03:24.93,0:03:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth, ke atas!
Dialogue: 0,0:03:26.24,0:03:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:03:28.86,0:03:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, jangan kabur!
Dialogue: 0,0:03:32.82,0:03:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kumpul Bagai Hewan Buas, Bubar Bagai Burung".
Dialogue: 0,0:03:37.32,0:03:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penontonnya bertambah terus.
Dialogue: 0,0:03:40.20,0:03:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, buat apa menangkap kita?
Dialogue: 0,0:03:43.36,0:03:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat dijual ke sirkus?
Dialogue: 0,0:03:45.42,0:03:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, capek banget jadi terkenal.
Dialogue: 0,0:03:50.38,0:03:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo sembunyi di sini\Nsampai situasinya reda.
Dialogue: 0,0:03:54.71,0:03:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembunyi?
Dialogue: 0,0:03:56.59,0:03:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah, aku mau pergi.
Dialogue: 0,0:03:59.34,0:04:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang mengincar kita di kota!
Dialogue: 0,0:04:02.68,0:04:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bunuh diri?
Dialogue: 0,0:04:03.93,0:04:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus sembunyi dari manusia?
Dialogue: 0,0:04:08.21,0:04:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau hidup bebas!
Dialogue: 0,0:04:10.98,0:04:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bakal ditangkap!
Dialogue: 0,0:04:12.94,0:04:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meremehkan manusia!
Dialogue: 0,0:04:15.01,0:04:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka diperintah!
Dialogue: 0,0:04:17.27,0:04:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:17.99,0:04:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilang mau pergi, ya, pergi!
Dialogue: 0,0:04:19.74,0:04:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keras kepala banget, dasar batu!
Dialogue: 0,0:04:23.24,0:04:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel, betina rempong!
Dialogue: 0,0:04:25.87,0:04:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan, sih?
Dialogue: 0,0:04:26.78,0:04:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh siapa kamu ngotot kayak bocil!
Dialogue: 0,0:04:30.08,0:04:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?\N- Jangan bertengkar!
Dialogue: 0,0:04:36.05,0:04:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup!
Dialogue: 0,0:04:38.02,0:04:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berpisah saja.
Dialogue: 0,0:04:39.67,0:04:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:40.47,0:04:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau bertualang sendirian.
Dialogue: 0,0:04:42.89,0:04:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan Ayam!\N- Tunggu!
Dialogue: 0,0:04:44.71,0:04:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi!
Dialogue: 0,0:04:47.66,0:04:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Piyoko?\N- Tuan Ayam,
Dialogue: 0,0:04:50.16,0:04:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah kubilang, jangan pergi!\N- tunggu aku!
Dialogue: 0,0:04:56.73,0:04:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, cewek menyebalkan.
Dialogue: 0,0:05:00.95,0:05:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena!
Dialogue: 0,0:05:14.92,0:05:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mesin yang suka dimainkan manusia.
Dialogue: 0,0:05:18.97,0:05:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar enggak stres, coba mampir, ah.
Dialogue: 0,0:05:26.89,0:05:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya mereka bermain di kebisingan ini.
Dialogue: 0,0:05:30.60,0:05:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia memang aneh.
Dialogue: 0,0:05:38.78,0:05:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:05:39.86,0:05:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gambarnya sama bisa dapat uang, ya.
Dialogue: 0,0:05:43.53,0:05:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau coba juga?
Dialogue: 0,0:05:47.91,0:05:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bicara langsung ke pikiranku.
Dialogue: 0,0:05:50.11,0:05:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aroma ini...\NTidak salah lagi...
Dialogue: 0,0:05:53.92,0:05:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu
Dialogue: 0,0:05:55.19,0:05:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}iblis, kan?
Dialogue: 0,0:05:59.63,0:06:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:06:01.42,0:06:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iblis bernama Morio.
Dialogue: 0,0:06:04.18,0:06:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa kamu kemari?
Dialogue: 0,0:06:07.01,0:06:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan galak begitu.
Dialogue: 0,0:06:08.93,0:06:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini cinta damai.
Dialogue: 0,0:06:12.85,0:06:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hawa membunuh darinya.
Dialogue: 0,0:06:15.59,0:06:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau coba, silakan.
Dialogue: 0,0:06:29.70,0:06:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:06:30.75,0:06:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bikin ketagihan.
Dialogue: 0,0:06:32.70,0:06:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga kamu.
Dialogue: 0,0:06:34.51,0:06:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak.
Dialogue: 0,0:06:36.81,0:06:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang bawa peliharaan.
Dialogue: 0,0:06:42.09,0:06:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh.
Dialogue: 0,0:06:43.55,0:06:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:44.34,0:06:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku cuma pakai koin hasil pungutan.
Dialogue: 0,0:06:47.26,0:06:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}U-Uangnya malah jadi banyak.
Dialogue: 0,0:06:51.52,0:06:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, awalnya dia tidak punya uang?
Dialogue: 0,0:06:54.68,0:06:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hasil memungut,
Dialogue: 0,0:06:56.06,0:06:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku enggak akan dosa kalau minta sedikit, kan?
Dialogue: 0,0:06:59.57,0:07:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengin bulu babi!
Dialogue: 0,0:07:02.23,0:07:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi merasa bersalah.
Dialogue: 0,0:07:05.65,0:07:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan, ah...
Dialogue: 0,0:07:08.31,0:07:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:08.80,0:07:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, enggak, anu...
Dialogue: 0,0:07:10.64,0:07:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu murni keberuntunganmu.
Dialogue: 0,0:07:12.74,0:07:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau buang-buang anugerah dewa,\Nmalah bakal dosa.
Dialogue: 0,0:07:18.25,0:07:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, ini boleh kuambil?
Dialogue: 0,0:07:20.54,0:07:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, tentu saja!
Dialogue: 0,0:07:22.90,0:07:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong...
Dialogue: 0,0:07:25.42,0:07:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya ide.
Dialogue: 0,0:07:32.59,0:07:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu ayam makan beginian.
Dialogue: 0,0:07:35.89,0:07:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bulu babiku tersayang.
Dialogue: 0,0:07:39.25,0:07:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini momen yang kuimpikan.
Dialogue: 0,0:07:54.37,0:07:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok enggak enak?
Dialogue: 0,0:07:57.61,0:07:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini basi, ya?
Dialogue: 0,0:07:59.48,0:08:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda jauh sama bulu babi segar!
Dialogue: 0,0:08:03.17,0:08:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kukira bisa makan...\N- He-Hei?
Dialogue: 0,0:08:08.28,0:08:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu babi yang kuimpikan!
Dialogue: 0,0:08:13.35,0:08:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu babiku!
Dialogue: 0,0:08:19.23,0:08:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam!
Dialogue: 0,0:08:20.35,0:08:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei, ayam!
Dialogue: 0,0:08:22.89,0:08:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam!
Dialogue: 0,0:08:31.12,0:08:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah bangun?
Dialogue: 0,0:08:32.90,0:08:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:08:34.20,0:08:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahku.
Dialogue: 0,0:08:35.76,0:08:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tiba-tiba pingsan, jadi kubawa kemari.
Dialogue: 0,0:08:40.85,0:08:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya, maaf merepotkan.
Dialogue: 0,0:08:44.00,0:08:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tinggal sendirian?
Dialogue: 0,0:08:45.88,0:08:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku sudah lama tinggal di sini.
Dialogue: 0,0:08:49.18,0:08:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang, aku ke kota mencari hiburan.
Dialogue: 0,0:08:52.47,0:08:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:54.22,0:08:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini yang paling nyaman.
Dialogue: 0,0:08:57.16,0:09:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain hening, pemandangannya indah.
Dialogue: 0,0:09:01.27,0:09:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempat kesukaanku.
Dialogue: 0,0:09:06.07,0:09:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana inangmu?
Dialogue: 0,0:09:08.28,0:09:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin, sedang hidup bahagia\Ndi suatu tempat.
Dialogue: 0,0:09:13.86,0:09:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lahir enam bulan yang lalu.
Dialogue: 0,0:09:19.69,0:09:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf, ini kanker lambung stadium akhir.
Dialogue: 0,0:09:23.43,0:09:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa hidupmu, sekitar satu bulan.
Dialogue: 0,0:09:30.26,0:09:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama 47 tahun, hidupku membosankan.
Dialogue: 0,0:09:36.43,0:09:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacaran pun tidak pernah.
Dialogue: 0,0:09:42.73,0:09:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, buat apa aku terlahir?
Dialogue: 0,0:09:48.82,0:09:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau mati!\NAku masih mau hidup!
Dialogue: 0,0:09:53.05,0:09:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau hidup...
Dialogue: 0,0:09:56.08,0:09:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau hidup!
Dialogue: 0,0:10:07.96,0:10:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlahir dari harapan kuatmu untuk hidup.
Dialogue: 0,0:10:12.84,0:10:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu bisa mati dengan tenang.
Dialogue: 0,0:10:16.74,0:10:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus hidup demi dirimu.
Dialogue: 0,0:10:22.40,0:10:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama saja bohong, dong?
Dialogue: 0,0:10:28.09,0:10:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Rumah sakit meneleponku.
Dialogue: 0,0:10:31.12,0:10:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:10:31.92,0:10:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Morio!
Dialogue: 0,0:10:33.24,0:10:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak kena kanker!
Dialogue: 0,0:10:35.83,0:10:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:36.49,0:10:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya!
Dialogue: 0,0:10:37.99,0:10:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Catatan medismu tertukar!
Dialogue: 0,0:10:40.48,0:10:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sehat walafiat!
Dialogue: 0,0:10:42.58,0:10:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segar bugar!
Dialogue: 0,0:10:46.38,0:10:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku bisa terus hidup.
Dialogue: 0,0:10:49.00,0:10:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana nasibku...
Dialogue: 0,0:10:51.01,0:10:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!\NAku bisa terus hidup!
Dialogue: 0,0:10:54.51,0:10:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berjuang memulai hidup baru!
Dialogue: 0,0:10:57.18,0:11:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Waktunya cari pacar!\N- He-Hei, tunggu...
Dialogue: 0,0:11:02.14,0:11:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku hidup menggantikannya.
Dialogue: 0,0:11:06.51,0:11:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lahir dari kekeliruan.
Dialogue: 0,0:11:09.09,0:11:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupku tidak berarti.
Dialogue: 0,0:11:12.34,0:11:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang di kota menindas\Ndan menyebutku monster.
Dialogue: 0,0:11:17.49,0:11:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar monster!\N- Pergi sana!
Dialogue: 0,0:11:20.50,0:11:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hajar dia!
Dialogue: 0,0:11:24.60,0:11:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat sedih.
Dialogue: 0,0:11:27.58,0:11:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku pun sampai menyusut.
Dialogue: 0,0:11:32.46,0:11:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada seorang pun,\Nyang hidupnya tidak berarti.
Dialogue: 0,0:11:38.07,0:11:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah hidup.
Dialogue: 0,0:11:40.12,0:11:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu saat kamu pasti menemukan arti hidupmu.
Dialogue: 0,0:11:43.56,0:11:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang berharap untuk hidup,\Ntapi tidak bisa, lo.
Dialogue: 0,0:11:48.02,0:11:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Sara?
Dialogue: 0,0:11:51.39,0:11:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ayam yang baik.
Dialogue: 0,0:11:54.61,0:11:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:11:55.93,0:11:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tunggu sebentar.
Dialogue: 0,0:11:59.03,0:12:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tada! Aku punya sake!
Dialogue: 0,0:12:00.99,0:12:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibeli dari gaji kerja perbaikan jalan!
Dialogue: 0,0:12:03.79,0:12:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tiba-tiba ingin minum.
Dialogue: 0,0:12:06.20,0:12:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau?
Dialogue: 0,0:12:07.86,0:12:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:12:10.41,0:12:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan minum juga.
Dialogue: 0,0:12:14.88,0:12:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata minum sama orang seenak ini, ya!
Dialogue: 0,0:12:18.38,0:12:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyenangkan!
Dialogue: 0,0:12:20.18,0:12:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini yang namanya mabuk.
Dialogue: 0,0:12:24.01,0:12:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:12:25.89,0:12:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku tiba-tiba meluap!
Dialogue: 0,0:12:32.77,0:12:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganmu?
Dialogue: 0,0:12:35.28,0:12:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:12:37.36,0:12:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunjukkan jurus andalanku.
Dialogue: 0,0:12:41.91,0:12:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saksikanlah!
Dialogue: 0,0:12:43.53,0:12:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Joget ayam.
Dialogue: 0,0:12:48.25,0:12:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jogetmu aneh banget!
Dialogue: 0,0:12:58.74,0:13:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia muntah lagi, deh!
Dialogue: 0,0:13:02.77,0:13:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru pertama merasa sesenang ini.
Dialogue: 0,0:13:06.10,0:13:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Keiji.
Dialogue: 0,0:13:09.77,0:13:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu ada iblis sepertimu.
Dialogue: 0,0:13:12.10,0:13:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang berjumpa denganmu, Morio.
Dialogue: 0,0:13:15.58,0:13:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:13:16.45,0:13:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:17.36,0:13:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan-kapan kita ketemu lagi, ya.
Dialogue: 0,0:13:22.07,0:13:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, Keiji!
Dialogue: 0,0:13:25.02,0:13:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa!
Dialogue: 0,0:13:32.46,0:13:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya mencari tempat tidur malam ini.
Dialogue: 0,0:13:37.25,0:13:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sedang apa...
Dialogue: 0,0:13:40.80,0:13:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan urusanku.
Dialogue: 0,0:13:49.43,0:13:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya akan ada badai besar.
Dialogue: 0,0:13:58.57,0:14:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam!
Dialogue: 0,0:14:01.45,0:14:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di mana?
Dialogue: 0,0:14:04.20,0:14:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu sedang apa, sih, Piyoko?\N- Tuan Ayam!
Dialogue: 0,0:14:06.12,0:14:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo kita cari tempat aman!\N- Tuan Ayam!
Dialogue: 0,0:14:08.45,0:14:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu juga rabun kalau malam, kan?\N- Tuan Ayam!
Dialogue: 0,0:14:11.96,0:14:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:14:13.33,0:14:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji sudah pergi dari kota ini.
Dialogue: 0,0:14:15.66,0:14:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja cowok egois dan payah begitu!
Dialogue: 0,0:14:19.09,0:14:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu setia pada Tuan Ayam
Dialogue: 0,0:14:22.34,0:14:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak akan jauh darinya!
Dialogue: 0,0:14:24.09,0:14:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula kalau membencinya,\Nkenapa kamu mengikuti Tuan Ayam?
Dialogue: 0,0:14:28.68,0:14:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu mengganggunya!
Dialogue: 0,0:14:31.10,0:14:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan dia!
Dialogue: 0,0:14:32.64,0:14:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jahat!\NAku benci kamu!
Dialogue: 0,0:14:41.13,0:14:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada ayam.
Dialogue: 0,0:14:44.07,0:14:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada anaknya juga, kalian ibu dan anak?
Dialogue: 0,0:14:46.87,0:14:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu kelihatan modis.
Dialogue: 0,0:14:49.47,0:14:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamu punya tulisan di punggung.
Dialogue: 0,0:14:52.18,0:14:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggemaskan!
Dialogue: 0,0:14:53.71,0:14:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kalian basah.
Dialogue: 0,0:14:56.57,0:14:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas masuk angin.
Dialogue: 0,0:14:57.96,0:15:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Apa ayam bisa masuk angin?
Dialogue: 0,0:15:02.46,0:15:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa kalian di sini?
Dialogue: 0,0:15:05.85,0:15:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersesat?
Dialogue: 0,0:15:09.33,0:15:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mampir ke rumahku?
Dialogue: 0,0:15:13.52,0:15:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang, Kakek.
Dialogue: 0,0:15:16.05,0:15:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengikutinya karena terlihat baik, tapi...
Dialogue: 0,0:15:20.69,0:15:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:15:22.19,0:15:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak kolam mini!
Dialogue: 0,0:15:24.89,0:15:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek, aku bawa obatnya.
Dialogue: 0,0:15:28.52,0:15:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Misuzu.
Dialogue: 0,0:15:31.33,0:15:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menolong kami, Misuzu.
Dialogue: 0,0:15:34.73,0:15:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:35.96,0:15:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang barusan bicara...
Dialogue: 0,0:15:37.58,0:15:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Elizabeth,\Naku bisa bicara pakai ponsel.
Dialogue: 0,0:15:41.54,0:15:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan dia Piyoko.
Dialogue: 0,0:15:44.67,0:15:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memperkenalkan seenaknya.
Dialogue: 0,0:15:47.34,0:15:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat banget!
Dialogue: 0,0:15:50.10,0:15:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek juga dengar, kan?
Dialogue: 0,0:15:52.22,0:15:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:56.48,0:15:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma punya gandum, kamu mau?
Dialogue: 0,0:15:58.98,0:16:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, aku mau.
Dialogue: 0,0:16:01.06,0:16:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dimakan.
Dialogue: 0,0:16:08.61,0:16:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cuma tinggal berdua?
Dialogue: 0,0:16:10.92,0:16:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Enak sekali.\N- Iya.
Dialogue: 0,0:16:12.78,0:16:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu meninggal karena kecelakaan.
Dialogue: 0,0:16:16.46,0:16:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku diasuh Kakek.
Dialogue: 0,0:16:19.70,0:16:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:16:21.47,0:16:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, cuci piring selesai.
Dialogue: 0,0:16:23.52,0:16:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya...
Dialogue: 0,0:16:27.50,0:16:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka belajar?
Dialogue: 0,0:16:29.60,0:16:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:16:30.63,0:16:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi dokter.
Dialogue: 0,0:16:32.85,0:16:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya bisa menyembuhkan Kakek dengan gratis.
Dialogue: 0,0:16:36.43,0:16:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar anak baik.
Dialogue: 0,0:16:38.81,0:16:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti bisa, kok.
Dialogue: 0,0:16:40.70,0:16:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga bocil, tahu.
Dialogue: 0,0:16:43.53,0:16:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tanya sesuatu.
Dialogue: 0,0:16:46.88,0:16:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut internet,
Dialogue: 0,0:16:48.69,0:16:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daerah ini punya curah hujan tertinggi\Nyang pernah tercatat.
Dialogue: 0,0:16:52.67,0:16:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dekat sini juga ada sungai.
Dialogue: 0,0:16:55.83,0:16:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian tidak mengungsi?
Dialogue: 0,0:17:00.80,0:17:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:17:03.09,0:17:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 85 tahun aku tinggal di sini,
Dialogue: 0,0:17:07.41,0:17:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak pernah ada korban jiwa.
Dialogue: 0,0:17:10.56,0:17:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga hujannya berhenti.
Dialogue: 0,0:17:14.20,0:17:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja begitu.
Dialogue: 0,0:17:17.39,0:17:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringatan evakuasi!
Dialogue: 0,0:17:19.39,0:17:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air sungai sudah naik ke level banjir!
Dialogue: 0,0:17:22.40,0:17:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera lakukan evakuasi!
Dialogue: 0,0:17:25.48,0:17:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ulangi...
Dialogue: 0,0:17:34.53,0:17:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membencinya,\Nkenapa kamu mengikuti Tuan Ayam?
Dialogue: 0,0:17:38.94,0:17:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengikuti Keiji
Dialogue: 0,0:17:41.30,0:17:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kekuatannya diperlukan\Nuntuk memusnahkan iblis.
Dialogue: 0,0:17:45.69,0:17:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini disebut berahi.
Dialogue: 0,0:17:48.57,0:17:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal.
Dialogue: 0,0:17:49.82,0:17:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebencian yang muncul di hari itu
Dialogue: 0,0:17:52.86,0:17:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan pernah hilang.
Dialogue: 0,0:17:55.09,0:17:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, saat kami berjumpa kembali,
Dialogue: 0,0:17:57.81,0:17:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak sanggup membunuhnya.
Dialogue: 0,0:17:59.77,0:18:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan di momen itu,\Naku tidak bisa melawan.
Dialogue: 0,0:18:03.73,0:18:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah aku masih mencintainya?
Dialogue: 0,0:18:07.73,0:18:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, perasaanku sulit dimengerti.
Dialogue: 0,0:18:15.24,0:18:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang, tidak?
Dialogue: 0,0:18:16.86,0:18:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu, biar kubuka pintunya.
Dialogue: 0,0:18:20.01,0:18:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian belum mengungsi?
Dialogue: 0,0:18:22.20,0:18:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air sungainya sudah naik!
Dialogue: 0,0:18:26.13,0:18:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini area rawan banjir!
Dialogue: 0,0:18:27.67,0:18:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air bakal sampai ke sini!
Dialogue: 0,0:18:29.38,0:18:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat mengungsi!
Dialogue: 0,0:18:30.59,0:18:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuperiksa rumah yang lain!
Dialogue: 0,0:18:46.61,0:18:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pos pengungsiannya.
Dialogue: 0,0:18:48.90,0:18:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hampir sampai, Kek.
Dialogue: 0,0:18:55.66,0:18:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:01.87,0:19:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa maju!
Dialogue: 0,0:19:03.29,0:19:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rodanya macet!
Dialogue: 0,0:19:09.21,0:19:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamatlah sudah!
Dialogue: 0,0:19:13.48,0:19:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth?
Dialogue: 0,0:19:14.59,0:19:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyerah hingga akhir!
Dialogue: 0,0:19:19.21,0:19:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru ingat.
Dialogue: 0,0:19:22.18,0:19:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski seharusnya membenciku,
Dialogue: 0,0:19:25.03,0:19:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tetap menolongku saat itu.
Dialogue: 0,0:19:28.23,0:19:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini pun dia mempertaruhkan nyawa\Ndemi menolong manusia.
Dialogue: 0,0:19:34.23,0:19:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan,
Dialogue: 0,0:19:35.27,0:19:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di awal pertemuan kami...
Dialogue: 0,0:19:38.07,0:19:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas ada yang salah dari dunia\Nkalau yang sengsara sebanyak ini!
Dialogue: 0,0:19:43.67,0:19:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:19:45.14,0:19:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tipe yang tidak bisa mengabaikan\Norang yang kesusahan.
Dialogue: 0,0:19:49.29,0:19:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham sekarang.
Dialogue: 0,0:19:51.90,0:19:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth adalah...
Dialogue: 0,0:19:53.67,0:19:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakti!
Dialogue: 0,0:19:59.94,0:20:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko?
Dialogue: 0,0:20:02.78,0:20:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergeraklah!
Dialogue: 0,0:20:05.29,0:20:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma saja.
Dialogue: 0,0:20:06.77,0:20:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggalkan saja aku!
Dialogue: 0,0:20:08.56,0:20:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak akan!
Dialogue: 0,0:20:14.15,0:20:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menyerah!
Dialogue: 0,0:20:16.90,0:20:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misuzu!
Dialogue: 0,0:20:18.66,0:20:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarlah!
Dialogue: 0,0:20:22.28,0:20:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan penuhku!
Dialogue: 0,0:20:39.49,0:20:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menolongku,\NElizabeth, Piyoko.
Dialogue: 0,0:20:43.81,0:20:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:20:47.56,0:20:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kakek botak!\NJangan mudah menyerah!
Dialogue: 0,0:20:50.38,0:20:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mati sebelum Misuzu dewasa, ya!
Dialogue: 0,0:20:55.07,0:20:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kami tidak akan berhasil
Dialogue: 0,0:20:58.00,0:20:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau Piyoko tidak membantu.
Dialogue: 0,0:20:59.95,0:21:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sayang Misuzu.
Dialogue: 0,0:21:02.93,0:21:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu boleh juga, Piyoko.
Dialogue: 0,0:21:05.98,0:21:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tenaganya gede banget.
Dialogue: 0,0:21:11.17,0:21:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujannya deras.
Dialogue: 0,0:21:14.04,0:21:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga Keiji baik-baik saja.
Dialogue: 0,0:21:19.63,0:21:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Getaran apa ini?
Dialogue: 0,0:21:22.84,0:21:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana asalnya?
Dialogue: 0,0:21:24.26,0:21:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan bahaya dari getaran ini.
Dialogue: 0,0:21:33.59,0:21:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin...\NIni gawat!
Dialogue: 0,0:21:40.99,0:21:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wa-Waduknya...
Dialogue: 0,0:21:43.43,0:21:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduk raksasanya akan jebol!
Dialogue: 0,0:21:46.99,0:21:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:21:49.62,0:21:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau air waduknya masuk,
Dialogue: 0,0:21:53.46,0:21:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kota yang dikelilingi gunung ini
Dialogue: 0,0:21:55.92,0:21:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan tenggelam sepenuhnya!
Dialogue: 0,0:23:40.43,0:23:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Morio,
Dialogue: 0,0:23:41.90,0:23:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sahabatnya Keiji.
Dialogue: 0,0:23:44.03,0:23:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus...
Dialogue: 0,0:23:45.74,0:23:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, cepat lari!
Dialogue: 0,0:23:48.66,0:23:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Istana Sayap Burung".
Dialogue: 0,0:23:51.33,0:23:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, aku tidak akan pernah melupakanmu.
