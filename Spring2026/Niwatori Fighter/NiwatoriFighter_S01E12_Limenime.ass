Dialogue: 0,0:05:08.88,0:05:11.96,sign,,0000,0000,0000,,EPISODE DUA BELAS: AYAM SEMESTA
Dialogue: 0,0:10:17.39,0:10:20.04,sign,,0000,0000,0000,,UPACARA MASUK SEKOLAH
Dialogue: 0,0:23:42.15,0:23:44.78,sign,,0000,0000,0000,,TAMAT
Dialogue: 0,0:23:54.75,0:24:01.29,sign,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:03.02,0:00:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, sudah dua menit berlalu.
Dialogue: 0,0:00:05.90,0:00:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu lama.
Dialogue: 0,0:00:07.75,0:00:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sophia, lengan petir!
Dialogue: 0,0:00:09.81,0:00:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:00:15.79,0:00:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau rawanya disetrum,
Dialogue: 0,0:00:18.58,0:00:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}iblis itu pasti keluar.
Dialogue: 0,0:00:20.71,0:00:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ayahnya Keisuke
Dialogue: 0,0:00:23.01,0:00:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam kondisi lemah.
Dialogue: 0,0:00:25.00,0:00:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya dia tidak kuat.
Dialogue: 0,0:00:28.91,0:00:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh,
Dialogue: 0,0:00:29.88,0:00:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus bagaimana?
Dialogue: 0,0:00:33.30,0:00:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keras kepala sekali.
Dialogue: 0,0:00:36.00,0:00:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi sana, Ayam Bodoh!
Dialogue: 0,0:00:40.60,0:00:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu lagi!
Dialogue: 0,0:00:42.61,0:00:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap begini, dia bisa mati!
Dialogue: 0,0:00:45.11,0:00:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba dulu!
Dialogue: 0,0:00:50.11,0:00:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:00:52.41,0:00:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:00:58.33,0:01:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, dia tidak bernapas!
Dialogue: 0,0:01:00.25,0:01:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mati!
Dialogue: 0,0:01:02.38,0:01:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahnya Keisuke, jangan mati!
Dialogue: 0,0:01:06.00,0:01:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke menunggumu!\NTolong bertahanlah!
Dialogue: 0,0:01:10.13,0:01:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, bertahanlah!
Dialogue: 0,0:01:20.03,0:01:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu Kakak juga punya telur mulia.
Dialogue: 0,0:01:24.11,0:01:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya hancur serangannya
Dialogue: 0,0:01:26.23,0:01:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah pasti dari telur mulia.
Dialogue: 0,0:01:28.99,0:01:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, ini kebangkitan keduanya?
Dialogue: 0,0:01:32.74,0:01:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, rasanya berbeda denganku.
Dialogue: 0,0:01:35.78,0:01:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan kegelapan
Dialogue: 0,0:01:37.99,0:01:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari aura merah kehitaman itu.
Dialogue: 0,0:01:40.64,0:01:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:01:42.28,0:01:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pakai kekuatan telur mulia itu!
Dialogue: 0,0:01:45.00,0:01:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya kamu tidak bisa kembali lagi!
Dialogue: 0,0:01:51.19,0:01:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang anak baik.
Dialogue: 0,0:01:53.80,0:01:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah yang kutunggu.
Dialogue: 0,0:01:55.93,0:01:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebangkitan malapetaka.
Dialogue: 0,0:01:58.32,0:02:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, tunjukkan padaku.
Dialogue: 0,0:02:01.72,0:02:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang dibalut kebencian itu!
Dialogue: 0,0:02:05.06,0:02:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akui ada perubahan.
Dialogue: 0,0:02:08.90,0:02:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu cuma Goshikidori.
Dialogue: 0,0:02:10.82,0:02:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bangkit ribuan kali pun\Ntetap saja lemah.
Dialogue: 0,0:02:14.99,0:02:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukan tandinganku.
Dialogue: 0,0:02:17.83,0:02:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menyentuh jari kakiku saja\Nsudah bag—
Dialogue: 0,0:02:26.25,0:02:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu cepat.
Dialogue: 0,0:02:28.88,0:02:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok jago,
Dialogue: 0,0:02:30.92,0:02:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dasar ayam!
Dialogue: 0,0:02:33.05,0:02:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meremehkanku!
Dialogue: 0,0:02:50.98,0:02:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok jago!
Dialogue: 0,0:02:52.94,0:02:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku kalah\Ndari kalian para Goshikidori!
Dialogue: 0,0:02:59.57,0:03:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati, mati, matilah!
Dialogue: 0,0:03:02.20,0:03:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya kami harus\Nmenghancurkan bola itu!
Dialogue: 0,0:03:06.25,0:03:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:03:09.34,0:03:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbesar! Alihkan!
Dialogue: 0,0:03:11.09,0:03:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang
Dialogue: 0,0:03:14.42,0:03:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghancur Super!
Dialogue: 0,0:03:16.68,0:03:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurlah!
Dialogue: 0,0:03:20.56,0:03:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, keras sekali!
Dialogue: 0,0:03:27.44,0:03:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian
Dialogue: 0,0:03:29.27,0:03:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kujadikan ayam cincang!
Dialogue: 0,0:03:35.87,0:03:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:03:38.45,0:03:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah!
Dialogue: 0,0:03:41.28,0:03:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk
Dialogue: 0,0:03:42.66,0:03:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Super!
Dialogue: 0,0:03:52.30,0:03:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku makhluk terpilih!
Dialogue: 0,0:03:54.80,0:03:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin kalah olehmu!
Dialogue: 0,0:03:57.59,0:04:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:04:04.47,0:04:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:05.98,0:04:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolanya tidak hancur
Dialogue: 0,0:04:08.77,0:04:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan malah meregenerasi tubuhnya!
Dialogue: 0,0:04:11.73,0:04:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, dia tangguh sekali!
Dialogue: 0,0:04:14.81,0:04:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:04:16.32,0:04:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaga Kakak melemah.
Dialogue: 0,0:04:18.35,0:04:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah akhirnya?
Dialogue: 0,0:04:20.99,0:04:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:04:28.25,0:04:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh kekuatannya
Dialogue: 0,0:04:30.75,0:04:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipusatkan ke bola itu!
Dialogue: 0,0:05:03.85,0:05:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berakhir sudah, Ayah.
Dialogue: 0,0:05:08.88,0:05:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ayam Semesta".
Dialogue: 0,0:05:27.97,0:05:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak baik-baik saja?
Dialogue: 0,0:05:32.60,0:05:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, sih, sepele.
Dialogue: 0,0:05:35.59,0:05:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi luar biasa itu
Dialogue: 0,0:05:38.40,0:05:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terasa gelap dan dahsyat.
Dialogue: 0,0:05:40.32,0:05:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur mulia yang bangkit\Ntidak bisa kembali ke semula.
Dialogue: 0,0:05:44.03,0:05:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebangkitan itu berbahaya.
Dialogue: 0,0:05:46.66,0:05:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari nanti,
Dialogue: 0,0:05:48.91,0:05:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin saja kewarasan Kakak\Nakan ditelan kegelapan.
Dialogue: 0,0:05:54.46,0:05:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan itu terjadi!
Dialogue: 0,0:05:57.71,0:06:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam!
Dialogue: 0,0:06:02.22,0:06:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merindukanmu!
Dialogue: 0,0:06:05.44,0:06:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, lukamu parah banget!
Dialogue: 0,0:06:07.97,0:06:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam baik-baik saja?
Dialogue: 0,0:06:10.37,0:06:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:06:11.69,0:06:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:06:13.35,0:06:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu, tidak?
Dialogue: 0,0:06:15.05,0:06:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak ingat,
Dialogue: 0,0:06:16.94,0:06:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku membasmi parasit\Ndi dalam kepala Morio!
Dialogue: 0,0:06:20.48,0:06:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil!
Dialogue: 0,0:06:24.25,0:06:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu tidak memujiku?
Dialogue: 0,0:06:26.85,0:06:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, mana Morio?
Dialogue: 0,0:06:30.00,0:06:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko.
Dialogue: 0,0:06:33.81,0:06:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio sudah mati.
Dialogue: 0,0:06:37.79,0:06:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:44.04,0:06:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:06:45.55,0:06:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak mungkin!
Dialogue: 0,0:06:54.24,0:06:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio...
Dialogue: 0,0:06:55.52,0:06:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal baru kutolong,
Dialogue: 0,0:06:58.65,0:07:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kok kamu malah mati?
Dialogue: 0,0:07:02.53,0:07:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak terima!
Dialogue: 0,0:07:04.53,0:07:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mati!
Dialogue: 0,0:07:09.07,0:07:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bangun!
Dialogue: 0,0:07:12.29,0:07:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio!
Dialogue: 0,0:07:14.58,0:07:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:07:16.87,0:07:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...masih hidup?
Dialogue: 0,0:07:22.44,0:07:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio jadi zombi!
Dialogue: 0,0:07:26.18,0:07:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio?
Dialogue: 0,0:07:33.97,0:07:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aduh.
Dialogue: 0,0:07:40.32,0:07:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku masih hidup.
Dialogue: 0,0:07:44.94,0:07:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:07:46.71,0:07:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih hidup!
Dialogue: 0,0:07:52.92,0:07:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu benaran Morio?
Dialogue: 0,0:07:56.08,0:07:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Keiji!
Dialogue: 0,0:07:57.54,0:07:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana bisa.
Dialogue: 0,0:07:59.67,0:08:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma terus berharap bisa hidup
Dialogue: 0,0:08:02.04,0:08:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ternyata terkabul!
Dialogue: 0,0:08:04.67,0:08:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya daya hidupku sangat tinggi.
Dialogue: 0,0:08:10.99,0:08:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar di luar nalar.
Dialogue: 0,0:08:13.99,0:08:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio hebat!
Dialogue: 0,0:08:17.94,0:08:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Morio! Morio!\N- E-Elizabeth?
Dialogue: 0,0:08:22.44,0:08:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku...
Dialogue: 0,0:08:24.31,0:08:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, dia hidup\Ndan mungkin akan segera sadar.
Dialogue: 0,0:08:28.49,0:08:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih!
Dialogue: 0,0:08:30.99,0:08:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Biar aku yang menggendongnya.
Dialogue: 0,0:08:36.00,0:08:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:08:42.71,0:08:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benaran menang, ya.
Dialogue: 0,0:08:45.27,0:08:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:08:47.92,0:08:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka,\Nkebangkitanmu sekuat itu.
Dialogue: 0,0:08:53.56,0:08:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan merahasiakan dulu\Nsoal kebangkitan Kakak.
Dialogue: 0,0:08:57.43,0:08:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu.
Dialogue: 0,0:08:59.27,0:09:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi akan segera datang\Nkarena keributan ini.
Dialogue: 0,0:09:04.75,0:09:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi dari sini.
Dialogue: 0,0:09:07.20,0:09:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Betul juga.
Dialogue: 0,0:09:08.82,0:09:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bergegas.
Dialogue: 0,0:09:10.12,0:09:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:09:18.56,0:09:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:09:26.73,0:09:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar keras kepala!
Dialogue: 0,0:09:28.71,0:09:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini...
Dialogue: 0,0:09:29.97,0:09:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Kak!
Dialogue: 0,0:09:31.59,0:09:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat aneh.
Dialogue: 0,0:09:34.29,0:09:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa niat membunuh.
Dialogue: 0,0:09:37.28,0:09:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari.
Dialogue: 0,0:09:39.49,0:09:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari.
Dialogue: 0,0:09:41.77,0:09:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari.
Dialogue: 0,0:09:47.23,0:09:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari.
Dialogue: 0,0:09:53.15,0:09:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari-ku tersayang.
Dialogue: 0,0:09:56.36,0:09:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta berhargaku.
Dialogue: 0,0:10:00.84,0:10:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:10:02.08,0:10:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:10:03.59,0:10:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu sedang apa?
Dialogue: 0,0:10:04.75,0:10:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menata album foto.
Dialogue: 0,0:10:06.29,0:10:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku baru lihat yang ini.
Dialogue: 0,0:10:08.67,0:10:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posenya mirip semua, ya.
Dialogue: 0,0:10:10.55,0:10:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking gemasnya, aku selalu\Nmenempel ke wajahmu tiap difoto.
Dialogue: 0,0:10:14.76,0:10:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja aku tampak agak risi.
Dialogue: 0,0:10:17.39,0:10:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dulu sempat khawatir
Dialogue: 0,0:10:20.04,0:10:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan banyak yang menentang,\Nakhirnya kamu tumbuh sebesar ini.
Dialogue: 0,0:10:24.69,0:10:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bersyukur.
Dialogue: 0,0:10:26.88,0:10:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumbuh tanpa ayah pasti berat bagimu.
Dialogue: 0,0:10:32.21,0:10:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:10:33.15,0:10:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak apa-apa,\Nlagi pula aku punya Ibu.
Dialogue: 0,0:10:37.75,0:10:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, sudah jam enam.
Dialogue: 0,0:10:39.36,0:10:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus pergi bekerja.
Dialogue: 0,0:10:41.54,0:10:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari, maaf.
Dialogue: 0,0:10:43.20,0:10:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lauk makan malamnya ada di panci.
Dialogue: 0,0:10:45.79,0:10:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, nanti kamu kelelahan.
Dialogue: 0,0:10:48.54,0:10:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjanya tidak bisa siang saja?
Dialogue: 0,0:10:55.45,0:11:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu ingin kamu kuliah\Ndan jadi orang sukses.
Dialogue: 0,0:11:01.33,0:11:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya Ibu harus kerja keras.
Dialogue: 0,0:11:04.81,0:11:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan giat belajar
Dialogue: 0,0:11:08.97,0:11:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar nanti Ibu bisa hidup nyaman.
Dialogue: 0,0:11:14.61,0:11:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari, aku jadi terharu.
Dialogue: 0,0:11:17.87,0:11:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hentikan, bikin malu saja.
Dialogue: 0,0:11:22.39,0:11:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat, ya.
Dialogue: 0,0:11:23.91,0:11:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, selamat jalan.
Dialogue: 0,0:11:31.97,0:11:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, ini Yoshino.
Dialogue: 0,0:11:33.63,0:11:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dari kepolisian Akamori.
Dialogue: 0,0:11:35.97,0:11:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Yoshino Kimiko\Nmengalami kecelakaan lalu lintas.
Dialogue: 0,0:11:39.05,0:11:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:40.56,0:11:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo? Halo?
Dialogue: 0,0:12:11.73,0:12:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu...
Dialogue: 0,0:12:19.71,0:12:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:12:27.75,0:12:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:30.71,0:12:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mati?
Dialogue: 0,0:12:35.05,0:12:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:12:36.13,0:12:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku kenapa?
Dialogue: 0,0:12:53.75,0:12:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana para Goshikidori?
Dialogue: 0,0:13:04.72,0:13:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat.
Dialogue: 0,0:13:09.17,0:13:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup!
Dialogue: 0,0:13:11.61,0:13:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari.
Dialogue: 0,0:13:14.19,0:13:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah aman, Hikari.
Dialogue: 0,0:13:17.44,0:13:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?
Dialogue: 0,0:13:22.05,0:13:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu.
Dialogue: 0,0:13:24.00,0:13:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu menderita lagi.
Dialogue: 0,0:13:39.47,0:13:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:44.26,0:13:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang terima kasih?
Dialogue: 0,0:13:47.47,0:13:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa dia juga korban cuci otak?
Dialogue: 0,0:13:53.33,0:13:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu helikopter polisi.
Dialogue: 0,0:13:54.65,0:13:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pergi!
Dialogue: 0,0:13:56.90,0:13:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio?
Dialogue: 0,0:13:58.48,0:14:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia masih hidup
Dialogue: 0,0:14:00.82,0:14:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sudah tidak jahat.
Dialogue: 0,0:14:02.61,0:14:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bawa dia.
Dialogue: 0,0:14:04.16,0:14:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu gila, ya?
Dialogue: 0,0:14:06.11,0:14:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Keiji.
Dialogue: 0,0:14:07.40,0:14:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia tahu rahasia soal demon.
Dialogue: 0,0:14:10.12,0:14:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bawa dia.
Dialogue: 0,0:14:12.54,0:14:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah!
Dialogue: 0,0:14:16.75,0:14:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan yang hebat.
Dialogue: 0,0:14:19.93,0:14:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur muliamu masih punya potensi besar.
Dialogue: 0,0:14:25.80,0:14:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, beliau pasti senang.
Dialogue: 0,0:15:03.55,0:15:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, bangun!
Dialogue: 0,0:15:04.72,0:15:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu sudah bangun!
Dialogue: 0,0:15:08.55,0:15:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lengah.
Dialogue: 0,0:15:09.85,0:15:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:15:11.31,0:15:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku sudah jahat pada kalian.
Dialogue: 0,0:15:16.19,0:15:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh minta maaf.
Dialogue: 0,0:15:21.69,0:15:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu cuma dicuci otak, kan?
Dialogue: 0,0:15:24.60,0:15:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pelakunya?
Dialogue: 0,0:15:29.76,0:15:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita bernama Kugone.
Dialogue: 0,0:15:32.53,0:15:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu siapa?
Dialogue: 0,0:15:42.32,0:15:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata anak ini
Dialogue: 0,0:15:44.51,0:15:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kandidat yang cocok.
Dialogue: 0,0:15:48.73,0:15:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu.
Dialogue: 0,0:15:50.80,0:15:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku.
Dialogue: 0,0:15:52.51,0:15:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari.
Dialogue: 0,0:15:54.39,0:15:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji akan membahagiakanmu.
Dialogue: 0,0:15:58.94,0:16:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa cinta pada ibu mengubahnya jadi iblis.
Dialogue: 0,0:16:04.93,0:16:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan itu akan sulit dihapus.
Dialogue: 0,0:16:09.82,0:16:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang harus ditaklukkan bukan tubuhmu,
Dialogue: 0,0:16:14.20,0:16:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hatimu.
Dialogue: 0,0:16:21.79,0:16:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi mamamu.
Dialogue: 0,0:16:26.03,0:16:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukan ibuku.
Dialogue: 0,0:16:33.81,0:16:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa sakitnya tidak akan berhenti
Dialogue: 0,0:16:36.27,0:16:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai cinta pada ibumu hilang.
Dialogue: 0,0:16:38.77,0:16:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak waktu.
Dialogue: 0,0:16:42.86,0:16:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku disiksa selama sebulan lebih.
Dialogue: 0,0:16:47.11,0:16:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:16:49.32,0:16:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisimu, Hikari?
Dialogue: 0,0:16:52.71,0:16:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat baik, Mama.
Dialogue: 0,0:16:56.99,0:16:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari-ku tersayang.
Dialogue: 0,0:16:58.83,0:17:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada ikatan keluarga\Nyang melebihi ikatan kita.
Dialogue: 0,0:17:03.71,0:17:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, Mama.
Dialogue: 0,0:17:06.58,0:17:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikatan sejati, kan?
Dialogue: 0,0:17:10.06,0:17:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu, Hikari.
Dialogue: 0,0:17:12.72,0:17:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu, Mama.
Dialogue: 0,0:17:16.76,0:17:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu jahat sekali.
Dialogue: 0,0:17:19.64,0:17:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat keji!
Dialogue: 0,0:17:20.48,0:17:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak bisa dimaafkan.
Dialogue: 0,0:17:23.85,0:17:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kugone menciptakan demon\Ndi berbagai tempat.
Dialogue: 0,0:17:26.90,0:17:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menguasai dunia?
Dialogue: 0,0:17:29.65,0:17:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, makanya Goshikidori\Ndianggap pengganggu.
Dialogue: 0,0:17:34.07,0:17:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:17:35.26,0:17:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya Kugone mengincar telur muliamu.
Dialogue: 0,0:17:38.93,0:17:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur muliaku?
Dialogue: 0,0:17:40.66,0:17:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melarangku membunuhmu.
Dialogue: 0,0:17:43.00,0:17:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:17:44.96,0:17:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata itu kekuatan telur mulia.
Dialogue: 0,0:17:48.01,0:17:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu bosnya?
Dialogue: 0,0:17:50.80,0:17:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kugone orang nomor dua.
Dialogue: 0,0:17:56.21,0:17:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Gakuma.
Dialogue: 0,0:17:58.08,0:18:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya Keiji meraih\Nkebangkitan malapetaka.
Dialogue: 0,0:18:04.86,0:18:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:07.60,0:18:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, saatnya bergerak.
Dialogue: 0,0:18:11.11,0:18:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap laksanakan.
Dialogue: 0,0:18:16.45,0:18:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rencana kalian ke depannya?
Dialogue: 0,0:18:19.79,0:18:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:18:21.25,0:18:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah menghancurkan kota itu.
Dialogue: 0,0:18:24.59,0:18:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masih ada beberapa iblis\Nyang patuh padaku,
Dialogue: 0,0:18:28.55,0:18:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami akan membantu memperbaiki kotanya.
Dialogue: 0,0:18:31.01,0:18:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin?
Dialogue: 0,0:18:33.30,0:18:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak ada korban jiwa,\Nwarga tetap marah besar.
Dialogue: 0,0:18:37.05,0:18:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamu pun cuma korban, kan?
Dialogue: 0,0:18:40.52,0:18:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja aku bertanggung jawab.
Dialogue: 0,0:18:45.05,0:18:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap menebusnya.
Dialogue: 0,0:18:48.60,0:18:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Morio tidak ada.
Dialogue: 0,0:18:50.86,0:18:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak kuat berpisah sama kalian,
Dialogue: 0,0:18:54.40,0:18:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pergi duluan.
Dialogue: 0,0:18:55.98,0:18:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:57.19,0:19:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, Morio jahat.
Dialogue: 0,0:19:00.70,0:19:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bahkan belum pamitan.
Dialogue: 0,0:19:05.60,0:19:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah dia.
Dialogue: 0,0:19:07.54,0:19:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, nanti juga kita berjumpa lagi.
Dialogue: 0,0:19:10.55,0:19:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ketemu akan kuhajar!
Dialogue: 0,0:19:13.41,0:19:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, jaga diri kalian.
Dialogue: 0,0:19:15.75,0:19:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kalian juga.
Dialogue: 0,0:19:17.43,0:19:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:19:18.84,0:19:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah!
Dialogue: 0,0:19:29.84,0:19:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, anak ayam, semuanya...
Dialogue: 0,0:19:41.41,0:19:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:19:42.37,0:19:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya musuh kita sama.
Dialogue: 0,0:19:45.65,0:19:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:47.12,0:19:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ciri-ciri bosmu?
Dialogue: 0,0:19:49.84,0:19:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya dia berwujud manusia.
Dialogue: 0,0:19:53.01,0:19:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau jadi iblis,
Dialogue: 0,0:19:55.88,0:19:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin dia jauh lebih kuat dari kalian.
Dialogue: 0,0:19:58.89,0:20:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana dia sekarang?
Dialogue: 0,0:20:00.91,0:20:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu.
Dialogue: 0,0:20:02.93,0:20:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia pernah muncul sekali\Ndi depan umum.
Dialogue: 0,0:20:06.69,0:20:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan videonya viral.
Dialogue: 0,0:20:08.77,0:20:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siapa namanya?
Dialogue: 0,0:20:11.29,0:20:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang menyebutnya,
Dialogue: 0,0:20:13.82,0:20:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis Putih.
Dialogue: 0,0:20:15.61,0:20:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah julukannya.
Dialogue: 0,0:20:19.67,0:20:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis Putih.
Dialogue: 0,0:20:21.78,0:20:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kita memang terikat takdir.
Dialogue: 0,0:20:26.91,0:20:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kolamnya besar sekali!
Dialogue: 0,0:20:34.87,0:20:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, Sara.
Dialogue: 0,0:20:38.24,0:20:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocil itu saja bisa kembali.
Dialogue: 0,0:20:42.23,0:20:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sara, aku akan membawamu pulang!
Dialogue: 0,0:20:59.69,0:21:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
