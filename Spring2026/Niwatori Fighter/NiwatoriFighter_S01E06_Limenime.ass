Dialogue: 0,0:01:45.34,0:01:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana para ayam itu?
Dialogue: 0,0:01:48.75,0:01:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil mereka pergi jauh\Ndi hujan selebat ini.
Dialogue: 0,0:01:53.53,0:01:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menemukan
Dialogue: 0,0:01:55.30,0:01:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuat video mereka viral lagi!
Dialogue: 0,0:01:57.72,0:02:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku akan sukses jadi viewtuber!
Dialogue: 0,0:02:01.77,0:02:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku wajib sukses!
Dialogue: 0,0:02:04.56,0:02:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:02:06.15,0:02:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan lupa penghinaan itu.
Dialogue: 0,0:02:14.01,0:02:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, Ibokura!
Dialogue: 0,0:02:16.79,0:02:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Bagian marah, tahu!
Dialogue: 0,0:02:18.66,0:02:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin laporan saja kamu tidak becus?
Dialogue: 0,0:02:20.72,0:02:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang mau baca ini coba?
Dialogue: 0,0:02:24.37,0:02:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah memperbaikinya,
Dialogue: 0,0:02:26.65,0:02:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}minimal berterima kasih, lah!
Dialogue: 0,0:02:28.51,0:02:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak minta kalian melakukannya,
Dialogue: 0,0:02:32.89,0:02:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}buat apa berterima kasih?
Dialogue: 0,0:02:34.88,0:02:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:02:35.74,0:02:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:02:37.50,0:02:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bercanda, kok.
Dialogue: 0,0:02:38.97,0:02:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, sudahlah.
Dialogue: 0,0:02:41.52,0:02:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang tidak tahu terima kasih.
Dialogue: 0,0:02:45.75,0:02:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kerjanya payah,\Nharga dirinya setinggi langit.
Dialogue: 0,0:02:49.27,0:02:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, jauhi saja hama itu.
Dialogue: 0,0:02:51.90,0:02:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga dia cepat berhenti.
Dialogue: 0,0:02:53.82,0:02:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia ampas.
Dialogue: 0,0:02:54.72,0:02:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaji buta.
Dialogue: 0,0:02:55.78,0:02:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:02:57.87,0:03:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak akan kumaafkan!
Dialogue: 0,0:03:04.19,0:03:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus sukses jadi viewtuber
Dialogue: 0,0:03:07.03,0:03:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membalas para sampah itu!
Dialogue: 0,0:03:10.74,0:03:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya ayam-ayam itu harus kutemukan!
Dialogue: 0,0:03:15.34,0:03:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam!
Dialogue: 0,0:03:19.39,0:03:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Istana Sayap Burung".
Dialogue: 0,0:03:34.43,0:03:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat.
Dialogue: 0,0:03:51.58,0:03:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek baik-baik saja?
Dialogue: 0,0:03:53.68,0:03:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sudah lumayan tenang.
Dialogue: 0,0:03:57.25,0:04:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam apa kabar, ya?
Dialogue: 0,0:04:00.69,0:04:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir.
Dialogue: 0,0:04:04.77,0:04:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau bertualang sendirian.
Dialogue: 0,0:04:07.95,0:04:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar pergi sendirian?
Dialogue: 0,0:04:10.77,0:04:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:04:12.57,0:04:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap tenang dan dengarkan.
Dialogue: 0,0:04:13.95,0:04:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:04:14.67,0:04:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:15.36,0:04:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:16.14,0:04:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kantor prefektur mengabari
Dialogue: 0,0:04:18.52,0:04:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena curah hujan\Nsejak semalam melebihi 100 cm,
Dialogue: 0,0:04:21.79,0:04:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendungan Kurome mungkin akan jebol.
Dialogue: 0,0:04:24.40,0:04:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:27.68,0:04:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya apa?
Dialogue: 0,0:04:29.37,0:04:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seisi kota akan terendam air!
Dialogue: 0,0:04:31.41,0:04:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:32.50,0:04:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Masa?\NBendungannya besar, lo!
Dialogue: 0,0:04:35.73,0:04:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku baru ingat.
Dialogue: 0,0:04:37.29,0:04:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempat ramai rumor
Dialogue: 0,0:04:38.79,0:04:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa bendungannya dibangun asal-asalan.
Dialogue: 0,0:04:41.76,0:04:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kontraktor bedebah!
Dialogue: 0,0:04:43.99,0:04:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kami harus apa?
Dialogue: 0,0:04:45.74,0:04:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kantor prefektur minta kita tetap di sini.
Dialogue: 0,0:04:48.39,0:04:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:04:49.55,0:04:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau waduknya tumpah,\Nkota ini akan tenggelam!
Dialogue: 0,0:04:52.75,0:04:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus cepat pergi.
Dialogue: 0,0:04:54.27,0:04:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujan di luar masih lebat!\NSungainya juga meluap!
Dialogue: 0,0:04:57.40,0:04:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil pergi dari kota ini!
Dialogue: 0,0:04:59.46,0:05:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang apa?
Dialogue: 0,0:05:00.99,0:05:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari rute ke bendungan.
Dialogue: 0,0:05:02.91,0:05:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada solusi kalau ke sana langsung.
Dialogue: 0,0:05:07.84,0:05:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:05:10.75,0:05:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ikut!
Dialogue: 0,0:05:16.13,0:05:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ada di mana, sih?
Dialogue: 0,0:05:21.68,0:05:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ayamnya!
Dialogue: 0,0:05:23.54,0:05:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, yang jantan tidak ada.
Dialogue: 0,0:05:26.38,0:05:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, percuma saja mengeluh.
Dialogue: 0,0:05:29.18,0:05:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting, buntuti dulu!
Dialogue: 0,0:05:34.19,0:05:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendungannya akan jebol!
Dialogue: 0,0:05:35.68,0:05:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kami harus ke mana?
Dialogue: 0,0:05:38.86,0:05:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, mau ke mana mereka?
Dialogue: 0,0:05:42.28,0:05:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendungannya terlihat!
Dialogue: 0,0:05:46.43,0:05:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, iblis?
Dialogue: 0,0:05:53.04,0:05:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis itu sedang apa?
Dialogue: 0,0:05:55.59,0:05:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti!
Dialogue: 0,0:06:01.06,0:06:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth dan Piyoko menghilang.
Dialogue: 0,0:06:03.68,0:06:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, lihat ini!
Dialogue: 0,0:06:06.22,0:06:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis itu menghancurkan bendungannya!
Dialogue: 0,0:06:08.78,0:06:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Serius?
Dialogue: 0,0:06:10.23,0:06:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain banjir, malah muncul iblis!
Dialogue: 0,0:06:12.62,0:06:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambungkan ke TV!
Dialogue: 0,0:06:14.06,0:06:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis itu semacam monster raksasa, kan?
Dialogue: 0,0:06:19.71,0:06:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersambung!
Dialogue: 0,0:06:21.11,0:06:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar iblis!
Dialogue: 0,0:06:22.14,0:06:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:06:23.63,0:06:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamatlah kita.
Dialogue: 0,0:06:24.93,0:06:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, lihat baik-baik!
Dialogue: 0,0:06:26.62,0:06:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya iblis itu menahan bendungannya!
Dialogue: 0,0:06:29.80,0:06:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:30.53,0:06:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:06:31.62,0:06:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benaran!
Dialogue: 0,0:06:33.26,0:06:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis itu menahan bendungannya!
Dialogue: 0,0:06:35.17,0:06:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:38.50,0:06:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah...
Dialogue: 0,0:06:39.71,0:06:41.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berjuanglah, Iblis!\N- Kumohon!
Dialogue: 0,0:06:41.42,0:06:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berjuanglah, Iblis!\N- Berjuanglah!
Dialogue: 0,0:06:42.63,0:06:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah!
Dialogue: 0,0:06:45.64,0:06:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:46.64,0:06:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth dan Piyoko?
Dialogue: 0,0:06:48.76,0:06:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka di situ?
Dialogue: 0,0:06:54.77,0:06:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!\NPenontonnya naik drastis!
Dialogue: 0,0:07:02.53,0:07:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan?
Dialogue: 0,0:07:04.90,0:07:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini berbahaya!
Dialogue: 0,0:07:06.24,0:07:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari!
Dialogue: 0,0:07:07.91,0:07:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu iblis, kan?
Dialogue: 0,0:07:10.12,0:07:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa melakukan ini?
Dialogue: 0,0:07:12.70,0:07:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku ingin menolong warga kota.
Dialogue: 0,0:07:17.50,0:07:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menolong manusia?
Dialogue: 0,0:07:26.09,0:07:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruslah hidup.
Dialogue: 0,0:07:28.38,0:07:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu saat kamu pasti menemukan arti hidupmu.
Dialogue: 0,0:07:32.32,0:07:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, aku menemukannya.
Dialogue: 0,0:07:35.61,0:07:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini, aku ingin berguna\Nbagi orang lain.
Dialogue: 0,0:07:39.73,0:07:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku menyadari itu.
Dialogue: 0,0:07:43.32,0:07:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, sekarang aku bisa\Nmengatakannya dengan bangga.
Dialogue: 0,0:07:47.25,0:07:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Inilah...
Dialogue: 0,0:07:49.09,0:07:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah alasanku dilahirkan!
Dialogue: 0,0:07:53.45,0:07:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berkorban\Ndemi menahan bendungan ini!
Dialogue: 0,0:07:56.54,0:07:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua, cepat lari!
Dialogue: 0,0:07:59.23,0:08:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia iblis yang baik.
Dialogue: 0,0:08:01.88,0:08:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma pernah lihat di internet.
Dialogue: 0,0:08:04.32,0:08:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, iblis sepertinya benar-benar ada.
Dialogue: 0,0:08:08.18,0:08:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah,\Naku ingin memusnahkan semua iblis.
Dialogue: 0,0:08:12.63,0:08:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa selama ini, aku salah?
Dialogue: 0,0:08:16.30,0:08:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth!
Dialogue: 0,0:08:17.56,0:08:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat itu!
Dialogue: 0,0:08:19.06,0:08:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia?\NSedang apa dia di sini?
Dialogue: 0,0:08:22.38,0:08:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:08:24.69,0:08:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia
Dialogue: 0,0:08:26.57,0:08:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berbuat sejauh ini demi menolong manusia?
Dialogue: 0,0:08:29.94,0:08:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sampai mengorbankan nyawa.
Dialogue: 0,0:08:33.73,0:08:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan pernah...
Dialogue: 0,0:08:36.95,0:08:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama.
Dialogue: 0,0:08:38.79,0:08:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau jadi pengacara.
Dialogue: 0,0:08:41.02,0:08:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menolong\Norang-orang yang kesusahan.
Dialogue: 0,0:08:48.44,0:08:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak lulus karena Mama.
Dialogue: 0,0:08:51.52,0:08:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini salah Mama!
Dialogue: 0,0:08:54.70,0:08:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sadar, aku mulai menyalahkan\Norang lain atas apa pun.
Dialogue: 0,0:09:00.10,0:09:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya aku sadar.
Dialogue: 0,0:09:02.72,0:09:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya adalah salahku.
Dialogue: 0,0:09:06.15,0:09:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma tidak mau mengakuinya.
Dialogue: 0,0:09:29.81,0:09:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak...\NMama, aku tidak mau...
Dialogue: 0,0:09:33.30,0:09:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau mati.
Dialogue: 0,0:09:35.76,0:09:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau mati!
Dialogue: 0,0:09:51.40,0:09:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji?
Dialogue: 0,0:09:56.41,0:09:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Ayam!
Dialogue: 0,0:09:57.97,0:09:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:10:03.41,0:10:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam itu menolongku?
Dialogue: 0,0:10:06.13,0:10:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:10:07.30,0:10:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga khawatir pada bendungannya?
Dialogue: 0,0:10:11.98,0:10:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka kamu yang menahannya, Morio.
Dialogue: 0,0:10:16.01,0:10:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah, Keiji.
Dialogue: 0,0:10:17.89,0:10:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang menolong warga kota.
Dialogue: 0,0:10:21.33,0:10:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya hidupku berarti!
Dialogue: 0,0:10:24.65,0:10:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:25.82,0:10:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sudah banyak korban jiwa\Nkalau tidak ada kamu.
Dialogue: 0,0:10:29.53,0:10:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu adalah pahlawan sejati.
Dialogue: 0,0:10:32.67,0:10:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pahlawan?
Dialogue: 0,0:10:36.78,0:10:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak pantas disebut begitu.
Dialogue: 0,0:10:41.39,0:10:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin berguna bagi orang lain.
Dialogue: 0,0:10:47.10,0:10:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah sifatmu.
Dialogue: 0,0:10:57.90,0:11:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak kuat!
Dialogue: 0,0:11:03.48,0:11:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio!
Dialogue: 0,0:11:09.48,0:11:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio...
Dialogue: 0,0:11:12.28,0:11:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:11:13.36,0:11:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth, ikut aku!
Dialogue: 0,0:11:16.34,0:11:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pergilah ke tempat aman!
Dialogue: 0,0:11:18.39,0:11:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:11:19.80,0:11:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghentikan banjirnya!
Dialogue: 0,0:11:21.59,0:11:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:33.85,0:11:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendungannya benar-benar jebol.
Dialogue: 0,0:11:38.51,0:11:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin...
Dialogue: 0,0:11:39.72,0:11:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Astaga...
Dialogue: 0,0:11:41.14,0:11:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sayang...
Dialogue: 0,0:11:42.35,0:11:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berserah diri.
Dialogue: 0,0:11:44.35,0:11:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa, aku takut.
Dialogue: 0,0:11:45.97,0:11:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak mungkin, kami semua akan mati?\N- Te-Tenang saja.
Dialogue: 0,0:11:52.28,0:11:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kabur?
Dialogue: 0,0:11:53.66,0:11:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:11:54.50,0:11:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil mereka pergi begitu saja.
Dialogue: 0,0:11:56.70,0:11:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka punya rencana.
Dialogue: 0,0:11:58.96,0:12:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengejarnya!
Dialogue: 0,0:12:05.20,0:12:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berusaha sekuat tenaga.
Dialogue: 0,0:12:08.38,0:12:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga bisa berguna bagi seseorang.
Dialogue: 0,0:12:12.96,0:12:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji.
Dialogue: 0,0:12:14.13,0:12:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dirimu aku jadi percaya diri.
Dialogue: 0,0:12:19.77,0:12:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur berjumpa denganmu.
Dialogue: 0,0:12:24.95,0:12:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Keiji.
Dialogue: 0,0:12:27.77,0:12:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh bersyukur telah terlahir.
Dialogue: 0,0:12:33.52,0:12:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh...
Dialogue: 0,0:12:42.37,0:12:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio...
Dialogue: 0,0:12:43.83,0:12:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekad yang kamu tukar dengan nyawa,
Dialogue: 0,0:12:46.69,0:12:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan aku sia-siakan!
Dialogue: 0,0:12:53.27,0:13:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:13:02.22,0:13:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, apa yang kamu lakukan?
Dialogue: 0,0:13:06.14,0:13:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:13:08.39,0:13:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayam jantan itu...
Dialogue: 0,0:13:10.52,0:13:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihatnya di viewtube.
Dialogue: 0,0:13:12.02,0:13:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!\NDia ayam yang mengalahkan iblis!
Dialogue: 0,0:13:17.41,0:13:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan,
Dialogue: 0,0:13:18.74,0:13:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia mau menghentikan banjirnya?
Dialogue: 0,0:13:20.59,0:13:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar,
Dialogue: 0,0:13:21.67,0:13:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia mencoba menolong kita!
Dialogue: 0,0:13:23.82,0:13:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berusahalah, Ayam!
Dialogue: 0,0:13:25.01,0:13:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Ayam!
Dialogue: 0,0:13:28.00,0:13:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, dia teman\NElizabeth dan Piyoko?
Dialogue: 0,0:13:36.25,0:13:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banjirnya terhalang!
Dialogue: 0,0:13:44.26,0:13:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, jangan hancur!
Dialogue: 0,0:13:54.54,0:13:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mungkin!
Dialogue: 0,0:13:55.68,0:13:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya.
Dialogue: 0,0:13:57.02,0:13:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dinding itu kurang kuat.
Dialogue: 0,0:13:59.53,0:14:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus buat yang lebih kokoh.
Dialogue: 0,0:14:02.03,0:14:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih kokoh...
Dialogue: 0,0:14:05.31,0:14:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:14:10.03,0:14:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:14:12.92,0:14:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mau membuat dinding lagi?
Dialogue: 0,0:14:14.70,0:14:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal hancur lagi!
Dialogue: 0,0:14:16.42,0:14:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotanya sudah sangat dekat!
Dialogue: 0,0:14:18.75,0:14:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gagal lagi, kotanya akan...
Dialogue: 0,0:14:20.88,0:14:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tahu!
Dialogue: 0,0:14:22.93,0:14:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu besar itu!
Dialogue: 0,0:14:24.61,0:14:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:25.55,0:14:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau batu besar itu dijatuhkan,\Njalur air akan tertutup!
Dialogue: 0,0:14:29.10,0:14:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bongkahan sebesar itu\Ntidak akan kalah oleh arus air!
Dialogue: 0,0:14:32.64,0:14:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lu-Luar biasa!\NTuan Ayam genius!
Dialogue: 0,0:14:39.38,0:14:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu rupanya!\NDia mau menjatuhkan itu!
Dialogue: 0,0:14:44.82,0:14:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu besar sekali, memangnya sempat?
Dialogue: 0,0:14:52.70,0:14:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, cepatlah!
Dialogue: 0,0:14:54.23,0:14:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banjirnya datang!
Dialogue: 0,0:15:04.55,0:15:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:15:05.41,0:15:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam!
Dialogue: 0,0:15:10.50,0:15:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji...
Dialogue: 0,0:15:11.68,0:15:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam, berjuanglah!
Dialogue: 0,0:15:15.83,0:15:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berjuanglah.
Dialogue: 0,0:15:18.31,0:15:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah, Ayam!
Dialogue: 0,0:15:19.44,0:15:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah!
Dialogue: 0,0:15:20.29,0:15:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kami, Ayam!
Dialogue: 0,0:15:22.79,0:15:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Tuan Ayam.
Dialogue: 0,0:15:25.84,0:15:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah!
Dialogue: 0,0:15:30.18,0:15:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti waktu kita pertama berjumpa.
Dialogue: 0,0:15:33.11,0:15:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menolong orang asing seperti kami.
Dialogue: 0,0:15:37.33,0:15:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah dirimu, tidak bisa\Nmembiarkan orang yang kesulitan.
Dialogue: 0,0:15:45.30,0:15:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku sadar.
Dialogue: 0,0:15:47.95,0:15:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku masih
Dialogue: 0,0:15:50.50,0:15:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencintaimu.
Dialogue: 0,0:16:08.45,0:16:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:11.58,0:16:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum selesai!
Dialogue: 0,0:16:13.49,0:16:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situ, ya!
Dialogue: 0,0:16:22.09,0:16:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:16:23.71,0:16:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam!
Dialogue: 0,0:16:29.09,0:16:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, yang benar saja!
Dialogue: 0,0:16:31.10,0:16:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin...
Dialogue: 0,0:16:38.35,0:16:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam telah...
Dialogue: 0,0:16:41.52,0:16:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat itu!
Dialogue: 0,0:16:47.24,0:16:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:17:04.05,0:17:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk Super!
Dialogue: 0,0:17:29.61,0:17:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya berhenti...
Dialogue: 0,0:17:33.20,0:17:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya bikin bendungan bobrok.
Dialogue: 0,0:17:36.79,0:17:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin jenggerku panas saja!
Dialogue: 0,0:17:44.54,0:17:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio, kita berhasil.
Dialogue: 0,0:17:47.80,0:17:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia berhasil!
Dialogue: 0,0:17:51.17,0:17:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya berhenti!
Dialogue: 0,0:17:52.53,0:17:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita selamat!
Dialogue: 0,0:17:54.93,0:17:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:17:56.34,0:17:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:56.93,0:18:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, dewa.
Dialogue: 0,0:18:00.10,0:18:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup Ayam! Hidup Ayam!
Dialogue: 0,0:18:04.14,0:18:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung kita gagal menangkapnya!
Dialogue: 0,0:18:07.22,0:18:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:18:10.56,0:18:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth, Piyoko, Tuan Ayam.
Dialogue: 0,0:18:15.02,0:18:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menolong kami.
Dialogue: 0,0:18:17.54,0:18:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi dokter yang hebat.
Dialogue: 0,0:18:21.27,0:18:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:18:22.65,0:18:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menolong banyak orang seperti kalian.
Dialogue: 0,0:18:27.10,0:18:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, para ayam.
Dialogue: 0,0:18:30.15,0:18:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misuzu, kemarilah.
Dialogue: 0,0:18:32.55,0:18:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:18:37.10,0:18:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam!
Dialogue: 0,0:18:39.35,0:18:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus!
Dialogue: 0,0:18:41.31,0:18:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cinta kamu!
Dialogue: 0,0:18:46.73,0:18:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei, Piyoko.
Dialogue: 0,0:18:48.86,0:18:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciumanmu kebanyakan.
Dialogue: 0,0:18:51.70,0:18:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kenapa?\NApa salahnya mencium suamiku sendiri?
Dialogue: 0,0:18:57.04,0:18:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suami?
Dialogue: 0,0:18:58.74,0:19:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup mengkhayalnya.
Dialogue: 0,0:19:01.97,0:19:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth...
Dialogue: 0,0:19:04.63,0:19:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jatuh cinta pada Tuan Ayam?
Dialogue: 0,0:19:07.13,0:19:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jleb!
Dialogue: 0,0:19:08.83,0:19:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin.
Dialogue: 0,0:19:11.09,0:19:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini peka banget!
Dialogue: 0,0:19:13.59,0:19:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kamu kaget, kan?
Dialogue: 0,0:19:15.78,0:19:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak wajar!
Dialogue: 0,0:19:17.97,0:19:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma perasaanmu saja.
Dialogue: 0,0:19:19.54,0:19:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong!
Dialogue: 0,0:19:20.54,0:19:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius.
Dialogue: 0,0:19:22.49,0:19:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jelas-jelas kaget!
Dialogue: 0,0:19:24.31,0:19:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:19:25.70,0:19:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:19:28.09,0:19:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama.
Dialogue: 0,0:19:30.25,0:19:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badainya parah.
Dialogue: 0,0:19:32.18,0:19:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:33.11,0:19:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:19:35.01,0:19:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku mau berkelana untuk sementara.
Dialogue: 0,0:19:39.47,0:19:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viewtube?
Dialogue: 0,0:19:40.67,0:19:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku tidak cocok di situ.
Dialogue: 0,0:19:43.79,0:19:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:45.06,0:19:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:19:46.89,0:19:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil berkelana,\Naku ingin menghadapi kelemahanku.
Dialogue: 0,0:19:52.06,0:19:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi menjadi manusia kuat.
Dialogue: 0,0:19:55.13,0:19:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, nanti kuhubungi lagi.\NDadah.
Dialogue: 0,0:20:01.52,0:20:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam Jantan, aku akan berubah.
Dialogue: 0,0:20:04.94,0:20:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa melindungi orang lain\Nlayaknya dirimu.
Dialogue: 0,0:20:08.58,0:20:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam Jantan, Iblis.
Dialogue: 0,0:20:12.72,0:20:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang kuucapkan,
Dialogue: 0,0:20:16.47,0:20:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terima kasih telah menyadarkanku.
Dialogue: 0,0:20:20.63,0:20:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Keiji.
Dialogue: 0,0:20:22.88,0:20:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu cuma peduli\Nsoal membalas dendamnya Sara?
Dialogue: 0,0:20:26.06,0:20:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu di sini?
Dialogue: 0,0:20:30.55,0:20:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Firasatku sangat buruk.
Dialogue: 0,0:20:33.42,0:20:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:20:34.50,0:20:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendungannya akan jebol!
Dialogue: 0,0:20:35.58,0:20:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, ya.
Dialogue: 0,0:20:36.51,0:20:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:20:38.03,0:20:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bendungannya jebol?
Dialogue: 0,0:20:39.58,0:20:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kota ini akan tenggelam?
Dialogue: 0,0:20:42.25,0:20:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji.
Dialogue: 0,0:20:43.09,0:20:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam.
Dialogue: 0,0:20:45.10,0:20:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu mencari mereka.
Dialogue: 0,0:20:47.58,0:20:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:20:49.58,0:20:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucegah bendungannya jebol!
Dialogue: 0,0:20:54.71,0:20:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma kebetulan lewat.
Dialogue: 0,0:20:58.41,0:21:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong banget.
Dialogue: 0,0:21:05.37,0:21:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio...
Dialogue: 0,0:21:06.66,0:21:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia iblis yang baik.
Dialogue: 0,0:21:10.31,0:21:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada yang seperti dia.
Dialogue: 0,0:21:14.04,0:21:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski pernah bilang\Nmau memusnahkan semua iblis,
Dialogue: 0,0:21:17.17,0:21:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kutarik lagi ucapan itu.
Dialogue: 0,0:21:29.62,0:21:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sake yang kita minum bersama\Nadalah yang terbaik.
Dialogue: 0,0:21:34.34,0:21:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat jalan, Morio.
Dialogue: 0,0:21:46.43,0:21:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:21:49.23,0:21:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup?
Dialogue: 0,0:21:51.74,0:21:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku masih hidup!
Dialogue: 0,0:21:58.00,0:22:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah, aku sangat tangguh!
Dialogue: 0,0:22:01.09,0:22:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih hidup!
Dialogue: 0,0:22:05.25,0:22:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kok banjirnya berhenti?
Dialogue: 0,0:22:12.16,0:22:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti Keiji!
Dialogue: 0,0:22:16.11,0:22:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:22:20.36,0:22:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio?
Dialogue: 0,0:22:21.14,0:22:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu si Iblis Baik!
Dialogue: 0,0:22:22.88,0:22:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:22:24.99,0:22:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bedebah itu masih hidup!
Dialogue: 0,0:22:27.62,0:22:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menghentikan banjirnya, kan?
Dialogue: 0,0:22:31.49,0:22:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:22:34.32,0:22:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa mampir lagi!
Dialogue: 0,0:22:36.98,0:22:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, akan kutraktir bulu babi segar!
Dialogue: 0,0:22:44.51,0:22:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo minum sake lagi nanti!
Dialogue: 0,0:22:47.73,0:22:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sampai jumpa!
Dialogue: 0,0:23:00.35,0:23:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah pergi.
Dialogue: 0,0:23:13.91,0:23:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siapa kamu?
Dialogue: 0,0:23:40.26,0:23:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji ikut kencan buta?
Dialogue: 0,0:23:41.99,0:23:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak jadi masalah?
Dialogue: 0,0:23:43.49,0:23:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dilakukan di kencan buta?
Dialogue: 0,0:23:45.95,0:23:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}So-Soal itu...
Dialogue: 0,0:23:47.85,0:23:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Kokok Heboh Nihil Hasil".
Dialogue: 0,0:23:49.68,0:23:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu tersentak?
Dialogue: 0,0:23:51.68,0:23:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat beri tahu!
Dialogue: 0,0:23:52.49,0:23:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu!
