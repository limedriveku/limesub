Dialogue: 0,0:06:32.97,0:06:35.92,tanda,,0000,0000,0000,,EPISODE SEPULUH: KEJUTAN BURUNG TERPOJOK
Dialogue: 0,0:06:49.56,0:06:55.20,tanda,,0000,0000,0000,,BAKTI
Dialogue: 0,0:14:17.38,0:14:19.45,tanda,,0000,0000,0000,,SATU TAHUN LALU
Dialogue: 0,0:23:48.28,0:23:54.19,tanda,,0000,0000,0000,,EPISODE SEBELAS: MANA CUKUP SATU SAYAP
Dialogue: 0,0:23:54.75,0:24:01.05,tanda,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:02.86,0:00:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat, jangan bunuh mereka!
Dialogue: 0,0:00:04.68,0:00:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Elizabeth!
Dialogue: 0,0:00:13.62,0:00:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya berkurang,\Ntinggal sedikit lagi!
Dialogue: 0,0:00:16.21,0:00:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:00:26.30,0:00:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:33.51,0:00:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demonnya muncul!
Dialogue: 0,0:00:35.59,0:00:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia demon?
Dialogue: 0,0:00:37.35,0:00:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa iblisnya kamu bunuh?
Dialogue: 0,0:00:39.10,0:00:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian rekan, bukan?
Dialogue: 0,0:00:40.27,0:00:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan?
Dialogue: 0,0:00:42.86,0:00:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka cuma alat.
Dialogue: 0,0:00:44.32,0:00:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jelek pantas dibuang.
Dialogue: 0,0:00:47.03,0:00:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejam sekali!
Dialogue: 0,0:00:49.40,0:00:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo mulai.
Dialogue: 0,0:00:53.06,0:00:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak sabar.
Dialogue: 0,0:01:03.92,0:01:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo main sepuasnya.
Dialogue: 0,0:01:09.30,0:01:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Auranya mengerikan.
Dialogue: 0,0:01:11.18,0:01:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kalinya aku\Nmerasakan yang seperti ini.
Dialogue: 0,0:01:15.10,0:01:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa aku bisa menang\Nmelawan monster ini?
Dialogue: 0,0:01:19.18,0:01:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu untuk ragu,\Naku harus menolong Ayah!
Dialogue: 0,0:01:23.44,0:01:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghadapinya!
Dialogue: 0,0:01:26.40,0:01:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau aku yang maju duluan?
Dialogue: 0,0:01:29.07,0:01:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai dengan hadiah
Dialogue: 0,0:01:31.68,0:01:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pembukaan!
Dialogue: 0,0:01:39.12,0:01:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:01:40.69,0:01:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth!
Dialogue: 0,0:01:43.46,0:01:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terluka parah.
Dialogue: 0,0:01:45.11,0:01:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus jadi umpan.
Dialogue: 0,0:01:48.25,0:01:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, mau ke mana?
Dialogue: 0,0:01:53.38,0:01:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larilah yang kencang!
Dialogue: 0,0:01:56.64,0:01:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, peluru itu tidak terbatas?
Dialogue: 0,0:02:00.29,0:02:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, dia sembunyi dalam asap.
Dialogue: 0,0:02:05.10,0:02:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar naif!
Dialogue: 0,0:02:25.71,0:02:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ini kemampuanmu?
Dialogue: 0,0:02:28.71,0:02:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku baru mulai.
Dialogue: 0,0:02:33.17,0:02:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia terlalu kuat!
Dialogue: 0,0:02:36.02,0:02:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, bagaimana cara melawannya?
Dialogue: 0,0:02:39.52,0:02:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Inikah demon?
Dialogue: 0,0:02:42.48,0:02:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan dia?
Dialogue: 0,0:02:44.02,0:02:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelnya jauh di atas iblis.
Dialogue: 0,0:02:47.51,0:02:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi kalau tidak kubantu,\NKeisuke bakal mati.
Dialogue: 0,0:02:54.65,0:02:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, aku pasti bisa.
Dialogue: 0,0:03:07.21,0:03:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth!
Dialogue: 0,0:03:09.21,0:03:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak bisa bergerak.
Dialogue: 0,0:03:19.14,0:03:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Keiji!
Dialogue: 0,0:03:21.09,0:03:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:03:22.97,0:03:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana Morio?
Dialogue: 0,0:03:24.35,0:03:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan pada Piyoko.
Dialogue: 0,0:03:25.85,0:03:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:28.35,0:03:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, yang lincah datang.
Dialogue: 0,0:03:30.73,0:03:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, dia sangat kuat!
Dialogue: 0,0:03:34.19,0:03:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saja.
Dialogue: 0,0:03:36.03,0:03:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi,
Dialogue: 0,0:03:38.05,0:03:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan
Dialogue: 0,0:03:39.74,0:03:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghabisinya!
Dialogue: 0,0:03:43.29,0:03:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mempan.
Dialogue: 0,0:03:47.17,0:03:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambat, ah.
Dialogue: 0,0:03:53.84,0:03:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Penghancur!
Dialogue: 0,0:03:57.68,0:04:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, yang tadi cukup bahaya.
Dialogue: 0,0:04:01.18,0:04:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak baik-baik saja?
Dialogue: 0,0:04:03.34,0:04:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi-Minggir sana.
Dialogue: 0,0:04:06.54,0:04:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bedebah itu akan kuhabisi sendiri!
Dialogue: 0,0:04:11.01,0:04:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak belum kapok?\NDia bukan tandinganmu!
Dialogue: 0,0:04:14.72,0:04:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bekerja sama,\Nmustahil kita menang!
Dialogue: 0,0:04:17.81,0:04:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan, menang pun belum tentu.
Dialogue: 0,0:04:21.07,0:04:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada kerja sama denganmu,
Dialogue: 0,0:04:25.19,0:04:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik aku mati!
Dialogue: 0,0:04:27.91,0:04:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ayam ini?
Dialogue: 0,0:04:30.50,0:04:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:31.71,0:04:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah gila, ya?
Dialogue: 0,0:04:34.33,0:04:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:04:35.99,0:04:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu meremehkanku?
Dialogue: 0,0:04:38.59,0:04:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dilarang membunuh si Jengger Merah.
Dialogue: 0,0:04:41.31,0:04:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bodoh amat.
Dialogue: 0,0:04:42.85,0:04:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikir kalian akan mati mudah.
Dialogue: 0,0:04:46.92,0:04:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal harus kusiksa dulu\Nsebanyak mungkin!
Dialogue: 0,0:06:32.97,0:06:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kejutan Burung Terpojok".
Dialogue: 0,0:06:37.21,0:06:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mati?
Dialogue: 0,0:06:41.34,0:06:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa bertemu Tuan Ayam lagi, dong?
Dialogue: 0,0:06:47.60,0:06:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak mau!
Dialogue: 0,0:06:49.56,0:06:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pengin ketemu Tuan Ayam!
Dialogue: 0,0:06:52.56,0:06:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:06:59.44,0:07:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siapa kamu?
Dialogue: 0,0:07:02.72,0:07:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah lupa?
Dialogue: 0,0:07:05.13,0:07:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:07:06.84,0:07:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu akan kuambil alih.
Dialogue: 0,0:07:09.03,0:07:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa?\NJangan!
Dialogue: 0,0:07:17.29,0:07:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bebas.
Dialogue: 0,0:07:20.96,0:07:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sampah, akan kubalas kamu.
Dialogue: 0,0:07:38.86,0:07:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:07:40.82,0:07:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur,
Dialogue: 0,0:07:42.44,0:07:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sialan!
Dialogue: 0,0:07:52.98,0:07:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyahlah.
Dialogue: 0,0:08:04.49,0:08:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:08:05.84,0:08:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ayo, ayo!
Dialogue: 0,0:08:07.93,0:08:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bakal mati kalau lelet, lo!
Dialogue: 0,0:08:11.55,0:08:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu!
Dialogue: 0,0:08:12.76,0:08:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan istirahat!
Dialogue: 0,0:08:16.10,0:08:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:08:17.04,0:08:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sengaja melemahkan tembakan\Nbiar melihat kami berlarian!
Dialogue: 0,0:08:21.84,0:08:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:08:23.23,0:08:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ayo, ayo!
Dialogue: 0,0:08:25.74,0:08:28.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari!
Dialogue: 0,0:08:30.88,0:08:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, pelurunya habis.
Dialogue: 0,0:08:32.83,0:08:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelurunya?
Dialogue: 0,0:08:33.47,0:08:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habis?
Dialogue: 0,0:08:34.45,0:08:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelurunya habis!
Dialogue: 0,0:08:36.20,0:08:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata pelurunya terbatas!
Dialogue: 0,0:08:38.59,0:08:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan emas.
Dialogue: 0,0:08:40.46,0:08:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh disia-siakan,\Nsaatnya menyerang!
Dialogue: 0,0:08:43.34,0:08:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, di situ.
Dialogue: 0,0:08:45.59,0:08:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, mustahil Kakak diam saja.
Dialogue: 0,0:08:49.93,0:08:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga pasti sadar.
Dialogue: 0,0:08:52.29,0:08:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya...
Dialogue: 0,0:08:56.22,0:08:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia maju!
Dialogue: 0,0:08:58.35,0:09:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:09:04.06,0:09:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bohong.
Dialogue: 0,0:09:06.98,0:09:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Penghancur!
Dialogue: 0,0:09:15.37,0:09:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:09:22.17,0:09:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku sepolos itu, bodoh!
Dialogue: 0,0:09:25.34,0:09:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jurusmu layak dipuji.
Dialogue: 0,0:09:27.87,0:09:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa gawat kalau aku tidak berubah wujud.
Dialogue: 0,0:09:31.13,0:09:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh macam apa itu!
Dialogue: 0,0:09:33.68,0:09:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logam Bentukan Memori.
Dialogue: 0,0:09:36.72,0:09:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena serangan apa pun,\Ntubuhku akan kembali normal.
Dialogue: 0,0:09:40.40,0:09:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerahlah, serangan kalian\Ntidak akan mempan lagi.
Dialogue: 0,0:09:46.15,0:09:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:09:47.78,0:09:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya makan.
Dialogue: 0,0:09:56.53,0:09:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bom plastik kualitas tinggi enak banget!
Dialogue: 0,0:09:59.78,0:10:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.
Dialogue: 0,0:10:01.00,0:10:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia butuh bahan peledak\Nuntuk membuat peluru.
Dialogue: 0,0:10:04.37,0:10:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pelurunya terbatas,\Nmasih ada harapan.
Dialogue: 0,0:10:10.95,0:10:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:10:12.06,0:10:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa lanjut lagi.
Dialogue: 0,0:10:14.01,0:10:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku agak bosan.
Dialogue: 0,0:10:16.93,0:10:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo naikkan levelnya.
Dialogue: 0,0:10:19.39,0:10:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ronde dua dimulai!
Dialogue: 0,0:10:25.15,0:10:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakannya...
Dialogue: 0,0:10:26.02,0:10:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meleset?
Dialogue: 0,0:10:29.90,0:10:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:10:31.65,0:10:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curang sekali!
Dialogue: 0,0:10:33.90,0:10:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:10:35.41,0:10:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak masuk akal!
Dialogue: 0,0:10:37.94,0:10:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larilah yang kencang!
Dialogue: 0,0:10:40.16,0:10:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, kami dipermainkan!
Dialogue: 0,0:10:42.49,0:10:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:10:45.79,0:10:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip!
Dialogue: 0,0:10:46.67,0:10:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, menyebalkan!
Dialogue: 0,0:10:50.55,0:10:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ayo!
Dialogue: 0,0:10:52.34,0:10:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nerakanya belum selesai!
Dialogue: 0,0:10:56.84,0:11:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari!
Dialogue: 0,0:11:14.95,0:11:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, aku tidak sanggup\Nmenunggu pelurunya habis!
Dialogue: 0,0:11:20.87,0:11:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya,
Dialogue: 0,0:11:22.54,0:11:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}inti meriamnya ada di bahu kiri.
Dialogue: 0,0:11:25.97,0:11:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian itu harus hancur,
Dialogue: 0,0:11:28.04,0:11:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bagaimana caranya?
Dialogue: 0,0:11:30.02,0:11:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!
Dialogue: 0,0:11:31.82,0:11:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski berisiko, apa boleh buat!
Dialogue: 0,0:11:35.80,0:11:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir!
Dialogue: 0,0:11:38.43,0:11:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak mau apa?
Dialogue: 0,0:11:39.68,0:11:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel, cepat menyingkir!
Dialogue: 0,0:11:43.18,0:11:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghancurkannya!
Dialogue: 0,0:11:48.06,0:11:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini, Bedebah!
Dialogue: 0,0:11:51.69,0:11:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:11:55.91,0:11:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hilang akal, ya?
Dialogue: 0,0:11:58.06,0:12:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dicoba ratusan kali pun percuma!
Dialogue: 0,0:12:09.21,0:12:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:12:09.96,0:12:11.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:12:20.14,0:12:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bunuh diri!
Dialogue: 0,0:12:22.00,0:12:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, ini giliranmu.
Dialogue: 0,0:12:25.91,0:12:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah!
Dialogue: 0,0:12:33.86,0:12:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:12:36.46,0:12:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk tadi bukan buatmu.
Dialogue: 0,0:12:41.95,0:12:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi buat ini!
Dialogue: 0,0:12:44.83,0:12:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:52.50,0:12:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:12:56.42,0:12:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kamu
Dialogue: 0,0:12:58.76,0:13:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memutus lenganku!
Dialogue: 0,0:13:01.64,0:13:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulitnya luntur!
Dialogue: 0,0:13:03.26,0:13:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke!
Dialogue: 0,0:13:04.87,0:13:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang!
Dialogue: 0,0:13:07.01,0:13:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:13:08.02,0:13:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbesar!
Dialogue: 0,0:13:09.59,0:13:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alihkan!
Dialogue: 0,0:13:10.77,0:13:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Penghancur!
Dialogue: 0,0:13:13.98,0:13:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:13:24.87,0:13:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berhasil.
Dialogue: 0,0:13:28.41,0:13:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu lumayan berguna.
Dialogue: 0,0:13:31.50,0:13:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:13:32.55,0:13:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, kamu baik-baik saja?
Dialogue: 0,0:13:34.17,0:13:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu sembrono!
Dialogue: 0,0:13:36.94,0:13:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma luka kecil...
Dialogue: 0,0:13:39.51,0:13:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada!
Dialogue: 0,0:13:42.38,0:13:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada kerja sama denganmu,
Dialogue: 0,0:13:43.80,0:13:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik aku mati!
Dialogue: 0,0:13:46.89,0:13:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski membenciku,
Dialogue: 0,0:13:49.58,0:13:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia berkorban demi memberiku celah.
Dialogue: 0,0:13:53.76,0:13:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh mengagumi
Dialogue: 0,0:13:56.25,0:13:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kegigihanmu untuk menang, Kakak.
Dialogue: 0,0:14:05.49,0:14:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia bosnya?
Dialogue: 0,0:14:07.74,0:14:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kayaknya iya.
Dialogue: 0,0:14:19.45,0:14:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke, ayo mulai.
Dialogue: 0,0:14:21.30,0:14:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:14:23.36,0:14:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:14:25.72,0:14:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbesar!
Dialogue: 0,0:14:27.81,0:14:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alihkan!
Dialogue: 0,0:14:38.52,0:14:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sensasi apa ini?
Dialogue: 0,0:14:40.73,0:14:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku serasa dipenuhi kekuatan.
Dialogue: 0,0:14:44.23,0:14:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kekuatan "telur mulia".
Dialogue: 0,0:14:46.51,0:14:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Telur mulia?
Dialogue: 0,0:14:49.33,0:14:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:14:50.71,0:14:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam punya organ bernama ampela.
Dialogue: 0,0:14:53.87,0:14:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat menghaluskan makanan\Npakai kerikil di dalamnya.
Dialogue: 0,0:14:58.50,0:15:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma sepuluh persen keturunan Goshikidori
Dialogue: 0,0:15:02.26,0:15:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang punya telur mulia di dalam sini.
Dialogue: 0,0:15:05.51,0:15:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah satunya, Keisuke.
Dialogue: 0,0:15:08.76,0:15:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu aku juga punya.
Dialogue: 0,0:15:10.70,0:15:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur mulia memicu getaran di luar nalar
Dialogue: 0,0:15:13.99,0:15:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menghasilkan energi dahsyat.
Dialogue: 0,0:15:16.93,0:15:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan energi ini disebut "api phoenix".
Dialogue: 0,0:15:20.82,0:15:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Api phoenix?
Dialogue: 0,0:15:23.11,0:15:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini.
Dialogue: 0,0:15:24.65,0:15:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas api phoenix\Ndengan menggetarkan telur mulia.
Dialogue: 0,0:15:28.95,0:15:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbesar kekuatan apinya.
Dialogue: 0,0:15:31.79,0:15:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu alihkan ke bagian untuk menyerang.
Dialogue: 0,0:15:35.49,0:15:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokuskan pikiran dan serang!
Dialogue: 0,0:15:44.01,0:15:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hebat!
Dialogue: 0,0:15:45.90,0:15:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur muliamu aku bangkitkan
Dialogue: 0,0:15:49.23,0:15:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan api phoenix barusan.
Dialogue: 0,0:15:52.65,0:15:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membasmi iblis\Nadalah tugas pemilik telur mulia.
Dialogue: 0,0:15:56.39,0:15:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar telur mulia dan api phoenix-mu
Dialogue: 0,0:15:59.98,0:16:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mencapai potensi maksimal,
Dialogue: 0,0:16:02.73,0:16:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}latihan kita akan lebih keras.
Dialogue: 0,0:16:05.24,0:16:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siap laksanakan!
Dialogue: 0,0:16:16.58,0:16:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Mama bilang jangan lengah.
Dialogue: 0,0:16:19.57,0:16:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih kurang disiplin.
Dialogue: 0,0:16:22.50,0:16:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hebat juga kalian.
Dialogue: 0,0:16:24.24,0:16:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku meremehkan Goshikidori.
Dialogue: 0,0:16:27.89,0:16:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata klan kalian memang harus dihapus.
Dialogue: 0,0:16:31.95,0:16:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuan kalian?
Dialogue: 0,0:16:34.31,0:16:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma memberi tahu calon mayat.
Dialogue: 0,0:16:37.99,0:16:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena bertahan sejauh ini,\Nakan kujawab, deh.
Dialogue: 0,0:16:43.07,0:16:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi kami adalah menciptakan demon.
Dialogue: 0,0:16:46.32,0:16:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menciptakan demon?
Dialogue: 0,0:16:49.95,0:16:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa iblis punya potensi jadi demon.
Dialogue: 0,0:16:54.48,0:16:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamilah yang bisa mengubah mereka.
Dialogue: 0,0:16:58.08,0:17:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pakai parasit yang itu?
Dialogue: 0,0:17:03.35,0:17:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cerdas.
Dialogue: 0,0:17:04.53,0:17:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:17:05.33,0:17:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parasit itu menyeleksi iblis\Nuntuk dijadikan demon.
Dialogue: 0,0:17:10.57,0:17:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat jadi demon, kecerdasan, kekuatan,\Ndan fungsi mereka akan melonjak drastis.
Dialogue: 0,0:17:16.81,0:17:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tidak layak\Ntinggal kami jadikan bawahan.
Dialogue: 0,0:17:20.31,0:17:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti para iblis itu, ya.
Dialogue: 0,0:17:22.58,0:17:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demon bukan cuma kami, kok.
Dialogue: 0,0:17:25.11,0:17:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bertambah banyak\Ndi tempat lain juga.
Dialogue: 0,0:17:27.73,0:17:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, mereka masih ada banyak?
Dialogue: 0,0:17:31.71,0:17:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami makhluk terpilih\Nyang kelak menguasai dunia.
Dialogue: 0,0:17:38.58,0:17:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, Klan Goshikidori\Nadalah pengganggu.
Dialogue: 0,0:17:48.13,0:17:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menghajarnya...
Dialogue: 0,0:17:53.55,0:17:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarilah kondisimu!
Dialogue: 0,0:17:56.64,0:17:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sudah tidak bisa bertarung.
Dialogue: 0,0:17:59.77,0:18:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Elizabeth, aku akan maju sendirian.
Dialogue: 0,0:18:03.03,0:18:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:03.60,0:18:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, pertarungan ini\Nterlalu bahaya buatmu.
Dialogue: 0,0:18:13.20,0:18:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sengaja menahan auranya?
Dialogue: 0,0:18:16.19,0:18:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatannya tidak terbaca!
Dialogue: 0,0:18:18.45,0:18:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:18:19.34,0:18:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku tidak boleh kalah\Nsekuat apa pun dirinya!
Dialogue: 0,0:18:24.46,0:18:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menang!
Dialogue: 0,0:18:29.86,0:18:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:18:35.03,0:18:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa dia jadikan senjata\Nbukan cuma tangan?
Dialogue: 0,0:18:39.10,0:18:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:18:40.21,0:18:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demon yang kamu bunuh itu ciptaanku.
Dialogue: 0,0:18:43.52,0:18:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pasti aku lebih kuat darinya.
Dialogue: 0,0:18:47.72,0:18:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak serius, tamat riwayatmu.
Dialogue: 0,0:18:51.44,0:18:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:18:52.66,0:18:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:18:54.24,0:18:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga kali lipat!
Dialogue: 0,0:18:56.74,0:18:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alihkan!
Dialogue: 0,0:19:03.87,0:19:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:19:05.34,0:19:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga kali lipat!
Dialogue: 0,0:19:07.50,0:19:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alihkan!
Dialogue: 0,0:19:08.67,0:19:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Penghancur!
Dialogue: 0,0:19:13.55,0:19:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:19.43,0:19:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, dia menangkis jurus itu?
Dialogue: 0,0:19:24.06,0:19:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga kali lipatku ditahan?
Dialogue: 0,0:19:27.37,0:19:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:19:28.81,0:19:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seranganmu tadi belum serius.
Dialogue: 0,0:19:34.32,0:19:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur mulia tidak mungkin selemah ini.
Dialogue: 0,0:19:38.32,0:19:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia tahu soal telur mulia?
Dialogue: 0,0:19:42.03,0:19:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski telur muliaku\Nsudah dilatih sampai maksimal...
Dialogue: 0,0:19:45.96,0:19:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah Keisuke,\Nbatasmu tiga kali lipat.
Dialogue: 0,0:19:49.87,0:19:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ragamu baru sanggup sampai situ.
Dialogue: 0,0:19:53.30,0:19:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak bisa menang\Nkalau tetap begini.
Dialogue: 0,0:19:57.18,0:19:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, bagaimana ini?
Dialogue: 0,0:19:59.18,0:20:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tunjukkan.
Dialogue: 0,0:20:01.28,0:20:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan sejati telur mulia.
Dialogue: 0,0:20:04.43,0:20:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma ragu-ragu.
Dialogue: 0,0:20:07.13,0:20:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menolong Ayah!
Dialogue: 0,0:20:09.85,0:20:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ini caranya!
Dialogue: 0,0:20:11.25,0:20:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukerahkan semuanya\Ndalam satu serangan ini!
Dialogue: 0,0:20:16.19,0:20:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:20:17.68,0:20:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga kali lipat!
Dialogue: 0,0:20:19.91,0:20:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat kali lipat!
Dialogue: 0,0:20:22.58,0:20:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Li-Lima
Dialogue: 0,0:20:24.70,0:20:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kali lipat!
Dialogue: 0,0:20:27.63,0:20:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa!
Dialogue: 0,0:20:30.13,0:20:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam!
Dialogue: 0,0:20:31.53,0:20:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuh kali lipat!
Dialogue: 0,0:20:33.98,0:20:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serasa mau pecah...
Dialogue: 0,0:20:38.18,0:20:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi, masih bisa!
Dialogue: 0,0:20:41.22,0:20:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan!
Dialogue: 0,0:20:42.98,0:20:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembilan kali lipat!
Dialogue: 0,0:20:50.23,0:20:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepuluh kali lipat!
Dialogue: 0,0:20:56.90,0:20:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alihkan!
Dialogue: 0,0:21:08.55,0:21:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurus Pemungkas Aliran Lima Dewa!
Dialogue: 0,0:21:14.13,0:21:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Penghancur\NSepuluh Kali Lipat!
Dialogue: 0,0:21:31.02,0:21:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke!
Dialogue: 0,0:21:45.28,0:21:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mungkin...
Dialogue: 0,0:21:49.98,0:21:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Sial...
Dialogue: 0,0:23:39.73,0:23:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demon sialan, kuhajar kamu!
Dialogue: 0,0:23:43.82,0:23:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keisuke, ada apa denganmu?
Dialogue: 0,0:23:46.90,0:23:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ganti gaya rambut?
Dialogue: 0,0:23:48.28,0:23:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Mana Cukup Satu Sayap".
Dialogue: 0,0:23:50.66,0:23:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bikin jenggerku panas!
