Dialogue: 0,0:17:22.56,0:17:24.94,tanda,,0000,0000,0000,,KUKURUYUK
Dialogue: 0,0:19:08.50,0:19:14.88,tanda,,0000,0000,0000,,BAKTI
Dialogue: 0,0:23:49.57,0:23:51.45,tanda,,0000,0000,0000,,EPISODE TIGA: PERUMPAMAAN TIGA BURUNG
Dialogue: 0,0:23:54.91,0:23:59.75,tanda,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:10.74,0:00:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkapan besar!\NMaaf menunggu lama.
Dialogue: 0,0:00:13.99,0:00:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah bulu babi ini, enak, lo.
Dialogue: 0,0:00:17.41,0:00:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia mau memakannya?
Dialogue: 0,0:00:21.00,0:00:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengawasi!
Dialogue: 0,0:00:23.61,0:00:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam jantan itu kenapa, ya?
Dialogue: 0,0:00:25.30,0:00:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berkeliaran di sini selama dua tiga hari.
Dialogue: 0,0:00:28.72,0:00:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:00:30.72,0:00:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Makhluk aneh apa ini?
Dialogue: 0,0:00:34.64,0:00:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa dimakan?
Dialogue: 0,0:00:37.77,0:00:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku coba, deh.
Dialogue: 0,0:00:45.69,0:00:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan rasa lezat ini?
Dialogue: 0,0:00:49.57,0:00:51.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini setara 100 kepik daun
Dialogue: 0,0:00:51.57,0:00:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan umami 100 cacing tanah\Ndalam satu gigitan.
Dialogue: 0,0:00:56.16,0:00:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harmoni yang terbaik!
Dialogue: 0,0:01:00.62,0:01:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum pernah ada makanan\Nyang membuatku sebahagia ini!
Dialogue: 0,0:02:52.15,0:02:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Burung Dalam Sangkar".
Dialogue: 0,0:02:54.74,0:02:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ayam.
Dialogue: 0,0:02:57.16,0:03:00.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belilah anak ayam yang manis ini.
Dialogue: 0,0:03:00.12,0:03:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu ekor cuma 300 yen.
Dialogue: 0,0:03:02.37,0:03:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat, Ayah! Semangat!
Dialogue: 0,0:03:06.37,0:03:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:03:07.71,0:03:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diamlah, Kerdil!
Dialogue: 0,0:03:09.46,0:03:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bilang, "Semangat"?
Dialogue: 0,0:03:11.84,0:03:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah sedang bekerja keras!
Dialogue: 0,0:03:15.32,0:03:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyemangatinya!
Dialogue: 0,0:03:16.43,0:03:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bertingkah!
Dialogue: 0,0:03:17.80,0:03:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sedang dijual, tahu!
Dialogue: 0,0:03:19.26,0:03:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hentikan!
Dialogue: 0,0:03:20.76,0:03:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggemaskan sekali!
Dialogue: 0,0:03:23.10,0:03:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka anak ayam!
Dialogue: 0,0:03:24.23,0:03:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulunya lembut sekali!
Dialogue: 0,0:03:26.98,0:03:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka manis, bukan?
Dialogue: 0,0:03:29.48,0:03:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jadi...
Dialogue: 0,0:03:30.65,0:03:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak butuh...
Dialogue: 0,0:03:34.53,0:03:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu...
Dialogue: 0,0:03:36.36,0:03:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi kamu.
Dialogue: 0,0:03:39.50,0:03:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini peringatan terakhir.
Dialogue: 0,0:03:42.62,0:03:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan diulangi lagi.
Dialogue: 0,0:03:44.21,0:03:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, maafkan aku.
Dialogue: 0,0:03:50.96,0:03:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya makan malam!
Dialogue: 0,0:03:53.81,0:03:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berebut, ya.
Dialogue: 0,0:03:55.88,0:03:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hore!
Dialogue: 0,0:03:58.01,0:04:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore, makan malam!
Dialogue: 0,0:04:01.26,0:04:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir!
Dialogue: 0,0:04:02.39,0:04:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi sana!
Dialogue: 0,0:04:03.64,0:04:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjauhlah!
Dialogue: 0,0:04:09.56,0:04:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lapar sekali...
Dialogue: 0,0:04:12.65,0:04:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:15.19,0:04:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:04:18.17,0:04:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah dan tumbuh besar dan kuat.
Dialogue: 0,0:04:22.70,0:04:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:04:25.41,0:04:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku memikul tanggung jawab ini.
Dialogue: 0,0:04:28.46,0:04:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, aku bersamamu.
Dialogue: 0,0:04:31.08,0:04:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkap mereka!
Dialogue: 0,0:04:34.22,0:04:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kamu di sini?
Dialogue: 0,0:04:37.09,0:04:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ken memang yang terbaik.
Dialogue: 0,0:04:41.13,0:04:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus mati.
Dialogue: 0,0:04:43.14,0:04:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pria ini seperti Ayah.\N- Diam!
Dialogue: 0,0:04:44.89,0:04:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pria ini seperti Ayah.
Dialogue: 0,0:04:47.77,0:04:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia luar biasa.
Dialogue: 0,0:05:05.62,0:05:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama! Gambar yang sama!
Dialogue: 0,0:05:08.79,0:05:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengerti, ya?
Dialogue: 0,0:05:10.87,0:05:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ini ikan koi yang sama\Ndengan milik Ken.
Dialogue: 0,0:05:15.45,0:05:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya jadi orang terhormat sepertinya.
Dialogue: 0,0:05:20.88,0:05:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gambarkan untukku!
Dialogue: 0,0:05:25.51,0:05:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mau?
Dialogue: 0,0:05:27.89,0:05:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau! Mau!
Dialogue: 0,0:05:31.85,0:05:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, akan kubuat gambar spesial.
Dialogue: 0,0:05:36.11,0:05:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bakti" yang berarti\Nmenghargai kewajiban dan nurani.
Dialogue: 0,0:05:39.65,0:05:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membela yang lemah dan melawan yang kuat.
Dialogue: 0,0:05:43.78,0:05:44.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakti...
Dialogue: 0,0:05:44.99,0:05:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata yang bagus.
Dialogue: 0,0:05:47.12,0:05:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:48.49,0:05:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupakan baktimu.
Dialogue: 0,0:05:51.41,0:05:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh...
Dialogue: 0,0:05:55.25,0:05:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku bisulan.
Dialogue: 0,0:06:00.34,0:06:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu di punggungmu?
Dialogue: 0,0:06:02.93,0:06:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh banget.
Dialogue: 0,0:06:04.72,0:06:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Norak.
Dialogue: 0,0:06:05.72,0:06:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah menulisnya untukku!\NIni keren!
Dialogue: 0,0:06:11.02,0:06:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Ayah!
Dialogue: 0,0:06:16.15,0:06:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:06:20.28,0:06:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Bang Tajima.
Dialogue: 0,0:06:23.32,0:06:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wakil bos memang tidak tahu\Ncara menahan diri.
Dialogue: 0,0:06:26.91,0:06:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir sama Ayah.
Dialogue: 0,0:06:29.91,0:06:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:06:31.91,0:06:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karena aku selalu menunggak setoran.
Dialogue: 0,0:06:35.98,0:06:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih untung aku tidak disuruh jual organku.
Dialogue: 0,0:06:39.46,0:06:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cari uang lebih banyak.
Dialogue: 0,0:06:42.53,0:06:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yasuo, aku berniat memulai perusahaan sendiri.
Dialogue: 0,0:06:46.84,0:06:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perusahaan?
Dialogue: 0,0:06:49.25,0:06:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, perusahaan pembersih.
Dialogue: 0,0:06:51.81,0:06:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah saatnya Yakuza juga\Nbekerja dengan jujur.
Dialogue: 0,0:06:56.15,0:06:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan membantuku mengelolanya.
Dialogue: 0,0:06:58.94,0:07:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, setoranmu bisa dibayar, kan?
Dialogue: 0,0:07:05.95,0:07:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu baik\Nbahkan pada orang bodoh sepertiku!
Dialogue: 0,0:07:12.33,0:07:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak tahu cara membalas budi ini.
Dialogue: 0,0:07:17.00,0:07:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh, jangan sungkan.\NKita bersaudara, kan?
Dialogue: 0,0:07:20.89,0:07:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha keras!
Dialogue: 0,0:07:25.30,0:07:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:07:28.46,0:07:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa yang terjadi,\Ntapi syukurlah!
Dialogue: 0,0:07:42.73,0:07:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:07:45.36,0:07:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kalian?
Dialogue: 0,0:07:49.96,0:07:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tajima kabur.
Dialogue: 0,0:07:52.05,0:07:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamulah yang harus membayar utangnya.
Dialogue: 0,0:07:58.61,0:08:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak kekurangan uang sekarang.
Dialogue: 0,0:08:01.85,0:08:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya butuh tanda tanganmu di sini.
Dialogue: 0,0:08:05.09,0:08:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi dia bilang\Nakan mendirikan perusahaan?
Dialogue: 0,0:08:11.72,0:08:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kamu yang paling tahu
Dialogue: 0,0:08:14.10,0:08:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa Yakuza tidak bisa dipercaya.
Dialogue: 0,0:08:18.02,0:08:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yasuo.
Dialogue: 0,0:08:19.89,0:08:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yasuo.
Dialogue: 0,0:08:21.61,0:08:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yasuo.
Dialogue: 0,0:08:22.61,0:08:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pulang larut.
Dialogue: 0,0:08:25.51,0:08:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sampai nanti.
Dialogue: 0,0:08:36.75,0:08:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ditelantarkan.
Dialogue: 0,0:08:38.62,0:08:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar ibunya kabur dengan seorang pria.
Dialogue: 0,0:08:40.91,0:08:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dibuang, tahu.
Dialogue: 0,0:08:43.00,0:08:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sampah! Sampah! Sampah!
Dialogue: 0,0:08:48.26,0:08:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanyalah sampah!
Dialogue: 0,0:08:51.54,0:08:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:08:54.14,0:08:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan sampah!
Dialogue: 0,0:08:58.85,0:09:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ada apa?
Dialogue: 0,0:09:01.02,0:09:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:09:11.91,0:09:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:09:16.79,0:09:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:09:20.58,0:09:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi, Ayah?
Dialogue: 0,0:09:22.71,0:09:25.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah baik-baik saja?
Dialogue: 0,0:09:32.68,0:09:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih,
Dialogue: 0,0:09:33.43,0:09:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bulu babi kesukaanmu.
Dialogue: 0,0:09:35.68,0:09:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Bulu babi!
Dialogue: 0,0:09:42.44,0:09:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ayam jantan aneh di sana!
Dialogue: 0,0:09:45.36,0:09:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:53.24,0:09:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu babinya nanti saja.
Dialogue: 0,0:10:00.37,0:10:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:10:04.00,0:10:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan sampah!
Dialogue: 0,0:10:06.96,0:10:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:10:08.17,0:10:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, hentikan!
Dialogue: 0,0:10:10.67,0:10:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, kumohon!\NKendalikan dirimu!
Dialogue: 0,0:10:17.93,0:10:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:10:22.35,0:10:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:10:26.86,0:10:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:10:28.44,0:10:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:10:30.28,0:10:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini, Napas Ikan!
Dialogue: 0,0:10:32.28,0:10:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Napas Ikan?
Dialogue: 0,0:10:36.82,0:10:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga memperlakukanku seperti sampah?\NTamat riwayatmu!
Dialogue: 0,0:10:42.58,0:10:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:10:44.79,0:10:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:10:46.96,0:10:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, tolong hentikan!
Dialogue: 0,0:10:49.84,0:10:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan ganggu Ayah!
Dialogue: 0,0:10:53.47,0:10:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ayam?
Dialogue: 0,0:10:55.09,0:10:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan sampah!
Dialogue: 0,0:10:59.22,0:11:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:11:03.31,0:11:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ku...
Dialogue: 0,0:11:05.06,0:11:06.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ku...
Dialogue: 0,0:11:06.73,0:11:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ru...
Dialogue: 0,0:11:09.73,0:11:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuk!
Dialogue: 0,0:11:25.79,0:11:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:11:28.92,0:11:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah! Ayah!
Dialogue: 0,0:11:33.17,0:11:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak akan bergerak lagi,
Dialogue: 0,0:11:35.76,0:11:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak akan pernah bangun lagi.
Dialogue: 0,0:11:44.18,0:11:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu orang jahat!
Dialogue: 0,0:11:45.98,0:11:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku kasihan!
Dialogue: 0,0:11:48.27,0:11:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jahat!
Dialogue: 0,0:11:50.61,0:11:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu orang jahat!
Dialogue: 0,0:11:52.32,0:11:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jahat!
Dialogue: 0,0:12:04.91,0:12:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, dia masih hidup?
Dialogue: 0,0:12:09.77,0:12:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang yang menjadi Iblis\Nditakdirkan untuk berakhir tragis.
Dialogue: 0,0:12:15.39,0:12:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mungkin lubuk hatinya\Ntidak diambil alih oleh Iblis.
Dialogue: 0,0:12:20.62,0:12:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena kalian semua\Nada di hidupnya.
Dialogue: 0,0:12:27.31,0:12:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan mau membunuh Ayah,\Ntapi justru menolongnya?
Dialogue: 0,0:12:32.82,0:12:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bakti" yang berarti\Nmenghargai kewajiban dan nurani.
Dialogue: 0,0:12:35.61,0:12:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membela yang lemah
Dialogue: 0,0:12:37.19,0:12:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melawan yang kuat.
Dialogue: 0,0:12:41.40,0:12:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam jago ini...
Dialogue: 0,0:12:44.24,0:12:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perwujudan dari "bakti"!
Dialogue: 0,0:12:47.66,0:12:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan apa ini?
Dialogue: 0,0:12:50.04,0:12:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa aneh.
Dialogue: 0,0:12:53.12,0:12:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti.
Dialogue: 0,0:12:54.00,0:12:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:55.00,0:12:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu mau pergi?
Dialogue: 0,0:12:57.08,0:12:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada urusan lagi di sini.
Dialogue: 0,0:12:59.01,0:13:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tapi...
Dialogue: 0,0:13:01.76,0:13:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku masih punya Ayah.
Dialogue: 0,0:13:05.94,0:13:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan hidup bahagia lagi sama Ayah!
Dialogue: 0,0:13:12.88,0:13:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa itu yang kuinginkan?
Dialogue: 0,0:13:26.24,0:13:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah dan tumbuh besar dan kuat.
Dialogue: 0,0:13:29.58,0:13:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mau?
Dialogue: 0,0:13:33.29,0:13:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bakti".
Dialogue: 0,0:13:45.39,0:13:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Ayah!
Dialogue: 0,0:13:47.56,0:13:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bahagia tinggal bersama Ayah!
Dialogue: 0,0:13:51.98,0:13:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih untuk semuanya!
Dialogue: 0,0:13:54.73,0:13:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menemukan kebahagiaan!
Dialogue: 0,0:14:06.20,0:14:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut, aku benci mampus sama bocah.
Dialogue: 0,0:14:10.50,0:14:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:14.25,0:14:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu dulu!
Dialogue: 0,0:14:16.75,0:14:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa aku bersamamu!
Dialogue: 0,0:14:25.01,0:14:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:14:27.43,0:14:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang...
Dialogue: 0,0:14:36.23,0:14:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:14:38.73,0:14:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pria itu?
Dialogue: 0,0:14:41.61,0:14:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia meninggalkan\Nanak manis sepertiku?
Dialogue: 0,0:14:48.99,0:14:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengejar dan memarahinya!
Dialogue: 0,0:14:53.00,0:14:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:54.75,0:14:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlari membuatku lapar.
Dialogue: 0,0:14:57.79,0:15:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada makanan, tidak, ya?
Dialogue: 0,0:15:00.59,0:15:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:03.88,0:15:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya itu cacing!
Dialogue: 0,0:15:06.76,0:15:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa orang dewasa\Nmakan makanan menjijikkan itu?
Dialogue: 0,0:15:10.72,0:15:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya!
Dialogue: 0,0:15:14.77,0:15:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku makan rumput saja, deh.\NAh, enak sekali.
Dialogue: 0,0:15:21.43,0:15:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari!
Dialogue: 0,0:15:27.28,0:15:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lagi.
Dialogue: 0,0:15:30.41,0:15:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin Tuan Ayam\Nakan muncul dan melawannya.
Dialogue: 0,0:15:34.66,0:15:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bertemu dia lagi!
Dialogue: 0,0:15:38.79,0:15:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hama kecil menyebalkan!
Dialogue: 0,0:15:50.30,0:15:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:15:51.68,0:15:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat, Tuan! Semangat, Tuan!
Dialogue: 0,0:15:58.31,0:16:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalat menyebalkan!
Dialogue: 0,0:16:01.01,0:16:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:16:04.03,0:16:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:16:16.12,0:16:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dir lendir...
Dialogue: 0,0:16:20.00,0:16:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dir lendir...
Dialogue: 0,0:16:28.84,0:16:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi begitu.
Dialogue: 0,0:16:30.55,0:16:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang itu percuma.
Dialogue: 0,0:16:33.43,0:16:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kebal.
Dialogue: 0,0:16:37.81,0:16:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:16:39.77,0:16:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua Iblis yang pernah kulawan\Npunya titik lemah
Dialogue: 0,0:16:42.59,0:16:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sekitar otak atau jantung.
Dialogue: 0,0:16:44.32,0:16:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti punya titik lemah juga.
Dialogue: 0,0:16:50.16,0:16:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya membidik tubuhku.
Dialogue: 0,0:16:52.74,0:16:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otak dan jantungku ada di ekor.
Dialogue: 0,0:16:55.54,0:16:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada yang kepikiran\Nuntuk menyerang ekor.
Dialogue: 0,0:16:58.96,0:17:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, merepotkan saja!
Dialogue: 0,0:17:04.67,0:17:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba lagi?
Dialogue: 0,0:17:06.13,0:17:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:17:07.92,0:17:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memanggang dan memakanmu.
Dialogue: 0,0:17:11.43,0:17:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini, Kukuruyuk!
Dialogue: 0,0:17:16.89,0:17:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang itu sia-sia.
Dialogue: 0,0:17:24.94,0:17:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NKa-Kalau terus begini...
Dialogue: 0,0:17:42.71,0:17:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berhasil!\NKamu mengalahkannya!
Dialogue: 0,0:17:50.72,0:17:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis sialan!\NSenjata rahasiaku jadi terpakai!
Dialogue: 0,0:17:54.64,0:17:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Tuan?
Dialogue: 0,0:17:57.83,0:18:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu anak ayam jago itu?
Dialogue: 0,0:18:02.81,0:18:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan aku bawa mati sama-sama!
Dialogue: 0,0:18:04.98,0:18:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan!
Dialogue: 0,0:18:16.03,0:18:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan itu...
Dialogue: 0,0:18:24.04,0:18:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan!
Dialogue: 0,0:18:25.38,0:18:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berdarah banyak!\NBertahanlah, Tuan!
Dialogue: 0,0:18:30.55,0:18:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu ayam jantan, bukan?
Dialogue: 0,0:18:32.63,0:18:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku juga melihatnya!\N- Aku juga!
Dialogue: 0,0:18:34.34,0:18:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat kalau ketahuan manusia.
Dialogue: 0,0:18:42.85,0:18:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu berat.
Dialogue: 0,0:19:08.50,0:19:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Tuan?
Dialogue: 0,0:19:11.25,0:19:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Air...
Dialogue: 0,0:19:13.47,0:19:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air, ya?
Dialogue: 0,0:19:14.88,0:19:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuambilkan!
Dialogue: 0,0:19:16.64,0:19:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membantu Tuan Ayam!
Dialogue: 0,0:19:19.22,0:19:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baktiku!
Dialogue: 0,0:19:23.85,0:19:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:19:25.81,0:19:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini airnya...
Dialogue: 0,0:19:28.98,0:19:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum yang banyak...
Dialogue: 0,0:19:37.33,0:19:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak membaik.
Dialogue: 0,0:19:43.40,0:19:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku, ada di sekitar sini.
Dialogue: 0,0:19:47.17,0:19:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:19:48.85,0:19:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sanggup...
Dialogue: 0,0:19:59.01,0:20:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baktiku!
Dialogue: 0,0:20:07.88,0:20:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lekaslah sembuh.
Dialogue: 0,0:20:31.82,0:20:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih hidup?
Dialogue: 0,0:20:36.45,0:20:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyelamatkanku?
Dialogue: 0,0:20:38.59,0:20:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baktiku...
Dialogue: 0,0:20:43.73,0:20:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ditolong bocil ini...\NSepertinya kemampuanku menumpul.
Dialogue: 0,0:20:51.71,0:20:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:52.61,0:20:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hilang!
Dialogue: 0,0:20:57.11,0:20:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia meninggalkanku?
Dialogue: 0,0:20:59.91,0:21:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau ke mana?
Dialogue: 0,0:21:07.24,0:21:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyusahkan, kamu akan kutinggalkan.
Dialogue: 0,0:21:10.39,0:21:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah syarat kalau kamu mau ikut.
Dialogue: 0,0:21:17.96,0:21:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:21:19.84,0:21:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:21:21.34,0:21:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ucapan terima kasih\Nkarena telah menyelamatkan nyawamu?
Dialogue: 0,0:21:25.68,0:21:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak tahu konsep "bakti"?
Dialogue: 0,0:21:28.02,0:21:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sombong
Dialogue: 0,0:21:29.56,0:21:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya karena kamu sedikit gagah!
Dialogue: 0,0:21:42.03,0:21:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya ketemu.
Dialogue: 0,0:21:45.56,0:21:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:21:47.37,0:21:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:21:49.79,0:21:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu belum berubah, ya, Keiji.
Dialogue: 0,0:21:52.15,0:21:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi terima kasih.
Dialogue: 0,0:21:54.04,0:21:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku bisa membunuhmu tanpa ragu.
Dialogue: 0,0:23:40.44,0:23:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore! Aku bisa bersama Tuan!
Dialogue: 0,0:23:44.11,0:23:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Siapa wanita ini?
Dialogue: 0,0:23:46.70,0:23:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Itu mantan pacarnya?
Dialogue: 0,0:23:48.99,0:23:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Perumpamaan Tiga Burung".
Dialogue: 0,0:23:51.45,0:23:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mengganggu Tuan,\Nkamu akan terima akibatnya!
