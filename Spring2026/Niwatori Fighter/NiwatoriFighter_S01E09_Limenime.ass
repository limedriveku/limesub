Dialogue: 0,0:06:29.87,0:06:31.75,tanda,,0000,0000,0000,,PAPA!
Dialogue: 0,0:06:31.75,0:06:33.37,tanda,,0000,0000,0000,,ELIZABETH!
Dialogue: 0,0:06:33.37,0:06:34.75,tanda,,0000,0000,0000,,PAPA!
Dialogue: 0,0:06:34.75,0:06:38.13,tanda,,0000,0000,0000,,AKU MERINDUKANMU, ELIZABETH!
Dialogue: 0,0:06:38.13,0:06:40.88,tanda,,0000,0000,0000,,PA-PAPA, AKU SESAK!
Dialogue: 0,0:06:40.88,0:06:43.63,tanda,,0000,0000,0000,,MA-MAAF, SOALNYA SUDAH ENAM BULAN\NKITA TIDAK BERTEMU
Dialogue: 0,0:07:43.69,0:07:46.70,tanda,,0000,0000,0000,,EPISODE SEMBILAN: DUNIA CEKER AYAM
Dialogue: 0,0:10:47.75,0:10:50.17,tanda,,0000,0000,0000,,KOKOKODUAR
Dialogue: 0,0:11:02.06,0:11:03.93,tanda,,0000,0000,0000,,TENDANGAN BADAI KILAT
Dialogue: 0,0:11:18.72,0:11:20.78,tanda,,0000,0000,0000,,LEDAKAN PUTARAN NAGA
Dialogue: 0,0:13:41.88,0:13:47.14,tanda,,0000,0000,0000,,KUKURUYUK
Dialogue: 0,0:15:01.80,0:15:04.55,tanda,,0000,0000,0000,,RAIJIN KEKUATAN PENUH
Dialogue: 0,0:16:49.40,0:16:51.41,tanda,,0000,0000,0000,,GELOMBANG PENGHANCUR
Dialogue: 0,0:19:13.47,0:19:15.05,tanda,,0000,0000,0000,,BAKTI
Dialogue: 0,0:23:47.91,0:23:50.28,tanda,,0000,0000,0000,,EPISODE SEPULUH: KEJUTAN BURUNG TERPOJOK
Dialogue: 0,0:23:54.79,0:24:05.04,tanda,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:03.94,0:00:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu bisa bicara?
Dialogue: 0,0:00:08.40,0:00:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tidak.
Dialogue: 0,0:00:10.24,0:00:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah sadar!
Dialogue: 0,0:00:11.87,0:00:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sebenarnya baik!\NJangan jadi jahat!
Dialogue: 0,0:00:26.58,0:00:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Makhluk apa ini?
Dialogue: 0,0:00:31.97,0:00:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menghentikanku.
Dialogue: 0,0:00:34.26,0:00:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sadar kembali?
Dialogue: 0,0:00:38.14,0:00:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:00:40.27,0:00:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:00:41.81,0:00:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sadar!
Dialogue: 0,0:00:43.77,0:00:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu dikendalikan makhluk itu?
Dialogue: 0,0:00:47.65,0:00:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjelaskannya.
Dialogue: 0,0:00:50.91,0:00:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tolong lepaskan ini dulu.
Dialogue: 0,0:00:55.17,0:00:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sesak.
Dialogue: 0,0:00:57.04,0:00:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Keiji?
Dialogue: 0,0:00:58.61,0:01:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal bunuh saja kalau dia mengamuk lagi.
Dialogue: 0,0:01:03.49,0:01:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bebas.
Dialogue: 0,0:01:08.84,0:01:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh.
Dialogue: 0,0:01:09.80,0:01:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengannya copot.
Dialogue: 0,0:01:11.41,0:01:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, jijik!
Dialogue: 0,0:01:14.80,0:01:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka akan diselamatkan oleh ayam.
Dialogue: 0,0:01:19.12,0:01:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:01:21.35,0:01:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?\NKamu yang waktu itu?
Dialogue: 0,0:01:24.40,0:01:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengingatnya?
Dialogue: 0,0:01:25.82,0:01:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:01:26.69,0:01:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tetap punya ingatan\Nmeski dikendalikan.
Dialogue: 0,0:01:31.81,0:01:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau ini ulah mereka,\Naku tetap minta maaf.
Dialogue: 0,0:01:36.45,0:01:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga ini ulah demon.
Dialogue: 0,0:01:39.83,0:01:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, seingatku...
Dialogue: 0,0:01:49.84,0:01:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat makhluk itu memasuki otak,
Dialogue: 0,0:01:53.59,0:01:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuhku langsung ditumbuhi lengan\Ndan kehilangan kendali.
Dialogue: 0,0:02:02.10,0:02:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka makhluk\Nmenjijikkan itu merasukiku.
Dialogue: 0,0:02:06.69,0:02:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek Gurita juga menjijikkan, kok.
Dialogue: 0,0:02:09.97,0:02:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tajam juga lidahmu.
Dialogue: 0,0:02:13.53,0:02:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau demon pelakunya,
Dialogue: 0,0:02:16.38,0:02:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}level mereka pasti di atas iblis.
Dialogue: 0,0:02:19.06,0:02:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis-iblis di pabrik tua pun\Nmungkin kena cara yang sama.
Dialogue: 0,0:02:22.91,0:02:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu iblis ini?
Dialogue: 0,0:02:25.79,0:02:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia baru dibawa kemari.
Dialogue: 0,0:02:29.65,0:02:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada di gudang.
Dialogue: 0,0:02:31.86,0:02:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuan para demon?
Dialogue: 0,0:02:33.87,0:02:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghancurkan kota dan menyiksa manusia?
Dialogue: 0,0:02:37.30,0:02:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ini cuma melepas stres.
Dialogue: 0,0:02:39.81,0:02:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melepas stres?
Dialogue: 0,0:02:41.06,0:02:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali kami dilepas\Nuntuk melampiaskan stres.
Dialogue: 0,0:02:45.86,0:02:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin supaya tidak memberontak.
Dialogue: 0,0:02:49.52,0:02:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, apa yang mereka incar?
Dialogue: 0,0:02:52.19,0:02:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:02:53.97,0:02:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sempat mendengar obrolan mereka.
Dialogue: 0,0:02:57.74,0:03:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, hari ini gagal lagi.
Dialogue: 0,0:03:00.74,0:03:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersabarlah, Yuuji, ayo cari pelan-pelan.
Dialogue: 0,0:03:04.46,0:03:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari?
Dialogue: 0,0:03:05.96,0:03:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari apa?
Dialogue: 0,0:03:07.28,0:03:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak penting.
Dialogue: 0,0:03:09.34,0:03:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antar aku ke pabrik tua
Dialogue: 0,0:03:11.33,0:03:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menolong Morio!
Dialogue: 0,0:03:12.85,0:03:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya?
Dialogue: 0,0:03:14.45,0:03:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek gurita ini saja bisa sadar.
Dialogue: 0,0:03:17.31,0:03:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti bisa sembuh.
Dialogue: 0,0:03:19.01,0:03:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ikut!
Dialogue: 0,0:03:23.10,0:03:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Piyoko.
Dialogue: 0,0:03:24.68,0:03:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak iblis di sana!
Dialogue: 0,0:03:27.55,0:03:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tidak terlalu berguna.
Dialogue: 0,0:03:31.98,0:03:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Morio temannya Tuan Ayam.
Dialogue: 0,0:03:34.85,0:03:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau menolongnya!
Dialogue: 0,0:03:37.99,0:03:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko...
Dialogue: 0,0:03:39.78,0:03:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham perasaan kalian.
Dialogue: 0,0:03:41.53,0:03:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi demon sangatlah kuat.
Dialogue: 0,0:03:43.56,0:03:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus sabar dan menyusun rencana.
Dialogue: 0,0:03:46.75,0:03:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:03:49.14,0:03:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu takut pada mereka, kan?
Dialogue: 0,0:03:51.75,0:03:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak berani\Nkarena belum melihatnya sendiri.
Dialogue: 0,0:03:55.46,0:03:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melawan mereka!
Dialogue: 0,0:03:57.68,0:04:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kakak yang kalah dariku,
Dialogue: 0,0:04:00.08,0:04:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- mustahil men—\N- Persetan menang atau kalah!
Dialogue: 0,0:04:03.01,0:04:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau menolong Morio.
Dialogue: 0,0:04:05.44,0:04:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja.
Dialogue: 0,0:04:09.60,0:04:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski menyebalkan, Kakak benar.
Dialogue: 0,0:04:12.80,0:04:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil menang kalau aku ciut.
Dialogue: 0,0:04:15.86,0:04:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa!
Dialogue: 0,0:04:17.14,0:04:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti menyelamatkan Ayah!
Dialogue: 0,0:04:20.52,0:04:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji.
Dialogue: 0,0:04:22.28,0:04:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ada orang yang harus kutemui.
Dialogue: 0,0:04:25.98,0:04:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau selesai, aku segera menyusul.
Dialogue: 0,0:04:29.55,0:04:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:04:37.36,0:04:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, Morio.
Dialogue: 0,0:06:43.63,0:06:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juragan memang hebat.
Dialogue: 0,0:06:45.01,0:06:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahasa ayamnya masih lancar.
Dialogue: 0,0:06:47.76,0:06:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa bawa pesananku?
Dialogue: 0,0:06:49.85,0:06:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bawa.
Dialogue: 0,0:06:51.79,0:06:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:06:53.02,0:06:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, Nona Elizabeth.
Dialogue: 0,0:06:57.73,0:07:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, langsung siap dalam empat jam?
Dialogue: 0,0:07:00.40,0:07:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup Yonesaka kami membuat mahakarya ini
Dialogue: 0,0:07:03.49,0:07:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan seluruh kekuatan.
Dialogue: 0,0:07:05.28,0:07:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fitur yang kamu mau
Dialogue: 0,0:07:07.11,0:07:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah kami masukkan.
Dialogue: 0,0:07:09.20,0:07:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Papa!
Dialogue: 0,0:07:10.74,0:07:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah, Elizabeth.
Dialogue: 0,0:07:12.98,0:07:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, benda ini buat apa?
Dialogue: 0,0:07:17.75,0:07:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang iblis menyadarkanku
Dialogue: 0,0:07:21.84,0:07:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa membunuh bukanlah\Nsatu-satunya solusi.
Dialogue: 0,0:07:26.30,0:07:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya,\Nkamu memang baik hati.
Dialogue: 0,0:07:30.81,0:07:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyayangimu, Elizabeth.
Dialogue: 0,0:07:33.47,0:07:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sayang Papa.
Dialogue: 0,0:07:43.69,0:07:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dunia Ceker Ayam".
Dialogue: 0,0:07:50.87,0:07:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya datang.
Dialogue: 0,0:07:55.37,0:07:57.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ayam itu juga temanmu?
Dialogue: 0,0:07:58.37,0:07:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat kuat.
Dialogue: 0,0:08:01.71,0:08:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan Ayah!
Dialogue: 0,0:08:03.21,0:08:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?\NItu ayahmu?
Dialogue: 0,0:08:06.66,0:08:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak miri—
Dialogue: 0,0:08:13.35,0:08:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, temanmu boleh juga.
Dialogue: 0,0:08:16.99,0:08:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lincah, ya.
Dialogue: 0,0:08:18.85,0:08:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berengsek, mana Morio?
Dialogue: 0,0:08:21.73,0:08:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio?
Dialogue: 0,0:08:23.15,0:08:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iblis tangkapan Mama.
Dialogue: 0,0:08:26.24,0:08:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti dia...
Dialogue: 0,0:08:29.26,0:08:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin teman yang dia bawa
Dialogue: 0,0:08:31.93,0:08:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah ayam yang kukenal.
Dialogue: 0,0:08:34.76,0:08:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah kuduga akan datang,
Dialogue: 0,0:08:37.38,0:08:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak disangka satu klan sekaligus.
Dialogue: 0,0:08:40.25,0:08:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih cepat dari perkiraan.
Dialogue: 0,0:08:42.72,0:08:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sudah waktunya memburunya.
Dialogue: 0,0:08:45.88,0:08:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat, Hikari.
Dialogue: 0,0:08:47.05,0:08:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bunuh kenalanku.
Dialogue: 0,0:08:49.38,0:08:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya terserah kamu.
Dialogue: 0,0:08:51.89,0:08:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan sampai lengah.
Dialogue: 0,0:08:55.34,0:08:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Mama.
Dialogue: 0,0:08:59.09,0:09:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah misi kalian membasmi iblis?
Dialogue: 0,0:09:03.28,0:09:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa berkorban nyawa\Ncuma demi seekor iblis?
Dialogue: 0,0:09:07.03,0:09:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Cuma demi seekor iblis"?
Dialogue: 0,0:09:11.03,0:09:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio mengorbankan nyawa\Ndemi menyelamatkan manusia.
Dialogue: 0,0:09:17.09,0:09:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mana paham perasaannya!
Dialogue: 0,0:09:19.91,0:09:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio dipaksa menyakiti
Dialogue: 0,0:09:22.67,0:09:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manusia yang seharusnya dia lindungi.
Dialogue: 0,0:09:27.30,0:09:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatinya pasti menjerit karena tidak terima.
Dialogue: 0,0:09:33.12,0:09:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Keiji!\N- Pria baik hati sepertinya pasti tersiksa.
Dialogue: 0,0:09:39.94,0:09:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dimaafkan.
Dialogue: 0,0:09:42.16,0:09:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kalian menginjak-injak
Dialogue: 0,0:09:44.98,0:09:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perasaan Morio!
Dialogue: 0,0:09:47.07,0:09:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bikin jenggerku panas!
Dialogue: 0,0:09:52.82,0:09:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persahabatan dan keluarga, ya.
Dialogue: 0,0:09:57.58,0:10:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling itu cuma ikatan palsu.
Dialogue: 0,0:10:00.75,0:10:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:01.98,0:10:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukembalikan.
Dialogue: 0,0:10:04.33,0:10:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:10:11.10,0:10:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bermainlah dulu dengan mereka.
Dialogue: 0,0:10:14.86,0:10:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegangan yang erat, Piyoko!
Dialogue: 0,0:10:16.55,0:10:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:10:18.39,0:10:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, permainan dimulai.
Dialogue: 0,0:10:22.89,0:10:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bunuh si Jengger Merah.
Dialogue: 0,0:10:25.44,0:10:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya boleh.
Dialogue: 0,0:10:34.91,0:10:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku tidak sempat\Nmenembakkan Kukuruyuk!
Dialogue: 0,0:10:38.94,0:10:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:10:40.29,0:10:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:10:43.79,0:10:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:10:47.75,0:10:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kokokokduar!
Dialogue: 0,0:10:53.92,0:10:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kewalahan duluan,\Nmustahil mengalahkan para demon!
Dialogue: 0,0:10:57.55,0:11:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kuserang habis-habisan!
Dialogue: 0,0:11:02.06,0:11:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tendangan Badai Kilat!
Dialogue: 0,0:11:10.32,0:11:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas!
Dialogue: 0,0:11:11.55,0:11:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga kali lipat!
Dialogue: 0,0:11:12.93,0:11:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alihkan!
Dialogue: 0,0:11:14.07,0:11:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aliran Lima Dewa!
Dialogue: 0,0:11:18.72,0:11:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ledakan Putaran Naga!
Dialogue: 0,0:11:23.50,0:11:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap.
Dialogue: 0,0:11:25.33,0:11:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jago juga mereka.
Dialogue: 0,0:11:27.42,0:11:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari, aku sudah boleh ikut, kan?
Dialogue: 0,0:11:30.32,0:11:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:11:37.97,0:11:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, banyak sekali!
Dialogue: 0,0:11:41.10,0:11:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati saja semuanya!
Dialogue: 0,0:11:43.72,0:11:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dibunuh!
Dialogue: 0,0:11:51.81,0:11:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf terlambat.
Dialogue: 0,0:11:53.86,0:11:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth!
Dialogue: 0,0:12:00.03,0:12:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak mati?
Dialogue: 0,0:12:00.99,0:12:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pakai senjata baru?
Dialogue: 0,0:12:03.83,0:12:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:05.36,0:12:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pistol energi terarah, Raijin.
Dialogue: 0,0:12:09.14,0:12:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bikin pingsan dua sampai tiga hari.
Dialogue: 0,0:12:11.38,0:12:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah langsung berguna.
Dialogue: 0,0:12:14.25,0:12:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara mereka pasti ada
Dialogue: 0,0:12:16.42,0:12:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}iblis baik seperti Morio dan gurita tadi.
Dialogue: 0,0:12:21.52,0:12:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin iblis baik tetap hidup.
Dialogue: 0,0:12:29.31,0:12:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth sangat memesona!
Dialogue: 0,0:12:32.98,0:12:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:12:34.27,0:12:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, temannya bertambah.
Dialogue: 0,0:12:38.57,0:12:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari naikkan levelnya sedikit.
Dialogue: 0,0:12:49.67,0:12:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio!
Dialogue: 0,0:12:51.76,0:12:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio!
Dialogue: 0,0:12:52.92,0:12:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio, ini aku!
Dialogue: 0,0:12:54.86,0:12:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:13:01.50,0:13:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:13:02.80,0:13:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sadarlah!
Dialogue: 0,0:13:09.89,0:13:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, mau bagaimana?
Dialogue: 0,0:13:18.10,0:13:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyadarkan Morio.
Dialogue: 0,0:13:20.22,0:13:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong urus dua sisanya.
Dialogue: 0,0:13:22.03,0:13:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:13:27.09,0:13:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:13:31.87,0:13:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam, jangan!
Dialogue: 0,0:13:33.38,0:13:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morio bisa mati!
Dialogue: 0,0:13:35.68,0:13:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengincar isi kepalanya.
Dialogue: 0,0:13:37.81,0:13:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu parasitnya keluar.
Dialogue: 0,0:13:41.88,0:13:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:13:52.23,0:13:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, tidak berhasil.
Dialogue: 0,0:13:56.73,0:13:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam.
Dialogue: 0,0:13:58.24,0:14:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menolong Morio!
Dialogue: 0,0:14:00.45,0:14:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:14:01.74,0:14:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cukup kecil\Nuntuk masuk ke kepala Morio.
Dialogue: 0,0:14:06.11,0:14:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengalahkan\Nmonster di kepala Morio
Dialogue: 0,0:14:08.86,0:14:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyadarkannya!
Dialogue: 0,0:14:10.75,0:14:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu gila, ya?
Dialogue: 0,0:14:12.51,0:14:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil!
Dialogue: 0,0:14:13.67,0:14:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan tahu sebelum dicoba!
Dialogue: 0,0:14:16.00,0:14:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu melihat\Ncaramu bertarung dari dekat.
Dialogue: 0,0:14:20.26,0:14:22.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa bertarung!
Dialogue: 0,0:14:22.85,0:14:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi...
Dialogue: 0,0:14:24.53,0:14:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa!\NTidak ada cara lain!
Dialogue: 0,0:14:35.73,0:14:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mungkin akan mati.
Dialogue: 0,0:14:38.77,0:14:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan mati\Nsebelum kita menua bersama!
Dialogue: 0,0:14:49.54,0:14:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaganya kurang.
Dialogue: 0,0:14:55.29,0:14:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:14:57.78,0:14:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba yang ini!
Dialogue: 0,0:15:01.80,0:15:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raijin Kekuatan Penuh!
Dialogue: 0,0:15:10.43,0:15:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:15:12.18,0:15:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa dijadikan senjata.
Dialogue: 0,0:15:14.51,0:15:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu tali untuk membawanya.
Dialogue: 0,0:15:17.23,0:15:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap!
Dialogue: 0,0:15:21.98,0:15:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko, naiklah!
Dialogue: 0,0:15:23.10,0:15:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:15:27.66,0:15:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau masuk lewat mana?
Dialogue: 0,0:15:29.18,0:15:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bisa lewat hidung!
Dialogue: 0,0:15:42.34,0:15:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, susah sekali.
Dialogue: 0,0:15:45.72,0:15:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, Morio!\NBiarkan aku memasuki kepalamu!
Dialogue: 0,0:15:49.55,0:15:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam dan biarkan aku menolongmu,\Ndasar bodoh!
Dialogue: 0,0:15:53.47,0:15:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko, dia harus\Ndilumpuhkan pistol Elizabeth.
Dialogue: 0,0:15:57.56,0:16:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, betul juga!
Dialogue: 0,0:16:00.25,0:16:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan soal itu padaku.
Dialogue: 0,0:16:11.62,0:16:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar rencana kalian,\Nkamu kecil tapi pemberani, ya.
Dialogue: 0,0:16:16.12,0:16:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakek Gurita?
Dialogue: 0,0:16:17.62,0:16:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah, anak ayam!
Dialogue: 0,0:16:19.23,0:16:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenagaku cukup besar, kok.
Dialogue: 0,0:16:21.54,0:16:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutahan dia.
Dialogue: 0,0:16:23.60,0:16:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kakek Gurita!
Dialogue: 0,0:16:46.13,0:16:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurus Pemungkas Aliran Lima Dewa.
Dialogue: 0,0:16:49.40,0:16:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelombang Penghancur!
Dialogue: 0,0:16:55.29,0:16:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hikari, sudah boleh, kan?
Dialogue: 0,0:17:11.01,0:17:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko, kamu tidak apa-apa?
Dialogue: 0,0:17:12.82,0:17:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut.
Dialogue: 0,0:17:15.47,0:17:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih sempat buat menyerah.
Dialogue: 0,0:17:18.21,0:17:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan masuk!
Dialogue: 0,0:17:20.19,0:17:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekadku sudah bulat!
Dialogue: 0,0:17:24.34,0:17:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah, Anak Ayam!
Dialogue: 0,0:17:31.47,0:17:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membantu Tuan Ayam!
Dialogue: 0,0:17:33.87,0:17:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti bisa kalau berusaha!
Dialogue: 0,0:17:36.98,0:17:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu saja, Morio.
Dialogue: 0,0:17:38.67,0:17:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti menolongmu!
Dialogue: 0,0:17:41.62,0:17:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya, Piyoko.
Dialogue: 0,0:17:44.33,0:17:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya di sekitar sini ada otak.
Dialogue: 0,0:17:48.96,0:17:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, lengket dan menjijikkan.
Dialogue: 0,0:17:53.34,0:17:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:54.47,0:17:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalnya dari bagian mirip lubang pantat itu.
Dialogue: 0,0:17:58.29,0:18:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku bisa lewat situ.
Dialogue: 0,0:18:00.60,0:18:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, lengket banget.
Dialogue: 0,0:18:05.52,0:18:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempit pula.
Dialogue: 0,0:18:09.11,0:18:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking gelapnya,\Naku tidak bisa melihat apa pun.
Dialogue: 0,0:18:12.27,0:18:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, lagi-lagi lengket.
Dialogue: 0,0:18:15.23,0:18:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau!\NBau banget!
Dialogue: 0,0:18:23.28,0:18:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuih!
Dialogue: 0,0:18:25.02,0:18:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:26.96,0:18:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:18:29.31,0:18:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikuti cahayanya, ah.
Dialogue: 0,0:18:34.13,0:18:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin sempit.
Dialogue: 0,0:18:37.79,0:18:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pintu keluar!
Dialogue: 0,0:18:41.60,0:18:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore, aku keluar!
Dialogue: 0,0:18:51.47,0:18:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku bisa\Nmengalahkan monster itu.
Dialogue: 0,0:18:56.32,0:19:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berkorban\Ndemi menahan bendungan ini!
Dialogue: 0,0:19:01.04,0:19:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu benar.
Dialogue: 0,0:19:03.41,0:19:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mungkin\Nmengabaikan orang sebaik dia.
Dialogue: 0,0:19:07.02,0:19:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, aku pasti bisa!
Dialogue: 0,0:19:09.33,0:19:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus yakin!
Dialogue: 0,0:19:11.21,0:19:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:19:16.55,0:19:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti bisa!
Dialogue: 0,0:19:32.22,0:19:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:19:34.03,0:19:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan kalah!
Dialogue: 0,0:19:46.37,0:19:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali.
Dialogue: 0,0:19:50.74,0:19:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tidak bisa, aku ingin lari.
Dialogue: 0,0:19:57.57,0:19:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini...
Dialogue: 0,0:19:59.64,0:20:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ini bulu Tuan Ayam.
Dialogue: 0,0:20:04.02,0:20:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujadikan jimat.
Dialogue: 0,0:20:07.87,0:20:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:20:10.53,0:20:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesulit apa pun keadaannya,
Dialogue: 0,0:20:13.57,0:20:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam tidak pernah menyerah.
Dialogue: 0,0:20:18.78,0:20:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam menyertaiku.
Dialogue: 0,0:20:22.56,0:20:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh lari\Ndan menyerah begitu saja!
Dialogue: 0,0:20:27.16,0:20:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirkan, pasti ada cara mengalahkannya.
Dialogue: 0,0:20:31.54,0:20:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirkan!
Dialogue: 0,0:20:34.92,0:20:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, dia cuma diam di situ.
Dialogue: 0,0:20:39.18,0:20:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster itu terhubung ke otak Morio.
Dialogue: 0,0:20:43.64,0:20:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia bukan tidak mau bergerak,
Dialogue: 0,0:20:47.22,0:20:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi memang tidak bisa!
Dialogue: 0,0:20:49.52,0:20:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kalau begitu...
Dialogue: 0,0:20:54.02,0:20:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuserang dari belakang!
Dialogue: 0,0:21:06.16,0:21:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menang!
Dialogue: 0,0:21:31.31,0:21:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu...
Dialogue: 0,0:21:32.22,0:21:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam...
Dialogue: 0,0:23:40.37,0:23:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sungguh pemberani.
Dialogue: 0,0:23:44.19,0:23:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi para demon itu datang.
Dialogue: 0,0:23:47.91,0:23:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Kejutan Burung Terpojok ".
Dialogue: 0,0:23:50.28,0:23:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Napa si Anak Ayam baik-baik saja?
