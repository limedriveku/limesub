Dialogue: 0,0:00:29.76,0:00:32.64,tanda,,0000,0000,0000,,EPISODE EMPAT: PERUMPAMAAN TIGA BURUNG
Dialogue: 0,0:04:21.99,0:04:24.24,tanda,,0000,0000,0000,,SEDANG MEMUAT\NMEREKA BERDUA CUMA
Dialogue: 0,0:05:30.02,0:05:31.64,tanda,,0000,0000,0000,,RAMEN AYAM
Dialogue: 0,0:16:55.08,0:16:58.66,tanda,,0000,0000,0000,,KUKURUYUK
Dialogue: 0,0:18:55.57,0:18:59.66,tanda,,0000,0000,0000,,KUKURUYUK
Dialogue: 0,0:23:49.20,0:23:49.93,tanda,,0000,0000,0000,,EPISODE EMPAT:
Dialogue: 0,0:23:49.93,0:23:53.95,tanda,,0000,0000,0000,,KUMPUL BAGAI HEWAN BUAS, BUBAR BAGAI BURUNG
Dialogue: 0,0:23:54.95,0:24:00.25,tanda,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:12.03,0:00:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, kamu yakin lewat sini?
Dialogue: 0,0:00:14.16,0:00:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan penciumanku, Elizabeth.
Dialogue: 0,0:00:17.71,0:00:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aroma hewan buas ikut tercium.
Dialogue: 0,0:00:20.63,0:00:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan terburuknya, Piyoko sudah...
Dialogue: 0,0:00:23.25,0:00:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam, tolong!
Dialogue: 0,0:00:29.76,0:00:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bernapas dan Melihat Layaknya Burung".
Dialogue: 0,0:00:32.64,0:00:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan! Lepaskan aku!
Dialogue: 0,0:00:46.62,0:00:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti, Kucing Garong!
Dialogue: 0,0:00:48.78,0:00:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan anak ayam itu.
Dialogue: 0,0:00:52.28,0:00:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Ayam!
Dialogue: 0,0:00:55.07,0:00:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mangsaku.
Dialogue: 0,0:00:56.66,0:00:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kuserahkan!
Dialogue: 0,0:00:58.61,0:01:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, apa boleh buat.
Dialogue: 0,0:01:08.80,0:01:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama!
Dialogue: 0,0:01:15.05,0:01:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang jangan keluar rumah.
Dialogue: 0,0:01:17.52,0:01:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lapar, Mama.
Dialogue: 0,0:01:21.81,0:01:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menculik Piyoko demi anak-anak ini?
Dialogue: 0,0:01:25.23,0:01:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepuluh hari, aku kesulitan\Nmemberi mereka makanan layak.
Dialogue: 0,0:01:29.99,0:01:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berkenan, aku punya sedikit makanan.
Dialogue: 0,0:01:33.66,0:01:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:01:40.20,0:01:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini telur segar dan bergizi\Nyang baru saja keluar.
Dialogue: 0,0:01:45.25,0:01:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:01:46.92,0:01:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, kelihatan enak.\N- Apa ini?
Dialogue: 0,0:01:48.30,0:01:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, kelihatan enak.\N- Aromanya sedap!
Dialogue: 0,0:01:50.59,0:01:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman buat dimakan, kok.
Dialogue: 0,0:01:52.38,0:01:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telur itu tidak bernyawa\Nkarena tidak dibuahi.
Dialogue: 0,0:01:54.93,0:01:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat makan!\N- Enaknya!
Dialogue: 0,0:01:57.01,0:02:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma telur, nanti juga\Naku bisa menghasilkannya.
Dialogue: 0,0:02:02.48,0:02:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jasamu begitu besar.
Dialogue: 0,0:02:04.85,0:02:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa memakannya,
Dialogue: 0,0:02:07.19,0:02:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi biasanya dibuang.
Dialogue: 0,0:02:09.32,0:02:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah bisa bermanfaat.
Dialogue: 0,0:02:11.39,0:02:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu kucing peliharaan, kan?
Dialogue: 0,0:02:15.28,0:02:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majikanmu tidak memberi makan?
Dialogue: 0,0:02:17.87,0:02:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}So-Soal itu...
Dialogue: 0,0:02:23.69,0:02:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Elizabeth.
Dialogue: 0,0:02:27.25,0:02:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lu-Lubang apa itu?
Dialogue: 0,0:02:30.38,0:02:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya menggali.
Dialogue: 0,0:02:32.26,0:02:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada wanita dan lansia.
Dialogue: 0,0:02:35.96,0:02:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak terlihat sadar.
Dialogue: 0,0:02:39.10,0:02:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu majikanku.
Dialogue: 0,0:02:41.02,0:02:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:42.02,0:02:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:02:43.60,0:02:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Mengerikan.
Dialogue: 0,0:02:45.81,0:02:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini ulah monster.
Dialogue: 0,0:02:48.32,0:02:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster?
Dialogue: 0,0:02:50.32,0:02:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia muncul sepuluh hari lalu.
Dialogue: 0,0:02:52.78,0:02:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah tujuannya apa,
Dialogue: 0,0:02:54.81,0:02:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia mengendalikan warga desa\Nuntuk menggali tanpa henti.
Dialogue: 0,0:02:59.70,0:03:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dia menetap\Ndi rumah besar di pinggiran desa.
Dialogue: 0,0:03:04.91,0:03:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kasihan adalah anak-anak desa.
Dialogue: 0,0:03:07.80,0:03:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dikurung di gubuk\Ndan tidak diberi makan.
Dialogue: 0,0:03:13.63,0:03:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf malah jadi begini.
Dialogue: 0,0:03:16.63,0:03:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan salahmu.
Dialogue: 0,0:03:18.80,0:03:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kondisinya buntu.
Dialogue: 0,0:03:20.68,0:03:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap begini, kita bakal mati.
Dialogue: 0,0:03:24.02,0:03:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau tidak mau harus bertaruh.
Dialogue: 0,0:03:27.81,0:03:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, dorong sekuat tenaga.
Dialogue: 0,0:03:30.77,0:03:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:03:31.90,0:03:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap, mulai!
Dialogue: 0,0:03:36.32,0:03:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan ada bunyi dari sana.
Dialogue: 0,0:03:41.58,0:03:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutahan dia, cepat lari!
Dialogue: 0,0:03:44.54,0:03:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi...
Dialogue: 0,0:03:45.83,0:03:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak bisa meninggalkanmu!
Dialogue: 0,0:03:47.96,0:03:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh! Kalian bakal mati kalau tertangkap!
Dialogue: 0,0:03:50.38,0:03:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyusul, cepat pergi!
Dialogue: 0,0:03:52.88,0:03:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak.
Dialogue: 0,0:04:02.41,0:04:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei...
Dialogue: 0,0:04:05.70,0:04:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kabur, akan kubunuh.
Dialogue: 0,0:04:16.44,0:04:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:04:18.57,0:04:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam?
Dialogue: 0,0:04:24.24,0:04:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua cuma pingsan.
Dialogue: 0,0:04:26.75,0:04:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya diikat sebelum sadar kembali.
Dialogue: 0,0:04:30.75,0:04:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-Yang benar saja!
Dialogue: 0,0:04:33.29,0:04:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam macam apa dia?
Dialogue: 0,0:04:35.51,0:04:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memakai ponsel.
Dialogue: 0,0:04:36.96,0:04:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ayam genius!
Dialogue: 0,0:04:40.01,0:04:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bicara bahasa manusia?\NMesin yang di luar nalar.
Dialogue: 0,0:04:46.89,0:04:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah, Sei!
Dialogue: 0,0:04:48.27,0:04:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, sudah selesai.
Dialogue: 0,0:04:53.44,0:04:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, ayo ke rumahku dulu.
Dialogue: 0,0:04:55.40,0:04:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:04:56.53,0:04:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing, terima kasih bantuannya.
Dialogue: 0,0:04:58.65,0:05:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru aku senang bisa membantu.
Dialogue: 0,0:05:01.91,0:05:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami para ayam rabun di saat malam.
Dialogue: 0,0:05:06.49,0:05:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mengejar?
Dialogue: 0,0:05:08.29,0:05:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin tidak, soalnya cuma\Nmereka berdua yang berjaga.
Dialogue: 0,0:05:12.17,0:05:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pernah ada bantuan\Ndari polisi atau semacamnya?
Dialogue: 0,0:05:16.12,0:05:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi desa yang dikendalikan
Dialogue: 0,0:05:18.51,0:05:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kayaknya menyembunyikan\Nsoal desa ini dengan baik.
Dialogue: 0,0:05:23.19,0:05:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya monster kali ini punya kecerdasan.
Dialogue: 0,0:05:28.50,0:05:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:05:34.65,0:05:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, harumnya!
Dialogue: 0,0:05:37.02,0:05:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei, kamu hebat!
Dialogue: 0,0:05:38.86,0:05:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku terkejut.
Dialogue: 0,0:05:40.40,0:05:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada ayam yang bisa diajak mengobrol.
Dialogue: 0,0:05:44.16,0:05:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jadi!
Dialogue: 0,0:05:45.21,0:05:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:05:46.78,0:05:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan!
Dialogue: 0,0:05:51.25,0:05:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:05:55.59,0:05:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyang banget!
Dialogue: 0,0:06:02.05,0:06:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terbiasa memasak, ya.
Dialogue: 0,0:06:04.09,0:06:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu meninggal sejak aku kecil.
Dialogue: 0,0:06:06.60,0:06:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mahir sendiri, deh.
Dialogue: 0,0:06:09.28,0:06:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:06:14.18,0:06:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bertualang
Dialogue: 0,0:06:15.51,0:06:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sambil membasmi iblis\Nyang muncul di seluruh Jepang.
Dialogue: 0,0:06:19.69,0:06:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster yang muncul di desamu pun\Nmungkin adalah iblis.
Dialogue: 0,0:06:25.32,0:06:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sedih melihat\Nkeluarga kalian dikendalikan.
Dialogue: 0,0:06:28.99,0:06:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tolong beri tahu kalau tahu\Nsesuatu tentang monster itu.
Dialogue: 0,0:06:36.00,0:06:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dikurung dari awal,
Dialogue: 0,0:06:38.79,0:06:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami juga kurang tahu.
Dialogue: 0,0:06:40.34,0:06:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:06:42.10,0:06:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Keiji.
Dialogue: 0,0:06:43.34,0:06:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok, ayo pergi ke kediaman monster itu.
Dialogue: 0,0:06:47.30,0:06:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba tanyakan berapa tanduk monster itu?
Dialogue: 0,0:06:50.39,0:06:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat?
Dialogue: 0,0:06:52.30,0:06:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa tanduk monsternya? Empat?
Dialogue: 0,0:06:55.94,0:07:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, kurasa tidak sebanyak itu.
Dialogue: 0,0:07:00.15,0:07:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, aku tidak pergi.
Dialogue: 0,0:07:01.78,0:07:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:07:02.94,0:07:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuhku cuma si Bedebah.
Dialogue: 0,0:07:06.07,0:07:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iblis lain, sih, bodoh amat.
Dialogue: 0,0:07:08.80,0:07:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang menderita, lo!
Dialogue: 0,0:07:11.24,0:07:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak kasihan?
Dialogue: 0,0:07:12.93,0:07:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:15.71,0:07:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Payah! Aku salah menilaimu!
Dialogue: 0,0:07:27.93,0:07:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, di situasi begini...
Dialogue: 0,0:07:33.85,0:07:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau malah datang.
Dialogue: 0,0:07:38.15,0:07:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, waktunya tidak tepat!
Dialogue: 0,0:07:47.28,0:07:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Beliau datang!
Dialogue: 0,0:07:51.45,0:07:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master Berahi datang!
Dialogue: 0,0:07:56.96,0:08:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berahi ekstrem yang cuma keluar sekali\Natau dua kali dalam setahun ini malah datang!
Dialogue: 0,0:08:04.59,0:08:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepengin...
Dialogue: 0,0:08:06.24,0:08:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan!
Dialogue: 0,0:08:09.18,0:08:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepengin...\NDuh, kepengin!
Dialogue: 0,0:08:13.72,0:08:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izin sebentar, ya.
Dialogue: 0,0:08:16.74,0:08:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:17.89,0:08:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kamu?\NDasar cabul!
Dialogue: 0,0:08:20.27,0:08:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth, cuma kamu yang bisa\Nmenenangkan amarah Master Berahi!
Dialogue: 0,0:08:24.90,0:08:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tolong aku!
Dialogue: 0,0:08:26.15,0:08:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak jelas.\NKamu cuma berahi, kan?
Dialogue: 0,0:08:30.73,0:08:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua ayam itu sedang apa?
Dialogue: 0,0:08:33.12,0:08:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, ya?
Dialogue: 0,0:08:34.65,0:08:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok ditutup?
Dialogue: 0,0:08:35.90,0:08:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelap!
Dialogue: 0,0:08:40.03,0:08:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:41.58,0:08:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ikut membantu pembasmian iblis besok,
Dialogue: 0,0:08:45.05,0:08:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kukabulkan permintaanmu!
Dialogue: 0,0:08:48.13,0:08:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:08:50.09,0:08:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti aku harus tahan sampai besok?
Dialogue: 0,0:08:54.68,0:08:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:09:06.77,0:09:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah, pokoknya besok.
Dialogue: 0,0:09:12.28,0:09:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sebegitunya?\NNgeri banget.
Dialogue: 0,0:09:21.45,0:09:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakti.
Dialogue: 0,0:09:27.84,0:09:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berbahaya, tidurlah di toilet.
Dialogue: 0,0:09:47.20,0:09:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei?
Dialogue: 0,0:09:50.19,0:09:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak bisa tidur.
Dialogue: 0,0:09:52.45,0:09:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan itu, Sei hilang, lo.
Dialogue: 0,0:09:55.83,0:09:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:09:57.66,0:09:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tahu Sei pergi ke mana?
Dialogue: 0,0:09:59.95,0:10:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, mendatangi si monster—
Dialogue: 0,0:10:02.25,0:10:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:10:04.44,0:10:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:10:06.34,0:10:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:10:20.98,0:10:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:10:22.56,0:10:24.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu aku.
Dialogue: 0,0:10:24.17,0:10:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Sei mendatangi monster itu?
Dialogue: 0,0:10:29.84,0:10:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster itu...
Dialogue: 0,0:10:35.11,0:10:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahnya Sei.
Dialogue: 0,0:10:39.06,0:10:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, tolong dia!
Dialogue: 0,0:10:40.41,0:10:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei bisa-bisa dibunuh!
Dialogue: 0,0:10:46.25,0:10:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antar aku ke tempat monster itu.
Dialogue: 0,0:10:53.31,0:10:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu minta dimakan, ya, bocil?
Dialogue: 0,0:10:58.82,0:11:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kembalikan ayahku!
Dialogue: 0,0:11:04.37,0:11:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mainanmu boleh juga.
Dialogue: 0,0:11:05.94,0:11:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan ayahku!
Dialogue: 0,0:11:07.09,0:11:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet!
Dialogue: 0,0:11:15.57,0:11:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayah?
Dialogue: 0,0:11:18.53,0:11:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, tolong hentikan semua ini!
Dialogue: 0,0:11:23.09,0:11:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei, tinggal sedikit lagi.
Dialogue: 0,0:11:26.33,0:11:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit lagi, mimpi Ayah akan terkabul.
Dialogue: 0,0:11:31.08,0:11:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo maju!
Dialogue: 0,0:11:32.64,0:11:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus! 3-6 majulah!
Dialogue: 0,0:11:37.44,0:11:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, padahal sedikit lagi menang besar!
Dialogue: 0,0:11:41.51,0:11:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah pinjam uang lagi, ya?
Dialogue: 0,0:11:43.77,0:11:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tapi sudah habis karena judi kuda.
Dialogue: 0,0:11:47.97,0:11:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gila!
Dialogue: 0,0:11:49.15,0:11:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utangmu sudah lima juta yen lebih, tahu!
Dialogue: 0,0:11:50.86,0:11:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bayarnya?
Dialogue: 0,0:11:52.78,0:11:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kupikirkan, kok, Sei.
Dialogue: 0,0:11:55.65,0:11:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku diajak ke kasino ilegal.
Dialogue: 0,0:11:59.11,0:12:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal menang banyak di situ\Ndan utangnya pasti lunas.
Dialogue: 0,0:12:03.99,0:12:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa uangnya akan jadi modal usaha.
Dialogue: 0,0:12:07.25,0:12:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bakal kubelikan rumah\Ndengan kolam renang.
Dialogue: 0,0:12:12.29,0:12:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti bermimpi dan bekerjalah dengan giat.
Dialogue: 0,0:12:15.59,0:12:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!\NGiat bekerja mana bisa kaya!
Dialogue: 0,0:12:24.15,0:12:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei memang bocah tengik, sok tahu banget.
Dialogue: 0,0:12:27.56,0:12:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang sudi menyerah.
Dialogue: 0,0:12:31.26,0:12:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti jadi kaya suatu hari nanti.
Dialogue: 0,0:12:35.97,0:12:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:12:40.84,0:12:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:12:44.60,0:12:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:12:46.54,0:12:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah digali,
Dialogue: 0,0:12:48.08,0:12:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kotaknya berisi koin emas dan naskah kuno.
Dialogue: 0,0:12:51.71,0:12:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naskah kuno itu kupelajari secara autodidak.
Dialogue: 0,0:12:54.77,0:12:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ditafsirkan,
Dialogue: 0,0:12:56.26,0:12:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata di wilayah ini
Dialogue: 0,0:12:57.88,0:13:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terdapat harta karun\Nyang disembunyikan perampok masa lalu.
Dialogue: 0,0:13:03.94,0:13:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di masa ini, nilainya setara satu miliar yen.
Dialogue: 0,0:13:06.17,0:13:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya dewa menolongku!
Dialogue: 0,0:13:08.83,0:13:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kaya raya!
Dialogue: 0,0:13:17.74,0:13:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku mulai menggali\Nseolah dirasuki sesuatu.
Dialogue: 0,0:13:22.87,0:13:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bikin risi, tahu!\N- Cepat hentikan!
Dialogue: 0,0:13:25.24,0:13:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudahlah!\N- Menyerah saja!
Dialogue: 0,0:13:26.95,0:13:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Anakmu kasihan, tuh!\N- Harta karun!
Dialogue: 0,0:13:28.50,0:13:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karunku!
Dialogue: 0,0:13:32.12,0:13:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Setelah satu tahun menggali,\N- Seharusnya ada.
Dialogue: 0,0:13:34.21,0:13:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- harta karunnya tidak ketemu.\N- Uangku...
Dialogue: 0,0:13:36.25,0:13:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana uangku?
Dialogue: 0,0:13:40.34,0:13:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, sudahlah!
Dialogue: 0,0:13:42.73,0:13:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uangku, uangku, uangku!
Dialogue: 0,0:13:44.97,0:13:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang milikku!
Dialogue: 0,0:13:54.92,0:13:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:13:59.07,0:14:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:14:05.28,0:14:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, tolong hentikan.
Dialogue: 0,0:14:09.60,0:14:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei, kamu juga mau jadi kaya, kan?
Dialogue: 0,0:14:13.66,0:14:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,\Nkita bisa meninggalkan desa ini, lo.
Dialogue: 0,0:14:16.83,0:14:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa beli mainan dan camilan sesuka—
Dialogue: 0,0:14:18.38,0:14:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak butuh itu!
Dialogue: 0,0:14:21.88,0:14:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mau hidup tenang bersama Ayah.
Dialogue: 0,0:14:26.31,0:14:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang tidaklah penting.
Dialogue: 0,0:14:30.06,0:14:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:14:32.44,0:14:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, monster, tutup saja.
Dialogue: 0,0:14:37.31,0:14:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bocil, membual apa kamu dari tadi?
Dialogue: 0,0:14:43.14,0:14:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang, lah!
Dialogue: 0,0:14:45.48,0:14:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang itu segalanya!
Dialogue: 0,0:14:51.42,0:14:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau uang.
Dialogue: 0,0:14:55.96,0:14:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang!
Dialogue: 0,0:14:59.71,0:15:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri aku uang!
Dialogue: 0,0:15:02.33,0:15:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang! Uang!
Dialogue: 0,0:15:06.59,0:15:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau uang!
Dialogue: 0,0:15:12.47,0:15:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang!
Dialogue: 0,0:15:14.89,0:15:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia memang iblis mutan.
Dialogue: 0,0:15:16.73,0:15:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubah jadi raksasa pula.
Dialogue: 0,0:15:18.94,0:15:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian...
Dialogue: 0,0:15:20.48,0:15:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam?
Dialogue: 0,0:15:22.99,0:15:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, bedebah,\Nberhenti mengoceh soal uang.
Dialogue: 0,0:15:26.28,0:15:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin aku emosi, tahu!
Dialogue: 0,0:15:28.74,0:15:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hewan ternak berani melawanku?
Dialogue: 0,0:15:33.75,0:15:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik juga.
Dialogue: 0,0:15:37.37,0:15:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, jangan menatapnya!
Dialogue: 0,0:15:48.76,0:15:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaan, itulah yang memengaruhi warga.
Dialogue: 0,0:15:51.64,0:15:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau harta karun, cari saja sendiri!
Dialogue: 0,0:15:55.89,0:15:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyusahkan orang,\NPengangguran!
Dialogue: 0,0:15:58.27,0:16:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam kamu, lalat!
Dialogue: 0,0:16:02.27,0:16:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya memanggil lalat\Npada seorang wanita!
Dialogue: 0,0:16:06.86,0:16:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang, ang, ang, ang.
Dialogue: 0,0:16:08.86,0:16:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak terasa?
Dialogue: 0,0:16:12.41,0:16:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tegangannya kurang, ya.
Dialogue: 0,0:16:14.45,0:16:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawanmu ada di sini!
Dialogue: 0,0:16:33.01,0:16:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini, majulah dari mana pun,\Nakan kumakan kamu.
Dialogue: 0,0:16:38.94,0:16:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau aku maunya makan uang, sih.
Dialogue: 0,0:16:43.57,0:16:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:45.07,0:16:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Ternyata ritsleting dompet?
Dialogue: 0,0:16:47.99,0:16:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misteri terpecahkan.
Dialogue: 0,0:16:49.53,0:16:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:16:52.07,0:16:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasakan yang ini!
Dialogue: 0,0:16:55.08,0:16:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:16:58.66,0:16:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:16:59.54,0:17:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:05.23,0:17:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurus yang bagus.
Dialogue: 0,0:17:07.13,0:17:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi percuma kalau tidak kena.
Dialogue: 0,0:17:09.93,0:17:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang, ang, ang, ang.
Dialogue: 0,0:17:12.73,0:17:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia merepotkan!
Dialogue: 0,0:17:14.18,0:17:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam!
Dialogue: 0,0:17:16.61,0:17:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bunuh ayahku!
Dialogue: 0,0:17:22.23,0:17:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:17:23.77,0:17:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, giring iblisnya kemari!
Dialogue: 0,0:17:26.56,0:17:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:17:32.03,0:17:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:17:38.29,0:17:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, sialan!
Dialogue: 0,0:17:41.21,0:17:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, tahan dia di sini!
Dialogue: 0,0:17:43.35,0:17:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:17:54.26,0:17:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar lalat menyebalkan!
Dialogue: 0,0:18:02.35,0:18:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kumakan kamu duluan!
Dialogue: 0,0:18:13.03,0:18:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini...
Dialogue: 0,0:18:15.74,0:18:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:18:20.79,0:18:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ini cara mengalahkan ayah Sei\Ntanpa membunuhnya.
Dialogue: 0,0:18:35.45,0:18:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kurang, pakai tegangan tinggi!
Dialogue: 0,0:18:39.51,0:18:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Harta karun!
Dialogue: 0,0:18:42.43,0:18:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punggungmu terbuka lebar.
Dialogue: 0,0:18:47.31,0:18:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tubuhku...
Dialogue: 0,0:18:49.23,0:18:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, ini saatnya!
Dialogue: 0,0:18:51.74,0:18:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:18:54.05,0:18:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:18:55.57,0:18:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuruyuk!
Dialogue: 0,0:19:16.35,0:19:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:19:18.18,0:19:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok aku di sini?
Dialogue: 0,0:19:20.20,0:19:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang apa, ya?
Dialogue: 0,0:19:22.60,0:19:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggali lubang?
Dialogue: 0,0:19:25.09,0:19:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia bangun!
Dialogue: 0,0:19:29.31,0:19:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa paruhku rasa tanah?
Dialogue: 0,0:19:34.19,0:19:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth!
Dialogue: 0,0:19:39.45,0:19:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ikut membantu pembasmian iblis besok,
Dialogue: 0,0:19:42.29,0:19:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kukabulkan permintaanmu!
Dialogue: 0,0:19:47.83,0:19:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana janjimu?
Dialogue: 0,0:19:50.92,0:19:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:19:52.46,0:19:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:53.42,0:19:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lupa, ya?
Dialogue: 0,0:19:55.72,0:19:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya dendam kesumat padamu!
Dialogue: 0,0:19:58.47,0:20:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cowok sepertimu,\Nmana mungkin kukasih jatah!
Dialogue: 0,0:20:15.30,0:20:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:20:16.86,0:20:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:20:17.78,0:20:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sei.
Dialogue: 0,0:20:24.99,0:20:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}To-Tolong aku!
Dialogue: 0,0:20:27.25,0:20:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai bertarung sia-sia\Nbahkan tidak dapat jatah.
Dialogue: 0,0:20:32.20,0:20:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini salahmu!
Dialogue: 0,0:20:34.75,0:20:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang dibutakan nafsu sepertimu\Ntidak pantas hidup!
Dialogue: 0,0:20:40.01,0:20:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah!
Dialogue: 0,0:20:50.31,0:20:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:20:52.56,0:20:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocil, kalau tidak minggir,\Nkamu juga aku sikat!
Dialogue: 0,0:20:59.70,0:21:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan, Keiji?
Dialogue: 0,0:21:01.70,0:21:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:21:03.70,0:21:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:21:07.39,0:21:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei, menyingkirlah!
Dialogue: 0,0:21:11.71,0:21:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh saja aku seorang!
Dialogue: 0,0:21:13.75,0:21:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah?
Dialogue: 0,0:21:16.69,0:21:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sampah,\Nmanusia yang tidak berguna.
Dialogue: 0,0:21:21.64,0:21:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan aku menyusahkan warga desa.
Dialogue: 0,0:21:24.88,0:21:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang pantas mati.
Dialogue: 0,0:21:28.83,0:21:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kumohon...
Dialogue: 0,0:21:31.28,0:21:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, jangan bunuh Sei!
Dialogue: 0,0:21:35.21,0:21:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia putraku yang berharga!
Dialogue: 0,0:21:39.44,0:21:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, jangan bunuh Sei!
Dialogue: 0,0:21:42.97,0:21:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:21:43.95,0:21:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, kumohon Tuan Ayam.
Dialogue: 0,0:21:49.25,0:21:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon.
Dialogue: 0,0:21:58.74,0:22:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiduplah dengan selalu mengingat perasaan itu.
Dialogue: 0,0:22:03.09,0:22:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sei, berjuanglah.
Dialogue: 0,0:22:05.00,0:22:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:22:06.95,0:22:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, sampai jumpa.
Dialogue: 0,0:22:14.23,0:22:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku manusia yang bahkan diceramahi ayam,
Dialogue: 0,0:22:18.23,0:22:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mustahil bisa kaya raya.
Dialogue: 0,0:22:22.37,0:22:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hebat juga.
Dialogue: 0,0:22:26.85,0:22:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau belum berubah juga,\Ndia memang sampah sejati.
Dialogue: 0,0:22:33.00,0:22:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, mungkin aku salah menilaimu.
Dialogue: 0,0:22:37.46,0:22:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, nih!
Dialogue: 0,0:22:39.84,0:22:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, pada akhirnya cinta yang berbicara.
Dialogue: 0,0:22:44.05,0:22:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Elizabeth, aku mencintaimu.
Dialogue: 0,0:22:49.14,0:22:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dibutakan nafsu itu...
Dialogue: 0,0:22:54.27,0:22:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu!
Dialogue: 0,0:23:02.19,0:23:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master Berahi
Dialogue: 0,0:23:04.95,0:23:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pulang.
Dialogue: 0,0:23:09.92,0:23:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku kelewatan.
Dialogue: 0,0:23:11.33,0:23:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Ayam baik-baik saja?
Dialogue: 0,0:23:14.29,0:23:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah!
Dialogue: 0,0:23:16.07,0:23:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam baik-baik saja?
Dialogue: 0,0:23:18.00,0:23:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan paksakan dirimu.
Dialogue: 0,0:23:22.01,0:23:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat video bagus, nih.
Dialogue: 0,0:23:25.73,0:23:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pasti ini bakal viral.
Dialogue: 0,0:23:39.94,0:23:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup!
Dialogue: 0,0:23:41.83,0:23:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku muak bertualang bersama kalian!
Dialogue: 0,0:23:44.57,0:23:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Ada iblis di tempat seperti ini?
Dialogue: 0,0:23:48.32,0:23:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya,
Dialogue: 0,0:23:49.20,0:23:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kumpul Bagai Hewan Buas,
Dialogue: 0,0:23:49.93,0:23:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Bubar Bagai Burung".
Dialogue: 0,0:23:50.91,0:23:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya cuma bikin emosi!
