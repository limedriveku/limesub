Dialogue: 0,0:03:48.88,0:03:51.96,tanda,,0000,0000,0000,,EPISODE TUJUH: KOKOK HEBOH NIHIL HASIL
Dialogue: 0,0:14:18.67,0:14:19.42,tanda,,0000,0000,0000,,TUMIS IKAN PUTIH\NDENGAN SAUS SAYURAN DUA WARNA
Dialogue: 0,0:14:19.42,0:14:21.17,tanda,,0000,0000,0000,,DAN HIASAN DANDELION
Dialogue: 0,0:17:07.01,0:17:13.76,tanda,,0000,0000,0000,,BAKTI
Dialogue: 0,0:21:24.18,0:21:28.93,tanda,,0000,0000,0000,,BAKTI
Dialogue: 0,0:23:48.51,0:23:54.83,tanda,,0000,0000,0000,,EPISODE DELAPAN: AYAM TIDAK BERDAYA
Dialogue: 0,0:23:54.83,0:24:04.16,tanda,,0000,0000,0000,,PENGHARGAAN KONTES SENI PENGGEMAR
Dialogue: 0,0:00:02.23,0:00:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:00:19.28,0:00:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu barusan?
Dialogue: 0,0:00:28.51,0:00:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kakak.
Dialogue: 0,0:00:31.20,0:00:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahku.
Dialogue: 0,0:00:32.54,0:00:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan salahmu, tenang saja.
Dialogue: 0,0:00:35.52,0:00:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat berniat menolong Kakak,
Dialogue: 0,0:00:38.55,0:00:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuhku mengeluarkan api.
Dialogue: 0,0:00:41.64,0:00:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kena penyakit?
Dialogue: 0,0:00:43.94,0:00:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak sakit!
Dialogue: 0,0:00:46.55,0:00:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:00:48.00,0:00:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi pada Sara?
Dialogue: 0,0:00:52.53,0:00:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasibku akan bagaimana?
Dialogue: 0,0:00:56.74,0:01:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, aku takut!
Dialogue: 0,0:01:02.92,0:01:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi,\NKakak akan melindungimu.
Dialogue: 0,0:01:06.63,0:01:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir, Sara.
Dialogue: 0,0:01:12.09,0:01:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:01:16.35,0:01:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Sara!
Dialogue: 0,0:01:18.60,0:01:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:01:21.73,0:01:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sara!
Dialogue: 0,0:01:23.48,0:01:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:01:33.03,0:01:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:01:35.37,0:01:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Sara?
Dialogue: 0,0:01:40.00,0:01:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tidak menyelamatkanku?
Dialogue: 0,0:01:43.69,0:01:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya mau melindungiku?
Dialogue: 0,0:01:59.10,0:02:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, lagi-lagi mimpi ini.
Dialogue: 0,0:03:48.88,0:03:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kokok Heboh Nihil Hasil".
Dialogue: 0,0:04:09.98,0:04:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau main pasir!
Dialogue: 0,0:04:15.15,0:04:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko, Keiji itu sedang mandi pasir.
Dialogue: 0,0:04:18.07,0:04:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:18.99,0:04:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuannya untuk membersihkan parasit,\Nkutu, dan kotoran di sayap.
Dialogue: 0,0:04:23.99,0:04:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti manusia,\Nmandi biar tetap sehat.
Dialogue: 0,0:04:27.62,0:04:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:04:29.08,0:04:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu kurang cocok buatku.
Dialogue: 0,0:04:32.38,0:04:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia, semprotan antiserangga\Nkhusus ayam betina!
Dialogue: 0,0:04:36.26,0:04:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita memang wajib\Nmerawat diri dengan elegan.
Dialogue: 0,0:04:40.51,0:04:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:04:44.73,0:04:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, jangan-jangan...
Dialogue: 0,0:04:47.52,0:04:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ayam yang melawan iblis?
Dialogue: 0,0:04:50.25,0:04:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tahu?
Dialogue: 0,0:04:51.52,0:04:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga!
Dialogue: 0,0:04:52.56,0:04:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, gila!
Dialogue: 0,0:04:54.52,0:04:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menonton dari ponsel manusia.
Dialogue: 0,0:04:56.36,0:04:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bahkan tenar di kalangan merpati!
Dialogue: 0,0:04:58.61,0:05:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka bisa ketemu langsung,\Nkamu keren banget!
Dialogue: 0,0:05:03.12,0:05:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitulah.
Dialogue: 0,0:05:05.03,0:05:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi malu, nih.
Dialogue: 0,0:05:07.04,0:05:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, coba ajak dia.
Dialogue: 0,0:05:10.08,0:05:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, mana bisa?
Dialogue: 0,0:05:12.21,0:05:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya mereka keluarga.
Dialogue: 0,0:05:13.76,0:05:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja dulu!
Dialogue: 0,0:05:17.03,0:05:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu, kalau berkenan...
Dialogue: 0,0:05:21.18,0:05:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikut kencan buta, yuk!
Dialogue: 0,0:05:23.01,0:05:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan buta?
Dialogue: 0,0:05:24.55,0:05:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kegiatan manusia, kan?
Dialogue: 0,0:05:27.52,0:05:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, itu sedang tren di kalangan merpati.
Dialogue: 0,0:05:30.73,0:05:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tre-Tren?
Dialogue: 0,0:05:32.44,0:05:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu.
Dialogue: 0,0:05:33.81,0:05:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggota kami ada yang berhalangan\Nkarena mendadak harus mengirim pos.
Dialogue: 0,0:05:39.29,0:05:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berkenan,\Nmaukah kamu menggantikannya?
Dialogue: 0,0:05:42.36,0:05:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:05:43.41,0:05:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak minat sama merpati.
Dialogue: 0,0:05:45.99,0:05:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong pertimbangkan!
Dialogue: 0,0:05:47.95,0:05:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti meriah kalau kamu ikut!
Dialogue: 0,0:05:51.21,0:05:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para cewek pasti penasaran sama pahlawan!
Dialogue: 0,0:05:53.79,0:05:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, sebentar saja!
Dialogue: 0,0:05:57.42,0:05:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya seru.
Dialogue: 0,0:05:59.26,0:06:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, coba ikut sana.
Dialogue: 0,0:06:04.26,0:06:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kalau kalian memaksa.
Dialogue: 0,0:06:07.32,0:06:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar saja, ya.
Dialogue: 0,0:06:08.35,0:06:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih!
Dialogue: 0,0:06:15.98,0:06:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kok ada ayam?
Dialogue: 0,0:06:18.79,0:06:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin bete, deh!
Dialogue: 0,0:06:21.53,0:06:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Acaranya gagal total.
Dialogue: 0,0:06:23.49,0:06:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tidak sesuai ceritamu?
Dialogue: 0,0:06:26.16,0:06:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!\NKok aneh, ya?
Dialogue: 0,0:06:28.78,0:06:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak tahu?
Dialogue: 0,0:06:30.21,0:06:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pahlawan yang melawan para monster!
Dialogue: 0,0:06:32.91,0:06:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak tahu, tuh.
Dialogue: 0,0:06:35.25,0:06:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula ayam tidak bisa terbang,\Ncupu banget.
Dialogue: 0,0:06:38.84,0:06:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kukuruyuk!"\NSuaranya aneh pula.
Dialogue: 0,0:06:42.63,0:06:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menggelantung di dagunya bikin jijik.
Dialogue: 0,0:06:45.84,0:06:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani-beraninya!
Dialogue: 0,0:06:50.60,0:06:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian!
Dialogue: 0,0:06:52.52,0:06:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengejek Tuan Ayam!
Dialogue: 0,0:06:55.69,0:06:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko, tenanglah.
Dialogue: 0,0:06:57.52,0:06:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji, dengarkan aku.
Dialogue: 0,0:06:59.32,0:07:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur aku juga naik pitam\Nkarena hinaan mereka.
Dialogue: 0,0:07:03.78,0:07:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:07:05.82,0:07:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin jenggerku panas banget!
Dialogue: 0,0:07:08.72,0:07:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Keiji, hindari kekerasan.
Dialogue: 0,0:07:11.31,0:07:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kencan buta, ajang sosialisasi.
Dialogue: 0,0:07:14.21,0:07:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita cuma perlu menunjukkan\Nbetapa hebatnya seekor ayam.
Dialogue: 0,0:07:18.96,0:07:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil, kita yang menang.
Dialogue: 0,0:07:23.17,0:07:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi semuanya bergantung padaku.
Dialogue: 0,0:07:27.22,0:07:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:07:29.22,0:07:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Martabat ayam dipertaruhkan\Ndi pertarungan...
Dialogue: 0,0:07:33.00,0:07:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, di kencan ini!
Dialogue: 0,0:07:35.69,0:07:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat mereka tergila-gila\Noleh daya tarikku!
Dialogue: 0,0:07:40.73,0:07:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:41.27,0:07:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat, Tuan Ayam!
Dialogue: 0,0:07:44.11,0:07:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semangat, Tuan Ayam!\N- Kayaknya dia salah paham.
Dialogue: 0,0:07:47.38,0:07:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Semangat, Tuan Ayam!\N- Aku agak khawatir.
Dialogue: 0,0:07:50.07,0:07:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari saling berkenalan.
Dialogue: 0,0:07:52.25,0:07:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Ken.
Dialogue: 0,0:07:53.28,0:07:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Masa, salam kenal.
Dialogue: 0,0:07:57.37,0:07:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku An.
Dialogue: 0,0:07:58.54,0:07:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Seiko.
Dialogue: 0,0:07:59.63,0:08:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Marin, salam kenal.
Dialogue: 0,0:08:03.50,0:08:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku...
Dialogue: 0,0:08:04.88,0:08:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adalah...
Dialogue: 0,0:08:14.52,0:08:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji!
Dialogue: 0,0:08:17.14,0:08:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wih, Tuan Ayam keren!
Dialogue: 0,0:08:20.35,0:08:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Norak.
Dialogue: 0,0:08:21.90,0:08:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Geli.
Dialogue: 0,0:08:23.32,0:08:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jijik.
Dialogue: 0,0:08:28.01,0:08:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga bakal begini.
Dialogue: 0,0:08:32.24,0:08:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:08:34.20,0:08:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, kamu ikut balap merpati?
Dialogue: 0,0:08:36.87,0:08:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naluri pulang merpati sangat kuat.
Dialogue: 0,0:08:39.08,0:08:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbang ratusan kilo bukan masalah.
Dialogue: 0,0:08:41.46,0:08:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, waktunya unjuk gigi.
Dialogue: 0,0:08:44.56,0:08:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke.
Dialogue: 0,0:08:46.46,0:08:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayam juga keren, lo.
Dialogue: 0,0:08:49.38,0:08:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bangun pagi dan bersuara lantang.
Dialogue: 0,0:08:51.39,0:08:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berisik banget tiap pagi.
Dialogue: 0,0:08:53.64,0:08:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin risi, ya.
Dialogue: 0,0:08:55.67,0:08:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari yang lain!
Dialogue: 0,0:08:57.14,0:08:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari kami cepat!
Dialogue: 0,0:08:58.48,0:09:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih cepat terbang, lah.
Dialogue: 0,0:09:00.23,0:09:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:01.10,0:09:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak efisien.
Dialogue: 0,0:09:02.65,0:09:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul banget!
Dialogue: 0,0:09:05.40,0:09:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin besar jenggernya makin keren!
Dialogue: 0,0:09:07.78,0:09:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang butuh jengger.
Dialogue: 0,0:09:12.16,0:09:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melupakan hal buruk dalam sekejap!
Dialogue: 0,0:09:14.72,0:09:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya bukan cuma hal buruk.
Dialogue: 0,0:09:17.35,0:09:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, bego, dong?
Dialogue: 0,0:09:19.37,0:09:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bodoh minggir dulu.
Dialogue: 0,0:09:20.68,0:09:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendek akal!
Dialogue: 0,0:09:22.04,0:09:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi kepalanya cuma otot?
Dialogue: 0,0:09:23.49,0:09:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan banget.
Dialogue: 0,0:09:25.54,0:09:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel!
Dialogue: 0,0:09:35.24,0:09:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persetan dengan anggapan kalian soal ayam.
Dialogue: 0,0:09:39.00,0:09:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting adalah hidup dengan bangga!
Dialogue: 0,0:09:44.75,0:09:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memilih jalanku sendiri!
Dialogue: 0,0:09:47.69,0:09:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja.
Dialogue: 0,0:09:51.82,0:09:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren banget!
Dialogue: 0,0:09:55.57,0:09:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu ada ayam sejantan ini!
Dialogue: 0,0:09:58.62,0:10:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah yang aku cari!
Dialogue: 0,0:10:01.25,0:10:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat-lihat, ganteng juga!
Dialogue: 0,0:10:03.33,0:10:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah? Eh?
Dialogue: 0,0:10:05.27,0:10:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Entah bagaimana, ini terasa bagaikan...
Dialogue: 0,0:10:10.71,0:10:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Home run pembalik keadaan!
Dialogue: 0,0:10:15.59,0:10:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah pacarku!
Dialogue: 0,0:10:16.68,0:10:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku saja!
Dialogue: 0,0:10:17.47,0:10:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikahi aku.
Dialogue: 0,0:10:18.48,0:10:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan Ayam itu suamiku!\N- Ayo, dong!
Dialogue: 0,0:10:22.94,0:10:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi macam apa ini?
Dialogue: 0,0:10:25.48,0:10:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, jadi malu.
Dialogue: 0,0:10:27.94,0:10:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh? Waduh.\N- Nikah, yuk!
Dialogue: 0,0:10:32.45,0:10:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu hidung belang.
Dialogue: 0,0:10:36.56,0:10:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Da-Dasar pengkhianat!
Dialogue: 0,0:10:43.50,0:10:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bejat.
Dialogue: 0,0:10:44.24,0:10:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampah.
Dialogue: 0,0:10:44.83,0:10:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bajingan.
Dialogue: 0,0:10:46.00,0:10:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:10:46.97,0:10:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacau balau.
Dialogue: 0,0:10:58.76,0:11:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal tadi, aku sangat menyesal.
Dialogue: 0,0:11:03.73,0:11:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:11:05.40,0:11:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, mereka merpati.
Dialogue: 0,0:11:07.65,0:11:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini kenapa, sih?
Dialogue: 0,0:11:10.90,0:11:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elizabeth!
Dialogue: 0,0:11:11.98,0:11:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas saja kalau diulangi!
Dialogue: 0,0:11:14.40,0:11:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham, tidak?
Dialogue: 0,0:11:23.08,0:11:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, jagalah dengan benar.
Dialogue: 0,0:11:49.56,0:11:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mau bagaimana?
Dialogue: 0,0:11:51.73,0:11:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}La-Lari, Keisuke!
Dialogue: 0,0:11:59.77,0:12:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejar dia!
Dialogue: 0,0:12:00.45,0:12:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:12:01.45,0:12:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita punya sandera.
Dialogue: 0,0:12:04.58,0:12:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti kembali lagi.
Dialogue: 0,0:12:12.68,0:12:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji akan kembali untuk menolongmu!
Dialogue: 0,0:12:16.49,0:12:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, Ayah!
Dialogue: 0,0:12:23.60,0:12:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang apa, Elizabeth?
Dialogue: 0,0:12:26.43,0:12:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang membuat makan siang.
Dialogue: 0,0:12:28.60,0:12:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:12:29.52,0:12:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ikan ini!
Dialogue: 0,0:12:32.23,0:12:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirip sama yang di punggung Ayah.
Dialogue: 0,0:12:36.67,0:12:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini namanya ikan koi, Piyoko.
Dialogue: 0,0:12:39.86,0:12:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memancing?
Dialogue: 0,0:12:41.28,0:12:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:12:43.88,0:12:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mengalirkan listrik\Nke area yang mungkin ada ikannya.
Dialogue: 0,0:12:48.08,0:12:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudah, kan?
Dialogue: 0,0:12:49.21,0:12:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Canggih juga trikmu.
Dialogue: 0,0:12:51.08,0:12:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya seru.
Dialogue: 0,0:12:52.96,0:12:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau coba.
Dialogue: 0,0:12:55.21,0:12:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku juga bisa?
Dialogue: 0,0:12:58.72,0:13:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya...
Dialogue: 0,0:13:00.33,0:13:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya terlalu dini\Nbeberapa bulan buatmu.
Dialogue: 0,0:13:05.35,0:13:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma menangkap koi, aku juga bisa!
Dialogue: 0,0:13:08.73,0:13:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai ini!
Dialogue: 0,0:13:14.98,0:13:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang terlalu dini.
Dialogue: 0,0:13:17.75,0:13:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengalah dulu kali ini.
Dialogue: 0,0:13:23.29,0:13:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pas banget ada itu.
Dialogue: 0,0:13:26.12,0:13:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko, bisakah kamu memetik\Ntiga bunga dandelion di sana?
Dialogue: 0,0:13:30.46,0:13:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat hidangannya.
Dialogue: 0,0:13:32.12,0:13:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunga buat menghias hidangan, ya?
Dialogue: 0,0:13:34.38,0:13:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu perkara mudah!
Dialogue: 0,0:13:37.80,0:13:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunga, bunga.
Dialogue: 0,0:13:41.43,0:13:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak juga bunganya.
Dialogue: 0,0:13:44.57,0:13:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:45.39,0:13:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, bunga ini mungil dan imut sepertiku!
Dialogue: 0,0:13:49.81,0:13:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petik yang ini, ah!
Dialogue: 0,0:13:52.59,0:13:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko, itu memang bunga.
Dialogue: 0,0:13:55.81,0:13:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bunga inilah yang aku minta.
Dialogue: 0,0:14:01.57,0:14:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku cuma mampir!
Dialogue: 0,0:14:03.57,0:14:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga aku petik yang itu, kok!
Dialogue: 0,0:14:06.92,0:14:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu sudah dapat,\Naku balik lagi saja!
Dialogue: 0,0:14:13.64,0:14:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal bumbui garam dan merica...
Dialogue: 0,0:14:19.42,0:14:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi!
Dialogue: 0,0:14:21.17,0:14:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumis Ikan putih\Ndengan saus sayuran dua warna
Dialogue: 0,0:14:24.18,0:14:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hiasan dandelion.
Dialogue: 0,0:14:25.80,0:14:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!\NAku suka ikan!
Dialogue: 0,0:14:28.76,0:14:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa dimakan?
Dialogue: 0,0:14:30.33,0:14:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga mulutmu!
Dialogue: 0,0:14:31.31,0:14:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini pandai masak!
Dialogue: 0,0:14:34.20,0:14:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling rasanya hambar.
Dialogue: 0,0:14:41.49,0:14:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajib!
Dialogue: 0,0:14:44.03,0:14:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan saus sayuran ini?
Dialogue: 0,0:14:47.65,0:14:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa gurih ikan putih yang khas\Ndibuat jadi maksimal!
Dialogue: 0,0:14:51.41,0:14:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya jauh melampaui kenikmatan
Dialogue: 0,0:14:55.03,0:14:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat memakan belalang\Ndan katak secara bersamaan!
Dialogue: 0,0:15:00.04,0:15:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang jago.
Dialogue: 0,0:15:01.92,0:15:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita makan.
Dialogue: 0,0:15:03.63,0:15:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:15:15.14,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ikanku paling kecil?
Dialogue: 0,0:15:19.94,0:15:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?\NJelas-jelas sama!
Dialogue: 0,0:15:22.32,0:15:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NUjung yang ini tidak utuh!
Dialogue: 0,0:15:25.03,0:15:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar serakah!
Dialogue: 0,0:15:26.16,0:15:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kecil itu rasa syukurmu!
Dialogue: 0,0:15:28.51,0:15:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah untung masih kuberi!
Dialogue: 0,0:15:30.15,0:15:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri setengah lagi biar bersyukur!
Dialogue: 0,0:15:33.54,0:15:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan bercanda!\N- Berikan!
Dialogue: 0,0:15:35.54,0:15:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak akan pernah!\N- Berikan!
Dialogue: 0,0:15:37.43,0:15:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta jatah lagi!
Dialogue: 0,0:15:39.41,0:15:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan!
Dialogue: 0,0:15:41.05,0:15:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatah begituan!
Dialogue: 0,0:15:42.55,0:15:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Minta jatah! Minta makan!\N- Tuan Ayam, ambillah punyaku.
Dialogue: 0,0:15:46.43,0:15:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, makasih.
Dialogue: 0,0:15:51.14,0:15:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih kecil, tahu!
Dialogue: 0,0:15:53.52,0:15:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar berengsek!
Dialogue: 0,0:15:54.64,0:15:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajib!
Dialogue: 0,0:15:57.77,0:15:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat muntahkan!
Dialogue: 0,0:15:59.44,0:16:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa!
Dialogue: 0,0:16:04.44,0:16:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada info baru soal Iblis Putih?
Dialogue: 0,0:16:06.70,0:16:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum.
Dialogue: 0,0:16:07.95,0:16:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terakhir muncul di video itu.
Dialogue: 0,0:16:10.96,0:16:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada info baru lagi.
Dialogue: 0,0:16:14.20,0:16:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, kita cuma bisa mendatangi\Nlokasi munculnya dia.
Dialogue: 0,0:16:18.51,0:16:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu di sana ada petunjuk.
Dialogue: 0,0:16:21.91,0:16:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, masih sekitar 200 km dari sini.
Dialogue: 0,0:16:25.49,0:16:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:16:26.47,0:16:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, mana Piyoko?
Dialogue: 0,0:16:32.22,0:16:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Cuma seekor?
Dialogue: 0,0:16:34.26,0:16:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilang sepuluh ekor, kan?
Dialogue: 0,0:16:36.18,0:16:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bercanda?
Dialogue: 0,0:16:37.98,0:16:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mu-Mustahil dapat sepuluh ekor!
Dialogue: 0,0:16:40.27,0:16:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampun!
Dialogue: 0,0:16:41.73,0:16:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berani melawanku?
Dialogue: 0,0:16:44.61,0:16:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu akibatnya, kan?
Dialogue: 0,0:16:49.36,0:16:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah di sini!
Dialogue: 0,0:16:50.95,0:16:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:16:58.25,0:16:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:16:59.87,0:17:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya!
Dialogue: 0,0:17:00.75,0:17:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:17:02.38,0:17:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa diriku?
Dialogue: 0,0:17:07.01,0:17:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku anak ayam bakti!
Dialogue: 0,0:17:09.42,0:17:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas ajaran dari Ayah,
Dialogue: 0,0:17:11.44,0:17:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian tidak akan kubiarkan!
Dialogue: 0,0:17:14.59,0:17:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempurna.
Dialogue: 0,0:17:16.27,0:17:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak ayam!\NMau menantang kami?
Dialogue: 0,0:17:20.73,0:17:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kalau kamu memang...
Dialogue: 0,0:17:24.77,0:17:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin mati!
Dialogue: 0,0:17:43.96,0:17:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berbuat jahat lagi, ya.
Dialogue: 0,0:17:48.71,0:17:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, ini belum berakhir!
Dialogue: 0,0:17:54.29,0:17:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju sini kalau berani!
Dialogue: 0,0:17:56.53,0:18:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan, nih, pantat!
Dialogue: 0,0:18:01.55,0:18:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa diampuni!
Dialogue: 0,0:18:03.81,0:18:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan kuampuni!
Dialogue: 0,0:18:10.94,0:18:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:22.46,0:18:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringatan munculnya iblis.
Dialogue: 0,0:18:24.96,0:18:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Peringatan munculnya iblis.\N- Tidak!
Dialogue: 0,0:18:26.67,0:18:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Peringatan munculnya iblis.\N- Berhenti!
Dialogue: 0,0:18:28.96,0:18:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan keluar rumah karena berbahaya.\N- Jangan lari!
Dialogue: 0,0:18:33.22,0:18:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, bocah sialan!
Dialogue: 0,0:18:36.22,0:18:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah!
Dialogue: 0,0:18:39.06,0:18:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, woi!
Dialogue: 0,0:19:10.27,0:19:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah...
Dialogue: 0,0:19:30.48,0:19:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu dini 10 miliar tahun\Nuntuk menyaingiku.
Dialogue: 0,0:19:34.61,0:19:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:53.17,0:19:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:19:56.15,0:19:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko, kamu aman?
Dialogue: 0,0:20:04.60,0:20:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Piyoko?
Dialogue: 0,0:20:16.80,0:20:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku selemah ini?
Dialogue: 0,0:20:20.62,0:20:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ingin membantu Tuan Ayam\Nseperti Elizabeth,
Dialogue: 0,0:20:26.66,0:20:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ujungnya aku yang selalu ditolong.
Dialogue: 0,0:20:29.79,0:20:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ayam, ambillah punyaku.
Dialogue: 0,0:20:39.13,0:20:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:20:41.22,0:20:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma itu yang bisa kulakukan
Dialogue: 0,0:20:44.47,0:20:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai beban tidak berguna.
Dialogue: 0,0:20:49.48,0:20:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak mau\Nmerepotkan Tuan Ayam!
Dialogue: 0,0:20:58.32,0:21:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya...
Dialogue: 0,0:21:01.70,0:21:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak pantas bersama Tuan Ayam.
Dialogue: 0,0:21:11.12,0:21:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sakit perut?
Dialogue: 0,0:21:13.06,0:21:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatan bersedih.
Dialogue: 0,0:21:16.21,0:21:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keiji.
Dialogue: 0,0:21:18.64,0:21:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak kepikiran.
Dialogue: 0,0:21:21.48,0:21:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piyoko sudah hampir sebulan bersama kita.
Dialogue: 0,0:21:24.97,0:21:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia tidak tambah besar.
Dialogue: 0,0:21:28.93,0:21:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu aneh?
Dialogue: 0,0:21:32.32,0:21:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keresahan kita sama.
Dialogue: 0,0:21:41.25,0:21:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:21:43.11,0:21:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya...
Dialogue: 0,0:21:44.66,0:21:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku menemukanmu.
Dialogue: 0,0:21:47.12,0:21:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka...
Dialogue: 0,0:21:48.72,0:21:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak...
Dialogue: 0,0:21:50.92,0:21:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:21:53.21,0:21:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Barusan,
Dialogue: 0,0:21:56.96,0:21:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bilang apa?
Dialogue: 0,0:23:40.42,0:23:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini saatnya kita Klan Goshikidori tampil.
Dialogue: 0,0:23:43.99,0:23:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Keisuke, sepertinya kota ini berbahaya.
Dialogue: 0,0:23:48.51,0:23:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Ayam Tidak Berdaya".
Dialogue: 0,0:23:51.49,0:23:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan cewek!
