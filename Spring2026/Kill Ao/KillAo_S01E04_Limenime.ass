Dialogue: 0,0:02:36.03,0:02:40.03,tanda,,0000,0000,0000,,DUEL DOT BAYI\NSABTU, 2 MEI
Dialogue: 0,0:11:16.91,0:11:18.01,tanda,,0000,0000,0000,,A...
Dialogue: 0,0:11:18.31,0:11:19.41,tanda,,0000,0000,0000,,A?
Dialogue: 0,0:12:20.61,0:12:22.00,tanda,,0000,0000,0000,,AKU MENYUKAIMU. INGIN KUSAMPAIKAN LANGSUNG.\NKUTUNGGU DI HALAMAN SEPULANG SEKOLAH.
Dialogue: 0,0:16:08.77,0:16:09.17,tanda,,0000,0000,0000,,DUH...
Dialogue: 0,0:16:19.66,0:16:20.17,tanda,,0000,0000,0000,,PEMILIK SAH PULPEN DIAKUI SEBAGAI TUNANGAN
Dialogue: 0,0:19:45.97,0:19:48.52,tanda,,0000,0000,0000,,UNTUK PAPA
Dialogue: 0,0:23:27.92,0:23:28.73,tanda,,0000,0000,0000,,RUANG TATA BOGA
Dialogue: 0,0:00:02.91,0:00:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuoka!
Dialogue: 0,0:00:04.25,0:00:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren!
Dialogue: 0,0:00:05.81,0:00:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:00:07.65,0:00:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbincangan tadi...
Dialogue: 0,0:00:08.81,0:00:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjutkan, dong!
Dialogue: 0,0:00:13.77,0:00:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita berhasil kabur.
Dialogue: 0,0:00:17.11,0:00:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:00:18.18,0:00:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:00:19.01,0:00:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus aku?
Dialogue: 0,0:00:20.45,0:00:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:00:21.78,0:00:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sangat menantikan\Nkegiatan klub yang menyenangkan.
Dialogue: 0,0:00:25.45,0:00:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya jadi kacau dan membuatku stres.
Dialogue: 0,0:00:28.25,0:00:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku asal bicara saja.
Dialogue: 0,0:00:29.95,0:00:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini rencana buruk.
Dialogue: 0,0:00:31.75,0:00:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, ya.
Dialogue: 0,0:00:34.01,0:00:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi artinya misi kita sukses, 'kan?
Dialogue: 0,0:00:37.58,0:00:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:00:38.65,0:00:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertunangan dengan gadis seusia anakku...
Dialogue: 0,0:00:41.65,0:00:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik aku mati saja.
Dialogue: 0,0:00:43.41,0:00:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, aku tahu ini egois.
Dialogue: 0,0:00:46.51,0:00:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tolong berpura-puralah\Nmenjadi pacarku untuk sementara.
Dialogue: 0,0:00:50.58,0:00:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:00:51.45,0:00:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lihat sendiri tadi, 'kan?
Dialogue: 0,0:00:54.05,0:00:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan terus mengejarku\Nkalau tahu aku lajang.
Dialogue: 0,0:00:57.18,0:00:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!
Dialogue: 0,0:01:01.25,0:01:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:01:03.15,0:01:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat, ya.
Dialogue: 0,0:01:04.34,0:01:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma pura-pura.
Dialogue: 0,0:02:41.81,0:02:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belikan kami roti!
Dialogue: 0,0:02:43.55,0:02:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, jadi ini salah satu dampaknya.
Dialogue: 0,0:02:45.85,0:02:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dengar atau tidak?
Dialogue: 0,0:02:48.61,0:02:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang kau adalah pesuruhku
Dialogue: 0,0:02:50.41,0:02:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menjauhlah dari Mitsuoka Noren.
Dialogue: 0,0:02:53.11,0:02:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan pilih.
Dialogue: 0,0:02:54.45,0:02:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua-duanya pilihan buruk.
Dialogue: 0,0:03:00.19,0:03:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur!
Dialogue: 0,0:03:01.51,0:03:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih mudah kalau aku melawan,
Dialogue: 0,0:03:03.65,0:03:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi aku tidak mau kena skorsing\Natau dikeluarkan.
Dialogue: 0,0:03:07.18,0:03:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kabur saja.
Dialogue: 0,0:03:12.01,0:03:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini lantai tiga.
Dialogue: 0,0:03:21.55,0:03:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:03:32.21,0:03:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah dengar mereka berdua pacaran?
Dialogue: 0,0:03:35.81,0:03:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia jadi korban perundungan\Ncowok-cowok.
Dialogue: 0,0:03:39.38,0:03:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parah, ya.
Dialogue: 0,0:03:40.45,0:03:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan sekali.
Dialogue: 0,0:03:42.58,0:03:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang setuju menjalani\Nhubungan pura-pura ini,
Dialogue: 0,0:03:45.51,0:03:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak kusangka akan jadi begini.
Dialogue: 0,0:03:48.05,0:03:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan.
Dialogue: 0,0:03:49.95,0:03:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, ya, Oga.
Dialogue: 0,0:03:51.71,0:03:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguhan pacaran dengan Noren?
Dialogue: 0,0:03:54.18,0:03:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takada dan Baba.
Dialogue: 0,0:03:56.07,0:03:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hebat juga bisa kabur setelah dikepung.
Dialogue: 0,0:03:59.41,0:04:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lihat?
Dialogue: 0,0:04:00.58,0:04:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kalian membantuku.
Dialogue: 0,0:04:02.42,0:04:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bantu bagaimana?
Dialogue: 0,0:04:04.85,0:04:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, panggil guru.
Dialogue: 0,0:04:06.61,0:04:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Ogami bisa mengatasinya sendiri.
Dialogue: 0,0:04:10.20,0:04:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya kau berhasil lolos,\Nberarti aman, 'kan?
Dialogue: 0,0:04:13.18,0:04:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:04:13.80,0:04:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong...
Dialogue: 0,0:04:15.01,0:04:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ini mungkin akan\Nlebih berbahaya, lo.
Dialogue: 0,0:04:18.55,0:04:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:20.01,0:04:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah kita ini sekolah favorit, lo.
Dialogue: 0,0:04:24.25,0:04:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini saja banyak
Dialogue: 0,0:04:26.01,0:04:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cowok spek dewa.
Dialogue: 0,0:04:27.98,0:04:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma itu.
Dialogue: 0,0:04:30.15,0:04:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara mereka, ada tipe berbahaya.
Dialogue: 0,0:04:32.45,0:04:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dikenal sebagai "Unicorn".
Dialogue: 0,0:04:35.21,0:04:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon kepribadian dan penampilan\Nmereka nyaris sempurna,
Dialogue: 0,0:04:38.65,0:04:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta punya bakat kelas dunia\Ndan karisma di bidangnya masing-masing.
Dialogue: 0,0:04:44.05,0:04:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua juga mengincar Noren.
Dialogue: 0,0:04:48.31,0:04:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti akan memburumu.
Dialogue: 0,0:04:50.85,0:04:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu terjadi...
Dialogue: 0,0:04:52.35,0:04:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah.
Dialogue: 0,0:04:53.71,0:04:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:04:56.41,0:04:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya menyerah saja
Dialogue: 0,0:04:58.95,0:05:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi pacarnya?
Dialogue: 0,0:05:00.55,0:05:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:01.35,0:05:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang,
Dialogue: 0,0:05:02.35,0:05:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak berniat menikahi Noren, 'kan?
Dialogue: 0,0:05:05.18,0:05:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:05:06.95,0:05:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita hentikan saja misinya.
Dialogue: 0,0:05:09.65,0:05:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang kasihan kepadanya, tapi...
Dialogue: 0,0:05:13.35,0:05:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar banyak kabar merepotkan\Ntentang pekerjaan ini.
Dialogue: 0,0:05:17.04,0:05:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Resep rahasia lebah buatan\NFarmasi Mitsuoka,
Dialogue: 0,0:05:21.61,0:05:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak yang mengincarnya.
Dialogue: 0,0:05:24.95,0:05:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kekerasan atau cara licik\Ntidak akan berhasil.
Dialogue: 0,0:05:28.85,0:05:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, akan ada banyak\Nanak SMP berbakat kiriman organisasi lain.
Dialogue: 0,0:05:36.25,0:05:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua demi menjadi tunangan sah Noren.
Dialogue: 0,0:05:40.51,0:05:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, dia bakal jadi\Nrebutan semua orang,
Dialogue: 0,0:05:45.51,0:05:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik oleh Unicorn maupun\Npembunuh bayaran dari organisasi.
Dialogue: 0,0:05:49.81,0:05:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih mau lanjut, Bang?
Dialogue: 0,0:05:57.15,0:05:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:58.18,0:06:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacaran bohongannya sampai sini saja.
Dialogue: 0,0:06:01.81,0:06:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah merepotkanmu, maaf, ya.
Dialogue: 0,0:06:05.18,0:06:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, bagaimana denganmu?
Dialogue: 0,0:06:06.98,0:06:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal, ini adalah urusan pribadiku.
Dialogue: 0,0:06:10.15,0:06:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan keluar dari Klub Tata Boga.
Dialogue: 0,0:06:13.71,0:06:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih bisa bertemu di kedai ramen.
Dialogue: 0,0:06:17.05,0:06:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan-kapan, aku ingin curhat.
Dialogue: 0,0:06:22.05,0:06:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, lagi kencan, ya?
Dialogue: 0,0:06:23.78,0:06:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas sekali.
Dialogue: 0,0:06:25.41,0:06:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur terus, Ogami.
Dialogue: 0,0:06:29.11,0:06:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang tak habis pikir, tahu.
Dialogue: 0,0:06:32.01,0:06:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang muram sepertimu jadi pacarnya?\NYang benar saja.
Dialogue: 0,0:06:34.84,0:06:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah putus.
Dialogue: 0,0:06:36.38,0:06:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti mengganggunya.
Dialogue: 0,0:06:38.61,0:06:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, benarkah? Kalau begitu,\Njadian denganku saja.
Dialogue: 0,0:06:42.01,0:06:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Tidak mau. Jangan dekat-dekat!
Dialogue: 0,0:06:46.55,0:06:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok begitu?
Dialogue: 0,0:06:47.78,0:06:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini kuat. Aku bisa melindungimu.
Dialogue: 0,0:06:51.58,0:06:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memintanya. Jangan mendekat!
Dialogue: 0,0:06:53.95,0:06:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berlagak dingin begitu.
Dialogue: 0,0:06:55.95,0:06:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, kami masih pacaran.
Dialogue: 0,0:06:58.21,0:07:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh pacar orang.
Dialogue: 0,0:07:00.85,0:07:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan dia.
Dialogue: 0,0:07:02.95,0:07:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berencana menikah?
Dialogue: 0,0:07:04.95,0:07:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gas saja! Meski banyak rintangan,\Nkita tabrak!
Dialogue: 0,0:07:08.11,0:07:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:07:09.98,0:07:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu alasan.
Dialogue: 0,0:07:12.15,0:07:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:07:13.61,0:07:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya, aku benci pria yang terus\Nmemaksa meski sudah ditolak.
Dialogue: 0,0:07:19.18,0:07:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Tua ini keras kepala.
Dialogue: 0,0:07:21.75,0:07:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik dibilang suka ikut campur\Ndaripada dikhawatirkan anak-anak.
Dialogue: 0,0:07:25.45,0:07:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun yang datang,\Njika niatnya buruk, akan kuusir semua.
Dialogue: 0,0:07:29.71,0:07:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergumam apa, sih?
Dialogue: 0,0:07:31.71,0:07:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini sudah biasa melawan orang dewasa.
Dialogue: 0,0:07:34.15,0:07:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus sadar diri!
Dialogue: 0,0:07:41.61,0:07:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju pria itu harus\Nmelindungi wanita.
Dialogue: 0,0:07:48.15,0:07:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang,
Dialogue: 0,0:07:49.71,0:07:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mending kau latihan lagi, deh.
Dialogue: 0,0:07:54.08,0:07:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami?
Dialogue: 0,0:07:59.65,0:08:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami...
Dialogue: 0,0:08:02.15,0:08:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pacaran sedikit lebih lama.
Dialogue: 0,0:08:04.98,0:08:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menikmati ramen lezat itu\Ntanpa mendengarmu mengeluh.
Dialogue: 0,0:08:08.75,0:08:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:11.03,0:08:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalimat "jangan sentuh pacar orang",\Naku sampai bergidik.
Dialogue: 0,0:08:16.71,0:08:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaya bicaramu bukan seperti anak SMP.
Dialogue: 0,0:08:21.18,0:08:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:08:22.61,0:08:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu pacar Mitsuoka Noren.
Dialogue: 0,0:08:27.05,0:08:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari gerak-geriknya,\Nsepertinya dia seorang profesional.
Dialogue: 0,0:08:34.38,0:08:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia lawan tangguh.
Dialogue: 0,0:08:37.40,0:08:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rival cinta di pekerjaan ini.
Dialogue: 0,0:09:04.95,0:09:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh hebat.
Dialogue: 0,0:09:06.81,0:09:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan andal di usia muda.
Dialogue: 0,0:09:09.75,0:09:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adalah yang terbaik di organisasi.
Dialogue: 0,0:09:12.91,0:09:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:15.51,0:09:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini misimu selanjutnya.
Dialogue: 0,0:09:17.95,0:09:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Targetnya adalah murid kelas 1 SMP,\NMitsuoka Noren.
Dialogue: 0,0:09:21.45,0:09:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus menjadi tunangannya.
Dialogue: 0,0:09:23.95,0:09:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengandalkanmu, Baby-Face Baby.
Dialogue: 0,0:09:29.98,0:09:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ogami.
Dialogue: 0,0:09:33.01,0:09:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aslinya kau sangat kuat, ya?
Dialogue: 0,0:09:36.18,0:09:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.\NAku tidak pernah berkelahi.
Dialogue: 0,0:09:39.85,0:09:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pernah sekali pun.
Dialogue: 0,0:09:41.61,0:09:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?
Dialogue: 0,0:09:43.45,0:09:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang kemarin kelihatan kuat, lo.
Dialogue: 0,0:09:47.61,0:09:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma kebetulan.
Dialogue: 0,0:09:49.76,0:09:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia biasa saja,\Nhanya penampilannya yang garang.
Dialogue: 0,0:09:53.55,0:09:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja?
Dialogue: 0,0:09:54.51,0:09:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau lebih terbiasa\Ndengan yang tidak biasa, ya?
Dialogue: 0,0:09:58.25,0:09:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:09:59.71,0:10:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak.
Dialogue: 0,0:10:01.05,0:10:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang diprovokasi anak SMP.
Dialogue: 0,0:10:03.78,0:10:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:10:05.31,0:10:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang memintamu jadi pacarku,\Njadi kau tak perlu merahasiakannya.
Dialogue: 0,0:10:09.81,0:10:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pura-pura pacaran ini...
Dialogue: 0,0:10:13.11,0:10:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin, tiba-tiba\NPapa mengirimkanku sesuatu.
Dialogue: 0,0:10:18.81,0:10:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulpen?
Dialogue: 0,0:10:21.55,0:10:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti.
Dialogue: 0,0:10:23.35,0:10:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, "Berikan ini ke pacarmu,\Nsi Ogami itu."
Dialogue: 0,0:10:27.05,0:10:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:28.41,0:10:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:10:33.78,0:10:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia keren, ya.
Dialogue: 0,0:10:35.55,0:10:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi sekali.
Dialogue: 0,0:10:37.18,0:10:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakinya panjang sekali.
Dialogue: 0,0:10:38.81,0:10:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilannya juga bagus.
Dialogue: 0,0:10:41.61,0:10:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku perkenalkan murid pindahan baru.
Dialogue: 0,0:10:46.65,0:10:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang.
Dialogue: 0,0:10:48.51,0:10:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:49.71,0:10:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid pindahan di saat seperti ini,
Dialogue: 0,0:10:51.98,0:10:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aura ini...
Dialogue: 0,0:10:53.75,0:10:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia datang juga.
Dialogue: 0,0:10:56.51,0:11:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang kiriman organisasi\Nuntuk bertunangan dengan Noren.
Dialogue: 0,0:11:00.38,0:11:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan seprofesi.
Dialogue: 0,0:11:02.11,0:11:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Kohazame Shin.
Dialogue: 0,0:11:05.96,0:11:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mohon bantuannya, ya.\N- Dapat teman tampan.
Dialogue: 0,0:11:07.48,0:11:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh beda sama Oga,\Ntak sebanding sama sekali.
Dialogue: 0,0:11:10.95,0:11:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan perkenalkan dirimu.
Dialogue: 0,0:11:19.85,0:11:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duc... ku...
Dialogue: 0,0:11:23.01,0:11:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duck?
Dialogue: 0,0:11:24.98,0:11:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uh, ah... em...
Dialogue: 0,0:11:26.51,0:11:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Sal... ken...
Dialogue: 0,0:11:35.55,0:11:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu gugup sampai tak bisa bicara.
Dialogue: 0,0:11:39.61,0:11:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, cukup perkenalannya.
Dialogue: 0,0:11:42.41,0:11:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangkumu di sebelah Mitsuoka.
Dialogue: 0,0:11:47.95,0:11:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:11:58.18,0:11:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut banget!
Dialogue: 0,0:11:59.71,0:12:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda jauh dengan fotonya!
Dialogue: 0,0:12:02.71,0:12:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, aku terlalu gugup menyapanya.
Dialogue: 0,0:12:06.65,0:12:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku bisa merebut hati\Ngadis cantik ini.
Dialogue: 0,0:12:09.91,0:12:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini pekerjaan, aku harus bisa.
Dialogue: 0,0:12:12.15,0:12:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar bisa bicara tanpa gugup,\Ncuma "itu" caranya.
Dialogue: 0,0:12:18.18,0:12:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:19.78,0:12:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surat?
Dialogue: 0,0:12:22.05,0:12:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh!
Dialogue: 0,0:12:23.05,0:12:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sama sekali tidak berusaha.
Dialogue: 0,0:12:30.18,0:12:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, orang tampan pasti diistimewakan, ya.
Dialogue: 0,0:12:36.55,0:12:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba kau dapat surat cinta.
Dialogue: 0,0:12:39.15,0:12:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya aku boleh ikut?
Dialogue: 0,0:12:41.38,0:12:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku.
Dialogue: 0,0:12:42.51,0:12:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tugas seorang pacar.
Dialogue: 0,0:12:44.71,0:12:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau sudah punya pacar.
Dialogue: 0,0:12:46.85,0:12:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau akan mengajaknya,\Naku jadi kesulitan.
Dialogue: 0,0:12:51.15,0:12:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:52.25,0:12:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu suara Kohazame,\Ntapi pembawaannya beda sekali.
Dialogue: 0,0:12:57.61,0:13:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar! Apa itu?
Dialogue: 0,0:13:00.18,0:13:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dot bayi.
Dialogue: 0,0:13:01.51,0:13:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan masker, tahu.\NSantai sekali bicaranya.
Dialogue: 0,0:13:03.98,0:13:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah membuat kaget.
Dialogue: 0,0:13:05.85,0:13:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gampang sekali gugup.
Dialogue: 0,0:13:08.00,0:13:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi lebih tenang\Njika bersikap seperti bayi.
Dialogue: 0,0:13:10.41,0:13:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengakuinya dengan santai.
Dialogue: 0,0:13:12.98,0:13:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, sih, di dunia gelap\Nbanyak yang aneh-aneh.
Dialogue: 0,0:13:15.65,0:13:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gila juga.
Dialogue: 0,0:13:17.11,0:13:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelnya sudah beda.
Dialogue: 0,0:13:18.75,0:13:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, soal surat cintaku,\Nmari kita lanjutkan.
Dialogue: 0,0:13:22.81,0:13:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berpacaran dengan Ogami.
Dialogue: 0,0:13:25.91,0:13:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:13:27.05,0:13:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku ingin mengatakannya.
Dialogue: 0,0:13:30.18,0:13:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cinta pada pandangan pertama.
Dialogue: 0,0:13:32.51,0:13:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:13:34.15,0:13:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serakah sekali.
Dialogue: 0,0:13:35.85,0:13:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau punya pacar.
Dialogue: 0,0:13:37.81,0:13:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, beri aku kesempatan.
Dialogue: 0,0:13:41.71,0:13:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matanya indah juga.
Dialogue: 0,0:13:44.81,0:13:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku bergetar hanya dengan menatapnya.
Dialogue: 0,0:13:48.41,0:13:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma wajahnya tampan,
Dialogue: 0,0:13:52.35,0:13:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ada daya tarik tersendiri.
Dialogue: 0,0:13:56.35,0:13:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:13:57.78,0:13:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dot itu...
Dialogue: 0,0:13:59.75,0:14:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih pakai dot.\NLagi pula, masih banyak masalah lainnya.
Dialogue: 0,0:14:03.18,0:14:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini...
Dialogue: 0,0:14:04.85,0:14:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau ini? Bodoh!
Dialogue: 0,0:14:09.05,0:14:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, sepertinya\Nkau tidak sungguh-sungguh, 'kan?
Dialogue: 0,0:14:12.81,0:14:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku tak percaya cinta pertama,\Nmemang ada yang bisa tiba-tiba suka.
Dialogue: 0,0:14:17.45,0:14:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu masalahnya.
Dialogue: 0,0:14:18.98,0:14:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang membuatku kesal adalah\Npernyataan yang dipaksakan.
Dialogue: 0,0:14:22.91,0:14:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang muak,
Dialogue: 0,0:14:24.61,0:14:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi yang menyatakan dengan tulus,\Nakan kutolak baik-baik.
Dialogue: 0,0:14:29.41,0:14:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang main-main dan meremehkan\Nperasaan orang lain, akan kuhajar.
Dialogue: 0,0:14:36.47,0:14:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:14:39.98,0:14:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jujur sekali.
Dialogue: 0,0:14:41.51,0:14:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita kuat.
Dialogue: 0,0:14:42.51,0:14:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi makin suka.
Dialogue: 0,0:14:47.38,0:14:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak baik.
Dialogue: 0,0:14:48.65,0:14:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dimanjakan gadis seperti ini,
Dialogue: 0,0:14:49.95,0:14:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mati pun aku rela.
Dialogue: 0,0:14:54.71,0:14:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sungguh minta maaf.
Dialogue: 0,0:14:57.91,0:14:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar katamu.
Dialogue: 0,0:15:00.41,0:15:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu, kali ini aku serius.
Dialogue: 0,0:15:02.78,0:15:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa melihat keseriusanku\Nkali ini.
Dialogue: 0,0:15:07.05,0:15:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pacarmu...
Dialogue: 0,0:15:09.01,0:15:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Ogami.
Dialogue: 0,0:15:10.21,0:15:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami.
Dialogue: 0,0:15:14.31,0:15:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat tiba-tiba!
Dialogue: 0,0:15:16.51,0:15:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan dia ada di belakang?
Dialogue: 0,0:15:18.01,0:15:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga orang dari organisasi, ya?
Dialogue: 0,0:15:20.11,0:15:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak berharap banyak\Ndengan pengakuan cinta ini.
Dialogue: 0,0:15:22.58,0:15:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal itu cuma iseng saja.
Dialogue: 0,0:15:24.78,0:15:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatnya mau meninggalkan kesan,\Nlalu perlahan mendekati.
Dialogue: 0,0:15:28.95,0:15:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku berubah pikiran.
Dialogue: 0,0:15:33.11,0:15:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk memperebutkan posisi tunangan Noren,
Dialogue: 0,0:15:35.81,0:15:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo duel.
Dialogue: 0,0:15:37.38,0:15:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Duel?
Dialogue: 0,0:15:39.01,0:15:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulpen itu
Dialogue: 0,0:15:40.41,0:15:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah bukti resmi sebagai tunangan.
Dialogue: 0,0:15:45.58,0:15:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada duel yang diajukan,\Nwajib diterima.
Dialogue: 0,0:15:50.31,0:15:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panduannya sudah diumumkan.
Dialogue: 0,0:15:53.15,0:15:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:15:54.71,0:15:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan?
Dialogue: 0,0:15:56.78,0:15:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalah, otomatis pacarnya berganti?
Dialogue: 0,0:16:00.44,0:16:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin rumit saja.
Dialogue: 0,0:16:04.11,0:16:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau mau segera merebutnya dariku?
Dialogue: 0,0:16:07.60,0:16:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:16:09.21,0:16:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh.
Dialogue: 0,0:16:10.75,0:16:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan Noren padaku.
Dialogue: 0,0:16:13.01,0:16:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tertarik dengan duel begituan.
Dialogue: 0,0:16:15.55,0:16:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi takkan kuserahkan Noren.
Dialogue: 0,0:16:17.71,0:16:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu gila.
Dialogue: 0,0:16:20.21,0:16:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, yang memegang pulpen terakhir\Nitulah yang jadi tunangan?
Dialogue: 0,0:16:26.21,0:16:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat juga. Semangat, ya, Oga.
Dialogue: 0,0:16:29.38,0:16:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan lelucon.
Dialogue: 0,0:16:30.85,0:16:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren, apa kabar?
Dialogue: 0,0:16:33.21,0:16:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarku tidak baik.
Dialogue: 0,0:16:35.61,0:16:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci diperebutkan, dan makin kesal\Nkalau hidupku diusik. Aku mau muntah!
Dialogue: 0,0:16:40.78,0:16:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami cuma berpura-pura jadi pacarku.
Dialogue: 0,0:16:44.18,0:16:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari awal aku tak berniat\Nberpacaran dengan siapa pun.
Dialogue: 0,0:16:47.45,0:16:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami.
Dialogue: 0,0:16:49.11,0:16:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Master.
Dialogue: 0,0:16:51.15,0:16:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah telanjur terlibat.
Dialogue: 0,0:16:53.21,0:16:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan kalah, apa pun pertandingannya.
Dialogue: 0,0:16:58.18,0:17:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada duel memperebutkan\NMitsuoka Noren.
Dialogue: 0,0:17:01.05,0:17:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumor internet itu?
Dialogue: 0,0:17:02.75,0:17:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila, sungguhan ada?
Dialogue: 0,0:17:05.31,0:17:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Durasinya satu jam.
Dialogue: 0,0:17:06.95,0:17:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aturannya sederhana,\Naku harus membuatmu memakai dot ini.
Dialogue: 0,0:17:10.10,0:17:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau bertahan sampai waktu habis,\Nkau yang menang.
Dialogue: 0,0:17:16.10,0:17:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan macam apa ini?
Dialogue: 0,0:17:17.78,0:17:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dot bayi?
Dialogue: 0,0:17:18.84,0:17:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:17:19.91,0:17:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:17:20.98,0:17:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia memakai dot?
Dialogue: 0,0:17:23.98,0:17:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu, Noren.
Dialogue: 0,0:17:26.05,0:17:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak main-main.
Dialogue: 0,0:17:27.60,0:17:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalau aku memenangkan duel ini,
Dialogue: 0,0:17:30.75,0:17:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong elus kepalaku
Dialogue: 0,0:17:32.01,0:17:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak baik.
Dialogue: 0,0:17:33.31,0:17:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan biarkan aku tidur di pangkuanmu.
Dialogue: 0,0:17:34.38,0:17:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, itu mustahil terjadi.
Dialogue: 0,0:17:38.75,0:17:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita mulai.
Dialogue: 0,0:17:40.55,0:17:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini penghitung waktunya.
Dialogue: 0,0:17:43.41,0:17:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke. Ayo mulai.
Dialogue: 0,0:17:45.56,0:17:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai.
Dialogue: 0,0:17:50.35,0:17:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang!
Dialogue: 0,0:17:51.45,0:17:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bersiap, tapi ini bahaya.
Dialogue: 0,0:17:53.41,0:17:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski penampilannya begitu,
Dialogue: 0,0:17:54.71,0:17:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemampuannya memang nyata.
Dialogue: 0,0:17:56.81,0:17:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dimulai!
Dialogue: 0,0:17:57.83,0:17:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:18:01.35,0:18:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini sangat gila?
Dialogue: 0,0:18:03.75,0:18:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus menyembunyikan identitasmu!
Dialogue: 0,0:18:06.75,0:18:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Durasinya satu jam.
Dialogue: 0,0:18:08.21,0:18:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhentilah menghindar!
Dialogue: 0,0:18:10.31,0:18:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa selamat dari serangannya\Ntandanya kita hebat.
Dialogue: 0,0:18:14.41,0:18:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:18:15.35,0:18:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil menghindar!
Dialogue: 0,0:18:16.55,0:18:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gesit sekali!
Dialogue: 0,0:18:18.85,0:18:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sebelum jadi seperti sekarang,\Nlama tak berhadapan musuh selevel ini.
Dialogue: 0,0:18:22.98,0:18:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang kuat.
Dialogue: 0,0:18:24.78,0:18:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:18:26.21,0:18:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai pakai dot, langsung kalah.
Dialogue: 0,0:18:28.98,0:18:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan, sih?
Dialogue: 0,0:18:42.41,0:18:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ditolak Noren, aku merenung.
Dialogue: 0,0:18:45.11,0:18:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perbedaan kita?
Dialogue: 0,0:18:48.25,0:18:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyadarinya.
Dialogue: 0,0:18:50.21,0:18:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bedanya ada di... bayi atau bukan bayi.
Dialogue: 0,0:18:53.81,0:18:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau ini?
Dialogue: 0,0:19:06.71,0:19:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus memakainya dulu baru paham.
Dialogue: 0,0:19:09.85,0:19:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita sama-sama jadi "bayi",\Naku pasti lebih unggul.
Dialogue: 0,0:19:14.21,0:19:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti ucapannya.
Dialogue: 0,0:19:18.15,0:19:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, aku sungguh mencintai Noren.
Dialogue: 0,0:19:21.98,0:19:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa cintamu kepadanya lebih besar\Ndaripada cintaku?
Dialogue: 0,0:19:25.18,0:19:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku pada Noren?
Dialogue: 0,0:19:27.18,0:19:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku...
Dialogue: 0,0:19:29.05,0:19:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada. Sama sekali.
Dialogue: 0,0:19:33.15,0:19:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan ini karena telanjur\Nmenerima tantangannya.
Dialogue: 0,0:19:37.11,0:19:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kalaupun kalah, mau bagaimana lagi.
Dialogue: 0,0:19:40.65,0:19:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:19:48.58,0:19:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa...
Dialogue: 0,0:19:49.58,0:19:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan begitu.
Dialogue: 0,0:19:52.35,0:19:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sedikit perasaan.
Dialogue: 0,0:19:55.55,0:19:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa semenit lagi.
Dialogue: 0,0:19:59.75,0:20:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mereka!
Dialogue: 0,0:20:00.52,0:20:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sana!
Dialogue: 0,0:20:05.38,0:20:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilempar!
Dialogue: 0,0:20:06.54,0:20:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai?
Dialogue: 0,0:20:07.85,0:20:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dengan ini selesai sudah.
Dialogue: 0,0:20:10.31,0:20:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:20:17.45,0:20:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah bilang dotnya cuma satu.
Dialogue: 0,0:20:20.18,0:20:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jebakan!
Dialogue: 0,0:20:21.15,0:20:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali, beterbangan pula.
Dialogue: 0,0:20:29.05,0:20:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sengaja menyisakan jalan mundur.
Dialogue: 0,0:20:32.51,0:20:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di titik pendaratan ada perangkap.
Dialogue: 0,0:20:34.61,0:20:35.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia sampai menginjaknya,
Dialogue: 0,0:20:35.98,0:20:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu akan memicu perangkapnya.
Dialogue: 0,0:20:36.85,0:20:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ujung perangkap itu...
Dialogue: 0,0:20:38.85,0:20:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada dot.
Dialogue: 0,0:20:41.38,0:20:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin ditangkis!
Dialogue: 0,0:20:43.11,0:20:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung menuju mulutnya.
Dialogue: 0,0:20:49.45,0:20:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terhenti?
Dialogue: 0,0:20:50.61,0:20:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:57.41,0:20:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisau ukir dari ruang seni.
Dialogue: 0,0:21:00.41,0:21:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dia melompat ke belakang,
Dialogue: 0,0:21:02.45,0:21:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia melemparnya.
Dialogue: 0,0:21:06.25,0:21:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil bertahan selama satu jam.
Dialogue: 0,0:21:08.38,0:21:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi yang terakhir bagaimana caranya?
Dialogue: 0,0:21:09.98,0:21:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemenangan untuk Ogami!
Dialogue: 0,0:21:12.95,0:21:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:21:14.11,0:21:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cintaku padanya
Dialogue: 0,0:21:16.01,0:21:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa-bisanya kalah.
Dialogue: 0,0:21:18.31,0:21:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:21:19.75,0:21:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu perasaanku\Nlebih besar darimu atau tidak,
Dialogue: 0,0:21:23.11,0:21:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku juga punya perasaan untuk Noren.
Dialogue: 0,0:21:26.98,0:21:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuknya mungkin jauh berbeda.
Dialogue: 0,0:21:30.65,0:21:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru saja aku sadar.
Dialogue: 0,0:21:32.78,0:21:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sadar aku memproyeksikan putriku,\NKozue, ke dalam diri Noren.
Dialogue: 0,0:21:37.45,0:21:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal-hal yang tak bisa kulakukan\Nuntuk Kozue,
Dialogue: 0,0:21:40.51,0:21:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin ini cuma bentuk keegoisanku.
Dialogue: 0,0:21:42.81,0:21:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap saja, aku tidak ingin\NNoren tidak bahagia.
Dialogue: 0,0:23:21.25,0:23:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatan sedih.
Dialogue: 0,0:23:25.45,0:23:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan repot kalau dia mengajak duel.
Dialogue: 0,0:23:28.78,0:23:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:23:30.15,0:23:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid pindahan,
Dialogue: 0,0:23:32.15,0:23:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohazame Shin.
Dialogue: 0,0:23:34.89,0:23:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:23:35.65,0:23:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan menyerah, Noren!
Dialogue: 0,0:23:37.96,0:23:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong menyerahlah.
