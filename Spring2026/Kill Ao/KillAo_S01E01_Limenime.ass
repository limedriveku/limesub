Dialogue: 0,0:09:01.31,0:09:03.77,tanda,,0000,0000,0000,,SAATNYA PERGI KE SEKOLAH
Dialogue: 0,0:09:03.77,0:09:05.31,tanda,,0000,0000,0000,,SABTU, 11 APRIL
Dialogue: 0,0:13:59.31,0:14:02.98,tanda,,0000,0000,0000,,PETUNJUK PENGGUNAAN: CARA MEMAKAI MIKROSKOP
Dialogue: 0,0:14:17.51,0:14:18.50,tanda,,0000,0000,0000,,DEWA BELAJAR
Dialogue: 0,0:17:18.91,0:17:20.56,tanda,,0000,0000,0000,,"HIDRAN"
Dialogue: 0,0:17:30.23,0:17:33.28,tanda,,0000,0000,0000,,"BAHASA NASIONAL 1"
Dialogue: 0,0:19:27.43,0:19:27.92,tanda,,0000,0000,0000,,ORANG MESUM DITANGKAP DI SEKOLAH.
Dialogue: 0,0:20:38.11,0:20:39.77,tanda,,0000,0000,0000,,KELAS 1-E
Dialogue: 0,0:00:20.75,0:00:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menuju ke sana.
Dialogue: 0,0:00:23.35,0:00:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali\Nkita tak dapat banyak informasi.
Dialogue: 0,0:00:26.11,0:00:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kita tahu ada dua orang penjaga.
Dialogue: 0,0:00:29.98,0:00:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mudah.
Dialogue: 0,0:00:31.51,0:00:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:00:32.65,0:00:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasinya memang baru,
Dialogue: 0,0:00:35.11,0:00:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi sudah kukonfirmasi.
Dialogue: 0,0:00:37.45,0:00:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:00:38.78,0:00:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hubungi tim terkait.
Dialogue: 0,0:00:40.91,0:00:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:00:52.51,0:00:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kehilangan target.
Dialogue: 0,0:00:54.41,0:00:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tak ada untungnya bagi kita.
Dialogue: 0,0:00:56.86,0:00:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kau bakal dihajar, lo.
Dialogue: 0,0:01:01.09,0:01:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Siapa kau?
Dialogue: 0,0:01:12.78,0:01:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa kau?
Dialogue: 0,0:01:17.78,0:01:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Pak Tua!
Dialogue: 0,0:01:19.58,0:01:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tanya, siapa kau?
Dialogue: 0,0:01:24.51,0:01:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:01:28.73,0:01:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:01:40.95,0:01:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa targetnya?
Dialogue: 0,0:01:42.75,0:01:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas, 'kan?
Dialogue: 0,0:01:44.91,0:01:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:01:45.85,0:01:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membasmi penjahat.
Dialogue: 0,0:01:48.17,0:01:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:02:03.67,0:02:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:02:07.18,0:02:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang macam apa dia?
Dialogue: 0,0:02:08.65,0:02:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama harganya cocok,\Nsiapa pun bisa dia bunuh.
Dialogue: 0,0:02:15.18,0:02:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal harganya cocok?
Dialogue: 0,0:02:16.95,0:02:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru dengar.
Dialogue: 0,0:02:18.86,0:02:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya menghabisi orang jahat.
Dialogue: 0,0:02:22.71,0:02:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:02:24.37,0:02:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:02:25.78,0:02:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ampuni aku...
Dialogue: 0,0:02:28.04,0:02:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati kau!
Dialogue: 0,0:02:52.49,0:02:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua puluh lima orang, ya.
Dialogue: 0,0:02:54.98,0:02:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang hebat, Bang.
Dialogue: 0,0:02:56.75,0:02:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nekota Kotatsu.
Dialogue: 0,0:02:58.15,0:02:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:02:58.86,0:03:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kau bilang hanya ada\Ndua orang penjaga, 'kan?
Dialogue: 0,0:03:05.18,0:03:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:03:07.18,0:03:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, kau sukses, 'kan?
Dialogue: 0,0:03:10.05,0:03:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang legendaris.
Dialogue: 0,0:03:13.01,0:03:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan sanjunganmu,\Natau kerja sama kita batal.
Dialogue: 0,0:03:16.15,0:03:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:03:19.45,0:03:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya hanya sebegini.
Dialogue: 0,0:03:23.45,0:03:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sarang lebah?
Dialogue: 0,0:03:25.71,0:03:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, boleh aku menumpang pulang?
Dialogue: 0,0:03:29.31,0:03:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:03:31.11,0:03:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mampir makan dulu, ya.
Dialogue: 0,0:03:33.21,0:03:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap.
Dialogue: 0,0:03:35.21,0:03:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pesanannya.
Dialogue: 0,0:03:47.38,0:03:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lidahnya sensitif, ya.
Dialogue: 0,0:03:49.45,0:03:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak sekali.
Dialogue: 0,0:03:52.25,0:03:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat suka bawang, ya.
Dialogue: 0,0:03:54.95,0:03:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu komentar. Ini biasa saja.
Dialogue: 0,0:04:04.45,0:04:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kumasukkan, ya.
Dialogue: 0,0:04:06.21,0:04:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:04:14.55,0:04:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:21.12,0:04:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:04:24.55,0:04:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak cocok dengan anak-anak.
Dialogue: 0,0:04:29.98,0:04:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mengerti anak-anak.
Dialogue: 0,0:04:34.01,0:04:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja aku akrab dengan anak-anak,
Dialogue: 0,0:04:39.21,0:04:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin nasibku takkan seperti ini.
Dialogue: 0,0:04:46.71,0:04:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebaiknya kulakukan?
Dialogue: 0,0:04:49.55,0:04:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih tak tahu.
Dialogue: 0,0:04:52.25,0:04:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal, kami tak pandai mengobrol.
Dialogue: 0,0:04:57.38,0:05:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada kesamaan hobi atau semacamnya.
Dialogue: 0,0:05:00.65,0:05:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kerja dan kerja.
Dialogue: 0,0:05:02.71,0:05:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan gila kerja, aku hanya bisa itu.
Dialogue: 0,0:05:05.91,0:05:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupku yang membosankan.
Dialogue: 0,0:05:10.91,0:05:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang!
Dialogue: 0,0:05:11.87,0:05:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuncinya kutaruh di sini, ya.
Dialogue: 0,0:05:13.94,0:05:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:05:15.81,0:05:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Numpang ke toilet sebentar.
Dialogue: 0,0:05:17.88,0:05:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sekalian bersihkan, ya.
Dialogue: 0,0:05:27.46,0:05:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebah?
Dialogue: 0,0:05:28.78,0:05:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Aku tak sadar.
Dialogue: 0,0:05:45.18,0:05:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang!
Dialogue: 0,0:05:46.78,0:05:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah!
Dialogue: 0,0:05:51.41,0:05:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kozue...
Dialogue: 0,0:05:59.27,0:06:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil, aku tak mengerti.
Dialogue: 0,0:06:02.91,0:06:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:06:04.01,0:06:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah siuman?
Dialogue: 0,0:06:05.71,0:06:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eri?
Dialogue: 0,0:06:06.81,0:06:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini...
Dialogue: 0,0:06:08.11,0:06:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, laboratoriumku.
Dialogue: 0,0:06:10.61,0:06:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau baru sadar.
Dialogue: 0,0:06:12.95,0:06:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bisa jawab pertanyaanku sebentar?
Dialogue: 0,0:06:15.71,0:06:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:17.11,0:06:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa nama lengkapmu?
Dialogue: 0,0:06:19.95,0:06:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami Juzo.
Dialogue: 0,0:06:21.78,0:06:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh bayaran di bawah naungan Z.O.O.
Dialogue: 0,0:06:24.51,0:06:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa namaku?
Dialogue: 0,0:06:25.37,0:06:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanibuchi Eri.
Dialogue: 0,0:06:26.98,0:06:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Direktur Riset Z.O.O, sekaligus
Dialogue: 0,0:06:30.55,0:06:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mantan istriku.
Dialogue: 0,0:06:31.75,0:06:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatanmu aman.
Dialogue: 0,0:06:34.65,0:06:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisi vitalmu stabil,
Dialogue: 0,0:06:36.58,0:06:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi saat tiba di sini,\Nwujudmu berubah drastis.
Dialogue: 0,0:06:39.08,0:06:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat khawatir.
Dialogue: 0,0:06:41.78,0:06:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya itu efek sengatan lebah.
Dialogue: 0,0:06:44.15,0:06:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebah?
Dialogue: 0,0:06:45.71,0:06:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, aku ingat sekarang.
Dialogue: 0,0:06:48.98,0:06:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:49.85,0:06:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasinya baru jelas sekarang.
Dialogue: 0,0:06:51.95,0:06:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya target operasi kemarin
Dialogue: 0,0:06:54.35,0:06:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah perusahaan rekayasa genetika.
Dialogue: 0,0:06:58.21,0:07:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, itu bukan lebah biasa.
Dialogue: 0,0:07:02.27,0:07:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?\NSiapa ini?
Dialogue: 0,0:07:04.25,0:07:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ini diriku?
Dialogue: 0,0:07:06.18,0:07:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku waktu remaja?
Dialogue: 0,0:07:08.89,0:07:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kembali jadi dewasa atau tidak?
Dialogue: 0,0:07:12.43,0:07:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:07:13.95,0:07:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolonglah! Kau kan genius, Eri!
Dialogue: 0,0:07:17.15,0:07:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan hal mudah.
Dialogue: 0,0:07:21.38,0:07:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus?
Dialogue: 0,0:07:22.98,0:07:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agh!
Dialogue: 0,0:07:24.38,0:07:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaraku juga berubah!
Dialogue: 0,0:07:26.01,0:07:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulitku jadi mulus lagi.
Dialogue: 0,0:07:28.18,0:07:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, dong.
Dialogue: 0,0:07:33.38,0:07:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, 'kan?
Dialogue: 0,0:07:34.51,0:07:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak.
Dialogue: 0,0:07:36.45,0:07:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jadi bisa cuti.
Dialogue: 0,0:07:38.75,0:07:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil bekerja, 'kan?
Dialogue: 0,0:07:41.05,0:07:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:07:42.11,0:07:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, dong!\NAda cicilan rumah dan mobil!
Dialogue: 0,0:07:44.71,0:07:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menafkahimu.
Dialogue: 0,0:07:45.84,0:07:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih kerja, kok. Aman.
Dialogue: 0,0:07:48.01,0:07:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teganya!
Dialogue: 0,0:07:48.82,0:07:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor saja dulu pada atasan kita.
Dialogue: 0,0:07:51.61,0:07:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, pas sekali.
Dialogue: 0,0:07:55.78,0:07:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:56.65,0:07:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar ini Juzo?
Dialogue: 0,0:07:59.61,0:08:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Suaraku berubah, tapi ini aku.
Dialogue: 0,0:08:03.05,0:08:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya hal tak biasa terjadi padamu.
Dialogue: 0,0:08:07.81,0:08:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:08:09.31,0:08:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih bisa kerja, kok.
Dialogue: 0,0:08:13.05,0:08:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang bisa diandalkan.
Dialogue: 0,0:08:15.81,0:08:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya misi yang cocok untukmu.
Dialogue: 0,0:08:19.91,0:08:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyusuplah ke sebuah SMP.
Dialogue: 0,0:08:23.65,0:08:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:24.58,0:08:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar,
Dialogue: 0,0:08:25.98,0:08:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berencana mendaftarkan putriku\Nke SMP itu,
Dialogue: 0,0:08:30.81,0:08:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku ingin kau masuk ke sana\Ndan menyelidikinya.
Dialogue: 0,0:08:34.35,0:08:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Itu urusan rumah tanggamu!
Dialogue: 0,0:08:36.35,0:08:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan pekerjaan!
Dialogue: 0,0:08:38.38,0:08:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cuma penasaran dengan SMP itu, 'kan?
Dialogue: 0,0:08:42.77,0:08:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa-apa, 'kan?
Dialogue: 0,0:08:44.58,0:08:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau cuma lulusan SD, 'kan?
Dialogue: 0,0:08:47.18,0:08:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja aku tidak mau!
Dialogue: 0,0:08:50.81,0:08:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja begitu.
Dialogue: 0,0:08:52.35,0:08:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa.
Dialogue: 0,0:08:53.18,0:08:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuatnya terdengar keren!
Dialogue: 0,0:08:55.31,0:08:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pekerjaan.
Dialogue: 0,0:08:57.18,0:08:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat upah.
Dialogue: 0,0:09:10.55,0:09:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, cocok juga.
Dialogue: 0,0:09:13.65,0:09:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti sedang cosplay.
Dialogue: 0,0:09:16.51,0:09:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa kacamata ini?
Dialogue: 0,0:09:18.11,0:09:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dilengkapi kamera dan alat komunikasi.
Dialogue: 0,0:09:20.18,0:09:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosokmu memang muda,\Ntapi kau tetaplah Pak Tua.
Dialogue: 0,0:09:23.61,0:09:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membantumu, Abang!
Dialogue: 0,0:09:25.78,0:09:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar,\Ntapi tak perlu blak-blakan begitu.
Dialogue: 0,0:09:31.62,0:09:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:09:33.38,0:09:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah jadi remaja,\Npadahal aku tak cocok dengan anak-anak.
Dialogue: 0,0:09:37.65,0:09:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini pekerjaan. Pantang mengeluh.
Dialogue: 0,0:09:41.91,0:09:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, kalian resmi menjadi\Nmurid SMP Rikka.
Dialogue: 0,0:09:47.18,0:09:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid-muridku...
Dialogue: 0,0:09:48.78,0:09:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bergabung dengan Klub Basket.
Dialogue: 0,0:09:51.95,0:09:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:09:54.51,0:09:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia keren, ya.
Dialogue: 0,0:09:56.41,0:09:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:57.65,0:09:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, lanjut!
Dialogue: 0,0:10:00.55,0:10:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:10:02.75,0:10:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Ogami Juzo.
Dialogue: 0,0:10:06.05,0:10:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:10:09.98,0:10:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segitu saja.
Dialogue: 0,0:10:11.35,0:10:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah?
Dialogue: 0,0:10:12.21,0:10:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:15.05,0:10:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Payah.
Dialogue: 0,0:10:16.55,0:10:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampungan.
Dialogue: 0,0:10:17.80,0:10:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Payah sekali perkenalanmu, Abang.
Dialogue: 0,0:10:19.85,0:10:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:10:21.01,0:10:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbaur juga bagian dari pekerjaan!
Dialogue: 0,0:10:24.71,0:10:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku mau perkenalan ulang.
Dialogue: 0,0:10:28.85,0:10:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hobiku...
Dialogue: 0,0:10:30.51,0:10:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada.
Dialogue: 0,0:10:32.11,0:10:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlianku...
Dialogue: 0,0:10:35.01,0:10:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menembak runduk.
Dialogue: 0,0:10:41.11,0:10:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menembak?
Dialogue: 0,0:10:45.71,0:10:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah makin parah?
Dialogue: 0,0:10:47.71,0:10:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-Bohongan, kok. Senapan angin!
Dialogue: 0,0:10:50.42,0:10:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Aku suka survival game!
Dialogue: 0,0:10:53.15,0:10:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:10:53.78,0:10:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya itu.
Dialogue: 0,0:10:55.55,0:10:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia penyendiri.
Dialogue: 0,0:10:59.01,0:11:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pemurung, ya.
Dialogue: 0,0:11:00.41,0:11:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya.
Dialogue: 0,0:11:06.31,0:11:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya pulang juga.
Dialogue: 0,0:11:09.71,0:11:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari pertama sudah begini, parah.
Dialogue: 0,0:11:12.68,0:11:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar, deh.
Dialogue: 0,0:11:15.98,0:11:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf ya, otaku.
Dialogue: 0,0:11:19.11,0:11:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini.
Dialogue: 0,0:11:20.81,0:11:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kau dibunuh, lo.
Dialogue: 0,0:11:22.67,0:11:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram.
Dialogue: 0,0:11:23.78,0:11:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu kita beri pelajaran atau tidak, Bang?
Dialogue: 0,0:11:25.75,0:11:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja.
Dialogue: 0,0:11:28.55,0:11:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf ya, lama.
Dialogue: 0,0:11:31.51,0:11:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini omurice!
Dialogue: 0,0:11:33.71,0:11:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan!
Dialogue: 0,0:11:36.35,0:11:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau ada di rumahku?
Dialogue: 0,0:11:41.44,0:11:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak juga!
Dialogue: 0,0:11:43.31,0:11:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku tak masak,\Nkau pasti makan ramen lagi, 'kan?
Dialogue: 0,0:11:46.81,0:11:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin bau mulut, tahu.
Dialogue: 0,0:11:49.01,0:11:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa dirundung karena bau mulut.
Dialogue: 0,0:11:52.45,0:11:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalanku sangat buruk,\Naku sampai bergidik.
Dialogue: 0,0:11:56.58,0:11:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja identitas harus dirahasiakan.
Dialogue: 0,0:11:59.11,0:12:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jangan sampai buat masalah\Nyang berujung skorsing.
Dialogue: 0,0:12:04.15,0:12:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat! Kalau kau diskors atau dikeluarkan,\Nkita tak dapat upah.
Dialogue: 0,0:12:08.71,0:12:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengurusmu mulai sekarang.
Dialogue: 0,0:12:11.05,0:12:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kau ibuku?
Dialogue: 0,0:12:12.35,0:12:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:12:13.35,0:12:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus apa selain datang tiap hari?
Dialogue: 0,0:12:16.33,0:12:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolah itu tempat untuk belajar.
Dialogue: 0,0:12:20.55,0:12:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai kelas hari ini.
Dialogue: 0,0:12:23.25,0:12:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila ada pertanyaan,\Nlangsung angkat tangan.
Dialogue: 0,0:12:26.38,0:12:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, siapkan buku kalian.
Dialogue: 0,0:12:28.99,0:12:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar, ya?
Dialogue: 0,0:12:32.81,0:12:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu aku kecil,
Dialogue: 0,0:12:34.58,0:12:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dilatih oleh organisasi.
Dialogue: 0,0:12:38.81,0:12:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung kerja.
Dialogue: 0,0:12:42.41,0:12:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah diriku yang sekarang.
Dialogue: 0,0:12:46.35,0:12:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah merasakan pahit manis kehidupan.
Dialogue: 0,0:12:48.81,0:12:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini 39 tahun,\Nsudah menikah dan punya putri, tahu.
Dialogue: 0,0:12:53.16,0:12:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa aku kembali sekolah...
Dialogue: 0,0:12:57.11,0:13:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, bilangan positif.\NContohnya, 1, 2, 3.
Dialogue: 0,0:13:02.85,0:13:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa kita gunakan di kehidupan sehari-hari.
Dialogue: 0,0:13:18.81,0:13:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilangan positif?
Dialogue: 0,0:13:20.51,0:13:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira semua bilangan itu positif.
Dialogue: 0,0:13:24.81,0:13:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada bilangan negatif?
Dialogue: 0,0:13:29.55,0:13:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:13:53.25,0:13:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian pelajaran hari ini.
Dialogue: 0,0:13:55.65,0:13:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjut belajar di rumah,\Ndan jangan lupa kerjakan PR.
Dialogue: 0,0:14:05.51,0:14:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:14:07.25,0:14:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar itu asyik sekali!
Dialogue: 0,0:14:09.15,0:14:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahasa Jepang, Matematika, Sains,\Nsemuanya asyik.
Dialogue: 0,0:14:12.75,0:14:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar hal yang tak kuketahui.
Dialogue: 0,0:14:15.45,0:14:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memahaminya secara mendalam...
Dialogue: 0,0:14:18.51,0:14:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata seru!
Dialogue: 0,0:14:22.18,0:14:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini reaksi dari bertahun-tahun\Nbekerja tanpa berpikir.
Dialogue: 0,0:14:26.65,0:14:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ini,
Dialogue: 0,0:14:29.11,0:14:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setiap ilmu baru yang kudapat,
Dialogue: 0,0:14:31.65,0:14:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya seperti minum-minum sehabis kerja.\NNikmat!
Dialogue: 0,0:14:38.31,0:14:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, waktunya makan...
Dialogue: 0,0:14:41.51,0:14:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:14:45.11,0:14:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masalah besar.
Dialogue: 0,0:14:48.45,0:14:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:49.98,0:14:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran SMP
Dialogue: 0,0:14:52.35,0:14:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata sangat seru!
Dialogue: 0,0:14:55.35,0:14:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hal bagus, dong?\NMeski aku tidak tahu...
Dialogue: 0,0:14:59.15,0:15:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kecanduan belajar.
Dialogue: 0,0:15:03.18,0:15:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran besok sudah kupelajari!
Dialogue: 0,0:15:06.38,0:15:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat suka belajar, ya.
Dialogue: 0,0:15:09.51,0:15:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan malamnya ikan kembung dan sup miso.
Dialogue: 0,0:15:11.97,0:15:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}DHA bagus untuk belajar.
Dialogue: 0,0:15:16.01,0:15:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ceroboh saat bekerja,\Ntapi cekatan saat memasak.
Dialogue: 0,0:15:35.49,0:15:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti.
Dialogue: 0,0:15:40.31,0:15:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?
Dialogue: 0,0:15:42.35,0:15:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini sangat menyenangkan.
Dialogue: 0,0:15:44.91,0:15:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama IPS.
Dialogue: 0,0:15:46.45,0:15:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:47.31,0:15:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini pernah kulihat\Nwaktu bekerja dulu.
Dialogue: 0,0:15:49.45,0:15:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat.
Dialogue: 0,0:15:50.55,0:15:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin asyik karena relevan\Ndengan kehidupan nyata.
Dialogue: 0,0:15:52.51,0:15:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru banget.
Dialogue: 0,0:15:56.15,0:15:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, sudah saatnya pulang.
Dialogue: 0,0:16:00.81,0:16:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:16:03.65,0:16:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak cocok dengan anak-anak.
Dialogue: 0,0:16:06.51,0:16:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kembali menjadi dewasa.
Dialogue: 0,0:16:09.25,0:16:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Riuh sekali di sana.
Dialogue: 0,0:16:11.96,0:16:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera mengungsi ke dalam gedung sekolah!
Dialogue: 0,0:16:13.65,0:16:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, aku baru ingat...
Dialogue: 0,0:16:22.78,0:16:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:16:23.57,0:16:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K.O. dalam sekali tendang!
Dialogue: 0,0:16:25.15,0:16:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat atletis!
Dialogue: 0,0:16:29.70,0:16:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu banget.
Dialogue: 0,0:16:30.58,0:16:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar...
Dialogue: 0,0:16:31.78,0:16:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ke arah sini?
Dialogue: 0,0:16:36.45,0:16:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ke sini!
Dialogue: 0,0:16:38.09,0:16:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar ke sini?
Dialogue: 0,0:16:44.01,0:16:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuputuskan.
Dialogue: 0,0:16:46.55,0:16:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus melihat "itu"-ku.
Dialogue: 0,0:16:50.11,0:16:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan main-main!
Dialogue: 0,0:16:51.20,0:16:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulaporkan ke polisi!
Dialogue: 0,0:16:54.81,0:16:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja!
Dialogue: 0,0:16:56.15,0:16:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jago kabur.
Dialogue: 0,0:16:57.78,0:17:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau tertangkap pun tak apa-apa.
Dialogue: 0,0:17:00.85,0:17:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membulatkan tekad.
Dialogue: 0,0:17:07.75,0:17:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia apa-apaan?
Dialogue: 0,0:17:10.14,0:17:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelecehan seksual.
Dialogue: 0,0:17:11.98,0:17:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua orang itu perundung, 'kan?
Dialogue: 0,0:17:15.18,0:17:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu menolong mereka.
Dialogue: 0,0:17:16.91,0:17:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggalkan saja mereka.
Dialogue: 0,0:17:18.91,0:17:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak berbahaya, kok.
Dialogue: 0,0:17:20.57,0:17:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:17:25.15,0:17:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mereka berdua seumuran\Ndengan putriku.
Dialogue: 0,0:17:30.23,0:17:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini orang tua.
Dialogue: 0,0:17:34.05,0:17:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal mereka layak dibantu atau tidak,
Dialogue: 0,0:17:38.31,0:17:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak peduli soal itu.
Dialogue: 0,0:17:42.18,0:17:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau identitasmu terbongkar,\Nsemuanya tamat!
Dialogue: 0,0:17:45.01,0:17:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:17:53.80,0:17:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti!
Dialogue: 0,0:17:55.11,0:17:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat tabir asap dari kapur!
Dialogue: 0,0:17:56.55,0:17:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kau cepat.
Dialogue: 0,0:17:58.75,0:18:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berisik.
Dialogue: 0,0:18:03.28,0:18:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:07.35,0:18:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak tumbang dengan sekali pukul?
Dialogue: 0,0:18:11.95,0:18:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sekuat itu? Tidak...
Dialogue: 0,0:18:15.38,0:18:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena aku anak-anak sekarang.
Dialogue: 0,0:18:17.85,0:18:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kau?
Dialogue: 0,0:18:20.35,0:18:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini...
Dialogue: 0,0:18:24.65,0:18:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo meledak bersama!
Dialogue: 0,0:18:27.45,0:18:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana kau dapat itu?
Dialogue: 0,0:18:34.13,0:18:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah keterlaluan.
Dialogue: 0,0:18:37.45,0:18:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, akan kupotong "itu"-mu.
Dialogue: 0,0:18:41.11,0:18:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan yang "itu" pikiranmu, kok.
Dialogue: 0,0:18:51.58,0:18:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, yang menyelamatkan kita...
Dialogue: 0,0:18:54.35,0:18:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ota...
Dialogue: 0,0:18:55.57,0:18:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami?
Dialogue: 0,0:18:58.95,0:19:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Salah orang.
Dialogue: 0,0:19:01.01,0:19:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang menolong kalian sudah pergi.
Dialogue: 0,0:19:04.91,0:19:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma kebetulan lewat saat belajar.
Dialogue: 0,0:19:08.71,0:19:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya murid SMP biasa.
Dialogue: 0,0:19:13.55,0:19:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:19:15.18,0:19:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai jumpa!
Dialogue: 0,0:19:16.51,0:19:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku duluan!
Dialogue: 0,0:19:19.01,0:19:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, dia pingsan?
Dialogue: 0,0:19:20.81,0:19:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa dia meledakkan diri?\N- Tadi seram sekali!
Dialogue: 0,0:19:22.58,0:19:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat.
Dialogue: 0,0:19:24.61,0:19:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan peledaknya dirakit sendiri\Noleh pelaku
Dialogue: 0,0:19:27.92,0:19:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan penyelamat para siswa\Nmasih belum diketahui.
Dialogue: 0,0:19:31.19,0:19:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram. Kelakuan orang ada-ada saja.
Dialogue: 0,0:19:34.81,0:19:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:19:36.18,0:19:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi tengah mendalami kemungkinan\Nketerlibatan dalam kasus lain.
Dialogue: 0,0:19:39.11,0:19:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, ayo nongkrong!
Dialogue: 0,0:19:41.75,0:19:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:19:43.11,0:19:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut!
Dialogue: 0,0:19:44.38,0:19:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bikin grup obrolan kelas.
Dialogue: 0,0:19:46.74,0:19:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju!
Dialogue: 0,0:19:47.98,0:19:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undang aku.
Dialogue: 0,0:19:49.11,0:19:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirimkan ID-mu.
Dialogue: 0,0:19:50.85,0:19:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:19:53.01,0:19:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia...
Dialogue: 0,0:19:54.95,0:19:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajak saja?
Dialogue: 0,0:19:56.81,0:19:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia tak suka nongkrong.
Dialogue: 0,0:19:59.01,0:20:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:20:00.45,0:20:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Abaikan saja aku.\N- Tidak, tanya dulu orangnya.
Dialogue: 0,0:20:03.95,0:20:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memutuskan sendiri.
Dialogue: 0,0:20:07.01,0:20:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar katanya.
Dialogue: 0,0:20:08.65,0:20:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:09.55,0:20:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tak masalah, kok.
Dialogue: 0,0:20:11.81,0:20:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bikin obrolan grup kelas.
Dialogue: 0,0:20:13.87,0:20:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau gabung?
Dialogue: 0,0:20:15.18,0:20:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, ini cuma mungkin...
Dialogue: 0,0:20:18.18,0:20:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih untuk hari itu.
Dialogue: 0,0:20:21.41,0:20:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih.
Dialogue: 0,0:20:23.05,0:20:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tak masuk grup kelas pun\Ntak apa-apa.
Dialogue: 0,0:20:28.33,0:20:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, deh.
Dialogue: 0,0:20:36.66,0:20:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:39.78,0:20:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temponya cepat sekali.
Dialogue: 0,0:20:42.25,0:20:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa mengikuti percakapannya.
Dialogue: 0,0:20:44.05,0:20:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Notifikasi datang tanpa henti.
Dialogue: 0,0:20:45.81,0:20:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara menghentikannya?
Dialogue: 0,0:20:47.31,0:20:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Sulit sekali, maaf!
Dialogue: 0,0:20:50.21,0:20:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:20:51.58,0:20:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit juga jadi anak SMP.
Dialogue: 0,0:20:54.65,0:20:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tua sepertimu memang\Nlambat mengetik, ya.
Dialogue: 0,0:21:01.15,0:21:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau rokok?
Dialogue: 0,0:21:03.51,0:21:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:21:05.01,0:21:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa minum dan merokok\Ndengan tubuh ini.
Dialogue: 0,0:21:13.75,0:21:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ya,
Dialogue: 0,0:21:15.17,0:21:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daripada pekerjaanku yang dulu,
Dialogue: 0,0:21:18.15,0:21:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sekarang terasa lebih enak.
Dialogue: 0,0:21:21.18,0:21:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, jalani saja dulu.
Dialogue: 0,0:21:26.75,0:21:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjakan PR dulu, deh.
Dialogue: 0,0:23:02.05,0:23:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Eri?
Dialogue: 0,0:23:03.65,0:23:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebah yang menyengatmu itu...
Dialogue: 0,0:23:06.48,0:23:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lebah buatan.
Dialogue: 0,0:23:09.45,0:23:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibuat di lab.
Dialogue: 0,0:23:12.31,0:23:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang membuatnya adalah Farmasi Mitsuoka.
Dialogue: 0,0:23:14.81,0:23:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perusahaan yang berkembang pesat\N10 tahun terakhir,
Dialogue: 0,0:23:17.26,0:23:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kini peringkat dua nasional.
Dialogue: 0,0:23:20.15,0:23:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasi menariknya...
Dialogue: 0,0:23:22.71,0:23:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya putri sang pemilik\Nadalah teman sekelasmu.
Dialogue: 0,0:23:26.21,0:23:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba berteman dengannya.
Dialogue: 0,0:23:28.31,0:23:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kita bisa dapat informasi penting.
Dialogue: 0,0:23:31.81,0:23:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama putrinya...
Dialogue: 0,0:23:34.25,0:23:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuoka Noren.
Dialogue: 0,0:23:36.71,0:23:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:23:37.75,0:23:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
