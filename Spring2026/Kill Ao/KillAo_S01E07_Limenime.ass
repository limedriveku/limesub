Dialogue: 0,0:03:23.99,0:03:26.44,sign,,0000,0000,0000,,KLUB TATA BOGA
Dialogue: 0,0:04:44.28,0:04:48.26,sign,,0000,0000,0000,,KENCAN GANDA YANG MENDEBARKAN\NSABTU, 23 MEI
Dialogue: 0,0:07:17.97,0:07:18.17,sign,,0000,0000,0000,,HACHIRO RAMEN
Dialogue: 0,0:09:38.62,0:09:40.97,sign,,0000,0000,0000,,GYAAA!
Dialogue: 0,0:00:35.78,0:00:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekakmat.
Dialogue: 0,0:00:40.25,0:00:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh legendaris memang beda.
Dialogue: 0,0:00:43.38,0:00:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengejek, ya?
Dialogue: 0,0:00:45.75,0:00:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama kita tidak latih tanding.
Dialogue: 0,0:00:48.25,0:00:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski jadi anak SMP, kau tetap luar biasa.
Dialogue: 0,0:00:50.61,0:00:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya kekuatanku menurun\Nsejak jadi anak-anak.
Dialogue: 0,0:00:54.78,0:00:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena refleks,\Ngerakanku masih terbawa.
Dialogue: 0,0:00:57.91,0:01:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah jadi lebih lihai sekarang.
Dialogue: 0,0:01:00.61,0:01:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di masa jayamu, kau ini manusia super, ya?
Dialogue: 0,0:01:04.65,0:01:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang memang bukan anak biasa waktu SMP.
Dialogue: 0,0:01:10.81,0:01:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:01:11.98,0:01:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan tarung habis-habisan\Nseperti melawan Tenma kemarin.
Dialogue: 0,0:01:17.18,0:01:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak Klub Tata Boga\Nmasih curiga, tahu.
Dialogue: 0,0:01:21.41,0:01:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:01:23.45,0:01:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata Bos, laporan kita masih kurang detail.
Dialogue: 0,0:01:27.11,0:01:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maunya Bos apa, sih?
Dialogue: 0,0:01:30.95,0:01:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau masa SMP ini berlanjut,
Dialogue: 0,0:01:33.65,0:01:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}identitas harus benar-benar dirahasiakan.
Dialogue: 0,0:01:36.55,0:01:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi misi Bos dan demi penghasilanmu.
Dialogue: 0,0:01:40.25,0:01:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta demi dirimu sendiri.
Dialogue: 0,0:01:45.01,0:01:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kira-kira yang ada\Ndi pikiranku belakangan ini.
Dialogue: 0,0:01:49.85,0:01:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar juga.
Dialogue: 0,0:03:26.51,0:03:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, Noren.
Dialogue: 0,0:03:29.25,0:03:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau minta tolong.
Dialogue: 0,0:03:30.98,0:03:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggu ini...
Dialogue: 0,0:03:32.58,0:03:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kencan ganda!
Dialogue: 0,0:03:34.51,0:03:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bisa, 'kan?
Dialogue: 0,0:03:38.91,0:03:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:39.65,0:03:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau jadian sama Tenma?
Dialogue: 0,0:03:43.68,0:03:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, aku tidak pacaran dengannya.
Dialogue: 0,0:03:46.98,0:03:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:49.41,0:03:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kau.
Dialogue: 0,0:03:51.60,0:03:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:03:54.21,0:03:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chisato...
Dialogue: 0,0:03:57.55,0:03:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap hari dia datang\Ndengan penuh semangat.
Dialogue: 0,0:04:00.01,0:04:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kupikir, sekali kencan tidak apa-apa.
Dialogue: 0,0:04:03.31,0:04:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau gampang luluh.
Dialogue: 0,0:04:05.11,0:04:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa jadi kencan ganda?
Dialogue: 0,0:04:08.21,0:04:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu gugup kalau cuma berdua saja.
Dialogue: 0,0:04:10.98,0:04:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kubilang akan kuajak\NNoren dan yang lain.
Dialogue: 0,0:04:13.28,0:04:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan libatkan aku.
Dialogue: 0,0:04:15.15,0:04:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya kau tidak gampang panik.
Dialogue: 0,0:04:16.70,0:04:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal asmara, kau kewalahan juga, ya.
Dialogue: 0,0:04:19.18,0:04:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, maaf.
Dialogue: 0,0:04:21.18,0:04:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bisa terus begini.
Dialogue: 0,0:04:23.98,0:04:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau terlalu serius,\Ncowok malah minder mendekati.
Dialogue: 0,0:04:26.95,0:04:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti malah jatuh cinta pada\Ncowok agresif yang tidak jelas.
Dialogue: 0,0:04:30.45,0:04:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chisato...
Dialogue: 0,0:04:31.35,0:04:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti jadi wanita karier\Nyang sial urusan cinta.
Dialogue: 0,0:04:33.42,0:04:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir sekali kencan dengannya,\Nberes sudah.
Dialogue: 0,0:04:37.35,0:04:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ngawur, kayak kebijakan tanpa landasan.
Dialogue: 0,0:04:49.41,0:04:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, kami jadi kencan ganda juga.
Dialogue: 0,0:04:53.98,0:04:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku penasaran\Ndengan rahasia Ogami.
Dialogue: 0,0:04:57.91,0:05:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lewat kencan ini\Naku bisa menggalinya lebih jauh.
Dialogue: 0,0:05:01.01,0:05:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai!
Dialogue: 0,0:05:02.18,0:05:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ketua.\N- Maaf, ya.
Dialogue: 0,0:05:06.22,0:05:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa busanamu seperti itu?
Dialogue: 0,0:05:08.18,0:05:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jaga-jaga supaya tidak digoda.
Dialogue: 0,0:05:12.51,0:05:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian sudah duluan.
Dialogue: 0,0:05:14.58,0:05:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, lama.
Dialogue: 0,0:05:15.65,0:05:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baju olahraga, ya?
Dialogue: 0,0:05:18.41,0:05:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal aku tidak berekspektasi tinggi,
Dialogue: 0,0:05:21.05,0:05:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi masa pakai kaos olahraga?
Dialogue: 0,0:05:23.55,0:05:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh?
Dialogue: 0,0:05:24.16,0:05:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mau kencan, 'kan?\NBukan mau olahraga.
Dialogue: 0,0:05:27.41,0:05:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa bilang "Unicorn"\Nisinya manusia berkelas?
Dialogue: 0,0:05:32.01,0:05:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jago olahraga doang.\NSisanya nol.
Dialogue: 0,0:05:37.58,0:05:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik banget bisa kencan sama Chisato!
Dialogue: 0,0:05:42.58,0:05:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ugh, dia sangat tulus.
Dialogue: 0,0:05:44.45,0:05:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibiarkan,\Naku bakal terus terbawa temponya.
Dialogue: 0,0:05:47.45,0:05:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku telat, ya?
Dialogue: 0,0:05:49.31,0:05:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, lama.
Dialogue: 0,0:05:52.99,0:05:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Blazer dipadukan dengan tas genggam?
Dialogue: 0,0:05:56.71,0:06:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak nyambung.\NSemuanya salah.
Dialogue: 0,0:06:00.11,0:06:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, padahal ukurannya harusnya sudah pas.
Dialogue: 0,0:06:02.38,0:06:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan itu maksudku.
Dialogue: 0,0:06:05.31,0:06:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan...
Dialogue: 0,0:06:06.61,0:06:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang, baik-baik saja?
Dialogue: 0,0:06:08.71,0:06:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini sudah om-om.
Dialogue: 0,0:06:10.95,0:06:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi?
Dialogue: 0,0:06:12.21,0:06:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma jalan-jalan di kota, kok.
Dialogue: 0,0:06:15.58,0:06:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa ikut, lo.
Dialogue: 0,0:06:18.75,0:06:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapkan dulu pakaiannya.
Dialogue: 0,0:06:20.35,0:06:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai saja.
Dialogue: 0,0:06:21.95,0:06:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai baju sehari-hari saja.
Dialogue: 0,0:06:24.98,0:06:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa begitu, Bang.
Dialogue: 0,0:06:29.25,0:06:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ini cukup mencolok, ya.
Dialogue: 0,0:06:32.65,0:06:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren seperti selebriti\Nyang sedang menyamar.
Dialogue: 0,0:06:37.15,0:06:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma aku yang kelihatan\Nseperti anak SMP biasa.
Dialogue: 0,0:06:45.65,0:06:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, setelah ini mau ke mana?
Dialogue: 0,0:06:49.31,0:06:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keliling-keliling saja.
Dialogue: 0,0:06:51.61,0:06:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu nonton film.
Dialogue: 0,0:06:54.15,0:06:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata normal.\NKukira bakal ada sesi olahraga.
Dialogue: 0,0:06:58.38,0:07:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu tempat ini cuma taman biasa.
Dialogue: 0,0:07:01.95,0:07:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu banyak gelandangan di sini.
Dialogue: 0,0:07:03.78,0:07:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu?
Dialogue: 0,0:07:06.58,0:07:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah baca di internet.
Dialogue: 0,0:07:09.45,0:07:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma pernah baca.
Dialogue: 0,0:07:11.35,0:07:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu ceroboh, Bang.
Dialogue: 0,0:07:14.41,0:07:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Om-om?
Dialogue: 0,0:07:18.25,0:07:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran dengan kedai ramen itu.
Dialogue: 0,0:07:22.45,0:07:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau suka ramen?
Dialogue: 0,0:07:25.11,0:07:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, kok.
Dialogue: 0,0:07:26.58,0:07:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja, kok.
Dialogue: 0,0:07:29.31,0:07:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kedai ramen itu\Npenuh dengan pelanggan tetap.
Dialogue: 0,0:07:33.21,0:07:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti penuh banget.
Dialogue: 0,0:07:35.05,0:07:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak makan ramen.
Dialogue: 0,0:07:36.78,0:07:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menjaga pola makan.
Dialogue: 0,0:07:38.81,0:07:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ketat juga, ya.
Dialogue: 0,0:07:42.25,0:07:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi memang agak lapar, sih.
Dialogue: 0,0:07:46.25,0:07:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke warung kopi itu saja, yuk.
Dialogue: 0,0:07:48.51,0:07:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Warung kopi?\N- Memang benar jualan kopi.
Dialogue: 0,0:07:51.85,0:07:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istilah kuno, cocok sekali dengan Ogami.
Dialogue: 0,0:08:12.71,0:08:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru banget hari ini, Chisato.
Dialogue: 0,0:08:15.18,0:08:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:16.78,0:08:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, aku mulai menikmati kencan ini.
Dialogue: 0,0:08:25.05,0:08:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kubayangkan sebelumnya...
Dialogue: 0,0:08:29.78,0:08:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kesenjangan generasi.
Dialogue: 0,0:08:31.18,0:08:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jelas-jelas dia masih anak SMP.
Dialogue: 0,0:08:33.25,0:08:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan kelihatan muda,\Ntapi memang masih SMP.
Dialogue: 0,0:08:37.70,0:08:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:08:49.05,0:08:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan tubuhku?
Dialogue: 0,0:09:01.75,0:09:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pingsan, ya?
Dialogue: 0,0:09:04.58,0:09:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sekitar satu jam.
Dialogue: 0,0:09:08.58,0:09:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku kelihatan berbeda?
Dialogue: 0,0:09:12.18,0:09:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, jangan-jangan...
Dialogue: 0,0:09:15.55,0:09:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali jadi dewasa!
Dialogue: 0,0:09:19.01,0:09:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pemicunya?
Dialogue: 0,0:09:20.38,0:09:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa racun lebahnya hilang sendirinya?
Dialogue: 0,0:09:23.55,0:09:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti saja kupikirkan soal itu.
Dialogue: 0,0:09:26.85,0:09:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bahaya.
Dialogue: 0,0:09:29.58,0:09:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan, kenapa harus sekarang?
Dialogue: 0,0:09:32.45,0:09:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya sangat tidak tepat.
Dialogue: 0,0:09:35.51,0:09:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Identitasku bisa ketahuan.
Dialogue: 0,0:09:40.98,0:09:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, mau mati saja rasanya.
Dialogue: 0,0:09:44.95,0:09:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, ada apa?
Dialogue: 0,0:09:54.65,0:09:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipikir-pikir...
Dialogue: 0,0:09:56.65,0:09:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini ngapain, sih?
Dialogue: 0,0:09:59.21,0:10:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku cuma sebagai pendamping,
Dialogue: 0,0:10:02.58,0:10:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah ikut kencan ganda anak SMP.\NBodohnya aku.
Dialogue: 0,0:10:07.31,0:10:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus sadar diri.
Dialogue: 0,0:10:09.38,0:10:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku sudah cukup tenang.
Dialogue: 0,0:10:12.18,0:10:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sampai di sini.\NKembali ke kenyataan.
Dialogue: 0,0:10:16.15,0:10:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, aku tidak bisa\Nmenepati janjiku pada Noren.
Dialogue: 0,0:10:20.75,0:10:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal, om-om tidak seharusnya\Njadi murid SMP.
Dialogue: 0,0:10:24.45,0:10:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ogami!
Dialogue: 0,0:10:26.31,0:10:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau lama banget.\N- Tenma?
Dialogue: 0,0:10:28.58,0:10:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Filmnya mau selesai, nih...
Dialogue: 0,0:10:30.91,0:10:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget.
Dialogue: 0,0:10:31.98,0:10:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:10:32.78,0:10:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ke sini!
Dialogue: 0,0:10:36.15,0:10:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku harus bagaimana?
Dialogue: 0,0:10:41.38,0:10:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada pesan.
Dialogue: 0,0:10:43.58,0:10:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:10:45.51,0:10:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan banyak tanya, lihat sendiri.
Dialogue: 0,0:10:48.45,0:10:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kau kembali jadi dewasa!
Dialogue: 0,0:10:50.18,0:10:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar ada Noren dan yang lain.
Dialogue: 0,0:10:52.71,0:10:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa keluar.
Dialogue: 0,0:10:54.57,0:10:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kau bawa tas genggam, 'kan?
Dialogue: 0,0:10:58.35,0:11:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada alat pembobol atau bom kecil.
Dialogue: 0,0:11:02.91,0:11:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada stiker pengubah suara berbentuk kucing.
Dialogue: 0,0:11:05.95,0:11:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung bukan bentuk dasi.
Dialogue: 0,0:11:08.31,0:11:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau tidak apa-apa?
Dialogue: 0,0:11:11.11,0:11:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempelkan itu di jakun.
Dialogue: 0,0:11:13.51,0:11:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya bisa diatur\Ndi aplikasi lewat ponsel.
Dialogue: 0,0:11:17.61,0:11:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:11:19.15,0:11:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang enak badan.
Dialogue: 0,0:11:21.78,0:11:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius?
Dialogue: 0,0:11:23.71,0:11:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perutku sakit.
Dialogue: 0,0:11:25.65,0:11:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih lama.\NKalian duluan saja.
Dialogue: 0,0:11:28.77,0:11:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Separah itu? Perlu ambulans?
Dialogue: 0,0:11:31.28,0:11:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah panggil ambulans,\Ntapi perutku masih nyeri.
Dialogue: 0,0:11:35.15,0:11:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian duluan saja. Tolong.
Dialogue: 0,0:11:39.35,0:11:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, oke.
Dialogue: 0,0:11:40.98,0:11:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubilang ke yang lain.
Dialogue: 0,0:11:42.50,0:11:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:11:44.21,0:11:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, aku bisa keluar\Nsetelah mereka pergi.
Dialogue: 0,0:11:48.25,0:11:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:11:49.41,0:11:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?\NHei, tunggu dulu!
Dialogue: 0,0:11:52.38,0:11:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami!
Dialogue: 0,0:11:53.55,0:11:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:11:54.81,0:11:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulanglah.
Dialogue: 0,0:11:55.85,0:11:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren diculik!
Dialogue: 0,0:11:57.95,0:12:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diculik lagi?
Dialogue: 0,0:12:01.25,0:12:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren...
Dialogue: 0,0:12:02.65,0:12:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Om-om ini merasa prihatin padamu.
Dialogue: 0,0:12:05.65,0:12:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:12:07.22,0:12:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin kubiarkan begitu saja.\NNanti aku tidak bisa tidur tenang.
Dialogue: 0,0:12:10.61,0:12:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:12:12.75,0:12:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:12:13.91,0:12:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak apa-apa.
Dialogue: 0,0:12:15.15,0:12:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Noren...
Dialogue: 0,0:12:16.85,0:12:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, jati dirimu terlihat jelas.
Dialogue: 0,0:12:19.95,0:12:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma, tolong peluk dia dengan erat.
Dialogue: 0,0:12:26.78,0:12:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini?
Dialogue: 0,0:12:28.85,0:12:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak...
Dialogue: 0,0:12:30.05,0:12:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciri-ciri penculiknya apa?
Dialogue: 0,0:12:32.58,0:12:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em... ada dua orang.
Dialogue: 0,0:12:34.98,0:12:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya pakai hoodie hitam.
Dialogue: 0,0:12:40.05,0:12:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil van hitam.
Dialogue: 0,0:12:41.31,0:12:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menuju Gaien?
Dialogue: 0,0:12:49.13,0:12:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:12:50.18,0:12:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti telepon ke nomor ini saja.
Dialogue: 0,0:12:53.38,0:12:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubayar biayanya.
Dialogue: 0,0:12:57.76,0:13:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu masalah selesai,\Ndatang lagi yang baru.
Dialogue: 0,0:13:05.85,0:13:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, aku baru sadar.
Dialogue: 0,0:13:09.41,0:13:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi harusnya kita keluar dari toilet\Ndan berpura-pura tidak kenal.
Dialogue: 0,0:13:13.97,0:13:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:13:15.55,0:13:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena panik, aku tidak kepikiran.
Dialogue: 0,0:13:17.55,0:13:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:13:18.85,0:13:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben.
Dialogue: 0,0:13:21.21,0:13:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi yang menuntut keputusan\Ncepat sering terjadi.
Dialogue: 0,0:13:25.78,0:13:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan tipe\Nyang biasanya panik seperti itu.
Dialogue: 0,0:13:29.31,0:13:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masa SMP itu memang seru?
Dialogue: 0,0:13:34.61,0:13:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau peluk sampai kapan?
Dialogue: 0,0:13:37.27,0:13:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terbawa suasana.
Dialogue: 0,0:13:39.15,0:13:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu masalahnya.
Dialogue: 0,0:13:40.95,0:13:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami pergi mengejar sendirian.
Dialogue: 0,0:13:43.01,0:13:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa yang bisa kita lakukan,
Dialogue: 0,0:13:45.58,0:13:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ayo susul mereka.
Dialogue: 0,0:13:47.35,0:13:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa?
Dialogue: 0,0:13:50.95,0:13:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting Chisato baik-baik saja, 'kan?
Dialogue: 0,0:13:54.18,0:13:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menyusul?
Dialogue: 0,0:13:55.78,0:13:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan saja pada Ogami.
Dialogue: 0,0:14:02.51,0:14:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini...
Dialogue: 0,0:14:04.61,0:14:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja kita tidak boleh diam.
Dialogue: 0,0:14:06.21,0:14:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini robot atau apa?
Dialogue: 0,0:14:08.25,0:14:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah lupa perkataanku?
Dialogue: 0,0:14:11.11,0:14:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kesulitan kita harus saling bantu.
Dialogue: 0,0:14:13.71,0:14:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita masih SMP, 'kan?
Dialogue: 0,0:14:16.15,0:14:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh kalau kita bertindak sendiri.
Dialogue: 0,0:14:18.15,0:14:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan bersikap dingin begitu.
Dialogue: 0,0:14:20.81,0:14:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sangat menikmati hari ini.
Dialogue: 0,0:14:23.61,0:14:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buat aku kecewa.
Dialogue: 0,0:14:25.95,0:14:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka cowok\Nyang tidak punya perasaan.
Dialogue: 0,0:14:34.35,0:14:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:14:36.01,0:14:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tidak peka.
Dialogue: 0,0:14:38.45,0:14:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah banyak yang bilang begitu.
Dialogue: 0,0:14:42.05,0:14:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah bisa\Nmemahami perasaan orang.
Dialogue: 0,0:14:46.25,0:14:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini pun sama.
Dialogue: 0,0:14:48.05,0:14:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:14:50.15,0:14:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ajari aku.
Dialogue: 0,0:14:52.11,0:14:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha agar\Ntidak membuat Chisato menangis.
Dialogue: 0,0:14:57.01,0:14:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu.
Dialogue: 0,0:14:59.65,0:15:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chisato, tolong lapor polisi.
Dialogue: 0,0:15:02.75,0:15:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku juga ikut!
Dialogue: 0,0:15:04.01,0:15:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larimu lambat, nanti malah jadi beban.
Dialogue: 0,0:15:07.28,0:15:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Ogami?
Dialogue: 0,0:15:08.90,0:15:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya janji tidak akan\Nbikin aku menangis?
Dialogue: 0,0:15:15.78,0:15:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma mau menyusul?
Dialogue: 0,0:15:19.25,0:15:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa-apaan ini?
Dialogue: 0,0:15:21.58,0:15:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku kembali jadi anak-anak lagi?
Dialogue: 0,0:15:25.58,0:15:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:15:27.51,0:15:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, lama.
Dialogue: 0,0:15:28.63,0:15:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali! Ke sini naik apa?
Dialogue: 0,0:15:31.22,0:15:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari, sih.
Dialogue: 0,0:15:33.05,0:15:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya cuma 2-3 km, sebentar saja.
Dialogue: 0,0:15:34.85,0:15:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang manusia super.
Dialogue: 0,0:15:43.55,0:15:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:15:45.15,0:15:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, mereka ya?
Dialogue: 0,0:15:47.98,0:15:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Auranya beda dari preman biasa.
Dialogue: 0,0:15:51.35,0:15:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka seorang pro?
Dialogue: 0,0:15:53.41,0:15:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:15:54.51,0:15:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku salah perhitungan.
Dialogue: 0,0:15:56.15,0:15:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira cuma preman biasa,\Nmakanya kuajak Tenma.
Dialogue: 0,0:15:59.95,0:16:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logo itu...
Dialogue: 0,0:16:01.31,0:16:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skala organisasi mereka\Nmelebihi organisasi kita.
Dialogue: 0,0:16:03.85,0:16:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Organisasi besar.
Dialogue: 0,0:16:05.55,0:16:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkat satu dalam segala hal:\Nanggota, prestasi, dan kepuasan klien.
Dialogue: 0,0:16:08.71,0:16:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya nomor satu.
Dialogue: 0,0:16:10.25,0:16:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asosiasi pembunuh bayaran, Hardin.
Dialogue: 0,0:16:13.25,0:16:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Organisasi itu punya sistem peringkat\Nberdasarkan biaya keanggotaan klien.
Dialogue: 0,0:16:16.51,0:16:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin tinggi peringkatnya,\Nmakin jago pembunuh bayarannya.
Dialogue: 0,0:16:20.51,0:16:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkat tertinggi, Peringkat Black,\Nkhusus untuk klien VIP.
Dialogue: 0,0:16:25.51,0:16:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ada dua orang?
Dialogue: 0,0:16:27.81,0:16:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:16:29.15,0:16:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kecil itu...
Dialogue: 0,0:16:30.45,0:16:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa.
Dialogue: 0,0:16:31.85,0:16:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo Kazuma, usia 15 tahun.
Dialogue: 0,0:16:34.18,0:16:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi mereka akan jadi mayat.
Dialogue: 0,0:16:37.01,0:16:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang besar, Rindo Eiji, 13 tahun.
Dialogue: 0,0:16:40.78,0:16:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:16:42.51,0:16:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya pembunuh bayaran Peringkat Black.
Dialogue: 0,0:16:45.38,0:16:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka masih SMP?
Dialogue: 0,0:16:51.98,0:16:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:16:53.38,0:16:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal, Ogami.
Dialogue: 0,0:16:56.21,0:16:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal juga, Tendo Tenma.
Dialogue: 0,0:16:58.56,0:16:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:17:00.31,0:17:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuan kalian?
Dialogue: 0,0:17:01.78,0:17:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja soal duel Mitsuoka,\Ndemi menjadi tunangannya.
Dialogue: 0,0:17:05.91,0:17:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lamaran resmi bisa belakangan.
Dialogue: 0,0:17:09.38,0:17:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan hari ini adalah hati Noren.
Dialogue: 0,0:17:14.15,0:17:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlianku adalah hipnotis.
Dialogue: 0,0:17:16.84,0:17:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuatnya jatuh cinta pada Eiji.
Dialogue: 0,0:17:20.05,0:17:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa?
Dialogue: 0,0:17:21.58,0:17:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, kok.
Dialogue: 0,0:17:23.75,0:17:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menghipnotis siapa pun\Nsecara instan.
Dialogue: 0,0:17:28.61,0:17:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menang duel, langsung jadi tunangan resmi.
Dialogue: 0,0:17:31.75,0:17:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak puas kalau cuma begitu.
Dialogue: 0,0:17:34.41,0:17:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuoka Noren harus menjadi\Npengantin adikku.
Dialogue: 0,0:17:40.05,0:17:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:41.15,0:17:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:17:42.65,0:17:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikmu itu...
Dialogue: 0,0:17:44.85,0:17:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi cuma berdesah-desah saja.
Dialogue: 0,0:17:48.21,0:17:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:17:49.41,0:17:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikku memang tidak banyak bicara.
Dialogue: 0,0:17:51.45,0:17:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dalam hal asmara, itu tidak penting.
Dialogue: 0,0:17:53.78,0:17:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan sekadar tidak banyak bicara.
Dialogue: 0,0:17:56.81,0:17:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sehat?
Dialogue: 0,0:17:58.11,0:17:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya kalau mereka jadi menikah...
Dialogue: 0,0:18:00.21,0:18:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia bisa mempertahankan pernikahannya?
Dialogue: 0,0:18:04.25,0:18:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:18:05.95,0:18:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih bisa bergerak, kok.
Dialogue: 0,0:18:07.58,0:18:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang banyak kekurangannya.
Dialogue: 0,0:18:10.38,0:18:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, aku akan membantunya.
Dialogue: 0,0:18:12.61,0:18:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita sudahi pembicaraan ini.
Dialogue: 0,0:18:14.85,0:18:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas, 'kan?
Dialogue: 0,0:18:15.67,0:18:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jelas.
Dialogue: 0,0:18:17.45,0:18:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merepotkan.
Dialogue: 0,0:18:19.65,0:18:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau, Tenma.
Dialogue: 0,0:18:22.21,0:18:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku?
Dialogue: 0,0:18:24.21,0:18:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ke sini cuma karena\Ndisuruh Shiraishi Chisato, 'kan?
Dialogue: 0,0:18:29.41,0:18:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau tinggalkan Ogami,\Naku akan hipnotis Chisato agar suka kau.
Dialogue: 0,0:18:35.11,0:18:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginanmu terwujud dan kau\Ntidak perlu ambil risiko yang tidak perlu.
Dialogue: 0,0:18:39.75,0:18:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:18:41.01,0:18:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini...
Dialogue: 0,0:18:42.35,0:18:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah melakukan riset, ya?
Dialogue: 0,0:18:44.91,0:18:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang kadang kurang peka,\Ntapi tidak mungkin dia mau.
Dialogue: 0,0:18:53.25,0:18:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:18:54.58,0:18:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu tidak perlu diumbar.
Dialogue: 0,0:18:57.38,0:19:00.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama saja main curang.
Dialogue: 0,0:19:01.21,0:19:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius soal Chisato,\Nseperti atlet yang bertaruh segalanya.
Dialogue: 0,0:19:06.45,0:19:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada menang dengan licik,\Nlebih baik kalah dengan sportif.
Dialogue: 0,0:19:10.58,0:19:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma?
Dialogue: 0,0:19:11.95,0:19:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku pasti menang.
Dialogue: 0,0:19:14.41,0:19:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, kau ditaksir orang\Nyang merepotkan, ya.
Dialogue: 0,0:19:17.71,0:19:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal kalian membicarakan soal Noren,\Naku sudah tidak suka.
Dialogue: 0,0:19:25.21,0:19:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak mungkin aku tidak ikut campur.
Dialogue: 0,0:19:27.98,0:19:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup basa-basinya.
Dialogue: 0,0:19:31.21,0:19:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan Noren,\Nkakak-adik gagal cari jodoh.
Dialogue: 0,0:19:34.71,0:19:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi negosiasinya gagal?
Dialogue: 0,0:19:37.41,0:19:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:19:39.61,0:19:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai.
Dialogue: 0,0:19:40.89,0:19:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Golf?
Dialogue: 0,0:19:42.75,0:19:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:19:44.25,0:19:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uh.
Dialogue: 0,0:19:46.01,0:19:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya! Ayo kabur, Tenma!
Dialogue: 0,0:19:51.78,0:19:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar gila.
Dialogue: 0,0:19:59.05,0:20:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, bahkan aku\Nyang biasanya tidak peka pun tahu.
Dialogue: 0,0:20:01.91,0:20:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kena itu pasti mati, 'kan?
Dialogue: 0,0:20:04.41,0:20:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku juga berpikir begitu.
Dialogue: 0,0:20:06.71,0:20:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya hindari area terbuka\Ndan berlindung.
Dialogue: 0,0:20:10.61,0:20:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uwah!
Dialogue: 0,0:20:12.61,0:20:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku akan mengejar mereka.
Dialogue: 0,0:20:15.18,0:20:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau awasi Noren.
Dialogue: 0,0:20:17.18,0:20:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka muncul lagi, serang saja.
Dialogue: 0,0:20:20.01,0:20:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:21.56,0:20:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, mereka gila juga.
Dialogue: 0,0:20:25.95,0:20:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacau. Minim perlengkapan,\Nsulit menghadapinya.
Dialogue: 0,0:20:29.31,0:20:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, bisa ke Blok 320?
Dialogue: 0,0:20:32.65,0:20:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kukirim drone berisi senjata.
Dialogue: 0,0:20:34.95,0:20:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius? Terima kasih, ya.
Dialogue: 0,0:20:36.41,0:20:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat membantu, Nekota.
Dialogue: 0,0:20:37.98,0:20:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kerjamu bagus sekali.
Dialogue: 0,0:20:42.84,0:20:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu! Sudah terlihat.
Dialogue: 0,0:20:48.08,0:20:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan kau mengambilnya.
Dialogue: 0,0:20:51.97,0:20:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga seorang pembunuh bayaran, ya?
Dialogue: 0,0:20:59.41,0:21:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Drone-nya jatuh ke area terbuka.
Dialogue: 0,0:21:01.35,0:21:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi posisinya terlalu jauh.
Dialogue: 0,0:21:03.11,0:21:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil menembak drone\Ndari jarak sejauh itu?
Dialogue: 0,0:21:05.81,0:21:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mungkin bisa lolos darinya.
Dialogue: 0,0:21:07.71,0:21:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang berakhir di sini saja?
Dialogue: 0,0:21:11.15,0:21:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudah sekali.
Dialogue: 0,0:21:13.31,0:21:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang!
Dialogue: 0,0:21:16.38,0:21:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada penembak jitu di lapangan.
Dialogue: 0,0:21:37.75,0:21:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah?
Dialogue: 0,0:21:38.56,0:21:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengecoh Eiji dengan suara itu.
Dialogue: 0,0:21:40.75,0:21:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu menggunakan ledakan\Nuntuk menyamarkan dirinya.
Dialogue: 0,0:21:42.90,0:21:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar.
Dialogue: 0,0:21:44.75,0:21:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubunganku dan Noren itu seperti\Nhubungan ayah dan anak perempuan.
Dialogue: 0,0:21:51.41,0:21:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tolong izinkan aku\Nmenikahi putrimu."
Dialogue: 0,0:21:53.38,0:21:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku amat mencintainya."
Dialogue: 0,0:21:54.78,0:21:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Akan kugunakan hipnotis."
Dialogue: 0,0:21:56.15,0:21:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau calon menantuku bilang begitu...
Dialogue: 0,0:22:05.81,0:22:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah pasti kuhajar.
