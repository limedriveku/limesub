Dialogue: 0,0:01:29.98,0:01:33.99,sign,,0000,0000,0000,,PERTEMUAN PERTAMA PARA PEMBUNUH BAYARAN\NSABTU, 20 JUNI
Dialogue: 0,0:06:10.64,0:06:11.04,sign,,0000,0000,0000,,PERTEMUAN PERTAMA PARA PEMBUNUH BAYARAN
Dialogue: 0,0:10:38.68,0:10:40.24,sign,,0000,0000,0000,,BUKA 24 JAM
Dialogue: 0,0:11:10.90,0:11:13.74,sign,,0000,0000,0000,,"BAR JABAMI"
Dialogue: 0,0:14:10.45,0:14:11.87,sign,,0000,0000,0000,,KLUB TATA BOGA
Dialogue: 0,0:14:56.93,0:14:58.77,sign,,0000,0000,0000,,PEMBAGIAN TIM
Dialogue: 0,0:18:23.18,0:18:25.12,sign,,0000,0000,0000,,HARI PENENTUAN
Dialogue: 0,0:18:49.79,0:18:50.26,sign,,0000,0000,0000,,MI BIANGBIANG
Dialogue: 0,0:20:43.80,0:20:47.25,sign,,0000,0000,0000,,"SEMUA RAMEN DIHABISKAN DENGAN NIKMAT PARA STAF"
Dialogue: 0,0:01:34.38,0:01:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini ada siswa pindahan yang bergabung.
Dialogue: 0,0:01:38.20,0:01:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa pindahan? Lagi?
Dialogue: 0,0:01:40.25,0:01:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas kita banyak siswa pindahan, ya.
Dialogue: 0,0:01:44.66,0:01:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Rindo Eiji.
Dialogue: 0,0:01:46.51,0:01:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, rukun-rukun, ya.
Dialogue: 0,0:01:50.81,0:01:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal, hari-hari damai.
Dialogue: 0,0:01:52.78,0:01:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, dunia bunuh-membunuh.
Dialogue: 0,0:01:54.67,0:01:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingginya.
Dialogue: 0,0:01:55.81,0:01:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sepantaran kita?
Dialogue: 0,0:01:57.18,0:01:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu di jidatnya?
Dialogue: 0,0:01:58.78,0:01:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baut?
Dialogue: 0,0:01:59.38,0:02:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaya fesyen?
Dialogue: 0,0:02:00.22,0:02:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, muncul lagi karakter aneh.
Dialogue: 0,0:02:04.41,0:02:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa?
Dialogue: 0,0:02:06.35,0:02:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ga-Gawat, dia tipeku.
Dialogue: 0,0:02:09.41,0:02:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Dia tipemu?
Dialogue: 0,0:02:11.81,0:02:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:02:13.11,0:02:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok, wajahnya tidak asing?
Dialogue: 0,0:02:17.40,0:02:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menemukan satu pembunuh bayaran\Ndi sekolah saja sudah aneh, tapi…
Dialogue: 0,0:02:21.55,0:02:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:02:22.66,0:02:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Rindo, silakan duduk.
Dialogue: 0,0:02:25.31,0:02:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak tanggung-tanggung, empat orang\Nmenyusup sekaligus. Sungguh tidak lazim.
Dialogue: 0,0:02:29.17,0:02:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merasa situasinya mulai genting,\NOgami segera mengumpulkan mereka.
Dialogue: 0,0:02:33.58,0:02:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertemuan pertama para pembunuh bayaran\Npun dimulai.
Dialogue: 0,0:02:37.51,0:02:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Yugang, organisasi Tiongkok\Nperingkat dua di dunia pembunuh bayaran,
Dialogue: 0,0:02:41.39,0:02:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohazame Shin.
Dialogue: 0,0:02:43.31,0:02:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perwakilan organisasi terbesar\Ndi industri, Jardin,
Dialogue: 0,0:02:46.25,0:02:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo bersaudara.
Dialogue: 0,0:02:50.41,0:02:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:02:51.31,0:02:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Abang anggota Z.O.O,\Norganisasi veteran peringkat tiga.
Dialogue: 0,0:02:55.78,0:02:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak disangka, gara-gara Noren,
Dialogue: 0,0:02:57.66,0:02:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiga organisasi besar\Nbisa berkumpul sekaligus.
Dialogue: 0,0:02:59.95,0:03:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa sampai semua\Ndikumpulkan begini?
Dialogue: 0,0:03:02.61,0:03:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti sudah tahu\Nidentitas masing-masing, 'kan?
Dialogue: 0,0:03:05.41,0:03:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, mari berteman.
Dialogue: 0,0:03:08.15,0:03:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bikin keributan.
Dialogue: 0,0:03:11.45,0:03:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon.
Dialogue: 0,0:03:13.21,0:03:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau sampai sebegitunya?
Dialogue: 0,0:03:15.67,0:03:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa diingatkan pun,\Nkami takkan saling bunuh di tempat begini.
Dialogue: 0,0:03:19.41,0:03:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duelku dengan Mitsuoka pun\Nkutunda untuk sementara.
Dialogue: 0,0:03:22.14,0:03:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:03:24.11,0:03:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sayang sekali.
Dialogue: 0,0:03:26.43,0:03:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa akur dengan mereka.
Dialogue: 0,0:03:29.55,0:03:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama yang kecil itu.
Dialogue: 0,0:03:33.18,0:03:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu dia pernah merebut targetku.
Dialogue: 0,0:03:38.60,0:03:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, yang waktu itu, ya?
Dialogue: 0,0:03:40.78,0:03:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kau terlalu lamban.
Dialogue: 0,0:03:43.61,0:03:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda. Caramu curang.
Dialogue: 0,0:03:47.18,0:03:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia target khusus yang harus\Nkubunuh dengan tanganku sendiri.
Dialogue: 0,0:03:51.65,0:03:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:03:52.85,0:03:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nharusnya kau selesaikan lebih cepat.
Dialogue: 0,0:03:56.78,0:03:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:04:04.14,0:04:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, Eiji.
Dialogue: 0,0:04:05.71,0:04:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini urusanku dengan dia.
Dialogue: 0,0:04:08.51,0:04:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan. Kalian semua…
Dialogue: 0,0:04:11.25,0:04:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian dengar aku, tidak, sih?
Dialogue: 0,0:04:12.91,0:04:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beginilah yang namanya keributan.
Dialogue: 0,0:04:17.41,0:04:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai catatan,
Dialogue: 0,0:04:18.51,0:04:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga kecewa padamu.
Dialogue: 0,0:04:21.85,0:04:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang kalah duel dan berjanji\Nuntuk menjauhi Noren.
Dialogue: 0,0:04:27.01,0:04:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi nyatanya, dia diculik dengan mudah\Nbeberapa hari lalu, 'kan?
Dialogue: 0,0:04:31.45,0:04:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dia selamat,
Dialogue: 0,0:04:33.11,0:04:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihat betapa tak becusnya kau,
Dialogue: 0,0:04:34.58,0:04:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi tak yakin bisa mempercayakan\Norang yang kucintai kepadamu.
Dialogue: 0,0:04:38.61,0:04:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu kuberi tahu siapa penculiknya.
Dialogue: 0,0:04:40.96,0:04:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Noren.
Dialogue: 0,0:04:44.05,0:04:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, di sini rupanya kau, Ogami.
Dialogue: 0,0:04:46.65,0:04:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, tak ada kegiatan klub,\Nayo pulang bareng.
Dialogue: 0,0:04:50.71,0:04:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan kerumunan ini?
Dialogue: 0,0:04:52.35,0:04:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, kita sudahi dulu.
Dialogue: 0,0:04:54.81,0:04:56.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu khawatir.
Dialogue: 0,0:04:56.91,0:04:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak sengaja saling cari,
Dialogue: 0,0:04:58.44,0:05:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}siswa tahun pertama dan ketiga\Njarang berpapasan.
Dialogue: 0,0:05:01.41,0:05:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampun.
Dialogue: 0,0:05:06.45,0:05:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sepatuku hilang.
Dialogue: 0,0:05:08.32,0:05:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kok, bisa?
Dialogue: 0,0:05:10.51,0:05:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren.
Dialogue: 0,0:05:13.38,0:05:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuhangatkan.
Dialogue: 0,0:05:15.31,0:05:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah awal musim panas, tahu.
Dialogue: 0,0:05:17.10,0:05:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudku.\NMemang kau Toyotomi Hideyoshi?
Dialogue: 0,0:05:19.07,0:05:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau ini ngapain?
Dialogue: 0,0:05:21.05,0:05:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya!
Dialogue: 0,0:05:24.78,0:05:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kumbang.
Dialogue: 0,0:05:25.70,0:05:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak berbahaya.
Dialogue: 0,0:05:39.61,0:05:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kau juga ikut?
Dialogue: 0,0:05:41.41,0:05:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, sebenarnya kau kenapa?
Dialogue: 0,0:05:43.31,0:05:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melindungi Noren\Nyang berharga bagiku.
Dialogue: 0,0:05:45.85,0:05:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, aku akan selalu bersamamu.\NSudah kuputuskan.
Dialogue: 0,0:05:48.99,0:05:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Selalu?
Dialogue: 0,0:05:52.61,0:05:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, selalu.
Dialogue: 0,0:05:53.63,0:05:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat makan, mandi, bahkan tidur.
Dialogue: 0,0:05:57.33,0:06:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Jelas kutolak, bodoh!
Dialogue: 0,0:06:01.18,0:06:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, Shin bertingkah aneh.
Dialogue: 0,0:06:03.50,0:06:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:06:04.91,0:06:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua gara-gara aku tak becus.
Dialogue: 0,0:06:07.05,0:06:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara kau tak becus,\NShin sampai jadi begini?
Dialogue: 0,0:06:11.05,0:06:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekap pertemuan pertama\Npara pembunuh bayaran.
Dialogue: 0,0:06:13.45,0:06:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu: tiga dari empat peserta\Nterlibat perselisihan.
Dialogue: 0,0:06:16.21,0:06:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua: Kohazame Shin\Nberubah jadi penguntit.
Dialogue: 0,0:06:19.65,0:06:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira laporan begini\Nbakal disetujui, tidak, ya?
Dialogue: 0,0:06:27.61,0:06:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:06:28.75,0:06:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa, tuh?
Dialogue: 0,0:06:31.55,0:06:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa melihatku, 'kan?
Dialogue: 0,0:06:33.21,0:06:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, cuma bercanda.
Dialogue: 0,0:06:35.58,0:06:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan elus kepalaku.
Dialogue: 0,0:06:40.51,0:06:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buatanmu sendiri?
Dialogue: 0,0:06:41.96,0:06:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kotaknya kecil sekali.
Dialogue: 0,0:06:43.98,0:06:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sanggup habiskan lebih dari ini.
Dialogue: 0,0:06:46.31,0:06:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari suara sampai segalanya, imut semua.
Dialogue: 0,0:06:49.75,0:06:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, jangan elus kepalaku.
Dialogue: 0,0:06:54.31,0:06:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:06:55.38,0:06:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Tamada Mai.
Dialogue: 0,0:06:57.21,0:07:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa tahun kedua, anggota Klub Tata Boga,\Ndan Senior Ogami.
Dialogue: 0,0:07:00.91,0:07:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tidak kenal?
Dialogue: 0,0:07:02.36,0:07:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, selama ini aku cuma muncul sekilas.
Dialogue: 0,0:07:07.21,0:07:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang berkenalan, mulai sekarang.
Dialogue: 0,0:07:10.66,0:07:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi badanku…
Dialogue: 0,0:07:12.45,0:07:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imutnya.
Dialogue: 0,0:07:13.27,0:07:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah…
Dialogue: 0,0:07:15.73,0:07:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, dia kelas 2?
Dialogue: 0,0:07:17.05,0:07:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang paling pendek di klub.
Dialogue: 0,0:07:20.81,0:07:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya hari ini aku mau minta bantuan.
Dialogue: 0,0:07:23.41,0:07:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami.
Dialogue: 0,0:07:24.78,0:07:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:07:25.65,0:07:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kak Tamada?
Dialogue: 0,0:07:29.09,0:07:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:34.60,0:07:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau jadi kekar berotot.
Dialogue: 0,0:07:36.35,0:07:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:07:37.31,0:07:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:07:38.65,0:07:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar tidak diremehkan?
Dialogue: 0,0:07:39.91,0:07:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah meremehkan Senior, kok.
Dialogue: 0,0:07:42.85,0:07:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di Klub Tata Boga, tidak ada masalah.
Dialogue: 0,0:07:45.25,0:07:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya di kelas,\Naku sering dijadikan bahan godaan.
Dialogue: 0,0:07:49.51,0:07:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Kakak sudah keren apa adanya.
Dialogue: 0,0:07:53.11,0:07:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren yang tinggi semampai mana paham\Nperasaan orang pendek.
Dialogue: 0,0:07:57.38,0:08:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua bilang "imut, imut"\Nsambil mengelus kepalaku.
Dialogue: 0,0:08:00.25,0:08:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini bukan hewan peliharaan, lo.
Dialogue: 0,0:08:03.08,0:08:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham mereka tak bermaksud jahat.
Dialogue: 0,0:08:06.50,0:08:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu mereka sayang padaku.
Dialogue: 0,0:08:08.40,0:08:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi justru karena itu,\Nrasanya mereka tak menganggapku setara.
Dialogue: 0,0:08:12.35,0:08:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya harus jadi lebih besar.
Dialogue: 0,0:08:13.97,0:08:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi tak nambah pun tak apa,\Nkita bisa besar ke samping.
Dialogue: 0,0:08:16.47,0:08:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai beli dumbel.
Dialogue: 0,0:08:18.25,0:08:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya memutuskan latihan otot.
Dialogue: 0,0:08:19.78,0:08:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dumbel yang bisa diatur.
Dialogue: 0,0:08:24.71,0:08:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bahuku lebar…
Dialogue: 0,0:08:26.21,0:08:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bahuku lebih lebar…
Dialogue: 0,0:08:28.58,0:08:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus bahu?\NImajinasinya menyeramkan.
Dialogue: 0,0:08:31.41,0:08:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukannya Kakak suka kerajinan tangan?
Dialogue: 0,0:08:33.82,0:08:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak berniat berhenti, kok.
Dialogue: 0,0:08:36.01,0:08:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin punya bahu sebesar melon.
Dialogue: 0,0:08:38.90,0:08:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahu sebesar melon?
Dialogue: 0,0:08:40.33,0:08:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham situasinya.
Dialogue: 0,0:08:42.40,0:08:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa minta bantuanku?
Dialogue: 0,0:08:43.75,0:08:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Sebenarnya aku mau minta tolong…
Dialogue: 0,0:08:46.85,0:08:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kau kenalkan aku ke Tendo Tenma?
Dialogue: 0,0:08:50.80,0:08:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal melatih otot,
Dialogue: 0,0:08:52.35,0:08:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang paling tepat\Npasti pria sekuat dia.
Dialogue: 0,0:08:55.45,0:08:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu mau berotot,\Ntujuanmu langsung ke sana?
Dialogue: 0,0:08:59.11,0:09:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia itu…
Dialogue: 0,0:09:00.45,0:09:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling dia juga tidak ingat aku, 'kan?
Dialogue: 0,0:09:04.35,0:09:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku minta tolong.
Dialogue: 0,0:09:05.23,0:09:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, meski begitu…
Dialogue: 0,0:09:09.94,0:09:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, kenalkan aku ke Tendo.
Dialogue: 0,0:09:13.18,0:09:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:09:14.01,0:09:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hentikan shoulder press itu.\NKasihan otot deltoidmu.
Dialogue: 0,0:09:19.58,0:09:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Ogami dan anak Klub Tata Boga?\NAda apa?
Dialogue: 0,0:09:22.04,0:09:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau kenal aku?
Dialogue: 0,0:09:24.51,0:09:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat wajahmu, kalau nama tak tahu.
Dialogue: 0,0:09:27.18,0:09:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak Klub Tata Boga itu\Npunya ciri khas tersendiri.
Dialogue: 0,0:09:31.15,0:09:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada urusan apa?
Dialogue: 0,0:09:32.58,0:09:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk dulu, deh.\NPandanganku mentok di pinggangmu.
Dialogue: 0,0:09:36.21,0:09:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau ingin tubuh lebih besar\Nbiar tak diremehkan?
Dialogue: 0,0:09:39.45,0:09:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma. Mending berhenti saja.
Dialogue: 0,0:09:42.01,0:09:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, paling tidak aku bisa kasih\Nsedikit saran soal menu latihan.
Dialogue: 0,0:09:45.61,0:09:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sedikit tambahan otot\Ntak akan banyak ngaruh.
Dialogue: 0,0:09:48.65,0:09:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku atau Ogami serius,\Nkau tetap bakal tumbang dalam satu pukulan.
Dialogue: 0,0:09:55.03,0:09:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa masalahnya bukan itu.
Dialogue: 0,0:09:57.95,0:09:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:09:58.98,0:10:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu blak-blakan.
Dialogue: 0,0:10:10.22,0:10:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya, Kak Tamada.
Dialogue: 0,0:10:12.46,0:10:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang benar-benar mengenalmu\Ntakkan memandangmu sebelah mata.
Dialogue: 0,0:10:16.11,0:10:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:10:17.65,0:10:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, kedua orang tuaku juga pendek.
Dialogue: 0,0:10:20.58,0:10:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kalau aku tak menunjukkan\Npendirianku dengan jelas,
Dialogue: 0,0:10:22.81,0:10:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya aku akan terus diperlakukan\Nseperti hewan kecil selamanya.
Dialogue: 0,0:10:26.75,0:10:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memikirkannya saja sudah bikin kesal.
Dialogue: 0,0:10:31.45,0:10:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak keberatan,\Nsepulang sekolah,
Dialogue: 0,0:10:33.05,0:10:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau mampir ke toko pamanku,\Neh, salah, bibiku?
Dialogue: 0,0:10:40.25,0:10:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Dik Juzo.
Dialogue: 0,0:10:42.66,0:10:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini senior klub\Nyang kau ceritakan itu, ya?
Dialogue: 0,0:10:45.51,0:10:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:10:48.51,0:10:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Besar sekali.
Dialogue: 0,0:10:51.35,0:10:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih besar daripada Tenma.
Dialogue: 0,0:10:53.11,0:10:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pinggulnya saja setinggi itu, aku bahkan\Nbisa lewat di bawah kakinya begitu saja.
Dialogue: 0,0:10:57.85,0:11:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ehm, raksasa perang.
Dialogue: 0,0:11:00.76,0:11:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum apa-apa sudah menghina, ya.\NMau kuhajar sampai babak belur?
Dialogue: 0,0:11:05.91,0:11:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Mama. Kami datang sebelum toko buka.
Dialogue: 0,0:11:08.71,0:11:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa, masih sore.
Dialogue: 0,0:11:10.90,0:11:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya masuk dulu.
Dialogue: 0,0:11:13.75,0:11:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:14.91,0:11:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa nanti aku bisa keluar selamat?
Dialogue: 0,0:11:20.78,0:11:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu malah nilai plus,\Nkecil dan imut?
Dialogue: 0,0:11:23.61,0:11:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau tak suka itu, ya.
Dialogue: 0,0:11:26.31,0:11:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan apa, sih, sampai bisa sebesar itu?
Dialogue: 0,0:11:30.41,0:11:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, mungkin daging?
Dialogue: 0,0:11:34.01,0:11:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar juga.
Dialogue: 0,0:11:35.85,0:11:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejauh ini aku hampir\Ntak pernah diremehkan.
Dialogue: 0,0:11:39.98,0:11:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun ada, biasanya langsung kuhajar\Nhabis-habisan sampai tak bisa bergerak.
Dialogue: 0,0:11:43.91,0:11:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:11:45.01,0:11:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah merasakan\Nperasaan sepertimu.
Dialogue: 0,0:11:49.25,0:11:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti.
Dialogue: 0,0:11:51.51,0:11:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Kau iri?
Dialogue: 0,0:11:55.25,0:11:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:57.15,0:12:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku justru iri padamu.
Dialogue: 0,0:12:02.31,0:12:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada jadi wanita terkuat\Nyang tak bisa didekati siapa pun,
Dialogue: 0,0:12:06.25,0:12:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin terlahir sebagai gadis imut.
Dialogue: 0,0:12:10.25,0:12:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau punya sesuatu\Nyang tak bisa kumiliki,
Dialogue: 0,0:12:13.65,0:12:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau malah terus mengeluh.
Dialogue: 0,0:12:19.71,0:12:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Highball-nya dua, ya.
Dialogue: 0,0:12:22.85,0:12:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan pelanggan tetap, ya?
Dialogue: 0,0:12:24.31,0:12:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok, sudah mabuk dari jam segini?
Dialogue: 0,0:12:27.30,0:12:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami masih belum buka.
Dialogue: 0,0:12:30.35,0:12:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa, 'kan? Kami ini tamu.
Dialogue: 0,0:12:33.15,0:12:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dari penampilanmu, kau anak SD, 'kan?
Dialogue: 0,0:12:36.55,0:12:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak boleh ke tempat begini.
Dialogue: 0,0:12:47.05,0:12:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:12:48.41,0:12:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu gadis idamanku.
Dialogue: 0,0:12:50.81,0:12:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan asal ganggu.
Dialogue: 0,0:12:53.55,0:12:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau masih bikin ulah,\Nbisa kubuat kau pingsan sampai pagi.
Dialogue: 0,0:13:04.51,0:13:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:13:05.95,0:13:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus melayani tamu lain dulu.\NDatang lagi, ya, lain kali.
Dialogue: 0,0:13:12.25,0:13:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:17.38,0:13:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram.
Dialogue: 0,0:13:19.15,0:13:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah diajak ke sini?
Dialogue: 0,0:13:21.25,0:13:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bagian terakhir itu di luar rencana.
Dialogue: 0,0:13:23.51,0:13:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ketakutan setengah mati, nih.
Dialogue: 0,0:13:32.45,0:13:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau ini.
Dialogue: 0,0:13:33.95,0:13:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking tak masuk akalnya,\Naku cuma bisa tertawa.
Dialogue: 0,0:13:41.78,0:13:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar, Ogami.
Dialogue: 0,0:13:43.61,0:13:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kau bawa Tama\Nke toko yang tak biasa.
Dialogue: 0,0:13:47.95,0:13:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:13:49.58,0:13:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mereka pergi ke toko itu, ya.
Dialogue: 0,0:13:52.21,0:13:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru, kok. Aku menikmatinya.
Dialogue: 0,0:13:54.35,0:13:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat itu, aku jadi merasa lebih baik.
Dialogue: 0,0:13:58.21,0:13:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:01.32,0:14:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tetap lanjut latihan otot.
Dialogue: 0,0:14:03.85,0:14:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Side raise.
Dialogue: 0,0:14:06.85,0:14:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, usai Kak Tamada\Nmelakukan side raise…
Dialogue: 0,0:14:11.87,0:14:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, kita bagi dua tim untuk bikin ramen.\NIni kompetisi serius.
Dialogue: 0,0:14:15.38,0:14:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang membuat ramen paling enak akan menang.
Dialogue: 0,0:14:19.75,0:14:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:14:21.55,0:14:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, asyik sekali.
Dialogue: 0,0:14:23.55,0:14:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,
Dialogue: 0,0:14:24.61,0:14:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ramen itu selalu bikin semangat begini.
Dialogue: 0,0:14:27.58,0:14:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:14:29.25,0:14:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ramen?
Dialogue: 0,0:14:32.01,0:14:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren?
Dialogue: 0,0:14:33.85,0:14:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah. Gawat.
Dialogue: 0,0:14:37.01,0:14:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya eraku telah tiba.
Dialogue: 0,0:14:39.98,0:14:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia percaya diri sekali.
Dialogue: 0,0:14:42.51,0:14:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Era apa maksudnya?
Dialogue: 0,0:14:43.71,0:14:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, semuanya. Beda level pro\Ndan amatir akan kelihatan sekarang.
Dialogue: 0,0:14:49.85,0:14:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu berlebihan.
Dialogue: 0,0:14:51.55,0:14:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga masih pemula\Ndibanding paman itu, 'kan?
Dialogue: 0,0:14:53.99,0:14:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tim sudah ditentukan.
Dialogue: 0,0:14:59.05,0:15:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompetisinya seminggu lagi.
Dialogue: 0,0:15:00.78,0:15:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masing-masing tim, silakan cari informasi\Ndan coba berbagai eksperimen.
Dialogue: 0,0:15:05.21,0:15:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, kau penggemar ramen, ya?
Dialogue: 0,0:15:07.75,0:15:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku akan berusaha.
Dialogue: 0,0:15:09.81,0:15:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren juga penggemar ramen, ya?
Dialogue: 0,0:15:12.05,0:15:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:12.85,0:15:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku agak punya\Nstandar khusus soal masakan Tiongkok.
Dialogue: 0,0:15:16.21,0:15:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak boleh asal-asalan\Natau menurunkan kualitas.
Dialogue: 0,0:15:19.15,0:15:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang mencintai Noren,
Dialogue: 0,0:15:21.95,0:15:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi untuk kali ini…
Dialogue: 0,0:15:23.58,0:15:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:15:24.95,0:15:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:27.96,0:15:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa minta maaf?
Dialogue: 0,0:15:30.35,0:15:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau minta maaf karena\Nyakin akan mengalahkanku?
Dialogue: 0,0:15:33.21,0:15:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:34.45,0:15:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon maaf.
Dialogue: 0,0:15:35.33,0:15:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Tunggu dulu.
Dialogue: 0,0:15:39.18,0:15:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sejarah ramen Tiongkok\Nsudah ribuan tahun,
Dialogue: 0,0:15:41.75,0:15:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ramen yang berkembang khas di Jepang\Nkini sudah jadi kategori tersendiri.
Dialogue: 0,0:15:46.35,0:15:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sombong hanya karena\Nasalnya dari sana.
Dialogue: 0,0:15:50.61,0:15:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena asalnya dari Tiongkok.
Dialogue: 0,0:15:52.71,0:15:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengakui perkembangan dan keunikannya,
Dialogue: 0,0:15:54.78,0:15:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi konsepnya belum cukup matang.
Dialogue: 0,0:15:58.15,0:15:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan konsep yang belum matang itu,
Dialogue: 0,0:15:59.71,0:16:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan merasa sudah jadi\Nkategori tersendiri.
Dialogue: 0,0:16:03.25,0:16:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga cukup percaya diri, ya.
Dialogue: 0,0:16:05.61,0:16:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai kalah nanti,\Nmau beralasan apa?
Dialogue: 0,0:16:08.55,0:16:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan kalah,\Nmakanya kuminta maaf lebih dulu.
Dialogue: 0,0:16:11.05,0:16:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan minta maaf, itu provokasi.
Dialogue: 0,0:16:15.21,0:16:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin membuatmu menangis.
Dialogue: 0,0:16:17.38,0:16:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong mundur saja.
Dialogue: 0,0:16:19.65,0:16:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke. Kalau begitu, ini perang.
Dialogue: 0,0:16:23.01,0:16:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren? Noren, kau dengar, tidak?
Dialogue: 0,0:16:25.33,0:16:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantangmu. Kalau aku menang,\Nkau harus berhenti jadi penguntit.
Dialogue: 0,0:16:28.61,0:16:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu, itu tak perlu jadi syarat,\Nmenguntit itu memang harus dihentikan.
Dialogue: 0,0:16:32.59,0:16:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terima tantanganmu.\NKalau begitu, kalau aku menang,
Dialogue: 0,0:16:35.25,0:16:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bacakan dongeng untukku, ya.
Dialogue: 0,0:16:36.98,0:16:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini sudah masuk ke level aneh\Nyang agak berbahaya.
Dialogue: 0,0:16:41.78,0:16:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo, Ogami!
Dialogue: 0,0:16:44.29,0:16:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita keliling makan\Ndi berbagai tempat untuk riset.
Dialogue: 0,0:16:46.91,0:16:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga, Kak Yamaoka, ayo kita pergi.
Dialogue: 0,0:16:48.94,0:16:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kita masih ada kegiatan klub.
Dialogue: 0,0:16:51.71,0:16:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo pergi.
Dialogue: 0,0:16:52.95,0:16:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:54.75,0:16:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jadi merepotkan.
Dialogue: 0,0:17:01.54,0:17:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, ke tempat berikutnya.
Dialogue: 0,0:17:04.41,0:17:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:17:05.60,0:17:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren.
Dialogue: 0,0:17:06.98,0:17:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mau ke berapa tempat lagi?
Dialogue: 0,0:17:09.91,0:17:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perutku sudah mau meledak, nih.
Dialogue: 0,0:17:13.81,0:17:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Baru delapan tempat, kok.
Dialogue: 0,0:17:16.45,0:17:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan mangkuk itu\Nsudah hampir batas maut.
Dialogue: 0,0:17:20.41,0:17:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku saja yang lanjut.\NKalian pulang duluan saja.
Dialogue: 0,0:17:24.38,0:17:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau bisa lari normal\Ndan perutmu tak melar?
Dialogue: 0,0:17:27.94,0:17:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin perutku bakal jebol\Nkalau lanjut makan.
Dialogue: 0,0:17:34.71,0:17:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat dulu, deh.
Dialogue: 0,0:18:02.35,0:18:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:18:04.41,0:18:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, terima kasih.
Dialogue: 0,0:18:09.15,0:18:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:18:10.78,0:18:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, mau muntah.
Dialogue: 0,0:18:12.98,0:18:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:18:18.81,0:18:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi! Kau tidak apa-apa?
Dialogue: 0,0:18:21.18,0:18:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau terluka?
Dialogue: 0,0:18:25.81,0:18:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontes ramen Klub Tata Boga dimulai.
Dialogue: 0,0:18:29.71,0:18:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:18:31.29,0:18:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, biar adil, aku minta\Nseorang gadis yang lewat untuk jadi juri.
Dialogue: 0,0:18:37.65,0:18:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, mendadak.
Dialogue: 0,0:18:39.30,0:18:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa. Aku suka ramen.
Dialogue: 0,0:18:42.76,0:18:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, dimulai dari tim Kohazame dan Yamaoka.
Dialogue: 0,0:18:46.25,0:18:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan tunjukkan ramen\Nyang belum pernah kalian lihat.
Dialogue: 0,0:18:50.31,0:18:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi biangbiang.
Dialogue: 0,0:18:51.68,0:18:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Ini memang belum pernah kulihat,\Nitu sejenis mi?
Dialogue: 0,0:18:56.21,0:18:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi tebal dan pipih seperti kishimen.
Dialogue: 0,0:18:58.71,0:19:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disajikan dengan saus\Nserta toping pelengkap.
Dialogue: 0,0:19:00.81,0:19:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hidangan tradisional\Ndari Provinsi Shaanxi, Tiongkok.
Dialogue: 0,0:19:04.05,0:19:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ini benar-benar kenyal.
Dialogue: 0,0:19:08.01,0:19:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, biar makin nikmat dikunyah,
Dialogue: 0,0:19:10.35,0:19:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebar dan tebalnya dibuat tiga kali lipat\Ndari biasanya, jadi mi super tebal.
Dialogue: 0,0:19:15.95,0:19:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:19:30.95,0:19:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dinikmati.
Dialogue: 0,0:19:33.37,0:19:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi-nya terlalu berat untuk dimakan.\NNol poin.
Dialogue: 0,0:19:37.75,0:19:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nol poin?
Dialogue: 0,0:19:42.35,0:19:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cuma omong besar.\NIni kemenangan kami.
Dialogue: 0,0:19:45.85,0:19:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum ketahuan siapa pemenangnya.
Dialogue: 0,0:19:48.98,0:19:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, siapa dia?
Dialogue: 0,0:19:50.78,0:19:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, tim Mitsuoka dan Ogami.
Dialogue: 0,0:19:54.35,0:19:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mencoba berbagai ramen\Nsampai detik ini.
Dialogue: 0,0:19:57.75,0:19:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu akhirnya,
Dialogue: 0,0:19:59.81,0:20:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kutemukan ramen yang paling sempurna.
Dialogue: 0,0:20:01.75,0:20:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ketemu?
Dialogue: 0,0:20:03.42,0:20:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:20:04.65,0:20:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Campuran tonkotsu iekei,\Nblack shoyu, shio, miso, tantan,
Dialogue: 0,0:20:08.25,0:20:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kitakata gyokai tonkotsu,\Ntori paitan, ninniku, sayuran ekstra,
Dialogue: 0,0:20:12.58,0:20:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karami abura, dan Chomolungma.
Dialogue: 0,0:20:15.11,0:20:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekstra banget.\NIni, sih, semua menu jadi satu.
Dialogue: 0,0:20:20.18,0:20:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah seperti ramen Chimera.
Dialogue: 0,0:20:22.18,0:20:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garam, gula, dan minyak,\Nsemuanya berlebihan.
Dialogue: 0,0:20:24.61,0:20:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti sumber segala penyakit.
Dialogue: 0,0:20:26.85,0:20:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pasti 100 persen.
Dialogue: 0,0:20:30.11,0:20:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:20:31.85,0:20:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:20:34.11,0:20:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa. Maaf.
Dialogue: 0,0:20:37.58,0:20:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, ya. Maaf. Nol poin.
Dialogue: 0,0:20:41.81,0:20:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kita lanjut ke tim berikutnya.
Dialogue: 0,0:20:43.80,0:20:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya tim Kak Chisato dan Nishimura menang.
Dialogue: 0,0:20:47.25,0:20:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore.
Dialogue: 0,0:20:48.38,0:20:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kekuatan senior.
Dialogue: 0,0:20:54.73,0:20:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih. Maaf sudah merepotkan.
Dialogue: 0,0:20:57.51,0:20:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa. Asyik, kok.
Dialogue: 0,0:21:00.31,0:21:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, sebenarnya aku punya\Nhal yang ingin dibicarakan…
Dialogue: 0,0:21:06.81,0:21:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Kau yang dulu pernah\Nkuselamatkan, ya?
Dialogue: 0,0:21:10.66,0:21:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, benar sekali. Jadi…
Dialogue: 0,0:21:14.91,0:21:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kusampaikan pada Ogami.
Dialogue: 0,0:21:20.05,0:21:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku tidur sebentar\Nuntuk ganti kepribadian?
Dialogue: 0,0:21:26.75,0:21:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:29.95,0:21:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:21:41.35,0:21:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah?
Dialogue: 0,0:21:42.65,0:21:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:21:43.78,0:21:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak paham.
Dialogue: 0,0:21:45.78,0:21:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia tiba-tiba tidur?
Dialogue: 0,0:22:07.22,0:22:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuat kalian menunggu.
