Dialogue: 0,0:02:53.94,0:02:57.94,tanda,,0000,0000,0000,,MITSUOKA NOREN SABTU, 8 APRIL
Dialogue: 0,0:05:17.63,0:05:19.92,tanda,,0000,0000,0000,,KELAS SELANJUTNYA DI LAB IPA.
Dialogue: 0,0:05:27.45,0:05:28.59,tanda,,0000,0000,0000,,IPA SMP KELAS 1.
Dialogue: 0,0:05:47.68,0:05:50.36,tanda,,0000,0000,0000,,JIJIK
Dialogue: 0,0:06:54.93,0:06:58.23,tanda,,0000,0000,0000,,RAMEN NATSUKIYA
Dialogue: 0,0:09:32.13,0:09:32.73,tanda,,0000,0000,0000,,RAMEN NATSUKIYA
Dialogue: 0,0:00:04.98,0:00:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh,
Dialogue: 0,0:00:07.55,0:00:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pembunuh bayaran jadi remaja saja\Nsudah aneh.
Dialogue: 0,0:00:10.38,0:00:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini malah keasyikan belajar.
Dialogue: 0,0:00:13.91,0:00:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:00:15.05,0:00:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan,
Dialogue: 0,0:00:16.25,0:00:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau sengaja menambah pengetahuan\Nbiar makin banyak dapat tawaran kerja?
Dialogue: 0,0:00:19.51,0:00:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin.
Dialogue: 0,0:00:21.05,0:00:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulakukan karena asyik saja.
Dialogue: 0,0:00:23.98,0:00:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar itu asyik katamu?
Dialogue: 0,0:00:26.38,0:00:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak paham.
Dialogue: 0,0:00:28.45,0:00:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa?
Dialogue: 0,0:00:30.21,0:00:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, mungkin karena masih muda kali, ya?
Dialogue: 0,0:00:35.21,0:00:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oga, pagi!
Dialogue: 0,0:00:38.21,0:00:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau menyapaku?
Dialogue: 0,0:00:40.71,0:00:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:00:41.61,0:00:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:00:44.55,0:00:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:00:46.09,0:00:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takada, Baba.
Dialogue: 0,0:00:49.38,0:00:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan senyum. Jijik.
Dialogue: 0,0:00:53.38,0:00:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, lebih sering gabung\Nobrolan grup kelas, dong.
Dialogue: 0,0:00:56.58,0:00:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:57.91,0:00:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obrolan grup?
Dialogue: 0,0:00:58.98,0:01:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, di medsos maksudnya?
Dialogue: 0,0:01:01.65,0:01:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuusahakan.
Dialogue: 0,0:01:04.31,0:01:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tidak cocok dengan anak-anak.
Dialogue: 0,0:01:09.35,0:01:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa pembunuh bayaran paling ditakuti\Njadi seorang Oga?
Dialogue: 0,0:02:58.25,0:02:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Noren, 'kan?
Dialogue: 0,0:02:59.78,0:03:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren!
Dialogue: 0,0:03:02.35,0:03:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil posisi!
Dialogue: 0,0:03:04.65,0:03:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap!
Dialogue: 0,0:03:13.21,0:03:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hebat!\N- Cepat!
Dialogue: 0,0:03:14.95,0:03:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cepat sekali!\N- Ya, 'kan?
Dialogue: 0,0:03:17.35,0:03:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat mukanya itu.
Dialogue: 0,0:03:27.31,0:03:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pergi ke toko buku.
Dialogue: 0,0:03:30.49,0:03:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mencari buku bahasa asing\Nuntuk kelasnya.
Dialogue: 0,0:03:33.16,0:03:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berkeliling toko.
Dialogue: 0,0:03:35.25,0:03:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria menyapanya, lalu dia bertanya,
Dialogue: 0,0:03:37.75,0:03:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Buku bahasa asing di mana?" tanyanya.
Dialogue: 0,0:03:40.64,0:03:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu menunjuk, dan dia amat senang.
Dialogue: 0,0:03:45.44,0:03:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Mitsuoka Noren.
Dialogue: 0,0:03:48.55,0:03:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bisa dekat dengannya,\Nkita mungkin dapat informasi berguna.
Dialogue: 0,0:03:53.35,0:03:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Tunggu dulu.
Dialogue: 0,0:03:55.65,0:03:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma anak direktur\NFarmasi Mitsuoka, 'kan?
Dialogue: 0,0:03:59.45,0:04:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin dia punya info penting.
Dialogue: 0,0:04:01.51,0:04:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar.
Dialogue: 0,0:04:04.15,0:04:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita perlu petunjuk,\Nsekecil apa pun itu.
Dialogue: 0,0:04:12.18,0:04:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Enaknya istirahat melakukan apa, ya?\N- Meski begitu...
Dialogue: 0,0:04:15.31,0:04:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kau menyendiri lagi!
Dialogue: 0,0:04:18.31,0:04:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik, diam kau.
Dialogue: 0,0:04:20.55,0:04:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesenjangan generasinya terlalu besar.
Dialogue: 0,0:04:23.71,0:04:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah lebih aneh kalau aku\Ncocok dengan mereka.
Dialogue: 0,0:04:27.91,0:04:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar memang menyenangkan,
Dialogue: 0,0:04:30.65,0:04:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sekolah bukan tempat\Nuntuk Pak Tua sepertiku.
Dialogue: 0,0:04:33.98,0:04:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alangkah lebih baik\Nsegera kembali menjadi dewasa.
Dialogue: 0,0:04:36.21,0:04:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tujuan utama kita.
Dialogue: 0,0:04:39.21,0:04:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sekali.
Dialogue: 0,0:04:40.71,0:04:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, seperti kata Kak Eri...
Dialogue: 0,0:04:46.81,0:04:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:04:48.15,0:04:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh berharap.
Dialogue: 0,0:04:50.35,0:04:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi coba dulu saja.
Dialogue: 0,0:04:54.91,0:04:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuoka.
Dialogue: 0,0:04:58.11,0:04:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kuganggu sebentar?
Dialogue: 0,0:05:00.91,0:05:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Mau apa? Jijik.
Dialogue: 0,0:05:02.98,0:05:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak penting, pergi sana.
Dialogue: 0,0:05:08.76,0:05:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Sampai jumpa.
Dialogue: 0,0:05:33.31,0:05:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kuatkan dirimu!
Dialogue: 0,0:05:35.95,0:05:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, dibilang jijik.
Dialogue: 0,0:05:37.91,0:05:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang terburuk!
Dialogue: 0,0:05:39.65,0:05:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibilang menjijikkan dengan\Nintonasi seperti itu.
Dialogue: 0,0:05:42.05,0:05:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedih sekali.
Dialogue: 0,0:05:50.40,0:05:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang!
Dialogue: 0,0:05:52.71,0:05:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu...
Dialogue: 0,0:05:54.95,0:05:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Oga!
Dialogue: 0,0:05:56.25,0:05:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kau? Jijik.
Dialogue: 0,0:05:57.65,0:05:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi?
Dialogue: 0,0:05:59.58,0:06:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Noren, ya.
Dialogue: 0,0:06:01.75,0:06:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benci cowok.
Dialogue: 0,0:06:04.35,0:06:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya kau tidak tahu.
Dialogue: 0,0:06:06.78,0:06:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:07.91,0:06:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pintar, jago olahraga,\Nanak orang kaya pula.
Dialogue: 0,0:06:12.41,0:06:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan seperti anak SMP kebanyakan.
Dialogue: 0,0:06:15.65,0:06:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat perawakannya, sudah seperti model.
Dialogue: 0,0:06:19.01,0:06:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang menyatakan cinta\Ndan langsung ditolak.
Dialogue: 0,0:06:26.38,0:06:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ya...
Dialogue: 0,0:06:27.81,0:06:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan di kalangan cewek, dia penyendiri.
Dialogue: 0,0:06:31.15,0:06:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sulit didekati.
Dialogue: 0,0:06:34.85,0:06:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bagaimana, Bang?
Dialogue: 0,0:06:38.21,0:06:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini misi mustahil.
Dialogue: 0,0:06:40.41,0:06:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mulai saja sulit.
Dialogue: 0,0:06:43.21,0:06:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cowok sudah pasti ditolak.
Dialogue: 0,0:06:45.18,0:06:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi aku aslinya\Nadalah Pak Tua. Mustahil.
Dialogue: 0,0:06:48.31,0:06:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal sudah mustahil.
Dialogue: 0,0:06:51.45,0:06:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari menyerah.
Dialogue: 0,0:06:53.71,0:06:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:06:59.11,0:07:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru lihat kedai ini.
Dialogue: 0,0:07:03.98,0:07:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, jangan makan bawang!
Dialogue: 0,0:07:06.28,0:07:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:07:07.65,0:07:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan duduk.
Dialogue: 0,0:07:22.75,0:07:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:07:26.91,0:07:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan minumannya.
Dialogue: 0,0:07:28.78,0:07:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:30.15,0:07:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah siap pesan?
Dialogue: 0,0:07:31.78,0:07:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramen pakai telur.
Dialogue: 0,0:07:35.41,0:07:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramen pakai telur, satu!
Dialogue: 0,0:07:36.74,0:07:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:07:42.85,0:07:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:07:45.91,0:07:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Mitsuoka Noren!
Dialogue: 0,0:07:47.31,0:07:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia kerja di tempat ramen?
Dialogue: 0,0:07:50.18,0:07:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya anak SMP boleh kerja?
Dialogue: 0,0:07:52.65,0:07:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kerja saat kecil...
Dialogue: 0,0:07:55.01,0:07:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar dia, 'kan?
Dialogue: 0,0:07:57.31,0:07:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:08:00.15,0:08:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membingungkan.
Dialogue: 0,0:08:01.55,0:08:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan dahulu sajalah.
Dialogue: 0,0:08:12.75,0:08:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:08:14.21,0:08:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tampilannya biasa saja,
Dialogue: 0,0:08:18.05,0:08:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi minya sangat kenyal.
Dialogue: 0,0:08:22.18,0:08:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuahnya ini...
Dialogue: 0,0:08:28.35,0:08:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmat! Nikmat!
Dialogue: 0,0:08:29.81,0:08:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuahnya segar, tapi kaya rasa.
Dialogue: 0,0:08:32.40,0:08:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak. Mi dan kuahnya sangat serasi.
Dialogue: 0,0:08:36.45,0:08:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surga dunia.
Dialogue: 0,0:08:37.90,0:08:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:08:38.98,0:08:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:08:42.15,0:08:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah selesai makan,
Dialogue: 0,0:08:43.61,0:08:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}temui aku di belakang, ya.
Dialogue: 0,0:08:51.05,0:08:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Ogami, 'kan?
Dialogue: 0,0:08:53.01,0:08:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kau di sini?
Dialogue: 0,0:08:55.11,0:08:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahku dekat sini.
Dialogue: 0,0:08:58.21,0:09:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kupilih tempat ini karena sepi.\NKupikir bakal aman dari siapa pun.
Dialogue: 0,0:09:04.81,0:09:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:09:06.06,0:09:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali, ya.
Dialogue: 0,0:09:07.91,0:09:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!
Dialogue: 0,0:09:09.18,0:09:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong rahasiakan ini!
Dialogue: 0,0:09:13.11,0:09:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke saja.
Dialogue: 0,0:09:17.01,0:09:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap hari kau pulang sendirian?
Dialogue: 0,0:09:19.11,0:09:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Kenapa?
Dialogue: 0,0:09:21.31,0:09:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang menjemput?
Dialogue: 0,0:09:24.41,0:09:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kaya, 'kan?
Dialogue: 0,0:09:28.41,0:09:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau.
Dialogue: 0,0:09:30.98,0:09:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:09:32.78,0:09:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedai Natsukiya, ya?
Dialogue: 0,0:09:34.71,0:09:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman tadi pemiliknya.
Dialogue: 0,0:09:37.51,0:09:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak digaji.
Dialogue: 0,0:09:39.45,0:09:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya membantu sukarela.
Dialogue: 0,0:09:41.51,0:09:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan kerja, ya.
Dialogue: 0,0:09:43.41,0:09:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus buat apa?
Dialogue: 0,0:09:46.41,0:09:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:49.41,0:09:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini sudah teramat kaya.
Dialogue: 0,0:09:54.01,0:09:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku orang Kanada.
Dialogue: 0,0:09:56.71,0:09:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paras cantikku adalah turunan darinya.
Dialogue: 0,0:09:59.45,0:10:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sadar terlahir dengan privilese.
Dialogue: 0,0:10:01.38,0:10:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelebihan malah.
Dialogue: 0,0:10:02.65,0:10:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang bahkan menjodohkanku\Nsejak aku masih belia.
Dialogue: 0,0:10:07.75,0:10:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku masih SD.
Dialogue: 0,0:10:11.01,0:10:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kami baru bertemu.
Dialogue: 0,0:10:13.11,0:10:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal mereka belum mengenalku.
Dialogue: 0,0:10:15.35,0:10:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua penjilat ulung.
Dialogue: 0,0:10:18.05,0:10:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku cukup dewasa di usiaku,
Dialogue: 0,0:10:21.78,0:10:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka memperlakukanku bak orang dewasa.
Dialogue: 0,0:10:25.91,0:10:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar menjijikkan.
Dialogue: 0,0:10:30.45,0:10:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu SMP,
Dialogue: 0,0:10:31.95,0:10:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua cowok juga tertarik padaku.
Dialogue: 0,0:10:35.78,0:10:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengincar spek dewi ini.
Dialogue: 0,0:10:39.35,0:10:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:10:40.95,0:10:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi karena itu dia benci cowok.
Dialogue: 0,0:10:44.65,0:10:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi koki ramen!
Dialogue: 0,0:10:48.31,0:10:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:50.51,0:10:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah? Kok jadi itu?
Dialogue: 0,0:10:52.51,0:10:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mendengarkan atau tidak, sih?
Dialogue: 0,0:10:53.85,0:10:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka stigma\Nwanita itu harus menikah.
Dialogue: 0,0:10:56.71,0:10:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sangat kolot.
Dialogue: 0,0:11:00.45,0:11:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin hidup mandiri.
Dialogue: 0,0:11:03.15,0:11:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramen di kedai itu...
Dialogue: 0,0:11:08.45,0:11:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman juga benci pergaulan orang kaya,\Njadi dia memilih menjual ramen.
Dialogue: 0,0:11:21.05,0:11:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali aku murung,
Dialogue: 0,0:11:23.15,0:11:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia selalu menyuguhkan ramen\Ntanpa berkata apa-apa.
Dialogue: 0,0:11:35.25,0:11:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangkuk ramen hangat itu
Dialogue: 0,0:11:37.85,0:11:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangatlah enak.
Dialogue: 0,0:11:43.01,0:11:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, kau mirip Paman.
Dialogue: 0,0:11:48.11,0:11:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi banyak cerita.
Dialogue: 0,0:11:51.31,0:11:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.
Dialogue: 0,0:11:55.21,0:11:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan saja semaumu.
Dialogue: 0,0:12:00.38,0:12:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak bebas memilih,\Ntidak perlu menuruti keinginan orang tua.
Dialogue: 0,0:12:06.18,0:12:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramennya memang enak sekali.
Dialogue: 0,0:12:09.78,0:12:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama kuahnya.
Dialogue: 0,0:12:14.24,0:12:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:12:15.55,0:12:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuahnya memang maknyus, 'kan?
Dialogue: 0,0:12:19.01,0:12:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku membantu meracik kuah.
Dialogue: 0,0:12:22.85,0:12:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, senang sekali!
Dialogue: 0,0:12:24.21,0:12:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan utamanya kaldu ayam\Nyang dicampur kaldu boga bahari.
Dialogue: 0,0:12:28.31,0:12:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemilihan sayurnya juga...
Dialogue: 0,0:12:31.85,0:12:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belok sini.
Dialogue: 0,0:12:33.91,0:12:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga.
Dialogue: 0,0:12:35.65,0:12:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok, jangan tiba-tiba sok akrab, ya.
Dialogue: 0,0:12:40.18,0:12:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia kembali jadi pembenci cowok.
Dialogue: 0,0:13:06.15,0:13:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah?
Dialogue: 0,0:13:07.51,0:13:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba sekali, apa itu tadi?
Dialogue: 0,0:13:11.21,0:13:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahnya memang orang penting, sih.
Dialogue: 0,0:13:16.05,0:13:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak alasan untuk mengincarnya.
Dialogue: 0,0:13:19.58,0:13:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, aku mendapat informasi.
Dialogue: 0,0:13:23.45,0:13:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil tadi menggunakan\Npelat kawasan Hachioji.
Dialogue: 0,0:13:26.85,0:13:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat nomornya, sepertinya pelat palsu.
Dialogue: 0,0:13:30.78,0:13:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana?
Dialogue: 0,0:13:32.91,0:13:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku, sih...
Dialogue: 0,0:13:34.75,0:13:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan paling enak itu menurutku,
Dialogue: 0,0:13:37.51,0:13:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ya, ramen.
Dialogue: 0,0:13:40.15,0:13:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang.
Dialogue: 0,0:13:43.31,0:13:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluru pelacak dimasukkan ke tasnya, 'kan?
Dialogue: 0,0:13:46.45,0:13:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alat penyadapnya juga, 'kan?
Dialogue: 0,0:13:49.21,0:13:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:13:50.81,0:13:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, mau mengejar mereka? Mustahil.
Dialogue: 0,0:13:53.71,0:13:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlalu jauh.
Dialogue: 0,0:13:56.61,0:13:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya punya pistol.
Dialogue: 0,0:14:02.21,0:14:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:14:08.25,0:14:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini. Aku ini veteran, tahu.
Dialogue: 0,0:14:23.55,0:14:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarak tembaknya tidak mungkin sampai.
Dialogue: 0,0:14:25.65,0:14:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rencanamu?
Dialogue: 0,0:14:31.71,0:14:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubiarkan instingku bicara.
Dialogue: 0,0:14:43.55,0:14:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:14:45.71,0:14:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:14:50.15,0:14:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imajinasiku saja?
Dialogue: 0,0:14:51.21,0:14:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cek sana.
Dialogue: 0,0:14:53.01,0:14:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malas. Kau saja sana.
Dialogue: 0,0:14:58.18,0:15:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru makan semangkuk.
Dialogue: 0,0:15:07.35,0:15:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ya...
Dialogue: 0,0:15:08.58,0:15:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku biarkan
Dialogue: 0,0:15:10.58,0:15:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang akan\Nmeneruskan ramen itu hilang.
Dialogue: 0,0:15:20.55,0:15:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hampir sampai.
Dialogue: 0,0:15:22.15,0:15:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:15:33.75,0:15:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:15:35.55,0:15:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk yang manis, kami baik, kok.
Dialogue: 0,0:15:38.81,0:15:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang-kadang.
Dialogue: 0,0:15:39.70,0:15:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganmu pasti sakit, ya?
Dialogue: 0,0:15:42.05,0:15:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguhan anak SMP?
Dialogue: 0,0:15:43.78,0:15:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:15:44.98,0:15:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu cantik juga.
Dialogue: 0,0:15:46.61,0:15:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kucium?
Dialogue: 0,0:15:49.55,0:15:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat! Jijik!
Dialogue: 0,0:15:52.65,0:15:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:15:54.45,0:15:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja yang benar.
Dialogue: 0,0:15:56.58,0:15:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:15:58.31,0:15:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang bodoh.
Dialogue: 0,0:16:00.58,0:16:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh dia nanti, santai saja.
Dialogue: 0,0:16:03.98,0:16:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada syaratnya.\NAku punya satu pertanyaan.
Dialogue: 0,0:16:07.78,0:16:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahmu punya formulasi obat baru, 'kan?
Dialogue: 0,0:16:12.21,0:16:14.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu resepnya, 'kan?
Dialogue: 0,0:16:16.85,0:16:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku tidak mengerti.
Dialogue: 0,0:16:19.05,0:16:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengelak.
Dialogue: 0,0:16:20.61,0:16:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami punya informan.
Dialogue: 0,0:16:23.05,0:16:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau tidak tahu detailnya,
Dialogue: 0,0:16:25.41,0:16:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau tahu sesuatu.
Dialogue: 0,0:16:29.11,0:16:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu!
Dialogue: 0,0:16:29.95,0:16:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku tidak pernah\Nmembicarakan pekerjaannya!
Dialogue: 0,0:16:35.21,0:16:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sungguh?
Dialogue: 0,0:16:37.31,0:16:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu!
Dialogue: 0,0:16:38.55,0:16:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang!
Dialogue: 0,0:16:41.58,0:16:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kerja di tempat ramen, ya?
Dialogue: 0,0:16:44.45,0:16:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat suka ramen di kedai itu, ya?
Dialogue: 0,0:16:48.01,0:16:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin aku makan di sana.
Dialogue: 0,0:16:52.18,0:16:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya kotor.
Dialogue: 0,0:16:55.01,0:16:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya juga tidak enak.
Dialogue: 0,0:16:57.21,0:17:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan itu tidak layak.
Dialogue: 0,0:17:01.01,0:17:03.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya tutup kedai.
Dialogue: 0,0:17:04.91,0:17:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuobrak-abrik!
Dialogue: 0,0:17:10.78,0:17:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Paman penjual ramen\Ntidak ada hubungannya!
Dialogue: 0,0:17:14.18,0:17:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:17:15.81,0:17:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu aku formula rahasianya.
Dialogue: 0,0:17:18.55,0:17:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya minta itu.
Dialogue: 0,0:17:21.51,0:17:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:17:22.71,0:17:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar tidak tahu.
Dialogue: 0,0:17:32.41,0:17:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramen di kedai itu enak, lo.
Dialogue: 0,0:17:36.18,0:17:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lidahmu saja yang mati rasa.
Dialogue: 0,0:17:40.21,0:17:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:17:42.15,0:17:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, harus merahasiakan identitas kita.
Dialogue: 0,0:17:44.98,0:17:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang Tajima!
Dialogue: 0,0:17:46.21,0:17:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau? Dasar bocah!
Dialogue: 0,0:17:48.55,0:17:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini lebih tua darimu, tahu.
Dialogue: 0,0:17:50.78,0:17:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai senior,\Naku akan memberi kalian nasihat.
Dialogue: 0,0:17:55.18,0:17:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, jangan pernah mencela makanan.
Dialogue: 0,0:17:59.05,0:18:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua...
Dialogue: 0,0:18:00.15,0:18:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa peduli! Mati sana!
Dialogue: 0,0:18:02.65,0:18:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, dengarkan dulu nasihatku.
Dialogue: 0,0:18:07.43,0:18:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyela.
Dialogue: 0,0:18:10.00,0:18:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:18:11.01,0:18:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, home run.
Dialogue: 0,0:18:14.25,0:18:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tak suka membunuh\Ndi luar pekerjaan.
Dialogue: 0,0:18:17.38,0:18:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa itu?
Dialogue: 0,0:18:18.35,0:18:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sebelah sana.\N- Masih ada gerombolannya.
Dialogue: 0,0:18:20.79,0:18:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, amankan dulu dia.
Dialogue: 0,0:18:23.98,0:18:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?\NHei! Lepaskan ikatanku!
Dialogue: 0,0:18:29.45,0:18:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, ya.
Dialogue: 0,0:18:31.95,0:18:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegang yang erat, ya.
Dialogue: 0,0:18:36.46,0:18:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:18:48.31,0:18:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat juga.
Dialogue: 0,0:18:49.75,0:18:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa di sana?!
Dialogue: 0,0:18:50.61,0:18:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini kau!
Dialogue: 0,0:18:53.40,0:18:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:18:54.84,0:18:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:18:59.78,0:19:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal sedikit lagi!
Dialogue: 0,0:19:40.45,0:19:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita berhasil keluar.
Dialogue: 0,0:19:45.78,0:19:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodo amat! Matilah!
Dialogue: 0,0:19:47.78,0:19:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutabrak!
Dialogue: 0,0:19:52.65,0:19:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan peluru, ya?\NBerarti tidak mempan.
Dialogue: 0,0:19:56.05,0:19:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kau pasti bisa mengatasinya.
Dialogue: 0,0:20:00.06,0:20:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:20:04.38,0:20:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung aku bawa ini.
Dialogue: 0,0:20:11.11,0:20:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lanjutkan sesi nasihatku.
Dialogue: 0,0:20:15.41,0:20:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasihat kedua...
Dialogue: 0,0:20:18.41,0:20:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat kolot.
Dialogue: 0,0:20:23.58,0:20:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:20:24.98,0:20:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pria yang memperlakukan wanita\Ndengan buruk itu tidak keren.
Dialogue: 0,0:20:31.91,0:20:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Capek.
Dialogue: 0,0:20:33.61,0:20:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beres sudah, Bang.
Dialogue: 0,0:20:36.05,0:20:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:20:39.38,0:20:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan sebentar, ya.
Dialogue: 0,0:20:41.98,0:20:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:46.58,0:20:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:20:50.85,0:20:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:53.38,0:20:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukuku jatuh.
Dialogue: 0,0:22:33.45,0:22:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:35.75,0:22:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma mimpi?
Dialogue: 0,0:22:41.85,0:22:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan mimpi, 'kan?
Dialogue: 0,0:22:43.81,0:22:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapakah orang itu?
Dialogue: 0,0:22:46.71,0:22:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya, sih...
Dialogue: 0,0:22:48.65,0:22:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:22:51.61,0:22:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami?
Dialogue: 0,0:22:54.61,0:22:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:22:56.63,0:23:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang menyelamatkanku semalam?
Dialogue: 0,0:23:01.83,0:23:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya apa yang terjadi?
Dialogue: 0,0:23:05.46,0:23:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal kedai ramen itu?
Dialogue: 0,0:23:07.56,0:23:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan! Jangan keras-keras bicaranya!
Dialogue: 0,0:23:10.15,0:23:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:23:12.92,0:23:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan diam.
Dialogue: 0,0:23:14.97,0:23:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi boleh aku minta tolong?
Dialogue: 0,0:23:17.45,0:23:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:23:18.55,0:23:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka ramen kedai itu,\Nbiarkan aku jadi pelanggan.
Dialogue: 0,0:23:23.25,0:23:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan-kapan, traktir aku, ya.
Dialogue: 0,0:23:29.98,0:23:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak maunya, ya.
Dialogue: 0,0:23:32.05,0:23:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:23:33.95,0:23:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambah topping telur, ya.
Dialogue: 0,0:23:35.61,0:23:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
