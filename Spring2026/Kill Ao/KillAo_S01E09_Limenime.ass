Dialogue: 0,0:00:01.87,0:00:03.84,sign,,0000,0000,0000,,NATSUKIYA
Dialogue: 0,0:02:05.98,0:02:09.97,sign,,0000,0000,0000,,MUSTAHIL DISELESAIKAN. SUNGGUH MUSTAHIL\NSABTU, 6 JUNI
Dialogue: 0,0:02:32.73,0:02:33.40,sign,,0000,0000,0000,,KESAL, CINTA, CINTA, CINTA, PACAR BOHONGAN
Dialogue: 0,0:04:32.25,0:04:33.50,sign,,0000,0000,0000,,BUKU GAMBAR KRAYON
Dialogue: 0,0:04:36.02,0:04:36.84,sign,,0000,0000,0000,,SETUJU
Dialogue: 0,0:04:40.09,0:04:40.53,sign,,0000,0000,0000,,SETUJU
Dialogue: 0,0:04:40.53,0:04:41.15,sign,,0000,0000,0000,,KAU HEBAT, AKU TAK INGIN MEMBUNUHMU
Dialogue: 0,0:04:47.54,0:04:48.42,sign,,0000,0000,0000,,TAPI MISI INI TIDAK BISA DIHENTIKAN
Dialogue: 0,0:00:03.85,0:00:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:00:04.85,0:00:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramen kuah bening yang biasa juga\Ntak masalah, 'kan?
Dialogue: 0,0:00:07.42,0:00:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah ramen\Ndengan kuah seafood kental?
Dialogue: 0,0:00:11.01,0:00:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak akan melepas dahaga.
Dialogue: 0,0:00:14.53,0:00:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini...
Dialogue: 0,0:00:16.14,0:00:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang utama itu tsukemen, sudah aturannya.
Dialogue: 0,0:00:30.45,0:00:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah tonkotsu?
Dialogue: 0,0:02:13.18,0:02:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon. Noren, jangan bangun dulu.
Dialogue: 0,0:02:17.05,0:02:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menghipnosis Mitsuoka Noren.
Dialogue: 0,0:02:21.21,0:02:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dia sadar nanti, dia akan jatuh cinta\Npada hal pertama yang dilihatnya.
Dialogue: 0,0:02:26.58,0:02:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh.
Dialogue: 0,0:02:28.25,0:02:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pandang Rindo Eiji.
Dialogue: 0,0:02:29.91,0:02:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pandang Tenma saja.
Dialogue: 0,0:02:31.92,0:02:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau itu terjadi,
Dialogue: 0,0:02:33.41,0:02:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kisah cinta ini makin rumit.
Dialogue: 0,0:02:35.91,0:02:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti malah jadi canggung.
Dialogue: 0,0:02:47.75,0:02:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa laras meriamnya diisi daging?
Dialogue: 0,0:02:50.75,0:02:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi perdamaian.
Dialogue: 0,0:02:52.21,0:02:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tidak bisa dipakai lagi.
Dialogue: 0,0:02:54.21,0:02:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:02:55.00,0:02:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku bisa menembak seperti biasa,\Napa benar begitu?
Dialogue: 0,0:03:04.12,0:03:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agh.
Dialogue: 0,0:03:09.78,0:03:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak salah.
Dialogue: 0,0:03:15.38,0:03:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berhenti!
Dialogue: 0,0:03:19.38,0:03:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenggorokan rasanya makin kering.
Dialogue: 0,0:03:42.41,0:03:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:03:44.21,0:03:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat dulu.
Dialogue: 0,0:03:47.11,0:03:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lempar saja, ya.
Dialogue: 0,0:03:53.35,0:03:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kubeli dalam perjalanan ke sini.
Dialogue: 0,0:03:56.78,0:03:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia ini hebat juga.
Dialogue: 0,0:03:59.71,0:04:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah main golf,\Ntapi aku paham dia jago.
Dialogue: 0,0:04:04.15,0:04:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akurasi dan kekuatannya jelas\Nbukan hasil yang didapat instan.
Dialogue: 0,0:04:09.01,0:04:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mending jadi atlet golf saja.
Dialogue: 0,0:04:11.91,0:04:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu detailnya,
Dialogue: 0,0:04:14.35,0:04:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi orang seperti dia bisa membunuh, ya?
Dialogue: 0,0:04:20.99,0:04:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia sehebat itu.
Dialogue: 0,0:04:23.05,0:04:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malas.
Dialogue: 0,0:04:24.25,0:04:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau itu terjadi.
Dialogue: 0,0:04:36.85,0:04:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Setuju?"\NTernyata kau bisa mengobrol.
Dialogue: 0,0:04:41.18,0:04:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kau hebat, aku tak ingin membunuhmu."
Dialogue: 0,0:04:44.38,0:04:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:45.22,0:04:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kita akhiri saja.
Dialogue: 0,0:04:48.45,0:04:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tapi misi ini tidak bisa dihentikan."
Dialogue: 0,0:04:53.01,0:04:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Selain itu, aku tidak bisa memproses\Nhal-hal yang rumit."
Dialogue: 0,0:04:57.78,0:05:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kakak sedang mencari obat untuk itu."
Dialogue: 0,0:05:01.01,0:05:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku pun ingin sembuh."
Dialogue: 0,0:05:03.11,0:05:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku ingin kakakku bebas."
Dialogue: 0,0:05:07.01,0:05:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dia memang sedikit menyeramkan,
Dialogue: 0,0:05:08.95,0:05:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia sangat berharga bagiku."
Dialogue: 0,0:05:17.25,0:05:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:05:19.01,0:05:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menyerah.
Dialogue: 0,0:05:21.05,0:05:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak pandai bernegosiasi.
Dialogue: 0,0:05:24.58,0:05:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tidak baik tahu situasi pribadi lawan\Nsebelum bertarung.
Dialogue: 0,0:05:29.38,0:05:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:05:31.55,0:05:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan kalah.
Dialogue: 0,0:05:34.52,0:05:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita lanjut.
Dialogue: 0,0:05:38.81,0:05:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma, kau tidak apa-apa?
Dialogue: 0,0:05:41.31,0:05:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, kau sendiri?
Dialogue: 0,0:05:43.18,0:05:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudah beres.
Dialogue: 0,0:05:46.18,0:05:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Noren?
Dialogue: 0,0:05:50.05,0:05:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, dia belum bangun.
Dialogue: 0,0:05:53.11,0:05:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah beres?
Dialogue: 0,0:05:55.05,0:05:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:56.21,0:05:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakaknya sudah kuurus.
Dialogue: 0,0:05:59.98,0:06:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, jangan ngomong begitu, dong.
Dialogue: 0,0:06:02.65,0:06:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak mati, tahu.
Dialogue: 0,0:06:04.78,0:06:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kebiasaan.
Dialogue: 0,0:06:33.01,0:06:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, jangan bilang\Nyang satunya kau bunuh?
Dialogue: 0,0:06:36.62,0:06:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:06:37.65,0:06:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kuhajar sampai pingsan.
Dialogue: 0,0:06:40.29,0:06:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti mengira kakaknya sudah dibunuh.
Dialogue: 0,0:06:47.05,0:06:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakannya membabi buta.
Dialogue: 0,0:06:49.61,0:06:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi susah mengelak dan tak ada celah\Nuntuk menghindari serangannya.
Dialogue: 0,0:06:54.11,0:06:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Bagaimana cara menghentikannya?
Dialogue: 0,0:06:55.95,0:06:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak kaki dan tangannya?
Dialogue: 0,0:06:57.65,0:06:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, langsung kepala saja.
Dialogue: 0,0:07:00.23,0:07:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Tenma tidak boleh melihatnya.
Dialogue: 0,0:07:03.21,0:07:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, serahkan saja padaku.
Dialogue: 0,0:07:05.28,0:07:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:06.51,0:07:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma butuh beberapa detik.
Dialogue: 0,0:07:09.78,0:07:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pancing dia, akan kutunjukkan\Ntendangan legendaris.
Dialogue: 0,0:07:16.54,0:07:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sebelah sini!
Dialogue: 0,0:07:18.11,0:07:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini!
Dialogue: 0,0:07:26.94,0:07:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang!
Dialogue: 0,0:07:30.31,0:07:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:07:35.91,0:07:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tendangan legendaris?\NDia serius?
Dialogue: 0,0:07:39.01,0:07:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Tenma bukan tipe orang\Nyang asal bicara.
Dialogue: 0,0:07:44.21,0:07:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya padanya.
Dialogue: 0,0:07:46.41,0:07:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam sepak bola ada tendangan pisang,\Ntendangan tanpa putaran, dan lainnya, 'kan?
Dialogue: 0,0:07:53.15,0:07:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada satu jenis putaran yang hampir\Nmustahil dilakukan dalam sepak bola.
Dialogue: 0,0:07:57.51,0:07:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu apa?
Dialogue: 0,0:07:59.15,0:08:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah. Tidak pernah kepikiran.
Dialogue: 0,0:08:03.35,0:08:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putaran spiral. Tendangan gyro.
Dialogue: 0,0:08:06.81,0:08:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti peluru, bola berputar spiral\Nsehingga kekuatannya meningkat drastis.
Dialogue: 0,0:08:15.78,0:08:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu teorinya.
Dialogue: 0,0:08:18.51,0:08:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling cuma ide yang kepikiran\Nwaktu main-main.
Dialogue: 0,0:08:21.31,0:08:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, jangan sok pintar.
Dialogue: 0,0:08:36.37,0:08:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:08:47.03,0:08:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai membekas di beton.
Dialogue: 0,0:08:49.27,0:08:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:08:51.05,0:08:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kuat, tapi banyak kelemahannya.\NSulit dipakai di pertandingan.
Dialogue: 0,0:08:56.61,0:08:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak berguna, dong.
Dialogue: 0,0:09:01.91,0:09:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:09:03.65,0:09:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akhiri di sini.
Dialogue: 0,0:09:08.98,0:09:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Super Gyro Spin!
Dialogue: 0,0:09:55.81,0:09:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:09:57.15,0:09:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hebat banget.
Dialogue: 0,0:09:59.35,0:10:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil menumbangkan\Npembunuh dari Hardin.
Dialogue: 0,0:10:06.51,0:10:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya selesai juga.
Dialogue: 0,0:10:08.29,0:10:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekacauan ini...
Dialogue: 0,0:10:10.38,0:10:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya bagaimana, ya?
Dialogue: 0,0:10:12.44,0:10:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami.
Dialogue: 0,0:10:13.75,0:10:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya banyak pertanyaan.
Dialogue: 0,0:10:16.55,0:10:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah tahu\Nsiapa mereka sebenarnya, 'kan?
Dialogue: 0,0:10:19.78,0:10:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, itu...
Dialogue: 0,0:10:21.38,0:10:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, mustahil untuk mengelak.
Dialogue: 0,0:10:26.61,0:10:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:10:28.75,0:10:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:30.85,0:10:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami?
Dialogue: 0,0:10:52.07,0:10:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:10:53.95,0:10:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?\NKenapa aku tidur di lapangan?
Dialogue: 0,0:10:58.41,0:11:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, kita pergi ke bioskop.\NLalu dua orang misterius...
Dialogue: 0,0:11:09.01,0:11:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kau menyelamatkanku lagi?
Dialogue: 0,0:11:12.77,0:11:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Bukan aku.
Dialogue: 0,0:11:15.14,0:11:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali. Terima kasih!
Dialogue: 0,0:11:17.71,0:11:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bantu, lo.
Dialogue: 0,0:11:20.28,0:11:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi?
Dialogue: 0,0:11:21.91,0:11:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, dia ini...
Dialogue: 0,0:11:23.65,0:11:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sadar kita pernah menolongnya.
Dialogue: 0,0:11:26.95,0:11:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga sulit untuk mengelak.
Dialogue: 0,0:11:29.66,0:11:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlalu senang.
Dialogue: 0,0:11:32.79,0:11:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:11:34.21,0:11:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kau gemetar terus, lo.
Dialogue: 0,0:11:37.45,0:11:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, dong.
Dialogue: 0,0:11:39.78,0:11:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren itu seusia putriku, tahu.
Dialogue: 0,0:11:42.91,0:11:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku tidak bergidik.
Dialogue: 0,0:11:45.38,0:11:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, waktu umurnya lima tahun dulu...
Dialogue: 0,0:11:47.98,0:11:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cinta Papa.
Dialogue: 0,0:11:49.86,0:11:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita menikah.
Dialogue: 0,0:11:51.55,0:11:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senangnya! Papa juga cinta kau.
Dialogue: 0,0:11:54.61,0:11:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lucu sekali, jadi gemas sendiri.
Dialogue: 0,0:11:57.18,0:12:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tanda ayahnya sangat menyayanginya.\NBagus, 'kan?
Dialogue: 0,0:12:00.19,0:12:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bayangkan kalau dia sudah besar.
Dialogue: 0,0:12:03.71,0:12:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayangkan putrimu\Nmengucapkan hal yang sama.
Dialogue: 0,0:12:07.31,0:12:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menikah dengan Papa.
Dialogue: 0,0:12:10.18,0:12:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong!
Dialogue: 0,0:12:11.01,0:12:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius.
Dialogue: 0,0:12:12.32,0:12:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:13.46,0:12:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah normal mana pun\Npasti bakal pusing dibuatnya.
Dialogue: 0,0:12:17.01,0:12:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada neraka khusus\Nyang menantimu saat mati.
Dialogue: 0,0:12:19.93,0:12:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku tak tahu detailnya.
Dialogue: 0,0:12:21.45,0:12:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kita ini pembunuh bayaran, lo.
Dialogue: 0,0:12:25.15,0:12:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti masuk neraka.
Dialogue: 0,0:12:26.98,0:12:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, jangan dibahas lagi.
Dialogue: 0,0:12:31.11,0:12:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami.
Dialogue: 0,0:12:33.61,0:12:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini karena kaget.
Dialogue: 0,0:12:36.55,0:12:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti,\Ntapi sejak tadi hatiku berdegup kencang.
Dialogue: 0,0:12:40.81,0:12:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini bukan saat yang tepat,
Dialogue: 0,0:12:42.95,0:12:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jangan-jangan aku mulai menyukaimu.
Dialogue: 0,0:12:47.45,0:12:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cin...
Dialogue: 0,0:12:53.11,0:12:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:54.31,0:12:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kau, Ogami?
Dialogue: 0,0:12:56.58,0:12:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal suasananya sudah bagus.
Dialogue: 0,0:12:59.81,0:13:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau malah membuatnya pingsan?
Dialogue: 0,0:13:01.58,0:13:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, karena...
Dialogue: 0,0:13:03.11,0:13:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pukulanmu kencang begitu.
Dialogue: 0,0:13:04.55,0:13:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lehernya tidak patah, 'kan?
Dialogue: 0,0:13:06.72,0:13:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya boleh memukul gadis\Nyang baru saja bangun begitu?
Dialogue: 0,0:13:12.01,0:13:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang karena yakin adikku akan menang.
Dialogue: 0,0:13:15.31,0:13:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak kusangka malah jadi begini.
Dialogue: 0,0:13:18.45,0:13:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rindo Kazuma, kok kau ke sini?
Dialogue: 0,0:13:20.73,0:13:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, Ogami.
Dialogue: 0,0:13:22.78,0:13:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia aneh.
Dialogue: 0,0:13:25.05,0:13:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau memakai pakaian Kak Chisato?
Dialogue: 0,0:13:27.89,0:13:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mencurinya.\NIni cuma kebetulan sama.
Dialogue: 0,0:13:31.83,0:13:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang. Jangan gegabah.
Dialogue: 0,0:13:33.25,0:13:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kita bahas itu.
Dialogue: 0,0:13:34.98,0:13:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, Tenma.
Dialogue: 0,0:13:39.38,0:13:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu, ya.
Dialogue: 0,0:13:41.38,0:13:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah begini,\Ncuma ada satu hal yang bisa kulakukan.
Dialogue: 0,0:13:44.75,0:13:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon ampun.
Dialogue: 0,0:13:49.91,0:13:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon. Aku akan melakukan apa pun.
Dialogue: 0,0:13:53.58,0:13:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bunuh Eiji.
Dialogue: 0,0:13:56.38,0:13:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon.
Dialogue: 0,0:13:59.38,0:14:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia kami, kegagalan atau kekalahan\Nsama saja dengan kematian.
Dialogue: 0,0:14:03.65,0:14:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mempersiapkan diriku untuk itu.
Dialogue: 0,0:14:07.15,0:14:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:14:08.61,0:14:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyelamatkan nyawa adikku.
Dialogue: 0,0:14:12.61,0:14:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon.
Dialogue: 0,0:14:14.04,0:14:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak pernah berniat membunuh, kok.
Dialogue: 0,0:14:18.61,0:14:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Ogami? Kau niat membunuh?
Dialogue: 0,0:14:20.62,0:14:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:14:22.05,0:14:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai repot begini\Ndemi tidak membunuh, lo.
Dialogue: 0,0:14:31.95,0:14:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, yah...
Dialogue: 0,0:14:33.81,0:14:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih butuh kalian,\Njadi jangan pulang dulu, ya.
Dialogue: 0,0:14:37.15,0:14:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setelah itu, kalian berdua pulanglah.
Dialogue: 0,0:14:42.99,0:14:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Maaf.
Dialogue: 0,0:14:47.51,0:14:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kulupakan kebaikan ini.
Dialogue: 0,0:14:52.01,0:14:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kubilang tadi...
Dialogue: 0,0:14:55.25,0:14:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keadaan sekarang ini kacau.
Dialogue: 0,0:14:57.85,0:15:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga jadi ingin menangis.
Dialogue: 0,0:15:00.05,0:15:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita harus apa?
Dialogue: 0,0:15:02.33,0:15:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:15:04.18,0:15:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum membahas langkah kita,\Nada yang ingin kutanyakan.
Dialogue: 0,0:15:07.45,0:15:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kalian ini siapa?
Dialogue: 0,0:15:09.63,0:15:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memikirkannya sejak tadi.\NKalian tidak normal.
Dialogue: 0,0:15:13.78,0:15:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya kukira mereka cuma penjahat\Nyang menculik Noren.
Dialogue: 0,0:15:17.58,0:15:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini jelas bukan level preman\Natau yakuza biasa.
Dialogue: 0,0:15:21.19,0:15:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami juga sepertinya sudah tahu soal itu.
Dialogue: 0,0:15:25.25,0:15:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:15:26.65,0:15:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia hidup di dunia yang sama\Ndengan mereka?
Dialogue: 0,0:15:30.55,0:15:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kita bisa minta tolong Kazuma.
Dialogue: 0,0:15:33.11,0:15:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:15:33.95,0:15:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, gunakan hipnosismu.
Dialogue: 0,0:15:36.65,0:15:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa menghapus semua ingatannya?
Dialogue: 0,0:15:38.91,0:15:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:39.82,0:15:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:15:41.58,0:15:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, bantu aku.
Dialogue: 0,0:15:50.75,0:15:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan baik-baik.
Dialogue: 0,0:15:52.31,0:15:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu mendengar suara korek api ditutup,
Dialogue: 0,0:15:55.55,0:15:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan langsung tertidur.
Dialogue: 0,0:15:57.65,0:16:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bangun, kau akan lupa\Nsemua yang terjadi hari ini.
Dialogue: 0,0:16:01.00,0:16:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga.
Dialogue: 0,0:16:02.55,0:16:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua.
Dialogue: 0,0:16:03.95,0:16:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu.
Dialogue: 0,0:16:14.95,0:16:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini sedang apa, sih? Hentikan.
Dialogue: 0,0:16:18.08,0:16:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Tidak mempan?
Dialogue: 0,0:16:20.70,0:16:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi.
Dialogue: 0,0:16:23.15,0:16:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:16:23.70,0:16:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi.
Dialogue: 0,0:16:25.98,0:16:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang...
Dialogue: 0,0:16:30.11,0:16:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini...
Dialogue: 0,0:16:31.38,0:16:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:16:32.45,0:16:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bisa dihipnosis.
Dialogue: 0,0:16:35.05,0:16:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:35.91,0:16:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:16:37.38,0:16:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau bilang hipnosismu cepat,\Nampuh, dan praktis?
Dialogue: 0,0:16:40.95,0:16:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya restoran cepat saji, apa?
Dialogue: 0,0:16:43.41,0:16:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya hipnosisku\Nlangsung mempan pada siapa pun.
Dialogue: 0,0:16:46.65,0:16:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya.
Dialogue: 0,0:16:48.71,0:16:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia ini?
Dialogue: 0,0:16:50.86,0:16:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu di luar nalar.
Dialogue: 0,0:16:53.15,0:16:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang.
Dialogue: 0,0:16:54.05,0:16:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lagi?
Dialogue: 0,0:16:55.75,0:16:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertawa saja, lah.
Dialogue: 0,0:16:57.58,0:16:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat Tenma sekali.
Dialogue: 0,0:17:01.38,0:17:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini saatnya menerima nasib.
Dialogue: 0,0:17:07.24,0:17:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh bayaran?
Dialogue: 0,0:17:09.20,0:17:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh bayaran itu betulan ada?
Dialogue: 0,0:17:12.91,0:17:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, apa tidak apa-apa\Nkita membocorkannya?
Dialogue: 0,0:17:16.15,0:17:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja masalah.
Dialogue: 0,0:17:17.75,0:17:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak bisa kembali bersekolah.
Dialogue: 0,0:17:19.95,0:17:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misinya selesai,\Njadi mulai besok aku menganggur.
Dialogue: 0,0:17:24.21,0:17:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini semuanya berakhir.
Dialogue: 0,0:17:26.51,0:17:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah mencoba menghipnosismu.
Dialogue: 0,0:17:29.86,0:17:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih juga karena sudah\Nmembantu menyelamatkan Noren.
Dialogue: 0,0:17:35.01,0:17:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, kau mau menghilang?
Dialogue: 0,0:17:37.81,0:17:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:17:40.81,0:17:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:43.00,0:17:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:44.21,0:17:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh bayaran tidak boleh ke sekolah, ya?
Dialogue: 0,0:17:47.71,0:17:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:48.61,0:17:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuh memang tidak baik.
Dialogue: 0,0:17:51.58,0:17:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, hentikan mulai sekarang.
Dialogue: 0,0:17:53.55,0:17:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah lebih baik kalau kalian belajar\Ndan mencari jalan hidup yang benar, 'kan?
Dialogue: 0,0:17:59.03,0:18:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini kalian melakukannya\Nkarena terpaksa, 'kan?
Dialogue: 0,0:18:02.21,0:18:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya begitu yang kulihat.
Dialogue: 0,0:18:05.75,0:18:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang semua yang sudah terjadi\Ntidak bisa dianggap tidak pernah ada,
Dialogue: 0,0:18:10.77,0:18:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak menganggap\Nkalian orang jahat.
Dialogue: 0,0:18:16.18,0:18:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\Nkau suka sekolah dan belajar, 'kan?
Dialogue: 0,0:18:19.78,0:18:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, jangan menyerah.
Dialogue: 0,0:18:22.21,0:18:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berubahlah, kejar cita-citamu,\Nlanjutkan sekolah.
Dialogue: 0,0:18:26.38,0:18:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membocorkan rahasia kalian.
Dialogue: 0,0:18:29.78,0:18:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:18:31.61,0:18:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gurunya, kakaknya, sekarang dia juga?
Dialogue: 0,0:18:35.31,0:18:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak tahu lagi siapa\Nyang dewasa dan siapa yang anak-anak.
Dialogue: 0,0:18:40.15,0:18:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:41.35,0:18:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti itu tidaklah penting.
Dialogue: 0,0:18:46.91,0:18:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak mulai bersekolah,\Naku terus saja mendapat pelajaran baru.
Dialogue: 0,0:18:53.07,0:18:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua juga,
Dialogue: 0,0:18:55.38,0:18:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membunuh itu tidak boleh. Titik.
Dialogue: 0,0:18:57.75,0:18:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar juga.
Dialogue: 0,0:19:01.25,0:19:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti katamu,\Nadikku juga berkata demikian.
Dialogue: 0,0:19:07.18,0:19:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sirene.
Dialogue: 0,0:19:08.08,0:19:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kazuma.
Dialogue: 0,0:19:09.55,0:19:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kali ini bukan ulahku.
Dialogue: 0,0:19:12.98,0:19:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sungguhan.
Dialogue: 0,0:19:15.21,0:19:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, lari lewat pintu belakang.
Dialogue: 0,0:19:17.01,0:19:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:17.98,0:19:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya hipnosis.
Dialogue: 0,0:19:20.65,0:19:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menipu mereka dengan mudah.
Dialogue: 0,0:19:24.14,0:19:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal memang itu rencanaku.
Dialogue: 0,0:19:27.41,0:19:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau gagal bagaimana?
Dialogue: 0,0:19:30.21,0:19:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma itu pengecualian.
Dialogue: 0,0:19:35.36,0:19:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi urusanku belum selesai.
Dialogue: 0,0:19:37.71,0:19:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan hipnosis\Nyang kau pasang pada Noren.
Dialogue: 0,0:19:40.41,0:19:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, waktunya tidak cukup.
Dialogue: 0,0:19:42.51,0:19:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali saja.
Dialogue: 0,0:19:45.55,0:19:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengurus\Nadministrasi pindah sekolah.
Dialogue: 0,0:19:48.11,0:19:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti akan bertemu lagi.
Dialogue: 0,0:19:50.71,0:19:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin gadis itu adalah petunjuk\Nuntuk menyembuhkan adikku.
Dialogue: 0,0:19:55.38,0:19:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudahi dulu. Dalam waktu dekat\Naku akan segera bersekolah di sana.
Dialogue: 0,0:19:59.51,0:20:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekolah kalian.
Dialogue: 0,0:20:01.58,0:20:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar? Aku tunggu.
Dialogue: 0,0:20:03.65,0:20:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lama-lama, cepat pindah sekolah.
Dialogue: 0,0:20:15.41,0:20:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:20:17.21,0:20:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau terluka?
Dialogue: 0,0:20:19.15,0:20:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tidak apa-apa?
Dialogue: 0,0:20:21.55,0:20:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terluka...?
Dialogue: 0,0:22:37.01,0:22:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir pekan yang panjang, ya.
Dialogue: 0,0:22:40.85,0:22:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampun, deh.
Dialogue: 0,0:22:42.45,0:22:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita bisa kembali bersekolah.
Dialogue: 0,0:22:46.01,0:22:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, untuk kali ini.
Dialogue: 0,0:22:48.45,0:22:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\NTenma tahu pekerjaanku yang sebenarnya.
Dialogue: 0,0:22:53.11,0:22:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin akan terus berdatangan\Npembunuh bayaran lain yang mengincar Noren.
Dialogue: 0,0:22:57.98,0:23:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus memikirkan ulang banyak hal.
Dialogue: 0,0:23:02.81,0:23:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,\Nyang kemarin belum bisa dibilang selesai.
Dialogue: 0,0:23:06.15,0:23:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya kakak-beradik Rindo\Nakan menyusup ke SMP ini.
Dialogue: 0,0:23:12.25,0:23:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami.
Dialogue: 0,0:23:14.45,0:23:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sekarang Noren masih terhipnosis.
Dialogue: 0,0:23:18.21,0:23:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parahnya, efeknya benar-benar manjur.
Dialogue: 0,0:23:21.35,0:23:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat agresif.
Dialogue: 0,0:23:24.22,0:23:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini,\Naku tak bisa lengah sedetik pun di sekolah.
Dialogue: 0,0:23:28.65,0:23:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak absen saja?
Dialogue: 0,0:23:29.74,0:23:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau, aku mau belajar.
Dialogue: 0,0:23:33.37,0:23:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lakukan apa pun agar romansa\Nantara aku dan Noren tidak berlanjut.
