Dialogue: 0,0:02:19.01,0:02:22.99,tanda,,0000,0000,0000,,KELOMPOK MAKHLUK LEGENDARIS (UNICORN)\NSABTU, 9 MEI
Dialogue: 0,0:05:17.58,0:05:18.44,tanda,,0000,0000,0000,,RAMEN
Dialogue: 0,0:05:34.12,0:05:34.35,tanda,,0000,0000,0000,,RAMEN NATSUKIYA
Dialogue: 0,0:06:14.31,0:06:14.68,tanda,,0000,0000,0000,,BAR JUPAN
Dialogue: 0,0:09:03.68,0:09:04.18,tanda,,0000,0000,0000,,BAR JUPAN
Dialogue: 0,0:09:26.46,0:09:27.82,tanda,,0000,0000,0000,,UTS HARI KE-1 — IPS, MTK, IPA
Dialogue: 0,0:09:35.78,0:09:36.13,tanda,,0000,0000,0000,,UTS MTK — OGAMI JUZO
Dialogue: 0,0:10:19.01,0:10:19.93,tanda,,0000,0000,0000,,KLUB TATA BOGA
Dialogue: 0,0:16:13.05,0:16:14.87,tanda,,0000,0000,0000,,"PITCHER JUARA"
Dialogue: 0,0:16:15.25,0:16:16.78,tanda,,0000,0000,0000,,"STRIKER TERBAIK SMP"
Dialogue: 0,0:16:16.91,0:16:18.47,tanda,,0000,0000,0000,,"BINTANG BASKET"
Dialogue: 0,0:18:38.73,0:18:40.91,tanda,,0000,0000,0000,,"KLUB TATA BOGA"
Dialogue: 0,0:00:25.75,0:00:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:00:27.11,0:00:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau banyak membantuku.
Dialogue: 0,0:00:29.41,0:00:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, oke.
Dialogue: 0,0:00:31.21,0:00:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.\NDia sungguh masih SMP?
Dialogue: 0,0:00:33.91,0:00:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahasiswa pun tak sanggup\Nmenangkap lemparannya.
Dialogue: 0,0:00:36.51,0:00:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelnya sudah melampaui atlet SMA.
Dialogue: 0,0:00:38.98,0:00:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku ragu,
Dialogue: 0,0:00:41.01,0:00:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi setelah menyaksikannya...
Dialogue: 0,0:00:43.55,0:00:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seperti bukan manusia.
Dialogue: 0,0:00:45.98,0:00:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dia masuk Unicorn.
Dialogue: 0,0:02:23.38,0:02:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}UTS akan dimulai minggu depan.
Dialogue: 0,0:02:27.78,0:02:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini,\Nsemua ekskul libur selama seminggu.
Dialogue: 0,0:02:31.15,0:02:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajari kembali semua materi\Nyang sudah dibahas.
Dialogue: 0,0:02:35.31,0:02:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya datang juga.
Dialogue: 0,0:02:37.21,0:02:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}UTS pertama di SMP, aku deg-degan.
Dialogue: 0,0:02:41.58,0:02:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu, Ogami?
Dialogue: 0,0:02:43.11,0:02:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menakutkan.
Dialogue: 0,0:02:45.35,0:02:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau marah?
Dialogue: 0,0:02:46.95,0:02:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Bukan begitu.
Dialogue: 0,0:02:49.45,0:02:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku justru sangat semangat menghadapi tes.
Dialogue: 0,0:02:52.25,0:02:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura membunuhnya sangat kental.
Dialogue: 0,0:02:54.55,0:02:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mukanya seperti mau membunuh orang.
Dialogue: 0,0:02:56.61,0:03:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, identitas aslimu bisa ketahuan.
Dialogue: 0,0:03:01.18,0:03:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya ini UTS pertama.
Dialogue: 0,0:03:04.35,0:03:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana, Master?
Dialogue: 0,0:03:06.03,0:03:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kali buat kita semua.
Dialogue: 0,0:03:08.45,0:03:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti bisa, Noren.
Dialogue: 0,0:03:10.75,0:03:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba saja.
Dialogue: 0,0:03:12.31,0:03:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami 'kan rajin belajar.
Dialogue: 0,0:03:15.81,0:03:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti tak apa, seperti biasa saja.
Dialogue: 0,0:03:18.75,0:03:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih kata bijaknya.
Dialogue: 0,0:03:20.61,0:03:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master!
Dialogue: 0,0:03:21.61,0:03:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat sekali.
Dialogue: 0,0:03:25.61,0:03:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:03:26.75,0:03:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Noren.
Dialogue: 0,0:03:27.91,0:03:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:03:30.15,0:03:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silau.
Dialogue: 0,0:03:31.31,0:03:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cerah banget hari ini. Ada apa?
Dialogue: 0,0:03:33.75,0:03:34.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal ini...
Dialogue: 0,0:03:34.98,0:03:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena UTS, semua orang sibuk belajar.
Dialogue: 0,0:03:38.25,0:03:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua sibuk.
Dialogue: 0,0:03:41.25,0:03:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya tidak ada yang nembak aku.
Dialogue: 0,0:03:44.25,0:03:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:03:45.71,0:03:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa tidur nyenyak.
Dialogue: 0,0:03:48.15,0:03:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba setiap hari ada UTS.
Dialogue: 0,0:03:50.95,0:03:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti berat juga, ya, Noren.
Dialogue: 0,0:03:52.68,0:03:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir.
Dialogue: 0,0:03:55.65,0:03:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:03:56.71,0:03:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:03:57.91,0:03:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:03:58.95,0:04:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mukamu kusam banget, kering begitu.
Dialogue: 0,0:04:01.35,0:04:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, pagi.
Dialogue: 0,0:04:02.75,0:04:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mukamu?
Dialogue: 0,0:04:03.95,0:04:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tidur?
Dialogue: 0,0:04:05.05,0:04:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganmu, Ogami?
Dialogue: 0,0:04:07.30,0:04:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kebalikannya Noren.
Dialogue: 0,0:04:09.15,0:04:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasangan yang aneh juga.
Dialogue: 0,0:04:12.25,0:04:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata panda.
Dialogue: 0,0:04:14.31,0:04:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus tidur, Ogami.
Dialogue: 0,0:04:17.20,0:04:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku tahu.
Dialogue: 0,0:04:23.35,0:04:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sudah pagi?
Dialogue: 0,0:04:25.11,0:04:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keasyikan belajar.
Dialogue: 0,0:04:27.65,0:04:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ini...
Dialogue: 0,0:04:31.75,0:04:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti petinju jelang pertandingan.
Dialogue: 0,0:04:34.85,0:04:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bisa istirahat,\Nmereka tetap berlatih.
Dialogue: 0,0:04:38.75,0:04:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya kau terlalu larut\Nsampai kebablasan, ya?
Dialogue: 0,0:04:50.65,0:04:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau?
Dialogue: 0,0:04:51.85,0:04:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa menenangkanmu.
Dialogue: 0,0:04:52.87,0:04:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:04:54.96,0:04:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang...
Dialogue: 0,0:04:57.11,0:04:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berlebihan, Bang.
Dialogue: 0,0:04:59.21,0:05:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik, pergi sana.
Dialogue: 0,0:05:01.51,0:05:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga maunya begitu.
Dialogue: 0,0:05:03.61,0:05:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini ada orang\Nyang harus dipaksa berhenti belajar.
Dialogue: 0,0:05:07.61,0:05:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku ada urusan.\NMakan malam di Mama saja, ya.
Dialogue: 0,0:05:11.71,0:05:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Makan di mana juga sama aja.
Dialogue: 0,0:05:14.35,0:05:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, pergi saja, sekalian ganti suasana.
Dialogue: 0,0:05:18.51,0:05:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini pulanglah lebih cepat.
Dialogue: 0,0:05:20.78,0:05:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:21.72,0:05:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang UTS, 'kan?
Dialogue: 0,0:05:23.95,0:05:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa.
Dialogue: 0,0:05:25.11,0:05:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku giat belajar, kok.
Dialogue: 0,0:05:28.55,0:05:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, pulang sana.
Dialogue: 0,0:05:29.61,0:05:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah malam. Lagi pula,\Ntidak banyak yang datang jam segini.
Dialogue: 0,0:05:32.98,0:05:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:05:34.38,0:05:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku duluan.
Dialogue: 0,0:05:37.45,0:05:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:40.45,0:05:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami?
Dialogue: 0,0:05:47.71,0:05:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana dia?
Dialogue: 0,0:05:52.25,0:05:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:05:53.11,0:05:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masuk ke kawasan hiburan malam.
Dialogue: 0,0:05:56.58,0:05:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Juzo!
Dialogue: 0,0:05:59.51,0:06:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam.
Dialogue: 0,0:06:01.05,0:06:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Gekota, ya?
Dialogue: 0,0:06:03.71,0:06:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa.
Dialogue: 0,0:06:05.85,0:06:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah buka?
Dialogue: 0,0:06:07.62,0:06:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudah buka.
Dialogue: 0,0:06:11.61,0:06:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini mau makan.
Dialogue: 0,0:06:14.71,0:06:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyosuke... eh, maaf.
Dialogue: 0,0:06:16.45,0:06:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama ada?
Dialogue: 0,0:06:17.81,0:06:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk.
Dialogue: 0,0:06:19.45,0:06:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nagisa Mama, pacar berondongmu mampir!
Dialogue: 0,0:06:25.78,0:06:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:06:30.25,0:06:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut banget kau.
Dialogue: 0,0:06:33.31,0:06:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gemas!
Dialogue: 0,0:06:34.61,0:06:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilaf buatan Mama enak sekali.
Dialogue: 0,0:06:38.21,0:06:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Geko, tolong ambilkan teh.
Dialogue: 0,0:06:40.88,0:06:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, tunggu sebentar.
Dialogue: 0,0:06:44.58,0:06:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang salah sangka,\Nmengira aku punya anak haram.
Dialogue: 0,0:06:48.65,0:06:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang kau keponakanku.
Dialogue: 0,0:06:51.55,0:06:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak menyangka kau bisa jadi remaja lagi.
Dialogue: 0,0:06:56.95,0:06:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Neko! Selamat datang.
Dialogue: 0,0:06:59.85,0:07:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kau bawa anak imut.
Dialogue: 0,0:07:06.15,0:07:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kakakku.
Dialogue: 0,0:07:09.01,0:07:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama memang bisa diandalkan.
Dialogue: 0,0:07:10.95,0:07:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat bergantung padamu\Nsaat genting. Terima kasih.
Dialogue: 0,0:07:14.35,0:07:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku, Dik Juzo.
Dialogue: 0,0:07:16.86,0:07:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungimu.
Dialogue: 0,0:07:20.11,0:07:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, capek banget.
Dialogue: 0,0:07:22.15,0:07:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan aku, Mama,\Nanak barunya bikin masalah.
Dialogue: 0,0:07:26.31,0:07:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eri? Kenapa kau ke sini?
Dialogue: 0,0:07:28.55,0:07:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eri, selamat datang.\NSeperti biasa ya?
Dialogue: 0,0:07:31.58,0:07:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tolong.
Dialogue: 0,0:07:33.51,0:07:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda zaman sekarang ini...
Dialogue: 0,0:07:35.85,0:07:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka sekali ikut campur.
Dialogue: 0,0:07:42.25,0:07:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu alasanmu bermata panda?
Dialogue: 0,0:07:45.58,0:07:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik.
Dialogue: 0,0:07:46.91,0:07:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya tidak apa kau minum-minum?
Dialogue: 0,0:07:49.11,0:07:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kozue bagaimana?
Dialogue: 0,0:07:50.35,0:07:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:07:54.15,0:07:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku segera pulang setelah minum.
Dialogue: 0,0:07:56.51,0:07:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini saja.
Dialogue: 0,0:07:58.01,0:07:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kita sudah mandiri, kok.
Dialogue: 0,0:08:03.11,0:08:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya? Benar juga.
Dialogue: 0,0:08:09.01,0:08:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belajar semalaman?
Dialogue: 0,0:08:10.71,0:08:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tidak apa.
Dialogue: 0,0:08:11.95,0:08:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lanjut saja, kalau gagal ya sudah.
Dialogue: 0,0:08:14.91,0:08:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, bisakah sedikit lebih lembut?
Dialogue: 0,0:08:17.81,0:08:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keterlaluan.
Dialogue: 0,0:08:19.13,0:08:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau salah paham.
Dialogue: 0,0:08:21.81,0:08:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:24.75,0:08:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang dulu,
Dialogue: 0,0:08:26.81,0:08:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kerja yang penting itu\Nmenyelesaikan misi.
Dialogue: 0,0:08:29.91,0:08:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh ada kegagalan, 'kan?
Dialogue: 0,0:08:33.98,0:08:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sambil minum, kau selalu tegang.
Dialogue: 0,0:08:38.80,0:08:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi belajar tidak perlu\Nsampai segitu, 'kan?
Dialogue: 0,0:08:42.80,0:08:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid SMP gagal pun tidak apa-apa.
Dialogue: 0,0:08:45.95,0:08:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung ada kesempatan,\Njangan cuma fokus belajar.
Dialogue: 0,0:08:48.81,0:08:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba jalani hal-hal yang dulu tak bisa\Nkau lakukan, termasuk membuat kesalahan.
Dialogue: 0,0:08:53.15,0:08:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal kurang tidur itu\Nkita kesampingkan dulu.
Dialogue: 0,0:08:56.41,0:08:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kau mulai SMP,
Dialogue: 0,0:08:59.15,0:09:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau kelihatan lebih cerah.
Dialogue: 0,0:09:04.21,0:09:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Mama.
Dialogue: 0,0:09:05.75,0:09:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanannya enak.
Dialogue: 0,0:09:07.15,0:09:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:09:09.11,0:09:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana, antarkan dia.
Dialogue: 0,0:09:12.55,0:09:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya...
Dialogue: 0,0:09:17.85,0:09:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:19.18,0:09:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi dia sama waria,
Dialogue: 0,0:09:21.01,0:09:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang pulang sama tante cantik.
Dialogue: 0,0:09:23.81,0:09:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami itu orang macam apa, sih?
Dialogue: 0,0:09:27.85,0:09:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\Nhasil ujiannya tidak jelek juga.
Dialogue: 0,0:09:31.98,0:09:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada beberapa yang terlupa dan salah.
Dialogue: 0,0:09:34.05,0:09:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi masih oke.
Dialogue: 0,0:09:36.18,0:09:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk kali ini, begitu saja.
Dialogue: 0,0:09:39.61,0:09:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak yang harus dipelajari.\NYuk, semangat untuk berikutnya!
Dialogue: 0,0:09:52.93,0:09:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong...
Dialogue: 0,0:09:54.15,0:09:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini cuma mau makan ramen.
Dialogue: 0,0:09:57.18,0:10:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami memang bukan orang biasa, ya?
Dialogue: 0,0:10:00.81,0:10:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh pacar orang.
Dialogue: 0,0:10:02.78,0:10:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aneh, sih.
Dialogue: 0,0:10:04.81,0:10:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa, ya?
Dialogue: 0,0:10:06.55,0:10:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti om-om atau papa.\NAda kesenjangan generasi.
Dialogue: 0,0:10:11.91,0:10:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia benar masih SMP?
Dialogue: 0,0:10:19.98,0:10:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini caranya.
Dialogue: 0,0:10:21.71,0:10:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulangi gerakan ini tiga sampai empat kali.
Dialogue: 0,0:10:27.18,0:10:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisakan ruang dengan ibu jari\Nsebagai pengait.
Dialogue: 0,0:10:31.38,0:10:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu lilitkan benangnya,\Nini namanya tangkai benang.
Dialogue: 0,0:10:36.11,0:10:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat simpul, lalu kunci dengan simpul mati.
Dialogue: 0,0:10:41.91,0:10:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:10:44.11,0:10:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang, 'kan?
Dialogue: 0,0:10:46.01,0:10:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi begini cara memasang kancing.
Dialogue: 0,0:10:48.95,0:10:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah mahir,\Nbisa selesai kurang dari 10 menit.
Dialogue: 0,0:10:51.58,0:10:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan memperbaiki kancing sendiri,\Nkau akan makin sayang dengan pakaianmu.
Dialogue: 0,0:10:56.45,0:10:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:57.78,0:11:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti mobil atau motor...\Nmakin diutak-atik, makin sayang.
Dialogue: 0,0:11:01.51,0:11:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemikiranmu tidak seperti\Nanak SMP pada umumnya.
Dialogue: 0,0:11:05.58,0:11:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliran kalian mencoba.
Dialogue: 0,0:11:07.65,0:11:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang tidak mengerti, tanya saja.
Dialogue: 0,0:11:09.61,0:11:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:11:10.91,0:11:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata jarum bisa dipakai\Nseperti ini juga.
Dialogue: 0,0:11:13.15,0:11:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:14.35,0:11:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira jarum itu cuma buat\Ndilumuri racun atau semacamnya.
Dialogue: 0,0:11:17.88,0:11:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, sih...
Dialogue: 0,0:11:19.11,0:11:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:11:22.65,0:11:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:23.81,0:11:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tadi kelihatan mudah.
Dialogue: 0,0:11:27.02,0:11:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:11:27.98,0:11:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa jadi begitu?
Dialogue: 0,0:11:29.58,0:11:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren?
Dialogue: 0,0:11:31.45,0:11:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:11:33.38,0:11:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru sadar ternyata\Naku tidak pandai menjahit.
Dialogue: 0,0:11:37.25,0:11:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya ada ekskul.\NSaatnya tanya ke kakak kelas.
Dialogue: 0,0:11:41.65,0:11:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut.
Dialogue: 0,0:11:56.21,0:11:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana...
Dialogue: 0,0:11:57.45,0:12:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kito belum pulang?
Dialogue: 0,0:12:00.38,0:12:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian berdua.
Dialogue: 0,0:12:02.75,0:12:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir lupa menyiraminya.
Dialogue: 0,0:12:06.21,0:12:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunga matahari, ya?
Dialogue: 0,0:12:07.41,0:12:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ditanam lebih awal.
Dialogue: 0,0:12:09.95,0:12:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya akan mekar\Nsebelum liburan musim panas.
Dialogue: 0,0:12:12.65,0:12:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku menantikannya.
Dialogue: 0,0:12:17.78,0:12:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:12:19.21,0:12:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:20.15,0:12:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kelihatan senang.
Dialogue: 0,0:12:23.78,0:12:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang spesial.
Dialogue: 0,0:12:26.71,0:12:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya suka Klub Tata Boga.
Dialogue: 0,0:12:29.11,0:12:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:12:30.25,0:12:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kito suka berkebun,
Dialogue: 0,0:12:33.18,0:12:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Shiraishi jago masak,
Dialogue: 0,0:12:35.98,0:12:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamaoka jago bikin kue,
Dialogue: 0,0:12:38.55,0:12:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamura dan Nishimura\Npintar kerajinan tangan.
Dialogue: 0,0:12:42.71,0:12:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di klub kita melakukan kegiatan bersama,
Dialogue: 0,0:12:45.15,0:12:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi semua punya dunia mereka sendiri.
Dialogue: 0,0:12:50.05,0:12:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak suka kepo,\Njadi enak diajak ngobrol.
Dialogue: 0,0:12:54.55,0:12:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang masuk Klub Tata Boga.
Dialogue: 0,0:12:59.91,0:13:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, kita akan membuat\Nnasi kepal untuk klub bisbol.
Dialogue: 0,0:13:05.58,0:13:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya banyak, tapi mereka\Npasti senang. Ayo lakukan yang terbaik!
Dialogue: 0,0:13:10.45,0:13:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:12.11,0:13:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya...
Dialogue: 0,0:13:14.58,0:13:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini lapangan bisbol dipakai\Njuga oleh tim Little Senior.
Dialogue: 0,0:13:20.01,0:13:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, bekal hari ini untuk mereka.
Dialogue: 0,0:13:23.51,0:13:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tim itu ada Unicorn.
Dialogue: 0,0:13:27.05,0:13:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kepikiran.
Dialogue: 0,0:13:30.01,0:13:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Unicorn belum tentu mengincar Noren.
Dialogue: 0,0:13:33.78,0:13:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma rumor,\Nbelum tentu terjadi apa-apa.
Dialogue: 0,0:13:38.78,0:13:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kalian tidak nyaman,\Nkalian berdua boleh tidak ikut.
Dialogue: 0,0:13:43.61,0:13:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:13:46.55,0:13:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti perasaanmu.
Dialogue: 0,0:13:48.41,0:13:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan saja sesukamu.
Dialogue: 0,0:13:57.38,0:13:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, kami bawa bekal.
Dialogue: 0,0:13:59.53,0:14:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, terima kasih.
Dialogue: 0,0:14:01.55,0:14:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahat!
Dialogue: 0,0:14:03.66,0:14:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:14:04.64,0:14:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:14:08.18,0:14:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, buruan!
Dialogue: 0,0:14:10.45,0:14:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah datang.
Dialogue: 0,0:14:13.18,0:14:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tinggi itu orangnya.
Dialogue: 0,0:14:19.01,0:14:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Auranya berbeda.
Dialogue: 0,0:14:21.71,0:14:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung ketahuan.
Dialogue: 0,0:14:27.51,0:14:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tendo Tenma.
Dialogue: 0,0:14:29.15,0:14:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi banget untuk anak SMP.
Dialogue: 0,0:14:31.65,0:14:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas 190 cm.
Dialogue: 0,0:14:33.91,0:14:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, nasi kepal!
Dialogue: 0,0:14:36.61,0:14:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf telat.
Dialogue: 0,0:14:38.61,0:14:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:14:42.65,0:14:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, jadi makin semangat.
Dialogue: 0,0:14:47.05,0:14:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, baru ingat.
Dialogue: 0,0:14:48.95,0:14:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ke sini, ya?\NBoleh mengobrol sebentar?
Dialogue: 0,0:14:52.11,0:14:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian Noren dan Juzo, ya?
Dialogue: 0,0:14:54.65,0:14:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir-akhir ini kalian lumayan mencolok.
Dialogue: 0,0:14:57.38,0:14:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi banget.
Dialogue: 0,0:14:58.85,0:15:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lihat apakah\Nrumor itu benar atau tidak.
Dialogue: 0,0:15:02.18,0:15:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia langsung akan mengajak duel?
Dialogue: 0,0:15:05.05,0:15:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo duel.
Dialogue: 0,0:15:07.05,0:15:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku menang, aku jadi pacar Noren, ya?
Dialogue: 0,0:15:10.85,0:15:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:15:11.95,0:15:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, seperti di rumor,\Nlangsung mengajak duel.
Dialogue: 0,0:15:15.65,0:15:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:15:16.98,0:15:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tenma.
Dialogue: 0,0:15:18.41,0:15:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai, santai,\Nini cuma obrolan waktu istirahat.
Dialogue: 0,0:15:22.65,0:15:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh ajukan duel dadakan begitu.
Dialogue: 0,0:15:26.71,0:15:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:15:28.25,0:15:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka kau, maaf ya.
Dialogue: 0,0:15:32.11,0:15:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:33.31,0:15:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku tidak mau jadi pacarmu...
Dialogue: 0,0:15:36.81,0:15:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma mau mengalahkan dia.
Dialogue: 0,0:15:42.81,0:15:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, olahraga itu yang paling utama.
Dialogue: 0,0:15:47.25,0:15:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kalian semua\Nharus menyaksikanku.
Dialogue: 0,0:15:49.45,0:15:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajib menyaksikanku.
Dialogue: 0,0:15:52.05,0:15:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi atlet legendaris.
Dialogue: 0,0:15:55.05,0:15:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi\N"Tiga Pedang" yang luar biasa.
Dialogue: 0,0:15:58.61,0:15:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga Pedang?
Dialogue: 0,0:15:59.85,0:16:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu istilah bisbol?
Dialogue: 0,0:16:02.38,0:16:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang.
Dialogue: 0,0:16:03.38,0:16:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah cek artinya.
Dialogue: 0,0:16:05.75,0:16:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:16:06.61,0:16:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga Pedang bukan istilah bisbol.
Dialogue: 0,0:16:09.38,0:16:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atlet Tiga Pedang artinya...
Dialogue: 0,0:16:13.05,0:16:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di bisbol ada Little Senior,
Dialogue: 0,0:16:15.25,0:16:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sepak bola ada Tim Youth,
Dialogue: 0,0:16:16.91,0:16:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di basket dengan klub SMP
Dialogue: 0,0:16:18.51,0:16:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia jagoan di semua cabang.
Dialogue: 0,0:16:20.61,0:16:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah banyak gelar nasional yang diraih.
Dialogue: 0,0:16:23.55,0:16:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan atletik yang luar biasa sempurna.
Dialogue: 0,0:16:28.01,0:16:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Major League, NBA, dan Premier League.
Dialogue: 0,0:16:31.58,0:16:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi pemain terbaik di semuanya.
Dialogue: 0,0:16:35.45,0:16:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:36.31,0:16:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang bisa?
Dialogue: 0,0:16:37.78,0:16:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang tahu.
Dialogue: 0,0:16:39.11,0:16:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang ada pro yang bisa\Ndi lebih dari satu cabang.
Dialogue: 0,0:16:42.81,0:16:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:44.18,0:16:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, atlet super ini\Ningin jadi pusat perhatian,
Dialogue: 0,0:16:46.98,0:16:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak tahan melihat orang\Nyang lebih mencolok dari dirinya.
Dialogue: 0,0:16:50.21,0:16:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:51.18,0:16:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:16:53.71,0:16:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cuma figuran di Klub Tata Boga, 'kan?
Dialogue: 0,0:16:56.61,0:17:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tertarik dengan orang\Ndan klub yang tidak jelas.
Dialogue: 0,0:17:02.98,0:17:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja,
Dialogue: 0,0:17:04.10,0:17:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau sedikit mengganggu.
Dialogue: 0,0:17:06.10,0:17:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ngomong apa, sih?
Dialogue: 0,0:17:08.55,0:17:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi
Dialogue: 0,0:17:09.41,0:17:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nasi kepalnya mantap.
Dialogue: 0,0:17:11.05,0:17:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu beli.
Dialogue: 0,0:17:12.45,0:17:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau keterlaluan.
Dialogue: 0,0:17:14.60,0:17:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:17:15.95,0:17:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terima
Dialogue: 0,0:17:17.21,0:17:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tantangan duelnya.
Dialogue: 0,0:17:18.60,0:17:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami!
Dialogue: 0,0:17:19.71,0:17:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu menerimanya.
Dialogue: 0,0:17:21.81,0:17:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa, aku kesal.
Dialogue: 0,0:17:24.57,0:17:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan hanya meremehkanku,\Ntapi juga kakak kelas di Klub Tata Boga.
Dialogue: 0,0:17:29.71,0:17:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau dia manusia super,\NTiga Pedang, atau apa pun...
Dialogue: 0,0:17:32.98,0:17:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan meremehkan Klub Tata Boga,\Ndasar bodoh!
Dialogue: 0,0:17:36.15,0:17:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:17:37.35,0:17:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, sudah diputuskan.
Dialogue: 0,0:17:39.21,0:17:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya bertanding apa, ya?
Dialogue: 0,0:17:41.41,0:17:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, futsal saja.
Dialogue: 0,0:17:43.51,0:17:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan minggu depan di ruang gym.
Dialogue: 0,0:17:45.75,0:17:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ajak satu orang lagi.\NKalian mau berapa orang juga boleh.
Dialogue: 0,0:17:49.58,0:17:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Tidak perlu dikasihani.
Dialogue: 0,0:17:51.85,0:17:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mending diterima saja.
Dialogue: 0,0:17:54.71,0:17:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, terserah.
Dialogue: 0,0:17:56.91,0:17:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa keringanan,\Npertandingannya berat sebelah.
Dialogue: 0,0:17:59.38,0:18:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserahmu saja.
Dialogue: 0,0:18:01.91,0:18:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf ya, Klub Tata Boga.
Dialogue: 0,0:18:04.35,0:18:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf.
Dialogue: 0,0:18:06.95,0:18:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hem...
Dialogue: 0,0:18:08.65,0:18:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia diperlakukan istimewa.
Dialogue: 0,0:18:11.15,0:18:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang ikut banyak klub\Nbiasanya kewalahan, 'kan?
Dialogue: 0,0:18:16.45,0:18:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia luar biasa, tidak masalah baginya.
Dialogue: 0,0:18:21.85,0:18:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal sikapnya yang kurang sopan,\Nkami mohon maaf.
Dialogue: 0,0:18:24.85,0:18:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau boleh aku sampaikan satu hal...
Dialogue: 0,0:18:28.18,0:18:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai anggota tim,
Dialogue: 0,0:18:30.15,0:18:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia adalah pahlawan.
Dialogue: 0,0:18:32.31,0:18:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebagai lawan,
Dialogue: 0,0:18:34.81,0:18:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia adalah musuh terkuat.
Dialogue: 0,0:18:38.73,0:18:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu ribet.
Dialogue: 0,0:18:41.61,0:18:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang meremehkan klub kita\Nharus kita hajar. Lawan mereka, Ogami!
Dialogue: 0,0:18:46.28,0:18:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku, Kak!\NAkan kubuat dia menyesal.
Dialogue: 0,0:18:50.91,0:18:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian malah kelihatan seperti antagonis.
Dialogue: 0,0:18:53.71,0:18:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini futsal, 'kan?\NSiapa yang akan bantu Ogami?
Dialogue: 0,0:18:57.78,0:18:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren?
Dialogue: 0,0:19:00.55,0:19:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh ajukan duel dadakan begitu.
Dialogue: 0,0:19:04.75,0:19:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:19:06.18,0:19:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka kau, maaf ya.
Dialogue: 0,0:19:10.95,0:19:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh!
Dialogue: 0,0:19:12.75,0:19:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal biasanya kalau sudah begitu,
Dialogue: 0,0:19:14.65,0:19:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan bilang,\N"Jangan memperebutkan aku."
Dialogue: 0,0:19:17.09,0:19:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah dapat, "Maaf, aku tidak tertarik."
Dialogue: 0,0:19:18.71,0:19:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, sakit hati juga.
Dialogue: 0,0:19:20.84,0:19:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa.
Dialogue: 0,0:19:21.65,0:19:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu berlebihan.
Dialogue: 0,0:19:23.68,0:19:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tak usah dipikirkan.
Dialogue: 0,0:19:24.78,0:19:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja.
Dialogue: 0,0:19:26.91,0:19:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin!
Dialogue: 0,0:19:27.91,0:19:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kau ternyata.
Dialogue: 0,0:19:29.71,0:19:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah mempermalukan Noren yang kusuka.
Dialogue: 0,0:19:32.58,0:19:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan memperebutkan aku."\N"Maaf, aku tidak tertarik."
Dialogue: 0,0:19:36.18,0:19:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia sakit hati.
Dialogue: 0,0:19:38.25,0:19:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa kumaafkan.
Dialogue: 0,0:19:39.38,0:19:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ingatkan aku soal itu.
Dialogue: 0,0:19:42.51,0:19:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak harus 2 lawan 2, aku juga ikut.
Dialogue: 0,0:19:46.51,0:19:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub Tata Boga bukan main-main.
Dialogue: 0,0:19:49.55,0:19:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita serius menjalani apa yang kita sukai.
Dialogue: 0,0:19:51.81,0:19:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kito!
Dialogue: 0,0:19:53.78,0:19:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga sudah mempermalukan Mitsuoka.
Dialogue: 0,0:19:55.81,0:19:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan memperebutkan aku."
Dialogue: 0,0:19:57.85,0:20:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Maaf, aku tidak tertarik."\NPasti dia sakit hati.
Dialogue: 0,0:20:01.55,0:20:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lupakan soal itu.
Dialogue: 0,0:20:05.31,0:20:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:20:06.55,0:20:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri tidak peduli\Nsoal duel jadi pacarku ini.
Dialogue: 0,0:20:09.95,0:20:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih penting,
Dialogue: 0,0:20:11.18,0:20:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa memaafkan mereka\Nyang meremehkan Klub Tata Boga.
Dialogue: 0,0:20:15.35,0:20:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:20:16.65,0:20:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian harus menang.
Dialogue: 0,0:20:18.41,0:20:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dukung penuh!
Dialogue: 0,0:20:19.64,0:20:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:21:55.35,0:21:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba diajak ikut duel,\Naku tidak ngerti.
Dialogue: 0,0:21:59.65,0:22:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekolahmu ada cewek konglomerat\Nbernama Mitsuoka itu, 'kan?
Dialogue: 0,0:22:03.58,0:22:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:22:04.81,0:22:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak ada alasan khusus.
Dialogue: 0,0:22:06.58,0:22:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:22:08.81,0:22:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini aneh.
Dialogue: 0,0:22:11.31,0:22:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau tidak biasa cari masalah.
Dialogue: 0,0:22:14.25,0:22:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang mulai duluan,\Naku hanya melanjutkan.
Dialogue: 0,0:22:17.58,0:22:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya,
Dialogue: 0,0:22:19.05,0:22:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak tertarik, harusnya tidak usah.
Dialogue: 0,0:22:21.78,0:22:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga.
Dialogue: 0,0:22:23.51,0:22:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, ya?
Dialogue: 0,0:22:29.35,0:22:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Ogami itu sangat mengganggu pikiranku.
Dialogue: 0,0:22:37.21,0:22:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya aku akan main seadanya saja.
Dialogue: 0,0:22:40.38,0:22:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, oke.
Dialogue: 0,0:22:42.01,0:22:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, dari awal\Naku juga tidak berharap banyak.
Dialogue: 0,0:22:45.81,0:22:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya jangan suka omong besar.
Dialogue: 0,0:22:49.95,0:22:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kelepasan.
Dialogue: 0,0:22:56.11,0:22:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil menerimanya.
Dialogue: 0,0:22:58.21,0:22:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang berbakat.
Dialogue: 0,0:23:00.00,0:23:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umpan bagus.
Dialogue: 0,0:23:01.18,0:23:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat menyebalkan.
Dialogue: 0,0:23:04.25,0:23:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duel Mitsuoka!
Dialogue: 0,0:23:05.46,0:23:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini dari Unicorn.
Dialogue: 0,0:23:06.91,0:23:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga lawan dua.
Dialogue: 0,0:23:08.81,0:23:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan macam apa ini?
Dialogue: 0,0:23:11.58,0:23:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalau kau menang,\Nkita ikuti aturan duel Mitsuoka.
Dialogue: 0,0:23:16.25,0:23:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kami yang menang, ada syaratnya.
Dialogue: 0,0:23:19.55,0:23:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:23:20.91,0:23:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus minta maaf ke kakak kelas\NKlub Tata Boga karena sudah meremehkan kami.
Dialogue: 0,0:23:25.51,0:23:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:23:27.55,0:23:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:23:28.65,0:23:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama saja kayak bilang\Njangan minta maaf, lo.
Dialogue: 0,0:23:31.78,0:23:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemenangnya pasti aku.
