Dialogue: 0,0:00:00.00,0:00:00.42,sign,,0000,0000,0000,,INSIDEN LEDAKAN DI STADION NASIONAL BARU
Dialogue: 0,0:00:04.11,0:00:07.44,sign,,0000,0000,0000,,"DONASI BESAR UNTUK PERBAIKAN"
Dialogue: 0,0:00:07.48,0:00:07.95,sign,,0000,0000,0000,,KODA MORIO\NANGGOTA PARLEMEN
Dialogue: 0,0:10:17.01,0:10:21.01,sign,,0000,0000,0000,,DEATH OR KISS\NSABTU, 13 JUNI
Dialogue: 0,0:13:14.44,0:13:14.78,sign,,0000,0000,0000,,CHINATOWN
Dialogue: 0,0:15:31.78,0:15:33.78,sign,,0000,0000,0000,,SEJARAH BESAR MI INSTAN
Dialogue: 0,0:16:15.70,0:16:16.95,sign,,0000,0000,0000,,MI PENUH CINTA
Dialogue: 0,0:00:00.45,0:00:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tengah misteri ledakan\Nyang mengguncang Stadion Nasional Baru,
Dialogue: 0,0:00:04.11,0:00:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}muncul nama yang tak asing di telinga publik.
Dialogue: 0,0:00:07.98,0:00:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koda Morio, anggota parlemen yang pernah\Ntersorot karena skandal dana ilegal.
Dialogue: 0,0:00:13.91,0:00:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari wawancara dengan pihak terkait,
Dialogue: 0,0:00:15.95,0:00:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diketahui kelompok pendukungnya\Nmenawarkan donasi besar-besaran.
Dialogue: 0,0:00:20.01,0:00:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, mari kita dengar\Ntanggapan dari yang bersangkutan.
Dialogue: 0,0:00:25.18,0:00:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku khawatir.
Dialogue: 0,0:00:27.58,0:00:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi serius?\NItu benar-benar terjadi?
Dialogue: 0,0:00:30.98,0:00:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi saat kalian\Nmenemukan mobil para penculik,
Dialogue: 0,0:00:34.78,0:00:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka malah asyik\Nmain lempar bola di taman,
Dialogue: 0,0:00:38.01,0:00:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu kalian manfaatkan kelengahan itu\Nuntuk menyelamatkan Noren?
Dialogue: 0,0:00:40.85,0:00:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, serius.
Dialogue: 0,0:00:43.21,0:00:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penculiknya santai amat?
Dialogue: 0,0:00:46.48,0:00:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sekhawatir itu padaku.
Dialogue: 0,0:00:49.71,0:00:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan Kakak jatuh hati…
Dialogue: 0,0:00:51.45,0:00:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma khawatir, kok.
Dialogue: 0,0:02:33.75,0:02:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Oga, pagi.
Dialogue: 0,0:02:36.05,0:02:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:02:37.81,0:02:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:02:38.97,0:02:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram.
Dialogue: 0,0:02:40.11,0:02:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini gara-gara apa?
Dialogue: 0,0:02:42.05,0:02:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}UAS masih lama, lo.
Dialogue: 0,0:02:44.06,0:02:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abaikan saja aku.
Dialogue: 0,0:02:45.75,0:02:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Liburnya cukup panjang,\Naku cuma mau fokus lagi.
Dialogue: 0,0:02:49.56,0:02:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus macam apa ini?
Dialogue: 0,0:02:52.15,0:02:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu tegang banget.
Dialogue: 0,0:02:54.36,0:02:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kenapa, sih, Oga?
Dialogue: 0,0:02:56.03,0:02:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, jangan-jangan dia juga suka kau.
Dialogue: 0,0:03:00.95,0:03:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, duluan saja.
Dialogue: 0,0:03:03.45,0:03:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, oke.
Dialogue: 0,0:03:04.78,0:03:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang?
Dialogue: 0,0:03:06.05,0:03:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren sudah mengintai di area loker.
Dialogue: 0,0:03:08.36,0:03:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:09.11,0:03:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:03:10.15,0:03:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa sadar.\NKau memang hebat, Bang.
Dialogue: 0,0:03:12.72,0:03:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:03:13.71,0:03:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut Noren yang mencuat itu\Nkelihatan jelas.
Dialogue: 0,0:03:17.01,0:03:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, benar juga.\NSiapa pun pasti sadar.
Dialogue: 0,0:03:25.25,0:03:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku ini sedang apa?
Dialogue: 0,0:03:27.75,0:03:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai menguntit begini.
Dialogue: 0,0:03:30.11,0:03:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku terus kepikiran Ogami.
Dialogue: 0,0:03:34.94,0:03:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Noren.
Dialogue: 0,0:03:36.75,0:03:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan perasaanmu yang asli,\Ncuma efek hipnosis.
Dialogue: 0,0:03:41.01,0:03:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai orang-orang mengira\Nkita benar-benar pacaran,
Dialogue: 0,0:03:44.65,0:03:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nanti semuanya jadi rumit.
Dialogue: 0,0:03:49.38,0:03:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi untuk sementara,\Naku akan menjaga jarak.
Dialogue: 0,0:03:57.81,0:04:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master, pagi.
Dialogue: 0,0:04:00.15,0:04:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi, Ogami.
Dialogue: 0,0:04:03.28,0:04:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sering kubilang,\Nberhenti memanggilku Master.
Dialogue: 0,0:04:06.30,0:04:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung ke intinya saja.
Dialogue: 0,0:04:10.11,0:04:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau dikeluarkan.\N- Kenapa?
Dialogue: 0,0:04:15.60,0:04:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kemarin kau kencan ganda.
Dialogue: 0,0:04:18.69,0:04:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ah, sebentar...\N- Sama kakak dan si Young Corn itu.
Dialogue: 0,0:04:21.98,0:04:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Unicorn.
Dialogue: 0,0:04:23.18,0:04:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh amat.
Dialogue: 0,0:04:25.01,0:04:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau malah membiarkan serangga itu\Nnempel ke kakakku. Apa maksudmu?
Dialogue: 0,0:04:29.18,0:04:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:32.41,0:04:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini rupanya.
Dialogue: 0,0:04:33.94,0:04:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi, Shiraishi.
Dialogue: 0,0:04:35.45,0:04:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi.
Dialogue: 0,0:04:37.78,0:04:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi juga, Ogami.
Dialogue: 0,0:04:40.84,0:04:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi, aku mau ke toilet dulu.
Dialogue: 0,0:04:46.43,0:04:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pagi, aku mau ke toilet"?
Dialogue: 0,0:04:48.51,0:04:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:04:49.81,0:04:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara kaburnya kayak anak SMP yang om-om.
Dialogue: 0,0:04:52.65,0:04:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu ceritanya.
Dialogue: 0,0:05:00.85,0:05:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah ditertawakan.
Dialogue: 0,0:05:02.91,0:05:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga kewalahan, lo.
Dialogue: 0,0:05:06.15,0:05:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu banget, sih.
Dialogue: 0,0:05:09.55,0:05:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak kuat.
Dialogue: 0,0:05:11.81,0:05:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Eri.
Dialogue: 0,0:05:13.81,0:05:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:05:15.98,0:05:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balik ke pokoknya. Jadi dia sempat\Nmendadak balik ke wujud asli, ya?
Dialogue: 0,0:05:20.92,0:05:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:23.15,0:05:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita harus segera\Ncari tahu penyebabnya.
Dialogue: 0,0:05:26.38,0:05:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia tiba-tiba balik ke om-om\Nsaat pelajaran, bisa heboh.
Dialogue: 0,0:05:30.25,0:05:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada om-om di sini!
Dialogue: 0,0:05:31.68,0:05:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:05:32.61,0:05:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:05:34.39,0:05:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia makan sesuatu yang basi?
Dialogue: 0,0:05:37.55,0:05:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu tidak ada kaitannya.
Dialogue: 0,0:05:39.90,0:05:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tadi cuma bercanda.
Dialogue: 0,0:05:42.41,0:05:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kemungkinan besar,\Nreaksi itu dipicu sesuatu yang dia konsumsi.
Dialogue: 0,0:05:47.75,0:05:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau racunnya benar-benar hilang,\Ndia takkan berubah jadi anak kecil lagi.
Dialogue: 0,0:05:51.65,0:05:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, coba ingat-ingat\Napa saja yang dia makan.
Dialogue: 0,0:05:56.91,0:05:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:05:58.54,0:06:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, kudengar kalian sempat berurusan\Ndengan pembunuh bayaran Hardin.
Dialogue: 0,0:06:02.35,0:06:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:04.35,0:06:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya,
Dialogue: 0,0:06:06.18,0:06:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebah milik Mitsuoka itu buatan.
Dialogue: 0,0:06:09.18,0:06:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara tercepat adalah menemukan\Nsang pembuat lebah
Dialogue: 0,0:06:12.14,0:06:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menggali informasi darinya.
Dialogue: 0,0:06:15.05,0:06:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasi soal itu dijaga sangat ketat.
Dialogue: 0,0:06:18.45,0:06:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sepertinya Hardin berhasil\Nmendapat informasi terkait hal itu.
Dialogue: 0,0:07:27.55,0:07:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oga.
Dialogue: 0,0:07:28.78,0:07:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ngobrol.
Dialogue: 0,0:07:30.47,0:07:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:32.45,0:07:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar saja.
Dialogue: 0,0:07:34.22,0:07:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:07:35.61,0:07:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang menyuruh kami untuk menahanmu.
Dialogue: 0,0:07:39.75,0:07:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayarannya puding.
Dialogue: 0,0:07:41.21,0:07:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murah amat.
Dialogue: 0,0:07:41.90,0:07:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba tebak siapa klien kami?
Dialogue: 0,0:07:45.48,0:07:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami! Kau ini apa-apaan?
Dialogue: 0,0:07:47.81,0:07:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kau aneh.
Dialogue: 0,0:07:49.25,0:07:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang aneh itu justru kau, Noren.
Dialogue: 0,0:07:51.71,0:07:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menghindariku?
Dialogue: 0,0:07:54.21,0:07:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma… Ah, sudahlah.
Dialogue: 0,0:07:56.70,0:07:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sudah tak tahan!
Dialogue: 0,0:07:59.35,0:08:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kau serius?
Dialogue: 0,0:08:00.98,0:08:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar suka?
Dialogue: 0,0:08:02.16,0:08:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri tidak mengerti.
Dialogue: 0,0:08:04.28,0:08:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat katakan, Noren.
Dialogue: 0,0:08:06.17,0:08:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Ogami, aku su...
Dialogue: 0,0:08:09.25,0:08:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti pernyataan cinta.
Dialogue: 0,0:08:11.05,0:08:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren juga bersikap aneh.
Dialogue: 0,0:08:18.56,0:08:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali saja.
Dialogue: 0,0:08:22.38,0:08:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, Ogami.
Dialogue: 0,0:08:25.85,0:08:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan aku dulu.
Dialogue: 0,0:08:28.02,0:08:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat banget.
Dialogue: 0,0:08:30.38,0:08:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja, dia memang atletis.
Dialogue: 0,0:08:52.97,0:08:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?
Dialogue: 0,0:08:54.63,0:08:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa mengejar?\NNoren jago lari, ya.
Dialogue: 0,0:09:30.67,0:09:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:09:32.38,0:09:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami.
Dialogue: 0,0:09:34.58,0:09:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya bisa menjauh juga.
Dialogue: 0,0:09:36.91,0:09:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang saja, deh.\NTasku kuambil besok saja.
Dialogue: 0,0:09:45.25,0:09:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, boleh aku pinjam itu?
Dialogue: 0,0:09:47.89,0:09:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:00.41,0:10:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kau, Ogami.
Dialogue: 0,0:10:02.65,0:10:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau lari terus, ayo kita tanding.
Dialogue: 0,0:10:04.50,0:10:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku berhasil menangkapmu,
Dialogue: 0,0:10:06.61,0:10:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus kencan denganku.
Dialogue: 0,0:10:07.98,0:10:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak main-main.
Dialogue: 0,0:10:09.50,0:10:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia keren sekali?
Dialogue: 0,0:10:11.75,0:10:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kenapa malah tanding?
Dialogue: 0,0:10:14.35,0:10:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren, ada apa?
Dialogue: 0,0:10:30.81,0:10:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kau, Ogami.
Dialogue: 0,0:10:33.31,0:10:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau lari terus, ayo kita tanding.
Dialogue: 0,0:10:35.28,0:10:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku berhasil menangkapmu,
Dialogue: 0,0:10:37.31,0:10:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus kencan denganku.\NAku tidak main-main.
Dialogue: 0,0:10:40.28,0:10:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah tanding?
Dialogue: 0,0:10:42.08,0:10:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren, ada apa?
Dialogue: 0,0:10:43.87,0:10:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?\NBukankah mereka berdua pacaran?
Dialogue: 0,0:10:47.12,0:10:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi berantem?
Dialogue: 0,0:10:48.71,0:10:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusan cinta yang rumit.
Dialogue: 0,0:10:50.12,0:10:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, orang-orang mulai berkumpul.
Dialogue: 0,0:10:52.65,0:10:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren juga lagi sulit ditebak sekarang.
Dialogue: 0,0:10:56.41,0:10:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Ayo kita pindah ke tempat lain.
Dialogue: 0,0:11:04.18,0:11:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bicarakan baik-baik.
Dialogue: 0,0:11:06.05,0:11:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita cuma pura-pura pacaran,
Dialogue: 0,0:11:07.91,0:11:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu kita lakukan untuk mengusir\Ncowok-cowok yang mendekatimu, 'kan?
Dialogue: 0,0:11:12.23,0:11:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Tak kusangka aku akan\Njatuh cinta sungguhan.
Dialogue: 0,0:11:17.59,0:11:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri tidak paham,\Ntapi perasaanku begitu besar.
Dialogue: 0,0:11:22.61,0:11:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial. Hipnosis Kazuma\Nbenar-benar kuat.
Dialogue: 0,0:11:27.45,0:11:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tunggu dulu.
Dialogue: 0,0:11:31.85,0:11:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:11:34.04,0:11:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya perasaan\Nyang sama denganmu, Mitsuoka.
Dialogue: 0,0:11:38.51,0:11:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bisa sebatas pura-pura.
Dialogue: 0,0:11:41.09,0:11:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jadi serumit ini\Ndan harus saling menghindar,
Dialogue: 0,0:11:44.61,0:11:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mending kutolak saja dari awal.
Dialogue: 0,0:11:47.11,0:11:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya kulakukan sejak awal.
Dialogue: 0,0:11:51.85,0:11:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:11:53.25,0:11:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke.
Dialogue: 0,0:11:55.35,0:11:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah bikin ribut.
Dialogue: 0,0:12:03.70,0:12:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mati saja.
Dialogue: 0,0:12:05.62,0:12:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hentikan! Hei!
Dialogue: 0,0:12:07.71,0:12:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu! Tenangkan dirimu!
Dialogue: 0,0:12:09.95,0:12:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu sampai sebegitunya!\NAyo menepi dulu!
Dialogue: 0,0:12:12.53,0:12:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan. Aku sudah tidak peduli.
Dialogue: 0,0:12:15.51,0:12:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpamu, dunia ini sia-sia.
Dialogue: 0,0:12:16.93,0:12:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ada artinya, lah!
Dialogue: 0,0:12:18.31,0:12:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya jangan nekat!
Dialogue: 0,0:12:19.41,0:12:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, itu curang, 'kan?
Dialogue: 0,0:12:21.35,0:12:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah berkali-kali menolak orang,
Dialogue: 0,0:12:23.81,0:12:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}giliran kau ditolak langsung mau mati?
Dialogue: 0,0:12:27.39,0:12:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahat banget.
Dialogue: 0,0:12:28.25,0:12:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tadi aku agak tidak peka.
Dialogue: 0,0:12:44.01,0:12:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren?
Dialogue: 0,0:12:45.85,0:12:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hari ini benar-benar aneh, ya?
Dialogue: 0,0:12:49.25,0:12:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beginikah Noren saat sedang dimabuk cinta?
Dialogue: 0,0:12:53.11,0:12:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan berarti\Naku pernah lihat dia kasmaran, sih.
Dialogue: 0,0:12:57.35,0:12:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kutahu, dia tak suka cowok.
Dialogue: 0,0:12:59.71,0:13:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:13:01.01,0:13:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepribadiannya bisa berubah\Nsedrastis ini, ya?
Dialogue: 0,0:13:06.31,0:13:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telepon spam?
Dialogue: 0,0:13:08.38,0:13:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:13:10.41,0:13:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini nomor yang sama seperti waktu itu.
Dialogue: 0,0:13:12.61,0:13:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti…
Dialogue: 0,0:13:14.81,0:13:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo. Kazuma?
Dialogue: 0,0:13:17.11,0:13:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Apa kabar?
Dialogue: 0,0:13:20.32,0:13:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren, aku angkat telepon sebentar, ya.
Dialogue: 0,0:13:23.11,0:13:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan nekat, ya.
Dialogue: 0,0:13:26.95,0:13:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lagi kerepotan banget.
Dialogue: 0,0:13:28.81,0:13:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi teleponmu pas sekali.
Dialogue: 0,0:13:30.61,0:13:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkahnya aneh, tahu.
Dialogue: 0,0:13:32.45,0:13:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hipnosis macam apa\Nyang kau pasang ke Noren?
Dialogue: 0,0:13:34.70,0:13:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, 'kan?
Dialogue: 0,0:13:36.21,0:13:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuh cinta pada orang pertama\Nyang dilihatnya.
Dialogue: 0,0:13:39.59,0:13:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara ugal-ugalan.
Dialogue: 0,0:13:41.88,0:13:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa hidup tanpa Ogami.
Dialogue: 0,0:13:44.51,0:13:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, aku baru tahu.
Dialogue: 0,0:13:46.85,0:13:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan, sih? Itu apa-apaan?\NKenapa harus dibuat begitu?
Dialogue: 0,0:13:51.01,0:13:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya adikku bilang\Ndia suka cewek yang agresif.
Dialogue: 0,0:13:54.51,0:13:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan! Dasar kau ini.
Dialogue: 0,0:13:55.98,0:14:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia awalnya memang sudah agresif,\Nkalian malah bikin dia lepas kendali!
Dialogue: 0,0:14:00.91,0:14:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kalian pindah ke sini?
Dialogue: 0,0:14:03.55,0:14:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh sehari-dua hari\Nsampai efeknya hilang.
Dialogue: 0,0:14:06.11,0:14:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa instan.
Dialogue: 0,0:14:07.58,0:14:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:14:08.81,0:14:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan sekarang juga. Serius.
Dialogue: 0,0:14:11.31,0:14:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, tidak ada pilihan.
Dialogue: 0,0:14:14.38,0:14:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ketemu pukul 5 sore.
Dialogue: 0,0:14:21.25,0:14:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi berdua ke Yokohama,\Nini sudah kayak kencan, 'kan?
Dialogue: 0,0:14:25.21,0:14:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan kencan, tapi buat melepas hipnosis.
Dialogue: 0,0:14:28.58,0:14:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma janjiannya di taman hiburan.
Dialogue: 0,0:14:31.05,0:14:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih gampang mengajaknya\Nkalau dia mengira ini kencan.
Dialogue: 0,0:14:34.14,0:14:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, mau ke Museum Mi Instan?
Dialogue: 0,0:14:37.11,0:14:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Mi Instan?
Dialogue: 0,0:14:39.31,0:14:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin sekali ke sana.
Dialogue: 0,0:14:41.65,0:14:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita sempat?
Dialogue: 0,0:14:44.61,0:14:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuoka juga makan mi instan, ya?
Dialogue: 0,0:14:47.88,0:14:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda dari bayanganku.
Dialogue: 0,0:14:50.61,0:14:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering makan bareng paman.
Dialogue: 0,0:14:52.95,0:14:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:14:54.87,0:14:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat sekali.
Dialogue: 0,0:14:57.18,0:15:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku ramen Natsukiya\Ntak ada tandingannya,
Dialogue: 0,0:15:00.11,0:15:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mi instan memang enak, murah pula.
Dialogue: 0,0:15:03.11,0:15:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murah?
Dialogue: 0,0:15:04.35,0:15:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:05.25,0:15:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini bicara apa, Ogami?
Dialogue: 0,0:15:07.15,0:15:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi instan itu revolusioner. Lewat inovasi,\Nia bisa diproduksi murah dan tahan lama.
Dialogue: 0,0:15:13.38,0:15:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi instan lahir dari riset para pendahulu
Dialogue: 0,0:15:16.34,0:15:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi menyelamatkan orang\Nyang kekurangan pangan.
Dialogue: 0,0:15:19.31,0:15:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, mi instan bukan sekadar soal murah.
Dialogue: 0,0:15:23.15,0:15:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku salah ngomong.
Dialogue: 0,0:15:25.23,0:15:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita keliling ke bagian sejarah.
Dialogue: 0,0:15:27.91,0:15:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujelaskan semuanya.
Dialogue: 0,0:15:29.65,0:15:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:15:40.79,0:15:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kita harus pergi.
Dialogue: 0,0:15:42.96,0:15:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bagian intinya.
Dialogue: 0,0:15:44.90,0:15:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah sampai sini,\Nkita wajib bikin mi instan!
Dialogue: 0,0:15:47.76,0:15:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:50.44,0:15:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau?
Dialogue: 0,0:15:51.49,0:15:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bikin mi instan spesial\Nmilik kita sendiri, Noren.
Dialogue: 0,0:15:55.05,0:15:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:15:56.01,0:15:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga masih sempat.
Dialogue: 0,0:16:01.79,0:16:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari adonan?
Dialogue: 0,0:16:04.01,0:16:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup.
Dialogue: 0,0:16:05.45,0:16:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan. Hentikan!
Dialogue: 0,0:16:06.77,0:16:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melakukannya tanpa melihat.
Dialogue: 0,0:16:08.68,0:16:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah lihai. Seorang master.
Dialogue: 0,0:16:12.81,0:16:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan semua itu mau dibawa pulang?
Dialogue: 0,0:16:17.71,0:16:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cintanya terlalu besar sampai bikin enek.
Dialogue: 0,0:16:20.95,0:16:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, waktunya juga sudah mepet.
Dialogue: 0,0:16:23.95,0:16:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, semua beres dengan baik.
Dialogue: 0,0:16:26.21,0:16:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren, ada tempat yang ingin kukunjungi.
Dialogue: 0,0:16:30.80,0:16:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sekarang dia malah makan?
Dialogue: 0,0:16:32.32,0:16:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kan susah payah dibuat.
Dialogue: 0,0:16:34.58,0:16:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga, sih.
Dialogue: 0,0:16:36.05,0:16:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, kita harus cepat makan\Nlalu berangkat.
Dialogue: 0,0:16:39.31,0:16:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menunjukkan perasaanku ke Ogami
Dialogue: 0,0:16:44.14,0:16:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lewat tingkat kepedasan.
Dialogue: 0,0:16:51.51,0:16:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aman dimakan?\NSepertinya bahannya berbahaya.
Dialogue: 0,0:16:56.78,0:16:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:16:59.99,0:17:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:17:03.16,0:17:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:17:06.55,0:17:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:17:14.41,0:17:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada, lo.
Dialogue: 0,0:17:23.41,0:17:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa selamat juga, ya.
Dialogue: 0,0:17:27.96,0:17:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat janjiannya di sekitar sini, 'kan?
Dialogue: 0,0:17:29.88,0:17:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita masih sempat.
Dialogue: 0,0:17:31.98,0:17:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ogami, ayo naik itu.
Dialogue: 0,0:17:35.74,0:17:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kita tidak ada waktu\Nuntuk naik itu.
Dialogue: 0,0:17:38.55,0:17:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, bianglala itu ruang tertutup.
Dialogue: 0,0:17:44.18,0:17:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak mau, ya?\NBerdua denganku?
Dialogue: 0,0:17:47.35,0:17:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik. Ayo naik!
Dialogue: 0,0:18:19.78,0:18:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, lihat.
Dialogue: 0,0:18:22.08,0:18:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas banget mataharinya sedang terbenam.
Dialogue: 0,0:18:24.71,0:18:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali.
Dialogue: 0,0:18:25.88,0:18:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuoka, bahaya kalau berdiri...
Dialogue: 0,0:18:38.15,0:18:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami.
Dialogue: 0,0:18:44.68,0:18:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya tadi jangan naik bianglala.
Dialogue: 0,0:18:46.55,0:18:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bianglala terlalu berbahaya.
Dialogue: 0,0:18:49.11,0:18:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong hentikan, Noren.
Dialogue: 0,0:18:50.58,0:18:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menatapku seperti itu.
Dialogue: 0,0:18:52.36,0:18:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh. Aku ini om-om.
Dialogue: 0,0:18:54.81,0:18:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menolak.
Dialogue: 0,0:18:56.82,0:18:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:18:57.91,0:19:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kutolak, Noren pasti mau nekat lagi…
Dialogue: 0,0:19:00.85,0:19:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditolak ajakan naik bianglala saja\Nreaksinya sudah ekstrem…
Dialogue: 0,0:19:04.15,0:19:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenangkan dirimu.
Dialogue: 0,0:19:05.38,0:19:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini soal om-om dan siswi kelas 1 SMP, lo.
Dialogue: 0,0:19:08.41,0:19:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila.
Dialogue: 0,0:19:13.59,0:19:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku tidak mencium Noren di sini,\Ndia bisa nekat.
Dialogue: 0,0:19:18.81,0:19:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kucium, aku yang tamat.\NJadi sampah masyarakat.
Dialogue: 0,0:19:23.10,0:19:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua-duanya hasilnya buruk.
Dialogue: 0,0:19:25.10,0:19:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:19:26.65,0:19:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan\Npembunuh bayaran legendaris.
Dialogue: 0,0:19:34.55,0:19:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pintunya terbuka?
Dialogue: 0,0:19:37.05,0:19:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya terkunci dari luar, 'kan?\NBagaimana ini?
Dialogue: 0,0:19:40.51,0:19:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang. Kita bisa hubungi petugas\Nlewat interkom.
Dialogue: 0,0:19:44.75,0:19:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memantulkan peluru untuk membuka kunci.
Dialogue: 0,0:19:47.76,0:19:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin agak menyeramkan, tapi bertahanlah.
Dialogue: 0,0:19:49.85,0:19:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tahan sedikit.
Dialogue: 0,0:19:53.15,0:19:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan, Nona, kalian tidak apa-apa?
Dialogue: 0,0:19:56.78,0:19:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram.
Dialogue: 0,0:19:58.11,0:20:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mohon maaf atas insiden ini.
Dialogue: 0,0:20:02.71,0:20:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lewat sini, Tuan, Nona.
Dialogue: 0,0:20:15.78,0:20:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:20:16.98,0:20:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katamu tadi buru-buru.
Dialogue: 0,0:20:19.41,0:20:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah naik bianglala\Nsambil mesra-mesraan?
Dialogue: 0,0:20:21.85,0:20:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, kan, gara-gara hipnosismu.
Dialogue: 0,0:20:24.49,0:20:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menghapus hipnosis\Npada Mitsuoka Noren dan dirimu.
Dialogue: 0,0:20:28.21,0:20:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, semua selesai.
Dialogue: 0,0:20:29.79,0:20:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya tidak apa?\NHipnosisku juga ikut dilepas?
Dialogue: 0,0:20:33.91,0:20:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa.
Dialogue: 0,0:20:35.05,0:20:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sadar level kemampuan kita berbeda.
Dialogue: 0,0:20:38.51,0:20:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai hipnosis pun\Naku tetap kalah, mending kulepas.
Dialogue: 0,0:20:42.15,0:20:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, itu membuatku lebih lega.
Dialogue: 0,0:20:45.39,0:20:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sampai jumpa.\NKita ketemu lagi di sekolah.
Dialogue: 0,0:22:32.31,0:22:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:22:34.81,0:22:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bangun?
Dialogue: 0,0:22:36.45,0:22:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:22:38.18,0:22:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ogami?
Dialogue: 0,0:22:40.44,0:22:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok aku tertidur di sini?
Dialogue: 0,0:22:49.51,0:22:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kita ada di Yokohama?\NKok aku berdua dengan Ogami?
Dialogue: 0,0:22:54.65,0:22:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, aku sama sekali tidak ingat apa-apa.
Dialogue: 0,0:22:59.18,0:23:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Tak apa,\Nyang penting kau baik-baik saja.
Dialogue: 0,0:23:06.45,0:23:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuoka.
Dialogue: 0,0:23:08.31,0:23:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:23:09.86,0:23:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau suka aku?
Dialogue: 0,0:23:11.95,0:23:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa? Jijik.
Dialogue: 0,0:23:14.45,0:23:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ini cuma teman.
Dialogue: 0,0:23:16.78,0:23:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:17.78,0:23:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak benar-benar suka aku, 'kan?
Dialogue: 0,0:23:19.91,0:23:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi kau juga pasti tahu\Naku tak bisa menerimanya, 'kan?
Dialogue: 0,0:23:28.41,0:23:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kau malah nangis, Ogami?
Dialogue: 0,0:23:30.65,0:23:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami?
Dialogue: 0,0:23:32.05,0:23:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:23:33.38,0:23:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku senang\Nmeski disebut menjijikkan.
Dialogue: 0,0:23:37.15,0:23:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kenapa? Tidak apa-apa?
