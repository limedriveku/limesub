Dialogue: 0,0:00:12.17,0:00:12.78,tanda,,0000,0000,0000,,SHIN, TENMA, RYOHEI, JUZO, KITO
Dialogue: 0,0:03:08.96,0:03:12.96,tanda,,0000,0000,0000,,BERTERIMA KASIH DENGAN TULUS,\NSABTU, 16 MEI
Dialogue: 0,0:22:49.68,0:22:51.99,tanda,,0000,0000,0000,,"TENDO TENMA HIATUS JANGKA PANJANG"
Dialogue: 0,0:22:51.99,0:22:52.34,tanda,,0000,0000,0000,,CEDERA, IMPIAN TURNAMEN MUSIM PANAS SIRNA
Dialogue: 0,0:22:56.00,0:22:56.84,tanda,,0000,0000,0000,,HIATUS JANGKA PANJANG
Dialogue: 0,0:00:02.91,0:00:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kick off!
Dialogue: 0,0:00:07.00,0:00:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:00:09.58,0:00:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita punya satu keunggulan.
Dialogue: 0,0:00:12.85,0:00:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita menang jumlah.
Dialogue: 0,0:00:14.91,0:00:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kita mengoper ke teman yang bebas,\Npasti ada jalan.
Dialogue: 0,0:00:18.85,0:00:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:00:20.51,0:00:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami!
Dialogue: 0,0:00:24.51,0:00:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Bukankah tadi dia ada\Ndi arah yang berlawanan?
Dialogue: 0,0:00:27.21,0:00:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatnya!
Dialogue: 0,0:00:32.71,0:00:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, mari perkenalan dulu.
Dialogue: 0,0:00:35.35,0:00:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisi tembak?
Dialogue: 0,0:00:42.61,0:00:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:46.35,0:00:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:00:47.30,0:00:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawangnya rubuh!
Dialogue: 0,0:00:55.15,0:00:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti identitas aslimu bakal ketahuan, Bang.
Dialogue: 0,0:00:57.92,0:00:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peduli.
Dialogue: 0,0:00:58.90,0:01:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupikirkan soal itu nanti,
Dialogue: 0,0:01:01.31,0:01:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah memberinya sedikit pelajaran.
Dialogue: 0,0:01:13.31,0:01:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar!
Dialogue: 0,0:01:14.61,0:01:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lemparan ke dalam untuk Klub Tata Boga!
Dialogue: 0,0:01:18.85,0:01:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:01:20.21,0:01:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hebat sekali!
Dialogue: 0,0:01:22.89,0:01:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan cuma hebat.
Dialogue: 0,0:01:25.15,0:01:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma itu...
Dialogue: 0,0:01:27.55,0:01:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatan tendangannya sungguh luar biasa.
Dialogue: 0,0:01:32.45,0:01:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:01:33.78,0:01:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma soal menendang, aku jagonya.
Dialogue: 0,0:01:36.18,0:01:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah kalah\Ndalam permainan patah kaleng.
Dialogue: 0,0:03:15.05,0:03:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, boleh juga, Oga.
Dialogue: 0,0:03:17.05,0:03:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dia mau hidup tenang\Ndan tidak mencolok?
Dialogue: 0,0:03:21.45,0:03:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami hebat juga.
Dialogue: 0,0:03:23.31,0:03:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Hebat!
Dialogue: 0,0:03:24.91,0:03:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya akan jadi pertandingan seru.
Dialogue: 0,0:03:28.05,0:03:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:29.12,0:03:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menendang ke dalam.
Dialogue: 0,0:03:30.85,0:03:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:03:34.29,0:03:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Shin?
Dialogue: 0,0:03:38.31,0:03:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kohazame?
Dialogue: 0,0:03:40.01,0:03:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana dot-mu?
Dialogue: 0,0:03:41.80,0:03:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta... se... ja...
Dialogue: 0,0:03:43.21,0:03:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singa laut?
Dialogue: 0,0:03:44.75,0:03:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuh saat mengadang tendangan?
Dialogue: 0,0:03:47.35,0:03:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be... gi... tu...
Dialogue: 0,0:03:49.05,0:03:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bisa berbuat apa-apa\Ntanpa dot-nya.
Dialogue: 0,0:03:52.65,0:03:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:53.71,0:03:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah dia selalu memakai dot?
Dialogue: 0,0:03:57.81,0:03:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:03:59.45,0:04:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tadi sedikit keserempet, ya.
Dialogue: 0,0:04:03.55,0:04:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bawa cadangan?
Dialogue: 0,0:04:07.58,0:04:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada satu di tasnya.
Dialogue: 0,0:04:10.61,0:04:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuambil.
Dialogue: 0,0:04:12.01,0:04:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut.
Dialogue: 0,0:04:13.34,0:04:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:04:15.25,0:04:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kau diam saja di sini\Nbiar tidak mengganggu.
Dialogue: 0,0:04:19.70,0:04:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, jadi dua lawan dua, dong?
Dialogue: 0,0:04:24.01,0:04:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, lanjutnya kapan, nih?
Dialogue: 0,0:04:29.95,0:04:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin dipangku Noren\Ndan dielus kepalanya?
Dialogue: 0,0:04:33.11,0:04:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mimpinya?
Dialogue: 0,0:04:34.78,0:04:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang begitu.
Dialogue: 0,0:04:36.01,0:04:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkat keanehannya makin bertambah.
Dialogue: 0,0:04:41.55,0:04:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini...
Dialogue: 0,0:04:43.21,0:04:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:04:44.78,0:04:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung dibungkus dengan rapi.
Dialogue: 0,0:04:46.58,0:04:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jijik kalau tidak dibungkus.
Dialogue: 0,0:04:48.85,0:04:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kembali.
Dialogue: 0,0:04:52.31,0:04:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, pasti dia punya alasan\Nkenapa memakai dot.
Dialogue: 0,0:04:55.55,0:04:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:56.11,0:04:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu sesuatu?
Dialogue: 0,0:04:57.61,0:04:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:58.45,0:05:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertanya langsung kepadanya.
Dialogue: 0,0:05:00.61,0:05:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Blak-blakan sekali!
Dialogue: 0,0:05:02.05,0:05:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya malah aneh kalau tidak ditanya.
Dialogue: 0,0:05:04.91,0:05:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini membuatku tenang.
Dialogue: 0,0:05:07.55,0:05:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit menjelaskannya.
Dialogue: 0,0:05:10.15,0:05:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku yang sudah tiada...
Dialogue: 0,0:05:12.61,0:05:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat wajahnya yang lembut\Nsaat memberiku dot.
Dialogue: 0,0:05:15.41,0:05:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatanku tidak begitu jelas.
Dialogue: 0,0:05:18.81,0:05:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu alasannya.
Dialogue: 0,0:05:22.91,0:05:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia pernah mengalami masa berat.
Dialogue: 0,0:05:25.41,0:05:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali-kali pangkulah dia.
Dialogue: 0,0:05:27.41,0:05:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak harus dipangku juga, 'kan?
Dialogue: 0,0:05:30.45,0:05:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana pertandingannya?
Dialogue: 0,0:05:35.25,0:05:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:05:36.71,0:05:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, selamat datang.
Dialogue: 0,0:05:38.18,0:05:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tendangan dahsyat Tenma\Nterus dihalau oleh Shin.
Dialogue: 0,0:05:41.62,0:05:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bintangnya hari ini.
Dialogue: 0,0:05:42.99,0:05:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sampai babak belur begitu.
Dialogue: 0,0:05:45.71,0:05:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola diambil!
Dialogue: 0,0:05:48.05,0:05:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat berikan kepadanya!
Dialogue: 0,0:05:50.35,0:05:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:51.02,0:05:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dibiarkan, dia bisa mati!
Dialogue: 0,0:05:53.46,0:05:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bisa mati?\NAku harus bagaimana?
Dialogue: 0,0:05:55.98,0:05:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lempar saja!\NKau sepertinya cukup atletis!
Dialogue: 0,0:05:58.92,0:06:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kenapa harus aku?
Dialogue: 0,0:06:02.01,0:06:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin, ini dot barumu!
Dialogue: 0,0:06:17.35,0:06:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, aku tidak akan berdiam diri lagi.
Dialogue: 0,0:06:20.85,0:06:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang rasa percaya diriku sudah kembali.
Dialogue: 0,0:06:23.81,0:06:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghentikannya!
Dialogue: 0,0:06:24.75,0:06:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Auranya berubah drastis!
Dialogue: 0,0:06:27.31,0:06:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin!
Dialogue: 0,0:06:28.35,0:06:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin.
Dialogue: 0,0:06:29.58,0:06:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:06:31.05,0:06:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan baru dimulai!
Dialogue: 0,0:06:32.71,0:06:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seperti karakter gim pertarungan saja.
Dialogue: 0,0:06:45.81,0:06:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipuannya sederhana, tapi dia cepat.
Dialogue: 0,0:06:49.79,0:06:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, sial!
Dialogue: 0,0:06:57.78,0:06:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa mengubah temponya dalam sekejap.
Dialogue: 0,0:07:01.01,0:07:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan kami belum mencetak gol\Nbukan hanya karena si bayi berdot itu.
Dialogue: 0,0:07:05.18,0:07:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan amatir.
Dialogue: 0,0:07:07.71,0:07:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:07:11.78,0:07:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola keluar!
Dialogue: 0,0:07:13.41,0:07:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, hampir saja!
Dialogue: 0,0:07:16.05,0:07:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:07:17.18,0:07:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permainanmu makin meningkat!
Dialogue: 0,0:07:19.45,0:07:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku termotivasi untuk mengalahkan Tenma.
Dialogue: 0,0:07:23.64,0:07:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi selain itu...
Dialogue: 0,0:07:26.18,0:07:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah lama tidak olahraga,\Nternyata asyik juga.
Dialogue: 0,0:07:29.65,0:07:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:07:30.75,0:07:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sudah lama?
Dialogue: 0,0:07:32.51,0:07:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bicara seperti pak tua.
Dialogue: 0,0:07:34.71,0:07:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gugup.
Dialogue: 0,0:07:36.65,0:07:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan situasi hidup dan mati.
Dialogue: 0,0:07:38.18,0:07:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru rasanya bisa terus mencoba,\Nbelajar dari kesalahan.
Dialogue: 0,0:07:41.51,0:07:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi bersemangat.
Dialogue: 0,0:07:47.25,0:07:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tenma.
Dialogue: 0,0:07:48.91,0:07:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:07:49.98,0:07:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang Ogami itu spesial?
Dialogue: 0,0:07:54.38,0:07:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menganggapnya sebagai rival, ya?
Dialogue: 0,0:07:57.51,0:07:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:07:58.58,0:08:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski genius, kau itu pekerja keras.
Dialogue: 0,0:08:02.35,0:08:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun cabang olahraganya,\Nkau lebih unggul dari yang lain.
Dialogue: 0,0:08:05.55,0:08:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kau pasti ingin punya\Nlawan yang sepadan.
Dialogue: 0,0:08:09.65,0:08:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:08:10.92,0:08:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:11.71,0:08:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya suka mengalahkan orang lain.
Dialogue: 0,0:08:14.18,0:08:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa menang telak, malah lebih bagus.
Dialogue: 0,0:08:16.78,0:08:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku salah paham.
Dialogue: 0,0:08:20.61,0:08:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Tiga Pedang...
Dialogue: 0,0:08:22.41,0:08:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya tidak mau memilih,\Naku memang suka semuanya.
Dialogue: 0,0:08:25.65,0:08:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kata Ryohei, aku ini penyendiri.
Dialogue: 0,0:08:30.31,0:08:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap cabang olahraga pasti\Npunya sosok legendaris, 'kan?
Dialogue: 0,0:08:33.03,0:08:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan selalu\Ndibandingkan dengan sang legenda.
Dialogue: 0,0:08:38.45,0:08:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesal. Bagaimana kalau aku jadi\Nlegenda di tiga cabang sekaligus?
Dialogue: 0,0:08:43.40,0:08:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan setengah-setengah.\NAku akan jadi yang terbaik.
Dialogue: 0,0:08:49.45,0:08:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jago di semua bidang\Nsampai di titik itu, ya.
Dialogue: 0,0:08:53.31,0:08:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia bukan teman masa kecilku,\Nmungkin aku sudah menjauhinya.
Dialogue: 0,0:08:56.58,0:09:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bukan karena aku ingin punya rival.
Dialogue: 0,0:09:00.71,0:09:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, memang ada rasa kesepian\Nsaat menjadi tak tertandingi.
Dialogue: 0,0:09:07.98,0:09:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:09:09.15,0:09:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, boleh juga.
Dialogue: 0,0:09:10.71,0:09:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang mulai menarik.
Dialogue: 0,0:09:13.85,0:09:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ingin menang telak,\Naku tidak suka menindas yang tak berdaya.
Dialogue: 0,0:09:18.15,0:09:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diperlakukan kasar,\Nlawan pun tak akan bisa berkembang.
Dialogue: 0,0:09:25.05,0:09:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, aku akan mulai serius.
Dialogue: 0,0:09:30.01,0:09:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak main-main.
Dialogue: 0,0:09:31.55,0:09:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengatakannya dengan sangat serius.
Dialogue: 0,0:09:39.15,0:09:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang yang salah paham.
Dialogue: 0,0:09:41.38,0:09:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Tenma tidak mengerahkan\Nsemua kemampuannya,
Dialogue: 0,0:09:43.35,0:09:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tidak main-main.
Dialogue: 0,0:09:46.01,0:09:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu memikirkan cara\Nuntuk terus berkembang.
Dialogue: 0,0:09:49.78,0:09:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, dia tidak pernah menahan diri\Nsaat melawan siapa pun.
Dialogue: 0,0:09:54.18,0:09:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dia tak ingin lawannya\Nmenyerah karena kewalahan.
Dialogue: 0,0:09:58.71,0:10:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, dia memberikan batasan\Nuntuk dirinya sendiri.
Dialogue: 0,0:10:03.35,0:10:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya,
Dialogue: 0,0:10:04.65,0:10:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia membatasi dirinya sendiri\Nagar terus bisa berkembang.
Dialogue: 0,0:10:07.78,0:10:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian patut bangga.
Dialogue: 0,0:10:09.38,0:10:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma hampir tidak pernah\Nmelepaskan batasannya.
Dialogue: 0,0:10:22.15,0:10:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia hanya menggiring bola,
Dialogue: 0,0:10:24.75,0:10:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi dia kokoh seperti benteng.
Dialogue: 0,0:10:32.65,0:10:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:10:46.65,0:10:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:10:48.17,0:10:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma mencetak gol!
Dialogue: 0,0:10:50.13,0:10:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang manusia super.
Dialogue: 0,0:10:51.38,0:10:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga orang dilewatinya begitu saja!
Dialogue: 0,0:10:56.15,0:10:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babak pertama telah berakhir!
Dialogue: 0,0:10:58.05,0:11:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tim Tenma memimpin dengan satu poin!
Dialogue: 0,0:11:01.25,0:11:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:11:03.45,0:11:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatnya mau dukung Oga,\Ntetapi malah terbawa suasana.
Dialogue: 0,0:11:07.11,0:11:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasananya jadi sangat meriah.\NAura bintangnya benar-benar terasa!
Dialogue: 0,0:11:13.45,0:11:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bertiga tidak bisa melawannya.\NKita harus bagaimana?
Dialogue: 0,0:11:17.91,0:11:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong biarkan aku menghadapinya sendiri.
Dialogue: 0,0:11:20.95,0:11:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya rencana?
Dialogue: 0,0:11:22.36,0:11:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:11:23.57,0:11:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:23.98,0:11:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, sejak awal\Nakulah yang memulai pertengkaran ini.
Dialogue: 0,0:11:27.38,0:11:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, lupakan saja.
Dialogue: 0,0:11:30.31,0:11:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, biarkan aku melawannya sendirian.
Dialogue: 0,0:11:35.46,0:11:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babak kedua dimulai!
Dialogue: 0,0:11:37.25,0:11:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mampukah Klub Tata Boga melawan?
Dialogue: 0,0:11:40.51,0:11:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:41.55,0:11:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu lawan satu?
Dialogue: 0,0:11:43.35,0:11:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin bisa menang?
Dialogue: 0,0:11:45.51,0:11:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencetak gol kedua.
Dialogue: 0,0:11:51.05,0:11:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melewatinya!
Dialogue: 0,0:11:52.35,0:11:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?!
Dialogue: 0,0:11:53.65,0:11:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?!
Dialogue: 0,0:11:55.25,0:11:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih bisa mengimbangi Tenma\Nyang punya atletisme luar biasa!
Dialogue: 0,0:12:00.11,0:12:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,
Dialogue: 0,0:12:01.58,0:12:03.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami agak...
Dialogue: 0,0:12:04.01,0:12:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatan senang?
Dialogue: 0,0:12:06.65,0:12:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya rencana apa pun.
Dialogue: 0,0:12:09.78,0:12:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya tidak suka kalah.
Dialogue: 0,0:12:13.35,0:12:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun pertandingannya,\Naku akan melawan dengan serius.
Dialogue: 0,0:12:17.65,0:12:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, seiring mendewasa,\Naku kehilangan semangat itu.
Dialogue: 0,0:12:23.01,0:12:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia kerja hanya menuntut\Nhasil yang konsisten.
Dialogue: 0,0:12:26.35,0:12:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan tetapi, makin banyak\Nprestasi yang diraih,
Dialogue: 0,0:12:29.61,0:12:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hidup malah terasa makin membosankan.
Dialogue: 0,0:12:32.98,0:12:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi teringat kembali perasaan ini.
Dialogue: 0,0:12:35.95,0:12:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan ini memang seru sekali!
Dialogue: 0,0:12:39.75,0:12:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya!\NAku sangat menikmati pertandingan ini!
Dialogue: 0,0:12:44.58,0:12:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bicara seperti om-om saja.
Dialogue: 0,0:12:46.71,0:12:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uh.
Dialogue: 0,0:12:47.81,0:12:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan tetapi, aku mengerti.
Dialogue: 0,0:12:49.85,0:12:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan memang seharusnya begini.
Dialogue: 0,0:12:52.31,0:12:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, akulah yang menang!
Dialogue: 0,0:12:57.01,0:12:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pertarungan yang sengit!
Dialogue: 0,0:12:58.55,0:13:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya sama-sama tak mau mengalah!
Dialogue: 0,0:13:02.61,0:13:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sebelumnya,\Nsekadar menjaga saja dia sudah kewalahan.
Dialogue: 0,0:13:06.38,0:13:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal adu stamina, Tenma takkan kalah!
Dialogue: 0,0:13:09.18,0:13:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memprediksinya? Tidak...
Dialogue: 0,0:13:11.18,0:13:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membaca ritme gerakannya.
Dialogue: 0,0:13:13.15,0:13:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam olahraga maupun\Npertarungan hidup-mati
Dialogue: 0,0:13:16.51,0:13:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya ada satu hal yang terpenting.
Dialogue: 0,0:13:18.78,0:13:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa membaca lawan dan menyesuaikan diri.
Dialogue: 0,0:13:30.38,0:13:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan adu tendangan!
Dialogue: 0,0:13:32.18,0:13:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan menang!
Dialogue: 0,0:13:35.01,0:13:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka seimbang?
Dialogue: 0,0:13:37.01,0:13:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Sama sekali tidak imbang
Dialogue: 0,0:13:39.38,0:13:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini pendendam, tahu!
Dialogue: 0,0:13:43.38,0:13:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meremehkan Klub Tata Boga.
Dialogue: 0,0:13:45.41,0:13:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Introspeksi dirimu, dan perbaiki sikapmu.
Dialogue: 0,0:13:47.81,0:13:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan anggap kami sekadar alat.
Dialogue: 0,0:13:50.98,0:13:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus bersyukur karena kami\Nmembuatnya dengan penuh cinta.
Dialogue: 0,0:13:55.55,0:14:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapkan terima kasih yang tulus\Nuntuk nasi kepal buatan kami.
Dialogue: 0,0:14:08.95,0:14:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh!
Dialogue: 0,0:14:10.25,0:14:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:14:13.25,0:14:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:14:14.37,0:14:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membalikkan keadaan!
Dialogue: 0,0:14:15.21,0:14:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub Tata Boga berhasil\Nmenyamakan kedudukan!
Dialogue: 0,0:14:18.67,0:14:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:14:20.02,0:14:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:14:29.11,0:14:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, bagaimana bisa\Nskornya jadi seri begini?
Dialogue: 0,0:14:32.25,0:14:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita balas!
Dialogue: 0,0:14:52.71,0:14:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:14:54.55,0:14:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup.
Dialogue: 0,0:14:56.81,0:14:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyerah.
Dialogue: 0,0:14:58.11,0:14:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah.
Dialogue: 0,0:15:03.81,0:15:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katanya?
Dialogue: 0,0:15:05.11,0:15:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyerah?
Dialogue: 0,0:15:05.98,0:15:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai, dong?
Dialogue: 0,0:15:07.45,0:15:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menyerah?
Dialogue: 0,0:15:09.41,0:15:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:15:11.53,0:15:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku kram mendadak.
Dialogue: 0,0:15:14.85,0:15:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku cedera\Nakibat adu tendangan tadi.
Dialogue: 0,0:15:17.21,0:15:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kulanjutkan, lukanya akan makin parah.
Dialogue: 0,0:15:20.98,0:15:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya meremehkan kalian,
Dialogue: 0,0:15:22.98,0:15:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku hanya ingin bertaruh habis-habisan\Ndi pertandingan sungguhan.
Dialogue: 0,0:15:26.85,0:15:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kesal, aku berhenti di sini.
Dialogue: 0,0:15:29.51,0:15:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kita menang?
Dialogue: 0,0:15:32.55,0:15:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan berakhir!
Dialogue: 0,0:15:34.78,0:15:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:15:35.91,0:15:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma kalah?
Dialogue: 0,0:15:40.33,0:15:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, akhirnya jadi begini.
Dialogue: 0,0:15:44.31,0:15:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi.
Dialogue: 0,0:15:45.75,0:15:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terima kekalahan ini.
Dialogue: 0,0:15:47.55,0:15:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, Ryohei,
Dialogue: 0,0:15:49.11,0:15:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa bantu aku jalan?
Dialogue: 0,0:15:50.81,0:15:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ini sakit sekali.
Dialogue: 0,0:15:52.71,0:15:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Badanmu itu besar dan berat, tahu!
Dialogue: 0,0:15:56.31,0:15:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:15:58.91,0:16:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa kalian punya perban?
Dialogue: 0,0:16:02.21,0:16:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada.
Dialogue: 0,0:16:08.11,0:16:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selonjorkan kakimu.
Dialogue: 0,0:16:09.65,0:16:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan ahlinya, tapi akan lebih parah\Nkalau tidak diobati.
Dialogue: 0,0:16:13.98,0:16:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin.
Dialogue: 0,0:16:16.65,0:16:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Klub Tata Boga?
Dialogue: 0,0:16:19.19,0:16:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Shiraishi.\NShiraishi Chisato.
Dialogue: 0,0:16:21.98,0:16:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan kaus kakimu.
Dialogue: 0,0:16:25.05,0:16:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:26.45,0:16:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih belum meminta maaf kepada kalian.
Dialogue: 0,0:16:30.05,0:16:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini musuh kalian.
Dialogue: 0,0:16:32.39,0:16:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau ini?
Dialogue: 0,0:16:34.85,0:16:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi kepalamu itu hanya\Ntentang kawan dan musuh saja, ya?
Dialogue: 0,0:16:40.25,0:16:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang kesal dengan perkataanmu.
Dialogue: 0,0:16:44.38,0:16:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang pertama bereaksi.
Dialogue: 0,0:16:46.55,0:16:49.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu tidak penting.
Dialogue: 0,0:16:49.21,0:16:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kodrat manusia untuk\Nsaling membantu dalam kesulitan, 'kan?
Dialogue: 0,0:16:54.18,0:16:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai.
Dialogue: 0,0:16:58.95,0:17:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti itulah Klub Tata Boga.
Dialogue: 0,0:17:02.31,0:17:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang...
Dialogue: 0,0:17:04.38,0:17:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski kau sering dicemooh,
Dialogue: 0,0:17:08.18,0:17:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tetap teguh memprioritaskan mimpimu.
Dialogue: 0,0:17:12.10,0:17:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku respek kepadamu.
Dialogue: 0,0:17:14.71,0:17:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami membawa kruk.
Dialogue: 0,0:17:16.51,0:17:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pakai?
Dialogue: 0,0:17:22.31,0:17:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggota Klub Tata Boga.
Dialogue: 0,0:17:24.31,0:17:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sudah berjanji,\Ntapi ini sungguh tulus dari lubuk hatiku.
Dialogue: 0,0:17:29.61,0:17:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah meremehkan kalian.
Dialogue: 0,0:17:32.15,0:17:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasi kepal buatan kalian sangat enak.
Dialogue: 0,0:17:34.51,0:17:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:37.25,0:17:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia bisa jujur juga.\NYah, setiap orang punya sisi baiknya.
Dialogue: 0,0:17:45.98,0:17:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:17:47.38,0:17:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada Ryo juga.
Dialogue: 0,0:17:49.95,0:17:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau mengembalikan buku Ogami.
Dialogue: 0,0:17:53.75,0:17:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling sebentar lagi dia datang.
Dialogue: 0,0:17:55.95,0:17:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:17:57.01,0:17:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Ogami.
Dialogue: 0,0:17:59.15,0:18:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami?
Dialogue: 0,0:18:01.01,0:18:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:18:02.85,0:18:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak hari itu,\Nbanyak klub yang ingin merekrutku.
Dialogue: 0,0:18:08.11,0:18:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja, habisnya kau sangat hebat.
Dialogue: 0,0:18:11.06,0:18:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa hebat.
Dialogue: 0,0:18:13.41,0:18:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:14.61,0:18:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya kebetulan.\NCuma fenomena aneh saja.
Dialogue: 0,0:18:18.65,0:18:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi, Bang?
Dialogue: 0,0:18:20.01,0:18:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jadi pusat perhatian.
Dialogue: 0,0:18:22.65,0:18:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus apa?
Dialogue: 0,0:18:23.98,0:18:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siang.
Dialogue: 0,0:18:27.35,0:18:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:28.41,0:18:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:29.38,0:18:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tendo Tenma?
Dialogue: 0,0:18:31.21,0:18:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah kalian seperti\Nhabis melihat hantu saja.
Dialogue: 0,0:18:34.98,0:18:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga mau bergabung\Ndengan Klub Tata Boga?
Dialogue: 0,0:18:37.95,0:18:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:39.58,0:18:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau setiap hari pakai dot?
Dialogue: 0,0:18:43.01,0:18:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini karena ada urusan.
Dialogue: 0,0:18:45.11,0:18:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya, ada yang ingin kusampaikan
Dialogue: 0,0:18:48.21,0:18:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kepada Chisato.
Dialogue: 0,0:18:54.18,0:18:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:18:55.81,0:18:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacaranlah denganku.
Dialogue: 0,0:19:05.05,0:19:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya jago olahraga.
Dialogue: 0,0:19:07.71,0:19:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku tidak tahu apa-apa.
Dialogue: 0,0:19:10.65,0:19:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyadarinya\Nsetelah berbincang dengan Kak Chisato.
Dialogue: 0,0:19:13.31,0:19:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin selalu bersama Kak Chisato.
Dialogue: 0,0:19:16.95,0:19:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh... eh?
Dialogue: 0,0:19:18.58,0:19:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:19:20.15,0:19:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini...
Dialogue: 0,0:19:21.85,0:19:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum terbiasa dengan hal ini.
Dialogue: 0,0:19:23.21,0:19:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya, aku tidak pandai\Nmenghadapi hal semacam ini.
Dialogue: 0,0:19:25.61,0:19:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu blak-blakan!
Dialogue: 0,0:19:30.05,0:19:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Master?
Dialogue: 0,0:19:31.98,0:19:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau menggoda kakakku.
Dialogue: 0,0:19:37.41,0:19:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau ini siscon?
Dialogue: 0,0:19:40.15,0:19:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kau "Unicorn" atau "Popcorn",\Naku tidak peduli!
Dialogue: 0,0:19:43.15,0:19:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat kau jadi daging cincang!
Dialogue: 0,0:19:45.31,0:19:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenangkan dirimu, Master!
Dialogue: 0,0:19:46.75,0:19:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma, kau kabur dulu sana!
Dialogue: 0,0:19:48.91,0:19:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?\N- Ikuti saja perkataanku!
Dialogue: 0,0:19:50.15,0:19:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master sudah siap berduel denganmu, nih!
Dialogue: 0,0:19:55.55,0:19:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, yang benar saja.
Dialogue: 0,0:19:57.91,0:20:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa, sih, tiba-tiba ke sini?
Dialogue: 0,0:20:01.01,0:20:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguhan, kok.
Dialogue: 0,0:20:03.18,0:20:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sama saja dengan Shin.
Dialogue: 0,0:20:05.45,0:20:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak saat itu, aku jadi\Nincaran klub-klub olahraga.
Dialogue: 0,0:20:08.85,0:20:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa lagi fokus menikmati kelas.
Dialogue: 0,0:20:11.31,0:20:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku cuma ingin\Nbelajar dengan tenang.
Dialogue: 0,0:20:15.51,0:20:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tenang?
Dialogue: 0,0:20:18.18,0:20:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar?
Dialogue: 0,0:20:19.45,0:20:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini si pencari perhatian\Nyang benci belajar, berhentilah berbohong.
Dialogue: 0,0:20:24.25,0:20:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mau bagaimana lagi.
Dialogue: 0,0:20:25.61,0:20:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telanjur terkenal.
Dialogue: 0,0:20:28.45,0:20:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa yang kau sembunyikan,
Dialogue: 0,0:20:30.58,0:20:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kelak rahasiamu pasti akan ketahuan.
Dialogue: 0,0:20:32.75,0:20:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau itu bukan orang biasa.
Dialogue: 0,0:20:35.31,0:20:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang amatir tidak mungkin\Nbisa mengalahkanku.
Dialogue: 0,0:20:40.51,0:20:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan atlet papan atas pun\Nkesulitan mengalahkanku.
Dialogue: 0,0:20:48.95,0:20:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:20:50.61,0:20:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini semua hanya masalah waktu saja.
Dialogue: 0,0:20:55.01,0:20:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:20:57.75,0:21:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masa-masa sekolah ini adalah\Nhal yang sangat berharga bagiku.
Dialogue: 0,0:21:03.31,0:21:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tak tergantikan.
Dialogue: 0,0:21:05.75,0:21:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku ingin\Nmempertahankannya selama mungkin.
Dialogue: 0,0:22:43.35,0:22:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,\Nmungkin sebagai permintaan maaf,
Dialogue: 0,0:22:46.61,0:22:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia membantuku secara tidak langsung.
Dialogue: 0,0:22:49.68,0:22:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berita soal cederanya dibocorkan.
Dialogue: 0,0:22:52.35,0:22:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majalah serta berita olahraga\Njadi penuh dengan topik itu.
Dialogue: 0,0:22:56.85,0:23:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja itu bohong.\NHal yang ingin dia sebarkan adalah:
Dialogue: 0,0:23:00.95,0:23:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ogami Juzo menang karena\NTendo Tenma sedang cedera."
Dialogue: 0,0:23:06.75,0:23:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:23:08.51,0:23:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepopuleranku pun berkurang.
Dialogue: 0,0:23:10.95,0:23:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub olahraga pun\Nberhenti mencoba merekrutku.
Dialogue: 0,0:23:16.25,0:23:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kutanya apa dia akan absen\Ndari Turnamen Musim Panas...
Dialogue: 0,0:23:21.95,0:23:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal bilang saja\Naku sembuh secara ajaib.
Dialogue: 0,0:23:25.78,0:23:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu katanya.
Dialogue: 0,0:23:28.98,0:23:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah, Bang.
Dialogue: 0,0:23:31.03,0:23:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya.
Dialogue: 0,0:23:32.55,0:23:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini masih bisa kita atasi.
