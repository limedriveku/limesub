Dialogue: 0,0:01:45.02,0:01:49.00,tanda,,0000,0000,0000,,URUSI KEKACAUANMU SENDIRI\NSABTU, 25 APRIL
Dialogue: 0,0:02:55.36,0:02:57.86,tanda,,0000,0000,0000,,PERPUSTAKAAN
Dialogue: 0,0:03:49.86,0:03:51.93,tanda,,0000,0000,0000,,MATEMATIKA, SMP KELAS 1
Dialogue: 0,0:04:01.98,0:04:04.26,tanda,,0000,0000,0000,,KUIS MATEMATIKA\NWAKTU PENGERJAAN: 30 MENIT
Dialogue: 0,0:11:20.65,0:11:21.30,tanda,,0000,0000,0000,,KLUB TATA BOGA\NKEGIATAN: MEMASAK, MENJAHIT, DLL.
Dialogue: 0,0:12:44.45,0:12:46.03,tanda,,0000,0000,0000,,RUANG TATA BOGA
Dialogue: 0,0:12:46.03,0:12:46.74,tanda,,0000,0000,0000,,UJI COBA KLUB TATA BOGA\NHASIL MASAKAN BOLEH DIBAWA PULANG
Dialogue: 0,0:13:45.95,0:13:47.54,tanda,,0000,0000,0000,,HASIL MASAKAN BOLEH DIBAWA PULANG
Dialogue: 0,0:16:44.75,0:16:48.62,tanda,,0000,0000,0000,,"FORMULIR PENDAFTARAN KLUB"
Dialogue: 0,0:19:17.05,0:19:19.55,tanda,,0000,0000,0000,,RAMEN NATSUKIYA
Dialogue: 0,0:23:05.94,0:23:08.97,tanda,,0000,0000,0000,,"FORMULIR PENDAFTARAN KLUB"
Dialogue: 0,0:00:01.58,0:00:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, 2 itu koefisien.
Dialogue: 0,0:00:03.91,0:00:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menyatakan bentuk aljabar,\Nkita faktorkan faktor persekutuannya.
Dialogue: 0,0:00:07.25,0:00:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya 2x + 2c,
Dialogue: 0,0:00:08.93,0:00:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- bisa kita keluarkan jadi 2x + c.\N- Eng...
Dialogue: 0,0:00:11.00,0:00:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah contoh sifat distributif.
Dialogue: 0,0:00:13.11,0:00:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lalu, angka 2 ini...\N- Lo?
Dialogue: 0,0:01:50.05,0:01:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:01:51.18,0:01:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kesulitan mengikuti pelajarannya?
Dialogue: 0,0:01:53.98,0:01:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubaca berkali-kali,\Ntetapi tetap tidak paham.
Dialogue: 0,0:01:57.05,0:01:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja kau gelisah.
Dialogue: 0,0:02:00.98,0:02:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:02:02.42,0:02:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau pandai Matematika, tidak?
Dialogue: 0,0:02:03.71,0:02:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak!
Dialogue: 0,0:02:05.40,0:02:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:02:07.05,0:02:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau begitu...
Dialogue: 0,0:02:09.97,0:02:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Belajar?
Dialogue: 0,0:02:12.51,0:02:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau kesulitan memahami\Nperhitungan variabel x dan y?
Dialogue: 0,0:02:17.61,0:02:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolonglah, Eri! Ajari aku!
Dialogue: 0,0:02:20.41,0:02:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:02:21.78,0:02:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar pekerjaan, aku juga sibuk\Nmeneliti caramu kembali dewasa.
Dialogue: 0,0:02:26.51,0:02:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, aku sangat terbantu.
Dialogue: 0,0:02:29.91,0:02:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tolong ajari aku sedikit saja!
Dialogue: 0,0:02:32.01,0:02:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau lumayan cerdas.
Dialogue: 0,0:02:35.71,0:02:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanyakan saja pada gurumu di kelas.
Dialogue: 0,0:02:37.98,0:02:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kan gunanya kelas?
Dialogue: 0,0:02:40.35,0:02:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gurunya masih muda,\Nmasa aku bertanya pada yang lebih muda?
Dialogue: 0,0:02:45.78,0:02:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:02:46.81,0:02:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodo amat! Tidak usah gengsi\Nhanya karena kau lebih tua!
Dialogue: 0,0:02:52.58,0:02:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia menutup teleponnya.
Dialogue: 0,0:02:58.61,0:02:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit.
Dialogue: 0,0:02:59.91,0:03:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti.
Dialogue: 0,0:03:01.35,0:03:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sekarang saja tidak mengerti,\Nke depannya akan makin bingung.
Dialogue: 0,0:03:04.75,0:03:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku akan makin tertinggal!
Dialogue: 0,0:03:09.41,0:03:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana?
Dialogue: 0,0:03:11.45,0:03:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa?
Dialogue: 0,0:03:16.05,0:03:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Ogami, 'kan?
Dialogue: 0,0:03:19.75,0:03:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia teman sekelasku.
Dialogue: 0,0:03:21.95,0:03:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Shiraishi, ya?
Dialogue: 0,0:03:24.41,0:03:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku Shiraishi Ryo.
Dialogue: 0,0:03:27.75,0:03:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:03:29.61,0:03:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya ada di pemahaman\NMatematika dasarmu.
Dialogue: 0,0:03:32.38,0:03:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:33.51,0:03:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau bingung karena belum\Nmenguasai hitungan dasar saat SD.
Dialogue: 0,0:03:39.58,0:03:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku lebih suka bermain.
Dialogue: 0,0:03:44.21,0:03:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku biasa belajar di perpustakaan.
Dialogue: 0,0:03:47.76,0:03:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo belajar bersama!
Dialogue: 0,0:03:49.15,0:03:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:10.95,0:04:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkatmu aku dapat nilai 100!
Dialogue: 0,0:04:13.41,0:04:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:04:14.71,0:04:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu semua hasil kerja kerasmu, kok.
Dialogue: 0,0:04:19.70,0:04:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku senang sekali.
Dialogue: 0,0:04:25.51,0:04:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:04:27.78,0:04:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master!
Dialogue: 0,0:04:29.61,0:04:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master?
Dialogue: 0,0:04:31.05,0:04:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berutang budi banyak padamu.
Dialogue: 0,0:04:33.75,0:04:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya biarkan aku mentraktirmu.
Dialogue: 0,0:04:36.65,0:04:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gayamu seperti om-om saja!
Dialogue: 0,0:04:43.35,0:04:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sebelah sana saja.
Dialogue: 0,0:04:50.51,0:04:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:52.35,0:04:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya gunakan matamu, Bocah!
Dialogue: 0,0:04:55.31,0:04:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo. Sebelah sana kosong.
Dialogue: 0,0:04:57.58,0:04:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak gaya sekali.
Dialogue: 0,0:05:00.11,0:05:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjanya cuma menghamburkan\Nuang orang tua saja.
Dialogue: 0,0:05:02.85,0:05:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak-anak manja. Sial.
Dialogue: 0,0:05:05.65,0:05:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hebat sekali.
Dialogue: 0,0:05:08.35,0:05:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengajariku setiap hari,\Ntetapi tetap belajar lebih giat dariku.
Dialogue: 0,0:05:12.75,0:05:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain rajin, kelihatannya ada\Nhal yang ingin kau capai.
Dialogue: 0,0:05:20.29,0:05:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang teman-teman sekelas, ya.
Dialogue: 0,0:05:23.45,0:05:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku ingin menjadi dokter.
Dialogue: 0,0:05:26.71,0:05:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren!
Dialogue: 0,0:05:27.85,0:05:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kan impian yang hebat!
Dialogue: 0,0:05:29.98,0:05:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi malu.
Dialogue: 0,0:05:33.31,0:05:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kecil, ibuku meninggal karena sakit.
Dialogue: 0,0:05:36.81,0:05:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ayah tidak di rumah,\Nnenek yang merawatku.
Dialogue: 0,0:05:41.71,0:05:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, akhir-akhir ini,\Nkondisi nenek mulai menurun.
Dialogue: 0,0:05:46.38,0:05:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memutuskannya.
Dialogue: 0,0:05:47.98,0:05:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin orang seperti ibu dan nenekku\Nbisa hidup lebih lama.
Dialogue: 0,0:05:52.85,0:05:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku harus menjadi dokter.
Dialogue: 0,0:05:56.98,0:05:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:05:59.94,0:06:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahaguru!
Dialogue: 0,0:06:01.17,0:06:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggilanku naik tingkat?!
Dialogue: 0,0:06:02.55,0:06:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menangis!
Dialogue: 0,0:06:04.25,0:06:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat tersentuh!
Dialogue: 0,0:06:05.95,0:06:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat berbanding terbalik denganku!
Dialogue: 0,0:06:07.81,0:06:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menangis, dong.
Dialogue: 0,0:06:11.65,0:06:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham, kok.
Dialogue: 0,0:06:15.55,0:06:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku yang tak cocok dengan anak-anak ini.
Dialogue: 0,0:06:18.35,0:06:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena selama ini\Naku tidak memperlakukan mereka dengan baik.
Dialogue: 0,0:06:24.41,0:06:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pria yang baik.
Dialogue: 0,0:06:33.21,0:06:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar pembicaraan kalian.
Dialogue: 0,0:06:35.35,0:06:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin menjadi dokter, ya?
Dialogue: 0,0:06:39.21,0:06:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bodoh?
Dialogue: 0,0:06:42.55,0:06:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:43.24,0:06:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemikiranmu sangat naif.
Dialogue: 0,0:06:46.71,0:06:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bacalah lebih banyak data.
Dialogue: 0,0:06:49.18,0:06:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengajak ribut, ya?
Dialogue: 0,0:06:51.65,0:06:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, kita dilarang pakai kekerasan.
Dialogue: 0,0:06:53.95,0:06:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kacamata.
Dialogue: 0,0:06:56.51,0:07:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kelas 1 SMP saja kesulitan belajar,\Nkau bodoh, ya?
Dialogue: 0,0:07:02.35,0:07:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu, masih mencoba belajar?
Dialogue: 0,0:07:04.58,0:07:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah kelihatan makin bodoh!
Dialogue: 0,0:07:08.45,0:07:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh...
Dialogue: 0,0:07:09.75,0:07:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih nasihatnya.
Dialogue: 0,0:07:13.05,0:07:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sudah cukup.
Dialogue: 0,0:07:15.15,0:07:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mencoba membantu kalian.
Dialogue: 0,0:07:18.05,0:07:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapanmu tak ada hubungannya dengan\Nalasanku ingin menjadi dokter.
Dialogue: 0,0:07:23.05,0:07:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun yang kau katakan itu benar,
Dialogue: 0,0:07:25.41,0:07:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak bisa membenarkan orang\Nyang semena-mena merendahkan orang lain.
Dialogue: 0,0:07:31.38,0:07:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi jika dia mengejek temanku\Nyang pekerja keras.
Dialogue: 0,0:07:38.01,0:07:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang...
Dialogue: 0,0:07:38.58,0:07:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa diam, tidak?
Dialogue: 0,0:07:40.25,0:07:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berisik sekali.
Dialogue: 0,0:07:42.18,0:07:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu ikut campur.
Dialogue: 0,0:07:45.28,0:07:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar bodoh.\N- Menjijikkan.
Dialogue: 0,0:07:46.70,0:07:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ini.
Dialogue: 0,0:07:48.35,0:07:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masalah kalian?
Dialogue: 0,0:07:51.57,0:07:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan kalian!
Dialogue: 0,0:07:58.16,0:08:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau berani juga, ya.
Dialogue: 0,0:08:01.52,0:08:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku hanya terbawa emosi.
Dialogue: 0,0:08:04.38,0:08:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak baik.
Dialogue: 0,0:08:06.51,0:08:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:08:09.75,0:08:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bocah!
Dialogue: 0,0:08:11.61,0:08:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berani-beraninya membuatku malu!
Dialogue: 0,0:08:13.85,0:08:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja nanti, akan kubalas!
Dialogue: 0,0:08:17.55,0:08:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutendang saat menyalip!
Dialogue: 0,0:08:19.85,0:08:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia sedang berpikir begitu. Aduh.
Dialogue: 0,0:08:22.91,0:08:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:08:25.65,0:08:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang!
Dialogue: 0,0:08:26.75,0:08:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:08:27.98,0:08:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuberi dia sedikit pelajaran.
Dialogue: 0,0:08:30.85,0:08:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tindakanmu sudah kelewatan.
Dialogue: 0,0:08:40.15,0:08:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana, dinginkan dulu kepalamu.
Dialogue: 0,0:08:42.01,0:08:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sepertimu,
Dialogue: 0,0:08:43.95,0:08:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih belum pantas berhadapan\Nlangsung dengan Master.
Dialogue: 0,0:08:47.41,0:08:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:08:48.58,0:08:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, awas tertinggal.
Dialogue: 0,0:08:51.78,0:08:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laptop itu barang yang berharga.
Dialogue: 0,0:08:54.15,0:08:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut campur kau!
Dialogue: 0,0:08:58.05,0:09:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa yang jatuh itu?
Dialogue: 0,0:09:00.75,0:09:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:09:05.95,0:09:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah peka sedikit.
Dialogue: 0,0:09:07.71,0:09:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu kesepian.
Dialogue: 0,0:09:09.85,0:09:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:09:14.97,0:09:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kozue...
Dialogue: 0,0:09:27.61,0:09:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku.
Dialogue: 0,0:09:42.00,0:09:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi!
Dialogue: 0,0:09:44.35,0:09:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamarmu berantakan sekali, Bang!
Dialogue: 0,0:09:51.11,0:09:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang tamunya juga.
Dialogue: 0,0:09:53.18,0:09:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tidak memanggil\Njasa kebersihan.
Dialogue: 0,0:09:56.35,0:09:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersih-bersih sendirilah!
Dialogue: 0,0:09:58.81,0:10:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah bersih-bersih.
Dialogue: 0,0:10:01.15,0:10:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kan bukan pekerjaan pria.
Dialogue: 0,0:10:05.98,0:10:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, ucapanmu tadi tidak bercanda, 'kan?
Dialogue: 0,0:10:09.85,0:10:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zaman sudah banyak berubah, tahu!
Dialogue: 0,0:10:13.01,0:10:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemikiranmu sangat kolot!
Dialogue: 0,0:10:17.31,0:10:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus sadar diri!
Dialogue: 0,0:10:19.35,0:10:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.
Dialogue: 0,0:10:23.18,0:10:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekskul, ya?
Dialogue: 0,0:10:25.81,0:10:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, minggu ini pendaftaran ekskul dibuka.
Dialogue: 0,0:10:28.51,0:10:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau bergabung ekskul apa?
Dialogue: 0,0:10:30.78,0:10:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya?
Dialogue: 0,0:10:32.01,0:10:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan bukan ekskul olahraga.
Dialogue: 0,0:10:34.65,0:10:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:36.41,0:10:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:10:37.91,0:10:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tolong lemparkan ke sini!
Dialogue: 0,0:10:47.05,0:10:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agh.
Dialogue: 0,0:10:48.41,0:10:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:10:50.21,0:10:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi terlalu mencolok.
Dialogue: 0,0:10:53.78,0:10:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekskul?
Dialogue: 0,0:10:54.85,0:10:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bergabung dengan Klub Kendo.
Dialogue: 0,0:10:59.75,0:11:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah belajar kendo sedikit.
Dialogue: 0,0:11:01.81,0:11:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendalaminya\Nsembari tetap fokus belajar.
Dialogue: 0,0:11:06.61,0:11:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master!
Dialogue: 0,0:11:08.45,0:11:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau?
Dialogue: 0,0:11:09.78,0:11:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan bukan klub olahraga.
Dialogue: 0,0:11:13.35,0:11:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti klub seni, ya.
Dialogue: 0,0:11:15.61,0:11:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak klub seni.
Dialogue: 0,0:11:18.04,0:11:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:11:21.31,0:11:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klub Tata Boga?
Dialogue: 0,0:11:23.05,0:11:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus memasak, menjahit, dan\Npekerjaan rumah tangga lainnya.
Dialogue: 0,0:11:26.98,0:11:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti anggotanya perempuan semua.
Dialogue: 0,0:11:29.11,0:11:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, jaga mulutmu!
Dialogue: 0,0:11:30.58,0:11:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, oi!
Dialogue: 0,0:11:32.31,0:11:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksud ucapanmu barusan, Ogami?
Dialogue: 0,0:11:36.85,0:11:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:11:38.75,0:11:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kakaknya?
Dialogue: 0,0:11:40.95,0:11:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Omong-omong,\Naku ketua Klub Tata Boga.
Dialogue: 0,0:11:45.55,0:11:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikku banyak bercerita tentangmu.
Dialogue: 0,0:11:48.05,0:11:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan-jangan\Nkau ini penjelajah waktu, ya?
Dialogue: 0,0:11:53.01,0:11:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria dan wanita memang berbeda.
Dialogue: 0,0:11:55.81,0:11:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu tidak penting.
Dialogue: 0,0:11:58.05,0:12:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama hidup, kita butuh makan.
Dialogue: 0,0:12:00.75,0:12:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya belajar memasak.
Dialogue: 0,0:12:02.25,0:12:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita menghasilkan sampah.
Dialogue: 0,0:12:03.61,0:12:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya harus bersih-bersih.
Dialogue: 0,0:12:05.35,0:12:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibaratnya seperti belajar cebok sendiri.
Dialogue: 0,0:12:09.81,0:12:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja.
Dialogue: 0,0:12:14.05,0:12:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibarat cebok sendiri?!
Dialogue: 0,0:12:16.58,0:12:17.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu, ya!
Dialogue: 0,0:12:17.55,0:12:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau mengerti juga.
Dialogue: 0,0:12:20.11,0:12:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mandiri walau masih dimanja,\Nitu tidak masalah.
Dialogue: 0,0:12:23.05,0:12:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, kau akan lebih bersyukur.
Dialogue: 0,0:12:26.95,0:12:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:12:28.25,0:12:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini ada sesi uji coba! Kemarilah!
Dialogue: 0,0:12:31.29,0:12:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau wajib ikut!
Dialogue: 0,0:12:33.32,0:12:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku tidak tertarik.
Dialogue: 0,0:12:36.61,0:12:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kupinjamkan Kyo lagi.
Dialogue: 0,0:12:39.11,0:12:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, Master!
Dialogue: 0,0:12:41.21,0:12:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya dia mengancam\Nseorang pembunuh legendaris.
Dialogue: 0,0:12:46.75,0:12:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari mulai sesi uji cobanya.
Dialogue: 0,0:12:49.18,0:12:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi hari ini adalah membuat\Nnasi kepal dan sup miso.
Dialogue: 0,0:12:53.05,0:12:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:12:54.65,0:12:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak juga anggota prianya.
Dialogue: 0,0:12:56.85,0:12:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama.
Dialogue: 0,0:12:58.35,0:13:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini jadinya, mari kita berlomba!
Dialogue: 0,0:13:02.65,0:13:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terasa membosankan, kau menang.
Dialogue: 0,0:13:05.25,0:13:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiahnya, selama enam bulan ke depan,
Dialogue: 0,0:13:08.05,0:13:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memanjakanmu.
Dialogue: 0,0:13:10.58,0:13:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:11.58,0:13:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat serius, ya.
Dialogue: 0,0:13:14.25,0:13:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku kalah?
Dialogue: 0,0:13:17.21,0:13:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bergabung.\NArtinya keasyikanmu akan bertambah, 'kan?
Dialogue: 0,0:13:44.14,0:13:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:13:47.55,0:13:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bungkus saja sisanya untuk di rumah.
Dialogue: 0,0:13:49.85,0:13:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau merasa cocok,\Njangan lupa bergabung dengan klubku, ya.
Dialogue: 0,0:13:54.71,0:13:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan dan kesannya?
Dialogue: 0,0:13:56.58,0:13:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:13:58.61,0:13:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja...
Dialogue: 0,0:14:00.85,0:14:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja.
Dialogue: 0,0:14:02.51,0:14:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang!
Dialogue: 0,0:14:06.34,0:14:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Sayang sekali.
Dialogue: 0,0:14:08.61,0:14:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak membosankan, kok.
Dialogue: 0,0:14:11.81,0:14:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja kita seri.
Dialogue: 0,0:14:13.51,0:14:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, lomba kita belum berakhir.
Dialogue: 0,0:14:17.71,0:14:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya...
Dialogue: 0,0:14:21.45,0:14:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang ini!
Dialogue: 0,0:14:23.58,0:14:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu Abang tidak suka kalah.
Dialogue: 0,0:14:26.70,0:14:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katamu sup misonya enak.
Dialogue: 0,0:14:28.98,0:14:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kau berbohong.
Dialogue: 0,0:14:30.51,0:14:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:14:32.25,0:14:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang enak.
Dialogue: 0,0:14:33.71,0:14:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang enak, tetapi sebatas itu saja.
Dialogue: 0,0:14:36.95,0:14:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:38.75,0:14:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hal menarik\Nyang membuatku ingin bergabung.
Dialogue: 0,0:14:43.91,0:14:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau?
Dialogue: 0,0:14:45.58,0:14:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Maulah.
Dialogue: 0,0:14:48.91,0:14:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jadi.
Dialogue: 0,0:14:52.18,0:14:55.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah ini kau akan diperiksa\Ndi lab, 'kan?
Dialogue: 0,0:15:04.01,0:15:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:15:07.85,0:15:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Ada apa?
Dialogue: 0,0:15:09.71,0:15:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:15:10.98,0:15:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben tiba-tiba mengirim bingkisan.
Dialogue: 0,0:15:12.78,0:15:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada angin apa ini?
Dialogue: 0,0:15:15.15,0:15:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau ikut Klub Tata Boga.\NSangat di luar dugaan.
Dialogue: 0,0:15:19.25,0:15:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik. Aku cuma uji coba saja.
Dialogue: 0,0:15:23.45,0:15:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kozue juga ikut memakannya.
Dialogue: 0,0:15:26.05,0:15:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:27.35,0:15:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, kok.
Dialogue: 0,0:15:30.18,0:15:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:15:32.95,0:15:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kozue, kemarilah.
Dialogue: 0,0:15:34.45,0:15:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kau mau menyapanya.
Dialogue: 0,0:15:38.51,0:15:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanannya enak.
Dialogue: 0,0:15:40.18,0:15:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa.
Dialogue: 0,0:15:41.51,0:15:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:44.81,0:15:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya. Aku berbohong.
Dialogue: 0,0:15:48.25,0:15:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bilang ini semua penting\Ndipelajari demi dirimu sendiri.
Dialogue: 0,0:15:51.95,0:15:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecuali memasak.
Dialogue: 0,0:15:53.85,0:15:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasi kepal dan sup miso ini,
Dialogue: 0,0:15:56.31,0:15:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bawalah pulang untuk orang terdekatmu.
Dialogue: 0,0:16:01.15,0:16:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku...
Dialogue: 0,0:16:02.58,0:16:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasak itu memang penting.
Dialogue: 0,0:16:05.45,0:16:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, memasak lebih menyenangkan\Njika ada yang menikmatinya.
Dialogue: 0,0:16:10.05,0:16:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sup misonya keasinan.
Dialogue: 0,0:16:15.31,0:16:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:17.38,0:16:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:19.51,0:16:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara Papa, kok, agak aneh?
Dialogue: 0,0:16:22.15,0:16:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Papa sedang pilek.
Dialogue: 0,0:16:28.15,0:16:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telepon dari Kak Eri?
Dialogue: 0,0:16:29.71,0:16:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:33.65,0:16:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:16:35.31,0:16:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku kalah.
Dialogue: 0,0:16:44.75,0:16:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besoknya spontan langsung gabung, Bang?
Dialogue: 0,0:16:48.63,0:16:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:50.15,0:16:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada baiknya juga, sifat buruk Abang\Nberubah sedikit demi sedikit.
Dialogue: 0,0:16:52.97,0:16:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja begitu.
Dialogue: 0,0:16:54.05,0:16:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, aku tidak mau!
Dialogue: 0,0:16:58.95,0:17:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:01.45,0:17:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:17:02.95,0:17:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, kau populer, ya.
Dialogue: 0,0:17:05.10,0:17:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:06.10,0:17:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga mau mendaftar?
Dialogue: 0,0:17:08.19,0:17:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:10.21,0:17:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mendaftar juga, Ogami?
Dialogue: 0,0:17:12.34,0:17:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, karena satu dan lain hal.
Dialogue: 0,0:17:14.81,0:17:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mendaftar juga, Mitsuoka?
Dialogue: 0,0:17:16.57,0:17:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih...
Dialogue: 0,0:17:18.18,0:17:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mimpiku membuka kedai ramen.
Dialogue: 0,0:17:21.78,0:17:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat, itu rahasia!
Dialogue: 0,0:17:26.41,0:17:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bersikap sok akrab.
Dialogue: 0,0:17:29.65,0:17:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:17:31.18,0:17:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, ya.
Dialogue: 0,0:17:32.95,0:17:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:17:36.22,0:17:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan dari Kak Eri?
Dialogue: 0,0:17:42.85,0:17:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, ada kabar di luar dugaan.
Dialogue: 0,0:17:45.11,0:17:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:17:46.61,0:17:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan cara untuk\Nmembuatmu kembali dewasa.
Dialogue: 0,0:17:48.91,0:17:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja?
Dialogue: 0,0:17:50.21,0:17:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan baik-baik, ya.
Dialogue: 0,0:17:53.38,0:17:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikahlah dengan Mitsuoka Noren.
Dialogue: 0,0:17:58.01,0:17:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:17:59.95,0:18:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mendengarkan, tidak?
Dialogue: 0,0:18:00.95,0:18:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengar, kok.
Dialogue: 0,0:18:02.98,0:18:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:18:04.58,0:18:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya mau bahas caraku kembali dewasa!
Dialogue: 0,0:18:07.65,0:18:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru saja ada berita dari Farmasi Mitsuoka.
Dialogue: 0,0:18:12.51,0:18:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkait tunangan Mitsuoka Noren.
Dialogue: 0,0:18:14.61,0:18:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya akan dijadikan ahli waris.
Dialogue: 0,0:18:16.61,0:18:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:17.65,0:18:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa mereka membuat pengumuman itu?
Dialogue: 0,0:18:21.38,0:18:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan sebenarnya tidak diketahui.
Dialogue: 0,0:18:23.18,0:18:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berita itu yang ingin kusampaikan.
Dialogue: 0,0:18:26.81,0:18:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, apa kau ingat\Nucapan para penculik waktu itu?
Dialogue: 0,0:18:30.98,0:18:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau tidak tahu detailnya,
Dialogue: 0,0:18:33.25,0:18:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau tahu sesuatu.
Dialogue: 0,0:18:36.75,0:18:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak informan\Nyang membicarakan hal yang sama.
Dialogue: 0,0:18:41.98,0:18:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekerasan atau cara licik\Ntidak akan berhasil.
Dialogue: 0,0:18:47.61,0:18:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya cara adalah\Nmenjadi bagian dari perusahaan itu.
Dialogue: 0,0:18:49.85,0:18:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudahnya, jadilah tunangan Mitsuoka Noren.
Dialogue: 0,0:18:53.75,0:18:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga misi, Bang!
Dialogue: 0,0:18:56.45,0:18:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin!
Dialogue: 0,0:18:57.45,0:19:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa pria tua bertunangan\Ndengan anak remaja!
Dialogue: 0,0:19:01.65,0:19:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja nyatakan cinta padanya.
Dialogue: 0,0:19:04.41,0:19:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diterima, kau akan jadi ahli waris\NFarmasi Mitsuoka, lo.
Dialogue: 0,0:19:08.38,0:19:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti di drama televisi saja, ya.
Dialogue: 0,0:19:10.65,0:19:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menantu orang kaya, terdengar enak.
Dialogue: 0,0:19:12.31,0:19:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sepertinya itu memang mustahil.
Dialogue: 0,0:19:14.45,0:19:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tak perlu bahas rencana itu lagi.
Dialogue: 0,0:19:22.33,0:19:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:19:23.58,0:19:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramen di sini memang tidak ada tandingan.
Dialogue: 0,0:19:27.05,0:19:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya aku disuruh bertunangan?
Dialogue: 0,0:19:28.31,0:19:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin pria tua sepertiku bisa.
Dialogue: 0,0:19:30.58,0:19:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pupus sudah harapan kembali menjadi dewasa.
Dialogue: 0,0:19:34.18,0:19:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, terjadilah apa yang harus terjadi.
Dialogue: 0,0:19:39.51,0:19:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:40.67,0:19:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:19:42.78,0:19:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak berubah, ya, Ogami.
Dialogue: 0,0:19:45.45,0:19:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:19:46.21,0:19:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku turut prihatin.
Dialogue: 0,0:19:49.18,0:19:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti banyak yang mengganggumu.
Dialogue: 0,0:19:52.58,0:19:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sih, hanya ingin makan ramen.
Dialogue: 0,0:19:58.31,0:20:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren, sudah waktunya kau pulang.
Dialogue: 0,0:20:01.18,0:20:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:03.78,0:20:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar kesal.
Dialogue: 0,0:20:05.45,0:20:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sih, isi pikiran ayahmu?
Dialogue: 0,0:20:08.18,0:20:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu! Dia juga jarang pulang!
Dialogue: 0,0:20:10.98,0:20:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga malas bertemu dengannya.
Dialogue: 0,0:20:14.65,0:20:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tidak jelas!
Dialogue: 0,0:20:17.55,0:20:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:20:19.71,0:20:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, eh... kau malah tidak dengarkan!
Dialogue: 0,0:20:23.75,0:20:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku turut prihatin.
Dialogue: 0,0:20:26.65,0:20:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang ajak mengobrol, dengarkan, dong!
Dialogue: 0,0:20:29.95,0:20:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengarkan, kok.
Dialogue: 0,0:20:31.45,0:20:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku turut prihatin.
Dialogue: 0,0:20:32.69,0:20:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi kesal!
Dialogue: 0,0:20:33.47,0:20:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kelas Bahasa Inggris besok...
Dialogue: 0,0:20:35.38,0:20:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak peduli!
Dialogue: 0,0:20:43.81,0:20:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengobrol seperti ini asyik juga.
Dialogue: 0,0:20:46.65,0:20:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik sekali.
Dialogue: 0,0:20:48.71,0:20:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengobrol santai bersama teman\Nitu seru juga, ya.
Dialogue: 0,0:20:55.25,0:20:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di klub, mungkin bisa, ya.\NMengobrol santai seperti ini.
Dialogue: 0,0:20:59.58,0:21:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya, bisa saja.
Dialogue: 0,0:21:02.31,0:21:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami, maksudku bukan dirimu, ya.
Dialogue: 0,0:22:38.95,0:22:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya ekskul!
Dialogue: 0,0:22:41.45,0:22:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:22:42.55,0:22:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bisa mandiri!
Dialogue: 0,0:22:46.35,0:22:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura macam apa ini?
Dialogue: 0,0:22:49.15,0:22:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:22:49.98,0:22:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak?
Dialogue: 0,0:22:50.95,0:22:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, ya. Sedang ada kegaduhan.
Dialogue: 0,0:22:56.35,0:22:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendadak banyak yang datang mendaftar.
Dialogue: 0,0:22:59.75,0:23:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya ingin dekat dengan Noren.
Dialogue: 0,0:23:01.98,0:23:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga gabung Klub Tata Boga?\NKebetulan sekali!
Dialogue: 0,0:23:05.15,0:23:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan sekali bohongnya!
Dialogue: 0,0:23:05.94,0:23:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga suka tata boga!
Dialogue: 0,0:23:08.98,0:23:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya apa?
Dialogue: 0,0:23:12.95,0:23:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tama, bisa panggilkan guru, tidak?
Dialogue: 0,0:23:22.25,0:23:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:23:26.85,0:23:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya pengumuman!
Dialogue: 0,0:23:29.01,0:23:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah punya pacar.
Dialogue: 0,0:23:32.95,0:23:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan pacarku, Ogami Juzo!
