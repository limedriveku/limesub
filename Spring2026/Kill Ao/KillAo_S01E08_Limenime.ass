Dialogue: 0,0:00:55.05,0:00:59.03,sign,,0000,0000,0000,,MELAWAN RINDO BERSAUDARA\NSABTU, 30 MEI
Dialogue: 0,0:03:05.56,0:03:08.79,sign,,0000,0000,0000,,BAGAIMANA MAKAN MALAMNYA?\NKAU MAKAN DI SANA DENGAN TEMAN-TEMANMU?
Dialogue: 0,0:08:47.31,0:08:48.54,sign,,0000,0000,0000,,TENDO TENMA
Dialogue: 0,0:00:00.71,0:00:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogami Juzo, anggota Z.O.O,\Norganisasi peringkat ketiga
Dialogue: 0,0:00:05.01,0:00:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dunia sindikat.
Dialogue: 0,0:00:07.15,0:00:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh bayaran nomor satu\Nyang tiba-tiba menghilang tanpa jejak.
Dialogue: 0,0:00:12.71,0:00:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkat keberhasilan misinya sempurna.
Dialogue: 0,0:00:15.31,0:00:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dia tak menerima
Dialogue: 0,0:00:17.04,0:00:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pekerjaan yang menargetkan wanita,\Nanak-anak, atau warga sipil.
Dialogue: 0,0:00:20.81,0:00:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokok favoritnya Blue Apple,\Nwiski favoritnya Laphroaig.
Dialogue: 0,0:00:28.25,0:00:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan tembak, bela diri, teknik pisau,\Ndan tempurnya semua kelas satu.
Dialogue: 0,0:00:33.21,0:00:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pistol favoritnya P210.
Dialogue: 0,0:00:36.15,0:00:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambidekster. Tangan kirinya\Nsangat akurat saat memakai pistol.
Dialogue: 0,0:00:40.18,0:00:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia punya julukan...
Dialogue: 0,0:00:42.21,0:00:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tangan Kiri Iblis".
Dialogue: 0,0:00:46.85,0:00:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:00:53.51,0:00:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal sedikit lagi.
Dialogue: 0,0:02:37.75,0:02:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang berakhir di sini saja?
Dialogue: 0,0:02:41.25,0:02:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudah sekali.
Dialogue: 0,0:02:55.51,0:02:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menghubungi keluarganya?
Dialogue: 0,0:02:57.85,0:03:00.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya belum ada izin\Ndari pihak berwenang.
Dialogue: 0,0:03:02.85,0:03:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa?\N- Tidak tahu.
Dialogue: 0,0:03:09.95,0:03:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bertiga harus pulang\Ndengan selamat, ya.
Dialogue: 0,0:03:18.91,0:03:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan kuhajar.
Dialogue: 0,0:03:24.15,0:03:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih.
Dialogue: 0,0:03:24.95,0:03:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakan yang bagus.
Dialogue: 0,0:03:26.31,0:03:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau adu tembak biasa,\Npeluangku cukup buruk.
Dialogue: 0,0:03:35.81,0:03:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:03:37.51,0:03:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amunisi sudah kuamankan.\NTerima kasih, Nekota.
Dialogue: 0,0:03:42.05,0:03:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terluka?
Dialogue: 0,0:03:43.85,0:03:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satpam?
Dialogue: 0,0:03:45.55,0:03:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini tutup hari ini.\NKau masuk dari mana?
Dialogue: 0,0:03:49.05,0:03:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, begitu.
Dialogue: 0,0:03:50.58,0:03:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak ledakan misterius di sini.
Dialogue: 0,0:03:53.25,0:03:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini berbahaya, segera pulang sana.
Dialogue: 0,0:03:55.75,0:03:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:03:56.55,0:03:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sengaja memancing orang ke sini?
Dialogue: 0,0:03:59.98,0:04:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti! Ada warga sipil di sini!
Dialogue: 0,0:04:02.48,0:04:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kau yang peduli soal itu.
Dialogue: 0,0:04:05.55,0:04:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada hubungannya denganku.
Dialogue: 0,0:04:07.81,0:04:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau menghindar, satpam itu yang kena.
Dialogue: 0,0:04:11.45,0:04:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar licik, bajingan.
Dialogue: 0,0:04:16.91,0:04:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:23.71,0:04:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menembak jatuh peluru dengan peluru.
Dialogue: 0,0:04:25.98,0:04:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil.
Dialogue: 0,0:04:27.11,0:04:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia biasa takkan bisa melakukannya.
Dialogue: 0,0:04:31.31,0:04:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.\NSekarang aku mengerti.
Dialogue: 0,0:04:33.65,0:04:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mitsuoka Noren dan resep rahasia\NFarmasi Mitsuoka...
Dialogue: 0,0:04:38.18,0:04:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa aneh karena namamu\Nsama dengan pembunuh bayaran itu.
Dialogue: 0,0:04:42.41,0:04:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi selisih usianya jauh,\Nkukira cuma kebetulan.
Dialogue: 0,0:04:45.81,0:04:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kalian dua orang berbeda.
Dialogue: 0,0:04:47.78,0:04:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang semuanya masuk akal.
Dialogue: 0,0:04:51.01,0:04:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini Ogami Juzo yang asli.
Dialogue: 0,0:04:53.71,0:04:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan?
Dialogue: 0,0:04:55.01,0:04:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, sudah kubilang\Nlebih baik pakai nama samaran.
Dialogue: 0,0:04:59.78,0:05:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku tahu bakal jadi begini.
Dialogue: 0,0:05:03.38,0:05:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas awalnya kan cuma menyusup ke SMP.
Dialogue: 0,0:05:05.61,0:05:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sih gampang.
Dialogue: 0,0:05:09.11,0:05:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:05:11.05,0:05:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang ada hubungan dengan Ogami Juzo,
Dialogue: 0,0:05:15.15,0:05:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku bukan pembunuh legendaris.
Dialogue: 0,0:05:19.11,0:05:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini...
Dialogue: 0,0:05:19.79,0:05:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istriku tidak ada di rumah hari ini.
Dialogue: 0,0:05:21.55,0:05:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini...
Dialogue: 0,0:05:22.45,0:05:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar nakal.
Dialogue: 0,0:05:23.71,0:05:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku anak haram Ogami Juzo.
Dialogue: 0,0:05:26.61,0:05:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, kau mengarang apa?
Dialogue: 0,0:05:28.41,0:05:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan balik ke Tokyo.\NKalian jaga diri, ya.
Dialogue: 0,0:05:32.01,0:05:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar nakal.
Dialogue: 0,0:05:32.98,0:05:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku, yang cuma selingkuhan,
Dialogue: 0,0:05:35.46,0:05:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditinggalkan begitu saja\Ndemi wanita yang lebih muda.
Dialogue: 0,0:05:39.58,0:05:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah akan balas dendam padanya.
Dialogue: 0,0:05:41.41,0:05:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku pakai nama yang sama\Ndan pilih jalan yang sama dengannya.
Dialogue: 0,0:05:45.31,0:05:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu saat kelak kami bertemu,\Naku akan berkata padanya...
Dialogue: 0,0:05:51.78,0:05:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau meninggalkan kami?
Dialogue: 0,0:05:55.31,0:05:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritamu terlalu dipaksakan, Pak Tua!
Dialogue: 0,0:06:00.25,0:06:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:06:02.05,0:06:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.
Dialogue: 0,0:06:03.51,0:06:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengalami banyak kesulitan, ya.
Dialogue: 0,0:06:06.35,0:06:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taktiknya berhasil?
Dialogue: 0,0:06:07.41,0:06:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.
Dialogue: 0,0:06:08.58,0:06:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan dunia gelap seperti kita\Nmemang penuh penderitaan.
Dialogue: 0,0:06:12.41,0:06:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini penuh dengan sampah.
Dialogue: 0,0:06:16.35,0:06:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang, kau dibilang sampah.
Dialogue: 0,0:06:18.75,0:06:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kau sangat ingin membunuh ayahmu.
Dialogue: 0,0:06:21.55,0:06:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:23.05,0:06:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua pun, banyak yang sudah terjadi.
Dialogue: 0,0:06:26.25,0:06:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu adikku, Eiji,\Ntidak sependiam sekarang.
Dialogue: 0,0:06:30.38,0:06:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu bisa disebut pendiam?
Dialogue: 0,0:06:34.45,0:06:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh sebelum insiden itu terjadi...
Dialogue: 0,0:06:37.38,0:06:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka sulap,
Dialogue: 0,0:06:39.81,0:06:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adikku suka olahraga.
Dialogue: 0,0:06:41.85,0:06:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanyalah kakak beradik biasa.
Dialogue: 0,0:06:47.61,0:06:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lihat, tidak?
Dialogue: 0,0:06:49.61,0:06:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dong. Hebat juga.
Dialogue: 0,0:06:54.31,0:06:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku terbawa suasana.
Dialogue: 0,0:06:55.95,0:06:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membicarakan masa lalu\Ntidak akan menyelesaikan apa-apa.
Dialogue: 0,0:07:00.38,0:07:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, Eiji adalah\Nyang terpenting bagiku di dunia ini.
Dialogue: 0,0:07:06.31,0:07:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren akan menjadi bagian\Ndari kebahagiaannya.
Dialogue: 0,0:07:10.85,0:07:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Resep rahasia Farmasi Mitsuoka mungkin\Nbisa mengembalikan Eiji seperti semula.
Dialogue: 0,0:07:16.25,0:07:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sama-sama punya alasan tersendiri.
Dialogue: 0,0:07:18.98,0:07:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak bisa kalah.
Dialogue: 0,0:07:23.35,0:07:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek?
Dialogue: 0,0:07:24.65,0:07:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, keahlianku adalah hipnosis.
Dialogue: 0,0:07:28.45,0:07:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah senjata andalanku yang sebenarnya.
Dialogue: 0,0:07:41.19,0:07:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih, jadi begitu.
Dialogue: 0,0:07:43.18,0:07:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Munculnya satpam yang sangat kebetulan ini
Dialogue: 0,0:07:46.11,0:07:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua karena hipnosis darinya.
Dialogue: 0,0:07:48.35,0:07:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:07:55.85,0:07:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang agak mengejutkan.
Dialogue: 0,0:07:57.85,0:07:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma itu kemampuanmu?
Dialogue: 0,0:07:59.41,0:08:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu warga bukanlah apa-apa.
Dialogue: 0,0:08:03.21,0:08:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu? Jangan berasumsi.
Dialogue: 0,0:08:05.58,0:08:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kira cuma itu korban hipnosisku?
Dialogue: 0,0:08:09.81,0:08:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau salah paham.
Dialogue: 0,0:08:10.91,0:08:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memprediksi banyak hal.
Dialogue: 0,0:08:15.21,0:08:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyiapkan segalanya.
Dialogue: 0,0:08:20.21,0:08:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh-jauh hari.
Dialogue: 0,0:08:28.75,0:08:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:08:48.78,0:08:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Ogami. Kau di mana?
Dialogue: 0,0:08:50.90,0:08:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Aku terlalu ceroboh.\NCepat kabur!
Dialogue: 0,0:08:53.65,0:08:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauhi kerumunan warga sipil.
Dialogue: 0,0:08:55.91,0:08:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dikendalikan hipnosis.
Dialogue: 0,0:08:57.77,0:08:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, mengerti.
Dialogue: 0,0:08:59.98,0:09:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai banget.\NHei, kau benar-benar paham, tidak?
Dialogue: 0,0:09:03.01,0:09:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham, kok.
Dialogue: 0,0:09:05.01,0:09:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari pukulan bola golf tadi,\Nsudah jelas ini bukan hal biasa.
Dialogue: 0,0:09:09.21,0:09:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tahu bisa mati.
Dialogue: 0,0:09:12.65,0:09:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak akan lari.
Dialogue: 0,0:09:15.55,0:09:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan atlet.
Dialogue: 0,0:09:18.25,0:09:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di semua cabang olahraga,
Dialogue: 0,0:09:19.98,0:09:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para atlet pada dasarnya\Nmempertaruhkan nyawa dengan caranya.
Dialogue: 0,0:09:25.45,0:09:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpiku itu menjadi Tiga Pedang, tahu.
Dialogue: 0,0:09:29.31,0:09:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertaruh nyawa sekali, dua kali,\Ntiga kali itu wajar saja, 'kan?
Dialogue: 0,0:09:34.98,0:09:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian sana kuserahkan padamu.
Dialogue: 0,0:09:37.85,0:09:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:09:39.15,0:09:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang berisiko,
Dialogue: 0,0:09:40.55,0:09:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini adalah kesempatan.
Dialogue: 0,0:09:42.78,0:09:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuanku adalah menjadi Tiga Pedang.
Dialogue: 0,0:09:45.95,0:09:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hal yang luar biasa.
Dialogue: 0,0:09:48.45,0:09:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mencapainya, aku sudah berusaha\Nsebaik mungkin dengan cara paling efisien.
Dialogue: 0,0:09:55.75,0:09:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teori dan segala macamnya.
Dialogue: 0,0:09:58.01,0:10:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin aku sudah di jalan yang benar.
Dialogue: 0,0:10:01.78,0:10:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untuk meraih hal luar biasa,\Ndibutuhkan hal yang luar biasa pula.
Dialogue: 0,0:10:09.11,0:10:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah kesempatan.
Dialogue: 0,0:10:11.01,0:10:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku bisa melewati\Nduel hidup dan mati ini,
Dialogue: 0,0:10:13.55,0:10:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti bisa menghadapi apa pun.
Dialogue: 0,0:10:18.21,0:10:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bilang,\N"Ini bukan apa-apa."
Dialogue: 0,0:10:21.21,0:10:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti bisa.
Dialogue: 0,0:10:22.85,0:10:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menjadi Tiga Pedang.
Dialogue: 0,0:10:41.15,0:10:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, raksasa penuh tambalan.
Dialogue: 0,0:10:44.31,0:10:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo olahraga.
Dialogue: 0,0:11:21.31,0:11:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berisik.
Dialogue: 0,0:11:30.84,0:11:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku mulai sekarang.
Dialogue: 0,0:11:47.01,0:11:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, seram.
Dialogue: 0,0:11:48.98,0:11:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang penjahat.
Dialogue: 0,0:11:51.38,0:11:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi nekat banget,\Nbom itu dipukul balik begitu saja.
Dialogue: 0,0:11:56.61,0:11:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:02.91,0:12:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dari belakang?
Dialogue: 0,0:12:04.41,0:12:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, ada yang namanya backspin.
Dialogue: 0,0:12:13.75,0:12:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:12:15.03,0:12:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stik golfnya berubah.
Dialogue: 0,0:12:16.98,0:12:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:12:17.84,0:12:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa selengkap itu?
Dialogue: 0,0:12:18.91,0:12:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan?
Dialogue: 0,0:12:28.20,0:12:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:12:32.55,0:12:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga.
Dialogue: 0,0:12:33.61,0:12:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengendalikan bola sesuka hati\Ndengan akurasi tinggi.
Dialogue: 0,0:12:39.31,0:12:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:12:57.07,0:12:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:13:07.31,0:13:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:13:13.21,0:13:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah mereka terlalu banyak.
Dialogue: 0,0:13:14.65,0:13:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir pada Tenma,\Ntapi terlalu banyak yang mengejarku.
Dialogue: 0,0:13:18.13,0:13:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, yang penting kabur dulu!
Dialogue: 0,0:13:32.35,0:13:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial. Kacau balau.
Dialogue: 0,0:13:41.35,0:13:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sudah ada yang lapor polisi.
Dialogue: 0,0:13:43.38,0:13:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja, kita membuat kegaduhan.
Dialogue: 0,0:13:45.65,0:13:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:13:48.98,0:13:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang aneh.
Dialogue: 0,0:13:51.41,0:13:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:52.15,0:13:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita diserang!
Dialogue: 0,0:13:55.71,0:13:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pakai tandu seperti itu!
Dialogue: 0,0:13:58.55,0:13:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyalakan airnya!
Dialogue: 0,0:14:01.15,0:14:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang!
Dialogue: 0,0:14:02.25,0:14:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa, malah aku terbantu.
Dialogue: 0,0:14:08.45,0:14:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kupinjam?
Dialogue: 0,0:14:12.85,0:14:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:14:17.05,0:14:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung bukan musim dingin.
Dialogue: 0,0:14:20.15,0:14:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang dingin, tapi tak apa,\Nbiar kalian bangun.
Dialogue: 0,0:14:34.78,0:14:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, sekarang sudah aman.
Dialogue: 0,0:14:37.91,0:14:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berhasil, Bang.
Dialogue: 0,0:14:41.75,0:14:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak!
Dialogue: 0,0:14:42.61,0:14:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang kau pegang itu?
Dialogue: 0,0:14:44.91,0:14:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pistol bohongan, kok.
Dialogue: 0,0:14:46.51,0:14:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airsoft gun.
Dialogue: 0,0:14:48.58,0:14:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Kakak ada di sini?
Dialogue: 0,0:14:50.98,0:14:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir.
Dialogue: 0,0:14:52.81,0:14:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa di sini?\NTempat ini hancur berantakan.
Dialogue: 0,0:14:56.85,0:14:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa. Coba lihat ini.
Dialogue: 0,0:15:04.65,0:15:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam tiga hitungan.
Dialogue: 0,0:15:06.11,0:15:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kau dengar suara korek api ditutup,
Dialogue: 0,0:15:09.21,0:15:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak akan bisa menyerang\NRindo Kazuma maupun Rindo Eiji.
Dialogue: 0,0:15:14.63,0:15:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga.
Dialogue: 0,0:15:16.71,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua.
Dialogue: 0,0:15:17.95,0:15:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu.
Dialogue: 0,0:15:25.25,0:15:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini Rindo Kazuma, ya?
Dialogue: 0,0:15:28.91,0:15:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga jago menyamar.
Dialogue: 0,0:15:31.41,0:15:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kau terlambat menyadarinya.
Dialogue: 0,0:15:35.78,0:15:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya Abang lengah.
Dialogue: 0,0:15:38.95,0:15:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak biasanya.
Dialogue: 0,0:15:41.21,0:15:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini normal.
Dialogue: 0,0:15:43.91,0:15:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang memang seperti itu.
Dialogue: 0,0:15:45.65,0:15:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang tidak akan kalah melawan penjahat,
Dialogue: 0,0:15:48.78,0:15:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia tidak bisa melawan warga sipil.
Dialogue: 0,0:15:50.85,0:15:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terlihat dingin,\Ndia bukan orang kejam.
Dialogue: 0,0:15:52.78,0:15:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu baik untuk seorang pembunuh.
Dialogue: 0,0:15:57.51,0:16:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, dia bahkan mulai\Nmenyukai teman-teman sekelasnya.
Dialogue: 0,0:16:00.75,0:16:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebaikannya itu dimanfaatkan\Nhabis-habisan oleh Rindo Kazuma.
Dialogue: 0,0:16:09.58,0:16:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hipnosisnya berhasil.
Dialogue: 0,0:16:11.55,0:16:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar tak bisa menembaknya.
Dialogue: 0,0:16:13.25,0:16:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang.
Dialogue: 0,0:16:14.61,0:16:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin pengamannya belum dilepas?
Dialogue: 0,0:16:17.58,0:16:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin. Jangan asal bicara.
Dialogue: 0,0:16:30.95,0:16:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh.
Dialogue: 0,0:16:38.78,0:16:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih bisa menembak ke arah lain.
Dialogue: 0,0:16:43.55,0:16:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang kena peluru nyasar,\Nbukan salahku, lo.
Dialogue: 0,0:16:50.58,0:16:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi.
Dialogue: 0,0:16:52.11,0:16:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja ini kekurangan.
Dialogue: 0,0:16:53.58,0:16:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutunjukkan pentingnya jam terbang.
Dialogue: 0,0:17:05.10,0:17:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sembunyi?
Dialogue: 0,0:17:06.71,0:17:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hasilnya tetap sama.
Dialogue: 0,0:17:09.31,0:17:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku bisa menghipnosisnya,\Naku tak bisa menghentikannya.
Dialogue: 0,0:17:13.84,0:17:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan menembaknya menyebalkan.
Dialogue: 0,0:17:16.91,0:17:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba satu trik lagi\Ndan lihat reaksinya.
Dialogue: 0,0:17:25.25,0:17:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar kau, Ogami.
Dialogue: 0,0:17:27.10,0:17:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, anak haram.
Dialogue: 0,0:17:30.01,0:17:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sengaja kubuat begitu.
Dialogue: 0,0:17:33.61,0:17:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa lihat ini, 'kan?\NTunjukkan dirimu di hitungan ketiga.
Dialogue: 0,0:17:37.58,0:17:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak ingin warga sipil terlibat, 'kan?
Dialogue: 0,0:17:41.61,0:17:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada warga sipil yang dikendalikan?
Dialogue: 0,0:17:44.55,0:17:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sandera yang dia pilih itu...
Dialogue: 0,0:17:46.81,0:17:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kalian bertukar peran?
Dialogue: 0,0:17:50.58,0:17:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu, ketemu.
Dialogue: 0,0:17:53.01,0:17:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana rupanya.\NLempar pistolmu.
Dialogue: 0,0:17:58.85,0:18:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kau ingin mendengar jeritannya?
Dialogue: 0,0:18:01.95,0:18:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong...
Dialogue: 0,0:18:09.58,0:18:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampun.
Dialogue: 0,0:18:10.75,0:18:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melenceng dari sasaran,\Napa kau sudah putus asa?
Dialogue: 0,0:18:16.65,0:18:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:18:18.31,0:18:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kata-kata terakhir?
Dialogue: 0,0:18:21.78,0:18:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali, memang ada.
Dialogue: 0,0:18:25.51,0:18:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti menyamar jadi kakak.
Dialogue: 0,0:18:32.81,0:18:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:18:38.18,0:18:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah puas?
Dialogue: 0,0:18:40.61,0:18:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:18:41.95,0:18:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, syukurlah. Terima kasih.
Dialogue: 0,0:18:44.71,0:18:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tahu itu palsu, tidak enak\Nkalau harus memukul wajah kakak.
Dialogue: 0,0:18:50.05,0:18:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:51.51,0:18:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah.
Dialogue: 0,0:19:00.71,0:19:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakan jitu?\NAda teman lainnya?
Dialogue: 0,0:19:02.61,0:19:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, pelurunya datang dari atas.
Dialogue: 0,0:19:05.18,0:19:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:19:06.35,0:19:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakan asal tadi?
Dialogue: 0,0:19:11.98,0:19:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah merencanakannya?
Dialogue: 0,0:19:13.98,0:19:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang memang bukan manusia biasa.
Dialogue: 0,0:19:16.51,0:19:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iseng belajar taktik ini\Nsaat latihan dulu.
Dialogue: 0,0:19:20.31,0:19:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tidak semudah menembak biasa.
Dialogue: 0,0:19:23.35,0:19:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkat akurasinya hanya sekitar 70 persen.
Dialogue: 0,0:19:26.01,0:19:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang memang bukan manusia biasa.
Dialogue: 0,0:19:28.01,0:19:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kuulangi.
Dialogue: 0,0:19:29.51,0:19:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Targetnya tandu itu.
Dialogue: 0,0:19:31.18,0:19:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutembakkan tiga peluru,\Nsetidaknya satu pasti kena.
Dialogue: 0,0:19:34.91,0:19:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di bagian bawah tandu\Nada sakelar detonator.
Dialogue: 0,0:19:38.31,0:19:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana ada alat pembuka kunci\Ndan bom kecil. Ternyata berguna.
Dialogue: 0,0:19:43.15,0:19:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat sembunyi tadi, kau sudah\Nsiapkan bom dan pemicunya, 'kan?
Dialogue: 0,0:19:47.01,0:19:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:48.40,0:19:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu apa yang akan terjadi?
Dialogue: 0,0:19:50.45,0:19:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja.
Dialogue: 0,0:19:52.61,0:19:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau gumamkan dari tadi?
Dialogue: 0,0:20:00.01,0:20:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini sedang apa?
Dialogue: 0,0:20:02.45,0:20:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang di awal.\NAku akan menghajarmu.
Dialogue: 0,0:20:05.35,0:20:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maunya sih kulakukan secara langsung,
Dialogue: 0,0:20:08.61,0:20:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ya sudahlah.
Dialogue: 0,0:20:10.21,0:20:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini kau, biar kuhajar.
Dialogue: 0,0:22:14.25,0:22:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar!
Dialogue: 0,0:22:16.09,0:22:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa dipercaya.
Dialogue: 0,0:22:17.81,0:22:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau menembakkan peluru itu ke langit,
Dialogue: 0,0:22:20.05,0:22:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tahu hasilnya akan seperti ini?
Dialogue: 0,0:22:22.15,0:22:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih.
Dialogue: 0,0:22:24.98,0:22:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, bidik dulu tandunya.
Dialogue: 0,0:22:27.71,0:22:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu baru kususun rencana lainnya.
Dialogue: 0,0:22:32.45,0:22:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memikirkannya dengan detail.
Dialogue: 0,0:22:37.41,0:22:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal saja. Asal saja.
Dialogue: 0,0:22:39.91,0:22:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan orang ini?
Dialogue: 0,0:22:42.18,0:22:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma piawai.
Dialogue: 0,0:22:44.78,0:22:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengalaman, kekuatan, dan pengetahuannya\Nbenar-benar di level berbeda.
Dialogue: 0,0:22:53.73,0:22:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sudah terlambat.
Dialogue: 0,0:22:55.73,0:22:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:56.91,0:23:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menghipnosis Mitsuoka Noren.
Dialogue: 0,0:23:01.11,0:23:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dia sadar nanti, dia akan jatuh cinta\Npada hal pertama yang dilihatnya.
Dialogue: 0,0:23:07.55,0:23:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:23:08.91,0:23:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekeras apa pun kau berjuang,
Dialogue: 0,0:23:11.11,0:23:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nasib Noren
Dialogue: 0,0:23:13.71,0:23:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan tetap sama.
Dialogue: 0,0:23:21.58,0:23:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenma, tolong tetap hidup!
Dialogue: 0,0:23:33.18,0:23:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noren.
Dialogue: 0,0:23:34.81,0:23:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bangun dulu!
