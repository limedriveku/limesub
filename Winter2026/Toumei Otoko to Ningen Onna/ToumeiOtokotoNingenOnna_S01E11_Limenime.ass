Dialogue: 0,0:00:12.49,0:00:14.74,tanda,,0000,0000,0000,,EPISODE 11: DESA ORANG TAK KASATMATA
Dialogue: 0,0:01:17.84,0:01:22.84,tanda,,0000,0000,0000,,THE INVISIBLE MAN\NAND HIS SOON-TO-BE WIFE
Dialogue: 0,0:03:57.80,0:03:58.82,tanda,,0000,0000,0000,,TONOME
Dialogue: 0,0:15:03.57,0:15:05.57,tanda,,0000,0000,0000,,MENGEKSPRESIKAN DIRI
Dialogue: 0,0:18:05.93,0:18:07.43,tanda,,0000,0000,0000,,STASIUN SHINJUKU
Dialogue: 0,0:00:01.27,0:00:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka merasa lebih nyaman\Nsaat tak terlihat sama sekali.
Dialogue: 0,0:00:06.48,0:00:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:00:07.99,0:00:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak bisa bilang aku suka\Nsemua orang tak terlihat sama sekali.
Dialogue: 0,0:00:25.90,0:00:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhentian berikutnya adalah\NPasar Blok Ketiga. Pasar Blok Ketiga.
Dialogue: 0,0:00:35.53,0:00:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira?
Dialogue: 0,0:00:38.35,0:00:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa?
Dialogue: 0,0:00:40.03,0:00:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:00:42.26,0:00:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh minta maaf\Nkarena harus transit berkali-kali.
Dialogue: 0,0:00:44.81,0:00:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampung halamanku ada di pedesaan.
Dialogue: 0,0:00:47.05,0:00:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir! Aku sangat bersemangat\Nmengunjungi desa orang tak kasatmata!
Dialogue: 0,0:00:51.31,0:00:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya pedesaan biasa.\NHanya ada ladang di sana.
Dialogue: 0,0:00:55.13,0:00:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasinya juga cukup terpencil.
Dialogue: 0,0:00:56.49,0:00:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benarkah?
Dialogue: 0,0:00:59.18,0:01:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini bukan desa biasa.
Dialogue: 0,0:01:01.79,0:01:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan desa biasa?
Dialogue: 0,0:02:40.31,0:02:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udaranya sangat segar!
Dialogue: 0,0:02:42.69,0:02:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, inilah ketenangan alam.
Dialogue: 0,0:02:53.42,0:02:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasar desa.
Dialogue: 0,0:02:55.48,0:02:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:02:58.13,0:03:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, di sini cukup ramai.\NApakah semuanya penduduk setempat?
Dialogue: 0,0:03:05.51,0:03:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa merasakan ada banyak orang.
Dialogue: 0,0:03:07.23,0:03:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengamatanmu tajam, Shizuka.
Dialogue: 0,0:03:10.24,0:03:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa ini wilayah ekstrateritorial.\NLegal untuk tak terlihat sepenuhnya di sini.
Dialogue: 0,0:03:15.81,0:03:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang tak kasatmata di sini\Nmemilih untuk tak terlihat sama sekali.
Dialogue: 0,0:03:21.24,0:03:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja.
Dialogue: 0,0:03:23.07,0:03:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, anehkah jika orang tak kasatmata\Nsama sekali tak terlihat?
Dialogue: 0,0:03:28.27,0:03:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sebagian orang pasti terkejut,
Dialogue: 0,0:03:30.66,0:03:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bagimu ini hal biasa.
Dialogue: 0,0:03:33.22,0:03:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmm...
Dialogue: 0,0:03:35.24,0:03:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, rumahku ada di depan.
Dialogue: 0,0:03:37.13,0:03:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Awawa!
Dialogue: 0,0:03:39.52,0:03:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizuka, kau tidak apa-apa?
Dialogue: 0,0:03:41.27,0:03:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku gugup sekali...
Dialogue: 0,0:03:43.81,0:03:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti perasaanmu,
Dialogue: 0,0:03:45.44,0:03:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau pasti bisa, Shizuka.
Dialogue: 0,0:03:47.59,0:03:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Y-Ya! Aku akan berusaha!
Dialogue: 0,0:03:51.56,0:03:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:03:53.04,0:03:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:03:54.50,0:03:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aki?
Dialogue: 0,0:03:58.82,0:03:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:04:19.07,0:04:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizuka, di sebelah kirimu ada ayahku,\Ndan di sebelah kanan ada ibuku.
Dialogue: 0,0:04:24.04,0:04:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepi sekali...
Dialogue: 0,0:04:27.16,0:04:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira memang sangat pendiam,\Ntapi ini jauh lebih sepi.
Dialogue: 0,0:04:31.86,0:04:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan merasakan tekanan\Ndari keheningan ini...
Dialogue: 0,0:04:35.67,0:04:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:36.82,0:04:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh! Em...
Dialogue: 0,0:04:38.50,0:04:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Shizuka Yako!
Dialogue: 0,0:04:40.59,0:04:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira selalu menjagaku\Ndengan sangat baik!
Dialogue: 0,0:04:43.06,0:04:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em...
Dialogue: 0,0:04:44.69,0:04:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:04:45.34,0:04:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu dengan kalian!
Dialogue: 0,0:04:48.76,0:04:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:49.85,0:04:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih karena selalu menjaga Akira.
Dialogue: 0,0:04:52.74,0:04:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya sangat datar...
Dialogue: 0,0:04:55.30,0:04:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka tak tertarik padaku...
Dialogue: 0,0:04:58.85,0:05:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang harus kulakukan, Akira?!
Dialogue: 0,0:05:01.11,0:05:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang berpacaran.\NKami berencana tinggal bersama.
Dialogue: 0,0:05:04.94,0:05:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?! Langsung bahas itu?!
Dialogue: 0,0:05:07.55,0:05:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa tak masalah.
Dialogue: 0,0:05:10.11,0:05:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tak masalah.
Dialogue: 0,0:05:12.17,0:05:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula...
Dialogue: 0,0:05:13.64,0:05:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak tadi aku ingin bertanya,
Dialogue: 0,0:05:16.53,0:05:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kalian pakai topeng aneh itu?
Dialogue: 0,0:05:19.54,0:05:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:20.54,0:05:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topeng?
Dialogue: 0,0:05:23.83,0:05:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang akan membawa seseorang\Ndari ras yang berbeda.
Dialogue: 0,0:05:26.79,0:05:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pikir lebih baik jika kami punya wajah.
Dialogue: 0,0:05:29.80,0:05:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizuka tunanetra.\NKalian tak perlu melakukannya.
Dialogue: 0,0:05:32.80,0:05:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga.
Dialogue: 0,0:05:34.86,0:05:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau benar.
Dialogue: 0,0:05:36.20,0:05:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku sudah bilang.
Dialogue: 0,0:05:38.63,0:05:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak berpikir sejauh itu.
Dialogue: 0,0:05:40.30,0:05:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kami tak memikirkannya.
Dialogue: 0,0:05:42.45,0:05:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kurasa tak ada masalah.
Dialogue: 0,0:05:45.56,0:05:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia tak keberatan\Njika kami tak terlihat sama sekali?
Dialogue: 0,0:05:48.82,0:05:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tak apa-apa.
Dialogue: 0,0:05:50.04,0:05:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:50.77,0:05:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sepertinya mereka merasa lebih nyaman\Nsaat tak terlihat sama sekali.
Dialogue: 0,0:05:54.65,0:05:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, semua orang tak kasatmata juga begitu.
Dialogue: 0,0:05:57.90,0:06:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benarkah?
Dialogue: 0,0:06:00.75,0:06:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak terlihat sepenuhnya\Nadalah wujud asli kami.
Dialogue: 0,0:06:11.66,0:06:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nselanjutnya kuperkenalkan ke Nenek.
Dialogue: 0,0:06:14.46,0:06:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakinya kurang sehat, jadi dia ada di kamar.
Dialogue: 0,0:06:23.35,0:06:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... tak bisa bilang aku suka\Nsemua orang tak terlihat sama sekali.
Dialogue: 0,0:06:31.66,0:06:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu kau ingin bajumu\Ndilihat orang lain, 'kan?
Dialogue: 0,0:06:37.92,0:06:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku beri tahu hal yang kusuka\Ndari setelan ini nanti?
Dialogue: 0,0:06:42.00,0:06:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, beri tahu aku nanti.
Dialogue: 0,0:06:46.79,0:06:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek, kami masuk, ya.
Dialogue: 0,0:06:49.32,0:06:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuklah.
Dialogue: 0,0:06:50.65,0:06:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:06:51.68,0:06:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek, Shizuka tak bisa...
Dialogue: 0,0:06:53.61,0:06:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em, aku sudah meminta\Nmereka memberitahumu...
Dialogue: 0,0:06:56.82,0:06:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:07:00.40,0:07:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga kami mengabdi pada bangsawan\Nsebagai ninja di era Keshogunan!
Dialogue: 0,0:07:08.44,0:07:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph!
Dialogue: 0,0:07:09.94,0:07:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ninja!
Dialogue: 0,0:07:11.46,0:07:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Ninja?! I-Itu luar biasa!
Dialogue: 0,0:07:14.09,0:07:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha! Kau bahkan bisa\Nmenemukan shuriken di gudang!
Dialogue: 0,0:07:18.18,0:07:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apakah kau bisa memakai teknik ninja?!
Dialogue: 0,0:07:21.10,0:07:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi orang luar, kemampuan tak kasatmata\Nkami persis seperti teknik ninja!
Dialogue: 0,0:07:27.27,0:07:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:07:28.21,0:07:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi shuriken dan senjata lainnya\Ntak bisa diubah menjadi tak terlihat,
Dialogue: 0,0:07:32.24,0:07:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi penggunaannya butuh usaha!
Dialogue: 0,0:07:34.23,0:07:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat menarik!
Dialogue: 0,0:07:36.36,0:07:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat bersemangat.
Dialogue: 0,0:07:38.02,0:07:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira.
Dialogue: 0,0:07:46.18,0:07:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei. Lama tak bertemu, Aki.
Dialogue: 0,0:07:48.97,0:07:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiriguro! Kau pulang kampung?
Dialogue: 0,0:07:51.79,0:07:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa bilang begitu padamu.
Dialogue: 0,0:07:53.62,0:07:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh, kau sudah jadi pria dewasa sekarang.
Dialogue: 0,0:07:58.20,0:08:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir kali kita bertemu,\Naku masih sekolah.
Dialogue: 0,0:08:00.62,0:08:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau hanya bocah nakal.
Dialogue: 0,0:08:03.34,0:08:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir tak mengenalimu\Ndengan setelan itu.
Dialogue: 0,0:08:06.31,0:08:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau tahu ini\Naku dari setelannya saja?
Dialogue: 0,0:08:11.70,0:08:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran siapa dia.
Dialogue: 0,0:08:15.60,0:08:18.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Masashi Kiriguro.
Dialogue: 0,0:08:18.10,0:08:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau ingat saat kuceritakan
Dialogue: 0,0:08:21.40,0:08:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal orang tak kasatmata\Npertama yang jadi model fesyen.
Dialogue: 0,0:08:23.98,0:08:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia orangnya!
Dialogue: 0,0:08:25.61,0:08:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau ceritakan padanya tentangku?
Dialogue: 0,0:08:29.08,0:08:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya cerita lama.
Dialogue: 0,0:08:30.78,0:08:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berhenti jadi model.\NSekarang aku mengelola restoran Italia ini.
Dialogue: 0,0:08:34.40,0:08:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh, itu sangat mengejutkan.
Dialogue: 0,0:08:36.10,0:08:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kubuka restoran pagi ini,\Nkupikir itu kau, Aki.
Dialogue: 0,0:08:40.03,0:08:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau bisa mengenaliku?\NKita tak bertemu selama 10 tahun.
Dialogue: 0,0:08:43.75,0:08:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang ada orang di sini\Nyang mau menampakkan diri.
Dialogue: 0,0:08:47.26,0:08:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Firasatku bilang itu pasti kau.
Dialogue: 0,0:08:50.87,0:08:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia, silakan dinikmati.
Dialogue: 0,0:08:53.17,0:08:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Aromanya harum!
Dialogue: 0,0:08:55.83,0:08:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:57.38,0:08:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengenaliku, Aki?
Dialogue: 0,0:08:59.46,0:09:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum punya tato ini\Nsaat terakhir kali kita bertemu.
Dialogue: 0,0:09:02.31,0:09:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu hanya dengan melihatnya.
Dialogue: 0,0:09:04.24,0:09:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, kau menggambar pola itu\Ndi wajahmu dengan pena.
Dialogue: 0,0:09:09.33,0:09:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, benar. Aku tak berubah sedikit pun.
Dialogue: 0,0:09:14.84,0:09:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hal itu menyelamatkanku\Nsaat masih kecil.
Dialogue: 0,0:09:18.61,0:09:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:19.41,0:09:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku ingat! Kau menangis karena\Ntak bisa membedakan siapa saja di sini.
Dialogue: 0,0:09:24.80,0:09:27.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan sebut-sebut soal itu!
Dialogue: 0,0:09:30.12,0:09:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menangis?
Dialogue: 0,0:09:32.34,0:09:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tumbuh di lingkungan ras lain.
Dialogue: 0,0:09:37.58,0:09:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masih kecil,\Nketika aku datang ke desa ini...
Dialogue: 0,0:09:40.90,0:09:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau sendirian?
Dialogue: 0,0:09:42.02,0:09:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini. Aku punya permen!
Dialogue: 0,0:09:44.13,0:09:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget karena\Ntak ada satu pun yang terlihat.
Dialogue: 0,0:09:52.64,0:09:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku bertemu Kiriguro,\Nyang menggambar wajahnya.
Dialogue: 0,0:09:57.01,0:09:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau datang dari kota, 'kan?
Dialogue: 0,0:10:08.71,0:10:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membatin,\Nkenapa dia main Halloween sendirian?
Dialogue: 0,0:10:12.45,0:10:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau mau menangis?
Dialogue: 0,0:10:14.92,0:10:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, dia aneh sekali.
Dialogue: 0,0:10:17.50,0:10:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku merasa tenang saat bersamanya.
Dialogue: 0,0:10:21.46,0:10:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir lagi,\Naku dulu menggambar banyak hal di wajahku.
Dialogue: 0,0:10:26.34,0:10:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sempat masuk dunia modeling.\NMasa depan memang tak bisa ditebak.
Dialogue: 0,0:10:29.38,0:10:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, dia tampil\Nsebagai model tak kasatmata pertama
Dialogue: 0,0:10:32.64,0:10:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di suatu peragaan busana.
Dialogue: 0,0:10:34.26,0:10:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kedengarannya hebat!
Dialogue: 0,0:10:37.25,0:10:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu,\Norang-orang mengira orang tak kasatmata
Dialogue: 0,0:10:39.66,0:10:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya akan mengambil\Npekerjaan di balik layar
Dialogue: 0,0:10:41.76,0:10:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau tetap tinggal dan\Nbekerja di desa mereka.
Dialogue: 0,0:10:45.14,0:10:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin pergi ke kota.
Dialogue: 0,0:10:48.47,0:10:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengemas satu tas
Dialogue: 0,0:10:50.58,0:10:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu pergi ke kota.
Dialogue: 0,0:11:03.03,0:11:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Kau model tak kasatmata pertama
Dialogue: 0,0:11:06.08,0:11:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang pernah kulihat.
Dialogue: 0,0:11:07.46,0:11:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bagus untuk memamerkan\Nbagian dalam pakaian,
Dialogue: 0,0:11:10.50,0:11:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kupikir ide ini cukup menarik.
Dialogue: 0,0:11:12.73,0:11:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:11:13.96,0:11:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya sesaat.
Dialogue: 0,0:11:15.97,0:11:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir ide ini hanya menarik sesaat.
Dialogue: 0,0:11:21.63,0:11:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, asal tak terlihat,\Norang tak kasatmata mana pun bisa.
Dialogue: 0,0:11:29.05,0:11:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus kau?
Dialogue: 0,0:11:35.52,0:11:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Aku gagal audisi lagi!
Dialogue: 0,0:11:38.33,0:11:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus kau?
Dialogue: 0,0:11:40.27,0:11:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus aku?
Dialogue: 0,0:11:42.73,0:11:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:11:44.51,0:11:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Apa? Apa aku mengenaimu?
Dialogue: 0,0:11:47.66,0:11:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gulung lengan bajumu! Itu bahaya!
Dialogue: 0,0:11:55.39,0:11:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau benar.
Dialogue: 0,0:11:57.95,0:11:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus hari ini!
Dialogue: 0,0:11:59.43,0:12:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa besok.
Dialogue: 0,0:12:01.38,0:12:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, asal tak terlihat,\Norang tak kasatmata mana pun bisa.
Dialogue: 0,0:12:05.67,0:12:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gulung lengan bajumu! Itu bahaya!
Dialogue: 0,0:12:08.75,0:12:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja seluruh warga desa\Nmenentang keputusanku pergi ke kota.
Dialogue: 0,0:12:12.82,0:12:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota terlalu keras bagi kami\Nsi orang tak kasatmata.
Dialogue: 0,0:12:34.63,0:12:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kemampuanmu hanya tak terlihat,\Ntak harus kau orangnya!
Dialogue: 0,0:12:38.43,0:12:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melihatmu,\Njadi aku tak tahu apa yang kau pikirkan!
Dialogue: 0,0:12:44.41,0:12:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lari!
Dialogue: 0,0:12:47.19,0:12:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri yang mau datang ke sini!
Dialogue: 0,0:12:50.50,0:12:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kau bisa hidup damai di desa!
Dialogue: 0,0:12:54.15,0:12:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini salahmu sendiri\Nkarena datang kemari!
Dialogue: 0,0:13:23.19,0:13:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:13:38.89,0:13:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ugh...
Dialogue: 0,0:13:40.79,0:13:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badanku hancur rasanya.
Dialogue: 0,0:13:42.58,0:13:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, hari ini ada audisi.
Dialogue: 0,0:13:45.89,0:13:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus buru-buru.
Dialogue: 0,0:13:48.92,0:13:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:50.17,0:13:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa-apaan ini?!
Dialogue: 0,0:13:53.83,0:13:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Sial! Aku harus ikut audisi sekarang!
Dialogue: 0,0:14:02.13,0:14:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:14:04.73,0:14:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku minta maaf datang\Naudisi dengan penampilan seperti ini.
Dialogue: 0,0:14:10.67,0:14:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:14:11.94,0:14:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau menggagalkanku, lakukan saja!
Dialogue: 0,0:14:14.80,0:14:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:14:16.02,0:14:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat menarik.
Dialogue: 0,0:14:17.34,0:14:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:18.07,0:14:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh, maksud Anda, hanya untuk sesaat?
Dialogue: 0,0:14:21.57,0:14:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kau sangat menarik. Kau diterima.
Dialogue: 0,0:14:33.03,0:14:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tato kerangka di kulitnya
Dialogue: 0,0:14:35.48,0:14:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan cat tubuh yang sesuai\Ndengan desain pakaian,
Dialogue: 0,0:14:39.34,0:14:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka bilang polanya\Nseperti keluar dari pakaian.
Dialogue: 0,0:14:42.76,0:14:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:14:44.94,0:14:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmm... Aku sama sekali\Ntak bisa membayangkannya.
Dialogue: 0,0:14:47.89,0:14:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polanya sangat mencolok. Aku dipanggil\Nuntuk tampil di banyak peragaan.
Dialogue: 0,0:14:51.89,0:14:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami, kaum tak kasatmata,\Nselalu dianggap sama karena tak terlihat.
Dialogue: 0,0:14:55.58,0:15:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dipikir-pikir, cat tubuh dan\Ntato ini adalah caraku berekspresi.
Dialogue: 0,0:15:05.99,0:15:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah satu-satunya caraku\Nmengekspresikan diri.
Dialogue: 0,0:15:11.19,0:15:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengekspresikan diri...
Dialogue: 0,0:15:19.32,0:15:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mirip sekali.
Dialogue: 0,0:15:23.95,0:15:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em, apa warga desa tak kesulitan\Njika semuanya tak terlihat?
Dialogue: 0,0:15:29.64,0:15:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tak kasatmata memiliki organ
Dialogue: 0,0:15:30.96,0:15:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memungkinkan mereka merasakan kaumnya.
Dialogue: 0,0:15:34.05,0:15:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa merasakan hawa\Nkeberadaan satu sama lain
Dialogue: 0,0:15:37.16,0:15:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membedakan individu.
Dialogue: 0,0:15:39.30,0:15:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagi kaum tak kasatmata\Nyang tumbuh di kota sepertiku,
Dialogue: 0,0:15:42.96,0:15:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}organ itu cenderung kurang berkembang.
Dialogue: 0,0:15:47.07,0:15:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belajar membedakan\Norang-orang dari suara dan aroma
Dialogue: 0,0:15:52.58,0:15:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat masih SD.
Dialogue: 0,0:15:54.19,0:15:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ema, itu kau?
Dialogue: 0,0:15:56.43,0:15:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Tahu dari mana?
Dialogue: 0,0:15:58.47,0:16:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya orang lain tak bisa melakukannya.
Dialogue: 0,0:16:00.95,0:16:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuat mereka cukup kaget.
Dialogue: 0,0:16:02.94,0:16:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham.\NTubuh kita beradaptasi dengan lingkungan.
Dialogue: 0,0:16:06.81,0:16:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tumbuh bersama ras lain yang terlihat.
Dialogue: 0,0:16:09.88,0:16:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku belajar membedakan orang,
Dialogue: 0,0:16:13.18,0:16:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan karena sengaja berusaha,
Dialogue: 0,0:16:15.51,0:16:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau karena orang lain membantuku,
Dialogue: 0,0:16:18.31,0:16:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi karena aku hidup sebagai tunanetra.
Dialogue: 0,0:16:22.30,0:16:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membedakannya karena terpaksa.
Dialogue: 0,0:16:25.46,0:16:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat memahaminya.
Dialogue: 0,0:16:27.56,0:16:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:16:29.26,0:16:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu juga,\Naku sangat bersyukur bisa mengenalmu.
Dialogue: 0,0:16:36.85,0:16:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian berdua, cari kamar sana.
Dialogue: 0,0:16:40.23,0:16:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pamit dulu.
Dialogue: 0,0:16:41.15,0:16:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:16:42.69,0:16:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aki, mampirlah ke restoranku sesekali.
Dialogue: 0,0:16:44.91,0:16:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sampai jumpa.
Dialogue: 0,0:16:53.89,0:16:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak prasangka terhadap kaum tak kasatmata
Dialogue: 0,0:16:55.40,0:16:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berdasarkan terlihat atau tidaknya kami.
Dialogue: 0,0:16:58.35,0:17:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dihargai karena tak terlihat,
Dialogue: 0,0:17:00.36,0:17:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dicurigai karena tak terlihat,
Dialogue: 0,0:17:02.36,0:17:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditakuti,
Dialogue: 0,0:17:03.85,0:17:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diabaikan.
Dialogue: 0,0:17:06.28,0:17:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku yakin semua itu\Ntak penting bagi Shizuka.
Dialogue: 0,0:17:18.14,0:17:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizuka.
Dialogue: 0,0:17:19.35,0:17:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:17:22.78,0:17:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur bisa bertemu denganmu.
Dialogue: 0,0:17:25.18,0:17:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau blak-blakan sekali.
Dialogue: 0,0:17:27.77,0:17:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang kurasakan di hatiku saat ini.
Dialogue: 0,0:17:30.38,0:17:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu saja begitu blak-blakan.
Dialogue: 0,0:17:33.02,0:17:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tak kasatmata, emosiku\Nhanya bisa diungkapkan lewat kata-kata.
Dialogue: 0,0:17:39.17,0:17:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:17:45.30,0:17:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungku berdebar sangat\Nkencang saat kau melakukannya.
Dialogue: 0,0:17:50.22,0:17:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap tutur kata dan tindakan kecilmu
Dialogue: 0,0:17:53.79,0:17:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga membuat jantungku berdebar kencang.
Dialogue: 0,0:17:55.17,0:17:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bohong...
Dialogue: 0,0:17:59.53,0:18:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bohong.
Dialogue: 0,0:18:12.24,0:18:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya sampai juga.
Dialogue: 0,0:18:13.94,0:18:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:18:16.29,0:18:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fu!
Dialogue: 0,0:18:17.81,0:18:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kau bilang kalau mau datang.\NAda apa?
Dialogue: 0,0:18:23.43,0:18:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana Tonome?
Dialogue: 0,0:18:24.78,0:18:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak mengantarmu pulang sepulang kerja?
Dialogue: 0,0:18:27.28,0:18:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira masih bekerja!
Dialogue: 0,0:18:30.02,0:18:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detektif tak punya jam kerja pasti!
Dialogue: 0,0:18:32.70,0:18:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah...
Dialogue: 0,0:18:34.21,0:18:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku lapar nih.
Dialogue: 0,0:18:35.85,0:18:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa aku ke tempat makan enak.
Dialogue: 0,0:18:37.62,0:18:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Gajianku kan baru minggu depan...
Dialogue: 0,0:18:43.42,0:18:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah memberiku uang saku\Nmakan malam 10.000 yen.
Dialogue: 0,0:18:46.08,0:18:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik, ayo pergi!
Dialogue: 0,0:18:47.42,0:18:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyimpan beberapa\Nrestoran di aplikasi navigasiku.
Dialogue: 0,0:18:55.09,0:18:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:57.72,0:19:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Ada apa?
Dialogue: 0,0:19:00.60,0:19:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pria tak kasatmata berjas. Itu Tonome?
Dialogue: 0,0:19:04.34,0:19:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Akira ada di dekat sini?!
Dialogue: 0,0:19:06.56,0:19:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupastikan itu dia atau bukan.
Dialogue: 0,0:19:08.35,0:19:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Dipastikan?
Dialogue: 0,0:19:13.82,0:19:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegang ini.
Dialogue: 0,0:19:20.28,0:19:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonome!
Dialogue: 0,0:19:23.41,0:19:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:19:27.83,0:19:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:19:28.82,0:19:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau sudah kembali.
Dialogue: 0,0:19:30.30,0:19:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Benar itu Akira?
Dialogue: 0,0:19:32.25,0:19:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonome itu tukang selingkuh.
Dialogue: 0,0:19:35.30,0:19:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita labrak dia.
Dialogue: 0,0:19:36.50,0:19:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau ini?
Dialogue: 0,0:19:39.08,0:19:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja, mau membuntuti Akira?
Dialogue: 0,0:19:42.19,0:19:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu detektif. Dia akan sadar dibuntuti.
Dialogue: 0,0:19:44.26,0:19:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang main gila di belakangmu.
Dialogue: 0,0:19:46.13,0:19:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melabraknya bagaimanapun caranya.
Dialogue: 0,0:19:47.89,0:19:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\Nini sudah masuk penipuan pernikahan.
Dialogue: 0,0:19:50.10,0:19:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, Akira tak mungkin melakukan hal itu.
Dialogue: 0,0:19:54.31,0:19:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktimu belum cukup untuk\Nbilang kalau dia selingkuh.
Dialogue: 0,0:19:58.83,0:20:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, dia memberinya cincin. Sudah pasti.
Dialogue: 0,0:20:01.81,0:20:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh. Astaga. Kau amatir sekali, Fu.
Dialogue: 0,0:20:06.62,0:20:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kan bekerja di agensi detektif!
Dialogue: 0,0:20:10.86,0:20:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga amatir. Kau kan bukan detektif.
Dialogue: 0,0:20:13.57,0:20:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah. Mereka masuk ke sebuah gedung.
Dialogue: 0,0:20:25.37,0:20:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau gugup?
Dialogue: 0,0:20:26.58,0:20:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sangat.
Dialogue: 0,0:20:31.30,0:20:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:32.21,0:20:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Ah!
Dialogue: 0,0:20:36.97,0:20:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fu, kau di mana?! Jangan tinggalkan aku!
Dialogue: 0,0:20:40.60,0:20:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kaca? Jendela?
Dialogue: 0,0:20:42.26,0:20:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fu! Ayolah!
Dialogue: 0,0:21:01.49,0:21:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizuka, sebelah sini.
Dialogue: 0,0:21:04.24,0:21:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:21:05.75,0:21:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Akira?
Dialogue: 0,0:21:13.99,0:21:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:21:16.55,0:21:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa.
Dialogue: 0,0:21:17.50,0:21:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em... Eh...
Dialogue: 0,0:21:20.06,0:21:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K-Kebetulan sekali.
Dialogue: 0,0:21:22.21,0:21:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, tapi aku sedang bekerja.
Dialogue: 0,0:21:25.50,0:21:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kita bahas nanti?
Dialogue: 0,0:21:28.73,0:21:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja?
Dialogue: 0,0:21:34.97,0:21:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em, maaf sudah mengganggu...
Dialogue: 0,0:21:38.03,0:21:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K-Kakak!
Dialogue: 0,0:21:39.26,0:21:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:21:43.27,0:21:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama mencarimu!
Dialogue: 0,0:21:46.07,0:21:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 20 tahun lamanya...
Dialogue: 0,0:21:48.57,0:21:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita bertemu lagi!
Dialogue: 0,0:21:50.62,0:21:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:21:58.71,0:22:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?!
Dialogue: 0,0:22:00.58,0:22:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat merindukanmu!
Dialogue: 0,0:22:02.81,0:22:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:22:03.97,0:22:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita biarkan mereka dulu?
Dialogue: 0,0:22:07.25,0:22:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau ikut makan malam?
