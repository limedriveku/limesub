Dialogue: 0,0:00:00.98,0:00:02.14,tanda,,0000,0000,0000,,AGENSI DETEKTIF TONOME
Dialogue: 0,0:00:03.23,0:00:07.10,tanda,,0000,0000,0000,,"AGENSI DETEKTIF TONOME"
Dialogue: 0,0:00:07.17,0:00:08.16,tanda,,0000,0000,0000,,KANIYA
Dialogue: 0,0:01:03.98,0:01:08.94,tanda,,0000,0000,0000,,THE INVISIBLE MAN\NAND HIS SOON-TO-BE WIFE
Dialogue: 0,0:11:57.45,0:11:59.70,tanda,,0000,0000,0000,,THE INVISIBLE MAN\NAND HIS SOON-TO-BE WIFE
Dialogue: 0,0:22:09.68,0:22:10.72,tanda,,0000,0000,0000,,EPISODE 10\NSEBELUM KITA MULAI TINGGAL BERSAMA
Dialogue: 0,0:22:10.74,0:22:11.68,tanda,,0000,0000,0000,,BERSAMBUNG
Dialogue: 0,0:00:02.17,0:00:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh-oleh?
Dialogue: 0,0:00:03.23,0:00:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Kami dari pemandian air panas.
Dialogue: 0,0:00:08.18,0:00:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:00:09.11,0:00:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati\Nbersama staf agensi yang lain.
Dialogue: 0,0:00:13.54,0:00:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puding pemandian air panas!
Dialogue: 0,0:00:15.61,0:00:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku harus pilih yang mana?
Dialogue: 0,0:00:17.95,0:00:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya bisa bekerja sambil kencan\Ndi pemandian air panas.
Dialogue: 0,0:00:21.71,0:00:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memprioritaskan pekerjaan.
Dialogue: 0,0:00:24.00,0:00:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jadwal kalian bergeser, 'kan?
Dialogue: 0,0:00:26.99,0:00:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, tapi kami\Nberhasil menyelesaikan kasusnya...
Dialogue: 0,0:00:30.55,0:00:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pilih yang mana, ya...
Dialogue: 0,0:00:32.61,0:00:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kikira, kau tidak mau?\NAtau mungkin nanti saja?
Dialogue: 0,0:00:46.32,0:00:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia suka matcha?
Dialogue: 0,0:02:23.85,0:02:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat!
Dialogue: 0,0:02:25.85,0:02:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga baru saja sampai.
Dialogue: 0,0:02:27.92,0:02:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:02:29.35,0:02:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku datang lebih lambat\Ndari perkiraanku.
Dialogue: 0,0:02:32.52,0:02:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata Akira,\Nkau kesulitan mengumpulkan buktinya.
Dialogue: 0,0:02:36.96,0:02:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa semuanya lancar?
Dialogue: 0,0:02:38.49,0:02:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:02:39.62,0:02:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, begitulah.\NItu sebabnya aku terlambat hari ini.
Dialogue: 0,0:02:44.41,0:02:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari bukti di tumpukan sampah ini?
Dialogue: 0,0:02:47.79,0:02:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.\NAku tak menyangka akan sebanyak ini.
Dialogue: 0,0:02:53.17,0:02:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita butuh bukti untuk kasus ini.
Dialogue: 0,0:02:56.67,0:02:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf!
Dialogue: 0,0:02:57.79,0:03:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pekerjaan mendesak.\NBiar agensi lain saja yang urus.
Dialogue: 0,0:03:01.46,0:03:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah bilang\Ntidak mau melakukannya.
Dialogue: 0,0:03:03.37,0:03:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:03:04.67,0:03:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ugh. Merepotkan sekali.
Dialogue: 0,0:03:07.33,0:03:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kapan kau membutuhkannya?
Dialogue: 0,0:03:10.71,0:03:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, eh...
Dialogue: 0,0:03:12.63,0:03:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lusa ada pertemuan dengan klien.
Dialogue: 0,0:03:15.06,0:03:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan ini sangat mendesak.
Dialogue: 0,0:03:17.08,0:03:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf...
Dialogue: 0,0:03:20.15,0:03:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Daichi!
Dialogue: 0,0:03:22.52,0:03:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cepat sekali menemukan buktinya\Ndi tumpukan sampah itu!
Dialogue: 0,0:03:26.82,0:03:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau luar biasa! Terima kasih!
Dialogue: 0,0:03:29.50,0:03:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam. Bau busuknya\Nnanti menempel padamu.
Dialogue: 0,0:03:33.71,0:03:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku jatuh cinta lagi!
Dialogue: 0,0:03:36.16,0:03:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kikira memang luar biasa.
Dialogue: 0,0:03:38.22,0:03:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat serius\Nkalau menyangkut pekerjaan.
Dialogue: 0,0:03:42.06,0:03:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasiakan dari Daichi\Nkalau aku membanggakannya.
Dialogue: 0,0:03:46.23,0:03:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daichi sungguh beruntung.
Dialogue: 0,0:03:48.38,0:03:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat antisosial,\Ntapi punya pasangan yang pengertian.
Dialogue: 0,0:03:52.10,0:03:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya!
Dialogue: 0,0:03:52.91,0:03:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Jarashi, apa ada orang\Nyang pengertian dalam hidupmu?
Dialogue: 0,0:03:56.47,0:03:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:04:00.83,0:04:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:04:02.56,0:04:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Apa? Tertarik pada seseorang?
Dialogue: 0,0:04:05.65,0:04:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan begitu.\NLebih tepatnya, kami akrab.
Dialogue: 0,0:04:10.27,0:04:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku bisa tampil apa adanya.
Dialogue: 0,0:04:13.71,0:04:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh! Maksudmu staf di toko pakaian itu?
Dialogue: 0,0:04:16.30,0:04:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar!\NStaf yang pernah kuceritakan padamu!
Dialogue: 0,0:04:19.99,0:04:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dia, belanja pakaian\Njadi sangat menyenangkan.
Dialogue: 0,0:04:24.32,0:04:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku mengerti.
Dialogue: 0,0:04:26.77,0:04:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang butuh sosok seperti itu.
Dialogue: 0,0:04:28.91,0:04:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Selera kami mirip, jadi\Naku bisa mengobrol apa saja dengannya.
Dialogue: 0,0:04:33.45,0:04:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarashi, kau sedikit berubah\Nsejak bertemu dengannya.
Dialogue: 0,0:04:37.11,0:04:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Benarkah?
Dialogue: 0,0:04:38.19,0:04:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:04:38.92,0:04:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlihat lebih lembut\Ndan lebih ceria, 'kan?
Dialogue: 0,0:04:43.72,0:04:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kekhawatiranku berkurang satu,
Dialogue: 0,0:04:45.93,0:04:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa ada lebih banyak hal\Nyang bisa dinikmati tiap hari!
Dialogue: 0,0:04:49.06,0:04:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bagus sekali.
Dialogue: 0,0:04:51.31,0:04:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, omong-omong, bagaimana kabarmu\Nbelakangan ini, Shizuka?
Dialogue: 0,0:04:55.14,0:04:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sangat rukun\Ndengan Tonome.
Dialogue: 0,0:04:59.87,0:05:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berencana untuk tinggal bersama!
Dialogue: 0,0:05:02.61,0:05:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:05:03.61,0:05:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berjalan sangat lancar!
Dialogue: 0,0:05:06.49,0:05:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Akira akan segera menginap\Ndi tempatku untuk pertama kalinya!
Dialogue: 0,0:05:15.19,0:05:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau makin menggemaskan\Nsejak jatuh cinta.
Dialogue: 0,0:05:20.06,0:05:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal menyombongkan diri,\Naku tak bisa mengalahkanmu, Yako!
Dialogue: 0,0:05:22.76,0:05:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian serukun itu,\Npasti kalian tak pernah bertengkar!
Dialogue: 0,0:05:27.71,0:05:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:28.30,0:05:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu, orang yang berpacaran\Nbiasanya sering bertengkar,
Dialogue: 0,0:05:31.34,0:05:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalian belum pernah\Nbertengkar, 'kan?
Dialogue: 0,0:05:34.26,0:05:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kau benar.
Dialogue: 0,0:05:37.42,0:05:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah mengeluh kepadanya\Nkarena dia itu "supadari".
Dialogue: 0,0:05:41.92,0:05:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supadari?
Dialogue: 0,0:05:43.38,0:05:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu perhatian padaku.
Dialogue: 0,0:05:45.02,0:05:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:05:46.26,0:05:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, dia itu Tonome.
Dialogue: 0,0:05:48.74,0:05:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju.
Dialogue: 0,0:05:50.54,0:05:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Tonome selalu bersikap sopan.
Dialogue: 0,0:05:53.74,0:05:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin terkadang terlalu perhatian,\Ntapi tak akan pernah mengajak bertengkar.
Dialogue: 0,0:05:57.98,0:05:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:05:58.82,0:06:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar sekali.
Dialogue: 0,0:06:04.43,0:06:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:06:05.36,0:06:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Akira!
Dialogue: 0,0:06:07.33,0:06:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengundangku.
Dialogue: 0,0:06:09.04,0:06:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Apa ini wangi mawar?
Dialogue: 0,0:06:13.54,0:06:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku membelinya\Ndalam perjalanan ke sini.
Dialogue: 0,0:06:15.49,0:06:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:06:16.92,0:06:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bersemangat menginap\Ndi tempatmu untuk pertama kalinya.
Dialogue: 0,0:06:19.71,0:06:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku spontan membelinya.
Dialogue: 0,0:06:21.30,0:06:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Terima kasih banyak!
Dialogue: 0,0:06:24.97,0:06:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira akan ada di tempatku\Nmulai hari ini sampai besok!
Dialogue: 0,0:06:30.44,0:06:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah siapkan segalanya\Nuntuk menyambutnya!
Dialogue: 0,0:06:32.31,0:06:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masih terlalu dini\Nuntuk makan malam.
Dialogue: 0,0:06:34.85,0:06:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya, benar.
Dialogue: 0,0:06:37.09,0:06:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu bersemangat.\NSepertinya aku datang terlalu awal.
Dialogue: 0,0:06:40.02,0:06:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em, kau mau minum teh?
Dialogue: 0,0:06:44.31,0:06:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus. Kedengarannya enak.\NPerlu aku beli kue?
Dialogue: 0,0:06:48.55,0:06:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak perlu.
Dialogue: 0,0:06:51.80,0:06:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gâteau au chocolat untukmu.
Dialogue: 0,0:06:55.70,0:06:57.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau membuatnya sendiri?
Dialogue: 0,0:06:57.26,0:06:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:06:58.50,0:07:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatnya tidak terlalu sulit.
Dialogue: 0,0:07:01.67,0:07:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku dibuatkan\Nhidangan manis oleh pacarku!
Dialogue: 0,0:07:04.97,0:07:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Benarkah?!
Dialogue: 0,0:07:06.99,0:07:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu bukan sesuatu yang mewah...
Dialogue: 0,0:07:10.15,0:07:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita segera memakannya!\NAku merasa sangat senang sekarang!
Dialogue: 0,0:07:14.37,0:07:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:07:16.02,0:07:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku juga punya krim kocok\Nuntuk kuenya.
Dialogue: 0,0:07:19.43,0:07:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:07:20.81,0:07:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:07:22.55,0:07:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini krimnya! Aku akan menyeduh teh.
Dialogue: 0,0:07:26.67,0:07:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau punya vas atau gelas?
Dialogue: 0,0:07:29.72,0:07:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memajang mawarnya.
Dialogue: 0,0:07:31.75,0:07:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku punya gelas...
Dialogue: 0,0:07:34.32,0:07:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:07:36.82,0:07:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:07:37.70,0:07:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:07:43.32,0:07:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bergerak.
Dialogue: 0,0:07:48.37,0:07:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ugh...
Dialogue: 0,0:07:50.50,0:07:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Krimnya bisa mengenai pakaianmu.
Dialogue: 0,0:07:53.32,0:07:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku bisa membersihkannya sendiri.
Dialogue: 0,0:07:58.39,0:08:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ada krim di rambutmu.
Dialogue: 0,0:08:02.62,0:08:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, tengadahkan kepalamu.
Dialogue: 0,0:08:07.51,0:08:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini terlalu dingin?
Dialogue: 0,0:08:08.62,0:08:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak.
Dialogue: 0,0:08:10.24,0:08:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:08:12.31,0:08:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Sentuhan Akira sangat lembut!
Dialogue: 0,0:08:15.93,0:08:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungku berdebar kencang!
Dialogue: 0,0:08:22.65,0:08:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Dia terlihat sedih.
Dialogue: 0,0:08:26.36,0:08:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masih ada krim di kulkas?
Dialogue: 0,0:08:29.19,0:08:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Ya.
Dialogue: 0,0:08:30.86,0:08:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita\Nmenyiapkannya sama-sama?
Dialogue: 0,0:08:32.51,0:08:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:08:33.45,0:08:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ayo!
Dialogue: 0,0:08:35.27,0:08:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, beres.
Dialogue: 0,0:08:37.49,0:08:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:08:38.49,0:08:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bersih sekarang.
Dialogue: 0,0:08:41.02,0:08:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:08:49.33,0:08:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm! Ini enak!
Dialogue: 0,0:08:50.92,0:08:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, syukurlah!
Dialogue: 0,0:08:55.15,0:08:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat cocok dengan teh.\NEnak sekali.
Dialogue: 0,0:09:00.06,0:09:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa sangat bahagia saat ini.
Dialogue: 0,0:09:04.04,0:09:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen bahagia ini\Nakan berlanjut sampai besok...
Dialogue: 0,0:09:14.79,0:09:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira...
Dialogue: 0,0:09:16.16,0:09:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lebih keras kepala\Ndaripada yang kukira.
Dialogue: 0,0:09:18.19,0:09:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga, Shizuka.
Dialogue: 0,0:09:20.32,0:09:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Argh! Sudah kubilang,\Nbiar aku yang tidur di lantai!
Dialogue: 0,0:09:24.28,0:09:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mungkin\Nmembiarkanmu tidur di lantai!
Dialogue: 0,0:09:27.11,0:09:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku bisa tak sengaja menginjakmu\Nsaat turun dari ranjang!
Dialogue: 0,0:09:31.04,0:09:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan!\NBahkan, aku menyukainya!
Dialogue: 0,0:09:33.36,0:09:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang apa?!
Dialogue: 0,0:09:34.67,0:09:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menopangmu\Nsaat kau turun dari ranjang!
Dialogue: 0,0:09:37.48,0:09:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau membangunkanmu!
Dialogue: 0,0:09:42.68,0:09:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita menemui jalan buntu.
Dialogue: 0,0:09:45.92,0:09:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah! Kalau begitu, bagaimana kalau\Nkita berdua tidur di lantai!
Dialogue: 0,0:09:49.39,0:09:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kesimpulannya jadi begitu?
Dialogue: 0,0:09:51.58,0:09:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik kita berdua\Ntidur di ranjang.
Dialogue: 0,0:09:54.89,0:09:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:10:00.27,0:10:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini agak sempit.
Dialogue: 0,0:10:02.38,0:10:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya... benar...
Dialogue: 0,0:10:04.82,0:10:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira... ada di... ranjangku...
Dialogue: 0,0:10:08.05,0:10:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, dua orang\Ndi ranjang ukuran single...
Dialogue: 0,0:10:11.34,0:10:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku takut kau jatuh dari ranjang.\NMau bertukar tempat?
Dialogue: 0,0:10:14.55,0:10:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak apa-apa.
Dialogue: 0,0:10:17.19,0:10:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mendekatlah padaku.\NKau bisa jatuh.
Dialogue: 0,0:10:20.50,0:10:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh!
Dialogue: 0,0:10:22.43,0:10:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pernah tidur bersama di penginapan.
Dialogue: 0,0:10:24.49,0:10:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak perlu panik begitu...
Dialogue: 0,0:10:25.75,0:10:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidur di ranjangku sendiri\Nbersamamu sedekat ini...
Dialogue: 0,0:10:30.32,0:10:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahan!
Dialogue: 0,0:10:32.62,0:10:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat menggemaskan\Nkalau sedang begini.
Dialogue: 0,0:10:34.76,0:10:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sengaja ingin menggodaku?
Dialogue: 0,0:10:51.97,0:10:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira?
Dialogue: 0,0:10:53.59,0:10:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau sudah bangun?
Dialogue: 0,0:10:55.78,0:10:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat... pagi.
Dialogue: 0,0:10:58.35,0:11:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:11:00.11,0:11:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyeduh kopi. Kau mau?
Dialogue: 0,0:11:04.59,0:11:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:11:07.65,0:11:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat gugup,\Nsampai tidak bisa tidur sama sekali.
Dialogue: 0,0:11:11.66,0:11:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus ke kamar mandi juga.\NSyukurlah aku tidur di sisi luar.
Dialogue: 0,0:11:17.82,0:11:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya. Apa kau keberatan\Njika aku mengunjungi orang tuamu?
Dialogue: 0,0:11:22.04,0:11:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:11:23.15,0:11:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini saat yang tepat.\NBagaimana menurutmu?
Dialogue: 0,0:11:28.94,0:11:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:11:29.87,0:11:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:11:31.39,0:11:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:32.01,0:11:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita akan menikah?!
Dialogue: 0,0:11:34.42,0:11:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kupikir aku harus\Nmemperkenalkan diri
Dialogue: 0,0:11:36.10,0:11:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelum kita mulai tinggal bersama.
Dialogue: 0,0:11:37.48,0:11:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:11:38.98,0:11:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}B-Benar... Ya, itu benar...
Dialogue: 0,0:11:41.74,0:11:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu terburu-buru lagi!
Dialogue: 0,0:11:42.98,0:11:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku sangat bahagia\Nkau begitu menantikannya.
Dialogue: 0,0:11:46.60,0:11:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang kau sangat menggemaskan.
Dialogue: 0,0:11:48.15,0:11:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak senang mendengarnya!
Dialogue: 0,0:11:50.70,0:11:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jadi, aku akan menelepon ibuku.
Dialogue: 0,0:11:54.34,0:11:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Mari atur jadwal\Nuntuk bertemu mereka.
Dialogue: 0,0:12:00.73,0:12:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, jadi...
Dialogue: 0,0:12:02.42,0:12:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:12:03.42,0:12:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebelum Akira dan aku\Nmulai tinggal bersama...
Dialogue: 0,0:12:07.02,0:12:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kami mampir menemui kalian?
Dialogue: 0,0:12:08.63,0:12:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!\NAyah dan Futa ada di rumah.
Dialogue: 0,0:12:12.37,0:12:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sampai jumpa.
Dialogue: 0,0:12:14.46,0:12:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu!
Dialogue: 0,0:12:18.55,0:12:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:19.35,0:12:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Futa?
Dialogue: 0,0:12:20.85,0:12:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak menelepon?
Dialogue: 0,0:12:21.90,0:12:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, benar.
Dialogue: 0,0:12:22.82,0:12:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan segera berkunjung ke rumah.
Dialogue: 0,0:12:24.43,0:12:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari yang kutunggu-tunggu akhirnya tiba!
Dialogue: 0,0:12:28.05,0:12:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa dia kemari?
Dialogue: 0,0:12:29.06,0:12:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan membawa pacarnya!
Dialogue: 0,0:12:33.45,0:12:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:41.91,0:12:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar\Nuntuk melihat wajah pria ini.
Dialogue: 0,0:12:45.01,0:12:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ayolah. Dia pria yang sangat baik.
Dialogue: 0,0:12:50.75,0:12:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonome, selamat datang!
Dialogue: 0,0:12:53.67,0:12:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo. Futa, beri salam.
Dialogue: 0,0:12:56.17,0:12:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Futa di sini juga?
Dialogue: 0,0:12:57.67,0:12:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama tidak bertemu!
Dialogue: 0,0:12:59.64,0:13:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira, Futa adalah adikku.
Dialogue: 0,0:13:02.82,0:13:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu.
Dialogue: 0,0:13:04.42,0:13:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pria ini tidak punya wajah...
Dialogue: 0,0:13:06.54,0:13:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:06.99,0:13:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak,\Nbukannya aku tidak punya wajah...
Dialogue: 0,0:13:10.79,0:13:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo berangkat!
Dialogue: 0,0:13:13.63,0:13:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, santai sekali rasanya\Ndi mobil keluarga sendiri.
Dialogue: 0,0:13:17.93,0:13:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau biasa naik mobil\Nbersama Tonome?
Dialogue: 0,0:13:20.49,0:13:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:21.43,0:13:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang dia mengajakku\Nke laut dan gunung.
Dialogue: 0,0:13:24.56,0:13:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terus menatapku...
Dialogue: 0,0:13:27.69,0:13:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, apa panggilanmu "Fu"?
Dialogue: 0,0:13:31.50,0:13:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Futa. Kelas dua SMA.
Dialogue: 0,0:13:33.66,0:13:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku orang tak kasatmata pertama\Nyang kau temui?
Dialogue: 0,0:13:37.64,0:13:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:13:40.22,0:13:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, tongkat bisbol itu untuk apa?
Dialogue: 0,0:13:43.83,0:13:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum perlu memikirkannya.
Dialogue: 0,0:13:45.81,0:13:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Belum"?
Dialogue: 0,0:13:46.92,0:13:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah hampir sampai!
Dialogue: 0,0:13:53.51,0:13:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sampai!
Dialogue: 0,0:13:57.78,0:14:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jadi ini rumah keluargamu?
Dialogue: 0,0:14:01.97,0:14:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ubin mosaik ini sangat cantik.
Dialogue: 0,0:14:04.82,0:14:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu yang kubuat\Nbersama Futa, 'kan?
Dialogue: 0,0:14:09.19,0:14:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ubin ini memberitahuku letak tangganya.
Dialogue: 0,0:14:12.47,0:14:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bagus. Ubinnya cukup timbul,\Njadi kau pasti bisa merasakannya.
Dialogue: 0,0:14:16.78,0:14:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami membuatnya\Nuntuk tugas liburan musim panas.
Dialogue: 0,0:14:20.92,0:14:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Bersama Ayah juga.
Dialogue: 0,0:14:22.98,0:14:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti itu penuh kenangan indah.
Dialogue: 0,0:14:25.56,0:14:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendengar lebih banyak.
Dialogue: 0,0:14:27.04,0:14:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada album foto.
Dialogue: 0,0:14:29.09,0:14:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:14:30.46,0:14:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan mendengarnya panjang lebar nanti.
Dialogue: 0,0:14:33.15,0:14:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simpan saja hal-hal terbaik\Nuntuk nanti.
Dialogue: 0,0:14:35.66,0:14:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:38.03,0:14:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo masuk.
Dialogue: 0,0:14:40.40,0:14:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uh... Kalau begitu, pertama-tama...
Dialogue: 0,0:14:43.79,0:14:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau mau melihat kamarku?
Dialogue: 0,0:14:45.73,0:14:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu saja.
Dialogue: 0,0:14:46.86,0:14:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ikut.
Dialogue: 0,0:14:47.63,0:14:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:48.34,0:14:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak keberatan, Tonome?
Dialogue: 0,0:14:50.57,0:14:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Bukankah seharusnya\Nkau minta izin padaku, Futa?
Dialogue: 0,0:14:54.04,0:14:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masalahnya?
Dialogue: 0,0:14:54.81,0:14:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph.
Dialogue: 0,0:14:56.21,0:14:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan.
Dialogue: 0,0:14:58.77,0:15:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Futa, tolong ambilkan minuman.
Dialogue: 0,0:15:01.86,0:15:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Shizuka, awas tangga. Sini tanganmu.
Dialogue: 0,0:15:04.60,0:15:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja!\NIni rumahku, aku sudah terbiasa.
Dialogue: 0,0:15:08.31,0:15:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kurasa kau benar.
Dialogue: 0,0:15:10.12,0:15:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:15:11.49,0:15:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengikutimu dari belakang.
Dialogue: 0,0:15:13.54,0:15:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:15:14.69,0:15:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kamarku.
Dialogue: 0,0:15:16.74,0:15:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat rapi dan sederhana.
Dialogue: 0,0:15:18.62,0:15:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kau mau melepas mantelmu?\NBiar kugantungkan.
Dialogue: 0,0:15:22.73,0:15:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:15:27.88,0:15:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akira ada di kamarku!\NRasanya canggung sekali!
Dialogue: 0,0:15:32.66,0:15:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:15:34.39,0:15:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih menatapku.
Dialogue: 0,0:15:36.78,0:15:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Futa. Apa ada sesuatu\Nyang ingin kau tanyakan?
Dialogue: 0,0:15:40.58,0:15:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:15:41.26,0:15:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau sangat penasaran denganku.
Dialogue: 0,0:15:44.51,0:15:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:45.31,0:15:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:15:46.46,0:15:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap kali aku melihatmu,\Nmata kita bertemu...
Dialogue: 0,0:15:49.87,0:15:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau lebih tepatnya,\Nkau seperti menatapku.
Dialogue: 0,0:15:51.44,0:15:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir mungkin\Nada yang ingin kau katakan.
Dialogue: 0,0:15:54.99,0:15:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau pikir aku tidak sadar\Nkalau kau sedang menatapku?
Dialogue: 0,0:15:59.03,0:16:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, maksudku, mata kita tidak bertemu.
Dialogue: 0,0:16:01.88,0:16:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu\Nkau sedang melihat ke arah mana.
Dialogue: 0,0:16:04.74,0:16:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujudku memang tidak terlihat.
Dialogue: 0,0:16:05.95,0:16:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kau bisa mengawasiku\Nsemaumu tanpa kusadari!
Dialogue: 0,0:16:08.82,0:16:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu curang!
Dialogue: 0,0:16:09.66,0:16:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang dari tadi mengawasinya!
Dialogue: 0,0:16:12.58,0:16:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sangat berguna sebagai detektif.
Dialogue: 0,0:16:16.39,0:16:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:16:19.43,0:16:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacar Shizuka sudah datang.
Dialogue: 0,0:16:21.78,0:16:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Ayah sudah pulang.
Dialogue: 0,0:16:24.17,0:16:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em... Apa kau ingin\Nmemperkenalkan dirimu... sekarang?
Dialogue: 0,0:16:28.73,0:16:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tapi dia baru saja pulang...
Dialogue: 0,0:16:33.52,0:16:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan waktu yang tepat\Nuntuk menyapanya?
Dialogue: 0,0:16:36.93,0:16:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke kamar mandi dulu, ya.
Dialogue: 0,0:16:38.52,0:16:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:16:42.62,0:16:45.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa Kakak dan dia\Nharus turun sekarang?
Dialogue: 0,0:16:45.83,0:16:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pesan makanan untuk malam ini.\NAku akan memanggil mereka kalau sudah tiba.
Dialogue: 0,0:16:49.06,0:16:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah. Baiklah.
Dialogue: 0,0:16:52.66,0:16:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sushinya sudah datang!
Dialogue: 0,0:17:05.59,0:17:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em, perkenalkan, namaku Akira Tonome.
Dialogue: 0,0:17:07.95,0:17:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu dengan Anda.
Dialogue: 0,0:17:10.31,0:17:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduklah di sini.
Dialogue: 0,0:17:12.02,0:17:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:17:13.42,0:17:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, selamat malam!
Dialogue: 0,0:17:16.54,0:17:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:17:17.68,0:17:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}-Selamat makan...\N-Selamat makan.
Dialogue: 0,0:17:20.16,0:17:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku taruh sushi kesukaanmu di depanmu.
Dialogue: 0,0:17:22.05,0:17:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat mirip dengan Futa.
Dialogue: 0,0:17:24.71,0:17:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa minum alkohol?
Dialogue: 0,0:17:26.33,0:17:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em, ya.
Dialogue: 0,0:17:28.06,0:17:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonome, kau pemilik\Ntempat kerja Shizuka?
Dialogue: 0,0:17:31.50,0:17:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:32.31,0:17:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu hanya agensi kecil.
Dialogue: 0,0:17:34.92,0:17:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, aku menghargainya.
Dialogue: 0,0:17:42.97,0:17:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasananya canggung sekali.
Dialogue: 0,0:17:44.79,0:17:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga menatapku seperti Futa.
Dialogue: 0,0:17:53.82,0:17:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan sekarang?
Dialogue: 0,0:17:55.44,0:17:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku melakukan kesalahan?
Dialogue: 0,0:18:01.34,0:18:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau minum wiski?
Dialogue: 0,0:18:03.67,0:18:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Ayah memang bukan\Npembicara yang andal.
Dialogue: 0,0:18:06.73,0:18:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat menantikan momen minum\Nbersama pacar putrinya!
Dialogue: 0,0:18:13.78,0:18:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa campuran? Dengan es batu?\NAtau tambah air?
Dialogue: 0,0:18:17.04,0:18:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan es batu, terima kasih.
Dialogue: 0,0:18:27.29,0:18:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:18:30.64,0:18:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin lihat putriku\Nsaat masih kecil?
Dialogue: 0,0:18:33.15,0:18:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:34.14,0:18:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengumpulkan foto dan videonya\Nmenjadi sebuah film.
Dialogue: 0,0:18:37.80,0:18:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benarkah?\NAku ingin sekali melihatnya.
Dialogue: 0,0:18:40.49,0:18:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengambilnya.
Dialogue: 0,0:18:43.83,0:18:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih untuk makanannya.\NAku mau mandi.
Dialogue: 0,0:18:46.15,0:18:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:18:46.85,0:18:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, mandilah dan bersiap untuk tidur.
Dialogue: 0,0:18:48.78,0:18:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, baiklah.
Dialogue: 0,0:18:50.28,0:18:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tonome, semoga beruntung.
Dialogue: 0,0:18:52.37,0:18:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:52.97,0:18:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Video kenangan keluarga buatan Ayah\Nberdurasi lima jam.
Dialogue: 0,0:18:56.95,0:18:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu sudah setara film epik!
Dialogue: 0,0:18:59.65,0:19:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai, ya.
Dialogue: 0,0:19:01.05,0:19:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:03.85,0:19:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putriku lahir di rumah sakit ini.
Dialogue: 0,0:19:06.98,0:19:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, dia lucu sekali!
Dialogue: 0,0:19:09.55,0:19:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, dia tidak mau berpisah\Ndari ibunya sedikit pun.
Dialogue: 0,0:19:13.38,0:19:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:19:23.34,0:19:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencananya aku mau pulang kemarin malam.
Dialogue: 0,0:19:25.05,0:19:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengizinkanku menginap.
Dialogue: 0,0:19:26.49,0:19:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa! Kalau Ayah sudah memutar videonya,\Npasti tak akan ada akhirnya.
Dialogue: 0,0:19:33.10,0:19:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan pulang setelah sarapan?
Dialogue: 0,0:19:34.50,0:19:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:35.09,0:19:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kuantar kau ke stasiun.
Dialogue: 0,0:19:37.23,0:19:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada toko roti enak\Ndi perjalanan menuju stasiun.
Dialogue: 0,0:19:41.06,0:19:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kalian membeli\Nmakan siang di sana.
Dialogue: 0,0:19:43.16,0:19:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Toko roti yang mana?
Dialogue: 0,0:19:45.35,0:19:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko yang baru buka beberapa hari lalu.\NRoti gulungnya...
Dialogue: 0,0:19:48.47,0:19:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}M-Maaf!
Dialogue: 0,0:19:49.82,0:19:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:19:54.22,0:19:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku sedang berpacaran\Ndengan Shizuka.
Dialogue: 0,0:19:57.77,0:20:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin segera mulai\Ntinggal bersamanya.
Dialogue: 0,0:20:03.43,0:20:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah! Benar! Dia kemari\Nuntuk memberitahukan soal itu!
Dialogue: 0,0:20:10.46,0:20:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja boleh!
Dialogue: 0,0:20:12.53,0:20:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan, Ayah?
Dialogue: 0,0:20:14.10,0:20:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:14.94,0:20:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal... bersama?
Dialogue: 0,0:20:16.78,0:20:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu... Ayah... sudah tahu?
Dialogue: 0,0:20:19.87,0:20:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku sudah bilang kau akan datang\Nuntuk membahas soal tinggal bersama.
Dialogue: 0,0:20:24.37,0:20:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Aku tak pernah dengar soal ini.
Dialogue: 0,0:20:26.65,0:20:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sekadar memperkenalkan pacar?
Dialogue: 0,0:20:28.41,0:20:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku belum memberitahumu?\NAku sudah memberi tahu Ayah.
Dialogue: 0,0:20:32.38,0:20:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, intinya begitulah!
Dialogue: 0,0:20:35.58,0:20:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas restu kalian!
Dialogue: 0,0:20:38.14,0:20:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:39.14,0:20:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama!
Dialogue: 0,0:20:42.35,0:20:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu soal ini.
Dialogue: 0,0:20:47.00,0:20:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat gugup!
Dialogue: 0,0:20:48.47,0:20:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}M-Maafkan aku. Aku terlalu bersantai\Nkarena sudah lama tak pulang...
Dialogue: 0,0:20:53.73,0:20:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak, aku terus menunggu waktu yang pas\Ntapi tidak bisa menemukannya...
Dialogue: 0,0:20:58.66,0:21:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi syukurlah mereka menerimanya, 'kan?
Dialogue: 0,0:21:02.86,0:21:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:04.24,0:21:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku belum pernah melihat\NAkira segugup itu sebelumnya.
Dialogue: 0,0:21:09.06,0:21:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, berikutnya aku ingin\Nmemperkenalkanmu pada orang tuaku...
Dialogue: 0,0:21:12.79,0:21:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pfft!
Dialogue: 0,0:21:13.71,0:21:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau baik-baik saja?!\NApa minumannya terlalu panas?!
Dialogue: 0,0:21:16.32,0:21:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh! Tidak!
Dialogue: 0,0:21:18.55,0:21:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Itu benar!
Dialogue: 0,0:21:22.26,0:21:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku harus bertemu\Norang tuanya juga! Benar!
Dialogue: 0,0:21:26.74,0:21:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah bertemu ibumu\Nsekali sebelumnya,
Dialogue: 0,0:21:30.01,0:21:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku bisa sedikit lebih tenang\Nmeskipun tetap gugup,
Dialogue: 0,0:21:32.54,0:21:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau belum pernah bertemu\Nkedua orang tuaku.
Dialogue: 0,0:21:36.94,0:21:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:21:38.71,0:21:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana? Haruskah kita\Nmenundanya untuk saat ini?
Dialogue: 0,0:21:41.21,0:21:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Aku ingin sekali bertemu mereka!
Dialogue: 0,0:21:44.12,0:21:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dibesarkan di kota dengan\Nbanyak ras hidup berdampingan,
Dialogue: 0,0:21:47.24,0:21:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi orang tuaku\Nsudah pindah kembali ke desa.
Dialogue: 0,0:21:50.61,0:21:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya agak jauh, jadi menurutku\Nbermalam adalah pilihan terbaik.
Dialogue: 0,0:21:54.38,0:21:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak keberatan?
Dialogue: 0,0:21:55.38,0:21:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak!
Dialogue: 0,0:21:57.12,0:22:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tempatnya agak unik...
Dialogue: 0,0:22:00.06,0:22:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:22:00.91,0:22:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah desa orang tak kasatmata,
Dialogue: 0,0:22:03.66,0:22:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat hanya orang tak kasatmata\Nyang tinggal di sana.
Dialogue: 0,0:22:06.25,0:22:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa orang...
Dialogue: 0,0:22:08.25,0:22:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak kasatmata?
