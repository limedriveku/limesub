Dialogue: 0,0:06:14.56,0:06:15.27,tanda,,0000,0000,0000,,JUMAT
Dialogue: 0,0:07:00.27,0:07:01.07,tanda,,0000,0000,0000,,MOMOTOSE AO, KOSTUM BARU!!\NMAAF AGAK SEKSI
Dialogue: 0,0:07:07.78,0:07:09.74,tanda,,0000,0000,0000,,BEBERAPA HARI KEMUDIAN
Dialogue: 0,0:07:09.74,0:07:11.91,tanda,,0000,0000,0000,,PENGUNGKAPAN KOSTUM BARU IKON!!
Dialogue: 0,0:07:17.63,0:07:21.46,tanda,,0000,0000,0000,,PENGUNGKAPAN KOSTUM BARU
Dialogue: 0,0:07:46.74,0:07:48.41,tanda,,0000,0000,0000,,TOLONG LOMPAT!!!
Dialogue: 0,0:10:21.31,0:10:24.73,tanda,,0000,0000,0000,,KOLABORASI MENDADAK: PESTA TAKOYAKI!
Dialogue: 0,0:11:32.00,0:11:35.01,tanda,,0000,0000,0000,,AKAN KUTUNJUKKAN SUATU HARI NANTI
Dialogue: 0,0:11:35.22,0:11:37.97,tanda,,0000,0000,0000,,SEMINGGU KEMUDIAN
Dialogue: 0,0:14:27.68,0:14:29.22,tanda,,0000,0000,0000,,1. REKAP SIARAN IKO SUMERAGI
Dialogue: 0,0:14:50.41,0:14:52.04,tanda,,0000,0000,0000,,VTUBER PEMULA KETAKUTAN SAMPAI NGOMPOL
Dialogue: 0,0:15:08.60,0:15:10.56,tanda,,0000,0000,0000,,UNDANGAN KOLABORASI DARI MOMOTOSE AO
Dialogue: 0,0:15:10.56,0:15:13.56,tanda,,0000,0000,0000,,KEJUTAN MENDADAK
Dialogue: 0,0:16:09.41,0:16:11.41,tanda,,0000,0000,0000,,BEBERAPA HARI KEMUDIAN
Dialogue: 0,0:16:38.48,0:16:40.48,tanda,,0000,0000,0000,,PIALA AO BLUE BOX
Dialogue: 0,0:17:59.02,0:18:03.52,tanda,,0000,0000,0000,,SUMERAGI IKON: TERAKHIR
Dialogue: 0,0:19:57.34,0:19:59.26,tanda,,0000,0000,0000,,MOMOTOSE AO
Dialogue: 0,0:20:52.90,0:20:54.77,tanda,,0000,0000,0000,,MOMOTOSE AO
Dialogue: 0,0:20:54.77,0:20:55.78,tanda,,0000,0000,0000,,PANGGILAN BERAKHIR
Dialogue: 0,0:22:06.97,0:22:09.98,tanda,,0000,0000,0000,,TAPI DENGAN KONTAK LANGSUNG
Dialogue: 0,0:00:12.95,0:00:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya! Hai-kon!
Dialogue: 0,0:00:15.70,0:00:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai-kon!
Dialogue: 0,0:00:18.66,0:00:22.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang ke konserku\Nuntuk merayakan tiga juta pelanggan!
Dialogue: 0,0:00:24.64,0:00:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya kostum baru\Nyang dipersiapkan untuk acara ini.
Dialogue: 0,0:00:27.73,0:00:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang mengenali ini?
Dialogue: 0,0:00:32.50,0:00:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak hal telah terjadi sampai saat ini.
Dialogue: 0,0:00:36.22,0:00:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya cukup buruk sampai aku\Nhampir berhenti beberapa kali.
Dialogue: 0,0:00:40.05,0:00:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikon!
Dialogue: 0,0:00:41.67,0:00:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti bisa!
Dialogue: 0,0:00:43.13,0:00:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku tetap kuat
Dialogue: 0,0:00:46.03,0:00:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kalian menontonku, kan?
Dialogue: 0,0:02:24.25,0:02:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai besok! Dah-ko!
Dialogue: 0,0:02:30.34,0:02:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini siarannya bagus.
Dialogue: 0,0:02:32.09,0:02:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah pelanggannya juga bertambah.
Dialogue: 0,0:02:34.38,0:02:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku sudah pantas\Nmenganggap diriku sebagai VTuber top?
Dialogue: 0,0:02:38.64,0:02:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu dapat tiket konsernya Blue Box?
Dialogue: 0,0:02:41.10,0:02:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Blue Box? Apa itu?
Dialogue: 0,0:02:42.89,0:02:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak tahu?
Dialogue: 0,0:02:44.14,0:02:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka grup VTuber terbaik di Jepang.\NMasa tidak tahu?
Dialogue: 0,0:02:46.60,0:02:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lama ini, andalan mereka, Momotose Ao,\Ntembus tiga juga pelanggan!
Dialogue: 0,0:02:51.36,0:02:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hidup di zaman\NVTuber bisa tampil di Chiba Messe.
Dialogue: 0,0:02:55.11,0:02:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga juta pelanggan...
Dialogue: 0,0:02:56.99,0:02:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan lajuku saat ini...
Dialogue: 0,0:02:59.12,0:03:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh waktu satu abad bagiku\Nuntuk sampai ke sana.
Dialogue: 0,0:03:03.79,0:03:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, dari kami berempat,\Naku yang paling jauh dari impianku?
Dialogue: 0,0:03:08.50,0:03:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?\NKalau begini, cuma aku yang tertinggal!
Dialogue: 0,0:03:17.51,0:03:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin Rikka, Nene, dan Shinobu\Npasti akan mencapai mimpi mereka.
Dialogue: 0,0:03:21.39,0:03:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu itu terjadi...
Dialogue: 0,0:03:23.77,0:03:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya aku tak pernah memikirkan soal ini.\NKenapa jadi begini?
Dialogue: 0,0:03:29.02,0:03:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:03:34.15,0:03:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Kirino?
Dialogue: 0,0:03:36.24,0:03:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelihatan bimbang.
Dialogue: 0,0:03:39.99,0:03:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua salahmu!
Dialogue: 0,0:03:42.79,0:03:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!
Dialogue: 0,0:03:44.79,0:03:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salahku?
Dialogue: 0,0:03:47.08,0:03:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dorongannya kuat, ya.
Dialogue: 0,0:03:48.79,0:03:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah itu yang dipikirkan?
Dialogue: 0,0:03:52.21,0:03:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh puas dengan situasi sekarang.
Dialogue: 0,0:03:54.17,0:03:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menjadi lebih populer.
Dialogue: 0,0:03:58.34,0:04:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}VTuber top, Momotose Ao.
Dialogue: 0,0:04:01.30,0:04:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan yang ingin kucapai.
Dialogue: 0,0:04:03.39,0:04:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cepat-cepat mengejarnya.
Dialogue: 0,0:04:05.85,0:04:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mencari yang kurang dariku!\NPokoknya aku harus mempelajari soal Ao
Dialogue: 0,0:04:12.36,0:04:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di konser peringatan\Ntiga juta pelangganku!
Dialogue: 0,0:04:16.24,0:04:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, kita bersenang-senang, ya!
Dialogue: 0,0:04:21.99,0:04:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dansanya...
Dialogue: 0,0:04:22.83,0:04:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dansanya jago!
Dialogue: 0,0:04:26.50,0:04:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Model 3D-nya juga cantik.
Dialogue: 0,0:04:28.96,0:04:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Presentasinya juga bagus!
Dialogue: 0,0:04:32.17,0:04:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih terlalu awal untuk tampil 3D.
Dialogue: 0,0:04:34.63,0:04:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siaran langsung regulernya\Nharus jadi contoh.
Dialogue: 0,0:04:38.13,0:04:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku akan buat makaron!
Dialogue: 0,0:04:40.13,0:04:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan resepnya kelihatan sulit untuk pro,\Ntapi aku akan berusaha!
Dialogue: 0,0:04:44.97,0:04:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:04:46.85,0:04:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah coba banyak konten,\Ntapi levelnya jauh beda...
Dialogue: 0,0:04:51.06,0:04:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dia juga pintar!\NCurang!
Dialogue: 0,0:04:53.27,0:04:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak boleh takut!
Dialogue: 0,0:04:55.48,0:04:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak melewatinya, aku tak bisa menang!
Dialogue: 0,0:05:05.08,0:05:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirino sedang siaran sekarang?
Dialogue: 0,0:05:07.58,0:05:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siaran memasak? Tumben.
Dialogue: 0,0:05:10.21,0:05:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai-ko!
Dialogue: 0,0:05:11.92,0:05:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku mau mencoba membuat kue!
Dialogue: 0,0:05:14.67,0:05:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang akan kubuat!
Dialogue: 0,0:05:16.46,0:05:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kue utuh spesial empat tingkat!
Dialogue: 0,0:05:19.63,0:05:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum ada VTuber yang melakukan ini, kan?
Dialogue: 0,0:05:22.55,0:05:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari mulai!
Dialogue: 0,0:05:24.22,0:05:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, siapkan gula kastornya...
Dialogue: 0,0:05:27.52,0:05:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, di mana miksernya?
Dialogue: 0,0:05:32.06,0:05:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya dengan suhu sekitar tubuh?
Dialogue: 0,0:05:35.15,0:05:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara memanaskan ovennya?
Dialogue: 0,0:05:37.61,0:05:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mangkuk tahan panas?\NMemangnya ada mangkuk yang tidak tahan?
Dialogue: 0,0:05:40.99,0:05:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, kalau tak pasang kamera tangan,\Nkalian tidak bisa lihat, ya?
Dialogue: 0,0:05:46.20,0:05:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pamit dulu, dah-ko!
Dialogue: 0,0:05:48.33,0:05:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia lakukan?
Dialogue: 0,0:05:49.87,0:05:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komentarnya pun pada kebingungan!
Dialogue: 0,0:05:52.21,0:05:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:05:53.46,0:05:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar-benar bencana!
Dialogue: 0,0:05:56.13,0:06:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak akan bisa mengalahkan Ao.\NTapi, kalau tidak nekat,
Dialogue: 0,0:06:04.55,0:06:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai-ko!
Dialogue: 0,0:06:06.18,0:06:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku akan main musik didgeridoo!
Dialogue: 0,0:06:08.97,0:06:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini tes masuk kuliah, target nilai 100!
Dialogue: 0,0:06:11.48,0:06:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan siaran karaoke
Dialogue: 0,0:06:12.94,0:06:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai dapat tiga juga pelanggan.
Dialogue: 0,0:06:15.27,0:06:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:06:17.52,0:06:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Kirino.
Dialogue: 0,0:06:20.11,0:06:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bicara sebentar.
Dialogue: 0,0:06:21.82,0:06:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:06:22.74,0:06:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah lari?
Dialogue: 0,0:06:23.70,0:06:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa akan dimarahi!
Dialogue: 0,0:06:25.49,0:06:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak begini,\NBiarkan aku!
Dialogue: 0,0:06:28.83,0:06:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak akan bisa mengalahkan Ao!
Dialogue: 0,0:06:31.16,0:06:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kamu ini?
Dialogue: 0,0:06:38.34,0:06:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ao? Begitu.
Dialogue: 0,0:06:44.34,0:06:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cerita ke Bukki,\Ndia pasti akan menghentikanku.
Dialogue: 0,0:06:47.01,0:06:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti akan bilang mustahil\Naku bisa mengalahkan Momotose Ao.
Dialogue: 0,0:06:50.97,0:06:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengatasi ini sendiri.
Dialogue: 0,0:06:53.18,0:06:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar aku bisa menang dari Ao...
Dialogue: 0,0:06:58.23,0:07:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ao sedang siaran.
Dialogue: 0,0:07:01.07,0:07:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini...
Dialogue: 0,0:07:08.40,0:07:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, lihat ini.
Dialogue: 0,0:07:09.74,0:07:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iko bilang mau siaran kostum baru.
Dialogue: 0,0:07:11.91,0:07:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendadak, ya?
Dialogue: 0,0:07:13.75,0:07:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa siaran itu,\Ndia tidak datang ke ekskul.
Dialogue: 0,0:07:16.17,0:07:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jadi tidak sabar.
Dialogue: 0,0:07:17.63,0:07:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari siluetnya, sepertinya seru, ya?
Dialogue: 0,0:07:22.05,0:07:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siarannya dimulai.
Dialogue: 0,0:07:23.67,0:07:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, hai-ko!
Dialogue: 0,0:07:28.55,0:07:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kostum baruku ini?
Dialogue: 0,0:07:31.47,0:07:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju renang?
Dialogue: 0,0:07:32.31,0:07:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, seksi, ya.
Dialogue: 0,0:07:34.23,0:07:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sampai melakukan ini, ya.
Dialogue: 0,0:07:38.02,0:07:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlah penayangannya naik.
Dialogue: 0,0:07:40.27,0:07:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini karena aku lebih vulgar dari Ao?
Dialogue: 0,0:07:43.65,0:07:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku menang!
Dialogue: 0,0:07:46.74,0:07:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ingin aku lompat?
Dialogue: 0,0:07:49.12,0:07:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:07:51.62,0:07:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia lompat.
Dialogue: 0,0:07:53.91,0:07:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, ternyata bisa goyang, ya.
Dialogue: 0,0:07:57.87,0:08:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini tidak terlalu lama?
Dialogue: 0,0:08:00.00,0:08:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergerakan lehernya mulai aneh.
Dialogue: 0,0:08:02.34,0:08:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:08:06.47,0:08:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang apa?
Dialogue: 0,0:08:08.01,0:08:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih siaran!
Dialogue: 0,0:08:09.84,0:08:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan!
Dialogue: 0,0:08:11.97,0:08:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang aku lakukan\Ntidak lebih baik daripada Ao!
Dialogue: 0,0:08:15.60,0:08:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus melakukan ini\Nuntuk mengejar ketinggalan!
Dialogue: 0,0:08:18.69,0:08:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.\NTapi aku menentangnya.
Dialogue: 0,0:08:25.07,0:08:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa mengejarnya pun,
Dialogue: 0,0:08:26.82,0:08:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu sudah punya kekuatan\Nuntuk menjadi top.
Dialogue: 0,0:08:29.85,0:08:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong.
Dialogue: 0,0:08:30.61,0:08:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bohong.
Dialogue: 0,0:08:31.91,0:08:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan berbohong\Nhanya untuk menghiburmu.
Dialogue: 0,0:08:34.78,0:08:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bimbang\Ndan mencoba banyak sendirian, ya?
Dialogue: 0,0:08:36.90,0:08:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya andalkan aku!
Dialogue: 0,0:08:42.63,0:08:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena, kamu sama bagusnya\Ndengan Momotose Ao!
Dialogue: 0,0:08:48.55,0:08:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku paham.\NBantu aku, Bukki!
Dialogue: 0,0:08:51.59,0:08:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu!\NSemuanya serahkan padaku!
Dialogue: 0,0:08:55.14,0:08:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, wajahmu.
Dialogue: 0,0:08:57.22,0:08:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akhirnya sadar, ya?
Dialogue: 0,0:08:58.52,0:09:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulitku sangat halus!
Dialogue: 0,0:09:00.77,0:09:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku kamu terlalu dekat!
Dialogue: 0,0:09:05.44,0:09:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaramu tadi keren.
Dialogue: 0,0:09:08.69,0:09:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin aku bisa menang melawan Ao?
Dialogue: 0,0:09:11.32,0:09:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di keluargaku, kami tidak suka menyanjung.
Dialogue: 0,0:09:13.28,0:09:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya potensi itu.
Dialogue: 0,0:09:14.95,0:09:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya?
Dialogue: 0,0:09:15.83,0:09:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari spek, aku merasa kalah semuanya.
Dialogue: 0,0:09:18.70,0:09:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:09:19.87,0:09:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang pertama, aku suka suaramu.
Dialogue: 0,0:09:23.29,0:09:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Suka?
Dialogue: 0,0:09:24.50,0:09:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku suka.
Dialogue: 0,0:09:25.92,0:09:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara itu salah satu\Nsenjata utama seorang VTuber.
Dialogue: 0,0:09:28.63,0:09:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya. Suaraku, ya.
Dialogue: 0,0:09:31.26,0:09:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Visual, suara, kemampuan perencanaan.
Dialogue: 0,0:09:33.97,0:09:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hilang salah satunya,\Njadi populer pasti sulit.
Dialogue: 0,0:09:36.31,0:09:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi menurutku,\Nyang paling penting itu suara.
Dialogue: 0,0:09:39.18,0:09:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat siaran panjang,
Dialogue: 0,0:09:41.19,0:09:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penonton akan hanyut menonton\Nsambil melakukan hal lain.
Dialogue: 0,0:09:44.61,0:09:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kondisi seperti itu, VTuber menjadi sosok\Nyang mengandalkan suaranya.
Dialogue: 0,0:09:48.19,0:09:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau suaranya tidak disukai penonton,\Nmereka tak akan lama menonton.
Dialogue: 0,0:09:51.28,0:09:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kamu,\Npunya suara yang tenang dan jernih.
Dialogue: 0,0:09:54.78,0:09:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sadar,\Npenonton ingin terus mendengarkan.
Dialogue: 0,0:09:58.16,0:10:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan itu saja, kamu sudah\Npunya bakat sebagai VTuber.
Dialogue: 0,0:10:01.71,0:10:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin suaramu lebih baik\Ndari Momotose Ao.
Dialogue: 0,0:10:05.08,0:10:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu berlebihan memujiku!
Dialogue: 0,0:10:07.09,0:10:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantatku sampai berdenyut!
Dialogue: 0,0:10:09.17,0:10:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kubilang,\Naku tidak suka menyanjung.
Dialogue: 0,0:10:13.05,0:10:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau tak ada yang mendengar suaramu,\Ntidak akan ada yang terjadi.
Dialogue: 0,0:10:16.68,0:10:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, yang dibutuhkan adalah\Nkolaborasi dengan talenta lain di atasmu.
Dialogue: 0,0:10:21.31,0:10:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan jadi tamu penyiar populer.
Dialogue: 0,0:10:24.73,0:10:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu mereka dengar suaramu,\Nmereka pasti akan tertarik padamu.
Dialogue: 0,0:10:29.07,0:10:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:10:29.98,0:10:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya ada yang mau kolaborasi denganku?
Dialogue: 0,0:10:32.95,0:10:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah cari banyak info.
Dialogue: 0,0:10:35.11,0:10:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini VTuber dengan lebih\Ndari 150 ribu pelanggan, Kon Piler.
Dialogue: 0,0:10:38.95,0:10:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang mencari peserta\Nuntuk proyek media sosialnya.
Dialogue: 0,0:10:42.33,0:10:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Proyek?
Dialogue: 0,0:10:43.83,0:10:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacu pesat gim horor.
Dialogue: 0,0:10:47.84,0:10:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan mendekati VTuber\Nyang bisa main pacu pesat.
Dialogue: 0,0:10:52.59,0:10:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NMau coba?
Dialogue: 0,0:10:55.13,0:10:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ayo coba.
Dialogue: 0,0:10:56.76,0:10:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga kamu akan setuju!
Dialogue: 0,0:10:58.64,0:11:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita punya waktu untuk latihan main\Ndan akan siaran minggu depan.
Dialogue: 0,0:11:04.18,0:11:05.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:11:05.10,0:11:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlepas hasilnya, kamu hebat\Nsetuju menerima tantangan apa pun.
Dialogue: 0,0:11:08.69,0:11:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu kamu cuma bisa siaran mengobrol saja.
Dialogue: 0,0:11:11.73,0:11:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bermimpi.
Dialogue: 0,0:11:13.61,0:11:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi?
Dialogue: 0,0:11:14.19,0:11:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi impianku terwujud.
Dialogue: 0,0:11:16.16,0:11:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, apa impiannya?
Dialogue: 0,0:11:20.49,0:11:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kuberi tahu!
Dialogue: 0,0:11:24.33,0:11:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bikin kesal!
Dialogue: 0,0:11:26.71,0:11:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kuberi tahu, tapi...
Dialogue: 0,0:11:35.84,0:11:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, hai-ko!
Dialogue: 0,0:11:37.97,0:11:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku mau coba pacu pesat gim horor\Nyang sedang ramai di internet.
Dialogue: 0,0:11:42.14,0:11:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku siaran\Ngim horor, jadi gugup!
Dialogue: 0,0:11:45.77,0:11:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gimnya sebenarnya pendek...
Dialogue: 0,0:11:48.15,0:11:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah meninjau siarannya Kirino...
Dialogue: 0,0:11:50.77,0:11:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lumayan punya intuisi bermain gim.
Dialogue: 0,0:11:52.90,0:11:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena ini cuma gim\Nmenembak zombi biasa.
Dialogue: 0,0:11:56.15,0:11:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu genre kesukaannya.
Dialogue: 0,0:11:58.57,0:12:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada peluang sangat tinggi\Ndia akan terpilih.
Dialogue: 0,0:12:03.45,0:12:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Kirino!
Dialogue: 0,0:12:04.91,0:12:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak zombi-zombi itu demi mimpimu!
Dialogue: 0,0:12:08.00,0:12:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil senjata di sini\Nlalu buat ramuan pemulihnya.
Dialogue: 0,0:12:11.84,0:12:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus pasang jebakannya di sini!
Dialogue: 0,0:12:14.67,0:12:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghindar dengan berguling!
Dialogue: 0,0:12:16.34,0:12:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tipe yang main\Nsambil badannya ikut gerak, ya.
Dialogue: 0,0:12:18.72,0:12:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemajuannya bagus.
Dialogue: 0,0:12:20.68,0:12:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lajunya begini, akan lancar.
Dialogue: 0,0:12:30.31,0:12:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!\NJangan ke sini!
Dialogue: 0,0:12:32.23,0:12:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku akan dimakan!
Dialogue: 0,0:12:34.73,0:12:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dimakan\Nlalu garis keturunanku terputus!
Dialogue: 0,0:12:37.99,0:12:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, jangan lepaskan konsolnya.
Dialogue: 0,0:12:40.57,0:12:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita melakukan ini untuk latihan!
Dialogue: 0,0:12:42.99,0:12:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegang konsolnya!
Dialogue: 0,0:12:44.16,0:12:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku tidak suka gim horor.
Dialogue: 0,0:12:49.58,0:12:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa tepat kena wajahku?
Dialogue: 0,0:12:51.79,0:12:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sanggup!
Dialogue: 0,0:12:53.38,0:12:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi aku bisa ngompol!
Dialogue: 0,0:12:55.30,0:12:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau keluar bisa gawat!
Dialogue: 0,0:12:58.80,0:13:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamabuki menyuruh Iko main gim horor.
Dialogue: 0,0:13:01.76,0:13:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:13:03.05,0:13:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Iko tidak suka gim berbau horor.
Dialogue: 0,0:13:10.52,0:13:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, obrolannya heboh\Ndan pelangganmu juga bertambah.
Dialogue: 0,0:13:14.44,0:13:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tak bisa kolaborasi, ya?
Dialogue: 0,0:13:17.07,0:13:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gimnya seperti ini, sepertinya sulit.
Dialogue: 0,0:13:19.49,0:13:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti percuma.
Dialogue: 0,0:13:21.32,0:13:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu sudah repot-repot\Nmencoba membantuku.
Dialogue: 0,0:13:24.45,0:13:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku tak bisa\Nmelakukannya dengan benar?
Dialogue: 0,0:13:26.99,0:13:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap orang punya kelebihan dan kekurangan.
Dialogue: 0,0:13:29.37,0:13:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahku karena tidak minta persetujuanmu.
Dialogue: 0,0:13:31.29,0:13:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:13:32.37,0:13:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bilang\Nakan menunjukkan mimpiku padamu.
Dialogue: 0,0:13:36.25,0:13:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, kapan pun pasti mustahil.
Dialogue: 0,0:13:38.59,0:13:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bahkan sudah memujiku,\Ntapi semuanya jadi sia-sia.
Dialogue: 0,0:13:48.27,0:13:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, VTuber itu menarik, ya?
Dialogue: 0,0:13:51.64,0:13:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:52.23,0:13:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirino, kenapa turnamen Koshien,\Nyang tingkatnya semi pro,
Dialogue: 0,0:13:54.77,0:13:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jauh lebih populer dari liga profesional?
Dialogue: 0,0:13:57.36,0:13:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena banyak fetis kepala botak.
Dialogue: 0,0:13:59.11,0:14:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan buat asumsi mengerikan begitu.
Dialogue: 0,0:14:01.03,0:14:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Drama kerja keras\Npara pemain sebelum turnamen.
Dialogue: 0,0:14:04.95,0:14:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada peristiwa tak terduga\Nkarena kurangnya pengalaman.
Dialogue: 0,0:14:07.79,0:14:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakat teknis murni saja tidak cukup\Nuntuk menggerakkan hati orang-orang.
Dialogue: 0,0:14:12.66,0:14:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}VTuber juga begitu.
Dialogue: 0,0:14:14.33,0:14:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang akan menyukaimu\Nselama usaha dan perasaanmu ditunjukkan.
Dialogue: 0,0:14:18.80,0:14:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kekuranganmu bisa jadi senjatamu.
Dialogue: 0,0:14:21.13,0:14:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuranganku jadi senjata?
Dialogue: 0,0:14:22.80,0:14:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klip siaran langsungmu masuk daftar tren!
Dialogue: 0,0:14:27.14,0:14:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, serius? Kenapa?
Dialogue: 0,0:14:29.22,0:14:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penonton suka reaksimu yang berlebihan.
Dialogue: 0,0:14:31.56,0:14:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu tidak suka gim horor,\Nini bisa mencapai banyak orang.
Dialogue: 0,0:14:35.94,0:14:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini akan viral\Ndan Kon Piler melihatnya.
Dialogue: 0,0:14:42.74,0:14:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:14:44.11,0:14:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi takut ternyata kelebihan, ya.
Dialogue: 0,0:14:46.24,0:14:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, klipnya seperti apa?
Dialogue: 0,0:14:48.53,0:14:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lihat?
Dialogue: 0,0:14:52.04,0:14:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ngompol!
Dialogue: 0,0:14:54.21,0:14:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, thumbnail itu penting\Nuntuk dapat impak bagus.
Dialogue: 0,0:14:56.67,0:14:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, mustahil aku akan dipanggil!
Dialogue: 0,0:14:59.34,0:15:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak pernah tahu.
Dialogue: 0,0:15:02.80,0:15:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, teleponmu berdering.
Dialogue: 0,0:15:05.13,0:15:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu undangan dari Kon Piler!
Dialogue: 0,0:15:08.60,0:15:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mustahil!
Dialogue: 0,0:15:13.56,0:15:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Ba-Bagaimana...
Dialogue: 0,0:15:15.06,0:15:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini, Bukki?
Dialogue: 0,0:15:16.23,0:15:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenangkan dirimu, Kirino!
Dialogue: 0,0:15:18.44,0:15:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undangan kolaborasi\Ndari VTuber top, Momotose Ao?
Dialogue: 0,0:15:21.69,0:15:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka ini bisa sampai ke VTuber monster\Nyang punya tiga juga pelanggan!
Dialogue: 0,0:15:25.07,0:15:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan bagiku, ini terlalu mendebarkan!
Dialogue: 0,0:15:28.12,0:15:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan untuk Kirino\Ndikenal secara nasional!
Dialogue: 0,0:15:30.99,0:15:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku langsung kolaborasi Ao!
Dialogue: 0,0:15:34.00,0:15:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baca pelan-pelan!\NDi awal, kamu itu satu dari banyak orang!
Dialogue: 0,0:15:37.88,0:15:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari 50 VTuber akan ambil bagian\Ndi Piala Ao, turnamen gim video.
Dialogue: 0,0:15:41.50,0:15:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya pemain terbaik yang dapat kesempatan\Nuntuk menghadapi Momotose Ao.
Dialogue: 0,0:15:45.01,0:15:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa berinteraksi langsung dengannya\Nkalau lolos di babak penyisihan.
Dialogue: 0,0:15:49.51,0:15:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gim yang akan mereka mainkan\Nadalah gim balap Nyandora.
Dialogue: 0,0:15:53.93,0:15:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gim ini, aku ahlinya!
Dialogue: 0,0:15:55.89,0:15:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:15:56.64,0:16:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lewati babak penyisihan\Ndan tampil di layar bersama Momotose Ao!
Dialogue: 0,0:16:00.02,0:16:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku akan berusaha!
Dialogue: 0,0:16:01.90,0:16:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiper berusaha!
Dialogue: 0,0:16:04.65,0:16:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ditentukan! Kita latihan!
Dialogue: 0,0:16:11.91,0:16:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kon-Ao!
Dialogue: 0,0:16:13.41,0:16:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piala Ao akhirnya dimulai, ya!
Dialogue: 0,0:16:15.70,0:16:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertandingan panas satu lawan satu\Ndenganku akan dimulai!
Dialogue: 0,0:16:19.33,0:16:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari wajah familier sampai wajah baru\Npotensi kuda hitam,
Dialogue: 0,0:16:22.29,0:16:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini turnamen serius tanpa naskah,\Njadi dukung mereka semua, ya!
Dialogue: 0,0:16:25.84,0:16:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, aku kan tampilkan\Npembagian babak penyisihannya!
Dialogue: 0,0:16:29.30,0:16:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dimulai.
Dialogue: 0,0:16:32.35,0:16:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, Grup Khusus A!
Dialogue: 0,0:16:34.77,0:16:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup ini sebenarnya diisi\Noleh para VTuber bermasalah!
Dialogue: 0,0:16:40.48,0:16:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:16:41.65,0:16:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memisahkan para VTuber\Nyang ada riwayat ditolak agensi
Dialogue: 0,0:16:44.52,0:16:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kemungkinan besar akan diblokir.\Nkarena terlalu ekstrem
Dialogue: 0,0:16:48.03,0:16:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang paling menonjol di antara mereka
Dialogue: 0,0:16:51.16,0:16:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Sumeragi Ikon!
Dialogue: 0,0:16:52.91,0:16:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat bermasalah dan tren\Nkarena mengompol saat siaran!
Dialogue: 0,0:16:56.58,0:16:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ngompol!
Dialogue: 0,0:16:58.91,0:17:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan dia ditempatkan di slot melawak?
Dialogue: 0,0:17:02.04,0:17:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kalau menang, hadiahnya apa?
Dialogue: 0,0:17:07.05,0:17:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jadi pelangganku!
Dialogue: 0,0:17:08.42,0:17:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menang, aku akan kasih ciuman!
Dialogue: 0,0:17:11.18,0:17:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muah!
Dialogue: 0,0:17:12.05,0:17:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak butuh, Jelek!
Dialogue: 0,0:17:13.97,0:17:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka Ikon yang menciumku!
Dialogue: 0,0:17:17.56,0:17:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lihat kamu mengerutkan bibirmu!\NTiga, dua, satu...
Dialogue: 0,0:17:21.19,0:17:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:23.19,0:17:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muah...
Dialogue: 0,0:17:25.69,0:17:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia juga jelek!
Dialogue: 0,0:17:27.78,0:17:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajah ciuman?
Dialogue: 0,0:17:29.44,0:17:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikon, jangan bilang kamu ngompol sekarang?
Dialogue: 0,0:17:31.91,0:17:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Avatarku tidak ada fitur itu,\Njadi cuma bisa begini.
Dialogue: 0,0:17:35.66,0:17:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan lagi.\NKamu ngompol, kan?
Dialogue: 0,0:17:39.08,0:17:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:17:40.08,0:17:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guyonan seperti ini bukan keahlian Kirino!
Dialogue: 0,0:17:43.58,0:17:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius!
Dialogue: 0,0:17:45.92,0:17:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirino! Fokus untuk menang saja!
Dialogue: 0,0:17:49.84,0:17:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti bisa!
Dialogue: 0,0:17:51.55,0:17:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan hasil kerja kerasmu!
Dialogue: 0,0:17:56.76,0:17:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haa...
Dialogue: 0,0:17:59.02,0:18:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menang!
Dialogue: 0,0:18:01.10,0:18:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kamu beruntung!
Dialogue: 0,0:18:03.52,0:18:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmat!
Dialogue: 0,0:18:06.40,0:18:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Bukki, aku kalah...
Dialogue: 0,0:18:08.90,0:18:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat, hasil kadang\Ntergantung keberuntungan.
Dialogue: 0,0:18:12.03,0:18:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang kalah, kita berpisah di sini!
Dialogue: 0,0:18:14.91,0:18:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang menang,\Nsilakan beralih ke siaran berikutnya!
Dialogue: 0,0:18:18.33,0:18:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kalah dalam pertandingan?\NSelain itu, di posisi terakhir!
Dialogue: 0,0:18:23.12,0:18:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harusnya riset lebih banyak tentang gim.
Dialogue: 0,0:18:25.54,0:18:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, daripada itu, aku harusnya sadar\Ndia akan diperlakukan seperti ini!
Dialogue: 0,0:18:30.09,0:18:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat memalukan!
Dialogue: 0,0:18:32.47,0:18:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak dimaafkan,\Nbagi aku yang perfeksionis!
Dialogue: 0,0:18:38.56,0:18:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirino, maafkan aku.
Dialogue: 0,0:18:40.64,0:18:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua salahku.
Dialogue: 0,0:18:42.85,0:18:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Mereka semua luar biasa, ya!
Dialogue: 0,0:18:45.85,0:18:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya hebat, aku sampai kaget!
Dialogue: 0,0:18:47.86,0:18:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sempat berbicara dengan Ao,
Dialogue: 0,0:18:50.53,0:18:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku sangat senang\Ndengan eksposur yang kudapatkan!
Dialogue: 0,0:18:53.28,0:18:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Kirino, kamu tidak kesal\Ndiperlakukan begitu?
Dialogue: 0,0:18:57.41,0:19:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang kesal tak bisa membalas mereka.
Dialogue: 0,0:19:01.87,0:19:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, aku lebih senang bisa sampai\Nke panggung sebesar ini berkat usaha kita berdua!
Dialogue: 0,0:19:09.09,0:19:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kita akan mampu\Nmencapai titik yang lebih tinggi!
Dialogue: 0,0:19:15.30,0:19:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak terpikirkan\Ncara berpikir seperti itu.
Dialogue: 0,0:19:18.60,0:19:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku terlalu fokus pada peringkat.
Dialogue: 0,0:19:21.56,0:19:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kegembiraanmu itu prioritas.
Dialogue: 0,0:19:24.77,0:19:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NKamu gembira?
Dialogue: 0,0:19:26.85,0:19:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:19:27.56,0:19:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:19:29.02,0:19:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:19:30.40,0:19:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan memaafkan mereka bertiga\Nkarena sudah mengejekmu!
Dialogue: 0,0:19:33.94,0:19:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya mereka menyakiti Kirino-ku\Ndi depan mataku!
Dialogue: 0,0:19:37.03,0:19:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Momotose Ao!
Dialogue: 0,0:19:38.78,0:19:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengundang tapi tak menyapa,\Ndasar tidak sopan!
Dialogue: 0,0:19:40.99,0:19:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Kirino!
Dialogue: 0,0:19:42.49,0:19:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus balas dendam!
Dialogue: 0,0:19:44.20,0:19:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya kita akan berhadapan\Nlangsung dengan Momotose Ao!
Dialogue: 0,0:19:47.83,0:19:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukki, yang barusan itu...
Dialogue: 0,0:19:57.34,0:19:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ao meneleponku!
Dialogue: 0,0:19:59.26,0:20:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NBiar aku yang bicara dengannya!
Dialogue: 0,0:20:01.60,0:20:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, Bukki! Diam!
Dialogue: 0,0:20:07.39,0:20:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:20:08.77,0:20:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Momotose Ao.\NTerima kasih sudah berpartisipasi.
Dialogue: 0,0:20:11.40,0:20:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berbicara dengan semua\Npenyiar yang terlibat.
Dialogue: 0,0:20:14.11,0:20:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf tidak meneleponmu lebih awal.
Dialogue: 0,0:20:15.82,0:20:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak perlu meminta maaf!
Dialogue: 0,0:20:18.28,0:20:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sudah diundang\Nuntuk berpartisipasi.
Dialogue: 0,0:20:22.28,0:20:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal yang tadi, ya.
Dialogue: 0,0:20:25.00,0:20:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memasukkanmu ke grup itu\Nsambil berpikir akan seru.
Dialogue: 0,0:20:28.50,0:20:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka malah terbawa suasana.
Dialogue: 0,0:20:30.79,0:20:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak merasa terganggu dengan itu!
Dialogue: 0,0:20:33.21,0:20:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bekerja sama denganmu lagi\Nkalau ada kesempatan!
Dialogue: 0,0:20:36.05,0:20:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghubungimu lagi.
Dialogue: 0,0:20:38.01,0:20:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa mengundang orang\Ndi belakangmu lagi nanti.
Dialogue: 0,0:20:43.18,0:20:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perkembanganmu belakangan ini
Dialogue: 0,0:20:45.43,0:20:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kamu dibantu oleh orang\Nyang otaknya luar biasa, kan?
Dialogue: 0,0:20:48.39,0:20:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku juga ingin bicara\Ndengan orang di belakangmu, ya.
Dialogue: 0,0:20:53.61,0:20:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa!
Dialogue: 0,0:20:55.78,0:20:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukki, dia tahu!
Dialogue: 0,0:20:57.53,0:20:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:58.65,0:20:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:20:59.53,0:21:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa tahu aku terlibat\Nhanya lewat video?
Dialogue: 0,0:21:03.41,0:21:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:21:05.16,0:21:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini puncaknya VTuber, ya!
Dialogue: 0,0:21:09.29,0:21:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih sangat jauh.
Dialogue: 0,0:21:12.21,0:21:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, suatu hari nanti, pasti...
Dialogue: 0,0:21:16.38,0:21:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Kirino?
Dialogue: 0,0:21:18.34,0:21:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal tadi, aku kaget.
Dialogue: 0,0:21:21.38,0:21:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal apa?
Dialogue: 0,0:21:26.14,0:21:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:28.73,0:21:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu! Wajah itu...
Dialogue: 0,0:21:31.06,0:21:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, yang tadi itu...
Dialogue: 0,0:21:32.65,0:21:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:21:34.69,0:21:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini wajahku yang kebelet ke toilet.
Dialogue: 0,0:21:38.07,0:21:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toilet?
Dialogue: 0,0:21:39.99,0:21:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi jantungku berdegup kencang.
Dialogue: 0,0:21:43.32,0:21:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Beraninya mereka menyakiti Kirino-ku\Ndi depan mataku!"
Dialogue: 0,0:21:46.20,0:21:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak!\NMaaf, aku begitu karena marah!
Dialogue: 0,0:21:49.66,0:21:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku salah bicara!
Dialogue: 0,0:21:55.38,0:21:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melakukan yang terbaik.
Dialogue: 0,0:21:58.55,0:22:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kamu katakan.
Dialogue: 0,0:22:02.22,0:22:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, bukan dari jarak sejauh ini.
