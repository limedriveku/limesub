Dialogue: 0,0:01:00.20,0:01:01.03,tanda,,0000,0000,0000,,UZUKI SHINOBU
Dialogue: 0,0:01:02.04,0:01:03.16,tanda,,0000,0000,0000,,KIRINO IKO
Dialogue: 0,0:01:03.91,0:01:05.04,tanda,,0000,0000,0000,,HIMEKAWA NENE
Dialogue: 0,0:01:05.66,0:01:07.08,tanda,,0000,0000,0000,,INOHANA RIKKA
Dialogue: 0,0:01:07.08,0:01:09.51,tanda,,0000,0000,0000,,TUNE IN TO THE MIDNIGHT HEART
Dialogue: 0,0:01:42.32,0:01:43.42,tanda,,0000,0000,0000,,APOLLO?
Dialogue: 0,0:02:17.66,0:02:20.01,tanda,,0000,0000,0000,,TUNE IN TO THE MIDNIGHT HEART
Dialogue: 0,0:02:20.01,0:02:23.00,tanda,,0000,0000,0000,,SMA FURIN
Dialogue: 0,0:03:39.95,0:03:42.45,tanda,,0000,0000,0000,,RUANG SIARAN (SEMENTARA)
Dialogue: 0,0:06:03.09,0:06:05.09,tanda,,0000,0000,0000,,RUANG SIARAN (SEMENTARA)
Dialogue: 0,0:07:25.30,0:07:26.26,tanda,,0000,0000,0000,,RUANG SIARAN (SEMENTARA)
Dialogue: 0,0:10:50.96,0:10:53.97,tanda,,0000,0000,0000,,CIUM ATAU PELUK
Dialogue: 0,0:10:53.97,0:10:56.55,tanda,,0000,0000,0000,,SMA FURIN
Dialogue: 0,0:18:55.74,0:18:57.49,tanda,,0000,0000,0000,,CINTA RIKKA, RIKKA SELAMANYA,\NRIKKA YANG TERBAIK
Dialogue: 0,0:22:06.97,0:22:09.98,tanda,,0000,0000,0000,,ANGIN HITAM HUJAN PUTIH
Dialogue: 0,0:00:06.15,0:00:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kesusul!
Dialogue: 0,0:00:07.78,0:00:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka terlalu cepat!
Dialogue: 0,0:00:10.16,0:00:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, posisi terakhir!
Dialogue: 0,0:00:12.06,0:00:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lawannya susah.
Dialogue: 0,0:00:14.29,0:00:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang kalah, kita berpisah di sini!
Dialogue: 0,0:00:16.91,0:00:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang menang,\Nsilakan beralih ke siaran berikutnya!
Dialogue: 0,0:00:20.52,0:00:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, hebat, ya.\NSampai dipanggil penyiar besar.
Dialogue: 0,0:00:24.42,0:00:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Yamabuki punya andil.
Dialogue: 0,0:00:26.80,0:00:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu ikut campur dalam segala hal, ya.
Dialogue: 0,0:00:29.47,0:00:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga sampai mengirim sepuluh\Npamflet rekomendasi sekolah seiyu.
Dialogue: 0,0:00:33.64,0:00:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga seenaknya menentukan\Njadwal konser jalananku.
Dialogue: 0,0:00:36.77,0:00:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat berlebihnya itu\Nberpotensi jadi penguntit.
Dialogue: 0,0:00:39.69,0:00:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu.
Dialogue: 0,0:02:24.21,0:02:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada segmen baru\Ndi siaran siang mulai minggu ini!
Dialogue: 0,0:02:27.46,0:02:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tak sabar!
Dialogue: 0,0:02:29.05,0:02:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bersihkan telinga dulu.
Dialogue: 0,0:02:30.80,0:02:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jijik!
Dialogue: 0,0:02:34.05,0:02:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinobu, semangat!
Dialogue: 0,0:02:36.11,0:02:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:02:37.47,0:02:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waketos, aku menantikan segmen barunya!
Dialogue: 0,0:02:40.01,0:02:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha!
Dialogue: 0,0:02:42.56,0:02:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nene, kamu tidak makan siang?
Dialogue: 0,0:02:44.02,0:02:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang diet!
Dialogue: 0,0:02:47.90,0:02:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nene, semangat!
Dialogue: 0,0:02:49.65,0:02:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:02:55.61,0:02:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Inohana.
Dialogue: 0,0:02:58.07,0:02:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukis ini untukmu.
Dialogue: 0,0:02:59.66,0:03:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan nikmati selagi siaran!
Dialogue: 0,0:03:03.00,0:03:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:07.75,0:03:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iko, siarannya sebentar lagi dimulai!
Dialogue: 0,0:03:19.64,0:03:21.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bento hari ini menunya apa, ya?
Dialogue: 0,0:03:21.89,0:03:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa sudah antusias buatnya!\NJadi tidak sabar!
Dialogue: 0,0:03:29.02,0:03:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, sepertinya perutku keroncongan.
Dialogue: 0,0:03:31.57,0:03:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus makan onigiri.
Dialogue: 0,0:03:34.61,0:03:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku lihat kamu senyum saat tidur.\NKamu mimpi indah?
Dialogue: 0,0:03:38.36,0:03:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kuberi tahu.
Dialogue: 0,0:03:43.70,0:03:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dengan Ekskul Siaran\Nyang sedang makan siang.
Dialogue: 0,0:03:47.46,0:03:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kami sedang siaran\Ndengan peralatan baru.
Dialogue: 0,0:03:53.50,0:03:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang merasakan perbedaannya?
Dialogue: 0,0:03:55.59,0:03:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Deraunya harusnya berkurang.
Dialogue: 0,0:03:57.68,0:04:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Program siarannya kami rombak juga,\Njadi nantikan, ya!
Dialogue: 0,0:04:01.47,0:04:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari langsung ke segmen baru kita:\NRuang Curhat Cinta kita!
Dialogue: 0,0:04:07.19,0:04:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curhat pertama dari nama samaran: Nekko.
Dialogue: 0,0:04:10.42,0:04:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya lebih jernih, ya!
Dialogue: 0,0:04:12.61,0:04:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terdengar lembut di telinga.
Dialogue: 0,0:04:15.82,0:04:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku pikir pacarku selingkuh,\Ntapi aku terlalu takut untuk bertanya."
Dialogue: 0,0:04:20.27,0:04:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru mulai langsung topik yang berat.
Dialogue: 0,0:04:22.12,0:04:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung putuskan saja!
Dialogue: 0,0:04:23.78,0:04:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Retas ponselnya dan cek isi pesannya.
Dialogue: 0,0:04:26.54,0:04:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan dengan selingkuh juga.
Dialogue: 0,0:04:28.25,0:04:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, kalian gampang naik darah!
Dialogue: 0,0:04:31.12,0:04:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, sarannya apa, ya?
Dialogue: 0,0:04:34.42,0:04:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intip ponselnya.
Dialogue: 0,0:04:36.13,0:04:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau selingkuh, cari pacar baru\Ndan buang si tukang selingkuh!
Dialogue: 0,0:04:38.93,0:04:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru kamu yang paling naik darah!
Dialogue: 0,0:04:40.97,0:04:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang membuat Shinobu hebat.
Dialogue: 0,0:04:43.93,0:04:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamabuki, bukankah kamu\Nharusnya di ruangan ekskul juga?
Dialogue: 0,0:04:46.81,0:04:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saran cinta bukan keahlianku.
Dialogue: 0,0:04:49.35,0:04:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa aku lakukan di sana\Ncuma menuruti keinginan mereka.
Dialogue: 0,0:04:52.44,0:04:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tidak tahu diri!
Dialogue: 0,0:04:54.40,0:04:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rela membunuh agar bisa\Nmenuruti Shinobu!
Dialogue: 0,0:04:56.98,0:04:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa terus mengawasi mereka.
Dialogue: 0,0:04:59.74,0:05:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka harus bisa melakukan ini sendirian.
Dialogue: 0,0:05:03.49,0:05:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih untuk makanannya.
Dialogue: 0,0:05:05.27,0:05:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pencuci mulut.
Dialogue: 0,0:05:06.83,0:05:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nafsu makanmu besar, ya.
Dialogue: 0,0:05:08.69,0:05:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, curhat selanjutnya\Ndari nama samaran: Itachi.
Dialogue: 0,0:05:13.38,0:05:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ada seseorang yang aku suka,
Dialogue: 0,0:05:16.00,0:05:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sepertinya dia tak acuh\Nsaat aku menatapnya."
Dialogue: 0,0:05:18.55,0:05:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Apa aku punya peluang?"
Dialogue: 0,0:05:20.30,0:05:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, getir, ya!\NSedang ABG, ya?
Dialogue: 0,0:05:23.09,0:05:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Mesum!
Dialogue: 0,0:05:24.76,0:05:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana pendapatmu, Shinobu?
Dialogue: 0,0:05:27.89,0:05:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa menatap matanya, ya?
Dialogue: 0,0:05:49.33,0:05:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku ada peluang.
Dialogue: 0,0:05:51.50,0:05:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa wajahmu memerah, Shinobu?
Dialogue: 0,0:05:54.04,0:05:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu cuma perasaan dia saja.
Dialogue: 0,0:05:57.00,0:06:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itachi, kami menantikan kabar barumu!
Dialogue: 0,0:06:05.55,0:06:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, terima kasih\Natas semua kiriman kalian.
Dialogue: 0,0:06:09.02,0:06:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari nama samaran: Itachi.
Dialogue: 0,0:06:10.47,0:06:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kami sepakat untuk makan bersama.\NMenu apa yang harus kupilih?"
Dialogue: 0,0:06:15.56,0:06:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada progres! Hebat!
Dialogue: 0,0:06:18.15,0:06:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi peluang dia ada, ya.
Dialogue: 0,0:06:19.65,0:06:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah makan bareng?\NKedengarannya agak mesum!
Dialogue: 0,0:06:22.95,0:06:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gebetannya juga gampangan banget.
Dialogue: 0,0:06:24.82,0:06:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya mereka makan apa, ya?
Dialogue: 0,0:06:27.24,0:06:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal ini saran kita cuma selera.
Dialogue: 0,0:06:28.91,0:06:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Iko, kamu mau makan apa?
Dialogue: 0,0:06:31.04,0:06:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku...
Dialogue: 0,0:06:37.13,0:06:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya\Naku makan okonomiyaki di tempat,
Dialogue: 0,0:06:40.30,0:06:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan wajan panasnya membuatku takut.
Dialogue: 0,0:06:42.88,0:06:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balikkan, tambahkan saus, lalu selesai.
Dialogue: 0,0:06:46.01,0:06:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membaliknya.
Dialogue: 0,0:06:47.85,0:06:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:06:51.68,0:06:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah!
Dialogue: 0,0:06:54.44,0:06:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:07:01.15,0:07:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, jangan terlalu kasar membaliknya.
Dialogue: 0,0:07:04.95,0:07:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkat perlahan seperti ini.
Dialogue: 0,0:07:09.08,0:07:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pilih okonomiyaki.
Dialogue: 0,0:07:11.91,0:07:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tumben.
Dialogue: 0,0:07:13.50,0:07:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kedengarannya enak.
Dialogue: 0,0:07:14.96,0:07:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang-senang sambil makan.
Dialogue: 0,0:07:16.67,0:07:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iko suka okonomiyaki, ya?
Dialogue: 0,0:07:20.17,0:07:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ajak makan okonomiyaki bareng!
Dialogue: 0,0:07:26.26,0:07:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itachi menulis surat untuk kita lagi.
Dialogue: 0,0:07:29.89,0:07:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Progres kami makin berkembang\Nselagi kalian membaca ini!"
Dialogue: 0,0:07:33.14,0:07:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tahap selanjutnya,\Napa yang harus kulakukan?"
Dialogue: 0,0:07:36.02,0:07:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku terlalu gugup untuk bicara dengannya!"
Dialogue: 0,0:07:38.15,0:07:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang?
Dialogue: 0,0:07:39.19,0:07:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Progresnya jadi panas!
Dialogue: 0,0:07:40.77,0:07:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal mesum sedang terjadi di sekolah ini!
Dialogue: 0,0:07:43.94,0:07:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu dorongan terakhir, ya?
Dialogue: 0,0:07:45.61,0:07:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak dia pasti akan berhasil, kan?
Dialogue: 0,0:07:48.74,0:07:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia tak bisa bicara dengannya.
Dialogue: 0,0:07:50.87,0:07:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah di tahap itu, tinggal bilang!
Dialogue: 0,0:07:53.45,0:07:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertaruh ayam gorengku\Nkalau mereka akan pacaran.
Dialogue: 0,0:07:55.79,0:07:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti yang harus dilakukan cuma satu hal.
Dialogue: 0,0:07:58.29,0:07:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang.
Dialogue: 0,0:08:00.20,0:08:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu
Dialogue: 0,0:08:00.96,0:08:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- harus memeluknya.\N- harus menciumnya.
Dialogue: 0,0:08:03.80,0:08:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:06.09,0:08:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru mulai langsung ciuman itu\Nbukan opsi bagus, Nene.
Dialogue: 0,0:08:08.59,0:08:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kesantunanmu sudah rusak?
Dialogue: 0,0:08:10.51,0:08:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:11.47,0:08:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal kamu tahu, maksudku itu cium di pipi!
Dialogue: 0,0:08:14.01,0:08:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri, langsung pelukan?
Dialogue: 0,0:08:16.02,0:08:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma orang mesum\Nyang tiba-tiba kontak fisik!
Dialogue: 0,0:08:19.31,0:08:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelukan dianggap sebagai salam di Barat.
Dialogue: 0,0:08:21.81,0:08:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman juga sama!
Dialogue: 0,0:08:24.59,0:08:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinobu, kita harus matikan mikrofonnya!
Dialogue: 0,0:08:27.07,0:08:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan jadi berantem.
Dialogue: 0,0:08:28.32,0:08:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju!
Dialogue: 0,0:08:30.24,0:08:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, kalian berdua!
Dialogue: 0,0:08:31.99,0:08:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya malah jadi tak terkendali.
Dialogue: 0,0:08:35.58,0:08:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, kita tak bisa beri saran\Nkalau belum mengalaminya!
Dialogue: 0,0:08:39.00,0:08:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku sudah mengalaminya.
Dialogue: 0,0:08:41.28,0:08:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:42.74,0:08:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu... maaf.
Dialogue: 0,0:08:45.34,0:08:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinobu langsung lembek!
Dialogue: 0,0:08:46.80,0:08:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku pelukan itu boleh.
Dialogue: 0,0:08:48.26,0:08:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman juga boleh!
Dialogue: 0,0:08:54.47,0:08:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kamu lebih suka peluk, kan?
Dialogue: 0,0:08:56.97,0:08:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lebih suka cium, kan?
Dialogue: 0,0:08:58.89,0:09:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:09:00.19,0:09:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih yang mana?
Dialogue: 0,0:09:01.85,0:09:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh!
Dialogue: 0,0:09:08.11,0:09:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kamu lebih suka yang mana,\Nciuman atau pelukan?
Dialogue: 0,0:09:12.41,0:09:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih saja ngotot!
Dialogue: 0,0:09:15.16,0:09:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu malu.
Dialogue: 0,0:09:17.50,0:09:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mikrofonnya sudah dimatikan.
Dialogue: 0,0:09:20.16,0:09:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu...
Dialogue: 0,0:09:21.12,0:09:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian belum mematikan mikrofonnya.
Dialogue: 0,0:09:23.58,0:09:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Inohana dan Himekawa\Npernah pacaran, ya!
Dialogue: 0,0:09:27.30,0:09:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin dipeluk Rikka!
Dialogue: 0,0:09:29.42,0:09:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nene, cium aku!
Dialogue: 0,0:09:31.22,0:09:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, salah tombol.
Dialogue: 0,0:09:33.76,0:09:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinobu, dasar bodoh!
Dialogue: 0,0:09:35.81,0:09:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, reputasiku!
Dialogue: 0,0:09:40.31,0:09:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akhiri siarannya!
Dialogue: 0,0:09:42.60,0:09:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagaimana dengan saran untuk Itachi?
Dialogue: 0,0:09:45.77,0:09:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan mereka pasti lancar.
Dialogue: 0,0:09:48.62,0:09:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tadi itu suram!
Dialogue: 0,0:09:51.53,0:09:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tumben kamu kemari, Lemon.
Dialogue: 0,0:09:54.16,0:09:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau dengar aku curhat?
Dialogue: 0,0:09:55.53,0:09:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi guru cantik itu sengsara.
Dialogue: 0,0:09:58.74,0:10:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak rias di ruang gantimu saja?
Dialogue: 0,0:10:01.66,0:10:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tahu Pak Samejima, kan?
Dialogue: 0,0:10:03.79,0:10:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu si monster besar itu?
Dialogue: 0,0:10:06.71,0:10:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini dia menatapku terus.\NAku sampai harus tak acuh.
Dialogue: 0,0:10:11.88,0:10:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus dia mengajakku keluar\Nuntuk makan okonomiyaki.
Dialogue: 0,0:10:15.01,0:10:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju dia yang tanggung bayar makan,
Dialogue: 0,0:10:17.56,0:10:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ternyata dia mengira aku menyukainya.
Dialogue: 0,0:10:20.56,0:10:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, baru saja, saat kami hanya berdua.
Dialogue: 0,0:10:25.65,0:10:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mencoba mencium sekaligus memelukku,\Njadi aku menendangnya.
Dialogue: 0,0:10:29.53,0:10:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Itachi itu kamu!
Dialogue: 0,0:10:35.45,0:10:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, siaran yang tadi bagus, ya.
Dialogue: 0,0:10:38.38,0:10:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kalian mahir soal percintaan.
Dialogue: 0,0:10:41.41,0:10:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tadi itu bukan!
Dialogue: 0,0:10:43.12,0:10:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya cuma bohong!
Dialogue: 0,0:10:44.42,0:10:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Inohana tidak menyangkalnya.
Dialogue: 0,0:10:46.75,0:10:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu diam saja, Rikka?
Dialogue: 0,0:10:49.25,0:10:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku harus mengawasi mereka.
Dialogue: 0,0:10:56.97,0:11:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siaran hari ini semuanya karya fiksi.
Dialogue: 0,0:11:00.89,0:11:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hubungan dengan orang,\Norganisasi, dan peristiwa nyata.
Dialogue: 0,0:11:06.90,0:11:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, semuanya.\NMari belajar giat untuk sisa hari ini.
Dialogue: 0,0:11:11.65,0:11:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak.
Dialogue: 0,0:11:14.03,0:11:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku tidak peduli\Nkalau reputasi kalian rusak,
Dialogue: 0,0:11:18.82,0:11:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hati-hati soal saran percintaannya, ya.
Dialogue: 0,0:11:24.54,0:11:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:11:25.25,0:11:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujannya deras.
Dialogue: 0,0:11:26.79,0:11:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:11:27.79,0:11:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku lupa.
Dialogue: 0,0:11:29.48,0:11:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iko, kamu ada waktu?
Dialogue: 0,0:11:31.80,0:11:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin merencanakan\Nsiaranmu berikutnya.
Dialogue: 0,0:11:34.26,0:11:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.
Dialogue: 0,0:11:35.30,0:11:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma perasaanku saja,
Dialogue: 0,0:11:37.47,0:11:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belakangan ini si Pembantu\Nsering panggil nama Iko.
Dialogue: 0,0:11:40.30,0:11:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia panggil nama dia.
Dialogue: 0,0:11:41.43,0:11:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini mereka dekat, ya.
Dialogue: 0,0:11:44.43,0:11:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat, ya.
Dialogue: 0,0:11:45.89,0:11:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana selanjutnya—
Dialogue: 0,0:11:46.85,0:11:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Pembantu!
Dialogue: 0,0:11:48.56,0:11:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Yamabuki.
Dialogue: 0,0:11:49.98,0:11:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu memanggil Iko\Ndengan nama depannya?
Dialogue: 0,0:11:53.11,0:11:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf.\NAku tidak sadar.
Dialogue: 0,0:11:56.03,0:11:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini kami banyak waktu berdua\Njadi refleks begitu saja.
Dialogue: 0,0:11:59.66,0:12:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu berdua?
Dialogue: 0,0:12:01.28,0:12:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kirino.
Dialogue: 0,0:12:02.41,0:12:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sopan memanggil nama depanmu.
Dialogue: 0,0:12:04.62,0:12:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:12:06.00,0:12:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak terlalu mempermasalahkannya.
Dialogue: 0,0:12:09.38,0:12:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:12:11.00,0:12:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, biar gampang,\Naku panggil kamu Iko.
Dialogue: 0,0:12:13.34,0:12:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:12:14.34,0:12:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, oke, aku paham!
Dialogue: 0,0:12:16.84,0:12:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, apa boleh buat.\NIni pengecualian.
Dialogue: 0,0:12:20.22,0:12:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:21.76,0:12:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga
Dialogue: 0,0:12:23.43,0:12:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membolehkanmu memanggilku Nene.
Dialogue: 0,0:12:26.43,0:12:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:27.35,0:12:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga lebih gampang dipanggil Nene, kan?
Dialogue: 0,0:12:30.35,0:12:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himekawa itu empat suku kata!\NNene dua suku kata!
Dialogue: 0,0:12:33.57,0:12:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih hemat waktu!
Dialogue: 0,0:12:35.57,0:12:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:12:38.24,0:12:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nene.
Dialogue: 0,0:12:45.16,0:12:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, Inohana.\NDia kenapa?
Dialogue: 0,0:12:48.37,0:12:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka.
Dialogue: 0,0:12:50.50,0:12:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga boleh panggil aku Rikka.
Dialogue: 0,0:12:53.46,0:12:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu bilang begitu...
Dialogue: 0,0:12:55.17,0:12:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo coba.
Dialogue: 0,0:12:57.76,0:12:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka.
Dialogue: 0,0:13:00.26,0:13:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telingaku terasa geli.
Dialogue: 0,0:13:01.93,0:13:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alur macam apa ini?
Dialogue: 0,0:13:03.30,0:13:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu malu, ya, Pemuda.
Dialogue: 0,0:13:04.64,0:13:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak malu!
Dialogue: 0,0:13:07.18,0:13:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau alurnya begini,
Dialogue: 0,0:13:08.81,0:13:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus panggil\Nnama depan Uzuki juga?
Dialogue: 0,0:13:12.35,0:13:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:13:13.98,0:13:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal malu.
Dialogue: 0,0:13:16.11,0:13:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:13:17.28,0:13:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu ditolak.
Dialogue: 0,0:13:19.45,0:13:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nene.
Dialogue: 0,0:13:22.87,0:13:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu kelihatan merah.\NSedang demam?
Dialogue: 0,0:13:24.91,0:13:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:25.49,0:13:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kita batalkan belajar bersamanya.
Dialogue: 0,0:13:27.79,0:13:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak apa-apa.
Dialogue: 0,0:13:29.79,0:13:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kita ketemu di tempat biasa.
Dialogue: 0,0:13:35.59,0:13:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shinobu memintamu membantunya belajar?
Dialogue: 0,0:13:39.59,0:13:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut Bukki, pendidikan itu\Npenting bagi seorang penyiar.
Dialogue: 0,0:13:44.64,0:13:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bimbingan dari pembantu pasti repot.
Dialogue: 0,0:13:56.23,0:13:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabannya pilihan kedua.
Dialogue: 0,0:13:58.07,0:14:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatikan preposisinya.
Dialogue: 0,0:14:00.07,0:14:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.\NAku ceroboh, ya.
Dialogue: 0,0:14:03.70,0:14:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pertanyaan panjang,\Ncari dulu posisi subjeknya.
Dialogue: 0,0:14:08.37,0:14:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan dulu kata yang tak kamu paham,\Nbaca santai saja sampai selesai.
Dialogue: 0,0:14:14.25,0:14:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya renyah, ya.
Dialogue: 0,0:14:17.21,0:14:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beruntung dapat yang baru digoreng.\NMau makan setengahnya?
Dialogue: 0,0:14:20.84,0:14:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang diet.\NSatu saja.
Dialogue: 0,0:14:23.93,0:14:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:14:25.26,0:14:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai tangan,\Nnanti buku dan pulpenmu berminyak.
Dialogue: 0,0:14:29.39,0:14:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:14:31.31,0:14:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu. Serius?
Dialogue: 0,0:14:33.10,0:14:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Yamabuki selalu bersih.
Dialogue: 0,0:14:35.38,0:14:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebenarnya aku kurang suka kentang goreng.
Dialogue: 0,0:14:38.82,0:14:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:14:39.90,0:14:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kentang goreng di sini favoritnya Rikka.
Dialogue: 0,0:14:43.49,0:14:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau tidak mau, aku tak akan maksa.
Dialogue: 0,0:14:52.87,0:14:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu lagi.
Dialogue: 0,0:14:54.50,0:14:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:15:00.13,0:15:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh, iya, tempo hari!
Dialogue: 0,0:15:02.21,0:15:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua ke sini, ya?
Dialogue: 0,0:15:04.38,0:15:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parfait yang dimakan Nene parah, ya!
Dialogue: 0,0:15:09.97,0:15:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,\NIko harus berbagi es krimnya denganku.
Dialogue: 0,0:15:17.02,0:15:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:15:18.36,0:15:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini ada hubungannya dengan aku\Nmemanggil nama depan mereka?
Dialogue: 0,0:15:21.73,0:15:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:15:25.32,0:15:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tak akan tanya lagi.
Dialogue: 0,0:15:27.74,0:15:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin tak mau dipanggil\Ndengan nama depanmu?
Dialogue: 0,0:15:29.95,0:15:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NKalau begitu, jadinya curang.
Dialogue: 0,0:15:33.83,0:15:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari kita akhiri ini!
Dialogue: 0,0:15:43.26,0:15:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujannya tak kunjung reda, ya.
Dialogue: 0,0:15:44.92,0:15:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Payungku baru saja rusak!
Dialogue: 0,0:15:48.80,0:15:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ini salahku kita kelamaan di kafe.
Dialogue: 0,0:15:52.72,0:15:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, kamu payungan denganku.
Dialogue: 0,0:16:04.48,0:16:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilaimu meningkat akhir-akhir ini.
Dialogue: 0,0:16:07.11,0:16:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang melihatmu bekerja keras.
Dialogue: 0,0:16:09.49,0:16:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena mengajarmu bagus.
Dialogue: 0,0:16:12.16,0:16:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:16:14.49,0:16:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau nilaimu terus naik,\Nperanku sudah selesai.
Dialogue: 0,0:16:18.54,0:16:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melebih-lebihkan, Pak Guru.
Dialogue: 0,0:16:26.05,0:16:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Yamabuki.
Dialogue: 0,0:16:28.01,0:16:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal memanggil nama depanku,\Naku bilang malu.
Dialogue: 0,0:16:32.18,0:16:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya aku merasa tidak enak.
Dialogue: 0,0:16:34.97,0:16:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kami berempat, cuma aku\Nyang bentuk mimpinya beda.
Dialogue: 0,0:16:40.56,0:16:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iko bekerja keras, ya?
Dialogue: 0,0:16:42.27,0:16:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu menyadarinya?
Dialogue: 0,0:16:44.61,0:16:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku cemas dia\Nsangat tidak ekspresif di siaran.
Dialogue: 0,0:16:49.49,0:16:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iko.
Dialogue: 0,0:16:51.11,0:16:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu paham apa yang ingin\Ndidengar audiensmu, kan?
Dialogue: 0,0:16:56.41,0:16:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, selesaikan siaranmu.
Dialogue: 0,0:17:18.02,0:17:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beam Lupa!
Dialogue: 0,0:17:21.14,0:17:23.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siaran hasil kolaborasinya memang suram,
Dialogue: 0,0:17:23.94,0:17:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia terus mencoba hal lain\Ndan akan ada progres lagi.
Dialogue: 0,0:17:29.15,0:17:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nene juga.
Dialogue: 0,0:17:30.65,0:17:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku progres dia belum kelihatan.
Dialogue: 0,0:17:33.37,0:17:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:17:35.33,0:17:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ikut audisi sendiri\Nsebelum aku menyarankannya.
Dialogue: 0,0:17:39.79,0:17:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah memanggilmu ke sini.
Dialogue: 0,0:17:42.79,0:17:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia latihan diam-diam?
Dialogue: 0,0:17:45.34,0:17:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang lembut dan menyenangkan,\Nseperti kucing yang mencari perhatian.
Dialogue: 0,0:17:49.55,0:17:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum kamu pergi...
Dialogue: 0,0:17:52.38,0:17:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasana familier memang terasa.
Dialogue: 0,0:17:54.05,0:17:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memberitahumu sesuatu.
Dialogue: 0,0:17:56.47,0:17:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:59.35,0:18:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktingmu jelek parah!
Dialogue: 0,0:18:01.85,0:18:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah sekali lagi kamu bilang\Nbahwa kamu mencintaiku?
Dialogue: 0,0:18:05.11,0:18:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirkan, pikirkan, pikirkan...
Dialogue: 0,0:18:11.36,0:18:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, aku mencintaimu.
Dialogue: 0,0:18:15.20,0:18:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat buruk dalam memerankan\Napa yang belum pernah dia alami.
Dialogue: 0,0:18:19.33,0:18:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, setelah banyak usaha...
Dialogue: 0,0:18:23.45,0:18:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin\Nmelihat wajahmu lagi. Pergi.
Dialogue: 0,0:18:27.34,0:18:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menampilkan pertunjukan\Nyang membuatku merinding.
Dialogue: 0,0:18:31.80,0:18:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ingin lihat juga.
Dialogue: 0,0:18:35.26,0:18:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka juga ada progres, ya.
Dialogue: 0,0:18:38.51,0:18:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dan kalian mewujudkannya.
Dialogue: 0,0:18:42.81,0:18:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang Rikka menyanyikan\Nlagunya sendiri lagi.
Dialogue: 0,0:18:48.77,0:18:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa kalian ada di sini?
Dialogue: 0,0:18:51.03,0:18:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana penonton lainnya?
Dialogue: 0,0:18:52.97,0:18:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:18:54.11,0:18:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Rikka!
Dialogue: 0,0:18:57.91,0:19:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu malah sok keren\Ndan tak mau curhat apa pun.
Dialogue: 0,0:19:01.29,0:19:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali luapkan sampai puas.
Dialogue: 0,0:19:03.50,0:19:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kipas-kipas ini kami buat mendadak.
Dialogue: 0,0:19:06.17,0:19:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, kami akan menyiapkan yang bagus.
Dialogue: 0,0:19:08.38,0:19:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan pun, kami akan selalu ada\Ndi kursi paling depan.
Dialogue: 0,0:19:12.96,0:19:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau merasa sulit, fokus saja pada kami.
Dialogue: 0,0:19:20.56,0:19:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kalian benar.
Dialogue: 0,0:19:26.65,0:19:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantikan konser jalanannya.
Dialogue: 0,0:19:37.41,0:19:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah selangkah lebih dekat\Ndengan mimpinya.
Dialogue: 0,0:19:42.45,0:19:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuat mereka makin dekat denganmu.
Dialogue: 0,0:19:54.01,0:19:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin, mendekati mimpi kami\Nberarti mendekat denganmu.
Dialogue: 0,0:20:00.76,0:20:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu menjadikanku di posisi terakhir.
Dialogue: 0,0:20:06.02,0:20:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya...
Dialogue: 0,0:20:12.40,0:20:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:17.57,0:20:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:20:21.12,0:20:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menikmati sesi belajar mingguan kami.
Dialogue: 0,0:20:24.12,0:20:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik nilaiku tidak naik
Dialogue: 0,0:20:28.08,0:20:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar aku bisa terus belajar denganmu.
Dialogue: 0,0:20:33.30,0:20:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat berpikir begitu.
Dialogue: 0,0:20:42.26,0:20:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang sekarang cukup dipanggil\Ndengan nama keluargaku.
Dialogue: 0,0:20:46.14,0:20:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, aku ingin menikmati\Nwaktu ini lebih lama lagi.
Dialogue: 0,0:20:54.02,0:20:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, suatu hari...
Dialogue: 0,0:20:59.99,0:21:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Yamabuki, sepertinya...
Dialogue: 0,0:21:05.45,0:21:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku merasa bisa mengejar\Nmimpiku dengan bangga.
Dialogue: 0,0:21:13.54,0:21:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya kalau aku...
Dialogue: 0,0:21:19.97,0:21:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku merasa bisa makin dekat\Ndengan mimpiku.
Dialogue: 0,0:21:33.15,0:21:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menurutmu aku bisa ada di posisi\Nyang sama dengan mereka bertiga,
Dialogue: 0,0:21:37.98,0:21:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau waktunya tiba...
Dialogue: 0,0:21:51.54,0:21:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu
Dialogue: 0,0:22:04.51,0:22:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa memanggilku dengan nama depanku?
