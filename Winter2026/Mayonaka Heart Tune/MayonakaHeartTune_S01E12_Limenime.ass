Dialogue: 0,0:02:52.96,0:02:57.96,tanda,,0000,0000,0000,,TUNE IN TO THE MIDNIGHT HEART
Dialogue: 0,0:03:08.14,0:03:08.97,tanda,,0000,0000,0000,,UZUKI SHINOBU
Dialogue: 0,0:03:09.98,0:03:11.10,tanda,,0000,0000,0000,,KIRINO IKO
Dialogue: 0,0:03:11.85,0:03:12.98,tanda,,0000,0000,0000,,HIMEKAWA NENE
Dialogue: 0,0:03:13.60,0:03:15.02,tanda,,0000,0000,0000,,INOHANA RIKKA
Dialogue: 0,0:03:15.02,0:03:17.40,tanda,,0000,0000,0000,,TUNE IN TO THE MIDNIGHT HEART
Dialogue: 0,0:03:50.26,0:03:51.34,tanda,,0000,0000,0000,,APOLLO?
Dialogue: 0,0:04:25.64,0:04:27.95,tanda,,0000,0000,0000,,TUNE IN TO THE MIDNIGHT HEART
Dialogue: 0,0:07:45.90,0:07:49.78,tanda,,0000,0000,0000,,NYANYIAN MALAM
Dialogue: 0,0:09:41.35,0:09:44.73,tanda,,0000,0000,0000,,KONSER JALANAN INOHANA RIKKA
Dialogue: 0,0:15:28.95,0:15:31.95,tanda,,0000,0000,0000,,DI BARISAN PALING DEPAN DENGAN RIKKA
Dialogue: 0,0:19:12.76,0:19:15.13,tanda,,0000,0000,0000,,KONSER JALANAN RIKKA INOHANA
Dialogue: 0,0:19:35.99,0:19:38.99,tanda,,0000,0000,0000,,SIMBOL PEMBERONTAKAN
Dialogue: 0,0:22:48.18,0:22:50.68,tanda,,0000,0000,0000,,PANDUAN PENYIARAN PEMULA
Dialogue: 0,0:22:55.44,0:22:57.44,tanda,,0000,0000,0000,,TES AKTING SUARA MOGI SHIERI!!
Dialogue: 0,0:00:00.31,0:00:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menjadi utuh kembali ♪
Dialogue: 0,0:00:02.86,0:00:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Merindukan bulan ♪
Dialogue: 0,0:00:04.98,0:00:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku mengulurkan tangan ♪
Dialogue: 0,0:00:07.57,0:00:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berjinjit, meregang agar makin dekat ♪
Dialogue: 0,0:00:12.16,0:00:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku melakukan perjalanan ke luar angkasa ♪
Dialogue: 0,0:00:15.08,0:00:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Percaya bahwa aku akan sampai\Ndi sana suatu hari nanti ♪
Dialogue: 0,0:00:17.54,0:00:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang berhenti untuk mendengarkan,\Ntertarik oleh suaraku.
Dialogue: 0,0:00:23.25,0:00:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menjadi penyanyi.
Dialogue: 0,0:00:28.93,0:00:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil menenangkan diri.
Dialogue: 0,0:00:31.22,0:00:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa berhasil.
Dialogue: 0,0:00:33.05,0:00:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tinggal mempertahankan performanya,
Dialogue: 0,0:00:35.97,0:00:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}konsernya akan sukses\Ndan CD-nya akan terjual.
Dialogue: 0,0:00:39.48,0:00:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tetap membawaku makin dekat\Nmenyentuh bulan ♪
Dialogue: 0,0:00:46.99,0:00:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lihat aku ♪
Dialogue: 0,0:00:51.57,0:00:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Inilah aku ♪
Dialogue: 0,0:00:52.99,0:00:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logo itu...
Dialogue: 0,0:00:54.87,0:00:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu lagu Ask for the Moon.
Dialogue: 0,0:01:11.05,0:01:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita pergi.
Dialogue: 0,0:01:12.97,0:01:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tunggu sebentar.
Dialogue: 0,0:01:19.81,0:01:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau beli CD-nya satu!
Dialogue: 0,0:01:22.81,0:01:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, aku juga mau beli satu.\NBoleh?
Dialogue: 0,0:01:25.48,0:01:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:01:27.61,0:01:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:01:33.28,0:01:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, banyak orang...
Dialogue: 0,0:01:36.41,0:01:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terasa tak nyata.
Dialogue: 0,0:01:38.41,0:01:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ingin berhenti bernyanyi demi banyak orang,\Nmereka malah datang mendengarkan.
Dialogue: 0,0:01:50.34,0:01:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, lagu ketigaku, Half and Half.
Dialogue: 0,0:01:59.10,0:02:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya aku tak yakin ini akan lancar,\Ntapi aku senang melakukan konser.
Dialogue: 0,0:02:09.03,0:02:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku benci drum.\NBisa jangan berisik?
Dialogue: 0,0:02:14.57,0:02:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan minta yang aneh-aneh.
Dialogue: 0,0:02:16.49,0:02:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.\NAnu, Halo.
Dialogue: 0,0:02:19.62,0:02:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami Celestial.
Dialogue: 0,0:02:21.66,0:02:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi satu tahun debut kami.
Dialogue: 0,0:02:24.08,0:02:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan konser dadakan\Ndi tempat kenangan ini.
Dialogue: 0,0:02:27.21,0:02:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya ini merepotkan.
Dialogue: 0,0:02:28.63,0:02:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, dari semua hari, mereka konser hari ini?
Dialogue: 0,0:02:31.84,0:02:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Itu Celes, kan?
Dialogue: 0,0:02:33.42,0:02:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar!
Dialogue: 0,0:02:35.13,0:02:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Hizu!
Dialogue: 0,0:02:36.34,0:02:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mau konser lagi di sini?
Dialogue: 0,0:02:38.01,0:02:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap, ayo ke sana!
Dialogue: 0,0:02:42.85,0:02:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:02:43.81,0:02:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti disengaja.
Dialogue: 0,0:02:46.10,0:02:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda.
Dialogue: 0,0:04:31.33,0:04:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu pertama kami...
Dialogue: 0,0:04:33.46,0:04:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, ada judulnya?
Dialogue: 0,0:04:36.26,0:04:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, kamu kan yang buat!
Dialogue: 0,0:04:38.42,0:04:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:04:39.88,0:04:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kami mulai.
Dialogue: 0,0:04:41.59,0:04:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan permen sekarang?
Dialogue: 0,0:04:43.43,0:04:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, terserah dia saja.
Dialogue: 0,0:04:45.77,0:04:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kami mulai lagu pertamanya.
Dialogue: 0,0:04:48.85,0:04:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu, wa...
Dialogue: 0,0:04:56.61,0:04:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini suara dari tiga orang?
Dialogue: 0,0:05:03.53,0:05:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jauh sekali, sangat jauh ♪
Dialogue: 0,0:05:05.83,0:05:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku berjalan dalam kegelapan\NTempat tak seorang pun mendengarku ♪
Dialogue: 0,0:05:12.71,0:05:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menekan, menekan ♪
Dialogue: 0,0:05:15.25,0:05:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku melakukan apa yang harus aku lakukan ♪
Dialogue: 0,0:05:17.42,0:05:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vokalnya sangat luar biasa!
Dialogue: 0,0:05:20.80,0:05:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Benang-benang kesendirian ini ♪
Dialogue: 0,0:05:27.47,0:05:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Suaraku, terkubur dan tersumbat ♪
Dialogue: 0,0:05:30.14,0:05:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Seret keluar dan menjerit ♪
Dialogue: 0,0:05:33.48,0:05:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kau hanya punya satu kesempatan ♪
Dialogue: 0,0:05:35.06,0:05:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Singkirkan keraguan sebelum ia menguasai ♪
Dialogue: 0,0:05:38.19,0:05:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kau hanya punya satu kesempatan ♪
Dialogue: 0,0:05:39.65,0:05:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ambil benang biru itu dan fokuslah ♪
Dialogue: 0,0:05:42.86,0:05:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ini hidupmu, apa yang akan kau lakukan? ♪
Dialogue: 0,0:05:48.62,0:05:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Biarkan jantungmu berdetak\Ndan bersinar selagi masih bisa ♪
Dialogue: 0,0:05:53.67,0:05:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aku sendawa.
Dialogue: 0,0:06:03.47,0:06:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:06:04.76,0:06:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lagu ketigaku, Half and Half.
Dialogue: 0,0:06:37.21,0:06:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hei, apa yang aku rasakan ini? ♪
Dialogue: 0,0:06:41.46,0:06:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka melakukan perlawanan.
Dialogue: 0,0:06:44.22,0:06:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya lebih bagus\Ndibandingkan lagu pertama.
Dialogue: 0,0:06:47.30,0:06:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan salahnya!
Dialogue: 0,0:06:49.35,0:06:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi situasi ini, bukan salah Rikka.
Dialogue: 0,0:06:53.85,0:06:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahku karena memilih tempat ini!
Dialogue: 0,0:06:59.07,0:07:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita tidak butuh kepastian atau fakta ♪
Dialogue: 0,0:07:03.57,0:07:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ayo bermain musik bersamaku.
Dialogue: 0,0:07:07.45,0:07:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, Aiko yang mengajakku.
Dialogue: 0,0:07:11.24,0:07:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa kamu mengajakku?
Dialogue: 0,0:07:14.04,0:07:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja karena suaramu.
Dialogue: 0,0:07:15.71,0:07:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung jatuh cinta.
Dialogue: 0,0:07:17.21,0:07:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin suaramu bisa menghasilkan uang.
Dialogue: 0,0:07:22.63,0:07:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang?
Dialogue: 0,0:07:24.22,0:07:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku
Dialogue: 0,0:07:26.84,0:07:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}suka pilih tiket paling depan\Ndari konser penyanyi favoritku.
Dialogue: 0,0:07:30.72,0:07:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:31.26,0:07:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya,
Dialogue: 0,0:07:32.10,0:07:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sini barisan paling depanmu, kan?
Dialogue: 0,0:07:36.06,0:07:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi orang paling dekat\Nyang bisa mendengar suaramu.
Dialogue: 0,0:07:40.44,0:07:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:07:42.11,0:07:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu setelah itu, kami menulis lagu\Nberjudul Nyanyian Malam
Dialogue: 0,0:07:45.90,0:07:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengirim demonya ke label rekaman.
Dialogue: 0,0:07:49.78,0:07:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada balasan!
Dialogue: 0,0:07:51.78,0:07:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang ingin ketemuan langsung!
Dialogue: 0,0:07:53.87,0:07:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:07:56.08,0:07:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, saat itu momen yang menyenangkan.
Dialogue: 0,0:08:00.92,0:08:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang menyanyikan bagian reff-nya?
Dialogue: 0,0:08:03.09,0:08:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami cuma butuh suara dia.
Dialogue: 0,0:08:04.71,0:08:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:05.13,0:08:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa begitu!
Dialogue: 0,0:08:06.42,0:08:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ini duo!
Dialogue: 0,0:08:07.34,0:08:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka.
Dialogue: 0,0:08:09.14,0:08:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:08:10.18,0:08:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan yang terbaik untuk bagianku juga.
Dialogue: 0,0:08:14.39,0:08:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku yakin banyak hal\Nyang ingin dia bicarakan.
Dialogue: 0,0:08:24.48,0:08:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia menyembunyikannya\Ndan mendukungku dengan senyum lebar.
Dialogue: 0,0:08:29.63,0:08:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku malah kabur karena satu kegagalan.
Dialogue: 0,0:08:36.45,0:08:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menutup dunia, mengumpulkan\Npopularitas palsu dengan lagu orang lain.
Dialogue: 0,0:08:40.96,0:08:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pura-pura lanjut bermain musik.
Dialogue: 0,0:08:43.59,0:08:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar kamu marah.
Dialogue: 0,0:08:47.84,0:08:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah memutuskan\Ntidak bernyanyi demi kerumunan orang.
Dialogue: 0,0:08:51.89,0:08:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini rasanya berat...
Dialogue: 0,0:08:54.26,0:08:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, kalau lihat ke bawah,\Nrasanya ingin nangis.
Dialogue: 0,0:08:58.10,0:08:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tak bisa mengangkat kepalaku.
Dialogue: 0,0:09:03.15,0:09:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Yamabuki, kamu sedang apa?
Dialogue: 0,0:09:05.32,0:09:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bilang, kan?
Dialogue: 0,0:09:06.98,0:09:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau merasa berat mengangkat kepalamu,\Ncukup lihat ke arahku!
Dialogue: 0,0:09:11.61,0:09:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku bawa ini.
Dialogue: 0,0:09:14.28,0:09:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat jelas dari matamu\Nkalau ingin menangis!
Dialogue: 0,0:09:19.79,0:09:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kan sudah bilang itu norak,\Nsebaiknya hentikan...
Dialogue: 0,0:09:22.58,0:09:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka, kamu kenapa?
Dialogue: 0,0:09:24.13,0:09:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin akan berakhir di sini?
Dialogue: 0,0:09:26.17,0:09:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu ingin bernyanyi\Ndemi orang yang ingin kamu capai?
Dialogue: 0,0:09:28.84,0:09:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin akan membiarkan\Nmimpimu berakhir di sini?
Dialogue: 0,0:09:36.97,0:09:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memanggilnya kemari?
Dialogue: 0,0:09:38.68,0:09:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku...
Dialogue: 0,0:09:41.35,0:09:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat brosur ini di depan stasiun kereta.
Dialogue: 0,0:09:44.73,0:09:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka dia akan datang ke sini.
Dialogue: 0,0:09:47.27,0:09:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membagikan brosur ternyata keputusan tepat.
Dialogue: 0,0:09:57.20,0:09:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aiko, aku...
Dialogue: 0,0:10:00.16,0:10:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:10:01.66,0:10:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu.
Dialogue: 0,0:10:03.46,0:10:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sini ingin dengar lagumu.
Dialogue: 0,0:10:06.21,0:10:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari dulu kamu jarang bicara\Nkarena memang tidak mahir.
Dialogue: 0,0:10:10.30,0:10:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu akan lebih mudah paham\Nkalau lewat lagu.
Dialogue: 0,0:10:15.01,0:10:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:15.97,0:10:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:20.72,0:10:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lagu terakhirku hari ini.
Dialogue: 0,0:10:22.81,0:10:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lagu yang kubuat untuk sahabatku.
Dialogue: 0,0:10:28.52,0:10:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trails.
Dialogue: 0,0:10:49.00,0:10:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita berangkat mengejar jejak pelangi ♪
Dialogue: 0,0:10:53.22,0:10:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Senyuman kita berwarna kelereng kaca ♪
Dialogue: 0,0:10:59.89,0:11:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Senyumanmu membuatku bersemangat ♪
Dialogue: 0,0:11:04.81,0:11:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita berangkat dengan ransel usang kita ♪
Dialogue: 0,0:11:08.94,0:11:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Penuh dengan semua yang kita pikirkan ♪
Dialogue: 0,0:11:17.24,0:11:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Langit adalah batasnya, tidak terlalu jauh ♪
Dialogue: 0,0:11:21.66,0:11:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jangan berhenti\NSampai kita mencapai ujung pelangi ♪
Dialogue: 0,0:11:25.50,0:11:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mari kita buat pengalaman baru bersama ♪
Dialogue: 0,0:11:29.92,0:11:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai kita melambaikan tangan\Ndi persimpangan jalan ♪
Dialogue: 0,0:11:38.09,0:11:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Di bawah pelangi, tempat kita\Nmengucapkan selamat tinggal ♪
Dialogue: 0,0:12:04.54,0:12:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:12:08.37,0:12:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih kurang.
Dialogue: 0,0:12:09.12,0:12:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:09.79,0:12:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada penampilan tambahan.
Dialogue: 0,0:12:11.17,0:12:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun kamu minta,\Ndi CD-ku cuma ada empat lagu.
Dialogue: 0,0:12:21.18,0:12:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tambah repot, kita sudahi saja?
Dialogue: 0,0:12:24.64,0:12:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku tidak apa-apa.
Dialogue: 0,0:12:26.60,0:12:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:12:28.06,0:12:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pendengar yang takut ketinggalan!
Dialogue: 0,0:12:30.23,0:12:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka mau nyanyi Nyanyian Malam,\Njadi dengarkan!
Dialogue: 0,0:12:33.27,0:12:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:34.19,0:12:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:12:35.36,0:12:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bikin kesal, tidak apa-apa, kan?
Dialogue: 0,0:12:37.65,0:12:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa pilih Nyanyian Malam?
Dialogue: 0,0:12:39.20,0:12:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kamu lupa?
Dialogue: 0,0:12:41.24,0:12:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak lupa, tapi...
Dialogue: 0,0:12:43.99,0:12:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Mereka ngajak ribut?
Dialogue: 0,0:12:45.95,0:12:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram!
Dialogue: 0,0:12:48.25,0:12:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mau tarung band dengan kita?
Dialogue: 0,0:12:49.83,0:12:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalian takut menghadapi tantangan kami?
Dialogue: 0,0:12:54.34,0:12:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ayo!
Dialogue: 0,0:12:55.42,0:12:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aiko, kamu sudah berlebihan.
Dialogue: 0,0:12:57.97,0:13:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak punya uang!
Dialogue: 0,0:13:00.18,0:13:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka meremehkan kita!
Dialogue: 0,0:13:01.30,0:13:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hizumi, ayo kita lawan!
Dialogue: 0,0:13:02.34,0:13:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya duel band!
Dialogue: 0,0:13:04.35,0:13:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yamabuki, hentikan Aiko!\N- Kalian semua siap?
Dialogue: 0,0:13:07.02,0:13:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tak punya nyali, ya, Celestial?
Dialogue: 0,0:13:09.81,0:13:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamabuki?
Dialogue: 0,0:13:10.73,0:13:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan untuk membuat dirimu dikenal!
Dialogue: 0,0:13:13.44,0:13:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:14.69,0:13:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, semua penonton mendukung mereka.
Dialogue: 0,0:13:17.28,0:13:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah!
Dialogue: 0,0:13:18.90,0:13:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan!
Dialogue: 0,0:13:20.03,0:13:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aransemen spesial Nyanyian Malam!
Dialogue: 0,0:13:25.91,0:13:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aransemen?
Dialogue: 0,0:13:26.91,0:13:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, bersiap.
Dialogue: 0,0:13:28.70,0:13:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, dari dulu kamu selalu maksa.
Dialogue: 0,0:13:33.58,0:13:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Aiko.
Dialogue: 0,0:13:35.21,0:13:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, soal yang dulu.
Dialogue: 0,0:13:38.92,0:13:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga minta maaf, soal yang dulu.
Dialogue: 0,0:13:43.26,0:13:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa nyanyianku jadi lebih baik sejak saat itu?
Dialogue: 0,0:13:46.68,0:13:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:13:47.72,0:13:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar jail.
Dialogue: 0,0:13:48.68,0:13:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma satu lagu, susah menilai.
Dialogue: 0,0:13:51.81,0:13:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini aku akan dengarkan baik-baik.
Dialogue: 0,0:14:16.17,0:14:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Saat matahari terbenam di tepi air ♪
Dialogue: 0,0:14:20.30,0:14:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku menghela napas panjang ♪
Dialogue: 0,0:14:23.68,0:14:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Airnya seakan menanggapi\Ndengan ombak putih ♪
Dialogue: 0,0:14:30.14,0:14:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Setelah mengucapkan selamat tinggal ♪
Dialogue: 0,0:14:33.73,0:14:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita menyaksikan angin\Nmembawa mereka pergi ♪
Dialogue: 0,0:14:37.27,0:14:44.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Setelah itu, kita asal bersumpah kelingking ♪
Dialogue: 0,0:14:44.99,0:14:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ya ♪
Dialogue: 0,0:14:46.07,0:14:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Air tenang menyembunyikan bulan ♪
Dialogue: 0,0:14:49.58,0:14:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Karena air tenang menyembunyikan bulan ♪
Dialogue: 0,0:14:53.37,0:15:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Rasanya seolah-olah kita ada\Ndi dunia untuk kita berdua ♪
Dialogue: 0,0:15:00.09,0:15:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Laut menyatu dengan langit ♪
Dialogue: 0,0:15:03.55,0:15:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Keheningan tercipta saat mereka berkumpul ♪
Dialogue: 0,0:15:07.39,0:15:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski tahu hanya ada aku dan kau ♪
Dialogue: 0,0:15:12.68,0:15:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku berbisik ke telingamu ♪
Dialogue: 0,0:15:17.56,0:15:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ah... Ah... ♪
Dialogue: 0,0:15:21.23,0:15:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dalam nyanyian malam ♪
Dialogue: 0,0:15:33.75,0:15:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah!
Dialogue: 0,0:15:34.41,0:15:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, kerja bagus!
Dialogue: 0,0:15:37.37,0:15:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kerja bagus-ko!\N- Kerja bagus!
Dialogue: 0,0:15:39.33,0:15:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsermu sangat bagus, Rikka.
Dialogue: 0,0:15:41.38,0:15:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami cuma kebetulan lewat, cuma kebetulan.
Dialogue: 0,0:15:45.34,0:15:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kebetulan!\NTernyata keajaiban itu ada.
Dialogue: 0,0:15:48.30,0:15:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:15:49.93,0:15:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong kalian kelihatan.
Dialogue: 0,0:15:51.39,0:15:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}CD-mu juga terjual sekitar 20 keping, kan?
Dialogue: 0,0:15:54.39,0:15:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sukses besar!
Dialogue: 0,0:15:55.73,0:15:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Targetnya 50.
Dialogue: 0,0:15:58.35,0:16:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, untuk tahap awal, itu cukup bagus.
Dialogue: 0,0:16:00.86,0:16:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:03.07,0:16:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya Aiko juga ikut merayakan.
Dialogue: 0,0:16:06.20,0:16:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah ajak dia berkali-kali!
Dialogue: 0,0:16:08.66,0:16:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius tidak bisa!\NAku malu!
Dialogue: 0,0:16:11.12,0:16:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak biasa ketemu orang baru!
Dialogue: 0,0:16:13.54,0:16:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelakuannya begitu tapi dia pemalu?
Dialogue: 0,0:16:15.83,0:16:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, nanti kami akan merayakannya berdua.
Dialogue: 0,0:16:18.42,0:16:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalian bisa baikan.
Dialogue: 0,0:16:21.54,0:16:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:25.84,0:16:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, gawat!
Dialogue: 0,0:16:26.97,0:16:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dompetku ketinggalan di taman!
Dialogue: 0,0:16:29.09,0:16:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:16:30.26,0:16:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ambil ke sana!
Dialogue: 0,0:16:32.14,0:16:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada.
Dialogue: 0,0:16:33.35,0:16:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius masih ada?
Dialogue: 0,0:16:34.77,0:16:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kami temani?
Dialogue: 0,0:16:36.89,0:16:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak perlu.
Dialogue: 0,0:16:38.52,0:16:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana, Pembantu, pergi!
Dialogue: 0,0:16:40.19,0:16:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat.
Dialogue: 0,0:16:41.23,0:16:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Layani dia sepenuh hati!
Dialogue: 0,0:16:45.15,0:16:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai ketemu besok di sekolah, ya!
Dialogue: 0,0:16:47.49,0:16:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan macam-macam, Bukki.
Dialogue: 0,0:16:50.16,0:16:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka, kerja bagus!
Dialogue: 0,0:16:52.66,0:16:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Macam-macam?\NApa maksudnya?
Dialogue: 0,0:16:57.66,0:17:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, di gerbong ini cuma kita berdua.
Dialogue: 0,0:17:00.04,0:17:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kebetulan, kakiku sudah lelah.
Dialogue: 0,0:17:04.46,0:17:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:17:05.17,0:17:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matahari terbenam di laut itu indah.
Dialogue: 0,0:17:09.33,0:17:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tidak duduk?
Dialogue: 0,0:17:11.18,0:17:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi kesehatan kakiku,\Naku berusaha untuk tidak duduk.
Dialogue: 0,0:17:17.75,0:17:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini kesempatanmu\Nuntuk duduk di sampingku.
Dialogue: 0,0:17:20.94,0:17:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu terlalu sering\Nmelewatkan peluang, ya?
Dialogue: 0,0:17:23.52,0:17:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harap ada yang menemukan\Ndompetmu dan melaporkannya.
Dialogue: 0,0:17:26.48,0:17:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, kita harus mulai cari dari mana?
Dialogue: 0,0:17:28.90,0:17:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lebih memikirkan dompetku\Ndaripada diriku.
Dialogue: 0,0:17:33.91,0:17:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu menegangkan tapi seru, ya.
Dialogue: 0,0:17:36.70,0:17:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadaku masih berdebar.
Dialogue: 0,0:17:38.83,0:17:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu konser yang bagus.
Dialogue: 0,0:17:40.71,0:17:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berjuang sampai akhir.
Dialogue: 0,0:17:42.67,0:17:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi target CD terjual 50 mustahil.
Dialogue: 0,0:17:46.67,0:17:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku tetap puas.
Dialogue: 0,0:17:49.51,0:17:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas.
Dialogue: 0,0:17:51.97,0:17:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berhasil menulis beberapa lagu bagus.
Dialogue: 0,0:17:54.39,0:17:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti bernyanyi demi bisa populer.
Dialogue: 0,0:17:56.56,0:18:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka bernyanyi demi orang lain\Nyang ingin kucapai bisa seseru ini.
Dialogue: 0,0:18:02.85,0:18:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa caraku ini tidak salah.
Dialogue: 0,0:18:07.98,0:18:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:11.78,0:18:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh.
Dialogue: 0,0:18:14.03,0:18:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caraku tidak salah, kan?
Dialogue: 0,0:18:16.62,0:18:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak salah!
Dialogue: 0,0:18:18.33,0:18:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengutamakan kesenanganmu itu penting.
Dialogue: 0,0:18:21.58,0:18:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menikmatinya.
Dialogue: 0,0:18:23.04,0:18:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai pertengahan.
Dialogue: 0,0:18:25.13,0:18:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, saat penonton yang tertarik\Nmelihat konserku pergi,
Dialogue: 0,0:18:29.67,0:18:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku kesal, sedih, dan merasa sangat menderita.
Dialogue: 0,0:18:34.43,0:18:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang bilang merasa cukup\Nbisa sampai ke orang yang ingin kucapai,
Dialogue: 0,0:18:38.72,0:18:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ditinggalkan seperti itu\Ntetap terasa berat.
Dialogue: 0,0:18:41.93,0:18:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan salahmu!
Dialogue: 0,0:18:43.85,0:18:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan saja Celestial konser di dekatmu!
Dialogue: 0,0:18:46.73,0:18:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka lebih kuat dan aku lebih lemah.
Dialogue: 0,0:18:50.07,0:18:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persaingan penonton, persaingan popularitas.
Dialogue: 0,0:18:53.40,0:18:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu arti hidup sebagai profesional, kan?
Dialogue: 0,0:18:59.08,0:19:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir kamu bisa melakukannya.
Dialogue: 0,0:19:02.33,0:19:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku berharap terlalu banyak.
Dialogue: 0,0:19:06.21,0:19:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:19:07.75,0:19:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kerja bagus.
Dialogue: 0,0:19:09.38,0:19:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi aku ke kantor.
Dialogue: 0,0:19:11.21,0:19:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, semuanya lancar.
Dialogue: 0,0:19:12.76,0:19:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benci kelinci?
Dialogue: 0,0:19:15.13,0:19:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celes sukses melakukan konser dadakannya.
Dialogue: 0,0:19:17.76,0:19:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bahkan sampai viral di medsos.
Dialogue: 0,0:19:20.26,0:19:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, ada murid SMA\Nyang tampil di dekatnya.
Dialogue: 0,0:19:24.43,0:19:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat menarik.
Dialogue: 0,0:19:26.19,0:19:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tanda damai, bukan kelinci.
Dialogue: 0,0:19:28.73,0:19:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maknanya?
Dialogue: 0,0:19:30.40,0:19:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertarik ingin menghubunginya.
Dialogue: 0,0:19:35.07,0:19:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanda ini...
Dialogue: 0,0:19:40.08,0:19:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap Rikka berhasil menemukan dompetnya.
Dialogue: 0,0:19:42.66,0:19:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Pembantu pasti akan berbuat sesuatu.
Dialogue: 0,0:19:44.70,0:19:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben kamu percaya padanya.
Dialogue: 0,0:19:46.25,0:19:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Bukan itu maksudku.
Dialogue: 0,0:19:48.58,0:19:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, dia memang membantu.
Dialogue: 0,0:19:51.59,0:19:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin terlalu mengandalkan dia.
Dialogue: 0,0:19:54.63,0:19:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah!
Dialogue: 0,0:19:55.76,0:19:57.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kabur!
Dialogue: 0,0:19:58.97,0:20:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iko tegar, ya.
Dialogue: 0,0:20:00.76,0:20:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:20:02.06,0:20:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga ada urusan.
Dialogue: 0,0:20:04.18,0:20:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:20:05.56,0:20:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah.
Dialogue: 0,0:20:06.28,0:20:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:20:16.40,0:20:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin merasa caraku salah.
Dialogue: 0,0:20:20.99,0:20:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:22.24,0:20:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian diriku berpikir aku cuma\Nlari cari alasan dari persaingan ini.
Dialogue: 0,0:20:28.67,0:20:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka...
Dialogue: 0,0:20:29.54,0:20:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa diriku yang seperti ini\Nbisa terus lanjut bermusik?
Dialogue: 0,0:20:38.05,0:20:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh.
Dialogue: 0,0:20:43.22,0:20:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu menangis?
Dialogue: 0,0:20:46.02,0:20:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ini salahku.
Dialogue: 0,0:20:48.31,0:20:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:49.48,0:20:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku bisa memprediksi\NCelestial muncul di sana.
Dialogue: 0,0:20:53.06,0:20:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau saja aku cari tahu lebih banyak...
Dialogue: 0,0:20:56.23,0:20:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak salah apa pun!
Dialogue: 0,0:20:58.28,0:21:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu dan nyanyianmu, semuanya bagus!
Dialogue: 0,0:21:01.57,0:21:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua salahku!
Dialogue: 0,0:21:03.20,0:21:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:21:04.66,0:21:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konser kali ini, aku ingin\Nini menjadi kenangan indahmu.
Dialogue: 0,0:21:10.08,0:21:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu merasa bertanggung jawab!
Dialogue: 0,0:21:12.00,0:21:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang bisa memprediksi itu terjadi.
Dialogue: 0,0:21:14.54,0:21:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhentian selanjutnya, Kota Baru Makuhari.
Dialogue: 0,0:21:16.71,0:21:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:21:17.63,0:21:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:21:18.72,0:21:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah menangisku tidak boleh sampai terlihat!
Dialogue: 0,0:21:22.26,0:21:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kamu sangat terkenal?
Dialogue: 0,0:21:24.22,0:21:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang tahu, kan?\NSiapa pun bisa saja melihat kita!
Dialogue: 0,0:21:27.10,0:21:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa malu seperti tadi itu sulit dihilangkan!
Dialogue: 0,0:21:29.77,0:21:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, apa boleh buat.
Dialogue: 0,0:21:36.40,0:21:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesra banget, ya.
Dialogue: 0,0:21:37.90,0:21:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa puber memang enak, ya.
Dialogue: 0,0:22:02.13,0:22:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta ini akan berhenti\Ndi semua stasiun menuju Soga.
Dialogue: 0,0:22:05.72,0:22:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua usahamu, sudah lebih dari cukup.
Dialogue: 0,0:22:10.23,0:22:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal kemampuanku.
Dialogue: 0,0:22:13.10,0:22:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, aku payah.
Dialogue: 0,0:22:15.02,0:22:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak payah.
Dialogue: 0,0:22:16.40,0:22:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku payah, kalau dibandingkan dengan Celes.
Dialogue: 0,0:22:18.78,0:22:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi nyanyianmu lebih menyentuh hati.
Dialogue: 0,0:22:21.86,0:22:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka nyanyianmu.
Dialogue: 0,0:22:26.53,0:22:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai produser,\Napa itu pendapat yang tepat?
Dialogue: 0,0:22:30.45,0:22:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menaruh hati di dalamnya\Nakan tersampaikan,
Dialogue: 0,0:22:32.94,0:22:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu cuma membual.
Dialogue: 0,0:22:34.96,0:22:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:22:36.17,0:22:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:23:37.56,0:23:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat indah.
